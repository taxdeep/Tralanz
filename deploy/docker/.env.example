# PostgreSQL
CITUS_DB_NAME=citus_accounting
CITUS_DB_USER=postgres
CITUS_DB_PASSWORD=change-me
CITUS_DB_PORT=5432
CITUS_ENABLE_DEMO_SEED=true

# Published ports
CITUS_WEB_PORT=8080
CITUS_ACCOUNTING_API_PORT=5088
CITUS_SYSADMIN_API_PORT=5089
CITUS_SYSADMIN_WEB_PORT=8090

# Platform identity / MFA
CITUS_TOTP_PROTECTION_KEY=replace-with-a-long-random-secret

# Notifications
CITUS_NOTIFICATION_PROVIDER=disabled
CITUS_NOTIFICATION_FROM_EMAIL=
CITUS_NOTIFICATION_FROM_NAME=Citus
CITUS_SMTP_HOST=
CITUS_SMTP_PORT=587
CITUS_SMTP_USE_SSL=true
CITUS_SMTP_USERNAME=
CITUS_SMTP_PASSWORD=

# Optional bootstrap sysadmin for non-development Docker runs.
# Leave disabled if you want to create the first sysadmin account from the setup screen.
CITUS_SYSADMIN_BOOTSTRAP_ENABLED=false
CITUS_SYSADMIN_BOOTSTRAP_ALLOW_IN_NON_DEVELOPMENT=false
CITUS_SYSADMIN_BOOTSTRAP_EMAIL=sysadmin@citus.local
CITUS_SYSADMIN_BOOTSTRAP_DISPLAY_NAME=Platform Administrator
CITUS_SYSADMIN_BOOTSTRAP_PASSWORD=change-me-now
