@namespace Citus.Modules.UnitySearch.Blazor
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@inject UnitySearchPickerService PickerService

<div class="unity-picker @(Disabled ? "unity-picker--disabled" : null)">
    <div class="unity-picker__control">
        <i class="ti ti-search unity-picker__icon" aria-hidden="true"></i>
        @* type="text" instead of type="search": same Chromium quirk that
           hid the JE Debit/Credit cells under -webkit-text-fill-color was
           biting type="search" too. Plain text inputs paint via our token
           colour reliably; the picker has its own X clear button below so
           losing type="search"'s native clear is a no-op. *@
        <input class="unity-picker__input"
               type="text"
               autocomplete="off"
               value="@_searchText"
               placeholder="@Placeholder"
               disabled="@Disabled"
               @ref="_inputRef"
               @oninput="HandleInputAsync"
               @onfocus="HandleFocus"
               @onblur="HandleBlurAsync"
               @onkeydown="HandleKeyDownAsync" />

        @if (AllowClear && !Disabled && (!string.IsNullOrWhiteSpace(_searchText) || SelectedId.HasValue))
        {
            <button type="button"
                    class="unity-picker__clear"
                    @onmousedown:preventDefault
                    @onclick="ClearAsync"
                    aria-label="Clear selection">
                <i class="ti ti-x" aria-hidden="true"></i>
            </button>
        }

        @if (ShowDropdownButton && !Disabled)
        {
            <button type="button"
                    class="unity-picker__dropdown"
                    @onmousedown:preventDefault
                    @onclick="ToggleDropdownAsync"
                    aria-label="Show options">
                <i class="ti ti-chevron-down" aria-hidden="true"></i>
            </button>
        }
    </div>

    @if (_showResults && _options.Count > 0)
    {
        <div class="unity-picker__panel @(OneLineLayout ? "unity-picker__panel--inline" : null)" role="listbox">
            @{ var optionIndex = 0; }
            @foreach (var option in _options)
            {
                var i = optionIndex++;
                if (OneLineLayout)
                {
                    @* Compact one-line layout: code · name · kind, all on one row,
                       name truncates with ellipsis if it overflows. The
                       secondary slot is split on " · " — projection writers
                       producing one-line items must format secondary as
                       "<name> · <kind>". *@
                    var secondaryParts = (option.SecondaryText ?? string.Empty).Split(" · ", 2);
                    var inlineName = secondaryParts.Length > 0 ? secondaryParts[0] : string.Empty;
                    var inlineKind = secondaryParts.Length > 1 ? secondaryParts[1] : string.Empty;
                    <button type="button"
                            class="unity-picker__option unity-picker__option--inline @(i == _highlightedIndex ? "is-active" : null)"
                            @onmousedown:preventDefault
                            @onclick="@(() => SelectAsync(option))"
                            @onmouseover="@(() => _highlightedIndex = i)">
                        <span class="unity-picker__option-code">@RenderHighlighted(option.PrimaryText)</span>
                        <span class="unity-picker__option-name">@RenderHighlighted(inlineName)</span>
                        @if (!string.IsNullOrWhiteSpace(inlineKind))
                        {
                            <span class="unity-picker__option-kind">@inlineKind</span>
                        }
                    </button>
                }
                else
                {
                    <button type="button"
                            class="unity-picker__option @(i == _highlightedIndex ? "is-active" : null)"
                            @onmousedown:preventDefault
                            @onclick="@(() => SelectAsync(option))"
                            @onmouseover="@(() => _highlightedIndex = i)">
                        <span class="unity-picker__option-copy">
                            <span class="unity-picker__option-primary">@RenderHighlighted(option.PrimaryText)</span>
                            @if (!string.IsNullOrWhiteSpace(option.SecondaryText))
                            {
                                <span class="unity-picker__option-secondary">@RenderHighlighted(option.SecondaryText)</span>
                            }
                        </span>
                        <span class="unity-picker__option-kind">@FormatEntityType(option.EntityType)</span>
                    </button>
                }
            }

            @if (CanCreateFromSearch)
            {
                <button type="button"
                        class="unity-picker__create"
                        @onmousedown:preventDefault
                        @onclick="HandleCreateRequestedAsync">
                    <i class="ti ti-plus unity-picker__create-icon" aria-hidden="true"></i>
                    <span>Create "@_searchText.Trim()" as a new @CreateEntityLabel</span>
                </button>
            }
        </div>
    }
    else if (_showResults && _options.Count == 0)
    {
        <div class="unity-picker__panel" role="listbox">
            <div class="unity-picker__empty">No results found</div>
            @if (CanCreateFromSearch)
            {
                <button type="button"
                        class="unity-picker__create"
                        @onmousedown:preventDefault
                        @onclick="HandleCreateRequestedAsync">
                    <i class="ti ti-plus unity-picker__create-icon" aria-hidden="true"></i>
                    <span>Create "@_searchText.Trim()" as a new @CreateEntityLabel</span>
                </button>
            }
        </div>
    }
</div>

@code
{
    [Parameter, EditorRequired]
    public CompanyId CompanyId { get; set; }

    [Parameter]
    public UserId? UserId { get; set; }

    [Parameter, EditorRequired]
    public string Context { get; set; } = string.Empty;

    [Parameter]
    public Guid? SelectedId { get; set; }

    [Parameter]
    public string? SelectedDisplayText { get; set; }

    [Parameter]
    public string Placeholder { get; set; } = "Search";

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool AllowClear { get; set; } = true;

    [Parameter]
    public int Take { get; set; } = 8;

    [Parameter]
    public bool OpenOnFocus { get; set; } = true;

    [Parameter]
    public bool ShowDropdownButton { get; set; } = true;

    /// <summary>
    /// When true, options render as a single horizontal row
    /// (code · name · kind) instead of the default two-line stack with a
    /// right-aligned entity-type tag. The kind column reads the second
    /// half of <see cref="UnitySearchPickerOption.SecondaryText"/> after
    /// splitting on " · " — projections feeding inline pickers must
    /// format secondary as "<name> · <kind>".
    /// </summary>
    [Parameter]
    public bool OneLineLayout { get; set; }

    [Parameter]
    public string? CreateEntityLabel { get; set; }

    /// <summary>
    /// Stable entity-type identifier (e.g. <c>vendor</c>, <c>account</c>,
    /// <c>product_service</c>) for the unityAI learning loop. When set, the
    /// picker emits <c>no_match</c> and <c>create_new</c> usage events; when
    /// unset, only <c>select</c> events fire (entity type is taken from the
    /// selected option in that case).
    /// </summary>
    [Parameter]
    public string? EntityType { get; set; }

    /// <summary>Optional anchor-context for pair-stat learning (e.g. the vendor picker context for a category picker).</summary>
    [Parameter]
    public string? AnchorContext { get; set; }

    /// <summary>Optional anchor-entity type for pair-stat learning.</summary>
    [Parameter]
    public string? AnchorEntityType { get; set; }

    /// <summary>Optional anchor-entity id for pair-stat learning.</summary>
    [Parameter]
    public Guid? AnchorEntityId { get; set; }

    /// <summary>Optional source-route hint surfaced in usage events (e.g. /expenses/new).</summary>
    [Parameter]
    public string? SourceRoute { get; set; }

    [Parameter]
    public EventCallback<UnitySearchPickerOption> OnOptionSelected { get; set; }

    [Parameter]
    public EventCallback OnCleared { get; set; }

    [Parameter]
    public EventCallback<string> OnCreateRequested { get; set; }

    private string _searchText = string.Empty;
    private bool _showResults;
    private bool _isFocused;
    private IReadOnlyList<UnitySearchPickerOption> _options = Array.Empty<UnitySearchPickerOption>();
    private ElementReference _inputRef;
    private int _highlightedIndex = -1;
    private CancellationTokenSource? _searchCts;
    private CancellationTokenSource? _blurCts;
    private bool CanCreateFromSearch =>
        !Disabled &&
        OnCreateRequested.HasDelegate &&
        !string.IsNullOrWhiteSpace(CreateEntityLabel) &&
        !string.IsNullOrWhiteSpace(_searchText.Trim());

    protected override void OnParametersSet()
    {
        if (!_isFocused)
        {
            _searchText = SelectedDisplayText ?? string.Empty;
        }
    }

    private async Task HandleFocus(FocusEventArgs _)
    {
        _isFocused = true;
        _blurCts?.Cancel();
        _blurCts?.Dispose();
        _blurCts = null;

        if (OpenOnFocus)
        {
            await SearchAsync(_searchText.Trim(), allowEmptyQuery: true);
        }
    }

    private async Task HandleInputAsync(ChangeEventArgs args)
    {
        _searchText = args.Value?.ToString() ?? string.Empty;
        _highlightedIndex = -1;
        await SearchAsync(_searchText.Trim(), allowEmptyQuery: false);
    }

    private async Task SearchAsync(string query, bool allowEmptyQuery)
    {
        // Cancel + dispose the prior CTS, then null the field. Without
        // the null-out the empty-query early-return below leaves
        // _searchCts pointing at an already-disposed instance, and the
        // *next* call's Cancel() throws ObjectDisposedException —
        // observed as "type 100 → clear → type 100 → no dropdown".
        // Cancel-after-Dispose itself throws, so wrap it.
        try { _searchCts?.Cancel(); }
        catch (ObjectDisposedException) { }
        _searchCts?.Dispose();
        _searchCts = null;

        _showResults = false;
        _options = Array.Empty<UnitySearchPickerOption>();

        if (Disabled || string.IsNullOrEmpty(CompanyId.Value) || (!allowEmptyQuery && query.Length < 1))
        {
            _showResults = CanCreateFromSearch;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var cts = new CancellationTokenSource();
        _searchCts = cts;

        try
        {
            if (!allowEmptyQuery)
            {
                await Task.Delay(180, cts.Token);
            }

            var options = await PickerService.SearchAsync(
                CompanyId,
                UserId,
                Context,
                query,
                Take,
                cts.Token);

            if (!cts.IsCancellationRequested)
            {
                _options = options;
                _showResults = true;
                _highlightedIndex = options.Count > 0 ? 0 : -1;
                _lastSearchedQuery = query;
                _lastSearchResultCount = options.Count;

                if (options.Count == 0 && !string.IsNullOrWhiteSpace(query) && !string.IsNullOrWhiteSpace(EntityType))
                {
                    _ = PickerService.RecordUsageAsync(BuildUsageEvent(
                        eventType: "no_match",
                        entityType: EntityType!,
                        query: query,
                        resultCount: 0));
                }

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task ToggleDropdownAsync()
    {
        if (Disabled)
        {
            return;
        }

        if (_showResults)
        {
            _showResults = false;
            _options = Array.Empty<UnitySearchPickerOption>();
            await InvokeAsync(StateHasChanged);
            return;
        }

        await _inputRef.FocusAsync();
        await SearchAsync(_searchText.Trim(), allowEmptyQuery: true);
    }

    private async Task HandleBlurAsync(FocusEventArgs _)
    {
        _isFocused = false;
        _blurCts?.Cancel();
        _blurCts?.Dispose();

        var cts = new CancellationTokenSource();
        _blurCts = cts;

        try
        {
            await Task.Delay(120, cts.Token);
            if (!cts.IsCancellationRequested)
            {
                _showResults = false;
                _options = Array.Empty<UnitySearchPickerOption>();
                _highlightedIndex = -1;
                _searchText = SelectedDisplayText ?? _searchText;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task SelectAsync(UnitySearchPickerOption option)
    {
        // Capture rank position BEFORE we reset _options.
        var rankPosition = -1;
        for (var i = 0; i < _options.Count; i++)
        {
            if (_options[i].SourceId == option.SourceId)
            {
                rankPosition = i;
                break;
            }
        }
        var resultCount = _options.Count;

        _showResults = false;
        _options = Array.Empty<UnitySearchPickerOption>();
        _highlightedIndex = -1;
        _searchText = option.DisplayText;

        // Fire-and-forget the unityAI usage event. Tracking failures must not
        // surface to the user — UnitySearchPickerService.RecordUsageAsync
        // swallows everything and logs at warn level.
        _ = PickerService.RecordUsageAsync(BuildUsageEvent(
            eventType: "select",
            entityType: option.EntityType,
            query: _lastSearchedQuery ?? string.Empty,
            resultCount: resultCount,
            selectedEntityId: option.SourceId,
            rankPosition: rankPosition >= 0 ? rankPosition : null));

        await OnOptionSelected.InvokeAsync(option);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ClearAsync()
    {
        _showResults = false;
        _options = Array.Empty<UnitySearchPickerOption>();
        _highlightedIndex = -1;
        _searchText = string.Empty;
        await OnCleared.InvokeAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleCreateRequestedAsync()
    {
        var candidate = _searchText.Trim();
        if (string.IsNullOrWhiteSpace(candidate) || !OnCreateRequested.HasDelegate)
        {
            return;
        }

        _showResults = false;
        _options = Array.Empty<UnitySearchPickerOption>();
        _highlightedIndex = -1;

        if (!string.IsNullOrWhiteSpace(EntityType))
        {
            _ = PickerService.RecordUsageAsync(BuildUsageEvent(
                eventType: "create_new",
                entityType: EntityType!,
                query: candidate,
                resultCount: _lastSearchResultCount));
        }

        await OnCreateRequested.InvokeAsync(candidate);
        await InvokeAsync(StateHasChanged);
    }

    private string? _lastSearchedQuery;
    private int? _lastSearchResultCount;

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            _showResults = false;
            _options = Array.Empty<UnitySearchPickerOption>();
            _highlightedIndex = -1;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (!_showResults || _options.Count == 0)
        {
            return;
        }

        if (e.Key == "ArrowDown")
        {
            _highlightedIndex = Math.Min(_highlightedIndex + 1, _options.Count - 1);
            await InvokeAsync(StateHasChanged);
        }
        else if (e.Key == "ArrowUp")
        {
            _highlightedIndex = Math.Max(_highlightedIndex - 1, 0);
            await InvokeAsync(StateHasChanged);
        }
        else if (e.Key == "Enter" && _highlightedIndex >= 0 && _highlightedIndex < _options.Count)
        {
            await SelectAsync(_options[_highlightedIndex]);
        }
    }

    private static string FormatEntityType(string entityType) =>
        entityType.Trim().Replace('_', ' ');

    /// <summary>
    /// Wraps the matched substring in a highlight span so users can see
    /// what their query matched. Match is case-insensitive against the
    /// current trimmed query; if the query is empty or absent, the text
    /// is returned verbatim.
    /// </summary>
    private RenderFragment RenderHighlighted(string text) => builder =>
    {
        if (string.IsNullOrEmpty(text))
        {
            return;
        }

        var query = _searchText?.Trim();
        if (string.IsNullOrEmpty(query))
        {
            builder.AddContent(0, text);
            return;
        }

        var matchIndex = text.IndexOf(query, StringComparison.OrdinalIgnoreCase);
        if (matchIndex < 0)
        {
            builder.AddContent(0, text);
            return;
        }

        if (matchIndex > 0)
        {
            builder.AddContent(1, text.Substring(0, matchIndex));
        }
        builder.OpenElement(2, "strong");
        builder.AddAttribute(3, "class", "unity-picker__match");
        builder.AddContent(4, text.Substring(matchIndex, query.Length));
        builder.CloseElement();
        var tail = matchIndex + query.Length;
        if (tail < text.Length)
        {
            builder.AddContent(5, text.Substring(tail));
        }
    };

    private UnitysearchUsageEvent BuildUsageEvent(
        string eventType,
        string entityType,
        string query,
        int? resultCount,
        Guid? selectedEntityId = null,
        int? rankPosition = null) => new()
    {
        CompanyId = CompanyId,
        Context = Context,
        EntityType = entityType,
        EventType = eventType,
        Query = string.IsNullOrWhiteSpace(query) ? null : query,
        SelectedEntityId = selectedEntityId,
        RankPosition = rankPosition,
        ResultCount = resultCount,
        SourceRoute = SourceRoute,
        AnchorContext = AnchorContext,
        AnchorEntityType = AnchorEntityType,
        AnchorEntityId = AnchorEntityId,
    };
}
