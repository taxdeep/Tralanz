@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject Web.Shell.Services.WebShellBusinessSessionClient SessionClient
@inject WebShellState ShellState
@inject ILogger<ShellLayout> Logger

@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (!_isShellReady)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="pa-8">
        <MudProgressLinear Indeterminate="true" Color="Color.Info" />
    </MudContainer>
}
else if (!ShellState.IsAuthenticated)
{
    <main class="bz-main bz-main--login">
        <div class="bz-login-shell">
            @if (IsLoginRoute)
            {
                @Body
            }
            else
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Info" />
            }
        </div>
    </main>
}
else
{
    <div class="bz-shell">
        <header class="bz-shell__topbar">
            <div class="bz-shell__brand">
                <div class="bz-shell__brand-mark">
                    <i class="ti ti-scale-outline" aria-hidden="true"></i>
                </div>
                <div class="bz-shell__brand-copy">
                    <div class="bz-shell__brand-title">Balanciz</div>
                    <div class="bz-shell__brand-subtitle">Operator workspace</div>
                </div>
            </div>

            <div class="bz-shell__status-rail">
                <span class="bz-shell__status-pill">
                    <i class="ti ti-layout-sidebar-left-expand" aria-hidden="true"></i>
                    T-layout shell
                </span>
                <span class="bz-shell__status-pill">
                    <i class="ti ti-building-bank" aria-hidden="true"></i>
                    Business control
                </span>
            </div>

            <div class="bz-shell__topbar-controls">
                <WebShellTopBar />
            </div>
        </header>

        <div class="bz-shell__body">
            <aside class="bz-shell__sidebar">
                <div class="bz-sidebar__summary">
                    <div class="bz-sidebar__summary-badge">B</div>
                    <div>
                        <div class="bz-sidebar__summary-label">Balanciz</div>
                        <div class="bz-sidebar__summary-title">Workspace</div>
                        <div class="bz-sidebar__summary-text">Commercial, accounting, and control surfaces.</div>
                    </div>
                </div>

                <ErrorBoundary>
                    <ChildContent>
                        <NavMenu />
                    </ChildContent>
                    <ErrorContent>
                        <div class="bz-shell__error">
                            <i class="ti ti-alert-circle" aria-hidden="true"></i>
                            Navigation could not be loaded. Refresh the page after sign-in completes.
                        </div>
                    </ErrorContent>
                </ErrorBoundary>
            </aside>

            <main class="bz-main">
                <ErrorBoundary>
                    <ChildContent>
                        @Body
                    </ChildContent>
                    <ErrorContent>
                        <div class="bz-shell__error">
                            <i class="ti ti-alert-circle" aria-hidden="true"></i>
                            This workspace page could not be loaded. The session is still active; refresh or return to Home.
                        </div>
                    </ErrorContent>
                </ErrorBoundary>
            </main>
        </div>
    </div>
}

@code
{
    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#7ab6d9",
            Secondary = "#6fcf97",
            Background = "#0d131a",
            Surface = "#121a22",
            AppbarBackground = "#101821",
            DrawerBackground = "#0f151d",
            DrawerText = "#d9e2ea",
            TextPrimary = "#d9e2ea",
            TextSecondary = "#97a8b7",
            Info = "#7ab6d9",
            Success = "#6fcf97",
            Warning = "#d8b56a"
        }
    };

    private bool _isShellReady;

    private bool IsLoginRoute =>
        NavigationManager.ToBaseRelativePath(NavigationManager.Uri)
            .StartsWith("login", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await RestoreStoredSessionAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Web.Shell failed while restoring the browser business session.");
                ShellState.ClearAuthenticatedSession();
                await TryClearStoredSessionTokenAsync();
            }
            finally
            {
                _isShellReady = true;
                StateHasChanged();
            }
        }

        if (!_isShellReady)
        {
            return;
        }

        if (!ShellState.IsAuthenticated && !IsLoginRoute)
        {
            NavigationManager.NavigateTo("login", replace: true);
        }
        else if (ShellState.IsAuthenticated && IsLoginRoute)
        {
            NavigationManager.NavigateTo("/", replace: true);
        }
    }

    private async Task RestoreStoredSessionAsync()
    {
        var storedToken = await JS.InvokeAsync<string?>("citusBusinessAuth.getSessionToken");
        if (string.IsNullOrWhiteSpace(storedToken))
        {
            ShellState.ClearAuthenticatedSession();
            return;
        }

        var session = await SessionClient.ResumeSessionAsync(storedToken);
        if (session is null)
        {
            await TryClearStoredSessionTokenAsync();
            ShellState.ClearAuthenticatedSession();
            return;
        }

        ShellState.ApplyAuthenticatedSession(storedToken, session.Context, session.ExpiresAtUtc);
    }

    private async Task TryClearStoredSessionTokenAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("citusBusinessAuth.clearSessionToken");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Web.Shell could not clear the stored browser business session token.");
        }
    }
}
