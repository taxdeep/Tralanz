@using Citus.Modules.UnitySearch.Application.Contracts
@using Citus.Modules.UnitySearch.Domain.Shared
@using Web.Shell.Components.Search
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject Web.Shell.Services.WebShellBusinessSessionClient SessionClient
@inject UnitySearchClient UnitySearchClient
@inject WebShellState ShellState
@inject ILogger<ShellLayout> Logger

@inherits LayoutComponentBase
@implements IDisposable

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (!_isShellReady)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="pa-8">
        <MudProgressLinear Indeterminate="true" Color="Color.Info" />
    </MudContainer>
}
else if (!ShellState.IsAuthenticated)
{
    <main class="bz-main bz-main--login">
        <div class="bz-login-shell">
            @if (IsLoginRoute)
            {
                @Body
            }
            else
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Info" />
            }
        </div>
    </main>
}
else
{
    <div class="bz-shell">
        <header class="bz-shell__topbar">
            <div class="bz-shell__brand">
                <div class="bz-shell__brand-mark">
                    <i class="ti ti-scale-outline" aria-hidden="true"></i>
                </div>
                <div class="bz-shell__brand-copy">
                    <div class="bz-shell__brand-title">Balanciz <span class="bz-shell__brand-version">@DisplayVersion</span></div>
                    <div class="bz-shell__brand-subtitle">Operator workspace</div>
                </div>
            </div>

            <form class="bz-shell__search" @onsubmit="OnShellSearchAsync">
                <i class="ti ti-search bz-shell__search-icon" aria-hidden="true"></i>
                <input class="bz-shell__search-input"
                       type="search"
                       placeholder="Search transactions, contacts, products..."
                       value="@_shellSearchTerm"
                       @oninput="OnShellSearchInputAsync"
                       @onfocus="HandleTopbarSearchFocusAsync"
                       @onblur="HandleTopbarSearchBlurAsync"
                       aria-label="Search workspace" />

                @if (_showTopbarSearchPanel && ((_shellSearchGroups?.Count ?? 0) > 0 || (_shellRecentQueries?.Count ?? 0) > 0 || (_shellRecentSelections?.Count ?? 0) > 0))
                {
                    <UnitySearchResultsPanel Groups="_shellSearchGroups"
                                             RecentQueries="_shellRecentQueries"
                                             RecentSelections="_shellRecentSelections"
                                             OnItemSelected="HandleTopbarSuggestionSelectedAsync"
                                             OnRecentQuerySelected="HandleTopbarRecentQuerySelectedAsync"
                                             OnRecentSelectionSelected="HandleTopbarRecentSelectionSelectedAsync" />
                }
            </form>

            <div class="bz-shell__topbar-controls">
                <WebShellTopBar />
            </div>
        </header>

        <div class="bz-shell__body">
            <aside class="bz-shell__sidebar">
                <ErrorBoundary>
                    <ChildContent>
                        <NavMenu />
                    </ChildContent>
                    <ErrorContent>
                        <div class="bz-shell__error">
                            <i class="ti ti-alert-circle" aria-hidden="true"></i>
                            Navigation could not be loaded. Refresh the page after sign-in completes.
                        </div>
                    </ErrorContent>
                </ErrorBoundary>
            </aside>

            <main class="bz-main">
                <ErrorBoundary>
                    <ChildContent>
                        @Body
                    </ChildContent>
                    <ErrorContent>
                        <div class="bz-shell__error">
                            <i class="ti ti-alert-circle" aria-hidden="true"></i>
                            This workspace page could not be loaded. The session is still active; refresh or return to Home.
                        </div>
                    </ErrorContent>
                </ErrorBoundary>
            </main>
        </div>
    </div>
}

@code
{
    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#7ab6d9",
            Secondary = "#6fcf97",
            Background = "#0d131a",
            Surface = "#121a22",
            AppbarBackground = "#101821",
            DrawerBackground = "#0f151d",
            DrawerText = "#d9e2ea",
            TextPrimary = "#d9e2ea",
            TextSecondary = "#97a8b7",
            Info = "#7ab6d9",
            Success = "#6fcf97",
            Warning = "#d8b56a"
        }
    };

    private bool _isShellReady;
    private string _shellSearchTerm = string.Empty;
    private IReadOnlyList<UnitySearchGroupResult> _shellSearchGroups = Array.Empty<UnitySearchGroupResult>();
    private IReadOnlyList<UnitySearchRecentQueryRecord> _shellRecentQueries = Array.Empty<UnitySearchRecentQueryRecord>();
    private IReadOnlyList<UnitySearchRecentSelectionRecord> _shellRecentSelections = Array.Empty<UnitySearchRecentSelectionRecord>();
    private CancellationTokenSource? _searchDebounceCts;
    private CancellationTokenSource? _searchPanelBlurCts;
    private bool _showTopbarSearchPanel;
    private static string AppVersion =>
        typeof(ShellLayout).Assembly
            .GetCustomAttributes(typeof(System.Reflection.AssemblyInformationalVersionAttribute), false)
            .OfType<System.Reflection.AssemblyInformationalVersionAttribute>()
            .FirstOrDefault()?.InformationalVersion?.Split('+', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)[0]
        ?? typeof(ShellLayout).Assembly.GetName().Version?.ToString()
        ?? "0.0.0";
    private static string DisplayVersion => $"v{AppVersion}";

    private bool IsLoginRoute =>
        NavigationManager.ToBaseRelativePath(NavigationManager.Uri)
            .StartsWith("login", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await RestoreStoredSessionAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Web.Shell failed while restoring the browser business session.");
                ShellState.ClearAuthenticatedSession();
                await TryClearStoredSessionTokenAsync();
            }
            finally
            {
                _isShellReady = true;
                StateHasChanged();
            }
        }

        if (!_isShellReady)
        {
            return;
        }

        if (!ShellState.IsAuthenticated && !IsLoginRoute)
        {
            NavigationManager.NavigateTo("login", replace: true);
        }
        else if (ShellState.IsAuthenticated && IsLoginRoute)
        {
            NavigationManager.NavigateTo("/", replace: true);
        }
    }

    private async Task RestoreStoredSessionAsync()
    {
        var storedToken = await JS.InvokeAsync<string?>("citusBusinessAuth.getSessionToken");
        if (string.IsNullOrWhiteSpace(storedToken))
        {
            ShellState.ClearAuthenticatedSession();
            return;
        }

        var session = await SessionClient.ResumeSessionAsync(storedToken);
        if (session is null)
        {
            await TryClearStoredSessionTokenAsync();
            ShellState.ClearAuthenticatedSession();
            return;
        }

        ShellState.ApplyAuthenticatedSession(storedToken, session.Context, session.ExpiresAtUtc);
    }

    private async Task TryClearStoredSessionTokenAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("citusBusinessAuth.clearSessionToken");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Web.Shell could not clear the stored browser business session token.");
        }
    }

    private Task OnShellSearchAsync()
    {
        var term = _shellSearchTerm.Trim();
        if (string.IsNullOrWhiteSpace(term))
        {
            _shellSearchGroups = Array.Empty<UnitySearchGroupResult>();
            _showTopbarSearchPanel = false;
            NavigationManager.NavigateTo("/transactions");
            return Task.CompletedTask;
        }

        _shellSearchGroups = Array.Empty<UnitySearchGroupResult>();
        _showTopbarSearchPanel = false;
        NavigationManager.NavigateTo($"/transactions?q={Uri.EscapeDataString(term)}");
        return Task.CompletedTask;
    }

    private async Task HandleTopbarSearchFocusAsync(FocusEventArgs _)
    {
        _searchPanelBlurCts?.Cancel();
        _searchPanelBlurCts?.Dispose();
        _searchPanelBlurCts = null;
        _showTopbarSearchPanel = true;

        if (!ShellState.IsAuthenticated || ShellState.ActiveCompany.Id == Guid.Empty || ShellState.CurrentUserId == Guid.Empty)
        {
            _shellRecentQueries = Array.Empty<UnitySearchRecentQueryRecord>();
            _shellRecentSelections = Array.Empty<UnitySearchRecentSelectionRecord>();
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (!string.IsNullOrWhiteSpace(_shellSearchTerm.Trim()))
        {
            return;
        }

        _shellRecentQueries = await UnitySearchClient.ListRecentQueriesAsync(
            ShellState.ActiveCompany.Id,
            ShellState.CurrentUserId,
            SearchScopeContext.GlobalTopbar,
            6);
        _shellRecentSelections = await UnitySearchClient.ListRecentSelectionsAsync(
            ShellState.ActiveCompany.Id,
            ShellState.CurrentUserId,
            SearchScopeContext.GlobalTopbar,
            6);
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleTopbarSearchBlurAsync(FocusEventArgs _)
    {
        _searchPanelBlurCts?.Cancel();
        _searchPanelBlurCts?.Dispose();
        var cts = new CancellationTokenSource();
        _searchPanelBlurCts = cts;

        try
        {
            await Task.Delay(160, cts.Token);
            if (!cts.IsCancellationRequested)
            {
                _showTopbarSearchPanel = false;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task OnShellSearchInputAsync(ChangeEventArgs args)
    {
        _shellSearchTerm = args.Value?.ToString() ?? string.Empty;
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        _showTopbarSearchPanel = true;

        if (!ShellState.IsAuthenticated || ShellState.ActiveCompany.Id == Guid.Empty)
        {
            _shellSearchGroups = Array.Empty<UnitySearchGroupResult>();
            _shellRecentQueries = Array.Empty<UnitySearchRecentQueryRecord>();
            _shellRecentSelections = Array.Empty<UnitySearchRecentSelectionRecord>();
            return;
        }

        var trimmed = _shellSearchTerm.Trim();
        if (trimmed.Length < 2)
        {
            _shellSearchGroups = Array.Empty<UnitySearchGroupResult>();
            if (ShellState.CurrentUserId != Guid.Empty)
            {
                _shellRecentQueries = await UnitySearchClient.ListRecentQueriesAsync(
                    ShellState.ActiveCompany.Id,
                    ShellState.CurrentUserId,
                    SearchScopeContext.GlobalTopbar,
                    6);
                _shellRecentSelections = await UnitySearchClient.ListRecentSelectionsAsync(
                    ShellState.ActiveCompany.Id,
                    ShellState.CurrentUserId,
                    SearchScopeContext.GlobalTopbar,
                    6);
            }
            StateHasChanged();
            return;
        }

        var cts = new CancellationTokenSource();
        _searchDebounceCts = cts;

        try
        {
            await Task.Delay(220, cts.Token);
            var result = await UnitySearchClient.SearchAsync(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                SearchScopeContext.GlobalTopbar,
                trimmed,
                8,
                cts.Token);
            if (!cts.IsCancellationRequested)
            {
                _shellSearchGroups = result.Groups;
                _shellRecentQueries = Array.Empty<UnitySearchRecentQueryRecord>();
                _shellRecentSelections = Array.Empty<UnitySearchRecentSelectionRecord>();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "UnitySearch topbar query failed.");
            _shellSearchGroups = Array.Empty<UnitySearchGroupResult>();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleTopbarSuggestionSelectedAsync(UnitySearchSuggestion suggestion)
    {
        _shellSearchGroups = Array.Empty<UnitySearchGroupResult>();
        _shellRecentQueries = Array.Empty<UnitySearchRecentQueryRecord>();
        _shellRecentSelections = Array.Empty<UnitySearchRecentSelectionRecord>();
        _showTopbarSearchPanel = false;
        if (ShellState.IsAuthenticated && ShellState.ActiveCompany.Id != Guid.Empty)
        {
            await UnitySearchClient.RecordClickAsync(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                SearchScopeContext.GlobalTopbar,
                suggestion.EntityType,
                suggestion.SourceId);
        }

        NavigationManager.NavigateTo(suggestion.NavigationHref);
    }

    private Task HandleTopbarRecentQuerySelectedAsync(string queryText)
    {
        _shellSearchTerm = queryText;
        _showTopbarSearchPanel = false;
        NavigationManager.NavigateTo($"/transactions?q={Uri.EscapeDataString(queryText)}");
        return Task.CompletedTask;
    }

    private async Task HandleTopbarRecentSelectionSelectedAsync(UnitySearchRecentSelectionRecord selection)
    {
        _shellSearchGroups = Array.Empty<UnitySearchGroupResult>();
        _shellRecentQueries = Array.Empty<UnitySearchRecentQueryRecord>();
        _shellRecentSelections = Array.Empty<UnitySearchRecentSelectionRecord>();
        _showTopbarSearchPanel = false;

        if (ShellState.IsAuthenticated && ShellState.ActiveCompany.Id != Guid.Empty && ShellState.CurrentUserId != Guid.Empty)
        {
            await UnitySearchClient.RecordClickAsync(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                SearchScopeContext.GlobalTopbar,
                selection.EntityType,
                selection.SourceId);
        }

        NavigationManager.NavigateTo(selection.NavigationHref);
    }

    public void Dispose()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        _searchPanelBlurCts?.Cancel();
        _searchPanelBlurCts?.Dispose();
    }
}
