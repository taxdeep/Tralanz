@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject Web.Shell.Services.WebShellBusinessSessionClient SessionClient
@inject WebShellState ShellState

<div class="bz-topbar">
    <div class="bz-topbar__meta">
        <button type="button"
                class="bz-topbar__theme-toggle"
                title="@ThemeToggleTitle"
                aria-label="@ThemeToggleTitle"
                @onclick="OnThemeToggle">
            <i class="ti @(IsDarkMode ? "ti-sun" : "ti-moon")" aria-hidden="true"></i>
            <span>@(IsDarkMode ? "Light" : "Dark")</span>
        </button>

        @if (ShellState.IsCompanyReadOnly)
        {
            <span class="bz-topbar__pill bz-topbar__pill--warning">
                <i class="ti ti-lock" aria-hidden="true"></i>
                Read-only company
            </span>
        }
    </div>

    <div class="bz-topbar__user-menu">
        <button type="button"
                class="bz-topbar__user-trigger"
                @onclick="ToggleUserMenu"
                aria-expanded="@_userMenuOpen"
                aria-haspopup="menu">
            <span class="bz-topbar__avatar">@UserInitials</span>
            <span class="bz-topbar__identity">
                <span class="bz-topbar__label">User</span>
                <span class="bz-topbar__value">@ShellState.User.DisplayName</span>
            </span>
            <i class="ti ti-chevron-down bz-topbar__user-caret" aria-hidden="true"></i>
        </button>

        @if (_userMenuOpen)
        {
            <div class="bz-topbar__menu" role="menu">
                <div class="bz-topbar__menu-context" aria-label="Current business context">
                    <span>Company</span>
                    <strong>@ShellState.ActiveCompany.CompanyName</strong>
                    <small>@ShellState.ActiveCompany.CompanyCode | @PrimaryRole</small>
                </div>
                <a class="bz-topbar__menu-item" href="/profile" @onclick="CloseUserMenu" role="menuitem">
                    <i class="ti ti-user-circle" aria-hidden="true"></i>
                    <span>Profile</span>
                </a>
                <button type="button" class="bz-topbar__menu-item" @onclick="SignOutFromMenuAsync" role="menuitem">
                    <i class="ti ti-logout-2" aria-hidden="true"></i>
                    <span>Sign out</span>
                </button>
            </div>
        }
    </div>
</div>

@code
{
    [Parameter]
    public bool IsDarkMode { get; set; } = true;

    [Parameter]
    public EventCallback OnThemeToggle { get; set; }

    private string PrimaryRole => ShellState.User.Roles.FirstOrDefault() ?? "user";
    private bool _userMenuOpen;
    private string ThemeToggleTitle => IsDarkMode ? "Switch to light mode" : "Switch to dark mode";
    private string UserInitials =>
        string.Join(
            string.Empty,
            ShellState.User.DisplayName
                .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .Take(2)
                .Select(static part => char.ToUpperInvariant(part[0])))
        is { Length: > 0 } initials
            ? initials
            : "U";

    private void ToggleUserMenu()
    {
        _userMenuOpen = !_userMenuOpen;
    }

    private void CloseUserMenu()
    {
        _userMenuOpen = false;
    }

    private async Task SignOutFromMenuAsync()
    {
        _userMenuOpen = false;
        await SignOutAsync();
    }

    private async Task SignOutAsync()
    {
        await SessionClient.SignOutAsync(ShellState.SessionToken);
        await JS.InvokeVoidAsync("citusBusinessAuth.clearSessionToken");
        ShellState.ClearAuthenticatedSession();
        NavigationManager.NavigateTo("login", forceLoad: true);
    }
}
