@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject Web.Shell.Services.WebShellBusinessSessionClient SessionClient
@inject WebShellState ShellState

<div class="bz-topbar">
    <div class="bz-topbar__meta">
        <span class="bz-topbar__pill bz-topbar__pill--role">
            <i class="ti ti-shield-check" aria-hidden="true"></i>
            @PrimaryRole
        </span>

        @if (ShellState.IsCompanyReadOnly)
        {
            <span class="bz-topbar__pill bz-topbar__pill--warning">
                <i class="ti ti-lock" aria-hidden="true"></i>
                Read-only company
            </span>
        }
    </div>

    <label class="bz-topbar__company">
        <span class="bz-topbar__label">Active company</span>
        <select class="bz-topbar__select"
                value="@SelectedCompanyId"
                disabled="@IsCompanySwitcherDisabled"
                @onchange="OnSelectedCompanyChangedAsync">
            @foreach (var company in ShellState.AvailableCompanies)
            {
                <option value="@company.Id">
                    @company.CompanyName (@company.CompanyCode)@(company.IsReadOnly ? " | read-only" : string.Empty)
                </option>
            }
        </select>
    </label>

    <div class="bz-topbar__user-menu">
        <button type="button"
                class="bz-topbar__user-trigger"
                @onclick="ToggleUserMenu"
                aria-expanded="@_userMenuOpen"
                aria-haspopup="menu">
            <span class="bz-topbar__avatar">@UserInitials</span>
            <span class="bz-topbar__identity">
                <span class="bz-topbar__label">User</span>
                <span class="bz-topbar__value">@ShellState.User.DisplayName</span>
            </span>
            <i class="ti ti-chevron-down bz-topbar__user-caret" aria-hidden="true"></i>
        </button>

        @if (_userMenuOpen)
        {
            <div class="bz-topbar__menu" role="menu">
                <a class="bz-topbar__menu-item" href="/profile" @onclick="CloseUserMenu" role="menuitem">
                    <i class="ti ti-user-circle" aria-hidden="true"></i>
                    <span>Profile</span>
                </a>
                <button type="button" class="bz-topbar__menu-item" @onclick="SignOutFromMenuAsync" role="menuitem">
                    <i class="ti ti-logout-2" aria-hidden="true"></i>
                    <span>Sign out</span>
                </button>
            </div>
        }
    </div>
</div>

@code
{
    private string PrimaryRole => ShellState.User.Roles.FirstOrDefault() ?? "user";
    private bool _userMenuOpen;

    private Guid SelectedCompanyId => ShellState.ActiveCompany.Id;

    private bool IsCompanySwitcherDisabled => ShellState.AvailableCompanies.Count <= 1;
    private string UserInitials =>
        string.Join(
            string.Empty,
            ShellState.User.DisplayName
                .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .Take(2)
                .Select(static part => char.ToUpperInvariant(part[0])))
        is { Length: > 0 } initials
            ? initials
            : "U";

    private async Task OnSelectedCompanyChangedAsync(ChangeEventArgs args)
    {
        if (!Guid.TryParse(args.Value?.ToString(), out var companyId))
        {
            return;
        }

        await OnCompanyChangedAsync(companyId);
    }

    private async Task OnCompanyChangedAsync(Guid companyId)
    {
        if (companyId == Guid.Empty || companyId == ShellState.ActiveCompany.Id)
        {
            return;
        }

        var (result, error) = await SessionClient.SwitchActiveCompanyAsync(ShellState.SessionToken, companyId);
        if (result is null)
        {
            Snackbar.Add(
                string.IsNullOrWhiteSpace(error)
                    ? "Unable to switch the active company."
                    : error,
                Severity.Warning);
            return;
        }

        ShellState.ApplyAuthenticatedSession(ShellState.SessionToken, result.Context, result.ExpiresAtUtc);
        Snackbar.Add($"Active company switched to {result.Context.ActiveCompany.CompanyName}.", Severity.Success);
        NavigationManager.NavigateTo("/");
    }

    private void ToggleUserMenu()
    {
        _userMenuOpen = !_userMenuOpen;
    }

    private void CloseUserMenu()
    {
        _userMenuOpen = false;
    }

    private async Task SignOutFromMenuAsync()
    {
        _userMenuOpen = false;
        await SignOutAsync();
    }

    private async Task SignOutAsync()
    {
        await SessionClient.SignOutAsync(ShellState.SessionToken);
        await JS.InvokeVoidAsync("citusBusinessAuth.clearSessionToken");
        ShellState.ClearAuthenticatedSession();
        NavigationManager.NavigateTo("login", forceLoad: true);
    }
}
