@inject WebShellState ShellState
@inject Web.Shell.Services.WebShellBusinessSessionClient SessionClient
@inject Web.Shell.Services.WebShellCompanyOnboardingClient OnboardingClient
@inject Web.Shell.Services.WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject IJSRuntime JS

<nav class="bz-sidebar-nav">
    <div class="bz-sidebar-nav__create">
        <button type="button"
                class="bz-sidebar-nav__create-button"
                @onclick="ToggleCreateMenu"
                aria-expanded="@_isCreateMenuOpen"
                aria-controls="balanciz-create-menu">
            <i class="ti ti-plus" aria-hidden="true"></i>
            <span>Create</span>
        </button>

        @if (_isCreateMenuOpen)
        {
            <div id="balanciz-create-menu" class="bz-create-menu">
                <div class="bz-create-menu__columns">
                    <section class="bz-create-menu__column">
                        <h3 class="bz-create-menu__column-title">Customer</h3>
                        @if (WritesBlocked)
                        {
                            <span class="bz-create-menu__item bz-create-menu__item--disabled" title="@ShellState.WriteBlockMessage">New Invoice</span>
                        }
                        else
                        {
                            <a class="bz-create-menu__item" href="/documents/invoice/draft-editor" @onclick="CloseCreateMenu">New Invoice</a>
                        }
                        <a class="bz-create-menu__item" href="/ar/receive-payment" @onclick="CloseCreateMenu">Receive Payment</a>
                    </section>

                    <section class="bz-create-menu__column">
                        <h3 class="bz-create-menu__column-title">Vendor</h3>
                        @if (WritesBlocked)
                        {
                            <span class="bz-create-menu__item bz-create-menu__item--disabled" title="@ShellState.WriteBlockMessage">New Bill</span>
                            <span class="bz-create-menu__item bz-create-menu__item--disabled" title="@ShellState.WriteBlockMessage">New Expense</span>
                        }
                        else
                        {
                            <a class="bz-create-menu__item" href="/documents/bill/draft-editor" @onclick="CloseCreateMenu">New Bill</a>
                            <a class="bz-create-menu__item" href="/documents/bill/draft-editor?origin=expense" @onclick="CloseCreateMenu">New Expense</a>
                        }
                        <a class="bz-create-menu__item" href="/ap/pay-bill" @onclick="CloseCreateMenu">Make Payment</a>
                    </section>

                    <section class="bz-create-menu__column">
                        <h3 class="bz-create-menu__column-title">Other</h3>
                        @if (WritesBlocked)
                        {
                            <span class="bz-create-menu__item bz-create-menu__item--disabled" title="@ShellState.WriteBlockMessage">New Journal Entry</span>
                        }
                        else
                        {
                            <a class="bz-create-menu__item" href="/gl/journal-entry/editor" @onclick="CloseCreateMenu">New Journal Entry</a>
                        }
                    </section>
                </div>
            </div>
        }
    </div>

    <div class="bz-sidebar-nav__sections">
        <section class="bz-sidebar-nav__section">
            <button type="button" class="bz-sidebar-nav__section-toggle" @onclick="ToggleCore">
                <span>Core</span>
                <i class="ti @( _coreExpanded ? "ti-chevron-up" : "ti-chevron-down" )" aria-hidden="true"></i>
            </button>
            @if (_coreExpanded)
            {
                <div class="bz-sidebar-nav__items">
                    <NavLink href="/" Match="NavLinkMatch.All" class="bz-sidebar-nav__link">
                        <i class="ti ti-layout-dashboard bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Dashboard</span>
                    </NavLink>
                    <NavLink href="/documents/source-browser" class="bz-sidebar-nav__link">
                        <i class="ti ti-files bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Source Documents</span>
                    </NavLink>
                </div>
            }
        </section>

        <section class="bz-sidebar-nav__section">
            <button type="button" class="bz-sidebar-nav__section-toggle" @onclick="ToggleSales">
                <span>Sales &amp; Get Paid</span>
                <i class="ti @( _salesExpanded ? "ti-chevron-up" : "ti-chevron-down" )" aria-hidden="true"></i>
            </button>
            @if (_salesExpanded)
            {
                <div class="bz-sidebar-nav__items">
                    <NavLink href="/ar/customers" class="bz-sidebar-nav__link">
                        <i class="ti ti-users-group bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Customers</span>
                    </NavLink>
                    <NavLink href="/documents/source-browser?sourceType=invoice&counterpartyRole=customer" class="bz-sidebar-nav__link">
                        <i class="ti ti-receipt-2 bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Sales Transactions</span>
                    </NavLink>
                    <NavLink href="/documents/source-browser?sourceType=quote" class="bz-sidebar-nav__link">
                        <i class="ti ti-file-text-ai bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Quotes</span>
                    </NavLink>
                    <NavLink href="/documents/source-browser?sourceType=sales_order" class="bz-sidebar-nav__link">
                        <i class="ti ti-file-check bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Sales Orders</span>
                    </NavLink>
                    <NavLink href="/ar/aging" class="bz-sidebar-nav__link">
                        <i class="ti ti-chart-bar-popular bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Customer Statement</span>
                    </NavLink>
                    <NavLink href="/ar/receive-payment" class="bz-sidebar-nav__link">
                        <i class="ti ti-cash-register bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Receive Payment</span>
                    </NavLink>
                </div>
            }
        </section>

        <section class="bz-sidebar-nav__section">
            <button type="button" class="bz-sidebar-nav__section-toggle" @onclick="ToggleExpense">
                <span>Expense &amp; Bills</span>
                <i class="ti @( _expenseExpanded ? "ti-chevron-up" : "ti-chevron-down" )" aria-hidden="true"></i>
            </button>
            @if (_expenseExpanded)
            {
                <div class="bz-sidebar-nav__items">
                    <NavLink href="/documents/bill/draft-editor?origin=expense" class="bz-sidebar-nav__link">
                        <i class="ti ti-file-description bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Expenses</span>
                    </NavLink>
                    <NavLink href="/company/customer-vendor-setup" class="bz-sidebar-nav__link">
                        <i class="ti ti-building-store bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Vendors</span>
                    </NavLink>
                    <NavLink href="/documents/source-browser?sourceType=purchase_order" class="bz-sidebar-nav__link">
                        <i class="ti ti-clipboard-list bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Purchase Orders</span>
                    </NavLink>
                    <NavLink href="/ap/aging" class="bz-sidebar-nav__link">
                        <i class="ti ti-chart-donut-2 bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>AP Aging</span>
                    </NavLink>
                    <NavLink href="/ap/pay-bill" class="bz-sidebar-nav__link">
                        <i class="ti ti-credit-card-pay bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Pay Bills</span>
                    </NavLink>
                </div>
            }
        </section>

        @if (_showInventoryFoundation)
        {
            <section class="bz-sidebar-nav__section">
                <button type="button" class="bz-sidebar-nav__section-toggle" @onclick="ToggleInventory">
                    <span>Inventory</span>
                    <i class="ti @( _inventoryExpanded ? "ti-chevron-up" : "ti-chevron-down" )" aria-hidden="true"></i>
                </button>
                @if (_inventoryExpanded)
                {
                    <div class="bz-sidebar-nav__items">
                        <NavLink href="/company/product-service-setup" class="bz-sidebar-nav__link">
                            <i class="ti ti-package bz-sidebar-nav__icon" aria-hidden="true"></i>
                            <span>Products &amp; Services</span>
                        </NavLink>
                        <NavLink href="/company/inventory-foundation" class="bz-sidebar-nav__link">
                            <i class="ti ti-building-warehouse bz-sidebar-nav__icon" aria-hidden="true"></i>
                            <span>Warehouses</span>
                        </NavLink>
                        <NavLink href="/company/inventory-transfer" class="bz-sidebar-nav__link">
                            <i class="ti ti-arrows-transfer-up-down bz-sidebar-nav__icon" aria-hidden="true"></i>
                            <span>Warehouse Transfers</span>
                        </NavLink>
                        <NavLink href="/company/inventory-return-receive" class="bz-sidebar-nav__link">
                            <i class="ti ti-arrow-back-up bz-sidebar-nav__icon" aria-hidden="true"></i>
                            <span>Return Receipts</span>
                        </NavLink>
                    </div>
                }
            </section>
        }

        <section class="bz-sidebar-nav__section">
            <button type="button" class="bz-sidebar-nav__section-toggle" @onclick="ToggleControl">
                <span>Company &amp; Governance</span>
                <i class="ti @( _controlExpanded ? "ti-chevron-up" : "ti-chevron-down" )" aria-hidden="true"></i>
            </button>
            @if (_controlExpanded)
            {
                <div class="bz-sidebar-nav__items">
                    <NavLink href="/company/book-governance" class="bz-sidebar-nav__link">
                        <i class="ti ti-book-2 bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Book Governance</span>
                    </NavLink>
                    <NavLink href="/company/bank-and-cash-setup" class="bz-sidebar-nav__link">
                        <i class="ti ti-building-bank bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Bank &amp; Cash</span>
                    </NavLink>
                    <NavLink href="/company/tax-setup" class="bz-sidebar-nav__link">
                        <i class="ti ti-percentage bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Tax Setup</span>
                    </NavLink>
                    <NavLink href="/company/membership-permissions" class="bz-sidebar-nav__link">
                        <i class="ti ti-users bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Memberships</span>
                    </NavLink>
                    <NavLink href="/gl/journal-entries" class="bz-sidebar-nav__link">
                        <i class="ti ti-writing-sign bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Journal Entries</span>
                    </NavLink>
                    <NavLink href="/settings/user-preferences/system-setup" class="bz-sidebar-nav__link">
                        <i class="ti ti-adjustments-horizontal bz-sidebar-nav__icon" aria-hidden="true"></i>
                        <span>Preferences</span>
                    </NavLink>
                </div>
            }
        </section>
    </div>
</nav>

@code {
    private const string SidebarStateStorageKey = "balanciz.sidebar.sections.v1";

    private bool _showInventoryFoundation = true;
    private bool _isCreateMenuOpen;
    private bool _coreExpanded = true;
    private bool _salesExpanded = true;
    private bool _expenseExpanded = true;
    private bool _inventoryExpanded = true;
    private bool _controlExpanded = true;
    private bool _sidebarStateLoaded;

    private bool WritesBlocked => ShellState.AreWritesBlocked;

    protected override async Task OnInitializedAsync()
    {
        await ShellState.EnsureHydratedAsync();
        var probe = await SessionClient.ProbeContextAsync();
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe))
        {
            return;
        }

        var onboardingResult = await OnboardingClient.GetAsync();
        if (!onboardingResult.RequiresSignIn &&
            !onboardingResult.IsNotFound &&
            string.IsNullOrWhiteSpace(onboardingResult.ErrorMessage) &&
            onboardingResult.Value is not null)
        {
            _showInventoryFoundation = onboardingResult.Value.SupportsInventoryFoundation;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_sidebarStateLoaded)
        {
            return;
        }

        _sidebarStateLoaded = true;
        await LoadSidebarStateAsync();
    }

    private void ToggleCreateMenu() => _isCreateMenuOpen = !_isCreateMenuOpen;
    private Task CloseCreateMenu()
    {
        _isCreateMenuOpen = false;
        return Task.CompletedTask;
    }

    private async Task ToggleCore()
    {
        _coreExpanded = !_coreExpanded;
        await PersistSidebarStateAsync();
    }

    private async Task ToggleSales()
    {
        _salesExpanded = !_salesExpanded;
        await PersistSidebarStateAsync();
    }

    private async Task ToggleExpense()
    {
        _expenseExpanded = !_expenseExpanded;
        await PersistSidebarStateAsync();
    }

    private async Task ToggleInventory()
    {
        _inventoryExpanded = !_inventoryExpanded;
        await PersistSidebarStateAsync();
    }

    private async Task ToggleControl()
    {
        _controlExpanded = !_controlExpanded;
        await PersistSidebarStateAsync();
    }

    private async Task LoadSidebarStateAsync()
    {
        try
        {
            var raw = await JS.InvokeAsync<string?>("localStorage.getItem", SidebarStateStorageKey);
            if (string.IsNullOrWhiteSpace(raw))
            {
                return;
            }

            var state = System.Text.Json.JsonSerializer.Deserialize<SidebarSectionState>(raw);
            if (state is null)
            {
                return;
            }

            _coreExpanded = state.CoreExpanded;
            _salesExpanded = state.SalesExpanded;
            _expenseExpanded = state.ExpenseExpanded;
            _inventoryExpanded = state.InventoryExpanded;
            _controlExpanded = state.ControlExpanded;

            StateHasChanged();
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSException)
        {
        }
    }

    private async Task PersistSidebarStateAsync()
    {
        if (!_sidebarStateLoaded)
        {
            return;
        }

        try
        {
            var raw = System.Text.Json.JsonSerializer.Serialize(new SidebarSectionState(
                _coreExpanded,
                _salesExpanded,
                _expenseExpanded,
                _inventoryExpanded,
                _controlExpanded));

            await JS.InvokeVoidAsync("localStorage.setItem", SidebarStateStorageKey, raw);
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSException)
        {
        }
    }

    private sealed record SidebarSectionState(
        bool CoreExpanded,
        bool SalesExpanded,
        bool ExpenseExpanded,
        bool InventoryExpanded,
        bool ControlExpanded);
}
