@page "/company/inventory-availability"
@using Citus.Modules.Inventory.Application.Contracts
@using Web.Shell.Services
@rendermode InteractiveServer
@inject WebShellState ShellState
@inject WebShellBusinessSessionClient SessionClient
@inject WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject WebShellCompanyOnboardingClient OnboardingClient
@inject ShellInventoryReportingClient InventoryReporting

<PageTitle>Inventory Availability</PageTitle>

<div style="padding:1.75rem;display:grid;gap:1rem;">
    <MudPaper Elevation="0" Class="pa-5">
        <MudStack Spacing="2">
            <MudText Typo="Typo.overline" Class="text-secondary">Inventory Phase D</MudText>
            <MudText Typo="Typo.h4">Inventory Availability & Ledger Review</MudText>
            <MudText Typo="Typo.body1" Class="text-secondary">
                Review company-scoped inventory availability and recent stock-ledger truth without leaving the inventory seam. This page stays read-only, but now supports focused drill-down by item and warehouse so operators can inspect a narrower movement trail before transfer, write-off, or AR/AP bridges grow further.
            </MudText>
            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                    @ShellState.ActiveCompany.CompanyName (@ShellState.ActiveCompany.CompanyCode)
                </MudChip>
                <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">
                    Base currency @_dashboard?.BaseCurrencyCode
                </MudChip>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
            @_error
        </MudAlert>
    }
    else if (_onboardingSummary is not null && !_onboardingSummary.SupportsInventoryFoundation)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            Inventory availability review is closed by default for <strong>@_onboardingSummary.Industry</strong> companies. Keep using lighter service-led setup until company governance opens inventory-managed trading flow.
        </MudAlert>
    }
    else if (_dashboard is null)
    {
        <MudPaper Elevation="0" Class="pa-5">
            <MudProgressLinear Indeterminate="true" Color="Color.Info" />
        </MudPaper>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-4" Style="height:100%;">
                    <MudText Typo="Typo.caption" Class="text-secondary">Tracked balances</MudText>
                    <MudText Typo="Typo.h5">@_dashboard.AvailabilityRows.Count</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        Each row is one item + warehouse balance cache with current quantity and cost state.
                    </MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-4" Style="height:100%;">
                    <MudText Typo="Typo.caption" Class="text-secondary">On-hand total</MudText>
                    <MudText Typo="Typo.h5">@_dashboard.AvailabilityRows.Sum(static row => row.OnHandQty)</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        Available total is @_dashboard.AvailabilityRows.Sum(static row => row.AvailableQty).
                    </MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-4" Style="height:100%;">
                    <MudText Typo="Typo.caption" Class="text-secondary">Recent ledger rows</MudText>
                    <MudText Typo="Typo.h5">@_dashboard.RecentLedgerEntries.Count</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        Latest outbound/inbound truth is visible here before deeper stock reports land.
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Elevation="0" Class="pa-5">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Focused drill-down</MudText>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudSelect T="Guid?"
                                   Label="Item filter"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   @bind-Value="_selectedItemId">
                            <MudSelectItem T="Guid?" Value="@((Guid?)null)">-- All items --</MudSelectItem>
                            @foreach (var item in _dashboard.ActiveItems)
                            {
                                <MudSelectItem T="Guid?" Value="@item.Id">@item.ItemCode - @item.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="Guid?"
                                   Label="Warehouse filter"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   @bind-Value="_selectedWarehouseId">
                            <MudSelectItem T="Guid?" Value="@((Guid?)null)">-- All warehouses --</MudSelectItem>
                            @foreach (var warehouse in _dashboard.ActiveWarehouses)
                            {
                                <MudSelectItem T="Guid?" Value="@warehouse.Id">@warehouse.WarehouseCode - @warehouse.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4" Class="d-flex align-end">
                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyDrillDownAsync">
                                Apply Drill-Down
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ClearDrillDownAsync">
                                Clear
                            </MudButton>
                        </MudStack>
                    </MudItem>
                </MudGrid>
                <MudText Typo="Typo.body2" Class="text-secondary">
                    Drill-down keeps the overview intact, but narrows a second review section to the selected item and/or warehouse.
                </MudText>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="0" Class="pa-5">
            <MudText Typo="Typo.h6" Class="mb-3">Availability by item and warehouse</MudText>
            @if (_dashboard.AvailabilityRows.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="text-secondary">
                    No tracked inventory balances exist yet. Post a purchase receipt or sales issue to start building stock truth.
                </MudText>
            }
            else
            {
                <MudTable Items="_dashboard.AvailabilityRows" Dense="true" Hover="true" Bordered="true">
                    <HeaderContent>
                        <MudTh>Item</MudTh>
                        <MudTh>Warehouse</MudTh>
                        <MudTh>On hand</MudTh>
                        <MudTh>Reserved</MudTh>
                        <MudTh>Available</MudTh>
                        <MudTh>In transit out</MudTh>
                        <MudTh>In transit in</MudTh>
                        <MudTh>Cost balance</MudTh>
                        <MudTh>Last movement</MudTh>
                        <MudTh>Focus</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.ItemCode - @context.ItemName</MudTd>
                        <MudTd>@context.WarehouseCode - @context.WarehouseName</MudTd>
                        <MudTd>@context.OnHandQty</MudTd>
                        <MudTd>@context.ReservedQty</MudTd>
                        <MudTd>@context.AvailableQty</MudTd>
                        <MudTd>@context.InTransitOutQty</MudTd>
                        <MudTd>@context.InTransitInQty</MudTd>
                        <MudTd>@context.CostBalanceBase</MudTd>
                        <MudTd>@(context.LastMovementAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</MudTd>
                        <MudTd>
                            <MudButton Variant="Variant.Text"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="@(() => FocusRowAsync(context))">
                                Focus
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>

        <MudPaper Elevation="0" Class="pa-5">
            <MudText Typo="Typo.h6" Class="mb-3">Recent stock ledger entries</MudText>
            @if (_dashboard.RecentLedgerEntries.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="text-secondary">
                    No stock-ledger rows exist yet.
                </MudText>
            }
            else
            {
                <MudTable Items="_dashboard.RecentLedgerEntries" Dense="true" Hover="true" Bordered="true">
                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh>Movement</MudTh>
                        <MudTh>Item</MudTh>
                        <MudTh>Warehouse</MudTh>
                        <MudTh>Document</MudTh>
                        <MudTh>Qty delta</MudTh>
                        <MudTh>Qty after</MudTh>
                        <MudTh>Cost delta</MudTh>
                        <MudTh>Cost after</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.PostingDate.ToString("yyyy-MM-dd")</MudTd>
                        <MudTd>@context.MovementType (@context.MovementDirection)</MudTd>
                        <MudTd>@context.ItemCode - @context.ItemName</MudTd>
                        <MudTd>@context.WarehouseCode - @context.WarehouseName</MudTd>
                        <MudTd>@context.DocumentNumber</MudTd>
                        <MudTd>@context.QuantityDelta</MudTd>
                        <MudTd>@context.QuantityAfter</MudTd>
                        <MudTd>@context.CostAmountDeltaBase</MudTd>
                        <MudTd>@context.CostAmountAfterBase</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>

        @if (_dashboard.DrillDown is not null)
        {
            <MudPaper Elevation="0" Class="pa-5">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">Drill-down review</MudText>
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                        @if (!string.IsNullOrWhiteSpace(_dashboard.DrillDown.ItemDisplayText))
                        {
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                                @_dashboard.DrillDown.ItemDisplayText
                            </MudChip>
                        }
                        @if (!string.IsNullOrWhiteSpace(_dashboard.DrillDown.WarehouseDisplayText))
                        {
                            <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Small">
                                @_dashboard.DrillDown.WarehouseDisplayText
                            </MudChip>
                        }
                    </MudStack>

                    <MudText Typo="Typo.body2" Class="text-secondary">
                        Matching balances: @_dashboard.DrillDown.MatchingBalances.Count. Matching ledger rows: @_dashboard.DrillDown.LedgerEntries.Count.
                    </MudText>

                    @if (_dashboard.DrillDown.MatchingBalances.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                            No balance rows currently match the selected drill-down filter.
                        </MudAlert>
                    }
                    else
                    {
                        <MudTable Items="_dashboard.DrillDown.MatchingBalances" Dense="true" Hover="true" Bordered="true">
                            <HeaderContent>
                                <MudTh>Item</MudTh>
                                <MudTh>Warehouse</MudTh>
                                <MudTh>On hand</MudTh>
                                <MudTh>Reserved</MudTh>
                                <MudTh>Available</MudTh>
                                <MudTh>Cost balance</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.ItemCode - @context.ItemName</MudTd>
                                <MudTd>@context.WarehouseCode - @context.WarehouseName</MudTd>
                                <MudTd>@context.OnHandQty</MudTd>
                                <MudTd>@context.ReservedQty</MudTd>
                                <MudTd>@context.AvailableQty</MudTd>
                                <MudTd>@context.CostBalanceBase</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }

                    @if (_dashboard.DrillDown.LedgerEntries.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                            No stock-ledger entries currently match the selected drill-down filter.
                        </MudAlert>
                    }
                    else
                    {
                        <MudTable Items="_dashboard.DrillDown.LedgerEntries" Dense="true" Hover="true" Bordered="true">
                            <HeaderContent>
                                <MudTh>Date</MudTh>
                                <MudTh>Movement</MudTh>
                                <MudTh>Document</MudTh>
                                <MudTh>Qty delta</MudTh>
                                <MudTh>Qty after</MudTh>
                                <MudTh>Cost delta</MudTh>
                                <MudTh>Cost after</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.PostingDate.ToString("yyyy-MM-dd")</MudTd>
                                <MudTd>@context.MovementType (@context.MovementDirection)</MudTd>
                                <MudTd>@context.DocumentNumber</MudTd>
                                <MudTd>@context.QuantityDelta</MudTd>
                                <MudTd>@context.QuantityAfter</MudTd>
                                <MudTd>@context.CostAmountDeltaBase</MudTd>
                                <MudTd>@context.CostAmountAfterBase</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudStack>
            </MudPaper>
        }

        <MudPaper Elevation="0" Class="pa-5">
            <MudText Typo="Typo.h6" Class="mb-3">Recommended next workspaces</MudText>
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/company/inventory-foundation">
                    Back To Inventory Foundation
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Success" Href="/company/inventory-purchase-receipt">
                    Receipt Control
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" Href="/company/inventory-sales-issue">
                    Sales Issue
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" Href="/">
                    Back To Workspace
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</div>

@code {
    private InventoryAvailabilityDashboard? _dashboard;
    private WebShellCompanyOnboardingSummary? _onboardingSummary;
    private string? _error;
    private Guid? _selectedItemId;
    private Guid? _selectedWarehouseId;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _error = null;
            await ShellState.EnsureHydratedAsync();

            var probe = await SessionClient.ProbeContextAsync();
            if (await SessionExpirationCoordinator.HandleProbeAsync(probe))
            {
                return;
            }

            var onboardingResult = await OnboardingClient.GetAsync();
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(onboardingResult, CancellationToken.None))
            {
                return;
            }

            if (!onboardingResult.RequiresSignIn &&
                !onboardingResult.IsNotFound &&
                string.IsNullOrWhiteSpace(onboardingResult.ErrorMessage))
            {
                _onboardingSummary = onboardingResult.Value;
            }

            if (_onboardingSummary is not null && !_onboardingSummary.SupportsInventoryFoundation)
            {
                return;
            }

            _dashboard = await InventoryReporting.GetAvailabilityDashboardAsync(
                ShellState.ActiveCompany.Id,
                BuildFilter());
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private InventoryAvailabilityFilter BuildFilter() =>
        new(_selectedItemId, _selectedWarehouseId);

    private async Task ApplyDrillDownAsync()
    {
        await LoadAsync();
    }

    private async Task ClearDrillDownAsync()
    {
        _selectedItemId = null;
        _selectedWarehouseId = null;
        await LoadAsync();
    }

    private async Task FocusRowAsync(InventoryItemAvailabilitySummary row)
    {
        _selectedItemId = row.ItemId;
        _selectedWarehouseId = row.WarehouseId;
        await LoadAsync();
    }
}
