    private static string BuildReceiptInventoryActivationSummary(ShellReceiptInventoryActivationSummary summary) =>
        summary.ActivationStatus.Trim().ToLowerInvariant() switch
        {
            "activated" => $"{summary.ActivatedLineCount}/{summary.ReceiptLineCount} line(s), {summary.ActivatedQuantity:N2}/{summary.TotalQuantity:N2} quantity activated.",
            "partially_activated" => $"{summary.ActivatedLineCount}/{summary.ReceiptLineCount} line(s) activated; retry after resolving remaining receipt activation blockers.",
            "failed" => string.IsNullOrWhiteSpace(summary.LastFailureMessage)
                ? "Inventory activation failed. Review receipt lines and retry."
                : $"Inventory activation failed: {summary.LastFailureMessage}",
            _ => $"{summary.ActivatedLineCount}/{summary.ReceiptLineCount} line(s), status {FormatReceiptControlStatus(summary.ActivationStatus)}."
        };

