    private static Severity GetBillReceiptProjectedSeverity(string? matchStatus) =>
        matchStatus switch
        {
            "fully_receipted" => Severity.Success,
            "over_receipted" => Severity.Warning,
            "partially_receipted" => Severity.Info,
            "no_receipt" => Severity.Info,
            _ => Severity.Info
        };

    private string BuildBillReceiptPostedNotice(InventoryBillReceiptHandoffSummary summary) =>
        summary.MatchStatus switch
        {
            "fully_receipted" => "This posted receipt brings the bill hand-off into full receipt coverage.",
            "partially_receipted" => $"This posted receipt advanced receipt truth, but {summary.RemainingQuantity:N2} quantity still remains outstanding on the bill hand-off.",
            "over_receipted" => "Receipt truth now exceeds the bill hand-off quantity. Review the bill-side matching trail before continuing.",
            "no_inventory_handoff" => "The bill still has no complete inventory hand-off lines, so this receipt remains inventory-owned without bill-side quantity matching.",
            _ => "Receipt truth was posted successfully. Review the anchored bill match status before continuing AP-side work."
        };

    private (string Label, string Summary) ComputeProjectedBillReceiptStatus()
    {
        if (_billReceiptHandoffSummary is null)
        {
            return ("Awaiting bill truth", "No bill-assisted receipt projection is active in the current context.");
        }

        if (_billReceiptHandoffSummary.BillInboundLineCount == 0)
        {
            return ("No inventory hand-off", "The bill has no complete inventory-grade inbound lines, so receipt projection is not active.");
        }

        var projectedRemaining = decimal.Round(
            _billReceiptHandoffSummary.BillInboundQuantity - ProjectedReceiptedQuantity,
            6,
            MidpointRounding.AwayFromZero);

        if (ProjectedReceiptedQuantity <= 0m)
        {
            return ("No receipt yet", "No inbound quantity has been receipted yet against this bill anchor.");
        }

        if (projectedRemaining > 0m)
        {
            return ("Still partial", "Posting the current receipt would still leave some bill hand-off quantity unreceipted.");
        }

        if (projectedRemaining == 0m)
        {
            return ("Would fully receipt", "Posting the current receipt would bring the bill hand-off quantity into full receipt coverage.");
        }

        return ("Would over-receipt", "Posting the current receipt would push total receipted quantity above the bill hand-off quantity and should be reviewed carefully.");
    }

    private static bool IsGrIrClearingAccountCandidate(JournalEntryAccountOption account) =>
        account.AllowManualPosting &&
        string.Equals(account.RootType, "liability", StringComparison.OrdinalIgnoreCase);

    private static bool IsPreferredGrIrClearingAccountCandidate(JournalEntryAccountOption account)
    {
        var text = $"{account.Code} {account.Name} {account.DetailType} {account.TypeLabel}".ToLowerInvariant();
        return text.Contains("gr/ir", StringComparison.Ordinal) ||
               text.Contains("grir", StringComparison.Ordinal) ||
               text.Contains("clearing", StringComparison.Ordinal) ||
               text.Contains("receiving", StringComparison.Ordinal) ||
               text.Contains("accrual", StringComparison.Ordinal) ||
               text.Contains("payable", StringComparison.Ordinal);
    }

    private static JournalEntryAccountOption? ResolveDefaultGrIrClearingAccount(IReadOnlyList<JournalEntryAccountOption> accounts) =>
        accounts.FirstOrDefault(IsPreferredGrIrClearingAccountCandidate) ?? accounts.FirstOrDefault();

    private static string FormatGrIrClearingAccountOption(JournalEntryAccountOption account)
    {
        var rootLabel = FormatAccountRootType(account.RootType);
        return $"{account.DisplayText} | {rootLabel} / {account.TypeLabel}";
    }

    private static string FormatAccountRootType(string? rootType) =>
        rootType?.Trim().ToLowerInvariant() switch
        {
            "asset" => "Asset",
            "liability" => "Liability",
            "equity" => "Equity",
            "revenue" => "Revenue",
            "income" => "Income",
            "cost_of_sales" => "Cost Of Sales",
            "expense" => "Expense",
            _ => string.IsNullOrWhiteSpace(rootType) ? "Unknown" : rootType
        };

