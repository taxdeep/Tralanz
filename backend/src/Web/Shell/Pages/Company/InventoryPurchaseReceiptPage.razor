@page "/company/inventory-purchase-receipt"
@using Citus.Modules.Inventory.Application.Contracts
@using Citus.Modules.Inventory.Domain.Shared
@using Modules.GL.JournalEntry
@using Web.Shell.Services
@rendermode InteractiveServer
@inject WebShellState ShellState
@inject WebShellBusinessSessionClient SessionClient
@inject WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject WebShellCompanyOnboardingClient OnboardingClient
@inject ShellCounterpartyOnboardingClient CounterpartyClient
@inject ShellInventoryReceiptClient InventoryReceipt
@inject IJournalEntryAccountCatalog AccountCatalog
@inject ShellAccountingDocumentReviewClient ReviewClient
@inject ShellSourceDocumentDraftClient Drafts
@inject ISnackbar Snackbar

<PageTitle>Receipt Control</PageTitle>

<div style="padding:1.75rem;display:grid;gap:1rem;">
    <MudPaper Elevation="0" Class="pa-5">
        <MudStack Spacing="2">
            <MudText Typo="Typo.overline" Class="text-secondary">Inventory Receipt Control</MudText>
            <MudText Typo="Typo.h4">Receipt Control</MudText>
            <MudText Typo="Typo.body1" Class="text-secondary">
                Review posted receipt truth, configure GR/IR clearing policy, and run downstream inventory, GR/IR, AP settlement, and purchase variance control commands. New inbound receipt entry now starts in the governed Receipt Draft workbench.
            </MudText>
            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                    @ShellState.ActiveCompany.CompanyName (@ShellState.ActiveCompany.CompanyCode)
                </MudChip>
                <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">
                    @ShellState.User.DisplayName
                </MudChip>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (IsCompanyReadyHandOff)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true">
            Company-ready hand-off brought you into receipt control. Start new inbound receipt truth from the Receipt Draft workbench, then return here for GR/IR and PPV control.
        </MudAlert>
    }

    @if (IsBillHandoff && !string.IsNullOrWhiteSpace(_billSourceDisplayNumber))
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
            Bill-assisted hand-off loaded <strong>@_billSourceDisplayNumber</strong>. New receipt creation has moved to the governed Receipt Draft workbench.
        </MudAlert>
    }
    @if (IsBillHandoff && _billReceiptHandoffSummary is not null)
    {
        <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Href="@BuildFirstClassReceiptDraftHref()"
                       Disabled="@(_isSaving || WritesBlocked)">
                Open Receipt Draft
            </MudButton>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));gap:1rem;">
            <MudPaper Elevation="0" Class="pa-4">
                <MudText Typo="Typo.caption" Class="text-secondary">Bill hand-off qty</MudText>
                <MudText Typo="Typo.h6">@_billReceiptHandoffSummary.BillInboundQuantity.ToString("N2")</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@_billReceiptHandoffSummary.BillInboundLineCount inventory-grade line(s)</MudText>
            </MudPaper>
            <MudPaper Elevation="0" Class="pa-4">
                <MudText Typo="Typo.caption" Class="text-secondary">Already receipted</MudText>
                <MudText Typo="Typo.h6">@_billReceiptHandoffSummary.ReceivedQuantity.ToString("N2")</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@_billReceiptHandoffSummary.ReceiptCount anchored receipt(s)</MudText>
            </MudPaper>
            <MudPaper Elevation="0" Class="pa-4">
                <MudText Typo="Typo.caption" Class="text-secondary">Remaining qty</MudText>
                <MudText Typo="Typo.h6">@_billReceiptHandoffSummary.RemainingQuantity.ToString("N2")</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">Draft the remaining receipt from the governed workbench.</MudText>
            </MudPaper>
            <MudPaper Elevation="0" Class="pa-4">
                <MudText Typo="Typo.caption" Class="text-secondary">Current match status</MudText>
                <MudText Typo="Typo.h6">@FormatBillReceiptLineStatus(_billReceiptHandoffSummary.MatchStatus)</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">Receipt control stays read-only until draft truth is posted.</MudText>
            </MudPaper>
        </div>
        @if (_billReceiptHandoffSummary.LineSummaries.Count > 0)
        {
            <MudTable Items="_billReceiptHandoffSummary.LineSummaries" Dense="true" Hover="true" Bordered="true">
                <HeaderContent>
                    <MudTh>Item</MudTh>
                    <MudTh>Warehouse</MudTh>
                    <MudTh>UOM</MudTh>
                    <MudTh>Bill Qty</MudTh>
                    <MudTh>Receipted Qty</MudTh>
                    <MudTh>Remaining</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@($"{context.ItemCode} - {context.ItemName}")</MudTd>
                    <MudTd>@($"{context.WarehouseCode} - {context.WarehouseName}")</MudTd>
                    <MudTd>@context.UomCode</MudTd>
                    <MudTd>@context.BillQuantity.ToString("N2")</MudTd>
                    <MudTd>@context.ReceivedQuantity.ToString("N2")</MudTd>
                    <MudTd>@context.RemainingQuantity.ToString("N2")</MudTd>
                    <MudTd>@FormatBillReceiptLineStatus(context.MatchStatus)</MudTd>
                </RowTemplate>
            </MudTable>
        }
    }
    @if (IsBillHandoff && _loadedBillSourceId.HasValue && _loadedBillHandoffLineCount == 0)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
            The selected bill did not contain any complete inventory hand-off lines. Open the bill workbench and complete item, warehouse, UOM, quantity, and cost hand-off before drafting a receipt.
        </MudAlert>
    }
    @if (IsBillHandoff && _billReceiptHandoffSummary is not null && !HasOutstandingBillReceiptQuantity)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
            The current bill hand-off is already fully covered by anchored receipt truth. Continue with receipt control review instead of creating another inbound receipt.
        </MudAlert>
    }
    @if (_lastPostedReceipt is not null)
    {
        <MudPaper Elevation="0" Class="pa-4">
            <MudText Typo="Typo.h6">Posted Receipt Review</MudText>
            <MudText Typo="Typo.body2">Receipt: @_lastPostedReceipt.DocumentNumber</MudText>
            <MudText Typo="Typo.body2">Posting date: @_lastPostedReceipt.PostingDate.ToString("yyyy-MM-dd")</MudText>
            <MudText Typo="Typo.body2">Qty: @_lastPostedReceipt.TotalQuantity.ToString("N2")</MudText>
            <MudText Typo="Typo.body2">Cost (Base): @_lastPostedReceipt.TotalCostBase.ToString("N2")</MudText>
            @if (_billReceiptHandoffSummary is not null)
            {
                <MudAlert Severity="@GetBillReceiptProjectedSeverity(_billReceiptHandoffSummary.MatchStatus)" Variant="Variant.Outlined" Dense="true" Style="margin-top:.75rem;">
                    @BuildBillReceiptPostedNotice(_billReceiptHandoffSummary)
                </MudAlert>
            }
            <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:.75rem;">
                @if (_loadedBillSourceId.HasValue)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" Href="@BuildBillReviewHref()">
                        Review Bill Matching
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Info" Href="@BuildBillDetailHref()">
                        Open Bill Detail
                    </MudButton>
                }
            </div>
        </MudPaper>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
            @_error
        </MudAlert>
    }
    else if (_onboardingSummary is not null && !_onboardingSummary.SupportsInventoryFoundation)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            Receipt Control is closed by default for <strong>@_onboardingSummary.Industry</strong> companies. Keep using lighter service-led setup until company governance opens inventory-managed trading flow.
        </MudAlert>

        <MudPaper Elevation="0" Class="pa-5">
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="/company/product-service-setup">
                    Open Product & Service Setup
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" Href="/">
                    Back To Workspace
                </MudButton>
            </MudStack>
        </MudPaper>
    }

    @if (_onboardingSummary is not null && _onboardingSummary.SupportsInventoryFoundation && WritesBlocked)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
            @ShellState.WriteBlockMessage
        </MudAlert>
    }

    @if (_onboardingSummary is not null && !_onboardingSummary.SupportsInventoryFoundation)
    {
    }
    else if (_dashboard is null || _counterpartySummary is null)
    {
        <MudPaper Elevation="0" Class="pa-5">
            <MudProgressLinear Indeterminate="true" Color="Color.Info" />
        </MudPaper>
    }
    else
    {
        @if (ReceiptId.HasValue)
        {
            <MudAlert Severity="@GetFocusedReceiptSeverity()" Variant="Variant.Outlined" Dense="true">
                @BuildFocusedReceiptMessage()
            </MudAlert>
        }

        <MudGrid>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-4" Style="height:100%;">
                    <MudText Typo="Typo.caption" Class="text-secondary">Active stock items</MudText>
                    <MudText Typo="Typo.h5">@OperationalItems.Count</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        Only warehouse-managed stock items can be received into inventory in this stage.
                    </MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-4" Style="height:100%;">
                    <MudText Typo="Typo.caption" Class="text-secondary">Active warehouses</MudText>
                    <MudText Typo="Typo.h5">@_dashboard.ActiveWarehouses.Count</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        Receipt draft lines must land in one active warehouse.
                    </MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-4" Style="height:100%;">
                    <MudText Typo="Typo.caption" Class="text-secondary">Recent receipts</MudText>
                    <MudText Typo="Typo.h5">@_dashboard.RecentReceipts.Count</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        Base currency is @_dashboard.BaseCurrencyCode.
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
            Operational guardrail: tracked lot/serial flows are still closed here. Receipt Draft currently exposes only warehouse-managed stock items until tracked inbound document input is ready.
        </MudAlert>

        <MudPaper Elevation="0" Class="pa-5">
            <MudStack Spacing="2">
                <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <div>
                        <MudText Typo="Typo.overline" Class="text-secondary">GR/IR control</MudText>
                        <MudText Typo="Typo.h6">Clearing Account Policy</MudText>
                    </div>
                    @if (_savedGrIrClearingAccountId.HasValue)
                    {
                        <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small">
                            Policy configured
                        </MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">
                            Policy pending
                        </MudChip>
                    }
                </MudStack>

                <MudText Typo="Typo.body2" Class="text-secondary">
                    Select the default liability account used when receipt GR/IR bridge batches are posted.
                </MudText>

                @if (!string.IsNullOrWhiteSpace(_grIrClearingPolicyMessage))
                {
                    <MudAlert Severity="_grIrClearingPolicySeverity" Variant="Variant.Outlined" Dense="true">
                        @_grIrClearingPolicyMessage
                    </MudAlert>
                }

                @if (_grIrClearingAccountOptions.Count == 0)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                        No active liability manual-posting account is available yet. Create or activate one before posting receipt GR/IR bridge batches.
                    </MudAlert>
                }
                else
                {
                    <MudGrid>
                        <MudItem xs="12" md="8">
                            <MudSelect T="string"
                                       Label="Default GR/IR clearing account"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Disabled="@(_isGrIrClearingPolicySaving || WritesBlocked)"
                                       @bind-Value="_selectedGrIrClearingAccountIdText">
                                @foreach (var account in _grIrClearingAccountOptions)
                                {
                                    <MudSelectItem T="string" Value="@account.AccountId.ToString("D")">@FormatGrIrClearingAccountOption(account)</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="4" Style="display:flex;align-items:center;">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="@(_isGrIrClearingPolicySaving || WritesBlocked || string.IsNullOrWhiteSpace(_selectedGrIrClearingAccountIdText))"
                                       OnClick="SaveGrIrClearingAccountPolicyAsync">
                                @(_isGrIrClearingPolicySaving ? "Saving..." : "Save Policy")
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                }
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="0" Class="pa-5">
            <MudStack Spacing="2">
                <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <div>
                        <MudText Typo="Typo.overline" Class="text-secondary">Receipt creation path</MudText>
                        <MudText Typo="Typo.h6">Use Receipt Draft for new inbound truth</MudText>
                    </div>
                    <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">
                        Legacy direct posting closed
                    </MudChip>
                </MudStack>
                <MudText Typo="Typo.body2" Class="text-secondary">
                    Manual receipt entry now belongs to the first-class Receipt Draft workbench so PO anchors, bill receipt matching, draft review, and posting controls use one governed document path. This page remains the control surface for posted receipts and GR/IR follow-up.
                </MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Href="@BuildFirstClassReceiptDraftHref()"
                               Disabled="@(_isSaving || WritesBlocked)">
                        New Receipt Draft
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Info"
                               Href="/documents/source-browser?sourceType=receipt">
                        Browse Receipts
                    </MudButton>
                    <MudButton Variant="Variant.Text"
                               Color="Color.Default"
                               Href="/documents/source-browser?sourceType=purchase_order">
                        Start From PO
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="0" Class="pa-5">
            <MudText Typo="Typo.h6" Class="mb-3">Recent purchase receipts</MudText>
            @if (_isReceiptControlCommandRunning)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Warning" Style="margin-bottom:1rem;" />
            }
            @if (!string.IsNullOrWhiteSpace(_receiptControlCommandMessage))
            {
                <MudAlert Severity="_receiptControlCommandSeverity" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                    @_receiptControlCommandMessage
                </MudAlert>
            }
            @if (_dashboard.RecentReceipts.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="text-secondary">No inventory purchase receipts have been posted yet.</MudText>
            }
            else
            {
                <MudTable Items="_dashboard.RecentReceipts" Dense="true" Hover="true" Bordered="true">
                    <HeaderContent>
                        <MudTh>Receipt</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Vendor</MudTh>
                        <MudTh>Currency</MudTh>
                        <MudTh>Qty</MudTh>
                        <MudTh>Cost (Base)</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>GR/IR & PPV Control</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2">@context.DocumentNumber</MudText>
                                @if (IsFocusedReceipt(context.Id))
                                {
                                    <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small" Style="width:max-content;margin-top:.25rem;">
                                        Focused receipt
                                    </MudChip>
                                }
                            </MudStack>
                        </MudTd>
                        <MudTd>@context.PostingDate.ToString("yyyy-MM-dd")</MudTd>
                        <MudTd>@context.VendorDisplayName</MudTd>
                        <MudTd>@context.TransactionCurrencyCode</MudTd>
                        <MudTd>@context.TotalQuantity</MudTd>
                        <MudTd>@context.TotalCostBase</MudTd>
                        <MudTd>@context.Status</MudTd>
                        <MudTd>
                                <MudStack Spacing="1">
                                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                    <MudChip T="string"
                                             Color="@GetReceiptInventoryActivationColor(context.Id)"
                                             Variant="Variant.Outlined"
                                             Size="Size.Small">
                                        @GetReceiptInventoryActivationTitle(context.Id)
                                    </MudChip>
                                    <MudChip T="string"
                                             Color="@GetReceiptInventoryValuationColor(context.Id)"
                                             Variant="Variant.Outlined"
                                             Size="Size.Small">
                                        @GetReceiptInventoryValuationTitle(context.Id)
                                    </MudChip>
                                    <MudChip T="string"
                                             Color="@GetReceiptCostLayerEmissionColor(context.Id)"
                                             Variant="Variant.Outlined"
                                             Size="Size.Small">
                                        @GetReceiptCostLayerEmissionTitle(context.Id)
                                    </MudChip>
                                    <MudChip T="string"
                                             Color="@GetReceiptGrIrBridgeColor(context.Id)"
                                             Variant="Variant.Outlined"
                                             Size="Size.Small">
                                        @GetReceiptGrIrBridgeTitle(context.Id)
                                    </MudChip>
                                    <MudChip T="string"
                                             Color="@GetReceiptGrIrSettlementColor(context.Id)"
                                             Variant="Variant.Outlined"
                                             Size="Size.Small">
                                        @GetReceiptGrIrSettlementTitle(context.Id)
                                    </MudChip>
                                    <MudChip T="string"
                                             Color="@GetReceiptPurchaseVarianceColor(context.Id)"
                                             Variant="Variant.Outlined"
                                             Size="Size.Small">
                                        @GetReceiptPurchaseVarianceTitle(context.Id)
                                    </MudChip>
                                </MudStack>
                                <MudText Typo="Typo.caption">@GetReceiptInventoryActivationDetail(context.Id)</MudText>
                                <MudText Typo="Typo.caption">@GetReceiptInventoryValuationDetail(context.Id)</MudText>
                                <MudText Typo="Typo.caption">@GetReceiptCostLayerEmissionDetail(context.Id)</MudText>
                                <MudText Typo="Typo.caption">@GetReceiptGrIrBridgeDetail(context.Id)</MudText>
                                <MudText Typo="Typo.caption">@GetReceiptGrIrSettlementDetail(context.Id)</MudText>
                                <MudText Typo="Typo.caption">@GetReceiptPurchaseVarianceDetail(context.Id)</MudText>
                                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Success"
                                               Size="Size.Small"
                                               Disabled="@(_isReceiptControlCommandRunning || WritesBlocked)"
                                               OnClick="@(() => RetryReceiptInventoryActivationAsync(context))">
                                        Retry Activation
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Success"
                                               Size="Size.Small"
                                               Disabled="@(_isReceiptControlCommandRunning || WritesBlocked)"
                                               OnClick="@(() => RefreshReceiptInventoryValuationAsync(context))">
                                        Refresh Valuation
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Success"
                                               Size="Size.Small"
                                               Disabled="@(_isReceiptControlCommandRunning || WritesBlocked)"
                                               OnClick="@(() => EmitReceiptInventoryCostLayersAsync(context))">
                                        Emit Layers
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Info"
                                               Size="Size.Small"
                                               Disabled="@(_isReceiptControlCommandRunning || WritesBlocked)"
                                               OnClick="@(() => RefreshReceiptGrIrBridgeAsync(context))">
                                        Refresh Bridge
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Info"
                                               Size="Size.Small"
                                               Disabled="@(_isReceiptControlCommandRunning || WritesBlocked)"
                                               OnClick="@(() => PostReceiptGrIrBridgeAsync(context))">
                                        Post Bridge
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               Disabled="@_isReceiptControlCommandRunning"
                                               OnClick="@(() => LoadReceiptGrIrSettlementBatchesAsync(context))">
                                        Load Batches
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               Disabled="@(_isReceiptControlCommandRunning || WritesBlocked)"
                                               OnClick="@(() => RefreshReceiptGrIrSettlementAsync(context))">
                                        Refresh Settlement
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               Disabled="@(_isReceiptControlCommandRunning || WritesBlocked)"
                                               OnClick="@(() => ExecuteReceiptGrIrSettlementAsync(context))">
                                        Execute Settlement
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Secondary"
                                               Size="Size.Small"
                                               Disabled="@(_isReceiptControlCommandRunning || WritesBlocked)"
                                               OnClick="@(() => RefreshReceiptGrIrJournalReconciliationAsync(context))">
                                        Refresh Journal
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Warning"
                                               Size="Size.Small"
                                               Disabled="@(_isReceiptControlCommandRunning || WritesBlocked)"
                                               OnClick="@(() => RefreshReceiptPurchaseVarianceAsync(context))">
                                        Refresh PPV
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Warning"
                                               Size="Size.Small"
                                               Disabled="@_isReceiptControlCommandRunning"
                                               OnClick="@(() => LoadReceiptPurchaseVarianceLinesAsync(context))">
                                        Load PPV Lines
                                    </MudButton>
                                </MudStack>
                                @if (GetReceiptGrIrSettlementBatches(context.Id).Count > 0)
                                {
                                    <MudTable Items="@GetReceiptGrIrSettlementBatches(context.Id)"
                                              Dense="true"
                                              Hover="true"
                                              Elevation="0"
                                              Class="mt-2">
                                        <HeaderContent>
                                            <MudTh>Batch</MudTh>
                                            <MudTh>Amount</MudTh>
                                            <MudTh>Journal</MudTh>
                                            <MudTh>AP Clearing</MudTh>
                                            <MudTh>Actions</MudTh>
                                        </HeaderContent>
                                        <RowTemplate Context="batch">
                                            <MudTd>@batch.SettlementBatchId.ToString("N")[..8]</MudTd>
                                            <MudTd>@batch.SettledAmountBase.ToString("N2")</MudTd>
                                            <MudTd>@FormatReceiptGrIrJournalStatus(batch.JournalStatus)</MudTd>
                                            <MudTd>@FormatReceiptGrIrOpenItemClearingStatus(batch.OpenItemClearingStatus)</MudTd>
                                            <MudTd>
                                                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                                    <MudButton Variant="Variant.Text"
                                                               Color="Color.Secondary"
                                                               Size="Size.Small"
                                                               Disabled="@(_isReceiptControlCommandRunning || WritesBlocked)"
                                                               OnClick="@(() => PostReceiptGrIrSettlementJournalAsync(batch))">
                                                        Post Journal
                                                    </MudButton>
                                                    <MudButton Variant="Variant.Text"
                                                               Color="Color.Success"
                                                               Size="Size.Small"
                                                               Disabled="@(_isReceiptControlCommandRunning || WritesBlocked)"
                                                               OnClick="@(() => ClearReceiptGrIrSettlementOpenItemAsync(batch))">
                                                        Clear AP
                                                    </MudButton>
                                                    <MudButton Variant="Variant.Text"
                                                               Color="Color.Warning"
                                                               Size="Size.Small"
                                                               Disabled="@(_isReceiptControlCommandRunning || WritesBlocked)"
                                                               OnClick="@(() => ReverseReceiptGrIrSettlementOpenItemAsync(batch))">
                                                        Reverse AP
                                                    </MudButton>
                                                </MudStack>
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                                @if (GetReceiptPurchaseVarianceLines(context.Id).Count > 0)
                                {
                                    <MudTable Items="@GetReceiptPurchaseVarianceLines(context.Id)"
                                              Dense="true"
                                              Hover="true"
                                              Elevation="0"
                                              Class="mt-2">
                                        <HeaderContent>
                                            <MudTh>Receipt Line</MudTh>
                                            <MudTh>Bill Line</MudTh>
                                            <MudTh>Qty</MudTh>
                                            <MudTh>GR/IR</MudTh>
                                            <MudTh>Bill</MudTh>
                                            <MudTh>Variance</MudTh>
                                            <MudTh>Status</MudTh>
                                        </HeaderContent>
                                        <RowTemplate Context="variance">
                                            <MudTd>@variance.ReceiptLineNumber</MudTd>
                                            <MudTd>@variance.BillLineNumber</MudTd>
                                            <MudTd>@variance.SettledQuantity.ToString("N2") @variance.UomCode</MudTd>
                                            <MudTd>@variance.GrIrAmountBase.ToString("N2")</MudTd>
                                            <MudTd>@variance.BillAmountBase.ToString("N2")</MudTd>
                                            <MudTd>@variance.VarianceAmountBase.ToString("N2")</MudTd>
                                            <MudTd>
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2">@FormatReceiptPurchaseVarianceStatus(variance.VarianceStatus)</MudText>
                                                    @if (!string.IsNullOrWhiteSpace(variance.BlockedReasonCode))
                                                    {
                                                        <MudText Typo="Typo.caption" Class="text-secondary">@variance.BlockedReasonCode</MudText>
                                                    }
                                                </MudStack>
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>

        <MudPaper Elevation="0" Class="pa-5">
            <MudText Typo="Typo.h6" Class="mb-3">Recommended next workspaces</MudText>
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/company/inventory-foundation">
                    Back To Inventory Foundation
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="/company/customer-vendor-setup">
                    Customer & Vendor Setup
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" Href="/">
                    Back To Workspace
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "origin")]
    public string? Origin { get; set; }

    [SupplyParameterFromQuery(Name = "vendorId")]
    public Guid? VendorIdQuery { get; set; }

    [SupplyParameterFromQuery(Name = "billId")]
    public Guid? BillId { get; set; }

    [SupplyParameterFromQuery(Name = "receiptId")]
    public Guid? ReceiptId { get; set; }

    private InventoryPurchaseReceiptDashboard? _dashboard;
    private WebShellCompanyOnboardingSummary? _onboardingSummary;
    private ShellCounterpartyOnboardingSummary? _counterpartySummary;
    private string? _error;
    private bool _isSaving;
    private bool _isReceiptControlCommandRunning;
    private string? _receiptControlCommandMessage;
    private Severity _receiptControlCommandSeverity = Severity.Info;
    private Guid? _selectedVendorId;
    private DateTime? _postingDate = DateTime.Today;
    private string _transactionCurrencyCode = string.Empty;
    private decimal _fxRateToBase = 1m;
    private string? _memo;
    private List<ReceiptLineEditorState> _lineEditors = [];
    private Guid? _loadedBillSourceId;
    private string? _billSourceDisplayNumber;
    private string? _loadedBillSourceStatus;
    private ShellPurchaseSourceDocumentDraftReadModel? _loadedBillDraft;
    private int _loadedBillHandoffLineCount;
    private InventoryBillReceiptHandoffSummary? _billReceiptHandoffSummary;
    private InventoryPurchaseReceiptSummary? _lastPostedReceipt;
    private IReadOnlyDictionary<Guid, ShellReceiptGrIrBridgeSummary> _receiptBridgeSummaries =
        new Dictionary<Guid, ShellReceiptGrIrBridgeSummary>();
    private IReadOnlyDictionary<Guid, ShellReceiptGrIrApSettlementSummary> _receiptSettlementSummaries =
        new Dictionary<Guid, ShellReceiptGrIrApSettlementSummary>();
    private IReadOnlyDictionary<Guid, ShellReceiptInventoryActivationSummary> _receiptActivationSummaries =
        new Dictionary<Guid, ShellReceiptInventoryActivationSummary>();
    private IReadOnlyDictionary<Guid, ShellReceiptInventoryValuationSummary> _receiptValuationSummaries =
        new Dictionary<Guid, ShellReceiptInventoryValuationSummary>();
    private IReadOnlyDictionary<Guid, ShellReceiptInventoryCostLayerEmissionSummary> _receiptCostLayerEmissionSummaries =
        new Dictionary<Guid, ShellReceiptInventoryCostLayerEmissionSummary>();
    private IReadOnlyDictionary<Guid, IReadOnlyList<ShellReceiptGrIrApSettlementBatchSummary>> _receiptSettlementBatchSummaries =
        new Dictionary<Guid, IReadOnlyList<ShellReceiptGrIrApSettlementBatchSummary>>();
    private IReadOnlyDictionary<Guid, IReadOnlyList<ShellReceiptGrIrApPurchaseVarianceLineSummary>> _receiptPurchaseVarianceLineSummaries =
        new Dictionary<Guid, IReadOnlyList<ShellReceiptGrIrApPurchaseVarianceLineSummary>>();
    private IReadOnlyList<JournalEntryAccountOption> _grIrClearingAccountOptions = Array.Empty<JournalEntryAccountOption>();
    private string? _selectedGrIrClearingAccountIdText;
    private Guid? _savedGrIrClearingAccountId;
    private bool _isGrIrClearingPolicySaving;
    private string? _grIrClearingPolicyMessage;
    private Severity _grIrClearingPolicySeverity = Severity.Info;

    private bool IsCompanyReadyHandOff => string.Equals(Origin, "company-ready", StringComparison.OrdinalIgnoreCase);
    private bool IsBillHandoff => BillId.HasValue;
    private bool WritesBlocked => ShellState.AreWritesBlocked;
    private bool IsBaseCurrencySelected =>
        string.Equals(_transactionCurrencyCode, _dashboard?.BaseCurrencyCode, StringComparison.OrdinalIgnoreCase);
    private IReadOnlyList<InventoryManagedItemSummary> OperationalItems =>
        _dashboard?.ActiveItems.Where(item => item.ManageInventoryMethod == ManageInventoryMethod.ManageStock).ToList() ?? [];
    private IReadOnlyList<ShellManagedCounterpartySummary> ActiveVendors => _counterpartySummary?.ActiveVendors ?? [];
    private IReadOnlyList<ShellCompanyCurrencyOption> EnabledCurrencies => _counterpartySummary?.EnabledCurrencies ?? [];
    private InventoryPurchaseReceiptSummary? FocusedReceipt =>
        ReceiptId.HasValue
            ? _dashboard?.RecentReceipts.FirstOrDefault(receipt => receipt.Id == ReceiptId.Value)
            : null;
    private bool HasOutstandingBillReceiptQuantity => _billReceiptHandoffSummary?.LineSummaries.Any(static line => line.RemainingQuantity > 0m) == true;
    private decimal CurrentReceiptDraftQuantity => decimal.Round(_lineEditors.Sum(static line => line.Quantity), 6, MidpointRounding.AwayFromZero);
    private decimal ProjectedReceiptedQuantity => decimal.Round((_billReceiptHandoffSummary?.ReceivedQuantity ?? 0m) + CurrentReceiptDraftQuantity, 6, MidpointRounding.AwayFromZero);
    private string ProjectedBillReceiptStatusLabel => ComputeProjectedBillReceiptStatus().Label;
    private string ProjectedBillReceiptStatusSummary => ComputeProjectedBillReceiptStatus().Summary;
    private static string FormatBillReceiptLineStatus(string? matchStatus) => matchStatus switch
    {
        "no_receipt" => "No receipt yet",
        "partially_receipted" => "Partial",
        "fully_receipted" => "Full",
        "over_receipted" => "Over",
        _ => "Review"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _error = null;
            await ShellState.EnsureHydratedAsync();

            var probe = await SessionClient.ProbeContextAsync();
            if (await SessionExpirationCoordinator.HandleProbeAsync(probe))
            {
                return;
            }

            var onboardingResult = await OnboardingClient.GetAsync();
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(onboardingResult, CancellationToken.None))
            {
                return;
            }

            if (!onboardingResult.RequiresSignIn &&
                !onboardingResult.IsNotFound &&
                string.IsNullOrWhiteSpace(onboardingResult.ErrorMessage))
            {
                _onboardingSummary = onboardingResult.Value;
            }

            if (_onboardingSummary is not null && !_onboardingSummary.SupportsInventoryFoundation)
            {
                return;
            }

            _dashboard = await InventoryReceipt.GetDashboardAsync(ShellState.ActiveCompany.Id);
            _counterpartySummary = await CounterpartyClient.GetSummaryAsync(ShellState.ActiveCompany.Id);
            await LoadGrIrClearingAccountPolicyAsync();
            if (BillId.HasValue && BillId != _loadedBillSourceId)
            {
                await LoadBillHandoffAsync(BillId.Value);
            }

            SeedHeaderDefaults();
            SeedLinesIfNeeded();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task LoadGrIrClearingAccountPolicyAsync()
    {
        _grIrClearingPolicyMessage = null;
        _grIrClearingPolicySeverity = Severity.Info;

        var accounts = await AccountCatalog.ListManualPostingAccountsAsync(ShellState.ActiveCompany.Id, CancellationToken.None);
        _grIrClearingAccountOptions = accounts
            .Where(IsGrIrClearingAccountCandidate)
            .OrderByDescending(IsPreferredGrIrClearingAccountCandidate)
            .ThenBy(static account => account.Code, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        var policyResult = await ReviewClient.GetReceiptGrIrClearingAccountPolicyAsync(
            ShellState.ActiveCompany.Id,
            CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(policyResult, CancellationToken.None))
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(policyResult.ErrorMessage))
        {
            _grIrClearingPolicySeverity = Severity.Warning;
            _grIrClearingPolicyMessage = policyResult.ErrorMessage;
        }

        _savedGrIrClearingAccountId = policyResult.Value?.GrIrClearingAccountId;
        _selectedGrIrClearingAccountIdText =
            _savedGrIrClearingAccountId?.ToString("D")
            ?? ResolveDefaultGrIrClearingAccount(_grIrClearingAccountOptions)?.AccountId.ToString("D");
    }

    private async Task SaveGrIrClearingAccountPolicyAsync()
    {
        if (TryBlockWrites())
        {
            _grIrClearingPolicySeverity = Severity.Warning;
            _grIrClearingPolicyMessage = ShellState.WriteBlockMessage;
            return;
        }

        if (!Guid.TryParse(_selectedGrIrClearingAccountIdText, out var accountId) || accountId == Guid.Empty)
        {
            _grIrClearingPolicySeverity = Severity.Warning;
            _grIrClearingPolicyMessage = "Select a valid liability account before saving the GR/IR clearing policy.";
            return;
        }

        try
        {
            _isGrIrClearingPolicySaving = true;
            _grIrClearingPolicyMessage = null;

            var result = await ReviewClient.SaveReceiptGrIrClearingAccountPolicyAsync(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                accountId,
                CancellationToken.None);
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
            {
                return;
            }

            if (result.Value is null)
            {
                _grIrClearingPolicySeverity = Severity.Warning;
                _grIrClearingPolicyMessage = result.ErrorMessage ?? "GR/IR clearing policy save returned no policy payload.";
                return;
            }

            _savedGrIrClearingAccountId = result.Value.GrIrClearingAccountId;
            _selectedGrIrClearingAccountIdText = result.Value.GrIrClearingAccountId?.ToString("D");
            _grIrClearingPolicySeverity = Severity.Success;
            _grIrClearingPolicyMessage = "GR/IR clearing account policy saved.";
        }
        catch (Exception ex)
        {
            _grIrClearingPolicySeverity = Severity.Error;
            _grIrClearingPolicyMessage = ex.Message;
        }
        finally
        {
            _isGrIrClearingPolicySaving = false;
        }
    }

    private async Task LoadBillHandoffAsync(Guid billId)
    {
        var draftResult = await Drafts.GetBillDraftAsync(ShellState.ActiveCompany.Id, billId, CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(draftResult, CancellationToken.None))
        {
            return;
        }

        var draft = draftResult.Value;
        if (draft is null)
        {
            _error = draftResult.IsNotFound
                ? "The selected bill hand-off could not be found in the active company context."
                : draftResult.ErrorMessage ?? "Unable to load the bill hand-off.";
            return;
        }

        _loadedBillSourceId = draft.Id;
        _loadedBillDraft = draft;
        _billSourceDisplayNumber = draft.DisplayNumber;
        _loadedBillSourceStatus = draft.Status;
        _billReceiptHandoffSummary = await InventoryReceipt.GetBillHandoffSummaryAsync(
            ShellState.ActiveCompany.Id,
            draft.Id,
            CancellationToken.None);

        if (_counterpartySummary is not null &&
            _counterpartySummary.ActiveVendors.Any(vendor => vendor.Id == draft.VendorId))
        {
            _selectedVendorId = draft.VendorId;
        }

        _transactionCurrencyCode = draft.TransactionCurrencyCode;
        _fxRateToBase = draft.FxRate ?? 1m;
        _memo = string.IsNullOrWhiteSpace(draft.Memo)
            ? $"Bill hand-off from {draft.DisplayNumber}"
            : $"Bill hand-off from {draft.DisplayNumber}: {draft.Memo}";

        var receiptLines = BuildReceiptLinesFromBillHandoff(draft);
        _loadedBillHandoffLineCount = receiptLines.Count;

        if (receiptLines.Count > 0)
        {
            _lineEditors = receiptLines;
        }
    }

    private void SeedHeaderDefaults()
    {
        if (_counterpartySummary is null || _dashboard is null)
        {
            return;
        }

        var preferredVendor = VendorIdQuery.HasValue
            ? _counterpartySummary.ActiveVendors.FirstOrDefault(vendor => vendor.Id == VendorIdQuery.Value)
            : null;
        var defaultVendor = preferredVendor ?? _counterpartySummary.ActiveVendors.FirstOrDefault();

        _selectedVendorId ??= defaultVendor?.Id;

        if (string.IsNullOrWhiteSpace(_transactionCurrencyCode))
        {
            _transactionCurrencyCode =
                defaultVendor?.DefaultCurrencyCode
                ?? _counterpartySummary.BaseCurrencyCode
                ?? _dashboard.BaseCurrencyCode;
        }

        if (string.Equals(_transactionCurrencyCode, _dashboard.BaseCurrencyCode, StringComparison.OrdinalIgnoreCase))
        {
            _fxRateToBase = 1m;
        }
    }

    private void SeedLinesIfNeeded()
    {
        if (_dashboard is null || _lineEditors.Count > 0)
        {
            return;
        }

        if (IsBillHandoff && _billReceiptHandoffSummary is not null && !HasOutstandingBillReceiptQuantity)
        {
            return;
        }

        _lineEditors.Add(new ReceiptLineEditorState
        {
            LineNo = 1,
            ItemId = OperationalItems.FirstOrDefault()?.Id,
            WarehouseId = _dashboard.ActiveWarehouses.FirstOrDefault()?.Id,
            UomCode = OperationalItems.FirstOrDefault()?.StockUomCode ?? string.Empty,
            Quantity = 1m,
            UnitCostTx = 0m
        });
    }

    private async Task OnVendorChangedAsync(Guid? vendorId)
    {
        _selectedVendorId = vendorId;
        var vendor = ActiveVendors.FirstOrDefault(item => item.Id == vendorId);
        if (vendor is not null)
        {
            _transactionCurrencyCode = vendor.DefaultCurrencyCode;
            if (_dashboard is not null &&
                string.Equals(_transactionCurrencyCode, _dashboard.BaseCurrencyCode, StringComparison.OrdinalIgnoreCase))
            {
                _fxRateToBase = 1m;
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private void AddLine()
    {
        var nextLineNo = _lineEditors.Count == 0 ? 1 : _lineEditors.Max(line => line.LineNo) + 1;
        _lineEditors.Add(new ReceiptLineEditorState
        {
            LineNo = nextLineNo,
            ItemId = OperationalItems.FirstOrDefault()?.Id,
            WarehouseId = _dashboard?.ActiveWarehouses.FirstOrDefault()?.Id,
            UomCode = OperationalItems.FirstOrDefault()?.StockUomCode ?? string.Empty,
            Quantity = 1m,
            UnitCostTx = 0m
        });
    }

    private void ApplyReceiptItem(ReceiptLineEditorState line, Guid? itemId)
    {
        line.ItemId = itemId;
        var item = OperationalItems.FirstOrDefault(current => current.Id == itemId);
        line.UomCode = item?.StockUomCode ?? string.Empty;
        line.WarehouseId ??= _dashboard?.ActiveWarehouses.FirstOrDefault()?.Id;
        if (line.Quantity <= 0m)
        {
            line.Quantity = 1m;
        }
    }

    private void RemoveLine(ReceiptLineEditorState line)
    {
        _lineEditors.Remove(line);
        for (var index = 0; index < _lineEditors.Count; index++)
        {
            _lineEditors[index].LineNo = index + 1;
        }
    }

    private void ReloadBillRemainingLines()
    {
        if (!IsBillHandoff || _loadedBillSourceId is null)
        {
            return;
        }

        if (TryBlockWrites())
        {
            return;
        }

        var lines = _loadedBillDraft is null
            ? []
            : BuildReceiptLinesFromBillHandoff(_loadedBillDraft);
        _lineEditors = lines;
        if (_lineEditors.Count == 0)
        {
            Snackbar.Add("No remaining bill quantity is outstanding. The receipt form stays empty by default.", Severity.Info);
        }
    }

    private List<ReceiptLineEditorState> BuildReceiptLinesFromBillHandoff(ShellPurchaseSourceDocumentDraftReadModel draft)
    {
        var inboundLines = draft.Lines
            .Where(static line =>
                line.ItemId.HasValue &&
                line.WarehouseId.HasValue &&
                !string.IsNullOrWhiteSpace(line.UomCode) &&
                line.Quantity.HasValue &&
                line.UnitCost.HasValue)
            .ToArray();

        if (inboundLines.Length == 0)
        {
            return [];
        }

        if (_billReceiptHandoffSummary?.LineSummaries.Count > 0)
        {
            var billGroups = inboundLines
                .GroupBy(line => new BillReceiptGroupKey(
                    line.ItemId!.Value,
                    line.WarehouseId!.Value,
                    line.UomCode!.Trim().ToUpperInvariant()))
                .ToDictionary(group => group.Key, group => group.ToArray());

            var groupedLines = _billReceiptHandoffSummary.LineSummaries
                .Where(static summary => summary.RemainingQuantity > 0m)
                .Select(summary =>
                {
                    var key = new BillReceiptGroupKey(summary.ItemId, summary.WarehouseId, summary.UomCode.Trim().ToUpperInvariant());
                    if (!billGroups.TryGetValue(key, out var sourceLines) || sourceLines.Length == 0)
                    {
                        return null;
                    }

                    var totalGroupQuantity = sourceLines.Sum(line => line.Quantity!.Value);
                    var weightedUnitCost = totalGroupQuantity > 0m
                        ? decimal.Round(
                            sourceLines.Sum(line => line.Quantity!.Value * line.UnitCost!.Value) / totalGroupQuantity,
                            6,
                            MidpointRounding.AwayFromZero)
                        : decimal.Round(sourceLines.Average(line => line.UnitCost!.Value), 6, MidpointRounding.AwayFromZero);

                    var lineMemo = sourceLines.Length == 1
                        ? (string?)sourceLines[0].Description
                        : $"Bill hand-off aggregate from {draft.DisplayNumber}";

                    return new ReceiptLineEditorState
                    {
                        ItemId = summary.ItemId,
                        WarehouseId = summary.WarehouseId,
                        UomCode = summary.UomCode,
                        Quantity = summary.RemainingQuantity,
                        UnitCostTx = weightedUnitCost,
                        ReasonCode = "bill_handoff",
                        Memo = lineMemo
                    };
                })
                .Where(static line => line is not null)
                .Select(static line => line!)
                .OrderBy(static line => line.ItemId)
                .ThenBy(static line => line.WarehouseId)
                .ToList();

            for (var index = 0; index < groupedLines.Count; index++)
            {
                groupedLines[index].LineNo = index + 1;
            }

            if (groupedLines.Count > 0)
            {
                return groupedLines;
            }
        }

        return inboundLines
            .Select(line => new ReceiptLineEditorState
            {
                LineNo = line.LineNumber,
                ItemId = line.ItemId,
                WarehouseId = line.WarehouseId,
                UomCode = line.UomCode ?? string.Empty,
                Quantity = line.Quantity ?? 1m,
                UnitCostTx = line.UnitCost ?? 0m,
                ReasonCode = "bill_handoff",
                Memo = line.Description
            })
            .OrderBy(static line => line.LineNo)
            .ToList();
    }

    private async Task PostReceiptAsync()
    {
        if (TryBlockWrites() || _dashboard is null || _counterpartySummary is null)
        {
            return;
        }

        try
        {
            _isSaving = true;
            _error = null;

            var request = new InventoryPurchaseReceiptPostRequest(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                _selectedVendorId ?? Guid.Empty,
                DateOnly.FromDateTime((_postingDate ?? DateTime.Today).Date),
                _transactionCurrencyCode,
                _fxRateToBase,
                SourceModule: IsBillHandoff && _loadedBillSourceId.HasValue ? "ap_bill" : "web_shell_inventory",
                SourceDocumentId: IsBillHandoff ? _loadedBillSourceId : null,
                SourceDocumentNumber: IsBillHandoff ? _billSourceDisplayNumber : null,
                _memo,
                _lineEditors.Select(line => new InventoryPurchaseReceiptLineInput(
                    line.LineNo,
                    line.ItemId ?? Guid.Empty,
                    line.WarehouseId ?? Guid.Empty,
                    line.UomCode,
                    line.Quantity,
                    line.UnitCostTx,
                    line.ReasonCode,
                    line.Memo)).ToArray());

            var receipt = await InventoryReceipt.PostAsync(request, _dashboard, _counterpartySummary);
            await ReloadDashboardAsync();
            _lastPostedReceipt = receipt;
            if (IsBillHandoff && _loadedBillSourceId.HasValue)
            {
                _billReceiptHandoffSummary = await InventoryReceipt.GetBillHandoffSummaryAsync(
                    ShellState.ActiveCompany.Id,
                    _loadedBillSourceId.Value,
                    CancellationToken.None);
            }

            ResetForm(preserveBillContext: IsBillHandoff && _loadedBillSourceId.HasValue);
            Snackbar.Add($"Purchase receipt {receipt.DocumentNumber} posted.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task ReloadDashboardAsync()
    {
        _dashboard = await InventoryReceipt.GetDashboardAsync(ShellState.ActiveCompany.Id);
        _counterpartySummary = await CounterpartyClient.GetSummaryAsync(ShellState.ActiveCompany.Id);
    }

    private async Task RetryReceiptInventoryActivationAsync(InventoryPurchaseReceiptSummary receipt)
    {
        await RunReceiptInventoryControlAsync(
            receipt,
            () => ReviewClient.RetryReceiptInventoryActivationAsync(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                receipt.Id,
                CancellationToken.None),
            "inventory activation",
            result =>
            {
                var summaries = _receiptActivationSummaries.ToDictionary(static item => item.Key, static item => item.Value);
                summaries[receipt.Id] = result;
                _receiptActivationSummaries = summaries;
                return GetReceiptInventoryActivationSeverity(result.ActivationStatus);
            },
            BuildReceiptInventoryActivationSummary);
    }

    private async Task RefreshReceiptInventoryValuationAsync(InventoryPurchaseReceiptSummary receipt)
    {
        await RunReceiptInventoryControlAsync(
            receipt,
            () => ReviewClient.RefreshReceiptInventoryValuationAsync(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                receipt.Id,
                CancellationToken.None),
            "inventory valuation",
            result =>
            {
                var summaries = _receiptValuationSummaries.ToDictionary(static item => item.Key, static item => item.Value);
                summaries[receipt.Id] = result;
                _receiptValuationSummaries = summaries;
                return GetReceiptInventoryValuationSeverity(result.ValuationStatus);
            },
            BuildReceiptInventoryValuationSummary);
    }

    private async Task EmitReceiptInventoryCostLayersAsync(InventoryPurchaseReceiptSummary receipt)
    {
        await RunReceiptInventoryControlAsync(
            receipt,
            () => ReviewClient.EmitReceiptInventoryCostLayersAsync(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                receipt.Id,
                CancellationToken.None),
            "inventory cost-layer emission",
            result =>
            {
                var summaries = _receiptCostLayerEmissionSummaries.ToDictionary(static item => item.Key, static item => item.Value);
                summaries[receipt.Id] = result;
                _receiptCostLayerEmissionSummaries = summaries;
                return GetReceiptCostLayerEmissionSeverity(result.EmissionStatus);
            },
            BuildReceiptCostLayerEmissionSummary);
    }

    private async Task RunReceiptInventoryControlAsync<TSummary>(
        InventoryPurchaseReceiptSummary receipt,
        Func<Task<WebShellAuthenticatedApiResult<TSummary>>> command,
        string controlLabel,
        Func<TSummary, Severity> updateSummary,
        Func<TSummary, string> summaryText)
    {
        if (TryBlockReceiptControlWrites())
        {
            return;
        }

        BeginReceiptControlCommand();

        try
        {
            var result = await command();
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
            {
                return;
            }

            if (result.Value is null)
            {
                _receiptControlCommandSeverity = Severity.Warning;
                _receiptControlCommandMessage = WebShellPostingFeedback.DescribeFailure(
                    result.ErrorCode,
                    result.ErrorMessage,
                    $"Receipt {controlLabel} command did not return a response.");
                return;
