@page "/company/tax-setup"
@using Web.Shell.Services
@rendermode InteractiveServer
@inject WebShellState ShellState
@inject WebShellBusinessSessionClient SessionClient
@inject WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject ShellCompanyTaxSetupClient TaxSetup
@inject ISnackbar Snackbar

<PageTitle>Tax Setup</PageTitle>

<div style="padding:1.75rem;display:grid;gap:1rem;">
    <MudPaper Elevation="0" Class="pa-5">
        <MudStack Spacing="2">
            <MudText Typo="Typo.overline" Class="text-secondary">Company Setup</MudText>
            <MudText Typo="Typo.h4">Tax Operating Setup</MudText>
            <MudText Typo="Typo.body1" Class="text-secondary">
                Govern company-scoped tax codes that drive line-level tax truth, posting semantics, recoverability handling, and backend legality checks.
            </MudText>
            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                    @ShellState.ActiveCompany.CompanyName (@ShellState.ActiveCompany.CompanyCode)
                </MudChip>
                <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">
                    @ShellState.User.DisplayName
                </MudChip>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (IsCompanyReadyHandOff)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true">
            Company-ready hand-off brought you here so you can decide whether taxable invoice and bill activity may begin now or should remain tax-free until proper tax codes exist.
        </MudAlert>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
            @_error
        </MudAlert>
    }

    @if (WritesBlocked)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
            @ShellState.WriteBlockMessage
        </MudAlert>
    }

    @if (_summary is null)
    {
        <MudPaper Elevation="0" Class="pa-5">
            <MudProgressLinear Indeterminate="true" Color="Color.Info" />
        </MudPaper>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-4" Style="height:100%;">
                    <MudText Typo="Typo.caption" Class="text-secondary">Active sales tax codes</MudText>
                    <MudText Typo="Typo.h5">@_summary.SalesTaxCodes.Count</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        @if (_summary.SalesTaxCodes.Count == 0)
                        {
                            <span>No active sales-side tax codes are configured yet.</span>
                        }
                        else
                        {
                            <span>Sales documents can select from @_summary.SalesTaxCodes.Count governed tax code(s).</span>
                        }
                    </MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-4" Style="height:100%;">
                    <MudText Typo="Typo.caption" Class="text-secondary">Active purchase tax codes</MudText>
                    <MudText Typo="Typo.h5">@_summary.PurchaseTaxCodes.Count</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        @if (_summary.PurchaseTaxCodes.Count == 0)
                        {
                            <span>No active purchase-side tax codes are configured yet.</span>
                        }
                        else
                        {
                            <span>Purchase documents can select from @_summary.PurchaseTaxCodes.Count governed tax code(s).</span>
                        }
                    </MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-4" Style="height:100%;">
                    <MudText Typo="Typo.caption" Class="text-secondary">Recoverable purchase modes</MudText>
                    <MudText Typo="Typo.h5">@_summary.RecoverablePurchaseTaxCodeCount</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        @if (_summary.RecoverablePurchaseTaxCodeCount == 0)
                        {
                            <span>No active purchase tax codes currently declare recoverable or partially recoverable input tax.</span>
                        }
                        else
                        {
                            <span>@_summary.RecoverablePurchaseTaxCodeCount purchase code(s) currently carry recoverability semantics.</span>
                        }
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
            Tax code truth is backend-owned. Sales-side tax posts through the chosen tax payable account; purchase-side recoverability is controlled here and then consumed by line-level document truth.
        </MudAlert>

        <MudPaper Elevation="0" Class="pa-5">
            <MudStack Spacing="2">
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h6">@EditorHeading</MudText>
                    @if (_editor.Id.HasValue)
                    {
                        <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">
                            Editing existing tax code
                        </MudChip>
                    }
                </MudStack>

                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string"
                                      Label="Tax code"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Disabled="@(_isSaving || WritesBlocked)"
                                      @bind-Value="_editor.Code" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string"
                                      Label="Name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Disabled="@(_isSaving || WritesBlocked)"
                                      @bind-Value="_editor.Name" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudNumericField T="decimal"
                                         Label="Rate %"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="0m"
                                         Max="100m"
                                         Immediate="true"
                                         Disabled="@(_isSaving || WritesBlocked)"
                                         @bind-Value="_editor.RatePercent" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="string"
                                   Label="Applies to"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Disabled="@(_isSaving || WritesBlocked)"
                                   @bind-Value="_editor.AppliesTo">
                            <MudSelectItem T="string" Value="@ShellCompanyTaxSetupRules.AppliesToSales">Sales only</MudSelectItem>
                            <MudSelectItem T="string" Value="@ShellCompanyTaxSetupRules.AppliesToPurchase">Purchase only</MudSelectItem>
                            <MudSelectItem T="string" Value="@ShellCompanyTaxSetupRules.AppliesToBoth">Sales + purchase</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="string"
                                   Label="Purchase recoverability"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Disabled="@(_isSaving || WritesBlocked || IsSalesOnly)"
                                   @bind-Value="_editor.RecoverabilityMode">
                            <MudSelectItem T="string" Value="@ShellCompanyTaxSetupRules.RecoverabilityNone">Non-recoverable</MudSelectItem>
                            <MudSelectItem T="string" Value="@ShellCompanyTaxSetupRules.RecoverabilityFull">Recoverable</MudSelectItem>
                            <MudSelectItem T="string" Value="@ShellCompanyTaxSetupRules.RecoverabilityPartial">Partially recoverable</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="Guid?"
                                   Label="Tax payable account"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Disabled="@(_isSaving || WritesBlocked)"
                                   @bind-Value="_editor.PayableAccountId">
                            @foreach (var option in _summary.PayableAccountOptions)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)option.Id)">
                                    @option.DisplayLabel
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudSelect T="Guid?"
                                   Label="Recoverable tax account"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Disabled="@(_isSaving || WritesBlocked || !RequiresRecoverableAccount)"
                                   HelperText="@RecoverableAccountHelperText"
                                   @bind-Value="_editor.RecoverableAccountId">
                            @if (!RequiresRecoverableAccount)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)null)">
                                    Not required for the current recoverability mode
                                </MudSelectItem>
                            }
                            @foreach (var option in _summary.RecoverableAccountOptions)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)option.Id)">
                                    @option.DisplayLabel
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>

                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="@(_isSaving || WritesBlocked)"
                               OnClick="SaveAsync">
                        @(_isSaving ? "Saving..." : _editor.Id.HasValue ? "Save Tax Code" : "Create Tax Code")
                    </MudButton>
                    <MudButton Variant="Variant.Text"
                               Color="Color.Default"
                               Disabled="@(_isSaving)"
                               OnClick="ResetEditor">
                        Clear Editor
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        @if (!_summary.HasAnyActiveTaxCodes)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                No active tax codes are configured yet. First invoice and bill drafts can still begin tax-free, but taxable operations should wait until at least one governed tax code is active.
            </MudAlert>
        }

        <MudGrid>
            <MudItem xs="12" lg="8">
                <MudPaper Elevation="0" Class="pa-5">
                    <MudText Typo="Typo.h6" Class="mb-3">Active tax codes</MudText>
                    @if (_summary.ActiveTaxCodes.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="text-secondary">No active tax codes currently exist.</MudText>
                    }
                    else
                    {
                        <MudTable Items="_summary.ActiveTaxCodes" Dense="true" Hover="true" Bordered="true">
                            <HeaderContent>
                                <MudTh>Code</MudTh>
                                <MudTh>Name</MudTh>
                                <MudTh>Rate</MudTh>
                                <MudTh>Direction</MudTh>
                                <MudTh>Recoverability</MudTh>
                                <MudTh>Accounts</MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Code</MudTd>
                                <MudTd>@context.Name</MudTd>
                                <MudTd>@context.RatePercent.ToString("N2")%</MudTd>
                                <MudTd>@context.AppliesToLabel</MudTd>
                                <MudTd>@context.RecoverabilityLabel</MudTd>
                                <MudTd>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.caption">Payable: @(string.IsNullOrWhiteSpace(context.PayableAccountLabel) ? "Missing" : context.PayableAccountLabel)</MudText>
                                        <MudText Typo="Typo.caption">Recoverable: @(string.IsNullOrWhiteSpace(context.RecoverableAccountLabel) ? "Not used" : context.RecoverableAccountLabel)</MudText>
                                    </MudStack>
                                </MudTd>
                                <MudTd>
                                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="@(_isSaving)"
                                                   OnClick="@(() => BeginEdit(context))">
                                            Edit
                                        </MudButton>
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Warning"
                                                   Size="Size.Small"
                                                   Disabled="@(_isSaving || WritesBlocked)"
                                                   OnClick="@(() => SetActiveAsync(context, false))">
                                            Deactivate
                                        </MudButton>
                                    </MudStack>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="4">
                <MudPaper Elevation="0" Class="pa-5">
                    <MudText Typo="Typo.h6" Class="mb-3">Inactive history</MudText>
                    @if (_summary.InactiveTaxCodes.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="text-secondary">No inactive tax codes yet.</MudText>
                    }
                    else
                    {
                        <MudTable Items="_summary.InactiveTaxCodes" Dense="true" Hover="true" Bordered="true">
                            <HeaderContent>
                                <MudTh>Code</MudTh>
                                <MudTh>Direction</MudTh>
                                <MudTh>Action</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Code</MudTd>
                                <MudTd>@context.AppliesToLabel</MudTd>
                                <MudTd>
                                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="@(_isSaving)"
                                                   OnClick="@(() => BeginEdit(context))">
                                            Review
                                        </MudButton>
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Success"
                                                   Size="Size.Small"
                                                   Disabled="@(_isSaving || WritesBlocked)"
                                                   OnClick="@(() => SetActiveAsync(context, true))">
                                            Reactivate
                                        </MudButton>
                                    </MudStack>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Elevation="0" Class="pa-5">
            <MudText Typo="Typo.h6" Class="mb-3">Recommended next workspaces</MudText>
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Success" Href="/documents/invoice/draft-editor">
                    Open Invoice Draft
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="/documents/bill/draft-editor">
                    Open Bill Draft
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/company/book-governance">
                    Review Book Governance
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" Href="/">
                    Back To Workspace
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "origin")]
    public string? Origin { get; set; }

    private ShellCompanyTaxSetupSummary? _summary;
    private string? _error;
    private bool _isSaving;
    private TaxEditorModel _editor = TaxEditorModel.CreateDefault();

    private bool IsCompanyReadyHandOff => string.Equals(Origin, "company-ready", StringComparison.OrdinalIgnoreCase);

    private bool WritesBlocked => ShellState.AreWritesBlocked;

    private bool IsSalesOnly =>
        string.Equals(_editor.AppliesTo, ShellCompanyTaxSetupRules.AppliesToSales, StringComparison.OrdinalIgnoreCase);

    private bool RequiresRecoverableAccount =>
        ShellCompanyTaxSetupRules.HasPurchaseScope(_editor.AppliesTo) &&
        !string.Equals(_editor.RecoverabilityMode, ShellCompanyTaxSetupRules.RecoverabilityNone, StringComparison.OrdinalIgnoreCase);

    private string EditorHeading => _editor.Id.HasValue
        ? $"Edit tax code {_editor.Code}"
        : "Create tax code";

    private string RecoverableAccountHelperText =>
        RequiresRecoverableAccount
            ? "Required for purchase-side recoverable or partially recoverable tax."
            : "Only needed when purchase recoverability is enabled.";

    protected override async Task OnInitializedAsync()
    {
        await ShellState.EnsureHydratedAsync();
        var probe = await SessionClient.ProbeContextAsync();
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe))
        {
            return;
        }

        if (probe.Context is null)
        {
            _error = probe.ErrorMessage ?? WebShellBusinessSessionClient.AuthenticationRequiredError;
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _summary = await TaxSetup.GetSummaryAsync(ShellState.ActiveCompany.Id);
            _error = null;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void BeginEdit(ShellCompanyManagedTaxCodeSummary taxCode)
    {
        _editor = new TaxEditorModel
        {
            Id = taxCode.Id,
            Code = taxCode.Code,
            Name = taxCode.Name,
            RatePercent = taxCode.RatePercent,
            AppliesTo = taxCode.AppliesTo,
            RecoverabilityMode = taxCode.RecoverabilityMode,
            PayableAccountId = taxCode.PayableAccountId,
            RecoverableAccountId = taxCode.RecoverableAccountId
        };

        if (IsSalesOnly)
        {
            _editor.RecoverabilityMode = ShellCompanyTaxSetupRules.RecoverabilityNone;
            _editor.RecoverableAccountId = null;
        }
    }

    private void ResetEditor()
    {
        _editor = TaxEditorModel.CreateDefault();
        _error = null;
    }

    private async Task SaveAsync()
    {
        if (TryBlockWrites())
        {
            return;
        }

        _isSaving = true;
        _error = null;

        try
        {
            var taxCodeId = await TaxSetup.SaveAsync(
                ShellState.ActiveCompany.Id,
                new ShellCompanyTaxCodeUpsertRequest
                {
                    Id = _editor.Id,
                    Code = _editor.Code,
                    Name = _editor.Name,
                    RatePercent = _editor.RatePercent,
                    AppliesTo = _editor.AppliesTo,
                    RecoverabilityMode = IsSalesOnly ? ShellCompanyTaxSetupRules.RecoverabilityNone : _editor.RecoverabilityMode,
                    PayableAccountId = _editor.PayableAccountId,
                    RecoverableAccountId = RequiresRecoverableAccount ? _editor.RecoverableAccountId : null
                });

            await LoadAsync();
            var saved = _summary?.TaxCodes.FirstOrDefault(item => item.Id == taxCodeId);
            if (saved is not null)
            {
                BeginEdit(saved);
            }

            Snackbar.Add(
                _editor.Id.HasValue ? "Tax code updated." : "Tax code created.",
                Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task SetActiveAsync(ShellCompanyManagedTaxCodeSummary taxCode, bool isActive)
    {
        if (TryBlockWrites())
        {
            return;
        }

        _isSaving = true;
        _error = null;

        try
        {
            await TaxSetup.SetActiveAsync(ShellState.ActiveCompany.Id, taxCode.Id, isActive);
            await LoadAsync();
            if (_editor.Id == taxCode.Id && !isActive)
            {
                ResetEditor();
            }

            Snackbar.Add(
                isActive ? "Tax code reactivated." : "Tax code deactivated.",
                Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private bool TryBlockWrites()
    {
        if (!WritesBlocked)
        {
            return false;
        }

        _error = ShellState.WriteBlockMessage;
        Snackbar.Add(ShellState.WriteBlockMessage, Severity.Warning);
        return true;
    }

    private sealed class TaxEditorModel
    {
        public Guid? Id { get; set; }

        public string Code { get; set; } = string.Empty;

        public string Name { get; set; } = string.Empty;

        public decimal RatePercent { get; set; }

        public string AppliesTo { get; set; } = ShellCompanyTaxSetupRules.AppliesToBoth;

        public string RecoverabilityMode { get; set; } = ShellCompanyTaxSetupRules.RecoverabilityNone;

        public Guid? PayableAccountId { get; set; }

        public Guid? RecoverableAccountId { get; set; }

        public static TaxEditorModel CreateDefault() => new();
    }
}
