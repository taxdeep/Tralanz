@page "/company/inventory-return-receive"
@using Citus.Modules.Inventory.Application.Contracts
@using Web.Shell.Services
@rendermode InteractiveServer
@inject WebShellState ShellState
@inject WebShellBusinessSessionClient SessionClient
@inject WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject WebShellCompanyOnboardingClient OnboardingClient
@inject ShellInventoryReturnClient InventoryReturn
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Return Receive</PageTitle>

<div style="padding:1.75rem;display:grid;gap:1rem;">
    <MudPaper Elevation="0" Class="pa-5">
        <MudText Typo="Typo.overline" Class="text-secondary">Phase H1</MudText>
        <MudText Typo="Typo.h4">Return Receive</MudText>
        <MudText Typo="Typo.body1" Class="text-secondary">
            Return receive records physical return truth only. Goods are received back against a posted shipment anchor, but they do not re-enter on-hand inventory until later inspect / disposition decides what can actually be restocked.
        </MudText>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_error</MudAlert>
    }
    else if (_onboardingSummary is not null && !_onboardingSummary.SupportsInventoryFoundation)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            Return receive is closed by default for <strong>@_onboardingSummary.Industry</strong> companies.
        </MudAlert>
    }
    else if (_dashboard is null)
    {
        <MudPaper Elevation="0" Class="pa-5"><MudProgressLinear Indeterminate="true" Color="Color.Info" /></MudPaper>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
            Operational guardrail: tracked return selection is still closed here. H1 only receives warehouse-managed customer returns against posted shipment truth.
        </MudAlert>

        @if (_handoffSummary is not null)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                Shipment anchor <strong>@_handoffSummary.ShipmentDocumentNumber</strong> is active. Invoice / credit note stay commercial context only; this workspace records the physical return truth.
            </MudAlert>

            <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Disabled="@(_isSaving || WritesBlocked)" OnClick="ReloadRemainingLines">
                    Load Remaining From Shipment
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" Href="@BuildShipmentHref(_handoffSummary.ShipmentDocumentId)">
                    Open Shipment Workspace
                </MudButton>
            </div>

            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));gap:1rem;">
                <MudPaper Elevation="0" Class="pa-4">
                    <MudText Typo="Typo.caption">Shipment qty</MudText>
                    <MudText Typo="Typo.h6">@_handoffSummary.ShippedQuantity.ToString("N2")</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@_handoffSummary.ShipmentLineCount shipment line group(s)</MudText>
                </MudPaper>
                <MudPaper Elevation="0" Class="pa-4">
                    <MudText Typo="Typo.caption">Already returned</MudText>
                    <MudText Typo="Typo.h6">@_handoffSummary.ReturnedQuantity.ToString("N2")</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@_handoffSummary.ReturnReceiptCount return receipt(s)</MudText>
                </MudPaper>
                <MudPaper Elevation="0" Class="pa-4">
                    <MudText Typo="Typo.caption">Current form qty</MudText>
                    <MudText Typo="Typo.h6">@CurrentDraftQuantity.ToString("N2")</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">Projected returned total: @ProjectedReturnedQuantity.ToString("N2")</MudText>
                </MudPaper>
                <MudPaper Elevation="0" Class="pa-4">
                    <MudText Typo="Typo.caption">Projected status</MudText>
                    <MudText Typo="Typo.h6">@ProjectedStatusLabel</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@ProjectedStatusSummary</MudText>
                </MudPaper>
            </div>

            @if (_handoffSummary.LineSummaries.Count > 0)
            {
                <MudTable Items="_handoffSummary.LineSummaries" Dense="true" Hover="true" Bordered="true">
                    <HeaderContent>
                        <MudTh>Item</MudTh>
                        <MudTh>Warehouse</MudTh>
                        <MudTh>UOM</MudTh>
                        <MudTh>Shipped</MudTh>
                        <MudTh>Returned</MudTh>
                        <MudTh>Remaining</MudTh>
                        <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@($"{context.ItemCode} - {context.ItemName}")</MudTd>
                        <MudTd>@($"{context.WarehouseCode} - {context.WarehouseName}")</MudTd>
                        <MudTd>@context.UomCode</MudTd>
                        <MudTd>@context.ShippedQuantity.ToString("N2")</MudTd>
                        <MudTd>@context.ReturnedQuantity.ToString("N2")</MudTd>
                        <MudTd>@context.RemainingReturnableQuantity.ToString("N2")</MudTd>
                        <MudTd>@FormatReturnStatus(context.MatchStatus)</MudTd>
                    </RowTemplate>
                </MudTable>
            }

            @if (!HasOutstandingReturnQuantity)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    This shipment is already fully covered by return receive truth. The form stays empty by default to avoid accidental over-return.
                </MudAlert>
            }

            <MudPaper Elevation="0" Class="pa-5">
                <MudText Typo="Typo.h6">Return header</MudText>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string" Label="Customer" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="true" Value="@_handoffSummary.CustomerDisplayName" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudDatePicker Label="Return date" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(_isSaving || WritesBlocked)" @bind-Date="_postingDate" />
                    </MudItem>
                    <MudItem xs="12" md="5">
                        <MudTextField T="string" Label="Memo" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(_isSaving || WritesBlocked)" @bind-Value="_memo" />
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudPaper Elevation="0" Class="pa-5">
                <MudText Typo="Typo.h6">Return lines</MudText>
                @foreach (var line in _lineEditors.OrderBy(line => line.LineNo))
                {
                    <MudPaper Elevation="0" Class="pa-4" Outlined="true" Style="margin-top:.75rem;">
                        <MudGrid>
                            <MudItem xs="12" md="1">
                                <MudTextField T="int" Label="Line" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="true" Value="@line.LineNo" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudTextField T="string" Label="Item" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="true" Value="@line.ItemDisplay" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudTextField T="string" Label="Warehouse" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="true" Value="@line.WarehouseDisplay" />
                            </MudItem>
                            <MudItem xs="12" md="1">
                                <MudTextField T="string" Label="UOM" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="true" @bind-Value="line.UomCode" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudNumericField T="decimal" Label="Qty" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(_isSaving || WritesBlocked)" @bind-Value="line.Quantity" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudTextField T="string" Label="Condition" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(_isSaving || WritesBlocked)" @bind-Value="line.ConditionCode" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudTextField T="string" Label="Reason" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(_isSaving || WritesBlocked)" @bind-Value="line.ReturnReasonCode" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudTextField T="string" Label="Disposition seam" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(_isSaving || WritesBlocked)" @bind-Value="line.DispositionReasonCode" />
                            </MudItem>
                            <MudItem xs="12" md="10">
                                <MudTextField T="string" Label="Line memo" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(_isSaving || WritesBlocked)" @bind-Value="line.Memo" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                }

                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" Style="margin-top:1rem;">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_isSaving || WritesBlocked || _lineEditors.Count == 0)" OnClick="PostReturnAsync">
                        @(_isSaving ? "Posting..." : "Post Return Receive")
                    </MudButton>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                Start from a posted shipment anchor. Return receive should not invent quantity without a physical outbound source.
            </MudAlert>
        }

        @if (_lastPostedReturn is not null)
        {
            <MudPaper Elevation="0" Class="pa-4">
                <MudText Typo="Typo.h6">Posted Return Review</MudText>
                <MudText Typo="Typo.body2">Return: @_lastPostedReturn.DocumentNumber</MudText>
                <MudText Typo="Typo.body2">Shipment: @_lastPostedReturn.ShipmentDocumentNumber</MudText>
                <MudText Typo="Typo.body2">Qty: @_lastPostedReturn.TotalQuantity.ToString("N2")</MudText>
                <MudText Typo="Typo.body2">Coverage: @FormatReturnStatus(_lastPostedReturn.ReturnMatchStatus)</MudText>
                <MudText Typo="Typo.body2">Remaining returnable: @_lastPostedReturn.RemainingReturnableQuantity.ToString("N2")</MudText>
            </MudPaper>
        }

        <MudPaper Elevation="0" Class="pa-5">
            <MudText Typo="Typo.h6">Recent shipment anchors</MudText>
            <MudTable Items="_dashboard.RecentShipments" Dense="true" Hover="true" Bordered="true">
                <HeaderContent>
                    <MudTh>Shipment</MudTh>
                    <MudTh>Date</MudTh>
                    <MudTh>Customer</MudTh>
                    <MudTh>Qty</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.DocumentNumber</MudTd>
                    <MudTd>@context.PostingDate.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd>@context.CustomerDisplayName</MudTd>
                    <MudTd>@context.TotalQuantity.ToString("N2")</MudTd>
                    <MudTd>
                        <MudButton Variant="Variant.Text" Color="Color.Info" Disabled="@(_isSaving || WritesBlocked)" OnClick="@(() => LoadShipmentAsync(context.DocumentId))">
                            Use Shipment
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "shipmentId")] public Guid? ShipmentIdQuery { get; set; }

    private InventoryReturnReceiveDashboard? _dashboard;
    private WebShellCompanyOnboardingSummary? _onboardingSummary;
    private InventoryReturnReceiveHandoffSummary? _handoffSummary;
    private InventoryReturnReceiveSummary? _lastPostedReturn;
    private readonly List<ReturnLineEditorState> _lineEditors = [];
    private string? _error;
    private bool _isSaving;
    private Guid? _loadedShipmentId;
    private DateTime? _postingDate = DateTime.Today;
    private string? _memo;

    private bool WritesBlocked => ShellState.AreWritesBlocked;
    private bool HasOutstandingReturnQuantity => _handoffSummary is not null && _handoffSummary.RemainingReturnableQuantity > 0m;
    private decimal CurrentDraftQuantity => decimal.Round(_lineEditors.Sum(static line => line.Quantity), 6, MidpointRounding.AwayFromZero);
    private decimal ProjectedReturnedQuantity => _handoffSummary is null ? 0m : decimal.Round(_handoffSummary.ReturnedQuantity + CurrentDraftQuantity, 6, MidpointRounding.AwayFromZero);
    private string ProjectedStatusLabel => FormatReturnStatus(ResolveProjectedStatus());
    private string ProjectedStatusSummary => _handoffSummary is null
        ? "Choose a posted shipment anchor before projecting return truth."
        : $"Projected remaining returnable after this receipt: {decimal.Round(_handoffSummary.ShippedQuantity - ProjectedReturnedQuantity, 6, MidpointRounding.AwayFromZero):N2}.";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ShipmentIdQuery != _loadedShipmentId && ShipmentIdQuery.HasValue)
        {
            await LoadShipmentAsync(ShipmentIdQuery.Value);
        }
    }

    private async Task LoadAsync()
    {
        await ShellState.EnsureHydratedAsync();
        var probe = await SessionClient.ProbeContextAsync();
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe))
        {
            return;
        }

        var onboardingResult = await OnboardingClient.GetAsync();
        if (onboardingResult.RequiresSignIn || onboardingResult.IsNotFound || !string.IsNullOrWhiteSpace(onboardingResult.ErrorMessage))
        {
            _error = onboardingResult.ErrorMessage ?? "Company onboarding context is unavailable.";
            return;
        }

        _onboardingSummary = onboardingResult.Value;
        if (_onboardingSummary is null || !_onboardingSummary.SupportsInventoryFoundation)
        {
            return;
        }

        try
        {
            _dashboard = await InventoryReturn.GetDashboardAsync(ShellState.ActiveCompany.Id);
            if (ShipmentIdQuery.HasValue)
            {
                await LoadShipmentAsync(ShipmentIdQuery.Value);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task LoadShipmentAsync(Guid shipmentDocumentId)
    {
        try
        {
            _error = null;
            _handoffSummary = await InventoryReturn.GetShipmentHandoffSummaryAsync(ShellState.ActiveCompany.Id, shipmentDocumentId);
            _loadedShipmentId = shipmentDocumentId;
            ReloadRemainingLines();
            Navigation.NavigateTo($"/company/inventory-return-receive?shipmentId={shipmentDocumentId:D}", false);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void ReloadRemainingLines()
    {
        _lineEditors.Clear();
        if (_handoffSummary is null)
        {
            return;
        }

        foreach (var line in _handoffSummary.LineSummaries.Where(static line => line.RemainingReturnableQuantity > 0m).OrderBy(static line => line.ItemCode).ThenBy(static line => line.WarehouseCode))
        {
            _lineEditors.Add(new ReturnLineEditorState
            {
                LineNo = _lineEditors.Count + 1,
                ItemId = line.ItemId,
                ItemDisplay = $"{line.ItemCode} - {line.ItemName}",
                WarehouseId = line.WarehouseId,
                WarehouseDisplay = $"{line.WarehouseCode} - {line.WarehouseName}",
                UomCode = line.UomCode,
                Quantity = line.RemainingReturnableQuantity,
                ConditionCode = "SELLABLE",
                ReturnReasonCode = "CUSTOMER_RETURN",
                DispositionReasonCode = string.Empty
            });
        }
    }

    private async Task PostReturnAsync()
    {
        if (_handoffSummary is null)
        {
            _error = "Choose a shipment anchor before posting return receive.";
            return;
        }

        _isSaving = true;
        _error = null;
        try
        {
            var request = new InventoryReturnReceivePostRequest(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                _handoffSummary.CustomerId,
                DateOnly.FromDateTime(_postingDate ?? DateTime.Today),
                _handoffSummary.ShipmentDocumentId,
                _handoffSummary.ShipmentDocumentNumber,
                _memo,
                _lineEditors.Select(line => new InventoryReturnReceiveLineInput(
                    line.LineNo,
                    line.ItemId,
                    line.WarehouseId,
                    line.UomCode,
                    line.Quantity,
                    line.ConditionCode,
                    line.ReturnReasonCode,
                    string.IsNullOrWhiteSpace(line.DispositionReasonCode) ? null : line.DispositionReasonCode,
                    line.Memo)).ToArray());

            _lastPostedReturn = await InventoryReturn.PostAsync(request, _handoffSummary);
            Snackbar.Add($"Return receive {_lastPostedReturn.DocumentNumber} posted.", Severity.Success);
            _handoffSummary = await InventoryReturn.GetShipmentHandoffSummaryAsync(ShellState.ActiveCompany.Id, _handoffSummary.ShipmentDocumentId);
            ReloadRemainingLines();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private string ResolveProjectedStatus()
    {
        if (_handoffSummary is null)
        {
            return "no_shipment";
        }

        if (ProjectedReturnedQuantity <= 0m)
        {
            return "not_returned";
        }

        if (ProjectedReturnedQuantity < _handoffSummary.ShippedQuantity)
        {
            return "partially_returned";
        }

        if (ProjectedReturnedQuantity == _handoffSummary.ShippedQuantity)
        {
            return "fully_returned";
        }

        return "over_returned";
    }

    private static string FormatReturnStatus(string status) => status switch
    {
        "no_shipment" => "No shipment",
        "not_returned" => "Not returned",
        "partially_returned" => "Partially returned",
        "fully_returned" => "Fully returned",
        "over_returned" => "Over returned",
        _ => status.Replace('_', ' ')
    };

    private static string BuildShipmentHref(Guid shipmentDocumentId) =>
        $"/company/inventory-shipment?shipmentId={shipmentDocumentId:D}";

    private sealed class ReturnLineEditorState
    {
        public int LineNo { get; set; }
        public Guid ItemId { get; set; }
        public string ItemDisplay { get; set; } = string.Empty;
        public Guid WarehouseId { get; set; }
        public string WarehouseDisplay { get; set; } = string.Empty;
        public string UomCode { get; set; } = string.Empty;
        public decimal Quantity { get; set; }
        public string ConditionCode { get; set; } = string.Empty;
        public string ReturnReasonCode { get; set; } = string.Empty;
        public string DispositionReasonCode { get; set; } = string.Empty;
        public string? Memo { get; set; }
    }
}
