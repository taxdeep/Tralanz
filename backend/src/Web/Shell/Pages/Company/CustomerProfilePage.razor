@page "/ar/customers/{CustomerId:guid}"
@using Web.Business.AR.Aging
@inject WebShellState ShellState
@inject WebShellBusinessSessionClient SessionClient
@inject WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject ShellCounterpartyOnboardingClient CounterpartyOnboarding
@inject ArAgingReportClient AgingClient

<PageTitle>@ProfileTitle</PageTitle>

<div class="customer-profile">
    <aside class="customer-profile__rail">
        <a class="customer-profile__back" href="/ar/customers">Customers</a>
        <label class="customer-profile__rail-search">
            <i class="ti ti-search" aria-hidden="true"></i>
            <input class="ant-input" placeholder="Search customer list" @bind="_searchText" @bind:event="oninput" />
        </label>
        <div class="customer-profile__rail-list">
            @foreach (var customer in FilteredCustomers)
            {
                <a class="customer-profile__rail-item @(customer.Id == CustomerId ? "customer-profile__rail-item--active" : string.Empty)"
                   href="@BuildCustomerProfileHref(customer.Id)">
                    <strong>@customer.DisplayName</strong>
                    <span>@FormatCustomerBalance(customer.Id)</span>
                </a>
            }
        </div>
    </aside>

    <main class="customer-profile__main">
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="ant-alert ant-alert-warning customer-profile__alert">
                <i class="ti ti-alert-triangle" aria-hidden="true"></i>
                <span>@_error</span>
            </div>
        }

        @if (_isLoading)
        {
            <div class="customer-profile__loading">Loading customer profile...</div>
        }
        else if (SelectedCustomer is null)
        {
            <div class="customer-profile__missing">
                <h1>Customer profile not found</h1>
                <p>The selected customer does not belong to the active company or is no longer available.</p>
                <a class="ant-btn ant-btn-primary" href="/ar/customers">Back to customers</a>
            </div>
        }
        else
        {
            <section class="customer-profile__hero">
                <div class="customer-profile__identity">
                    <div class="customer-profile__avatar">@BuildInitials(SelectedCustomer.DisplayName)</div>
                    <div>
                        <a class="customer-profile__crumb" href="/ar/customers">Customers</a>
                        <h1>@SelectedCustomer.DisplayName</h1>
                        <p>@SelectedCustomer.EntityNumber | @SelectedCustomer.DefaultCurrencyCode | @(SelectedCustomer.IsActive ? "Active customer" : "Inactive customer")</p>
                    </div>
                </div>
                <div class="customer-profile__hero-actions">
                    <a class="ant-btn" href="@BuildEditHref(SelectedCustomer.Id)">Edit</a>
                    <a class="ant-btn ant-btn-primary" href="@BuildInvoiceHref(SelectedCustomer.Id)">New transaction</a>
                </div>
            </section>

            <section class="customer-profile__contact-grid">
                <article class="customer-profile__contact-card">
                    <div class="customer-profile__field-label">Email</div>
                    <a href="@BuildMailHref(SelectedCustomer.Email)">@DisplayAddable(SelectedCustomer.Email, "Add email")</a>
                    <div class="customer-profile__field-label">Billing address</div>
                    <span>@DisplayMultiline(SelectedCustomer.Address, "Add billing address")</span>
                    <div class="customer-profile__field-label">Notes</div>
                    <span>AR-only profile shell. Notes belong in the next profile project.</span>
                </article>

                <article class="customer-profile__contact-card">
                    <div class="customer-profile__field-label">Phone</div>
                    <a href="@BuildPhoneHref(SelectedCustomer.Phone)">@DisplayAddable(SelectedCustomer.Phone, "Add phone number")</a>
                    <div class="customer-profile__field-label">Shipping address</div>
                    <span>@DisplayMultiline(SelectedCustomer.Address, "Add shipping address")</span>
                    <div class="customer-profile__field-label">Custom fields</div>
                    <span>Reserved for customer profile project</span>
                </article>

                <article class="customer-profile__financial-card">
                    <h2>Financial summary</h2>
                    <div class="customer-profile__financial-row">
                        <span>Open balance</span>
                        <strong>@FormatMoney(SelectedAging?.TotalOutstandingAmountBase ?? 0m)</strong>
                    </div>
                    <div class="customer-profile__financial-row">
                        <span>Overdue payment</span>
                        <strong>@FormatMoney(SelectedAging?.TotalOverdueAmountBase ?? 0m)</strong>
                    </div>
                    <div class="customer-profile__financial-row">
                        <span>Open item(s)</span>
                        <strong>@(SelectedAging?.OpenItemCount ?? 0)</strong>
                    </div>
                </article>
            </section>

            <section class="customer-profile__tabs">
                <a class="@BuildTabClass(ProfileTab.Transactions)" href="@BuildTabHref(ProfileTab.Transactions)">Transaction List</a>
                <span class="customer-profile__tab-disabled">Activity Feed</span>
                <a class="@BuildTabClass(ProfileTab.Statements)" href="@BuildTabHref(ProfileTab.Statements)">Statements</a>
                <span class="customer-profile__tab-disabled">Recurring Transactions</span>
                <a class="@BuildTabClass(ProfileTab.Details)" href="@BuildTabHref(ProfileTab.Details)">Customer Details</a>
                <span class="customer-profile__tab-disabled">Notes</span>
                <span class="customer-profile__tab-disabled">Tasks <em>New</em></span>
                <a class="@BuildTabClass(ProfileTab.Opportunities)" href="@BuildTabHref(ProfileTab.Opportunities)">Opportunities</a>
            </section>

            <section class="customer-profile__workspace">
                @switch (ActiveTab)
                {
                    case ProfileTab.Statements:
                        @RenderStatementsTab(SelectedCustomer)
                        break;
                    case ProfileTab.Details:
                        @RenderDetailsTab(SelectedCustomer)
                        break;
                    case ProfileTab.Opportunities:
                        @RenderOpportunitiesTab(SelectedCustomer)
                        break;
                    default:
                        @RenderTransactionsTab(SelectedCustomer)
                        break;
                }
            </section>
        }
    </main>
</div>

@code {
    [Parameter]
    public Guid CustomerId { get; set; }

    [SupplyParameterFromQuery(Name = "tab")]
    public string? Tab { get; set; }

    private ShellCounterpartyOnboardingSummary? _summary;
    private ArAgingReportViewModel? _agingReport;
    private string _searchText = string.Empty;
    private string? _error;
    private bool _isLoading = true;

    private string ProfileTitle => SelectedCustomer is null ? "Customer Profile" : $"{SelectedCustomer.DisplayName} Profile";
    private ShellManagedCounterpartySummary? SelectedCustomer => _summary?.Customers.FirstOrDefault(customer => customer.Id == CustomerId);
    private ArAgingCustomerRowViewModel? SelectedAging => _agingReport?.CustomerRows.FirstOrDefault(customer => customer.CustomerId == CustomerId);
    private string BaseCurrencyCode => _agingReport?.BaseCurrencyCode ?? _summary?.BaseCurrencyCode ?? ShellState.ActiveCompany.BaseCurrencyCode;
    private ProfileTab ActiveTab => ParseTab(Tab);
    private decimal SelectedOpenBalanceBase => SelectedAging?.TotalOutstandingAmountBase ?? 0m;
    private decimal SelectedOverdueBalanceBase => SelectedAging?.TotalOverdueAmountBase ?? 0m;
    private int SelectedOpenItemCount => SelectedAging?.OpenItemCount ?? 0;

    private IReadOnlyList<ArAgingOpenItemRowViewModel> SelectedTransactions =>
        (_agingReport?.DetailRows ?? Array.Empty<ArAgingOpenItemRowViewModel>())
        .Where(row => row.CustomerId == CustomerId)
        .OrderByDescending(static row => row.DocumentDate)
        .ThenBy(static row => row.DisplayNumber, StringComparer.OrdinalIgnoreCase)
        .ToArray();

    private IReadOnlyList<ShellManagedCounterpartySummary> FilteredCustomers =>
        (_summary?.Customers ?? Array.Empty<ShellManagedCounterpartySummary>())
        .Where(customer => string.IsNullOrWhiteSpace(_searchText) || customer.DisplayName.Contains(_searchText.Trim(), StringComparison.OrdinalIgnoreCase))
        .OrderByDescending(static customer => customer.IsActive)
        .ThenBy(static customer => customer.DisplayName, StringComparer.OrdinalIgnoreCase)
        .ToArray();

    protected override async Task OnInitializedAsync()
    {
        await ShellState.EnsureHydratedAsync();
        var probe = await SessionClient.ProbeContextAsync();
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe))
        {
            return;
        }

        if (probe.Context is null)
        {
            _error = probe.ErrorMessage ?? WebShellBusinessSessionClient.AuthenticationRequiredError;
            _isLoading = false;
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _isLoading = true;
            _summary = await CounterpartyOnboarding.GetSummaryAsync(ShellState.ActiveCompany.Id);
            var agingResult = await AgingClient.GetAsync(ShellState.ActiveCompany.Id, DateOnly.FromDateTime(DateTime.UtcNow));
            _agingReport = agingResult.Value;
            _error = agingResult.Value is null ? agingResult.ErrorMessage : null;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string FormatCustomerBalance(Guid customerId)
    {
        var aging = _agingReport?.CustomerRows.FirstOrDefault(row => row.CustomerId == customerId);
        return FormatMoney(aging?.TotalOutstandingAmountBase ?? 0m);
    }

    private string FormatMoney(decimal value) =>
        $"{BaseCurrencyCode} {value:N2}";

    private static string DisplayAddable(string? value, string fallback) =>
        string.IsNullOrWhiteSpace(value) ? fallback : value;

    private static MarkupString DisplayMultiline(string? value, string fallback)
    {
        var text = string.IsNullOrWhiteSpace(value) ? fallback : value.Replace(Environment.NewLine, "<br />");
        return new MarkupString(text);
    }

    private static string BuildInitials(string? displayName)
    {
        var parts = (displayName ?? string.Empty).Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var initials = string.Concat(parts.Take(2).Select(static part => char.ToUpperInvariant(part[0])));
        return string.IsNullOrWhiteSpace(initials) ? "C" : initials;
    }

    private static string BuildCustomerProfileHref(Guid customerId) =>
        $"/ar/customers/{customerId:D}";

    private static string BuildInvoiceHref(Guid customerId) =>
        $"/documents/invoice/draft-editor?customerId={customerId:D}&origin=customer-profile";

    private static string BuildEditHref(Guid customerId) =>
        $"/company/customer-vendor-setup?create=customer&returnUrl=/ar/customers/{customerId:D}";

    private static string BuildMailHref(string? email) =>
        string.IsNullOrWhiteSpace(email) ? "#" : $"mailto:{email}";

    private static string BuildPhoneHref(string? phone) =>
        string.IsNullOrWhiteSpace(phone) ? "#" : $"tel:{phone}";

    private RenderFragment RenderTransactionsTab(ShellManagedCounterpartySummary customer) => @<text>
        <div class="customer-profile__workspace-toolbar">
            <div class="customer-profile__filters">
                <button class="ant-btn ant-btn-default customer-profile__batch-button" type="button" disabled>Batch actions</button>
                <label>
                    <span>Type</span>
                    <select class="ant-input" disabled>
                        <option>All open AR documents</option>
                    </select>
                </label>
                <label>
                    <span>Status</span>
                    <select class="ant-input" disabled>
                        <option>Open</option>
                    </select>
                </label>
                <label>
                    <span>Date</span>
                    <select class="ant-input" disabled>
                        <option>All</option>
                    </select>
                </label>
            </div>
            <div class="customer-profile__toolbar-links">
                <a href="/ar/receive-payment">Receive payment</a>
                <a href="@BuildInvoiceHref(customer.Id)">Create invoice</a>
            </div>
        </div>

        <div class="customer-profile__table-wrap">
            <table class="ant-table customer-profile__table">
                <thead class="ant-table-thead">
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>No.</th>
                        <th>Customer</th>
                        <th>Memo</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody class="ant-table-tbody">
                    @if (SelectedTransactions.Count == 0)
                    {
                        <tr>
                            <td colspan="8">
                                <div class="customer-profile__empty-inline">No open AR transactions matched this customer.</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var row in SelectedTransactions)
                        {
                            <tr>
                                <td>@row.DocumentDate.ToString("M/d/yy")</td>
                                <td>@FormatSourceType(row.SourceType)</td>
                                <td>@row.DisplayNumber</td>
                                <td>@row.CustomerDisplayName</td>
                                <td>@BuildTransactionMemo(row)</td>
                                <td>@FormatMoney(row.SignedOpenAmountBase)</td>
                                <td>
                                    <span class="@BuildTransactionStatusClass(row)">
                                        @BuildTransactionStatus(row)
                                    </span>
                                </td>
                                <td>
                                    <a href="@BuildSourceBrowserHref(row)">View</a>
                                    <span class="customer-profile__action-separator">|</span>
                                    <a href="/ar/receive-payment">Receive payment</a>
                                </td>
                            </tr>
                        }
                        <tr class="customer-profile__total-row">
                            <td></td>
                            <td>Total (@BaseCurrencyCode)</td>
                            <td colspan="3"></td>
                            <td>@FormatMoney(SelectedTransactions.Sum(static row => row.SignedOpenAmountBase))</td>
                            <td colspan="2"></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </text>;

    private RenderFragment RenderStatementsTab(ShellManagedCounterpartySummary customer) => @<text>
        <div class="customer-profile__workspace-toolbar">
            <div class="customer-profile__filters">
                <button class="ant-btn ant-btn-default customer-profile__batch-button" type="button" disabled>Batch actions</button>
                <label>
                    <span>Date</span>
                    <select class="ant-input" disabled>
                        <option>Last 12 months</option>
                    </select>
                </label>
            </div>
            <div class="customer-profile__toolbar-links">
                <a href="@BuildTabHref(ProfileTab.Transactions)">View transactions</a>
            </div>
        </div>
        <div class="customer-profile__table-wrap">
            <table class="ant-table customer-profile__table">
                <thead class="ant-table-thead">
                    <tr>
                        <th>Date</th>
                        <th>No.</th>
                        <th>Customer</th>
                        <th>Start date</th>
                        <th>End date</th>
                        <th>Statement type</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody class="ant-table-tbody">
                    <tr>
                        <td colspan="7">
                            <div class="customer-profile__empty-inline">No matching statements found for @customer.DisplayName.</div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </text>;

    private RenderFragment RenderDetailsTab(ShellManagedCounterpartySummary customer) => @<text>
        <div class="customer-profile__details-grid">
            <article class="customer-profile__details-card">
                <h2>Customer identity</h2>
                <dl>
                    <dt>Display name</dt>
                    <dd>@customer.DisplayName</dd>
                    <dt>Entity number</dt>
                    <dd>@customer.EntityNumber</dd>
                    <dt>Status</dt>
                    <dd>@(customer.IsActive ? "Active" : "Inactive")</dd>
                    <dt>Default currency</dt>
                    <dd>@customer.DefaultCurrencyCode</dd>
                </dl>
            </article>
            <article class="customer-profile__details-card">
                <h2>AR boundary</h2>
                <p>This profile is customer-scoped AR truth. Vendor/AP records stay in a separate AP workspace.</p>
                <dl>
                    <dt>Open balance</dt>
                    <dd>@FormatMoney(SelectedOpenBalanceBase)</dd>
                    <dt>Overdue payment</dt>
                    <dd>@FormatMoney(SelectedOverdueBalanceBase)</dd>
                    <dt>Open item count</dt>
                    <dd>@SelectedOpenItemCount</dd>
                </dl>
            </article>
        </div>
    </text>;

    private RenderFragment RenderOpportunitiesTab(ShellManagedCounterpartySummary customer) => @<text>
        <div class="customer-profile__workspace-toolbar">
            <h2>Opportunities</h2>
            <a href="@BuildInvoiceHref(customer.Id)">+ Add Opportunity</a>
        </div>
        <div class="customer-profile__empty-state">
            <i class="ti ti-search" aria-hidden="true"></i>
            <h3>No opportunities yet</h3>
            <p>Your opportunities will appear here once CRM tracking lands in the customer profile project.</p>
        </div>
    </text>;

    private string BuildTabClass(ProfileTab tab) =>
        ActiveTab == tab ? "customer-profile__tab-active" : string.Empty;

    private string BuildTabHref(ProfileTab tab) =>
        tab == ProfileTab.Transactions
            ? BuildCustomerProfileHref(CustomerId)
            : $"{BuildCustomerProfileHref(CustomerId)}?tab={GetTabValue(tab)}";

    private static ProfileTab ParseTab(string? tab) =>
        tab?.Trim().ToLowerInvariant() switch
        {
            "statements" => ProfileTab.Statements,
            "details" => ProfileTab.Details,
            "opportunities" => ProfileTab.Opportunities,
            _ => ProfileTab.Transactions
        };

    private static string GetTabValue(ProfileTab tab) =>
        tab switch
        {
            ProfileTab.Statements => "statements",
            ProfileTab.Details => "details",
            ProfileTab.Opportunities => "opportunities",
            _ => "transactions"
        };

    private static string FormatSourceType(string sourceType) =>
        sourceType.Replace('_', ' ').Trim() switch
        {
            "" => "Source document",
            var value => char.ToUpperInvariant(value[0]) + value[1..]
        };

    private static string BuildTransactionMemo(ArAgingOpenItemRowViewModel row) =>
        row.DueDate.HasValue
            ? $"Due {row.DueDate.Value:yyyy-MM-dd}"
            : row.AgingBucket;

    private static string BuildTransactionStatus(ArAgingOpenItemRowViewModel row) =>
        row.DaysPastDue > 0
            ? $"Overdue {row.DaysPastDue} days"
            : row.Status;

    private static string BuildTransactionStatusClass(ArAgingOpenItemRowViewModel row) =>
        row.DaysPastDue > 0
            ? "customer-profile__transaction-status customer-profile__transaction-status--overdue"
            : "customer-profile__transaction-status customer-profile__transaction-status--open";

    private static string BuildSourceBrowserHref(ArAgingOpenItemRowViewModel row) =>
        $"/documents/source-browser?sourceType={Uri.EscapeDataString(row.SourceType)}&counterpartyRole=customer&counterpartyId={row.CustomerId:D}";

    private enum ProfileTab
    {
        Transactions,
        Statements,
        Details,
        Opportunities
    }
}
