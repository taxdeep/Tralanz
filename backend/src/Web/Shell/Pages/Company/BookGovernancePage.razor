@page "/company/book-governance"
@using Modules.Company.MultiBook
@using SharedKernel.Company
@using Web.Shell.Services
@rendermode InteractiveServer
@inject WebShellState ShellState
@inject WebShellBusinessSessionClient SessionClient
@inject WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject ICompanyBookPolicyWorkflow Workflow
@inject ISnackbar Snackbar

<PageTitle>Book Governance</PageTitle>

<div class="book-governance-page">
    <section class="book-governance-page__hero">
        <div>
            <p class="book-governance-page__eyebrow">Company Settings</p>
            <h1>Multi-Book Governance</h1>
            <p class="book-governance-page__lede">
                Review active books, inspect current remeasurement policy truth, and register formal locks such as closed periods,
                issued statements, and filed tax without dropping down to raw signal types.
            </p>
            <div class="book-governance-page__context">
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                    @ShellState.ActiveCompany.CompanyName (@ShellState.ActiveCompany.CompanyCode)
                </MudChip>
                <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">
                    @ShellState.User.DisplayName
                </MudChip>
            </div>
        </div>
    </section>

    <MudPaper Class="book-governance-page__controls" Elevation="0">
        <MudSelect T="Guid"
                   Label="Active Company"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Value="@ShellState.ActiveCompany.Id"
                   ValueChanged="OnActiveCompanyChangedAsync">
            @foreach (var company in ShellState.AvailableCompanies)
            {
                <MudSelectItem T="Guid" Value="@company.Id">
                    @company.CompanyName (@company.CompanyCode)
                </MudSelectItem>
            }
        </MudSelect>
        <div class="book-governance-page__context-fact">
            <span>Current User</span>
            <strong>@ShellState.CurrentUserId</strong>
        </div>
        <div class="book-governance-page__context-fact">
            <span>Company Context</span>
            <strong>@ShellState.ActiveCompany.Id</strong>
        </div>
        <MudDatePicker Label="As Of Date"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Editable="true"
                       Date="@_asOfDatePicker"
                       DateChanged="OnAsOfDateChanged" />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="_isBusy"
                   OnClick="LoadAsync">
            Load Governance
        </MudButton>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_pageError))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">
            @_pageError
        </MudAlert>
    }

    @if (WritesBlocked)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
            @ShellState.WriteBlockMessage
        </MudAlert>
    }

    @if (_books.Count > 0)
    {
        <div class="book-governance-page__grid">
            @foreach (var item in _books)
            {
                <MudPaper Class="book-governance-card" Elevation="0">
                    <div class="book-governance-card__header">
                        <div>
                            <div class="book-governance-card__title-row">
                                <h2>@item.Book.BookName</h2>
                                @if (item.Book.IsPrimary)
                                {
                                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">Primary</MudChip>
                                }
                                @if (item.Book.IsAdjustmentOnly)
                                {
                                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">Adjustment</MudChip>
                                }
                            </div>
                            <p class="book-governance-card__meta">
                                @item.Book.BookCode - @item.Book.BookRole - @item.Book.AccountingStandard
                            </p>
                        </div>
                        <MudChip T="string"
                                 Color="@(item.MigrationEligibility.DirectEditAllowed ? Color.Success : Color.Warning)"
                                 Variant="Variant.Filled"
                                 Size="Size.Small">
                            @item.MigrationEligibility.ChangeMode
                        </MudChip>
                    </div>

                    <div class="book-governance-card__facts">
                        <div>
                            <span>Book Base</span>
                            <strong>@item.Book.BookBaseCurrencyCode</strong>
                        </div>
                        <div>
                            <span>Functional</span>
                            <strong>@item.Book.FunctionalCurrencyCode</strong>
                        </div>
                        <div>
                            <span>Presentation</span>
                            <strong>@(item.Book.PresentationCurrencyCode ?? "None")</strong>
                        </div>
                        <div>
                            <span>Remeasurement</span>
                            <strong>@(item.RemeasurementPolicy?.RateType ?? "Unconfigured")</strong>
                        </div>
                    </div>

                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                        @item.MigrationEligibility.Reason
                    </MudAlert>

                    <div class="book-governance-card__signals">
                        <MudChip T="string" Color="@(item.GovernanceSignals.HasClosedPeriods ? Color.Warning : Color.Default)" Variant="Variant.Outlined" Size="Size.Small">
                            Closed Periods: @(item.GovernanceSignals.HasClosedPeriods ? "Yes" : "No")
                        </MudChip>
                        <MudChip T="string" Color="@(item.GovernanceSignals.HasIssuedReports ? Color.Warning : Color.Default)" Variant="Variant.Outlined" Size="Size.Small">
                            Issued Statements: @(item.GovernanceSignals.HasIssuedReports ? "Yes" : "No")
                        </MudChip>
                        <MudChip T="string" Color="@(item.GovernanceSignals.HasFiledTax ? Color.Error : Color.Default)" Variant="Variant.Outlined" Size="Size.Small">
                            Filed Tax: @(item.GovernanceSignals.HasFiledTax ? "Yes" : "No")
                        </MudChip>
                    </div>

                    @if (item.GovernanceSignals.Signals.Count > 0)
                    {
                        <div class="book-governance-card__timeline">
                            @foreach (var signal in item.GovernanceSignals.Signals.Take(4))
                            {
                                <div class="book-governance-card__timeline-row">
                                    <strong>@signal.SignalDate.ToString("yyyy-MM-dd")</strong>
                                    <span>@signal.SignalType</span>
                                    <em>@(signal.ReferenceLabel ?? "No label")</em>
                                </div>
                            }
                        </div>
                    }

                    <MudExpansionPanels MultiExpansion="true" Dense="true" Elevation="0">
                        <MudExpansionPanel Text="Close Period">
                            <div class="book-governance-form">
                                <MudDatePicker Label="Period End"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Disabled="@(_isBusy || WritesBlocked)"
                                               Editable="true"
                                               Date="@item.ClosePeriodDatePicker"
                                               DateChanged="date => OnClosePeriodDateChanged(item, date)" />
                                <MudTextField T="string"
                                              Label="Reference Label"
                                              HelperText="Optional. Defaults to Period close YYYY-MM-DD."
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Disabled="@(_isBusy || WritesBlocked)"
                                              @bind-Value="item.ClosePeriodReferenceLabel" />
                                <MudTextField T="string"
                                              Label="Notes"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Disabled="@(_isBusy || WritesBlocked)"
                                              Lines="2"
                                              @bind-Value="item.ClosePeriodNotes" />
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Warning"
                                           Disabled="@(_isBusy || WritesBlocked)"
                                           OnClick="() => RegisterClosedPeriodAsync(item)">
                                    Register Close
                                </MudButton>
                            </div>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="Mark Statement Issued">
                            <div class="book-governance-form">
                                <MudDatePicker Label="Issued On"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Disabled="@(_isBusy || WritesBlocked)"
                                               Editable="true"
                                               Date="@item.StatementIssuedOnPicker"
                                               DateChanged="date => OnStatementIssuedOnChanged(item, date)" />
                                <MudTextField T="string"
                                              Label="Statement Label"
                                              HelperText="Required."
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Disabled="@(_isBusy || WritesBlocked)"
                                              @bind-Value="item.StatementLabel" />
                                <MudTextField T="string"
                                              Label="Notes"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Disabled="@(_isBusy || WritesBlocked)"
                                              Lines="2"
                                              @bind-Value="item.StatementNotes" />
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Info"
                                           Disabled="@(_isBusy || WritesBlocked)"
                                           OnClick="() => RegisterIssuedStatementAsync(item)">
                                    Mark Issued
                                </MudButton>
                            </div>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="Mark Tax Filed">
                            <div class="book-governance-form">
                                <MudDatePicker Label="Filed On"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Disabled="@(_isBusy || WritesBlocked)"
                                               Editable="true"
                                               Date="@item.FiledTaxOnPicker"
                                               DateChanged="date => OnFiledTaxOnChanged(item, date)" />
                                <MudTextField T="string"
                                              Label="Filing Label"
                                              HelperText="Required."
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Disabled="@(_isBusy || WritesBlocked)"
                                              @bind-Value="item.FilingLabel" />
                                <MudTextField T="string"
                                              Label="Notes"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Disabled="@(_isBusy || WritesBlocked)"
                                              Lines="2"
                                              @bind-Value="item.FilingNotes" />
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Error"
                                           Disabled="@(_isBusy || WritesBlocked)"
                                           OnClick="() => RegisterFiledTaxAsync(item)">
                                    Mark Filed
                                </MudButton>
                            </div>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                </MudPaper>
            }
        </div>
    }
</div>

@code {
    private DateOnly _asOfDate = DateOnly.FromDateTime(DateTime.Today);
    private DateTime? _asOfDatePicker = DateTime.Today;
    private bool _isBusy;
    private string? _pageError;
    private List<BookGovernanceCardState> _books = [];
    private bool WritesBlocked => ShellState.AreWritesBlocked;

    protected override async Task OnInitializedAsync()
    {
        if (!await EnsureWriteGateStateAsync())
        {
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (!await EnsureWriteGateStateAsync())
        {
            return;
        }

        _pageError = null;
        _isBusy = true;
        try
        {
            var results = await Workflow.ListBookGovernanceAsync(ShellState.ActiveCompany.Id, _asOfDate, CancellationToken.None);
            _books = results.Select(item => new BookGovernanceCardState(item, _asOfDate)).ToList();
        }
        catch (Exception ex)
        {
            _pageError = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task RegisterClosedPeriodAsync(BookGovernanceCardState item)
    {
        if (TryBlockWrites())
        {
            return;
        }

        _isBusy = true;
        try
        {
            await Workflow.RegisterClosedPeriodAsync(
                ShellState.ActiveCompany.Id,
                item.Book.BookId,
                item.ClosePeriodDate,
                item.ClosePeriodReferenceLabel,
                item.ClosePeriodNotes,
                ShellState.CurrentUserId,
                CancellationToken.None);
            Snackbar.Add($"Closed period registered for {item.Book.BookCode}.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task RegisterIssuedStatementAsync(BookGovernanceCardState item)
    {
        if (TryBlockWrites())
        {
            return;
        }

        _isBusy = true;
        try
        {
            await Workflow.RegisterIssuedStatementAsync(
                ShellState.ActiveCompany.Id,
                item.Book.BookId,
                item.StatementIssuedOn,
                item.StatementLabel,
                item.StatementNotes,
                ShellState.CurrentUserId,
                CancellationToken.None);
            Snackbar.Add($"Issued statement registered for {item.Book.BookCode}.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task RegisterFiledTaxAsync(BookGovernanceCardState item)
    {
        if (TryBlockWrites())
        {
            return;
        }

        _isBusy = true;
        try
        {
            await Workflow.RegisterFiledTaxAsync(
                ShellState.ActiveCompany.Id,
                item.Book.BookId,
                item.FiledTaxOn,
                item.FilingLabel,
                item.FilingNotes,
                ShellState.CurrentUserId,
                CancellationToken.None);
            Snackbar.Add($"Filed-tax lock registered for {item.Book.BookCode}.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void OnAsOfDateChanged(DateTime? value)
    {
        _asOfDatePicker = value;
        _asOfDate = DateOnly.FromDateTime(value ?? DateTime.Today);
    }

    private async Task OnActiveCompanyChangedAsync(Guid companyId)
    {
        if (!ShellState.TrySetActiveCompany(companyId))
        {
            Snackbar.Add("The selected company is not available in this shell context.", Severity.Warning);
            return;
        }

        Snackbar.Add($"Governance context switched to {ShellState.ActiveCompany.CompanyName}.", Severity.Info);
        await LoadAsync();
    }

    private async Task<bool> EnsureWriteGateStateAsync()
    {
        await ShellState.EnsureHydratedAsync(CancellationToken.None);
        var probe = await SessionClient.ProbeContextAsync(CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe, CancellationToken.None))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(probe.ErrorMessage))
        {
            _pageError = probe.ErrorMessage;
        }

        return true;
    }

    private bool TryBlockWrites()
    {
        if (!WritesBlocked)
        {
            return false;
        }

        _pageError = ShellState.WriteBlockMessage;
        Snackbar.Add(ShellState.WriteBlockMessage, Severity.Warning);
        return true;
    }

    private static void OnClosePeriodDateChanged(BookGovernanceCardState item, DateTime? value)
    {
        item.ClosePeriodDatePicker = value;
        item.ClosePeriodDate = DateOnly.FromDateTime(value ?? DateTime.Today);
    }

    private static void OnStatementIssuedOnChanged(BookGovernanceCardState item, DateTime? value)
    {
        item.StatementIssuedOnPicker = value;
        item.StatementIssuedOn = DateOnly.FromDateTime(value ?? DateTime.Today);
    }

    private static void OnFiledTaxOnChanged(BookGovernanceCardState item, DateTime? value)
    {
        item.FiledTaxOnPicker = value;
        item.FiledTaxOn = DateOnly.FromDateTime(value ?? DateTime.Today);
    }

    private sealed class BookGovernanceCardState
    {
        public BookGovernanceCardState(CompanyBookGovernanceOverview source, DateOnly seedDate)
        {
            Source = source;
            ClosePeriodDate = seedDate;
            StatementIssuedOn = seedDate;
            FiledTaxOn = seedDate;
            ClosePeriodDatePicker = seedDate.ToDateTime(TimeOnly.MinValue);
            StatementIssuedOnPicker = seedDate.ToDateTime(TimeOnly.MinValue);
            FiledTaxOnPicker = seedDate.ToDateTime(TimeOnly.MinValue);
            StatementLabel = string.Empty;
            FilingLabel = string.Empty;
        }

        public CompanyBookGovernanceOverview Source { get; }
        public CompanyBookRecord Book => Source.Book;
        public CompanyBookRemeasurementPolicy? RemeasurementPolicy => Source.RemeasurementPolicy;
        public CompanyBookMigrationEligibility MigrationEligibility => Source.MigrationEligibility;
        public CompanyBookGovernanceSignalSummary GovernanceSignals => Source.GovernanceSignals;

        public DateOnly ClosePeriodDate { get; set; }
        public DateTime? ClosePeriodDatePicker { get; set; }
        public string? ClosePeriodReferenceLabel { get; set; }
        public string? ClosePeriodNotes { get; set; }

        public DateOnly StatementIssuedOn { get; set; }
        public DateTime? StatementIssuedOnPicker { get; set; }
        public string StatementLabel { get; set; }
        public string? StatementNotes { get; set; }

        public DateOnly FiledTaxOn { get; set; }
        public DateTime? FiledTaxOnPicker { get; set; }
        public string FilingLabel { get; set; }
        public string? FilingNotes { get; set; }
    }
}
