    private async Task ReloadDashboardAsync()
    {
        _dashboard = await InventoryFoundation.GetDashboardAsync(ShellState.ActiveCompany.Id);
        ApplyPolicyEditorFromDashboard();
    }

    private InventoryItemUpsertRequest BuildItemRequest()
    {
        var manageMethod = _itemEditor.ItemKind == InventoryItemKind.Stock
            ? _itemEditor.ManageInventoryMethod
            : ManageInventoryMethod.DontManageStock;
        var backorderMode = _itemEditor.ItemKind == InventoryItemKind.Stock
            ? _itemEditor.BackorderMode
            : InventoryBackorderMode.Disallow;
        var lowStockActivity = _itemEditor.ItemKind == InventoryItemKind.Stock
            ? _itemEditor.LowStockActivity
            : InventoryLowStockActivity.Nothing;
        var stockUomCode = _itemEditor.ItemKind == InventoryItemKind.Stock
            ? _itemEditor.StockUomCode
            : null;
        var defaultInventoryAssetAccountId = _itemEditor.ItemKind == InventoryItemKind.Stock
            ? _itemEditor.DefaultInventoryAssetAccountId
            : null;
        var defaultCogsAccountId = _itemEditor.ItemKind == InventoryItemKind.Stock
            ? _itemEditor.DefaultCogsAccountId
            : null;
        var defaultWriteOffAccountId = _itemEditor.ItemKind == InventoryItemKind.Stock
            ? _itemEditor.DefaultWriteOffAccountId
            : null;
        var defaultPurchaseVarianceAccountId = _itemEditor.ItemKind == InventoryItemKind.Stock
            ? _itemEditor.DefaultPurchaseVarianceAccountId
            : null;

        return new InventoryItemUpsertRequest(
            ShellState.ActiveCompany.Id,
            ShellState.CurrentUserId,
            _itemEditor.ItemId,
            _itemEditor.ItemCode,
            _itemEditor.Name,
            _itemEditor.Description,
            _itemEditor.ItemKind,
            stockUomCode,
            manageMethod,
            _itemEditor.DefaultCostingMethod,
            backorderMode,
            lowStockActivity,
            defaultInventoryAssetAccountId,
            defaultCogsAccountId,
            defaultWriteOffAccountId,
            defaultPurchaseVarianceAccountId);
    }

    private void EditItem(InventoryManagedItemSummary item)
    {
        _itemEditor = new ItemEditorState
        {
            ItemId = item.Id,
            ItemCode = item.ItemCode,
            Name = item.Name,
            Description = item.Description,
            ItemKind = item.ItemKind,
            StockUomCode = item.StockUomCode,
            ManageInventoryMethod = item.ManageInventoryMethod,
            DefaultCostingMethod = item.DefaultCostingMethod,
            BackorderMode = item.BackorderMode,
            LowStockActivity = item.LowStockActivity,
            DefaultInventoryAssetAccountId = item.DefaultInventoryAssetAccountId,
            DefaultCogsAccountId = item.DefaultCogsAccountId,
            DefaultWriteOffAccountId = item.DefaultWriteOffAccountId,
            DefaultPurchaseVarianceAccountId = item.DefaultPurchaseVarianceAccountId
        };
    }

    private void ResetItemEditor() => _itemEditor = new ItemEditorState();

    private void EditWarehouse(InventoryManagedWarehouseSummary warehouse)
    {
        _warehouseEditor = new WarehouseEditorState
        {
            WarehouseId = warehouse.Id,
            WarehouseCode = warehouse.WarehouseCode,
            Name = warehouse.Name,
            Description = warehouse.Description
        };
    }

    private void ResetWarehouseEditor() => _warehouseEditor = new WarehouseEditorState();

    private void ApplyPolicyEditorFromDashboard()
    {
        var policy = CurrentPolicy;
        _policyEditor = new PolicyEditorState
        {
            DefaultCostingMethod = policy?.DefaultCostingMethod ?? InventoryCostingMethod.MovingAverage,
            NegativeStockAllowed = policy?.NegativeStockAllowed ?? false,
            RequireWriteOffApproval = policy?.RequireWriteOffApproval ?? true
        };
    }

    private string GetCostingPolicyHeadline() =>
        CurrentPolicy is null
            ? "Not initialized"
            : $"{GetCostingMethodLabel(CurrentPolicy.DefaultCostingMethod)} / {(CurrentPolicy.NegativeStockAllowed ? "Negative allowed" : "Strict")}";

    private static string GetCostingMethodLabel(InventoryCostingMethod method) => method switch
    {
        InventoryCostingMethod.MovingAverage => "Moving average",
        InventoryCostingMethod.Fifo => "FIFO",
        _ => method.ToString()
    };

    private static string GetItemKindLabel(InventoryItemKind kind) => kind switch
    {
        InventoryItemKind.Stock => "Stock",
        InventoryItemKind.NonStock => "Non-stock",
        InventoryItemKind.Service => "Service",
        _ => kind.ToString()
    };

    private static string GetManageInventoryMethodLabel(ManageInventoryMethod method) => method switch
    {
        ManageInventoryMethod.DontManageStock => "Do not track stock",
        ManageInventoryMethod.ManageStock => "Track stock",
        ManageInventoryMethod.ManageStockBySku => "Track by SKU (guarded)",
        _ => method.ToString()
    };

    private bool IsManageInventoryMethodGuarded(ManageInventoryMethod method) =>
        method == ManageInventoryMethod.ManageStockBySku &&
        _itemEditor.ManageInventoryMethod != ManageInventoryMethod.ManageStockBySku;

    private static string GetBackorderModeLabel(InventoryBackorderMode mode) => mode switch
    {
        InventoryBackorderMode.Disallow => "Disallow",
        InventoryBackorderMode.AllowNegative => "Allow negative",
        InventoryBackorderMode.AllowNegativeWithWarning => "Allow negative with warning",
        _ => mode.ToString()
    };

    private static string GetLowStockActivityLabel(InventoryLowStockActivity activity) => activity switch
    {
        InventoryLowStockActivity.Nothing => "Do nothing",
        InventoryLowStockActivity.Warn => "Warn only",
        InventoryLowStockActivity.BlockOutbound => "Block outbound",
        _ => activity.ToString()
    };

    private static string GetItemDefaultsLabel(InventoryManagedItemSummary item)
    {
        if (item.ItemKind != InventoryItemKind.Stock)
        {
            return "Not inventory-managed";
        }

        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(item.DefaultInventoryAssetAccountLabel))
        {
            parts.Add($"Asset: {item.DefaultInventoryAssetAccountLabel}");
        }

        if (!string.IsNullOrWhiteSpace(item.DefaultCogsAccountLabel))
        {
            parts.Add($"COGS: {item.DefaultCogsAccountLabel}");
        }

        if (!string.IsNullOrWhiteSpace(item.DefaultWriteOffAccountLabel))
        {
            parts.Add($"Write-off: {item.DefaultWriteOffAccountLabel}");
        }

        if (!string.IsNullOrWhiteSpace(item.DefaultPurchaseVarianceAccountLabel))
        {
            parts.Add($"Variance: {item.DefaultPurchaseVarianceAccountLabel}");
        }

        return parts.Count == 0 ? "Missing defaults" : string.Join(" | ", parts);
    }

