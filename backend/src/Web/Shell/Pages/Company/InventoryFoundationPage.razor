    [
        InventoryCostingMethod.MovingAverage,
        InventoryCostingMethod.Fifo
    ];

    private static readonly InventoryBackorderMode[] BackorderModeOptions =
    [
        InventoryBackorderMode.Disallow,
        InventoryBackorderMode.AllowNegative,
        InventoryBackorderMode.AllowNegativeWithWarning
    ];

    private static readonly InventoryLowStockActivity[] LowStockActivityOptions =
    [
        InventoryLowStockActivity.Nothing,
        InventoryLowStockActivity.Warn,
        InventoryLowStockActivity.BlockOutbound
    ];

    private InventoryFoundationDashboard? _dashboard;
    private WebShellCompanyOnboardingSummary? _onboardingSummary;
    private string? _error;
    private bool _isSaving;
    private PolicyEditorState _policyEditor = new();
    private ItemEditorState _itemEditor = new();
    private WarehouseEditorState _warehouseEditor = new();

    private bool IsCompanyReadyHandOff => string.Equals(Origin, "company-ready", StringComparison.OrdinalIgnoreCase);
    private bool WritesBlocked => ShellState.AreWritesBlocked;
    private InventoryCostingPolicyRecord? CurrentPolicy => _dashboard?.Summary.CostingPolicy;
    private IReadOnlyList<InventoryManagedItemSummary> ActiveItems => _dashboard?.Items.Where(static item => item.IsActive).ToList() ?? [];
    private IReadOnlyList<InventoryManagedItemSummary> InactiveItems => _dashboard?.Items.Where(static item => !item.IsActive).ToList() ?? [];
    private IReadOnlyList<InventoryManagedWarehouseSummary> ActiveWarehouses => _dashboard?.Warehouses.Where(static warehouse => warehouse.IsActive).ToList() ?? [];
    private IReadOnlyList<InventoryFoundationAccountOption> InventoryAssetAccountOptions => _dashboard?.InventoryAssetAccountOptions ?? [];
    private IReadOnlyList<InventoryFoundationAccountOption> ExpenseAccountOptions => _dashboard?.ExpenseAccountOptions ?? [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _error = null;
            await ShellState.EnsureHydratedAsync();

            var probe = await SessionClient.ProbeContextAsync();
            if (await SessionExpirationCoordinator.HandleProbeAsync(probe))
            {
                return;
            }

            var onboardingResult = await OnboardingClient.GetAsync();
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(onboardingResult, CancellationToken.None))
            {
                return;
            }

            if (!onboardingResult.RequiresSignIn &&
                !onboardingResult.IsNotFound &&
                string.IsNullOrWhiteSpace(onboardingResult.ErrorMessage))
            {
                _onboardingSummary = onboardingResult.Value;
            }

            if (_onboardingSummary is not null && !_onboardingSummary.SupportsInventoryFoundation)
            {
                return;
            }

            _dashboard = await InventoryFoundation.EnsureDashboardAsync(ShellState.ActiveCompany.Id, ShellState.CurrentUserId);
            ApplyPolicyEditorFromDashboard();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SavePolicyAsync()
    {
        if (_dashboard is null)
        {
            return;
        }

        try
        {
            _isSaving = true;
            _error = null;
            await InventoryFoundation.SavePolicyAsync(
                new InventoryCostingPolicyUpdateRequest(
                    ShellState.ActiveCompany.Id,
                    ShellState.CurrentUserId,
                    _policyEditor.DefaultCostingMethod,
                    _policyEditor.NegativeStockAllowed,
                    _policyEditor.RequireWriteOffApproval),
                _dashboard);
            await ReloadDashboardAsync();
            Snackbar.Add("Inventory costing policy saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task SaveItemAsync()
    {
