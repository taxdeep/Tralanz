@page "/ap/vendors"
@using AntDesign
@using Web.Business.AP.Aging
@inject WebShellState ShellState
@inject WebShellBusinessSessionClient SessionClient
@inject WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject ShellCounterpartyOnboardingClient CounterpartyOnboarding
@inject ApAgingReportClient AgingClient

<PageTitle>Vendors</PageTitle>

<div class="vendor-dashboard">
    <section class="vendor-dashboard__header">
        <div>
            <a class="vendor-dashboard__back-link" href="/">Back to shell</a>
            <h1>Vendors</h1>
            <p>AP vendor command center. Vendors live here; customers stay in AR.</p>
        </div>
        <div class="vendor-dashboard__actions">
            <Button Type="@AntDesign.ButtonType.Default" Href="/documents/source-browser?sourceType=bill&counterpartyRole=vendor">Bill transactions</Button>
            <Button Type="@AntDesign.ButtonType.Primary" Href="/company/customer-vendor-setup?create=vendor&returnUrl=/ap/vendors">New vendor</Button>
        </div>
    </section>

    <div class="vendor-dashboard__tabs" aria-label="Vendor dashboard sections">
        <span class="vendor-dashboard__tab vendor-dashboard__tab--active">Vendors</span>
        <span class="vendor-dashboard__tab vendor-dashboard__tab--muted">Contractors</span>
        <span class="vendor-dashboard__tab vendor-dashboard__tab--muted">AP Profile</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="ant-alert ant-alert-warning vendor-dashboard__alert">
            <i class="ti ti-alert-triangle" aria-hidden="true"></i>
            <span>@_error</span>
        </div>
    }

    @if (WritesBlocked)
    {
        <div class="ant-alert ant-alert-warning vendor-dashboard__alert">
            <i class="ti ti-lock" aria-hidden="true"></i>
            <span>@ShellState.WriteBlockMessage</span>
        </div>
    }

    @if (_isLoading)
    {
        <div class="vendor-dashboard__loading">
            <div class="vendor-dashboard__loading-bar"></div>
            <span>Loading vendor AP surface...</span>
        </div>
    }
    else
    {
        <section class="vendor-dashboard__summary-strip">
            <Card Class="vendor-dashboard__summary-card">
                <Statistic T="int" Title="Active vendors" Value="@ActiveVendorCount" />
                <span>Payable-ready vendor truth</span>
            </Card>
            <Card Class="vendor-dashboard__summary-card">
                <Statistic T="int" Title="Open AP items" Value="@(_agingReport?.OpenItemCount ?? 0)" />
                <span>Posted bills and credits still open</span>
            </Card>
            <Card Class="vendor-dashboard__summary-card">
                <Statistic T="decimal" Title="Outstanding payable" Value="@(_agingReport?.TotalOutstandingAmountBase ?? 0m)" Prefix="@CurrencyPrefix" Precision="2" />
                <span>@BaseCurrencyCode base currency</span>
            </Card>
            <Card Class="vendor-dashboard__summary-card vendor-dashboard__summary-card--amber">
                <Statistic T="decimal" Title="Overdue bills" Value="@(_agingReport?.TotalOverdueAmountBase ?? 0m)" Prefix="@CurrencyPrefix" Precision="2" />
                <span>AP payment attention</span>
            </Card>
        </section>

        <section class="vendor-dashboard__bar" aria-label="Vendor payable composition">
            <div class="vendor-dashboard__bar-segment vendor-dashboard__bar-segment--blue" style="@BuildBarWidth(ActiveVendorCount, Math.Max(TotalVendorCount, 1))"></div>
            <div class="vendor-dashboard__bar-segment vendor-dashboard__bar-segment--purple" style="@BuildBarWidth(InactiveVendorCount, Math.Max(TotalVendorCount, 1))"></div>
            <div class="vendor-dashboard__bar-segment vendor-dashboard__bar-segment--orange" style="@BuildBarWidth(_agingReport?.OpenItemCount ?? 0, Math.Max((_agingReport?.OpenItemCount ?? 0) + 1, 1))"></div>
            <div class="vendor-dashboard__bar-segment vendor-dashboard__bar-segment--green" style="@BuildBarWidth(_agingReport?.VendorRows.Count ?? 0, Math.Max(ActiveVendorCount, 1))"></div>
        </section>

        <section class="vendor-dashboard__toolbar">
            <label class="vendor-dashboard__search">
                <i class="ti ti-search" aria-hidden="true"></i>
                <input class="ant-input" placeholder="Search vendors by name, entity, email, phone, or currency" @bind="_searchText" @bind:event="oninput" />
            </label>
            <div class="vendor-dashboard__tools">
                <span>@FilteredRows.Count vendor(s)</span>
                <a class="ant-btn" href="/ap/aging">AP aging</a>
                <a class="ant-btn" href="/ap/pay-bill">Pay bill</a>
            </div>
        </section>

        <section class="vendor-dashboard__table-card">
            <table class="ant-table vendor-dashboard__table">
                <thead class="ant-table-thead">
                    <tr>
                        <th>Name</th>
                        <th>Company name</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Currency</th>
                        <th>Open balance</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody class="ant-table-tbody">
                    @if (FilteredRows.Count == 0)
                    {
                        <tr>
                            <td colspan="8">
                                <div class="vendor-dashboard__empty">No vendor matched the current search.</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var row in FilteredRows)
                        {
                            <tr>
                                <td>
                                    <a class="vendor-dashboard__vendor-link" href="@BuildVendorProfileHref(row.Vendor.Id)">
                                        @row.Vendor.DisplayName
                                    </a>
                                    <div class="vendor-dashboard__subtext">@row.Vendor.EntityNumber</div>
                                </td>
                                <td>@row.Vendor.DisplayName</td>
                                <td>@DisplayOptional(row.Vendor.Phone)</td>
                                <td>@DisplayOptional(row.Vendor.Email)</td>
                                <td>@row.Vendor.DefaultCurrencyCode</td>
                                <td>@FormatMoney(row.OpenBalanceBase)</td>
                                <td>
                                    <span class="vendor-dashboard__status @(row.Vendor.IsActive ? "vendor-dashboard__status--active" : "vendor-dashboard__status--inactive")">
                                        @(row.Vendor.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <a class="vendor-dashboard__row-action" href="@BuildBillHref(row.Vendor.Id)">Create bill</a>
                                    <span class="vendor-dashboard__action-separator">|</span>
                                    <a class="vendor-dashboard__row-action" href="@BuildPayBillHref(row.Vendor.Id)">Pay bill</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </section>
    }
</div>

@code {
    private ShellCounterpartyOnboardingSummary? _summary;
    private ApAgingReportViewModel? _agingReport;
    private string _searchText = string.Empty;
    private string? _error;
    private bool _isLoading = true;

    private bool WritesBlocked => ShellState.AreWritesBlocked;
    private string BaseCurrencyCode => _agingReport?.BaseCurrencyCode ?? _summary?.BaseCurrencyCode ?? ShellState.ActiveCompany.BaseCurrencyCode;
    private string CurrencyPrefix => $"{BaseCurrencyCode} ";
    private int TotalVendorCount => _summary?.Vendors.Count ?? 0;
    private int ActiveVendorCount => _summary?.ActiveVendors.Count ?? 0;
    private int InactiveVendorCount => Math.Max(TotalVendorCount - ActiveVendorCount, 0);

    private IReadOnlyList<VendorDashboardRow> Rows =>
        (_summary?.Vendors ?? Array.Empty<ShellManagedCounterpartySummary>())
        .Select(vendor =>
        {
            var aging = _agingReport?.VendorRows.FirstOrDefault(item => item.VendorId == vendor.Id);
            return new VendorDashboardRow(vendor, aging?.OpenItemCount ?? 0, aging?.TotalOutstandingAmountBase ?? 0m, aging?.TotalOverdueAmountBase ?? 0m);
        })
        .OrderByDescending(static row => row.Vendor.IsActive)
        .ThenBy(static row => row.Vendor.DisplayName, StringComparer.OrdinalIgnoreCase)
        .ToArray();

    private IReadOnlyList<VendorDashboardRow> FilteredRows =>
        string.IsNullOrWhiteSpace(_searchText)
            ? Rows
            : Rows.Where(MatchesSearch).ToArray();

    protected override async Task OnInitializedAsync()
    {
        await ShellState.EnsureHydratedAsync();
        var probe = await SessionClient.ProbeContextAsync();
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe))
        {
            return;
        }

        if (probe.Context is null)
        {
            _error = probe.ErrorMessage ?? WebShellBusinessSessionClient.AuthenticationRequiredError;
            _isLoading = false;
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _isLoading = true;
            _summary = await CounterpartyOnboarding.GetSummaryAsync(ShellState.ActiveCompany.Id);

            var agingResult = await AgingClient.GetAsync(ShellState.ActiveCompany.Id, DateOnly.FromDateTime(DateTime.UtcNow));
            if (agingResult.Value is not null)
            {
                _agingReport = agingResult.Value;
            }
            else if (!string.IsNullOrWhiteSpace(agingResult.ErrorMessage))
            {
                _error = agingResult.ErrorMessage;
            }

            _error = _summary is null ? _error : null;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool MatchesSearch(VendorDashboardRow row)
    {
        var text = _searchText.Trim();
        return Contains(row.Vendor.DisplayName, text)
            || Contains(row.Vendor.EntityNumber, text)
            || Contains(row.Vendor.Email, text)
            || Contains(row.Vendor.Phone, text)
            || Contains(row.Vendor.DefaultCurrencyCode, text);
    }

    private static bool Contains(string value, string searchText) =>
        value.Contains(searchText, StringComparison.OrdinalIgnoreCase);

    private string FormatMoney(decimal value) =>
        $"{BaseCurrencyCode} {value:N2}";

    private static string DisplayOptional(string value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string BuildVendorProfileHref(Guid vendorId) =>
        $"/ap/vendors/{vendorId:D}";

    private static string BuildBillHref(Guid vendorId) =>
        $"/documents/bill/draft-editor?vendorId={vendorId:D}&origin=vendor-dashboard";

    private static string BuildPayBillHref(Guid vendorId) =>
        $"/ap/pay-bill?vendorId={vendorId:D}";

    private static string BuildBarWidth(int value, int total)
    {
        var percent = total <= 0 ? 0 : Math.Clamp((decimal)value / total * 100m, 5m, 100m);
        return $"width:{percent:0.##}%";
    }

    private sealed record VendorDashboardRow(
        ShellManagedCounterpartySummary Vendor,
        int OpenItemCount,
        decimal OpenBalanceBase,
        decimal OverdueBalanceBase);
}
