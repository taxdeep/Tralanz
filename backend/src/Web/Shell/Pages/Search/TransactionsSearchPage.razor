@page "/transactions"
@using Citus.Modules.UnitySearch.Application.Contracts
@using Citus.Modules.UnitySearch.Domain.Shared
@using Web.Shell.Services
@using Web.Shell.State
@rendermode InteractiveServer
@inject UnitySearchClient SearchClient
@inject WebShellState ShellState
@inject NavigationManager Navigation

<PageTitle>Transactions | Balanciz</PageTitle>

<section class="unity-transactions">
    <header class="unity-transactions__hero">
        <div>
            <div class="unity-transactions__eyebrow">Balanciz UnitySearch</div>
            <h1 class="unity-transactions__title">Transactions</h1>
            <p class="unity-transactions__description">
                Search transactions, contacts, products, reports, and navigation surfaces inside the active company context.
            </p>
        </div>
        <div class="unity-transactions__badge">
            <span>Active company</span>
            <strong>@ShellState.ActiveCompany.CompanyName</strong>
        </div>
    </header>

    <section class="unity-transactions__search-shell">
        <form class="unity-transactions__search-form" @onsubmit="ExecuteSearchAsync">
            <i class="ti ti-search unity-transactions__search-icon" aria-hidden="true"></i>
            <input class="unity-transactions__search-input"
                   type="search"
                   placeholder="Search transactions, contacts, products..."
                   @bind="_searchText"
                   @bind:event="oninput" />
            <button type="submit" class="unity-transactions__search-button">Search</button>
        </form>
        <div class="unity-transactions__hint">
            Global results stay company-scoped and route-aware. Exact codes, recent clicks, and active records rank higher.
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="unity-transactions__empty">Searching the active company workspace...</div>
    }
    else if (!string.IsNullOrWhiteSpace(_searchText))
    {
        if ((_result?.Groups.Count ?? 0) == 0)
        {
            <div class="unity-transactions__empty">No results matched this search in the active company context.</div>
        }
        else
        {
            <div class="unity-transactions__groups">
                @foreach (var group in _result!.Groups)
                {
                    <section class="unity-transactions__group">
                        <div class="unity-transactions__group-header">
                            <h2>@group.Title</h2>
                            <span>@group.Items.Count item(s)</span>
                        </div>
                        <div class="unity-transactions__cards">
                            @foreach (var item in group.Items)
                            {
                                <button type="button"
                                        class="unity-transactions__card"
                                        @onclick="@(() => NavigateToSuggestionAsync(item))">
                                    <div class="unity-transactions__card-primary">@item.PrimaryText</div>
                                    @if (!string.IsNullOrWhiteSpace(item.SecondaryText))
                                    {
                                        <div class="unity-transactions__card-secondary">@item.SecondaryText</div>
                                    }
                                    <div class="unity-transactions__card-meta">
                                        <span>@item.EntityType.Replace('_', ' ')</span>
                                        @if (item.EffectiveDate.HasValue)
                                        {
                                            <span>@item.EffectiveDate.Value.ToString("yyyy-MM-dd")</span>
                                        }
                                        @if (item.Amount.HasValue)
                                        {
                                            <span>@item.Amount.Value.ToString("N2")</span>
                                        }
                                    </div>
                                </button>
                            }
                        </div>
                    </section>
                }
            </div>
        }
    }
    else if (_recentQueries.Count > 0)
    {
        <section class="unity-transactions__recent">
            <div class="unity-transactions__group-header">
                <h2>Recent queries</h2>
                <span>@_recentQueries.Count item(s)</span>
            </div>
            <div class="unity-transactions__recent-list">
                @foreach (var recentQuery in _recentQueries)
                {
                    <button type="button" class="unity-transactions__recent-chip" @onclick="@(() => UseRecentQueryAsync(recentQuery.QueryText))">
                        <i class="ti ti-history" aria-hidden="true"></i>
                        <span>@recentQuery.QueryText</span>
                    </button>
                }
            </div>
        </section>
    }
</section>

@code
{
    [SupplyParameterFromQuery(Name = "q")]
    public string? Query { get; set; }

    private string _searchText = string.Empty;
    private bool _isLoading;
    private UnitySearchResult? _result;
    private IReadOnlyList<UnitySearchRecentQueryRecord> _recentQueries = Array.Empty<UnitySearchRecentQueryRecord>();

    protected override async Task OnParametersSetAsync()
    {
        _searchText = Query?.Trim() ?? string.Empty;
        if (!ShellState.IsAuthenticated || ShellState.ActiveCompany.Id == Guid.Empty)
        {
            _result = null;
            _recentQueries = Array.Empty<UnitySearchRecentQueryRecord>();
            return;
        }

        if (string.IsNullOrWhiteSpace(_searchText))
        {
            _result = null;
            _recentQueries = await SearchClient.ListRecentQueriesAsync(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                SearchScopeContext.GlobalTransactions,
                10);
            return;
        }

        await LoadSearchResultAsync();
    }

    private async Task ExecuteSearchAsync()
    {
        var query = _searchText.Trim();
        if (string.IsNullOrWhiteSpace(query))
        {
            Navigation.NavigateTo("/transactions");
            return;
        }

        Navigation.NavigateTo($"/transactions?q={Uri.EscapeDataString(query)}");
        await Task.CompletedTask;
    }

    private async Task LoadSearchResultAsync()
    {
        _isLoading = true;
        try
        {
            _result = await SearchClient.SearchAsync(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                SearchScopeContext.GlobalTransactions,
                _searchText,
                30);
            _recentQueries = Array.Empty<UnitySearchRecentQueryRecord>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task NavigateToSuggestionAsync(UnitySearchSuggestion suggestion)
    {
        await SearchClient.RecordClickAsync(
            ShellState.ActiveCompany.Id,
            ShellState.CurrentUserId,
            SearchScopeContext.GlobalTransactions,
            suggestion.EntityType,
            suggestion.SourceId);
        Navigation.NavigateTo(suggestion.NavigationHref);
    }

    private async Task UseRecentQueryAsync(string queryText)
    {
        _searchText = queryText;
        Navigation.NavigateTo($"/transactions?q={Uri.EscapeDataString(queryText)}");
        await Task.CompletedTask;
    }
}
