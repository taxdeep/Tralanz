@page "/documents/receipt/draft-editor"
@using Citus.Modules.Inventory.Application.Contracts
@using Citus.Modules.Inventory.Domain.Shared
@using Web.Business.AP.SettlementLookup
@using Web.Shell.Services
@inject WebShellState ShellState
@inject WebShellBusinessSessionClient SessionClient
@inject WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject IApSettlementLookupService Vendors
@inject ShellInventoryReceiptClient InventoryReceipt
@inject ShellSourceDocumentDraftClient Drafts
@inject ShellAccountingDocumentReviewClient ReviewClient
@inject ShellBillReceiptMatchingClient BillReceiptMatching
@inject ISnackbar Snackbar

<PageTitle>Receipt Draft | Citus Web Shell</PageTitle>

<div style="padding:2rem 2.25rem;color:#d9e2ea;">
    <div style="display:flex;gap:.75rem;align-items:center;flex-wrap:wrap;margin-bottom:1rem;">
        <MudButton Variant="Variant.Text" Href="/documents/source-browser?sourceType=purchase_order" StartIcon="@Icons.Material.Filled.ArrowBack">
            Back
        </MudButton>
        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">Receipt draft</MudChip>
        @if (IsPurchaseOrderHandoff)
        {
            <MudChip T="string" Variant="Variant.Filled" Color="Color.Success">PO anchored</MudChip>
        }
        @if (IsBillHandoff)
        {
            <MudChip T="string" Variant="Variant.Filled" Color="Color.Warning">Bill hand-off</MudChip>
        }
    </div>

    <h1 style="margin:0 0 .75rem 0;">Receipt Draft Workbench</h1>
    <p style="margin:0 0 1rem 0;color:#97a8b7;max-width:62rem;">
        Create first-class inbound receipt truth before GR/IR, valuation, cost-layer emission, AP settlement, and purchase variance controls depend on it.
    </p>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Style="margin-bottom:1rem;">@_error</MudAlert>
    }

    @if (WritesBlocked)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">@ShellState.WriteBlockMessage</MudAlert>
    }
    else if (!CanEditDraft)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            This receipt is no longer a draft. Use receipt control for activation, valuation, GR/IR, and settlement follow-up.
        </MudAlert>
    }

    @if (IsPostedReceipt)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            Receipt @_saved?.DisplayNumber has been posted. Continue into Receipt Control to refresh inventory activation, valuation, cost-layer, GR/IR, AP settlement, and purchase variance controls.
            <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:.75rem;">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@BuildReceiptControlHref()">
                    Open Receipt Control
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="/documents/source-browser?sourceType=receipt">
                    Browse Receipts
                </MudButton>
            </div>
        </MudAlert>
    }

    @if (_purchaseOrder is not null)
    {
        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;border:1px solid rgba(119,210,160,.35);">
            <div style="display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;align-items:center;">
                <div>
                    <MudText Typo="Typo.caption">Purchase Order Anchor</MudText>
                    <MudText Typo="Typo.h6">@_purchaseOrder.DisplayNumber</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        @($"{_purchaseOrder.Status} | {_purchaseOrder.Lines.Count} ordered line(s) | vendor {_purchaseOrder.VendorId:D}")
                    </MudText>
                </div>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@($"/documents/purchase_order/{_purchaseOrder.Id:D}")">
                    Open PO
                </MudButton>
            </div>
        </MudPaper>
    }

    @if (_loadedBillDraft is not null)
    {
        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;border:1px solid rgba(255,193,7,.35);">
            <div style="display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;align-items:center;">
                <div>
                    <MudText Typo="Typo.caption">Bill Hand-off</MudText>
                    <MudText Typo="Typo.h6">@_loadedBillDraft.DisplayNumber</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        @($"{_loadedBillDraft.Status} | {_loadedBillDraft.Lines.Count} bill line(s) | vendor {_loadedBillDraft.VendorId:D}")
                    </MudText>
                </div>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@($"/documents/bill/draft-editor?draftId={_loadedBillDraft.Id:D}")">
                    Open Bill
                </MudButton>
            </div>
        </MudPaper>
    }

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(14rem,1fr));gap:1rem;margin-bottom:1rem;">
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.caption">Vendor Readiness</MudText>
            <MudText Typo="Typo.h6">@(_vendorOptions.Count > 0 ? $"{_vendorOptions.Count} vendor option(s)" : "Missing")</MudText>
            <MudText Typo="Typo.body2" Class="text-secondary">@GetVendorReadinessSummary()</MudText>
        </MudPaper>
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.caption">Warehouse Readiness</MudText>
            <MudText Typo="Typo.h6">@(_dashboard?.ActiveWarehouses.Count ?? 0)</MudText>
            <MudText Typo="Typo.body2" Class="text-secondary">Receipt drafts require one active receiving warehouse.</MudText>
        </MudPaper>
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.caption">Item Readiness</MudText>
            <MudText Typo="Typo.h6">@OperationalItems.Count</MudText>
            <MudText Typo="Typo.body2" Class="text-secondary">Only stock-managed active items can be received.</MudText>
        </MudPaper>
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.caption">Draft Status</MudText>
            <MudText Typo="Typo.h6">@(_saved?.Status ?? "New draft")</MudText>
            <MudText Typo="Typo.body2" Class="text-secondary">@(_saved?.DisplayNumber ?? "Not saved yet")</MudText>
        </MudPaper>
    </div>

    @if (_dashboard is not null && _dashboard.ActiveWarehouses.Count == 0)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            No active warehouse is available. Open Inventory Foundation first, create an active warehouse, then return to the receipt draft.
        </MudAlert>
    }

    @if (OperationalItems.Count == 0)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            No active stock-managed item is available. Open Inventory Foundation first, create an active stock item, then return to the receipt draft.
        </MudAlert>
    }

    <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
        <MudText Typo="Typo.h6" Class="mb-3">Header</MudText>
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudSelect T="string" Label="Vendor" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="_vendorIdText" Disabled="@HeaderMutationBlocked">
                    @foreach (var vendor in _vendorOptions)
                    {
                        <MudSelectItem T="string" Value="@vendor.Id.ToString("D")">@vendor.DisplayLabel</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="Guid?" Label="Warehouse" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="_warehouseId" Disabled="@WarehouseMutationBlocked">
                    @foreach (var warehouse in ActiveWarehouses)
                    {
                        <MudSelectItem T="Guid?" Value="@warehouse.Id">@($"{warehouse.WarehouseCode} - {warehouse.Name}")</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudDatePicker Label="Receipt Date" Variant="Variant.Outlined" Margin="Margin.Dense" Date="@_receiptDatePicker" DateChanged="OnReceiptDateChanged" Disabled="@DraftMutationBlocked" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField T="string" Label="Vendor Reference" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="_vendorReference" Disabled="@DraftMutationBlocked" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField T="string" Label="Source Reference" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="_sourceReference" Disabled="@DraftMutationBlocked" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField T="string" Label="Memo" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="_memo" Disabled="@DraftMutationBlocked" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:.75rem;">
            <div>
                <MudText Typo="Typo.h6">Lines</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@($"{_lines.Count} line(s), {_lines.Sum(static line => line.Quantity):N2} total quantity")</MudText>
            </div>
            <MudButton Variant="Variant.Outlined" Color="Color.Info" Disabled="@DraftMutationBlocked" OnClick="AddLine">
                Add line
            </MudButton>
        </div>

        <MudTable Items="_lines" Dense="true" Hover="true" Bordered="true">
            <HeaderContent>
                <MudTh>#</MudTh>
                <MudTh>Item</MudTh>
                <MudTh>Qty</MudTh>
                <MudTh>UOM</MudTh>
                <MudTh>Tracking</MudTh>
                <MudTh>PO Anchor</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.LineNumber</MudTd>
                <MudTd>
                    <MudSelect T="Guid?" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(DraftMutationBlocked || context.IsPurchaseOrderAnchored)" Value="context.ItemId" ValueChanged="@(value => ApplyItem(context, value))">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">-- Select --</MudSelectItem>
                        @foreach (var item in OperationalItems)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)item.Id)">@($"{item.ItemCode} {item.Name}")</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd><MudNumericField T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.01m" Immediate="true" @bind-Value="context.Quantity" Disabled="@DraftMutationBlocked" /></MudTd>
                <MudTd><MudTextField T="string" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="context.UomCode" Disabled="@(DraftMutationBlocked || context.IsPurchaseOrderAnchored)" /></MudTd>
                <MudTd><MudTextField T="string" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="context.TrackingCaptureHome" Disabled="@DraftMutationBlocked" /></MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2">@FormatPurchaseOrderAnchor(context)</MudText>
                    @if (context.IsPurchaseOrderAnchored)
                    {
                        <MudText Typo="Typo.caption" Class="text-secondary">@context.PurchaseOrderId?.ToString("D")</MudText>
                    }
                </MudTd>
                <MudTd>
                    <MudButton Variant="Variant.Text" Color="Color.Error" Disabled="@(_lines.Count == 1 || DraftMutationBlocked || context.IsPurchaseOrderAnchored)" OnClick="@(() => RemoveLine(context))">
                        X
                    </MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0">
        <div style="display:flex;gap:.75rem;flex-wrap:wrap;align-items:center;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_saving || DraftMutationBlocked)" OnClick="SaveAsync">
                @(_saving ? "Saving..." : "Save Receipt")
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(_posting || DraftMutationBlocked || !_documentId.HasValue)" OnClick="PostAsync">
                @(_posting ? "Posting..." : "Post Receipt")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@BuildReceiptControlHref()">
                Receipt Control
            </MudButton>
            @if (_saved is not null)
            {
                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">@($"{_saved.DisplayNumber} | {_saved.Status}")</MudChip>
            }
        </div>
    </MudPaper>
</div>

@code {
    [SupplyParameterFromQuery(Name = "draftId")]
    public Guid? DraftId { get; set; }

    [SupplyParameterFromQuery(Name = "purchaseOrderId")]
    public Guid? PurchaseOrderId { get; set; }

    [SupplyParameterFromQuery(Name = "billId")]
    public Guid? BillId { get; set; }

    [SupplyParameterFromQuery(Name = "vendorId")]
    public Guid? VendorId { get; set; }

    private readonly List<ReceiptLineEditor> _lines = [ReceiptLineEditor.Blank(1)];
    private IReadOnlyList<(Guid Id, string DisplayLabel, string CurrencyCode)> _vendorOptions = Array.Empty<(Guid Id, string DisplayLabel, string CurrencyCode)>();
    private InventoryPurchaseReceiptDashboard? _dashboard;
    private ShellPurchaseOrderReviewSummary? _purchaseOrder;
    private ShellPurchaseSourceDocumentDraftReadModel? _loadedBillDraft;
    private Guid? _documentId;
    private Guid? _loadedDraftId;
    private Guid? _loadedPurchaseOrderId;
    private Guid? _loadedBillId;
    private Guid? _warehouseId;
    private string? _vendorIdText;
    private string? _vendorReference;
    private string? _sourceReference;
    private string? _memo;
    private string? _error;
    private bool _saving;
    private bool _posting;
    private ShellSourceDocumentDraftSaveResult? _saved;
    private DateOnly _receiptDate = DateOnly.FromDateTime(DateTime.Today);
    private DateTime? _receiptDatePicker = DateTime.Today;

    private bool WritesBlocked => ShellState.AreWritesBlocked;
    private bool CanEditDraft => _saved is null || string.Equals(_saved.Status, "draft", StringComparison.OrdinalIgnoreCase);
    private bool IsPurchaseOrderHandoff => _purchaseOrder is not null || _lines.Any(static line => line.IsPurchaseOrderAnchored);
    private bool IsBillHandoff => _loadedBillDraft is not null;
    private bool DraftMutationBlocked => WritesBlocked || !CanEditDraft || ActiveWarehouses.Count == 0 || OperationalItems.Count == 0;
    private bool HeaderMutationBlocked => DraftMutationBlocked || IsPurchaseOrderHandoff || IsBillHandoff;
    private bool WarehouseMutationBlocked => DraftMutationBlocked || IsBillHandoff;
    private bool IsPostedReceipt => _documentId.HasValue && string.Equals(_saved?.Status, "posted", StringComparison.OrdinalIgnoreCase);
    private IReadOnlyList<InventoryManagedWarehouseSummary> ActiveWarehouses => _dashboard?.ActiveWarehouses ?? [];
    private IReadOnlyList<InventoryManagedItemSummary> OperationalItems =>
        _dashboard?.ActiveItems
            .Where(static item => item.IsActive && item.ManageInventoryMethod == ManageInventoryMethod.ManageStock)
            .OrderBy(static item => item.ItemCode)
            .ToArray() ?? [];

    protected override async Task OnParametersSetAsync()
    {
        if (!await EnsureLookupLoadedAsync())
        {
            return;
        }

        if (DraftId.HasValue && DraftId != _loadedDraftId)
        {
            await LoadDraftAsync(DraftId.Value);
            return;
        }

        if (!DraftId.HasValue &&
            PurchaseOrderId.HasValue &&
            PurchaseOrderId != _loadedPurchaseOrderId)
        {
            await LoadPurchaseOrderHandoffAsync(PurchaseOrderId.Value);
            return;
        }

        if (!DraftId.HasValue &&
            !PurchaseOrderId.HasValue &&
            BillId.HasValue &&
            BillId != _loadedBillId)
        {
            await LoadBillHandoffAsync(BillId.Value);
            return;
        }

        SeedDefaults();
    }

    private async Task<bool> EnsureLookupLoadedAsync()
    {
        if (_vendorOptions.Count > 0 && _dashboard is not null)
        {
            return true;
        }

        await ShellState.EnsureHydratedAsync();
        var probe = await SessionClient.ProbeContextAsync(CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe, CancellationToken.None))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(probe.ErrorMessage))
        {
            _error = probe.ErrorMessage;
        }

        _vendorOptions = await Vendors.ListVendorsAsync(ShellState.ActiveCompany.Id, CancellationToken.None);
        _dashboard = await InventoryReceipt.GetDashboardAsync(ShellState.ActiveCompany.Id, CancellationToken.None);
        SeedDefaults();
        return true;
    }

    private async Task LoadDraftAsync(Guid documentId)
    {
        var result = await Drafts.GetReceiptDraftAsync(ShellState.ActiveCompany.Id, documentId, CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
        {
            return;
        }

        var draft = result.Value;
        if (draft is null)
        {
            _error = result.IsNotFound ? "The receipt draft could not be found in the active company context." : result.ErrorMessage ?? "Unable to load the receipt draft.";
            return;
        }

        _documentId = draft.Id;
        _loadedDraftId = draft.Id;
        _saved = new ShellSourceDocumentDraftSaveResult
        {
            DocumentId = draft.Id,
            EntityNumber = draft.EntityNumber,
            DisplayNumber = draft.DisplayNumber,
            Status = draft.Status
        };
        _vendorIdText = draft.VendorId.ToString("D");
        _warehouseId = draft.WarehouseId;
        _receiptDate = draft.ReceiptDate;
        _receiptDatePicker = draft.ReceiptDate.ToDateTime(TimeOnly.MinValue);
        _vendorReference = draft.VendorReference;
        _sourceReference = draft.SourceReference;
        _memo = draft.Memo;
        _lines.Clear();
        _lines.AddRange(draft.Lines.Select(line => new ReceiptLineEditor
        {
            LineNumber = line.LineNumber,
            ItemId = line.ItemId,
            Quantity = line.Quantity,
            UomCode = line.UomCode,
            TrackingCaptureHome = line.TrackingCaptureHome,
            PurchaseOrderId = line.PurchaseOrderId,
            PurchaseOrderLineNumber = line.PurchaseOrderLineNumber
        }));

        if (_lines.Count == 0)
        {
            _lines.Add(ReceiptLineEditor.Blank(1));
        }
    }

    private async Task LoadPurchaseOrderHandoffAsync(Guid purchaseOrderId)
    {
        var result = await ReviewClient.GetPurchaseOrderAsync(ShellState.ActiveCompany.Id, purchaseOrderId, CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
        {
            return;
        }

        var purchaseOrder = result.Value;
        if (purchaseOrder is null)
        {
            _error = result.IsNotFound ? "The purchase order could not be found in the active company context." : result.ErrorMessage ?? "Unable to load the purchase order.";
            return;
        }

        if (!CanCreateReceiptFromPurchaseOrder(purchaseOrder))
        {
            _error = "Only issued purchase orders can start a governed receipt draft.";
            return;
        }

        _purchaseOrder = purchaseOrder;
        _loadedPurchaseOrderId = purchaseOrder.Id;
        _vendorIdText = purchaseOrder.VendorId.ToString("D");
        _sourceReference = purchaseOrder.DisplayNumber;
        _vendorReference = purchaseOrder.VendorReference;
        _memo = string.IsNullOrWhiteSpace(purchaseOrder.Memo)
            ? $"Receipt hand-off from {purchaseOrder.DisplayNumber}"
            : $"Receipt hand-off from {purchaseOrder.DisplayNumber}: {purchaseOrder.Memo}";

        _lines.Clear();
        foreach (var line in purchaseOrder.Lines.OrderBy(static line => line.LineNumber))
        {
            var remaining = purchaseOrder.ThreeQuantity?.Lines
                .FirstOrDefault(current => current.LineNumber == line.LineNumber)
                ?.RemainingToReceiveQuantity;
            var quantity = remaining.HasValue && remaining.Value > 0m
                ? remaining.Value
                : line.OrderedQuantity;
            if (quantity <= 0m)
            {
                continue;
            }

            _lines.Add(new ReceiptLineEditor
            {
                LineNumber = _lines.Count + 1,
                ItemId = line.ItemId,
                Quantity = quantity,
                UomCode = line.UomCode,
                TrackingCaptureHome = null,
                PurchaseOrderId = purchaseOrder.Id,
                PurchaseOrderLineNumber = line.LineNumber
            });
        }

        if (_lines.Count == 0)
        {
            _lines.Add(ReceiptLineEditor.Blank(1));
            _error = "The selected purchase order has no remaining receivable quantity.";
        }

        SeedDefaults();
    }

    private async Task LoadBillHandoffAsync(Guid billId)
    {
        var result = await Drafts.GetBillDraftAsync(ShellState.ActiveCompany.Id, billId, CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
        {
            return;
        }

        var draft = result.Value;
        if (draft is null)
        {
            _error = result.IsNotFound ? "The bill hand-off could not be found in the active company context." : result.ErrorMessage ?? "Unable to load the bill hand-off.";
            return;
        }

        _loadedBillDraft = draft;
        _loadedBillId = draft.Id;
        _vendorIdText = draft.VendorId.ToString("D");
        _sourceReference = draft.DisplayNumber;
        _memo = string.IsNullOrWhiteSpace(draft.Memo)
            ? $"Receipt hand-off from {draft.DisplayNumber}"
            : $"Receipt hand-off from {draft.DisplayNumber}: {draft.Memo}";

        var matchingResult = await BillReceiptMatching.GetBillSummaryAsync(
            ShellState.ActiveCompany.Id,
            draft.Id,
            CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(matchingResult, CancellationToken.None))
        {
            return;
        }

        var receiptLines = BuildReceiptLinesFromBillHandoff(draft, matchingResult.Value);
        if (receiptLines.Count == 0)
        {
            _lines.Clear();
            _lines.Add(ReceiptLineEditor.Blank(1));
            _error = "The selected bill has no complete inventory receipt hand-off lines.";
            return;
        }

        _lines.Clear();
        _lines.AddRange(receiptLines);
    }

    private IReadOnlyList<ReceiptLineEditor> BuildReceiptLinesFromBillHandoff(
        ShellPurchaseSourceDocumentDraftReadModel draft,
        ShellBillReceiptMatchingSummary? matchingSummary)
    {
        var inboundLines = draft.Lines
            .Where(static line =>
                line.ItemId.HasValue &&
                line.WarehouseId.HasValue &&
                !string.IsNullOrWhiteSpace(line.UomCode) &&
                line.Quantity.HasValue &&
                line.Quantity.Value > 0m)
            .ToArray();

        if (inboundLines.Length == 0)
        {
            return [];
        }

        var warehouseIds = inboundLines
            .Select(static line => line.WarehouseId!.Value)
            .Distinct()
            .ToArray();
        _warehouseId = warehouseIds[0];
        if (warehouseIds.Length > 1)
        {
            _error = "This bill has receipt hand-off lines across multiple warehouses. The receipt draft loaded the first warehouse; create separate receipt drafts for the remaining warehouse groups.";
        }

        var remainingByGroup = matchingSummary?.LineSummaries
            .Where(static summary => summary.RemainingQuantity > 0m)
            .GroupBy(static summary => new BillReceiptGroupKey(summary.ItemId, summary.WarehouseId, summary.UomCode.Trim().ToUpperInvariant()))
            .ToDictionary(
                static group => group.Key,
                static group => group.Sum(summary => summary.RemainingQuantity))
            ?? new Dictionary<BillReceiptGroupKey, decimal>();
        var hasMatchingGroups = matchingSummary?.LineSummaries.Count > 0;

        var built = inboundLines
            .Where(line => line.WarehouseId == _warehouseId)
            .Select(line =>
            {
                var quantity = line.Quantity!.Value;
                var groupKey = new BillReceiptGroupKey(line.ItemId!.Value, line.WarehouseId!.Value, line.UomCode!.Trim().ToUpperInvariant());
                if (hasMatchingGroups && !remainingByGroup.ContainsKey(groupKey))
                {
                    return null;
                }

                if (remainingByGroup.TryGetValue(groupKey, out var remainingQuantity) && remainingQuantity <= 0m)
                {
                    return null;
                }

                if (remainingByGroup.TryGetValue(groupKey, out remainingQuantity) && remainingQuantity < quantity)
                {
                    quantity = remainingQuantity;
                    remainingByGroup[groupKey] = 0m;
                }
                else if (remainingByGroup.ContainsKey(groupKey))
                {
                    remainingByGroup[groupKey] = remainingQuantity - quantity;
                }

                return new ReceiptLineEditor
                {
                    LineNumber = line.LineNumber,
                    ItemId = line.ItemId.Value,
                    Quantity = quantity,
                    UomCode = line.UomCode ?? string.Empty,
                    TrackingCaptureHome = null,
                    PurchaseOrderId = line.PurchaseOrderId,
                    PurchaseOrderLineNumber = line.PurchaseOrderLineNumber
                };
            })
            .Where(static line => line is not null)
            .Select(static line => line!)
            .OrderBy(static line => line.LineNumber)
            .ToList();

        for (var index = 0; index < built.Count; index++)
        {
            built[index].LineNumber = index + 1;
        }

        return built;
    }

    private void SeedDefaults()
    {
        if (VendorId.HasValue && _vendorOptions.Any(item => item.Id == VendorId.Value))
        {
            _vendorIdText ??= VendorId.Value.ToString("D");
        }
        else if (_vendorOptions.Count == 1)
        {
            _vendorIdText ??= _vendorOptions[0].Id.ToString("D");
        }

        _warehouseId ??= ActiveWarehouses.FirstOrDefault()?.Id;

        if (_lines.Count == 1 && !_lines[0].ItemId.HasValue)
        {
            var defaultItem = OperationalItems.FirstOrDefault();
            if (defaultItem is not null)
            {
                _lines[0].ItemId = defaultItem.Id;
                _lines[0].UomCode = defaultItem.StockUomCode ?? string.Empty;
            }
        }
    }

    private void AddLine()
    {
        if (TryBlockDraftEdits()) return;
        _lines.Add(ReceiptLineEditor.Blank(_lines.Count + 1));
    }

    private void RemoveLine(ReceiptLineEditor line)
    {
        if (TryBlockDraftEdits()) return;
        if (line.IsPurchaseOrderAnchored)
        {
            _error = "PO-anchored receipt lines stay with their purchase order hand-off.";
            return;
        }

        _lines.Remove(line);
        for (var index = 0; index < _lines.Count; index++)
        {
            _lines[index].LineNumber = index + 1;
        }
    }

    private void ApplyItem(ReceiptLineEditor line, Guid? itemId)
    {
        if (TryBlockDraftEdits()) return;
        line.ItemId = itemId;
        var item = OperationalItems.FirstOrDefault(current => current.Id == itemId);
        line.UomCode = item?.StockUomCode ?? string.Empty;
        if (line.Quantity <= 0m)
        {
            line.Quantity = 1m;
        }
    }

    private async Task SaveAsync()
    {
        if (TryBlockDraftEdits()) return;
        _error = null;

        if (!TryBuildRequest(out var request))
        {
            return;
        }

        try
        {
            _saving = true;
            var result = await Drafts.SaveReceiptDraftAsync(_documentId, request, CancellationToken.None);
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
            {
                return;
            }

            if (result.Value is null)
            {
                _error = result.ErrorMessage ?? "Unable to save the receipt draft.";
                return;
            }

            _saved = result.Value;
            _documentId = _saved.DocumentId;
            Snackbar.Add($"Receipt {_saved.DisplayNumber} saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task PostAsync()
    {
        if (TryBlockDraftEdits()) return;
        _error = null;

        if (!_documentId.HasValue)
        {
            _error = "Save the receipt draft before posting it.";
            return;
        }

        try
        {
            _posting = true;
            var result = await Drafts.PostReceiptAsync(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                _documentId.Value,
                CancellationToken.None);
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
            {
                return;
            }

            if (result.Value is null)
            {
                _error = WebShellPostingFeedback.DescribeFailure(
                    result.ErrorCode,
                    result.ErrorMessage,
                    "Unable to post the receipt.");
                return;
            }

            _saved = result.Value;
            Snackbar.Add($"Receipt {_saved.DisplayNumber} posted.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _posting = false;
        }
    }

    private bool TryBuildRequest(out ShellReceiptDraftSaveRequest request)
    {
        request = new ShellReceiptDraftSaveRequest();

        if (!Guid.TryParse(_vendorIdText, out var vendorId))
        {
            _error = "Vendor must be selected.";
            return false;
        }

        if (!_warehouseId.HasValue)
        {
            _error = "Warehouse must be selected.";
            return false;
        }

        if (!TryBuildLines(out var lines))
        {
            return false;
        }

        request = new ShellReceiptDraftSaveRequest
        {
            CompanyId = ShellState.ActiveCompany.Id,
            UserId = ShellState.CurrentUserId,
            VendorId = vendorId,
            WarehouseId = _warehouseId.Value,
            ReceiptDate = _receiptDate,
            VendorReference = NormalizeOptional(_vendorReference),
            SourceReference = NormalizeOptional(_sourceReference),
            Memo = NormalizeOptional(_memo),
            Lines = lines
        };
        return true;
    }

    private bool TryBuildLines(out IReadOnlyList<ShellReceiptDraftLineSaveRequest> lines)
    {
        var built = new List<ShellReceiptDraftLineSaveRequest>();
        foreach (var line in _lines)
        {
            if (!line.ItemId.HasValue)
            {
                _error = $"Item missing on line {line.LineNumber}.";
                lines = [];
                return false;
            }

            if (line.Quantity <= 0m)
            {
                _error = $"Quantity must be positive on line {line.LineNumber}.";
                lines = [];
                return false;
            }

            if (string.IsNullOrWhiteSpace(line.UomCode))
            {
                _error = $"UOM missing on line {line.LineNumber}.";
                lines = [];
                return false;
            }

            built.Add(new ShellReceiptDraftLineSaveRequest
            {
                LineNumber = line.LineNumber,
                ItemId = line.ItemId.Value,
                Quantity = line.Quantity,
                UomCode = line.UomCode.Trim().ToUpperInvariant(),
                TrackingCaptureHome = NormalizeOptional(line.TrackingCaptureHome),
                PurchaseOrderId = line.PurchaseOrderId,
                PurchaseOrderLineNumber = line.PurchaseOrderLineNumber
            });
        }

        if (built.Count == 0)
        {
            _error = "At least one receipt line is required.";
            lines = [];
            return false;
        }

        lines = built;
        return true;
    }

    private bool TryBlockDraftEdits()
    {
        if (WritesBlocked)
        {
            _error = ShellState.WriteBlockMessage;
            return true;
        }

        if (!CanEditDraft)
        {
            _error = "Only draft receipts can be modified or posted from this workbench.";
            return true;
        }

        if (ActiveWarehouses.Count == 0)
        {
            _error = "No active warehouse is available for receipt drafts.";
            return true;
        }

        if (OperationalItems.Count == 0)
        {
            _error = "No active stock-managed item is available for receipt lines.";
            return true;
        }

        return false;
    }

    private void OnReceiptDateChanged(DateTime? value)
    {
        _receiptDatePicker = value;
        _receiptDate = DateOnly.FromDateTime(value ?? DateTime.Today);
    }

    private string GetVendorReadinessSummary()
    {
        if (_purchaseOrder is null && _loadedBillDraft is null)
        {
            return "Select one active vendor before saving.";
        }

        return _purchaseOrder is not null
            ? "Locked to the purchase order vendor for governed anchor consistency."
            : "Locked to the bill vendor for receipt-first matching consistency.";
    }

    private string BuildReceiptControlHref() =>
        _documentId.HasValue
            ? $"/company/inventory-purchase-receipt?receiptId={_documentId.Value:D}"
            : "/company/inventory-purchase-receipt";

    private static bool CanCreateReceiptFromPurchaseOrder(ShellPurchaseOrderReviewSummary purchaseOrder) =>
        string.Equals(purchaseOrder.Status, "issued", StringComparison.OrdinalIgnoreCase);

    private static string FormatPurchaseOrderAnchor(ReceiptLineEditor line) =>
        line.PurchaseOrderId.HasValue && line.PurchaseOrderLineNumber.HasValue
            ? $"PO line {line.PurchaseOrderLineNumber.Value}"
            : "n/a";

    private static string? NormalizeOptional(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private readonly record struct BillReceiptGroupKey(
        Guid ItemId,
        Guid WarehouseId,
        string UomCode);

    private sealed class ReceiptLineEditor
    {
        public int LineNumber { get; set; }
        public Guid? ItemId { get; set; }
        public decimal Quantity { get; set; } = 1m;
        public string UomCode { get; set; } = string.Empty;
        public string? TrackingCaptureHome { get; set; }
        public Guid? PurchaseOrderId { get; set; }
        public int? PurchaseOrderLineNumber { get; set; }
        public bool IsPurchaseOrderAnchored => PurchaseOrderId.HasValue && PurchaseOrderLineNumber.HasValue;
        public static ReceiptLineEditor Blank(int lineNumber) => new() { LineNumber = lineNumber };
    }
}
