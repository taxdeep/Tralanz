@page "/documents/sales-order/draft-editor"
@using Citus.Modules.Inventory.Application.Contracts
@using Citus.Modules.UnitySearch.Blazor
@using Citus.Modules.UnitySearch.Domain.Shared
@using Modules.CompanyAccess.SessionContext
@using Modules.GL.JournalEntry
@using Web.Business.AR.SettlementLookup
@using Web.Shell.Services
@inject Web.Shell.State.WebShellState ShellState
@inject ICompanyAccessShellSession ShellSession
@inject Web.Shell.Services.WebShellBusinessSessionClient SessionClient
@inject Web.Shell.Services.WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject IArSettlementLookupService Customers
@inject IJournalEntryAccountCatalog Accounts
@inject ShellProductServiceCatalogClient ProductServices
@inject ShellInventoryShipmentClient InventoryShipment
@inject ShellSalesCommercialDocumentClient CommercialDocuments
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Sales Order</PageTitle>

<div style="padding:2rem 2.25rem;color:#d9e2ea;">
    <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-bottom:1rem;">
        <MudButton Variant="Variant.Text" Href="/documents/source-browser?sourceType=sales_order">Back</MudButton>
        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Success">Sales order</MudChip>
    </div>
    <h1 style="margin:0 0 .75rem 0;">Sales Order</h1>
    <p style="margin:0 0 1rem 0;color:#97a8b7;max-width:58rem;">
        Capture committed customer demand before fulfillment, invoicing, and cost issue truth take over.
    </p>

    <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
        <div style="display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;flex-wrap:wrap;">
            <div>
                <MudText Typo="Typo.subtitle2">Commercial Chain</MudText>
                <MudText Typo="Typo.h5">@SalesOrderStageLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@SalesOrderStageSummary</MudText>
            </div>
            <MudChip T="string" Color="@SalesOrderStageColor" Variant="Variant.Filled">@SalesOrderStageBadge</MudChip>
        </div>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));gap:1rem;margin-top:1rem;">
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Quote hand-off</MudText>
                <MudText Typo="Typo.h6">@SalesOrderQuoteLinkLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@SalesOrderQuoteLinkSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Current next step</MudText>
                <MudText Typo="Typo.h6">@SalesOrderNextStepTitle</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@SalesOrderNextStepSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">AR hand-off</MudText>
                <MudText Typo="Typo.h6">@SalesOrderInvoiceLaneLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@SalesOrderInvoiceLaneSummary</MudText>
            </MudPaper>
        </div>

        <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1rem;">
            <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="/documents/source-browser?sourceType=sales_order">
                Open SO Pipeline
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/documents/source-browser?sourceType=quote">
                Review Quotes
            </MudButton>
            @if (_sourceQuoteId.HasValue)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Success" Href="@($"/documents/quote/draft-editor?draftId={_sourceQuoteId.Value:D}")">
                    Open Source Quote
                </MudButton>
            }
            @if (_saved is not null && CanContinueInvoicing && !WritesBlocked)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success" Href="@BuildInvoiceHref()">
                    @(IsPartiallyInvoiced ? "Continue Invoice Coverage" : "Start Invoice Coverage")
                </MudButton>
            }
        </div>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_sourceQuoteDisplayNumber))
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            Quote hand-off <strong>@_sourceQuoteDisplayNumber</strong> prefilled this sales order.
        </MudAlert>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Style="margin-bottom:1rem;">@_error</MudAlert>
    }
    @if (WritesBlocked)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">@ShellState.WriteBlockMessage</MudAlert>
    }

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(14rem,1fr));gap:1rem;margin-bottom:1rem;">
        <div>
            <MudText Typo="Typo.caption" Class="mb-1">Customer</MudText>
            <UnitySearchPicker CompanyId="@ShellSession.ActiveCompanyId"
                               UserId="@ShellState.CurrentUserId"
                               Context="@SearchScopeContext.SalesOrderCustomerPicker"
                               SelectedId="@SelectedCustomerId"
                               SelectedDisplayText="@SelectedCustomerDisplayText"
                               Placeholder="Search customer"
                               CreateEntityLabel="customer"
                               Disabled="@WritesBlocked"
                               OnOptionSelected="HandleCustomerSelectedAsync"
                               OnCreateRequested="HandleCreateCustomerRequestedAsync"
                               OnCleared="HandleCustomerClearedAsync" />
        </div>
        <MudDatePicker Label="Order date" Variant="Variant.Outlined" Date="_documentDatePicker" DateChanged="OnDocumentDateChanged" Disabled="WritesBlocked" />
        <MudDatePicker Label="Requested ship" Variant="Variant.Outlined" Date="_requestedShipDatePicker" DateChanged="OnRequestedShipDateChanged" Disabled="WritesBlocked" />
        <MudTextField T="string" Label="Currency" Variant="Variant.Outlined" @bind-Value="_currencyCode" Disabled="WritesBlocked" />
        <MudTextField T="string" Label="Memo" Variant="Variant.Outlined" @bind-Value="_memo" Disabled="WritesBlocked" />
    </div>

    <MudPaper Class="pa-4" Elevation="0">
        <div style="display:flex;justify-content:space-between;gap:.75rem;align-items:center;flex-wrap:wrap;margin-bottom:1rem;">
            <MudText Typo="Typo.h6">Sales order lines</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Info" Disabled="WritesBlocked" OnClick="AddLine">Add Line</MudButton>
        </div>
        <MudTable Items="_lines" Dense="true" Hover="true" Bordered="true">
            <HeaderContent>
                <MudTh>#</MudTh><MudTh>Product / Service</MudTh><MudTh>Revenue</MudTh><MudTh>Description</MudTh><MudTh>Qty</MudTh><MudTh>Price</MudTh><MudTh>Item</MudTh><MudTh>Warehouse</MudTh><MudTh>UOM</MudTh><MudTh>Total</MudTh><MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.LineNumber</MudTd>
                <MudTd>
                    <UnitySearchPicker CompanyId="@ShellSession.ActiveCompanyId"
                                       UserId="@ShellState.CurrentUserId"
                                       Context="@SearchScopeContext.SalesOrderProductServicePicker"
                                       SelectedId="@ParseOptionalGuid(context.ProductServiceIdText)"
                                       SelectedDisplayText="@ResolveProductServiceLabel(context.ProductServiceIdText)"
                                       Placeholder="Search product or service"
                                       Disabled="@WritesBlocked"
                                       OnOptionSelected="@(option => HandleProductServiceSelectedAsync(context, option))"
                                       OnCleared="@(async () => await HandleProductServiceClearedAsync(context))" />
                </MudTd>
                <MudTd>
                    <MudSelect T="string" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="context.RevenueAccountIdText" Disabled="WritesBlocked">
                        <MudSelectItem T="string" Value="@string.Empty">Later</MudSelectItem>
                        @foreach (var account in _revenueAccounts)
                        {
                            <MudSelectItem T="string" Value="@account.AccountId.ToString("D")">@account.DisplayText</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd><MudTextField T="string" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="context.Description" Disabled="WritesBlocked" /></MudTd>
                <MudTd><MudNumericField T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.01m" @bind-Value="context.Quantity" Disabled="WritesBlocked" /></MudTd>
                <MudTd><MudNumericField T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0m" @bind-Value="context.UnitPrice" Disabled="WritesBlocked" /></MudTd>
                <MudTd>
                    <UnitySearchPicker CompanyId="@ShellSession.ActiveCompanyId"
                                       UserId="@ShellState.CurrentUserId"
                                       Context="@SearchScopeContext.SalesOrderInventoryItemPicker"
                                       SelectedId="@context.ItemId"
                                       SelectedDisplayText="@ResolveInventoryItemLabel(context.ItemId)"
                                       Placeholder="Search inventory item"
                                       Disabled="@WritesBlocked"
                                       OnOptionSelected="@(option => HandleInventoryItemSelectedAsync(context, option))"
                                       OnCleared="@(async () => await HandleInventoryItemClearedAsync(context))" />
                </MudTd>
                <MudTd>
                    <MudSelect T="Guid?" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="context.WarehouseId" Disabled="@(WritesBlocked || context.ItemId is null)">
                        @foreach (var warehouse in Warehouses)
                        {
                            <MudSelectItem T="Guid?" Value="@warehouse.Id">@warehouse.WarehouseCode</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd><MudTextField T="string" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="context.UomCode" Disabled="@(WritesBlocked || context.ItemId is null)" /></MudTd>
                <MudTd>@context.LineAmount.ToString("N2")</MudTd>
                <MudTd><MudButton Variant="Variant.Text" Color="Color.Error" Disabled="@(WritesBlocked || _lines.Count <= 1)" OnClick="@(() => RemoveLine(context))">X</MudButton></MudTd>
            </RowTemplate>
        </MudTable>
        <MudText Typo="Typo.h6" Style="margin-top:1rem;">Total: @TotalAmount.ToString("N2") @_currencyCode</MudText>
    </MudPaper>

    <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1rem;">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_isSaving || WritesBlocked)" OnClick="SaveAsync">Save SO</MudButton>
        @if (_saved is not null)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(!CanIssueSalesOrder || _isSaving || WritesBlocked)" OnClick="IssueAsync">Issue SO</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@BuildShipmentHref()" Disabled="@(!CanContinueShipment || WritesBlocked)">@(IsPartiallyShipped ? "Continue Shipment" : "Open Shipment")</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Success" Href="@BuildInvoiceHref()" Disabled="@(!CanContinueInvoicing || WritesBlocked)">@(IsPartiallyInvoiced ? "Continue Invoice" : "Open Invoice")</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" Disabled="@(!CanCloseSalesOrder || _isSaving || WritesBlocked)" OnClick="CloseAsync">Close SO</MudButton>
        }
    </div>

    @if (_outboundControl is not null)
    {
        <MudPaper Class="pa-4" Elevation="0" Style="margin-top:1rem;">
            <div style="display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;flex-wrap:wrap;">
                <div>
                    <MudText Typo="Typo.subtitle2">Outbound Control</MudText>
                    <MudText Typo="Typo.h5">@GetOutboundStatusLabel(_outboundControl.AggregateStatus)</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@BuildOutboundStatusSummary(_outboundControl)</MudText>
                </div>
                <MudChip T="string" Color="@GetOutboundStatusColor(_outboundControl.AggregateStatus)" Variant="Variant.Filled">
                    @_outboundControl.AggregateStatus
                </MudChip>
            </div>

            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(10rem,1fr));gap:1rem;margin-top:1rem;">
                <div style="border:1px solid rgba(148,163,184,.2);border-radius:6px;padding:.75rem;">
                    <MudText Typo="Typo.caption">SO status</MudText>
                    <MudText Typo="Typo.h6">@GetOutboundStatusLabel(_outboundControl.SalesOrderStatus)</MudText>
                </div>
                <div style="border:1px solid rgba(148,163,184,.2);border-radius:6px;padding:.75rem;">
                    <MudText Typo="Typo.caption">Shipment</MudText>
                    <MudText Typo="Typo.h6">@GetShipmentCoverageLabel(_outboundControl.ShipmentCoverageStatus)</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@_outboundControl.ShippedQuantity.ToString("N2") / @_outboundControl.ShippableQuantity.ToString("N2") shipped</MudText>
                </div>
                <div style="border:1px solid rgba(148,163,184,.2);border-radius:6px;padding:.75rem;">
                    <MudText Typo="Typo.caption">Invoice</MudText>
                    <MudText Typo="Typo.h6">@GetInvoiceCoverageLabel(_outboundControl.InvoiceCoverageStatus)</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@FormatInvoiceRatio(_outboundControl.InvoicedQuantity, _outboundControl.OrderQuantity) posted</MudText>
                </div>
                <div style="border:1px solid rgba(148,163,184,.2);border-radius:6px;padding:.75rem;">
                    <MudText Typo="Typo.caption">Remaining</MudText>
                    <MudText Typo="Typo.h6">@_outboundControl.RemainingToShipQuantity.ToString("N2") ship / @_outboundControl.RemainingToInvoiceQuantity.ToString("N2") invoice</MudText>
                </div>
            </div>

            <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:1rem;">
                @foreach (var stage in OutboundStages)
                {
                    <MudChip T="string" Color="@GetStageChipColor(stage, _outboundControl.AggregateStatus)" Variant="@GetStageChipVariant(stage, _outboundControl.AggregateStatus)">
                        @GetOutboundStatusLabel(stage)
                    </MudChip>
                }
            </div>

            <MudTable Items="_outboundControl.Lines" Dense="true" Hover="true" Bordered="true" Style="margin-top:1rem;">
                <HeaderContent>
                    <MudTh>#</MudTh><MudTh>Description</MudTh><MudTh>Ordered</MudTh><MudTh>Shipped</MudTh><MudTh>Ship Remaining</MudTh><MudTh>Invoiced</MudTh><MudTh>Invoice Remaining</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.LineNumber</MudTd>
                    <MudTd>@context.Description</MudTd>
                    <MudTd>@context.OrderQuantity.ToString("N2")</MudTd>
                    <MudTd>@context.ShippedQuantity.ToString("N2")</MudTd>
                    <MudTd>@context.RemainingToShipQuantity.ToString("N2")</MudTd>
                    <MudTd>@FormatInvoiceRatio(context.InvoicedQuantity, context.OrderQuantity)</MudTd>
                    <MudTd>@context.RemainingToInvoiceQuantity.ToString("N2")</MudTd>
                </RowTemplate>
            </MudTable>

            @if (_outboundControl.RecentShipments.Count > 0)
            {
                <MudText Typo="Typo.subtitle2" Style="margin-top:1rem;">Recent shipments</MudText>
                <MudTable Items="_outboundControl.RecentShipments" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Shipment</MudTh><MudTh>Status</MudTh><MudTh>Date</MudTh><MudTh>Qty</MudTh><MudTh>Tracking</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.DocumentNumber</MudTd>
                        <MudTd>@context.Status</MudTd>
                        <MudTd>@context.PostingDate</MudTd>
                        <MudTd>@context.Quantity.ToString("N2")</MudTd>
                        <MudTd>@(context.TrackingNumber ?? "n/a")</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    }

    @if (_invoiceCoverage is not null)
    {
        <MudPaper Class="pa-4" Elevation="0" Style="margin-top:1rem;">
            <div style="display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;flex-wrap:wrap;">
                <div>
                    <MudText Typo="Typo.subtitle2">Invoice Coverage</MudText>
                    <MudText Typo="Typo.h6">@GetInvoiceCoverageLabel(_invoiceCoverage.InvoiceCoverageStatus)</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@BuildInvoiceCoverageSummary(_invoiceCoverage)</MudText>
                </div>
                <MudChip T="string" Color="@GetInvoiceCoverageColor(_invoiceCoverage.InvoiceCoverageStatus)" Variant="Variant.Filled">
                    @_invoiceCoverage.InvoiceCoverageStatus
                </MudChip>
            </div>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(10rem,1fr));gap:1rem;margin-top:1rem;">
                <div style="border:1px solid rgba(148,163,184,.2);border-radius:6px;padding:.75rem;">
                    <MudText Typo="Typo.caption">Order qty</MudText>
                    <MudText Typo="Typo.h6">@_invoiceCoverage.OrderQuantity.ToString("N2")</MudText>
                </div>
                <div style="border:1px solid rgba(148,163,184,.2);border-radius:6px;padding:.75rem;">
                    <MudText Typo="Typo.caption">Posted invoice qty</MudText>
                    <MudText Typo="Typo.h6">@_invoiceCoverage.InvoicedQuantity.ToString("N2")</MudText>
                </div>
                <div style="border:1px solid rgba(148,163,184,.2);border-radius:6px;padding:.75rem;">
                    <MudText Typo="Typo.caption">Remaining</MudText>
                    <MudText Typo="Typo.h6">@_invoiceCoverage.RemainingToInvoiceQuantity.ToString("N2")</MudText>
                </div>
                <div style="border:1px solid rgba(148,163,184,.2);border-radius:6px;padding:.75rem;">
                    <MudText Typo="Typo.caption">Invoice anchors</MudText>
                    <MudText Typo="Typo.h6">@_invoiceCoverage.PostedInvoiceCount posted / @_invoiceCoverage.InvoiceCount total</MudText>
                </div>
            </div>
            @if (_invoiceCoverage.Lines.Count > 0)
            {
                <MudTable Items="_invoiceCoverage.Lines" Dense="true" Hover="true" Bordered="true" Style="margin-top:1rem;">
                    <HeaderContent>
                        <MudTh>#</MudTh><MudTh>Description</MudTh><MudTh>Ordered</MudTh><MudTh>Invoiced</MudTh><MudTh>Remaining</MudTh><MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.LineNumber</MudTd>
                        <MudTd>@context.Description</MudTd>
                        <MudTd>@context.OrderQuantity.ToString("N2")</MudTd>
                            <MudTd>@FormatInvoiceRatio(context.InvoicedQuantity, context.OrderQuantity)</MudTd>
                        <MudTd>@context.RemainingToInvoiceQuantity.ToString("N2")</MudTd>
                        <MudTd>@GetInvoiceCoverageLabel(context.InvoiceCoverageStatus)</MudTd>
                    </RowTemplate>
                </MudTable>
            }
            @if (_invoiceCoverage.RecentInvoices.Count > 0)
            {
                <MudText Typo="Typo.subtitle2" Style="margin-top:1rem;">Recent invoice anchors</MudText>
                <MudTable Items="_invoiceCoverage.RecentInvoices" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Invoice</MudTh><MudTh>Status</MudTh><MudTh>Date</MudTh><MudTh>Qty</MudTh><MudTh>Total</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.InvoiceDisplayNumber</MudTd>
                        <MudTd>@context.InvoiceStatus</MudTd>
                        <MudTd>@context.DocumentDate</MudTd>
                        <MudTd>@context.Quantity.ToString("N2")</MudTd>
                        <MudTd>@context.TotalAmount.ToString("N2")</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    }

    @if (_saved is not null)
    {
        <MudPaper Class="pa-4" Elevation="0" Style="margin-top:1rem;">
            <MudText Typo="Typo.h6">@_saved.DisplayNumber</MudText>
            <MudText Typo="Typo.body2">Status: @_saved.Status</MudText>
            <MudText Typo="Typo.body2">Document Id: @_saved.Id</MudText>
        </MudPaper>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "draftId")]
    public Guid? DraftId { get; set; }

    [SupplyParameterFromQuery(Name = "quoteId")]
    public Guid? QuoteId { get; set; }

    [SupplyParameterFromQuery(Name = "customerId")]
    public Guid? CustomerId { get; set; }

    private IReadOnlyList<(Guid Id, string DisplayLabel, string CurrencyCode)> _customers = Array.Empty<(Guid Id, string DisplayLabel, string CurrencyCode)>();
    private IReadOnlyList<JournalEntryAccountOption> _revenueAccounts = Array.Empty<JournalEntryAccountOption>();
    private IReadOnlyList<ShellManagedProductServiceSummary> _productServices = Array.Empty<ShellManagedProductServiceSummary>();
    private InventoryShipmentDashboard? _inventoryDashboard;
    private readonly List<CommercialLineState> _lines = [CommercialLineState.Blank(1)];
    private ShellSalesCommercialDocumentReadModel? _saved;
    private ShellSalesOrderInvoiceCoverageSummary? _invoiceCoverage;
    private ShellSalesOrderOutboundControlSummary? _outboundControl;
    private Guid? _sourceQuoteId;
    private string? _sourceQuoteDisplayNumber;
    private string? _customerIdText;
    private string _currencyCode = string.Empty;
    private string? _memo;
    private string? _error;
    private bool _isSaving;
    private DateOnly _documentDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly? _requestedShipDate = DateOnly.FromDateTime(DateTime.Today.AddDays(3));
    private DateTime? _documentDatePicker = DateTime.Today;
    private DateTime? _requestedShipDatePicker = DateTime.Today.AddDays(3);

    private bool WritesBlocked => ShellState.AreWritesBlocked;
    private IReadOnlyList<InventoryManagedItemSummary> InventoryItems => _inventoryDashboard?.ActiveItems.ToArray() ?? [];
    private IReadOnlyList<InventoryManagedWarehouseSummary> Warehouses => _inventoryDashboard?.ActiveWarehouses ?? [];
    private decimal TotalAmount => _lines.Sum(static line => line.LineAmount);
    private static readonly string[] OutboundStages = ["draft", "issued", "partially_shipped", "partially_invoiced", "closed"];
    private string SalesOrderStageLabel => _outboundControl is not null
        ? GetOutboundStatusLabel(_outboundControl.AggregateStatus)
        : _saved is not null
            ? "Sales order saved"
            : "Start demand control";
    private string SalesOrderStageSummary => _outboundControl is not null
        ? BuildOutboundStatusSummary(_outboundControl)
        : _saved is not null
            ? "Demand truth is saved but outbound control has not been evaluated yet."
            : "This lane owns committed customer demand before shipment and invoice truth take over.";
    private string SalesOrderStageBadge => _outboundControl?.AggregateStatus ?? (_saved?.Status ?? "new");
    private Color SalesOrderStageColor => GetOutboundStatusColor(_outboundControl?.AggregateStatus ?? _saved?.Status);
    private string SalesOrderQuoteLinkLabel => !string.IsNullOrWhiteSpace(_sourceQuoteDisplayNumber)
        ? _sourceQuoteDisplayNumber
        : _sourceQuoteId.HasValue
            ? "Quote linked"
            : "Direct sales order";
    private string SalesOrderQuoteLinkSummary => !string.IsNullOrWhiteSpace(_sourceQuoteDisplayNumber)
        ? "Customer offer truth was already accepted and prefilled this demand lane."
        : _sourceQuoteId.HasValue
            ? "A quote link exists, but this workbench loaded without the original display label."
            : "This sales order was created directly without a preceding quote hand-off.";
    private string SalesOrderNextStepTitle => _saved is null
        ? "Save the sales order"
        : CanContinueInvoicing
            ? (IsPartiallyInvoiced ? "Continue invoice coverage" : "Start invoice coverage")
            : CanContinueShipment
                ? (IsPartiallyShipped ? "Continue shipment" : "Start shipment")
                : CanIssueSalesOrder
                    ? "Issue the sales order"
                    : CanCloseSalesOrder
                        ? "Close the sales order"
                        : "Monitor outbound truth";
    private string SalesOrderNextStepSummary => _saved is null
        ? "Demand truth only becomes governed once the sales order is saved."
        : CanContinueInvoicing
            ? "Invoice coverage is still open. Continue the AR hand-off so demand truth can close through posted invoice anchors."
            : CanContinueShipment
                ? "Fulfillment truth is still open. Continue shipment before this order can fully close."
                : CanIssueSalesOrder
                    ? "Issue the order to move it from editable demand truth into live outbound control."
                    : CanCloseSalesOrder
                        ? "Shipment and invoice truth now cover this order, so it can move into the closed state."
                        : "Outbound truth already owns this lane. Use the workbench for review and follow-through.";
    private string SalesOrderInvoiceLaneLabel => _invoiceCoverage is null
        ? "Coverage pending"
        : GetInvoiceCoverageLabel(_invoiceCoverage.InvoiceCoverageStatus);
    private string SalesOrderInvoiceLaneSummary => _invoiceCoverage is null
        ? "AR hand-off has not been evaluated yet."
        : BuildInvoiceCoverageSummary(_invoiceCoverage);

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupAsync();
        if (DraftId.HasValue)
        {
            await LoadDocumentAsync(DraftId.Value);
        }
        else if (QuoteId.HasValue)
        {
            await LoadQuoteHandoffAsync(QuoteId.Value);
        }
    }

    private async Task LoadLookupAsync()
    {
        await ShellState.EnsureHydratedAsync();
        var probe = await SessionClient.ProbeContextAsync(CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe, CancellationToken.None)) return;

        _currencyCode = ShellState.ActiveCompany.BaseCurrencyCode;
        _customers = await Customers.ListCustomersAsync(ShellSession.ActiveCompanyId, CancellationToken.None);
        _revenueAccounts = (await Accounts.ListManualPostingAccountsAsync(ShellSession.ActiveCompanyId, CancellationToken.None))
            .Where(static account => account.TypeLabel.Contains("Revenue", StringComparison.OrdinalIgnoreCase))
            .ToArray();
        _productServices = (await ProductServices.GetSummaryAsync(ShellSession.ActiveCompanyId, CancellationToken.None)).ActiveSalesItems;
        _inventoryDashboard = await InventoryShipment.GetDashboardAsync(ShellSession.ActiveCompanyId, CancellationToken.None);

        if (CustomerId.HasValue && _customers.Any(customer => customer.Id == CustomerId.Value))
        {
            _customerIdText = CustomerId.Value.ToString("D");
        }
        else if (_customers.Count == 1)
        {
            _customerIdText = _customers[0].Id.ToString("D");
        }
    }

    private async Task LoadDocumentAsync(Guid documentId)
    {
        var document = await CommercialDocuments.GetAsync(ShellSession.ActiveCompanyId, documentId, CancellationToken.None);
        if (document is null || document.DocumentType != "sales_order")
        {
            _error = "The sales order could not be found in the active company context.";
            return;
        }

        ApplyDocument(document);
        _saved = document;
        _sourceQuoteId = document.SourceQuoteId;
        await LoadInvoiceCoverageAsync();
    }

    private async Task LoadQuoteHandoffAsync(Guid quoteId)
    {
        var quote = await CommercialDocuments.GetAsync(ShellSession.ActiveCompanyId, quoteId, CancellationToken.None);
        if (quote is null || quote.DocumentType != "quote")
        {
            _error = "The quote hand-off could not be found in the active company context.";
            return;
        }

        ApplyDocument(quote);
        _sourceQuoteId = quote.Id;
        _sourceQuoteDisplayNumber = quote.DisplayNumber;
        _memo = $"Sales order from quote {quote.DisplayNumber}. {quote.Memo}".Trim();
    }

    private void ApplyDocument(ShellSalesCommercialDocumentReadModel document)
    {
        _customerIdText = document.CustomerId.ToString("D");
        _currencyCode = document.TransactionCurrencyCode;
        _memo = document.Memo;
        _documentDate = document.DocumentDate;
        _requestedShipDate = document.RequestedShipDate;
        _documentDatePicker = document.DocumentDate.ToDateTime(TimeOnly.MinValue);
        _requestedShipDatePicker = document.RequestedShipDate?.ToDateTime(TimeOnly.MinValue);
        _lines.Clear();
        _lines.AddRange(document.Lines.Select(CommercialLineState.FromReadModel));
        if (_lines.Count == 0) _lines.Add(CommercialLineState.Blank(1));
    }

    private async Task SaveAsync()
    {
        if (TryBlockWrites() || !TryBuildRequest(out var request)) return;
        try
        {
            _isSaving = true;
            _error = null;
            _saved = await CommercialDocuments.SaveAsync(_saved?.Id, request, CancellationToken.None);
            await LoadInvoiceCoverageAsync();
            Snackbar.Add($"Sales order {_saved.DisplayNumber} saved.", Severity.Success);
        }
        catch (Exception ex) { _error = ex.Message; Snackbar.Add(ex.Message, Severity.Error); }
        finally { _isSaving = false; }
    }

    private async Task IssueAsync()
    {
        if (TryBlockWrites() || _saved is null || !CanIssueSalesOrder) return;
        _saved = await CommercialDocuments.IssueSalesOrderAsync(ShellSession.ActiveCompanyId, _saved.Id, CancellationToken.None);
        await LoadInvoiceCoverageAsync();
        Snackbar.Add($"Sales order {_saved.DisplayNumber} issued.", Severity.Success);
    }

    private async Task CloseAsync()
    {
        if (TryBlockWrites() || _saved is null || !CanCloseSalesOrder) return;
        try
        {
            _isSaving = true;
            _saved = await CommercialDocuments.CloseSalesOrderAsync(ShellSession.ActiveCompanyId, _saved.Id, CancellationToken.None);
            await LoadInvoiceCoverageAsync();
            Snackbar.Add($"Sales order {_saved.DisplayNumber} closed.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private bool TryBuildRequest(out ShellSalesCommercialDocumentSaveRequest request)
    {
        request = new();
        if (!Guid.TryParse(_customerIdText, out var customerId))
        {
            _error = "Customer is required.";
            return false;
        }

        request = new ShellSalesCommercialDocumentSaveRequest
        {
            CompanyId = ShellSession.ActiveCompanyId,
            UserId = ShellState.CurrentUserId,
            DocumentType = "sales_order",
            CustomerId = customerId,
            DocumentDate = _documentDate,
            RequestedShipDate = _requestedShipDate,
            TransactionCurrencyCode = _currencyCode,
            BaseCurrencyCode = ShellState.ActiveCompany.BaseCurrencyCode,
            Memo = _memo,
            SourceQuoteId = _sourceQuoteId,
            Lines = _lines.Select(static line => line.ToSaveRequest()).ToArray()
        };
        return true;
    }

    private string BuildShipmentHref() =>
        _saved is null
            ? "/company/inventory-shipment"
            : $"/company/inventory-shipment?sourceType=sales_order&salesOrderId={_saved.Id:D}&customerId={_saved.CustomerId:D}";

    private string BuildInvoiceHref() =>
        _saved is null
            ? "/documents/invoice/draft-editor"
            : $"/documents/invoice/draft-editor?origin=sales-order-invoice-handoff&salesOrderId={_saved.Id:D}&customerId={_saved.CustomerId:D}";

    private async Task LoadInvoiceCoverageAsync()
    {
        if (_saved is null)
        {
            _invoiceCoverage = null;
            _outboundControl = null;
            return;
        }

        _outboundControl = await CommercialDocuments.GetSalesOrderOutboundControlAsync(
            ShellSession.ActiveCompanyId,
            _saved.Id,
            CancellationToken.None);
        _invoiceCoverage = await CommercialDocuments.GetSalesOrderInvoiceCoverageAsync(
            ShellSession.ActiveCompanyId,
            _saved.Id,
            CancellationToken.None);
    }

    private bool IsPartiallyInvoiced =>
        string.Equals(_outboundControl?.InvoiceCoverageStatus, "partially_invoiced", StringComparison.OrdinalIgnoreCase);

    private bool IsPartiallyShipped =>
        string.Equals(_outboundControl?.ShipmentCoverageStatus, "partially_shipped", StringComparison.OrdinalIgnoreCase);

    private bool CanContinueShipment =>
        _saved is not null &&
        _outboundControl is not null &&
        _outboundControl.ShippableQuantity > 0m &&
        !string.Equals(_outboundControl.ShipmentCoverageStatus, "fully_shipped", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(_outboundControl.ShipmentCoverageStatus, "over_shipped", StringComparison.OrdinalIgnoreCase);

    private bool CanContinueInvoicing =>
        _saved is not null &&
        !string.Equals(_outboundControl?.InvoiceCoverageStatus, "fully_invoiced", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(_outboundControl?.InvoiceCoverageStatus, "over_invoiced", StringComparison.OrdinalIgnoreCase);

    private bool CanIssueSalesOrder =>
        _saved is not null &&
        !string.Equals(_saved.Status, "closed", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(_saved.Status, "cancelled", StringComparison.OrdinalIgnoreCase);

    private bool CanCloseSalesOrder =>
        _saved is not null &&
        _outboundControl is not null &&
        !string.Equals(_saved.Status, "closed", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(_outboundControl.AggregateStatus, "closed", StringComparison.OrdinalIgnoreCase);
    private Guid? SelectedCustomerId => ParseOptionalGuid(_customerIdText);
    private string? SelectedCustomerDisplayText =>
        SelectedCustomerId.HasValue
            ? _customers.FirstOrDefault(item => item.Id == SelectedCustomerId.Value).DisplayLabel
            : null;

    private static Color GetOutboundStatusColor(string? status) =>
        status switch
        {
            "closed" => Color.Success,
            "partially_shipped" => Color.Warning,
            "partially_invoiced" => Color.Warning,
            "over_shipped" => Color.Error,
            "over_invoiced" => Color.Error,
            "issued" => Color.Info,
            "draft" => Color.Default,
            _ => Color.Default
        };

    private static Color GetStageChipColor(string stage, string currentStatus) =>
        string.Equals(stage, currentStatus, StringComparison.OrdinalIgnoreCase)
            ? GetOutboundStatusColor(currentStatus)
            : Color.Default;

    private static Variant GetStageChipVariant(string stage, string currentStatus) =>
        string.Equals(stage, currentStatus, StringComparison.OrdinalIgnoreCase)
            ? Variant.Filled
            : Variant.Outlined;

    private static string GetOutboundStatusLabel(string? status) =>
        status switch
        {
            "draft" => "Draft",
            "issued" => "Issued",
            "partially_shipped" => "Partially shipped",
            "partially_invoiced" => "Partially invoiced",
            "closed" => "Closed",
            "over_shipped" => "Over shipped",
            "over_invoiced" => "Over invoiced",
            _ => "Outbound status pending"
        };

    private static string GetShipmentCoverageLabel(string? status) =>
        status switch
        {
            "no_inventory_handoff" => "No shipment lane",
            "not_shipped" => "Not shipped",
            "partially_shipped" => "Partially shipped",
            "fully_shipped" => "Fully shipped",
            "over_shipped" => "Over shipped",
            _ => "Shipment pending"
        };

    private static string BuildOutboundStatusSummary(ShellSalesOrderOutboundControlSummary control) =>
        control.AggregateStatus switch
        {
            "draft" => "The order is still editable demand truth. Issue it before fulfillment and AR start operating from it.",
            "issued" => "The order is issued and ready for outbound execution. Shipment and invoice coverage have not closed it yet.",
            "partially_shipped" => $"{control.RemainingToShipQuantity:N2} shippable quantity remains open before fulfillment truth is complete.",
            "partially_invoiced" => $"{control.RemainingToInvoiceQuantity:N2} order quantity remains open before AR truth closes this SO.",
            "closed" => "Shipment and posted invoice truth cover the sales order. This SO is operationally closed.",
            "over_shipped" => "Shipment truth exceeds SO shippable quantity. Review fulfillment before continuing.",
            "over_invoiced" => "Posted invoice truth exceeds SO quantity. Review AR anchors before continuing.",
            _ => "Outbound state has not been evaluated yet."
        };

    private static Color GetInvoiceCoverageColor(string? status) =>
        status switch
        {
            "fully_invoiced" => Color.Success,
            "partially_invoiced" => Color.Warning,
            "over_invoiced" => Color.Error,
            "not_invoiced" => Color.Info,
            _ => Color.Default
        };

    private static string GetInvoiceCoverageLabel(string? status) =>
        status switch
        {
            "not_invoiced" => "Not invoiced",
            "partially_invoiced" => "Partially invoiced",
            "fully_invoiced" => "Fully invoiced",
            "over_invoiced" => "Over invoiced",
            "no_order_quantity" => "No order quantity",
            _ => "Invoice coverage pending"
        };

    private static string BuildInvoiceCoverageSummary(ShellSalesOrderInvoiceCoverageSummary coverage) =>
        coverage.InvoiceCoverageStatus switch
        {
            "not_invoiced" => "No posted invoice is anchored to this sales order yet. Open Invoice to create the first AR draft from SO demand truth.",
            "partially_invoiced" => $"{coverage.RemainingToInvoiceQuantity:N2} order quantity remains open. Continue Invoice will prefill only the remaining lines.",
            "fully_invoiced" => "Posted invoice truth fully covers this sales order. Further invoice drafts are held to avoid accidental over-invoicing.",
            "over_invoiced" => "Posted invoice truth exceeds the sales order quantity. Review the invoice anchors before adding more AR truth.",
            "no_order_quantity" => "This sales order has no positive quantity to invoice.",
            _ => "Invoice coverage has not been evaluated yet."
        };

    private static string FormatInvoiceRatio(decimal invoicedQuantity, decimal orderQuantity) =>
        $"{FormatQuantity(invoicedQuantity)}/{FormatQuantity(orderQuantity)}";

    private static string FormatQuantity(decimal value) =>
        value == decimal.Truncate(value) ? value.ToString("N0") : value.ToString("N2");

    private string? ResolveProductServiceLabel(string? productServiceIdText)
    {
        var productServiceId = ParseOptionalGuid(productServiceIdText);
        if (!productServiceId.HasValue)
        {
            return null;
        }

        var productService = _productServices.FirstOrDefault(item => item.Id == productServiceId.Value);
        return productService?.DisplayLabel ?? productServiceId.Value.ToString("D");
    }

    private string? ResolveInventoryItemLabel(Guid? itemId)
    {
        if (!itemId.HasValue)
        {
            return null;
        }

        var item = InventoryItems.FirstOrDefault(candidate => candidate.Id == itemId.Value);
        return item is null ? itemId.Value.ToString("D") : $"{item.ItemCode} - {item.Name}";
    }

    private Task HandleCustomerSelectedAsync(UnitySearchPickerOption option)
    {
        _customerIdText = option.SourceId.ToString("D");
        return Task.CompletedTask;
    }

    private Task HandleCustomerClearedAsync()
    {
        if (TryBlockWrites())
        {
            return Task.CompletedTask;
        }

        _customerIdText = string.Empty;
        return Task.CompletedTask;
    }

    private Task HandleCreateCustomerRequestedAsync(string displayName)
    {
        Navigation.NavigateTo(BuildCounterpartyCreateHref("customer", displayName));
        return Task.CompletedTask;
    }

    private Task HandleProductServiceSelectedAsync(CommercialLineState line, UnitySearchPickerOption option)
    {
        ApplyProductService(line, option.SourceId.ToString("D"));
        return Task.CompletedTask;
    }

    private Task HandleProductServiceClearedAsync(CommercialLineState line)
    {
        ApplyProductService(line, string.Empty);
        return Task.CompletedTask;
    }

    private Task HandleInventoryItemSelectedAsync(CommercialLineState line, UnitySearchPickerOption option)
    {
        ApplyInventoryItem(line, option.SourceId);
        return Task.CompletedTask;
    }

    private Task HandleInventoryItemClearedAsync(CommercialLineState line)
    {
        ApplyInventoryItem(line, null);
        return Task.CompletedTask;
    }

    private void AddLine() => _lines.Add(CommercialLineState.Blank(_lines.Count == 0 ? 1 : _lines.Max(static line => line.LineNumber) + 1));

    private void RemoveLine(CommercialLineState line)
    {
        _lines.Remove(line);
        for (var index = 0; index < _lines.Count; index++) _lines[index].LineNumber = index + 1;
    }

    private void ApplyProductService(CommercialLineState line, string? productServiceIdText)
    {
        line.ProductServiceIdText = productServiceIdText ?? string.Empty;
        var item = _productServices.FirstOrDefault(candidate => string.Equals(candidate.Id.ToString("D"), line.ProductServiceIdText, StringComparison.OrdinalIgnoreCase));
        if (item is null) return;
        line.Description = item.EffectiveLineDescription;
        if (item.SalesRevenueAccountId.HasValue) line.RevenueAccountIdText = item.SalesRevenueAccountId.Value.ToString("D");
    }

    private void ApplyInventoryItem(CommercialLineState line, Guid? itemId)
    {
        line.ItemId = itemId;
        if (!itemId.HasValue)
        {
            line.WarehouseId = null;
            line.UomCode = string.Empty;
            return;
        }

        var item = InventoryItems.FirstOrDefault(candidate => candidate.Id == itemId.Value);
        line.UomCode = item?.StockUomCode ?? string.Empty;
        line.WarehouseId ??= Warehouses.FirstOrDefault()?.Id;
    }

    private void OnDocumentDateChanged(DateTime? value)
    {
        _documentDatePicker = value;
        _documentDate = DateOnly.FromDateTime(value ?? DateTime.Today);
    }

    private void OnRequestedShipDateChanged(DateTime? value)
    {
        _requestedShipDatePicker = value;
        _requestedShipDate = value.HasValue ? DateOnly.FromDateTime(value.Value) : null;
    }

    private bool TryBlockWrites()
    {
        if (!WritesBlocked) return false;
        _error = ShellState.WriteBlockMessage;
        Snackbar.Add(ShellState.WriteBlockMessage, Severity.Warning);
        return true;
    }

    private static Guid? ParseOptionalGuid(string? value) =>
        Guid.TryParse(value, out var parsed) ? parsed : null;

    private string BuildCounterpartyCreateHref(string entityType, string displayName)
    {
        var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        var normalizedReturnUrl = string.IsNullOrWhiteSpace(returnUrl) ? "/documents/sales-order/draft-editor" : $"/{returnUrl}";
        return $"/company/customer-vendor-setup?create={Uri.EscapeDataString(entityType)}&name={Uri.EscapeDataString(displayName.Trim())}&returnUrl={Uri.EscapeDataString(normalizedReturnUrl)}";
    }

    private sealed class CommercialLineState
    {
        public int LineNumber { get; set; }
        public string ProductServiceIdText { get; set; } = string.Empty;
        public string RevenueAccountIdText { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public decimal Quantity { get; set; } = 1m;
        public decimal UnitPrice { get; set; } = 1m;
        public Guid? ItemId { get; set; }
        public Guid? WarehouseId { get; set; }
        public string UomCode { get; set; } = string.Empty;
        public decimal LineAmount => decimal.Round(Quantity * UnitPrice, 2, MidpointRounding.AwayFromZero);
        public static CommercialLineState Blank(int lineNumber) => new() { LineNumber = lineNumber, Description = "Sales line" };
        public static CommercialLineState FromReadModel(ShellSalesCommercialDocumentLineReadModel line) => new()
        {
            LineNumber = line.LineNumber,
            RevenueAccountIdText = line.RevenueAccountId?.ToString("D") ?? string.Empty,
            Description = line.Description,
            Quantity = line.Quantity,
            UnitPrice = line.UnitPrice,
            ItemId = line.ItemId,
            WarehouseId = line.WarehouseId,
            UomCode = line.UomCode ?? string.Empty
        };

        public ShellSalesCommercialDocumentLineSaveRequest ToSaveRequest() => new()
        {
            LineNumber = LineNumber,
            RevenueAccountId = Guid.TryParse(RevenueAccountIdText, out var accountId) ? accountId : null,
            Description = Description,
            Quantity = Quantity,
            UnitPrice = UnitPrice,
            ItemId = ItemId,
            WarehouseId = WarehouseId,
            UomCode = UomCode
        };
    }
}
