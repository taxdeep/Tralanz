    private void AddLine() => _lines.Add(CommercialLineState.Blank(_lines.Count == 0 ? 1 : _lines.Max(static line => line.LineNumber) + 1));

    private void RemoveLine(CommercialLineState line)
    {
        _lines.Remove(line);
        for (var index = 0; index < _lines.Count; index++) _lines[index].LineNumber = index + 1;
    }

    private void ApplyProductService(CommercialLineState line, string? productServiceIdText)
    {
        line.ProductServiceIdText = productServiceIdText ?? string.Empty;
        var item = _productServices.FirstOrDefault(candidate => string.Equals(candidate.Id.ToString("D"), line.ProductServiceIdText, StringComparison.OrdinalIgnoreCase));
        if (item is null) return;
        line.Description = item.EffectiveLineDescription;
        if (item.SalesRevenueAccountId.HasValue) line.RevenueAccountIdText = item.SalesRevenueAccountId.Value.ToString("D");
    }

    private void ApplyInventoryItem(CommercialLineState line, Guid? itemId)
    {
        line.ItemId = itemId;
        if (!itemId.HasValue)
        {
            line.WarehouseId = null;
            line.UomCode = string.Empty;
            return;
        }

        var item = InventoryItems.FirstOrDefault(candidate => candidate.Id == itemId.Value);
        line.UomCode = item?.StockUomCode ?? string.Empty;
        line.WarehouseId ??= Warehouses.FirstOrDefault()?.Id;
    }

    private void OnDocumentDateChanged(DateTime? value)
    {
        _documentDatePicker = value;
        _documentDate = DateOnly.FromDateTime(value ?? DateTime.Today);
    }

    private void OnRequestedShipDateChanged(DateTime? value)
    {
        _requestedShipDatePicker = value;
        _requestedShipDate = value.HasValue ? DateOnly.FromDateTime(value.Value) : null;
    }

    private bool TryBlockWrites()
    {
        if (!WritesBlocked) return false;
        _error = ShellState.WriteBlockMessage;
        Snackbar.Add(ShellState.WriteBlockMessage, Severity.Warning);
        return true;
    }

    private sealed class CommercialLineState
    {
        public int LineNumber { get; set; }
        public string ProductServiceIdText { get; set; } = string.Empty;
        public string RevenueAccountIdText { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public decimal Quantity { get; set; } = 1m;
        public decimal UnitPrice { get; set; } = 1m;
        public Guid? ItemId { get; set; }
        public Guid? WarehouseId { get; set; }
        public string UomCode { get; set; } = string.Empty;
        public decimal LineAmount => decimal.Round(Quantity * UnitPrice, 2, MidpointRounding.AwayFromZero);
        public static CommercialLineState Blank(int lineNumber) => new() { LineNumber = lineNumber, Description = "Sales line" };
        public static CommercialLineState FromReadModel(ShellSalesCommercialDocumentLineReadModel line) => new()
        {
            LineNumber = line.LineNumber,
            RevenueAccountIdText = line.RevenueAccountId?.ToString("D") ?? string.Empty,
            Description = line.Description,
            Quantity = line.Quantity,
            UnitPrice = line.UnitPrice,
            ItemId = line.ItemId,
            WarehouseId = line.WarehouseId,
            UomCode = line.UomCode ?? string.Empty
        };

        public ShellSalesCommercialDocumentLineSaveRequest ToSaveRequest() => new()
        {
            LineNumber = LineNumber,
            RevenueAccountId = Guid.TryParse(RevenueAccountIdText, out var accountId) ? accountId : null,
            Description = Description,
            Quantity = Quantity,
            UnitPrice = UnitPrice,
            ItemId = ItemId,
            WarehouseId = WarehouseId,
            UomCode = UomCode
        };
    }
}
