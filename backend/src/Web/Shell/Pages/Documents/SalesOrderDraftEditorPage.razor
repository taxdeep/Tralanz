    private static string BuildInvoiceCoverageSummary(ShellSalesOrderInvoiceCoverageSummary coverage) =>
        coverage.InvoiceCoverageStatus switch
        {
            "not_invoiced" => "No posted invoice is anchored to this sales order yet. Open Invoice to create the first AR draft from SO demand truth.",
            "partially_invoiced" => $"{coverage.RemainingToInvoiceQuantity:N2} order quantity remains open. Continue Invoice will prefill only the remaining lines.",
            "fully_invoiced" => "Posted invoice truth fully covers this sales order. Further invoice drafts are held to avoid accidental over-invoicing.",
            "over_invoiced" => "Posted invoice truth exceeds the sales order quantity. Review the invoice anchors before adding more AR truth.",
            "no_order_quantity" => "This sales order has no positive quantity to invoice.",
            _ => "Invoice coverage has not been evaluated yet."
