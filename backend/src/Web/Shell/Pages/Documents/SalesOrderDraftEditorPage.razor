    private static string BuildOutboundStatusSummary(ShellSalesOrderOutboundControlSummary control) =>
        control.AggregateStatus switch
        {
            "draft" => "The order is still editable demand truth. Issue it before fulfillment and AR start operating from it.",
            "issued" => "The order is issued and ready for outbound execution. Shipment and invoice coverage have not closed it yet.",
            "partially_shipped" => $"{control.RemainingToShipQuantity:N2} shippable quantity remains open before fulfillment truth is complete.",
            "partially_invoiced" => $"{control.RemainingToInvoiceQuantity:N2} order quantity remains open before AR truth closes this SO.",
            "closed" => "Shipment and posted invoice truth cover the sales order. This SO is operationally closed.",
            "over_shipped" => "Shipment truth exceeds SO shippable quantity. Review fulfillment before continuing.",
            "over_invoiced" => "Posted invoice truth exceeds SO quantity. Review AR anchors before continuing.",
