        SelectedCustomerId.HasValue
            ? _customerOptions.FirstOrDefault(item => item.Id == SelectedCustomerId.Value).DisplayLabel
            : null;

    private string? ResolveSalesProductServiceLabel(string? productServiceIdText)
    {
        var productServiceId = ParseOptionalGuid(productServiceIdText);
        if (!productServiceId.HasValue)
        {
            return null;
        }

        foreach (var item in _salesProductServices)
        {
            if (item.Id == productServiceId.Value)
            {
                return item.DisplayLabel;
            }
        }

        return productServiceId.Value.ToString("D");
    }

    private Task HandleCustomerSelectedAsync(UnitySearchPickerOption option)
    {
        _customerIdText = option.SourceId.ToString("D");
        return Task.CompletedTask;
    }

    private Task HandleCustomerClearedAsync()
    {
        if (TryBlockDraftEdits())
        {
            return Task.CompletedTask;
        }

        _customerIdText = string.Empty;
        return Task.CompletedTask;
    }

    private Task HandleProductServiceSelectedAsync(SalesLine line, UnitySearchPickerOption option)
    {
        ApplyProductService(line, option.SourceId.ToString("D"));
        return Task.CompletedTask;
    }

    private Task HandleProductServiceClearedAsync(SalesLine line)
    {
        ApplyProductService(line, string.Empty);
        return Task.CompletedTask;
    }

    private void ApplyProductService(SalesLine line, string? productServiceIdText)
    {
        if (TryBlockDraftEdits())
        {
            return;
        }

        line.ProductServiceIdText = productServiceIdText ?? string.Empty;

        var productService = _salesProductServices.FirstOrDefault(
            item => string.Equals(item.Id.ToString("D"), line.ProductServiceIdText, StringComparison.OrdinalIgnoreCase));
        if (productService is null)
        {
            return;
        }

        line.Description = productService.EffectiveLineDescription;
        if (productService.SalesRevenueAccountId.HasValue)
        {
            line.AccountIdText = productService.SalesRevenueAccountId.Value.ToString("D");
        }

        if (productService.DefaultSalesTaxCodeId.HasValue)
        {
            var taxCode = _taxCodes.FirstOrDefault(option => option.Id == productService.DefaultSalesTaxCodeId.Value);
            if (taxCode is not null)
            {
                ApplyTaxCode(line, taxCode);
            }
        }
    }

    private void ApplyInventoryItem(SalesLine line, Guid? itemId)
    {
        if (TryBlockDraftEdits())
        {
            return;
        }

        line.ItemId = itemId;
        if (!itemId.HasValue)
        {
            line.WarehouseId = null;
            line.UomCode = string.Empty;
            return;
        }

        var item = InventoryOperationalItems.FirstOrDefault(current => current.Id == itemId.Value);
        if (item is null)
        {
            return;
        }

        line.UomCode = item.StockUomCode ?? string.Empty;
        line.WarehouseId ??= InventoryWarehouses.FirstOrDefault()?.Id;
    }

    private static bool IsInventorySalesIssueHandoffReady(SalesLine line) =>
        line.ItemId.HasValue &&
        line.WarehouseId.HasValue &&
        !string.IsNullOrWhiteSpace(line.UomCode);

    private static Guid? ParseOptionalGuid(string? value) =>
        Guid.TryParse(value, out var parsed) ? parsed : null;

    private sealed class SalesLine
    {
        public int LineNumber { get; set; }
        public string ProductServiceIdText { get; set; } = string.Empty;
        public string AccountIdText { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public decimal Quantity { get; set; } = 1m;
        public decimal UnitPrice { get; set; } = 1m;
        public string TaxCodeIdText { get; set; } = string.Empty;
        public decimal TaxAmount { get; set; }
        public Guid? ItemId { get; set; }
        public Guid? WarehouseId { get; set; }
        public string UomCode { get; set; } = string.Empty;
        public decimal LineAmount => Quantity * UnitPrice;
        public decimal TotalAmount => LineAmount + TaxAmount;
        public static SalesLine Blank(int lineNumber) => new() { LineNumber = lineNumber };
    }
}
