@page "/documents/invoice/draft-editor"
@using Citus.Modules.Inventory.Application.Contracts
@using Citus.Modules.UnitySearch.Blazor
@using Citus.Modules.UnitySearch.Domain.Shared
@using Modules.CompanyAccess.SessionContext
@using Modules.GL.JournalEntry
@using Web.Business.AR.SettlementLookup
@using Web.Shell.Services
@inject Web.Shell.State.WebShellState ShellState
@inject ICompanyAccessShellSession ShellSession
@inject Web.Shell.Services.WebShellBusinessSessionClient SessionClient
@inject Web.Shell.Services.WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject IArSettlementLookupService Customers
@inject IJournalEntryAccountCatalog Accounts
@inject ShellTaxCodeLookupService TaxCodes
@inject ShellProductServiceCatalogClient ProductServices
@inject WebShellCompanyOnboardingClient OnboardingClient
@inject ShellInventoryShipmentClient InventoryShipment
@inject ShellSalesCommercialDocumentClient CommercialDocuments
@inject ShellSourceDocumentDraftClient Drafts
@inject ISnackbar Snackbar

<PageTitle>Invoice Draft</PageTitle>

<div style="padding:2rem 2.25rem;color:#d9e2ea;">
    <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-bottom:1rem;">
        <MudButton Variant="Variant.Text" Href="/documents/source-browser">Back</MudButton>
        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Success">Invoice draft</MudChip>
    </div>
    <h1 style="margin:0 0 .75rem 0;">Invoice Draft Editor</h1>
    <p style="margin:0 0 1rem 0;color:#97a8b7;max-width:56rem;">
        Save or reopen a governed invoice draft in the active company context, then post it into the existing document-detail and journal-review flow.
    </p>

    @if (IsCompanyReadyHandOff)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            Company-ready hand-off opened the invoice workbench first so you can start operating as soon as the initial company, owner membership, and starter accounts are in place.
        </MudAlert>

        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Recommended next workspaces</MudText>
            <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/company/book-governance?origin=company-ready">
                    Review Book Governance
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" Href="/company/customer-vendor-setup?origin=company-ready">
                    Set Up Customer Truth
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Tertiary" Href="/company/product-service-setup?origin=company-ready">
                    Set Up Product & Service Defaults
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="/documents/bill/draft-editor?origin=company-ready">
                    Start First Bill
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" Href="/">
                    Open General Workspace
                </MudButton>
            </div>
        </MudPaper>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(14rem,1fr));gap:1rem;margin-bottom:1rem;">
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Customer Truth</MudText>
                <MudText Typo="Typo.h6">@CustomerTruthLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@CustomerTruthSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Tax Truth</MudText>
                <MudText Typo="Typo.h6">@TaxTruthLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@TaxTruthSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Product / Service Truth</MudText>
                <MudText Typo="Typo.h6">@ProductServiceTruthLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@ProductServiceTruthSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Posting Path</MudText>
                <MudText Typo="Typo.h6">@InvoicePostingPathLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@InvoicePostingPathSummary</MudText>
            </MudPaper>
        </div>

        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <MudText Typo="Typo.subtitle2" Class="mb-2">First-company operator steps</MudText>
            <MudList T="string" Dense="true">
                <MudListItem Text="1">
                    <ChildContent><MudText Typo="Typo.body2">@GetFirstInvoiceStepOne()</MudText></ChildContent>
                </MudListItem>
                <MudListItem Text="2">
                    <ChildContent><MudText Typo="Typo.body2">@GetFirstInvoiceStepTwo()</MudText></ChildContent>
                </MudListItem>
                <MudListItem Text="3">
                    <ChildContent><MudText Typo="Typo.body2">@GetFirstInvoiceStepThree()</MudText></ChildContent>
                </MudListItem>
            </MudList>
        </MudPaper>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Style="margin-bottom:1rem;">@_error</MudAlert>
    }
    @if (!string.IsNullOrWhiteSpace(_sourceShipmentDisplayNumber))
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            Shipment hand-off <strong>@_sourceShipmentDisplayNumber</strong> prefilled this invoice draft. Shipment remains fulfillment truth; complete price, revenue account, tax, and AR posting details before posting.
        </MudAlert>
    }
    @if (!string.IsNullOrWhiteSpace(_sourceSalesOrderDisplayNumber))
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            Sales order <strong>@_sourceSalesOrderDisplayNumber</strong> prefilled this invoice draft. Invoice owns AR/revenue truth; SO remains demand truth.
        </MudAlert>
    }

    <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
        <div style="display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;flex-wrap:wrap;">
            <div>
                <MudText Typo="Typo.subtitle2">Commercial Chain</MudText>
                <MudText Typo="Typo.h5">@InvoiceCommercialStageLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@InvoiceCommercialStageSummary</MudText>
            </div>
            <MudChip T="string" Color="@InvoiceCommercialStageColor" Variant="Variant.Filled">@InvoiceCommercialStageBadge</MudChip>
        </div>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));gap:1rem;margin-top:1rem;">
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Source demand</MudText>
                <MudText Typo="Typo.h6">@InvoiceSourceLinkLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@InvoiceSourceLinkSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Current next step</MudText>
                <MudText Typo="Typo.h6">@InvoicePostingPathLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@InvoicePostingPathSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Settlement lane</MudText>
                <MudText Typo="Typo.h6">@InvoiceSettlementLaneLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@InvoiceSettlementLaneSummary</MudText>
            </MudPaper>
        </div>

        <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1rem;">
            <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="/documents/source-browser?sourceType=invoice&counterpartyRole=customer">
                Open Invoice Pipeline
            </MudButton>
            @if (_loadedSourceSalesOrderId.HasValue)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Success" Href="@BuildSourceSalesOrderHref()">
                    Open Source Sales Order
                </MudButton>
            }
            @if (_saved is not null && _postedResult is not null)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success" Href="@BuildReceivePaymentHref()">
                    Continue to Receive Payment
                </MudButton>
            }
        </div>
    </MudPaper>

    @if (WritesBlocked)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">@ShellState.WriteBlockMessage</MudAlert>
    }
    else if (!CanEditDraft)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            This invoice is no longer editable in the draft workbench. Submitted invoices can still be posted, but draft-line mutations stop once the invoice is submitted.
        </MudAlert>
    }

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(14rem,1fr));gap:1rem;margin-bottom:1rem;">
        <div>
            <MudText Typo="Typo.caption" Class="mb-1">Customer</MudText>
            <UnitySearchPicker CompanyId="@ShellSession.ActiveCompanyId"
                               UserId="@ShellState.CurrentUserId"
                               Context="@SearchScopeContext.InvoiceCustomerPicker"
                               SelectedId="@SelectedCustomerId"
                               SelectedDisplayText="@SelectedCustomerDisplayText"
                               Placeholder="Search customer"
                               Disabled="@DraftMutationBlocked"
                               OnOptionSelected="HandleCustomerSelectedAsync"
                               OnCleared="HandleCustomerClearedAsync" />
        </div>
        <MudDatePicker Label="Invoice Date" Variant="Variant.Outlined" Date="@_documentDatePicker" DateChanged="OnDocumentDateChanged" Disabled="@DraftMutationBlocked" />
        <MudDatePicker Label="Due Date" Variant="Variant.Outlined" Date="@_dueDatePicker" DateChanged="OnDueDateChanged" Disabled="@DraftMutationBlocked" />
        <MudTextField T="string" Label="Tx Currency" Variant="Variant.Outlined" Value="_txCurrency" ValueChanged="OnCurrencyChanged" Disabled="@(!ShellState.ActiveCompany.MultiCurrencyEnabled || DraftMutationBlocked)" />
        <MudTextField T="string" Label="Base Currency" Variant="Variant.Outlined" Value="_baseCurrency" Disabled="true" />
        <MudNumericField T="decimal?" Label="FX Rate" Variant="Variant.Outlined" @bind-Value="_fxRate" Disabled="@((IsIdentityFx || DraftMutationBlocked))" />
        <MudTextField T="string" Label="Memo" Variant="Variant.Outlined" @bind-Value="_memo" Disabled="@DraftMutationBlocked" />
    </div>

    <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:.75rem;">
            <MudText Typo="Typo.h6">Lines</MudText>
            <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
                @if (DefaultSalesTaxCode is not null)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Disabled="@WritesBlocked" OnClick="ApplyDefaultSetupTaxToDraft">
                        Default Tax From Setup
                    </MudButton>
                }
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Disabled="@DraftMutationBlocked" OnClick="AddLine">Add line</MudButton>
            </div>
        </div>
        @if (MissingDefaultSalesTaxLineCount > 0 && DefaultSalesTaxCode is not null)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:.75rem;">
                @MissingDefaultSalesTaxLineCount line(s) still show <strong>No tax</strong>. The setup default <strong>@DefaultSalesTaxCode.DefaultSummaryLabel</strong> is available if those lines should be taxable.
            </MudAlert>
        }
        <MudTable Items="_lines" Dense="true" Hover="true" Bordered="true">
            <HeaderContent>
                <MudTh>#</MudTh><MudTh>Product / Service</MudTh><MudTh>Revenue</MudTh><MudTh>Description</MudTh><MudTh>Qty</MudTh><MudTh>Unit</MudTh><MudTh>Tax Code</MudTh><MudTh>Tax</MudTh><MudTh>Total</MudTh><MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.LineNumber</MudTd>
                <MudTd>
                    <UnitySearchPicker CompanyId="@ShellSession.ActiveCompanyId"
                                       UserId="@ShellState.CurrentUserId"
                                       Context="@SearchScopeContext.InvoiceItemPicker"
                                       SelectedId="@ParseOptionalGuid(context.ProductServiceIdText)"
                                       SelectedDisplayText="@ResolveSalesProductServiceLabel(context.ProductServiceIdText)"
                                       Placeholder="Search sellable item"
                                       Disabled="@DraftMutationBlocked"
                                       OnOptionSelected="@(option => HandleProductServiceSelectedAsync(context, option))"
                                       OnCleared="@(async () => await HandleProductServiceClearedAsync(context))" />
                </MudTd>
                <MudTd>
                    <MudSelect T="string" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="context.AccountIdText" Disabled="@DraftMutationBlocked">
                        @foreach (var account in _revenueAccounts)
                        {
                            <MudSelectItem T="string" Value="@account.AccountId.ToString("D")">@account.DisplayText</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd><MudTextField T="string" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="context.Description" Disabled="@DraftMutationBlocked" /></MudTd>
                <MudTd><MudNumericField T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.01m" Immediate="true" @bind-Value="context.Quantity" Disabled="@DraftMutationBlocked" /></MudTd>
                <MudTd><MudNumericField T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.01m" Immediate="true" @bind-Value="context.UnitPrice" Disabled="@DraftMutationBlocked" /></MudTd>
                <MudTd>
                    <MudSelect T="string" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="context.TaxCodeIdText" Disabled="@DraftMutationBlocked">
                        <MudSelectItem T="string" Value="@string.Empty">No tax</MudSelectItem>
                        @foreach (var taxCode in _taxCodes)
                        {
                            <MudSelectItem T="string" Value="@taxCode.Id.ToString("D")">@taxCode.DisplayLabel</MudSelectItem>
                        }
                    </MudSelect>
                    @if (!string.IsNullOrWhiteSpace(GetSalesTaxEditorHint(context)))
                    {
                        <MudText Typo="Typo.caption" Style="display:block;margin-top:.25rem;color:#97a8b7;">
                            @GetSalesTaxEditorHint(context)
                        </MudText>
                    }
                </MudTd>
                <MudTd><MudNumericField T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0m" Immediate="true" @bind-Value="context.TaxAmount" Disabled="@DraftMutationBlocked" /></MudTd>
                <MudTd>@context.TotalAmount.ToString("N2")</MudTd>
                <MudTd>
                    <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Disabled="@DraftMutationBlocked" OnClick="@(() => ApplyRate(context))">Rate</MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Error" Disabled="@(_lines.Count == 1 || DraftMutationBlocked)" OnClick="@(() => RemoveLine(context))">X</MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

    @if (SupportsInventorySalesIssueHandoff)
    {
        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:.75rem;">
                <MudText Typo="Typo.h6">Shipment-first outbound hand-off</MudText>
                @if (_saved is not null && HasReadyInventoryGradeOutboundLines)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Info"
                               Disabled="@(_invoiceShipmentLaneSummary is not null && _invoiceShipmentLaneSummary.RemainingToShipQuantity <= 0m)"
                               Href="@BuildShipmentHandoffHref()">
                        Open Shipment Workspace
                    </MudButton>
                    @if (_invoiceShipmentLaneSummary is not null && _invoiceShipmentLaneSummary.RecentShipments.Count > 0)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Success"
                                   Disabled="@(_invoiceShipmentLaneSummary.RemainingToIssueQuantity <= 0m)"
                                   Href="@BuildInvoiceSalesIssueHref(_invoiceShipmentLaneSummary)">
                            Open Sales Issue
                        </MudButton>
                    }
                }
            </div>
            @if (IncompleteInventoryHandoffLineCount > 0)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:.75rem;">
                    @IncompleteInventoryHandoffLineCount line(s) started shipment-first hand-off but are still missing item, warehouse, or stock UOM. Complete the outbound set before handing invoice intent into Sales Issue.
                </MudAlert>
            }
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));gap:1rem;margin-bottom:.75rem;">
                <MudPaper Class="pa-3" Elevation="0">
                    <MudText Typo="Typo.caption">Handoff Status</MudText>
                    <MudText Typo="Typo.h6">@ShipmentHandoffStatusLabel</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@ShipmentHandoffStatusSummary</MudText>
                </MudPaper>
                <MudPaper Class="pa-3" Elevation="0">
                    <MudText Typo="Typo.caption">Outbound Lines</MudText>
                    <MudText Typo="Typo.h6">@InventoryGradeOutboundLineCount</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">Invoice lines carrying item + warehouse hand-off truth</MudText>
                </MudPaper>
                <MudPaper Class="pa-3" Elevation="0">
                    <MudText Typo="Typo.caption">Next Step</MudText>
                    <MudText Typo="Typo.h6">@ShipmentHandoffNextStepTitle</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@ShipmentHandoffNextStepDetail</MudText>
                </MudPaper>
            </div>
            @if (_invoiceShipmentLaneSummary is not null && InventoryGradeOutboundLineCount > 0)
            {
                <MudAlert Severity="@(InvoiceShipmentAllowsPost ? Severity.Success : Severity.Warning)" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:.75rem;">
                    <strong>@InvoiceShipmentPostingGateLabel</strong>
                    <div>@InvoiceShipmentPostingGateSummary</div>
                </MudAlert>
                <MudAlert Severity="@InvoiceCoverageSeverity" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:.75rem;">
                    <strong>Invoice coverage: @_invoiceShipmentLaneSummary.InvoiceCoverageStatus.Replace('_', ' ')</strong>
                    <div>@BuildInvoiceCoverageSummary(_invoiceShipmentLaneSummary)</div>
                </MudAlert>
                <MudAlert Severity="@InvoiceIssueFollowThroughSeverity" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:.75rem;">
                    <strong>Downstream issue follow-through: @_invoiceShipmentLaneSummary.IssueMatchStatus.Replace('_', ' ')</strong>
                    <div>@BuildInvoiceIssueFollowThroughSummary(_invoiceShipmentLaneSummary)</div>
                </MudAlert>
                @if (_invoiceShipmentLaneSummary.RecentShipments.Count > 0)
                {
                    <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-bottom:.75rem;">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Warning"
                                   Disabled="@(_invoiceShipmentLaneSummary.RemainingToShipQuantity <= 0m)"
                                   Href="@BuildShipmentHandoffHref()">
                            Continue Shipment
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   Disabled="@(_invoiceShipmentLaneSummary.RemainingToIssueQuantity <= 0m)"
                                   Href="@BuildInvoiceSalesIssueHref(_invoiceShipmentLaneSummary)">
                            Continue Sales Issue
                        </MudButton>
                    </div>
                }
                @if (_invoiceShipmentLaneSummary.Discrepancies.Count > 0)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:.75rem;">
                        @foreach (var discrepancy in _invoiceShipmentLaneSummary.Discrepancies)
                        {
                            <div>@discrepancy.Summary</div>
                        }
                    </MudAlert>
                }
            }
            <MudTable Items="_lines" Dense="true" Hover="true" Bordered="true">
                <HeaderContent>
                    <MudTh>#</MudTh><MudTh>Item</MudTh><MudTh>Warehouse</MudTh><MudTh>UOM</MudTh><MudTh>Qty</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.LineNumber</MudTd>
                    <MudTd>
                        <MudSelect T="Guid?" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@DraftMutationBlocked" Value="context.ItemId" ValueChanged="@(value => ApplyInventoryItem(context, value))">
                            <MudSelectItem T="Guid?" Value="@((Guid?)null)">No shipment hand-off</MudSelectItem>
                            @foreach (var item in InventoryOperationalItems)
                            {
                                <MudSelectItem T="Guid?" Value="@item.Id">@item.ItemCode - @item.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudTd>
                    <MudTd>
                        <MudSelect T="Guid?" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(DraftMutationBlocked || context.ItemId is null)" @bind-Value="context.WarehouseId">
                            @foreach (var warehouse in InventoryWarehouses)
                            {
                                <MudSelectItem T="Guid?" Value="@warehouse.Id">@warehouse.WarehouseCode - @warehouse.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudTd>
                    <MudTd>
                        <MudTextField T="string" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(DraftMutationBlocked || context.ItemId is null)" @bind-Value="context.UomCode" />
                    </MudTd>
                    <MudTd>@context.Quantity.ToString("N2")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));gap:1rem;margin-bottom:1rem;">
        <MudPaper Class="pa-4" Elevation="0"><MudText Typo="Typo.caption">Subtotal</MudText><MudText Typo="Typo.h6">@Subtotal.ToString("N2")</MudText></MudPaper>
        <MudPaper Class="pa-4" Elevation="0"><MudText Typo="Typo.caption">Tax</MudText><MudText Typo="Typo.h6">@TaxTotal.ToString("N2")</MudText></MudPaper>
        <MudPaper Class="pa-4" Elevation="0"><MudText Typo="Typo.caption">Total</MudText><MudText Typo="Typo.h6">@GrandTotal.ToString("N2")</MudText></MudPaper>
    </div>

    <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
        <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(_saving || _submitting || _posting || !CanEditDraft || WritesBlocked)" OnClick="SaveAsync">Save Draft</MudButton>
        @if (_saved is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@($"/documents/invoice/{_saved.DocumentId:D}")">Open Detail</MudButton>
            @if (IsDraft)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Warning" Disabled="@(_submitting || _saving || _posting || WritesBlocked)" OnClick="SubmitAsync">Submit Draft</MudButton>
            }
            @if (CanPost)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Info" Disabled="@(_posting || _saving || WritesBlocked)" OnClick="PostAsync">Post Draft</MudButton>
            }
        }
    </div>

    @if (_saved is not null)
    {
        <MudPaper Class="pa-4" Elevation="0" Style="margin-top:1rem;">
            <MudText Typo="Typo.h6">Saved Draft</MudText>
            <MudText Typo="Typo.body2">Document Id: @_saved.DocumentId</MudText>
            <MudText Typo="Typo.body2">Display Number: @_saved.DisplayNumber</MudText>
            <MudText Typo="Typo.body2">Entity Number: @_saved.EntityNumber</MudText>
            <MudText Typo="Typo.body2">Status: @_saved.Status</MudText>
        </MudPaper>
    }

    @if (_postedResult is not null && _saved is not null)
    {
        <MudPaper Class="pa-4" Elevation="0" Style="margin-top:1rem;">
            <MudText Typo="Typo.h6">Posted Review Continuity</MudText>
            <MudText Typo="Typo.body2">Journal Entry: @_postedResult.JournalEntryDisplayNumber</MudText>
            <MudText Typo="Typo.body2">Posted At: @_postedResult.PostedAt.ToString("yyyy-MM-dd HH:mm 'UTC'")</MudText>
            <MudText Typo="Typo.body2">Status: @_postedResult.Status</MudText>
            @if (_postedResult.Warnings.Count > 0)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-top:1rem;">
                    @string.Join(" | ", _postedResult.Warnings)
                </MudAlert>
            }

            @if (IsCompanyReadyHandOff)
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true" Style="margin-top:1rem;">
                    The first invoice is now posted. Continue into Receive Payment when you are ready to settle the first receivable, or start the first vendor-side flow in parallel.
                </MudAlert>
            }

            <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1rem;">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@BuildPostedDetailHref()">
                    Open Posted Document
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@($"/gl/journal-entry/review/{_postedResult.JournalEntryId:D}")">Open Journal Entry Review</MudButton>
                @if (IsCompanyReadyHandOff)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Success" Href="@BuildFirstReceiptHref()">
                        Continue to First Receipt
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/documents/bill/draft-editor?origin=company-ready">
                        Start First Bill
                    </MudButton>
                }
            </div>
        </MudPaper>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "draftId")]
    public Guid? DraftId { get; set; }

    [SupplyParameterFromQuery(Name = "origin")]
    public string? Origin { get; set; }

    [SupplyParameterFromQuery(Name = "customerId")]
    public Guid? CustomerId { get; set; }

    [SupplyParameterFromQuery(Name = "productServiceId")]
    public Guid? ProductServiceId { get; set; }

    [SupplyParameterFromQuery(Name = "shipmentId")]
    public Guid? ShipmentId { get; set; }

    [SupplyParameterFromQuery(Name = "salesOrderId")]
    public Guid? SalesOrderId { get; set; }

    private readonly List<SalesLine> _lines = [SalesLine.Blank(1)];
    private IReadOnlyList<(Guid Id, string DisplayLabel, string CurrencyCode)> _customerOptions = Array.Empty<(Guid Id, string DisplayLabel, string CurrencyCode)>();
    private IReadOnlyList<JournalEntryAccountOption> _revenueAccounts = Array.Empty<JournalEntryAccountOption>();
    private IReadOnlyList<ShellTaxCodeLookupOption> _taxCodes = Array.Empty<ShellTaxCodeLookupOption>();
    private IReadOnlyList<ShellManagedProductServiceSummary> _salesProductServices = Array.Empty<ShellManagedProductServiceSummary>();
    private WebShellCompanyOnboardingSummary? _onboardingSummary;
    private InventoryShipmentDashboard? _inventoryShipmentDashboard;
    private InventoryInvoiceShipmentIssueLaneSummary? _invoiceShipmentLaneSummary;
    private Guid? _documentId;
    private ShellSourceDocumentDraftSaveResult? _saved;
    private string? _customerIdText;
    private string _txCurrency = string.Empty;
    private string _baseCurrency = string.Empty;
    private Guid? _fxSnapshotId;
    private decimal? _fxRate;
    private string? _memo;
    private string? _error;
    private bool _saving;
    private bool _submitting;
    private bool _posting;
    private ShellSourceDocumentPostResult? _postedResult;
    private DateOnly _documentDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly _dueDate = DateOnly.FromDateTime(DateTime.Today.AddDays(30));
    private DateTime? _documentDatePicker = DateTime.Today;
    private DateTime? _dueDatePicker = DateTime.Today.AddDays(30);
    private Guid? _loadedDraftId;
    private Guid? _loadedProductServiceHintId;
    private Guid? _loadedSourceShipmentId;
    private string? _sourceShipmentDisplayNumber;
    private Guid? _loadedSourceSalesOrderId;
    private string? _sourceSalesOrderDisplayNumber;

    private decimal Subtotal => _lines.Sum(static x => x.LineAmount);
    private decimal TaxTotal => _lines.Sum(static x => x.TaxAmount);
    private decimal GrandTotal => Subtotal + TaxTotal;
    private bool IsIdentityFx => string.Equals(_txCurrency, _baseCurrency, StringComparison.OrdinalIgnoreCase);
    private bool IsDraft => string.Equals(_saved?.Status, "draft", StringComparison.OrdinalIgnoreCase);
    private bool IsSubmitted => string.Equals(_saved?.Status, "submitted", StringComparison.OrdinalIgnoreCase);
    private bool IsPosted => string.Equals(_saved?.Status, "posted", StringComparison.OrdinalIgnoreCase);
    private bool CanEditDraft => _saved is null || IsDraft;
    private bool CanPost => IsSubmitted && _documentId.HasValue && InvoiceShipmentAllowsPost;
    private bool DraftMutationBlocked => WritesBlocked || !CanEditDraft;
    private bool IsCompanyReadyHandOff => string.Equals(Origin, "company-ready", StringComparison.OrdinalIgnoreCase);
    private bool WritesBlocked => ShellState.AreWritesBlocked;
    private bool SupportsInventorySalesIssueHandoff => _onboardingSummary?.SupportsInventoryFoundation == true && _inventoryShipmentDashboard is not null;
    private IReadOnlyList<InventoryManagedItemSummary> InventoryOperationalItems =>
        _inventoryShipmentDashboard?.ActiveItems.Where(static item => item.ManageInventoryMethod == Citus.Modules.Inventory.Domain.Shared.ManageInventoryMethod.ManageStock).ToList() ?? [];
    private IReadOnlyList<InventoryManagedWarehouseSummary> InventoryWarehouses => _inventoryShipmentDashboard?.ActiveWarehouses ?? [];
    private int InventoryGradeOutboundLineCount => _lines.Count(line => line.ItemId.HasValue);
    private bool HasReadyInventoryGradeOutboundLines => _lines.Any(IsInventorySalesIssueHandoffReady);
    private int IncompleteInventoryHandoffLineCount => _lines.Count(line => line.ItemId.HasValue && !IsInventorySalesIssueHandoffReady(line));
    private ShellTaxCodeLookupOption? DefaultSalesTaxCode => _taxCodes.Count == 1 ? _taxCodes[0] : null;
    private int MissingDefaultSalesTaxLineCount => DefaultSalesTaxCode is null ? 0 : _lines.Count(line => string.IsNullOrWhiteSpace(line.TaxCodeIdText));
    private string CustomerTruthLabel => _customerOptions.Count > 0 ? $"{_customerOptions.Count} customer option(s)" : "Customer truth missing";
    private string CustomerTruthSummary => _customerOptions.Count > 0
        ? "At least one customer is available in backend truth, so the first invoice can bind to a real counterparty."
        : "No customer options are available in the current company context. First invoice creation is blocked until customer truth exists.";
    private string TaxTruthLabel => _taxCodes.Count > 0 ? $"{_taxCodes.Count} sales tax code(s)" : "Tax can stay empty";
    private string TaxTruthSummary => DefaultSalesTaxCode is not null
        ? $"A single active sales tax code ({DefaultSalesTaxCode.DefaultSummaryLabel}) is available, so blank invoice lines can adopt the setup default instead of forcing a second tax decision."
        : _taxCodes.Count > 1
            ? "Sales tax rules are available and line-level tax truth can be carried directly into posting, but the operator still needs to choose the right tax code per taxable line."
            : "The first invoice can still be issued tax-free. Configure Tax Setup later before starting taxable sales.";
    private string ProductServiceTruthLabel => _salesProductServices.Count > 0 ? $"{_salesProductServices.Count} sales-ready item(s)" : "Catalog still optional";
    private string ProductServiceTruthSummary => _salesProductServices.Count > 0
        ? "Product and service defaults can now carry description, revenue account, and default sales tax into the first invoice lines."
        : "Invoice lines can still be entered manually. Product and service setup becomes useful once you want reusable account and tax defaults.";
    private string ShipmentHandoffStatusLabel => InventoryGradeOutboundLineCount == 0
        ? "No shipment hand-off"
        : IncompleteInventoryHandoffLineCount > 0
            ? "Hand-off still incomplete"
            : "Ready for shipment";
    private string ShipmentHandoffStatusSummary => InventoryGradeOutboundLineCount == 0
        ? "This invoice is not yet carrying any outbound inventory-grade hand-off lines, so shipment-first bridging has not started."
        : IncompleteInventoryHandoffLineCount > 0
            ? "At least one invoice line started the outbound hand-off set, but shipment-first truth still needs item, warehouse, and stock UOM to be complete."
            : "Outbound inventory-grade invoice lines are ready to be handed into the independent Sales Issue workspace without treating invoice truth as physical shipment truth.";
    private string ShipmentHandoffNextStepTitle => InventoryGradeOutboundLineCount == 0
        ? "Stay in invoice-only draft lane"
        : IncompleteInventoryHandoffLineCount > 0
            ? "Finish outbound hand-off"
            : "Confirm Sales Issue truth";
    private string ShipmentHandoffNextStepDetail => InventoryGradeOutboundLineCount == 0
        ? "Keep using invoice draft truth only until this document really needs inventory-linked outbound intent."
        : IncompleteInventoryHandoffLineCount > 0
            ? "Finish item, warehouse, and UOM first. Shipment and Sales Issue remain the authoritative physical truth once bridging begins."
            : "Open Shipment workspace next. Shipment owns fulfillment truth first, and Sales Issue stays the downstream inventory and cost truth.";
    private bool InvoiceShipmentAllowsPost =>
        _invoiceShipmentLaneSummary is null || AllowsInvoicePost(_invoiceShipmentLaneSummary.ShipmentMatchStatus);
    private string InvoiceShipmentPostingGateLabel =>
        GetInvoiceShipmentPostingGateLabel(_invoiceShipmentLaneSummary);
    private string InvoiceShipmentPostingGateSummary =>
        GetInvoiceShipmentPostingGateSummary(_invoiceShipmentLaneSummary);
    private Severity InvoiceCoverageSeverity =>
        string.Equals(_invoiceShipmentLaneSummary?.InvoiceCoverageStatus, "fully_invoiced", StringComparison.OrdinalIgnoreCase)
            ? Severity.Success
            : string.Equals(_invoiceShipmentLaneSummary?.InvoiceCoverageStatus, "over_invoiced", StringComparison.OrdinalIgnoreCase)
                ? Severity.Warning
                : Severity.Info;
    private Severity InvoiceIssueFollowThroughSeverity =>
        string.Equals(_invoiceShipmentLaneSummary?.IssueMatchStatus, "fully_issued", StringComparison.OrdinalIgnoreCase)
            ? Severity.Success
            : Severity.Info;
    private string InvoicePostingPathLabel => _postedResult is not null ? "Ready for settlement" : IsPosted ? "Posted" : IsSubmitted ? "Submitted, awaiting post" : _saved is not null ? "Draft saved, awaiting submit" : "Draft -> Submit -> Post -> Receive Payment";
    private string InvoicePostingPathSummary => _postedResult is not null
        ? "The first invoice is posted, so the next legal AR step is to move into Receive Payment once receivables need settlement."
        : IsPosted
            ? "The document is already posted and can now participate in downstream AR settlement workflows."
            : IsSubmitted
                ? "The invoice is submitted and no longer editable in the draft workbench. Post it when AR truth is ready to become formal accounting truth."
            : _saved is not null
                ? "The draft is saved but not yet submitted. Submit it before posting so the invoice lifecycle moves through the controlled AR lane."
                : "The first invoice path is now: build the draft, submit it, post it, then continue into Receive Payment.";
    private string InvoiceCommercialStageLabel => _postedResult is not null
        ? "Invoice posted into AR truth"
        : IsPosted
            ? "Invoice already posted"
            : IsSubmitted
                ? "Submitted and awaiting post"
                : _saved is not null
                    ? "Draft invoice in progress"
                    : "Start invoice hand-off";
    private string InvoiceCommercialStageSummary => _postedResult is not null
        ? "Receivable and revenue truth already exist. The next operator step is settlement, not more drafting."
        : IsPosted
            ? "This invoice has already become formal AR truth and now belongs in downstream settlement and review."
            : IsSubmitted
                ? "The draft has left the editable lane. Post it when the AR truth is ready to become formal."
                : _saved is not null
                    ? "The invoice draft exists but AR truth has not started yet."
                    : "This lane converts demand truth into receivable truth once the invoice is posted.";
    private string InvoiceCommercialStageBadge => _postedResult?.Status ?? (_saved?.Status ?? "new");
    private Color InvoiceCommercialStageColor => _postedResult is not null || IsPosted
        ? Color.Success
        : IsSubmitted
            ? Color.Warning
            : _saved is not null
                ? Color.Info
                : Color.Default;
    private string InvoiceSourceLinkLabel => !string.IsNullOrWhiteSpace(_sourceSalesOrderDisplayNumber)
        ? _sourceSalesOrderDisplayNumber
        : !string.IsNullOrWhiteSpace(_sourceShipmentDisplayNumber)
            ? _sourceShipmentDisplayNumber
            : "Direct invoice";
    private string InvoiceSourceLinkSummary => !string.IsNullOrWhiteSpace(_sourceSalesOrderDisplayNumber)
        ? "The sales order remains demand truth while this invoice becomes AR truth."
        : !string.IsNullOrWhiteSpace(_sourceShipmentDisplayNumber)
            ? "Shipment remains fulfillment truth while this invoice becomes AR truth."
            : "This invoice was started directly without a quote/SO/shipment hand-off.";
    private string InvoiceSettlementLaneLabel => _postedResult is not null || IsPosted
        ? "Ready for receive payment"
        : "Settlement not open yet";
    private string InvoiceSettlementLaneSummary => _postedResult is not null || IsPosted
        ? "Once the receivable needs settlement, continue from Receive Payment so cash and application truth can take over."
        : "Receive Payment should stay closed until this invoice is formally posted.";

    protected override async Task OnParametersSetAsync()
    {
        if (!await EnsureLookupLoadedAsync())
        {
            return;
        }

        if (DraftId.HasValue && DraftId != _loadedDraftId)
        {
            await LoadDraftAsync(DraftId.Value);
        }
    }

    private void AddLine()
    {
        if (TryBlockDraftEdits())
        {
            return;
        }

        _lines.Add(SalesLine.Blank(_lines.Count + 1));
    }

    private void ApplyDefaultSetupTaxToDraft()
    {
        if (TryBlockDraftEdits())
        {
            return;
        }

        if (DefaultSalesTaxCode is null)
        {
            return;
        }

        foreach (var line in _lines.Where(static line => string.IsNullOrWhiteSpace(line.TaxCodeIdText)))
        {
            ApplyTaxCode(line, DefaultSalesTaxCode);
        }
    }

    private void RemoveLine(SalesLine line)
    {
        if (TryBlockDraftEdits())
        {
            return;
        }

        _lines.Remove(line);
        for (var i = 0; i < _lines.Count; i++) _lines[i].LineNumber = i + 1;
    }

    private void ApplyRate(SalesLine line)
    {
        if (TryBlockDraftEdits())
        {
            return;
        }

        var taxCode = _taxCodes.FirstOrDefault(x => x.Id.ToString("D") == line.TaxCodeIdText) ?? DefaultSalesTaxCode;
        if (taxCode is null)
        {
            return;
        }

        ApplyTaxCode(line, taxCode);
    }

    private static void ApplyTaxCode(SalesLine line, ShellTaxCodeLookupOption taxCode)
    {
        line.TaxCodeIdText = taxCode.Id.ToString("D");
        line.TaxAmount = Math.Round(line.LineAmount * taxCode.RatePercent / 100m, 2, MidpointRounding.AwayFromZero);
    }

    private string? GetSalesTaxEditorHint(SalesLine line) =>
        DefaultSalesTaxCode is null || !string.IsNullOrWhiteSpace(line.TaxCodeIdText)
            ? null
            : $"Setup default {DefaultSalesTaxCode.DefaultSummaryLabel} is ready. Use Rate or Default Tax From Setup if this line should be taxable.";

    private async Task SaveAsync()
    {
        if (TryBlockDraftEdits())
        {
            return;
        }

        _error = null;
        if (!Guid.TryParse(_customerIdText, out var customerId)) { _error = "Customer must be selected."; return; }
        if (!TryBuildLines(out var lines)) return;

        try
        {
            _saving = true;
            var saveResult = await Drafts.SaveInvoiceDraftAsync(_documentId, new ShellSalesSourceDocumentDraftSaveRequest
            {
                CompanyId = ShellSession.ActiveCompanyId,
                UserId = ShellSession.CurrentUserId,
                CustomerId = customerId,
                DocumentDate = _documentDate,
                DueDate = _dueDate,
                TransactionCurrencyCode = _txCurrency.Trim().ToUpperInvariant(),
                BaseCurrencyCode = _baseCurrency,
                FxSnapshotId = _fxSnapshotId,
                FxRate = IsIdentityFx ? null : _fxRate,
                FxEffectiveDate = IsIdentityFx ? null : _documentDate,
                FxSource = IsIdentityFx ? null : "shell_manual",
                Memo = _memo,
                Lines = lines
            }, CancellationToken.None);
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(saveResult, CancellationToken.None))
            {
                return;
            }

            if (saveResult.Value is null)
            {
                _error = saveResult.ErrorMessage ?? "Unable to save the invoice draft.";
                return;
            }

            _saved = saveResult.Value;
            _documentId = _saved.DocumentId;
            _postedResult = null;
            await LoadShipmentHandoffSummaryAsync();
            await TryRecordSalesOrderInvoiceAnchorAsync(_saved.Status);
            Snackbar.Add($"Invoice draft {_saved.DisplayNumber} saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SubmitAsync()
    {
        if (TryBlockWrites())
        {
            return;
        }

        _error = null;
        if (!_documentId.HasValue)
        {
            _error = "Save the draft before submitting it.";
            return;
        }

        if (!IsDraft)
        {
            _error = "Only draft invoices can be submitted.";
            return;
        }

        try
        {
            _submitting = true;
            var submitResult = await Drafts.SubmitInvoiceDraftAsync(
                ShellSession.ActiveCompanyId,
                ShellSession.CurrentUserId,
                _documentId.Value,
                CancellationToken.None);
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(submitResult, CancellationToken.None))
            {
                return;
            }

            if (submitResult.Value is null)
            {
                _error = submitResult.ErrorMessage ?? "Unable to submit the invoice draft.";
                return;
            }

            _saved = submitResult.Value;
            _postedResult = null;
            await LoadShipmentHandoffSummaryAsync();
            await TryRecordSalesOrderInvoiceAnchorAsync(_saved.Status);
            Snackbar.Add($"Invoice {_saved.DisplayNumber} submitted.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _submitting = false;
        }
    }

    private async Task PostAsync()
    {
        if (TryBlockWrites())
        {
            return;
        }

        _error = null;
        if (!_documentId.HasValue)
        {
            _error = "Save the draft before posting.";
            return;
        }

        if (!IsSubmitted)
        {
            _error = "Submit the invoice before posting.";
            return;
        }

        try
        {
            _posting = true;
            var postResult = await Drafts.PostInvoiceAsync(
                ShellSession.ActiveCompanyId,
                ShellSession.CurrentUserId,
                _documentId.Value,
                _fxSnapshotId,
                CancellationToken.None);
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(postResult, CancellationToken.None))
            {
                return;
            }

            if (postResult.Value is null)
            {
                _error = WebShellPostingFeedback.DescribeFailure(
                    postResult.ErrorCode,
                    postResult.ErrorMessage,
                    "Unable to post the invoice draft.");
                return;
            }

            _postedResult = postResult.Value;
            if (_saved is not null)
            {
                _saved = _saved with { Status = _postedResult.Status };
            }
            await LoadShipmentHandoffSummaryAsync();
            await TryRecordSalesOrderInvoiceAnchorAsync(_postedResult.Status);

            Snackbar.Add($"Invoice posted to journal entry {_postedResult.JournalEntryDisplayNumber}.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _posting = false;
        }
    }

    private bool TryBuildLines(out IReadOnlyList<ShellSalesSourceDocumentDraftLineSaveRequest> lines)
    {
        var built = new List<ShellSalesSourceDocumentDraftLineSaveRequest>();
        foreach (var line in _lines)
        {
            if (!Guid.TryParse(line.AccountIdText, out var accountId)) { _error = $"Revenue account missing on line {line.LineNumber}."; lines = []; return false; }
            if (string.IsNullOrWhiteSpace(line.Description)) { _error = $"Description missing on line {line.LineNumber}."; lines = []; return false; }
            if (line.Quantity <= 0m || line.UnitPrice <= 0m) { _error = $"Quantity and unit price must be positive on line {line.LineNumber}."; lines = []; return false; }
            if (line.TaxAmount > 0m && !Guid.TryParse(line.TaxCodeIdText, out _)) { _error = $"Tax code missing on line {line.LineNumber}."; lines = []; return false; }
            if (line.ItemId.HasValue && !IsInventorySalesIssueHandoffReady(line)) { _error = $"Shipment-first hand-off is incomplete on line {line.LineNumber}. Item, warehouse, and stock UOM must all be present once the line joins outbound inventory truth."; lines = []; return false; }
            built.Add(new ShellSalesSourceDocumentDraftLineSaveRequest
            {
                LineNumber = line.LineNumber,
                RevenueAccountId = accountId,
                Description = line.Description.Trim(),
                Quantity = line.Quantity,
                UnitPrice = line.UnitPrice,
                TaxCodeId = Guid.TryParse(line.TaxCodeIdText, out var taxCodeId) ? taxCodeId : null,
                TaxAmount = line.TaxAmount,
                ItemId = line.ItemId,
                WarehouseId = line.WarehouseId,
                UomCode = line.ItemId.HasValue ? string.IsNullOrWhiteSpace(line.UomCode) ? null : line.UomCode.Trim().ToUpperInvariant() : null
            });
        }

        if (built.Count == 0) { _error = "At least one line is required."; lines = []; return false; }
        if (!IsIdentityFx && (!_fxRate.HasValue || _fxRate <= 0m)) { _error = "Foreign-currency drafts require a positive FX rate."; lines = []; return false; }
        lines = built;
        return true;
    }

    private void OnDocumentDateChanged(DateTime? value)
    {
        _documentDatePicker = value;
        _documentDate = DateOnly.FromDateTime(value ?? DateTime.Today);
    }

    private void OnDueDateChanged(DateTime? value)
    {
        _dueDatePicker = value;
        _dueDate = DateOnly.FromDateTime(value ?? DateTime.Today);
    }

    private void OnCurrencyChanged(string? value)
    {
        if (DraftMutationBlocked)
        {
            return;
        }

        _txCurrency = string.IsNullOrWhiteSpace(value) ? _baseCurrency : value.Trim().ToUpperInvariant();
        if (IsIdentityFx)
        {
            _fxRate = null;
            _fxSnapshotId = null;
        }
    }

    private async Task<bool> EnsureLookupLoadedAsync()
    {
        if (_customerOptions.Count > 0 && _revenueAccounts.Count > 0 && _taxCodes.Count > 0)
        {
            return true;
        }

        if (!await EnsureWriteGateStateAsync())
        {
            return false;
        }

        _baseCurrency = ShellState.ActiveCompany.BaseCurrencyCode;
        _txCurrency = _baseCurrency;
        _customerOptions = await Customers.ListCustomersAsync(ShellSession.ActiveCompanyId, CancellationToken.None);
        _revenueAccounts = (await Accounts.ListManualPostingAccountsAsync(ShellSession.ActiveCompanyId, CancellationToken.None))
            .Where(static x => x.TypeLabel.Contains("Revenue", StringComparison.OrdinalIgnoreCase))
            .ToArray();
        _taxCodes = await TaxCodes.ListSalesTaxCodesAsync(ShellSession.ActiveCompanyId, CancellationToken.None);
        _salesProductServices = (await ProductServices.GetSummaryAsync(ShellSession.ActiveCompanyId, CancellationToken.None)).ActiveSalesItems;
        var onboardingResult = await OnboardingClient.GetAsync(CancellationToken.None);
        if (!onboardingResult.RequiresSignIn && !onboardingResult.IsNotFound && string.IsNullOrWhiteSpace(onboardingResult.ErrorMessage))
        {
            _onboardingSummary = onboardingResult.Value;
        }

        if (_onboardingSummary?.SupportsInventoryFoundation == true)
        {
            _inventoryShipmentDashboard = await InventoryShipment.GetDashboardAsync(ShellSession.ActiveCompanyId, CancellationToken.None);
        }
        if (CustomerId.HasValue &&
            _customerOptions.Any(item => item.Id == CustomerId.Value))
        {
            _customerIdText = CustomerId.Value.ToString("D");
        }
        if (_customerOptions.Count == 1 && string.IsNullOrWhiteSpace(_customerIdText))
        {
            _customerIdText = _customerOptions[0].Id.ToString("D");
        }

        if (!DraftId.HasValue &&
            ProductServiceId.HasValue &&
            ProductServiceId != _loadedProductServiceHintId &&
            _salesProductServices.Any(item => item.Id == ProductServiceId.Value))
        {
            ApplyProductService(_lines[0], ProductServiceId.Value.ToString("D"));
            _loadedProductServiceHintId = ProductServiceId.Value;
        }

        if (!DraftId.HasValue &&
            ShipmentId.HasValue &&
            ShipmentId != _loadedSourceShipmentId)
        {
            await LoadShipmentInvoiceHandoffAsync(ShipmentId.Value);
        }

        if (!DraftId.HasValue &&
            SalesOrderId.HasValue &&
            SalesOrderId != _loadedSourceSalesOrderId)
        {
            await LoadSalesOrderInvoiceHandoffAsync(SalesOrderId.Value);
        }

        return true;
    }

    private async Task<bool> EnsureWriteGateStateAsync()
    {
        await ShellState.EnsureHydratedAsync();
        var probe = await SessionClient.ProbeContextAsync(CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe, CancellationToken.None))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(probe.ErrorMessage))
        {
            _error = probe.ErrorMessage;
        }

        return true;
    }

    private bool TryBlockWrites()
    {
        if (!WritesBlocked)
        {
            return false;
        }

        _error = ShellState.WriteBlockMessage;
        return true;
    }

    private bool TryBlockDraftEdits()
    {
        if (TryBlockWrites())
        {
            return true;
        }

        if (CanEditDraft)
        {
            return false;
        }

        _error = "This invoice is no longer editable in the draft workbench.";
        return true;
    }

    private async Task LoadDraftAsync(Guid documentId)
    {
        var draftResult = await Drafts.GetInvoiceDraftAsync(ShellSession.ActiveCompanyId, documentId, CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(draftResult, CancellationToken.None))
        {
            return;
        }

        var draft = draftResult.Value;
        if (draft is null)
        {
            _error = draftResult.IsNotFound
                ? "The invoice draft could not be found in the active company context."
                : draftResult.ErrorMessage ?? "Unable to load the invoice draft.";
            return;
        }

        _documentId = draft.Id;
        _loadedDraftId = draft.Id;
        _saved = new ShellSourceDocumentDraftSaveResult
        {
            DocumentId = draft.Id,
            EntityNumber = draft.EntityNumber,
            DisplayNumber = draft.DisplayNumber,
            Status = draft.Status
        };
        _customerIdText = draft.CustomerId.ToString("D");
        _documentDate = draft.DocumentDate;
        _dueDate = draft.DueDate;
        _documentDatePicker = draft.DocumentDate.ToDateTime(TimeOnly.MinValue);
        _dueDatePicker = draft.DueDate.ToDateTime(TimeOnly.MinValue);
        _txCurrency = draft.TransactionCurrencyCode;
        _baseCurrency = draft.BaseCurrencyCode;
        _fxSnapshotId = draft.FxSnapshotId;
        _fxRate = draft.FxRate;
        _memo = draft.Memo;
        _postedResult = null;
        await LoadShipmentHandoffSummaryAsync();
        _lines.Clear();
        _lines.AddRange(draft.Lines.Select(static line => new SalesLine
        {
            LineNumber = line.LineNumber,
            AccountIdText = line.RevenueAccountId.ToString("D"),
            Description = line.Description,
            Quantity = line.Quantity,
            UnitPrice = line.UnitPrice,
            TaxCodeIdText = line.TaxCodeId?.ToString("D") ?? string.Empty,
            TaxAmount = line.TaxAmount,
            ItemId = line.ItemId,
            WarehouseId = line.WarehouseId,
            UomCode = line.UomCode ?? string.Empty
        }));
        if (_lines.Count == 0)
        {
            _lines.Add(SalesLine.Blank(1));
        }
    }

    private async Task LoadShipmentHandoffSummaryAsync()
    {
        if (!_documentId.HasValue || !SupportsInventorySalesIssueHandoff)
        {
            _invoiceShipmentLaneSummary = null;
            return;
        }

        _invoiceShipmentLaneSummary = await InventoryShipment.GetInvoiceLaneSummaryAsync(
            ShellSession.ActiveCompanyId,
            _documentId.Value,
            CancellationToken.None);
    }

    private async Task LoadShipmentInvoiceHandoffAsync(Guid shipmentId)
    {
        if (_inventoryShipmentDashboard is null)
        {
            return;
        }

        var shipment = await InventoryShipment.GetAsync(ShellSession.ActiveCompanyId, shipmentId, CancellationToken.None);
        if (shipment is null)
        {
            _error = "The shipment hand-off could not be found in the active company context.";
            return;
        }

        _loadedSourceShipmentId = shipment.DocumentId;
        _sourceShipmentDisplayNumber = shipment.DocumentNumber;
        _customerIdText = shipment.CustomerId.ToString("D");
        _memo ??= $"Invoice coverage from shipment {shipment.DocumentNumber}";
        _lines.Clear();

        var defaultRevenueAccount = _revenueAccounts.Count == 1
            ? _revenueAccounts[0].AccountId.ToString("D")
            : string.Empty;
        var lineNumber = 1;
        foreach (var shipmentLine in shipment.Lines.OrderBy(static line => line.LineNo))
        {
            var item = _inventoryShipmentDashboard.ActiveItems.FirstOrDefault(candidate => candidate.Id == shipmentLine.ItemId);
            _lines.Add(new SalesLine
            {
                LineNumber = lineNumber++,
                AccountIdText = defaultRevenueAccount,
                Description = item is null
                    ? $"Shipment {shipment.DocumentNumber} line {shipmentLine.LineNo}"
                    : $"{item.ItemCode} - {item.Name}",
                Quantity = shipmentLine.Quantity,
                UnitPrice = 1m,
                ItemId = shipmentLine.ItemId,
                WarehouseId = shipmentLine.WarehouseId,
                UomCode = shipmentLine.UomCode
            });
        }

        if (_lines.Count == 0)
        {
            _lines.Add(SalesLine.Blank(1));
        }
    }

    private async Task LoadSalesOrderInvoiceHandoffAsync(Guid salesOrderId)
    {
        var salesOrder = await CommercialDocuments.GetAsync(ShellSession.ActiveCompanyId, salesOrderId, CancellationToken.None);
        if (salesOrder is null || salesOrder.DocumentType != "sales_order")
        {
            _error = "The sales order hand-off could not be found in the active company context.";
            return;
        }

        _loadedSourceSalesOrderId = salesOrder.Id;
        _sourceSalesOrderDisplayNumber = salesOrder.DisplayNumber;
        _customerIdText = salesOrder.CustomerId.ToString("D");
        _txCurrency = salesOrder.TransactionCurrencyCode;
        _memo ??= $"Invoice coverage from sales order {salesOrder.DisplayNumber}";
        _lines.Clear();

        var coverage = await CommercialDocuments.GetSalesOrderInvoiceCoverageAsync(
            ShellSession.ActiveCompanyId,
            salesOrder.Id,
            CancellationToken.None);
        var remainingByLine = coverage?.Lines.ToDictionary(static line => line.LineNumber);

        foreach (var sourceLine in salesOrder.Lines.OrderBy(static line => line.LineNumber))
        {
            var quantity = sourceLine.Quantity;
            if (remainingByLine is not null &&
                remainingByLine.TryGetValue(sourceLine.LineNumber, out var lineCoverage))
            {
                quantity = lineCoverage.RemainingToInvoiceQuantity;
            }

            if (coverage is not null && quantity <= 0m)
            {
                continue;
            }

            _lines.Add(new SalesLine
            {
                LineNumber = sourceLine.LineNumber,
                AccountIdText = sourceLine.RevenueAccountId?.ToString("D") ?? string.Empty,
                Description = sourceLine.Description,
                Quantity = quantity,
                UnitPrice = sourceLine.UnitPrice,
                ItemId = sourceLine.ItemId,
                WarehouseId = sourceLine.WarehouseId,
                UomCode = sourceLine.UomCode ?? string.Empty
            });
        }

        if (_lines.Count == 0)
        {
            _error = $"Sales order {salesOrder.DisplayNumber} is already fully invoiced.";
            _lines.Add(SalesLine.Blank(1));
        }
    }

    private async Task TryRecordSalesOrderInvoiceAnchorAsync(string? invoiceStatus)
    {
        if (!_loadedSourceSalesOrderId.HasValue || _saved is null)
        {
            return;
        }

        var lines = _lines
            .Where(static line => line.Quantity > 0m)
            .Select(static line => new ShellSalesCommercialInvoiceAnchorLineRequest
            {
                LineNumber = line.LineNumber,
                Description = line.Description,
                Quantity = line.Quantity,
                UnitPrice = line.UnitPrice,
                ItemId = line.ItemId,
                WarehouseId = line.WarehouseId,
                UomCode = line.UomCode
            })
            .ToArray();
        if (lines.Length == 0)
        {
            return;
        }

        try
        {
            await CommercialDocuments.RecordSalesOrderInvoiceAnchorAsync(
                ShellSession.ActiveCompanyId,
                _loadedSourceSalesOrderId.Value,
                new ShellSalesCommercialInvoiceAnchorRequest
                {
                    InvoiceDocumentId = _saved.DocumentId,
                    InvoiceDisplayNumber = _saved.DisplayNumber,
                    InvoiceStatus = string.IsNullOrWhiteSpace(invoiceStatus) ? _saved.Status : invoiceStatus,
                    DocumentDate = _documentDate,
                    TotalAmount = GrandTotal,
                    Lines = lines
                },
                CancellationToken.None);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Sales order invoice coverage was not updated: {ex.Message}", Severity.Warning);
        }
    }

    private static bool AllowsInvoicePost(string? matchStatus) =>
        string.Equals(matchStatus, "no_inventory_handoff", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(matchStatus, "fully_shipped", StringComparison.OrdinalIgnoreCase);

    private static string GetInvoiceShipmentPostingGateLabel(InventoryInvoiceShipmentIssueLaneSummary? summary) =>
        summary?.ShipmentMatchStatus switch
        {
            "no_shipment" => "Post on hold: no shipment yet",
            "partially_shipped" => "Post on hold: shipment still partial",
            "over_shipped" => "Post on hold: shipment mismatch",
            "fully_shipped" => "Post enabled",
            "no_inventory_handoff" => "Post enabled",
            _ => "Awaiting shipment review"
        };

    private static string GetInvoiceShipmentPostingGateSummary(InventoryInvoiceShipmentIssueLaneSummary? summary)
    {
        var remainingQuantity = summary?.RemainingToShipQuantity ?? 0m;
        return summary?.ShipmentMatchStatus switch
        {
            "no_shipment" => "Outbound inventory-grade invoice lines exist, but AR posting must wait until authoritative shipment truth is posted.",
            "partially_shipped" => $"AR posting stays on hold until the remaining {remainingQuantity:N2} outbound quantity is covered by authoritative shipment truth.",
            "over_shipped" => "AR posting stays on hold while anchored shipment truth exceeds the current invoice hand-off quantity. Review the outbound mismatch before formalizing AR truth.",
            "fully_shipped" => "Shipment truth fully covers the current invoice hand-off quantity, so the invoice can move into formal AR posting when you are ready.",
            "no_inventory_handoff" => "This invoice is not participating in shipment-first bridging, so AR posting remains controlled only by the draft lifecycle lane.",
            _ => "Shipment-first truth has not been loaded yet."
        };
    }

    private static string BuildInvoiceIssueFollowThroughSummary(InventoryInvoiceShipmentIssueLaneSummary summary) =>
        summary.IssueMatchStatus switch
        {
            "no_shipment" => "Shipment truth has not started yet, so there is no downstream issue follow-through to review.",
            "pending_issue" => "Shipment truth exists, but no downstream Sales Issue has been posted yet.",
            "partially_issued" => $"Shipment truth is ahead of cost truth by {summary.RemainingToIssueQuantity:N2}. Continue into Sales Issue to finish outbound inventory/cost coverage.",
            "fully_issued" => "Shipment and Sales Issue truth are aligned for the current invoice hand-off.",
            "over_issued" => "Downstream Sales Issue currently exceeds shipped quantity. Review the outbound mismatch before extending the lane further.",
            _ => "Downstream issue follow-through has not been evaluated yet."
        };

    private static string BuildInvoiceCoverageSummary(InventoryInvoiceShipmentIssueLaneSummary summary) =>
        summary.InvoiceCoverageStatus switch
        {
            "no_inventory_handoff" => "This invoice is not participating in outbound inventory-grade bridging, so there is no shipped/invoiced coverage lane to review yet.",
            "no_shipment" => "Shipment truth has not started yet, so no outbound quantity is formally invoiced against shipped fulfillment.",
            "not_invoiced" => $"Shipment truth exists, but {summary.RemainingToInvoiceQuantity:N2} shipped quantity still has no formal AR coverage.",
            "partially_invoiced" => $"{summary.RemainingToInvoiceQuantity:N2} shipped quantity is still waiting to become formal AR truth.",
            "fully_invoiced" => "Current shipped quantity is fully covered by posted AR truth.",
            "over_invoiced" => "Posted invoice truth currently exceeds shipped quantity and should move into discrepancy review.",
            _ => "Invoice coverage truth has not been evaluated yet."
        };

