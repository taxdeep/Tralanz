@page "/documents/bill/draft-editor"
@using AntDesign
@using Color = MudBlazor.Color
@using Citus.Modules.Inventory.Application.Contracts
@using Citus.Modules.UnitySearch.Blazor
@using Citus.Modules.UnitySearch.Domain.Shared
@using Modules.CompanyAccess.SessionContext
@using Modules.GL.JournalEntry
@using Web.Business.AP.SettlementLookup
@using Web.Shell.Services
@inject Web.Shell.State.WebShellState ShellState
@inject ICompanyAccessShellSession ShellSession
@inject Web.Shell.Services.WebShellBusinessSessionClient SessionClient
@inject Web.Shell.Services.WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject IApSettlementLookupService Vendors
@inject IJournalEntryAccountCatalog Accounts
@inject ShellTaxCodeLookupService TaxCodes
@inject ShellProductServiceCatalogClient ProductServices
@inject ShellSourceDocumentDraftClient Drafts
@inject ShellAccountingDocumentReviewClient ReviewClient
@inject WebShellCompanyOnboardingClient OnboardingClient
@inject ShellInventoryReceiptClient InventoryReceipt
@inject ShellBillReceiptMatchingClient BillReceiptMatching
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>@EntryPageTitle</PageTitle>

<div class="@EntryRootClass">
    <section class="source-entry__hero">
        <div class="source-entry__hero-copy">
            <a class="source-entry__back-link" href="/documents/source-browser">
                <i class="ti ti-arrow-left" aria-hidden="true"></i>
                Source documents
            </a>
            <div class="source-entry__eyebrow">
                <span>AP workspace</span>
                <span>@EntryBadge</span>
            </div>
            <h1>@EntryTitle</h1>
            <p>@EntrySubtitle</p>
        </div>
        <Card Class="source-entry__balance-card">
            <Statistic T="decimal" Title="@EntryAmountTitle" Value="@GrandTotal" Precision="2" />
            <span>@(_txCurrency.Length > 0 ? _txCurrency : "Currency pending")</span>
            <div class="source-entry__doc-number">@(_saved?.DisplayNumber ?? "Draft not saved")</div>
        </Card>
    </section>

    @if (IsCompanyReadyHandOff)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            Company-ready hand-off opened the bill workbench first so you can move straight into AP operations once the initial company, owner membership, and starter accounts are provisioned.
        </MudAlert>

        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Recommended next workspaces</MudText>
            <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/company/book-governance?origin=company-ready">
                    Review Book Governance
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" Href="/company/customer-vendor-setup?origin=company-ready">
                    Set Up Vendor Truth
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Tertiary" Href="/company/product-service-setup?origin=company-ready">
                    Set Up Product & Service Defaults
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Success" Href="/documents/invoice/draft-editor?origin=company-ready">
                    Start First Invoice
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" Href="/">
                    Open General Workspace
                </MudButton>
            </div>
        </MudPaper>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(14rem,1fr));gap:1rem;margin-bottom:1rem;">
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Vendor Truth</MudText>
                <MudText Typo="Typo.h6">@VendorTruthLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@VendorTruthSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Tax Truth</MudText>
                <MudText Typo="Typo.h6">@TaxTruthLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@TaxTruthSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Product / Service Truth</MudText>
                <MudText Typo="Typo.h6">@ProductServiceTruthLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@ProductServiceTruthSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Posting Path</MudText>
                <MudText Typo="Typo.h6">@BillPostingPathLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@BillPostingPathSummary</MudText>
            </MudPaper>
        </div>

        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <MudText Typo="Typo.subtitle2" Class="mb-2">First-company operator steps</MudText>
            <MudList T="string" Dense="true">
                <MudListItem Text="1">
                    <ChildContent><MudText Typo="Typo.body2">@GetFirstBillStepOne()</MudText></ChildContent>
                </MudListItem>
                <MudListItem Text="2">
                    <ChildContent><MudText Typo="Typo.body2">@GetFirstBillStepTwo()</MudText></ChildContent>
                </MudListItem>
                <MudListItem Text="3">
                    <ChildContent><MudText Typo="Typo.body2">@GetFirstBillStepThree()</MudText></ChildContent>
                </MudListItem>
            </MudList>
        </MudPaper>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Style="margin-bottom:1rem;">@_error</MudAlert>
    }

    @if (WritesBlocked)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">@ShellState.WriteBlockMessage</MudAlert>
    }
    else if (!CanEditDraft)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            @GetDraftWorkbenchLockMessage()
        </MudAlert>
    }

    @if (_purchaseOrder is not null)
    {
        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;border:1px solid rgba(119,210,160,.35);">
            <div style="display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;align-items:center;">
                <div>
                    <MudText Typo="Typo.caption">Purchase Order Anchor</MudText>
                    <MudText Typo="Typo.h6">@_purchaseOrder.DisplayNumber</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        @($"{_purchaseOrder.Status} | {_purchaseOrder.Lines.Count} ordered line(s) | vendor {_purchaseOrder.VendorId:D}")
                    </MudText>
                </div>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@($"/documents/purchase_order/{_purchaseOrder.Id:D}")">
                    Open PO
                </MudButton>
            </div>
        </MudPaper>
    }

    <section class="source-entry__form-card">
        <div class="source-entry__section-heading">
            <div>
                <span>1</span>
                <h2>@PartySectionTitle</h2>
            </div>
            <p>@PartySectionSummary</p>
        </div>
        <div class="source-entry__form-grid">
        <div class="source-entry__party-field">
            <MudText Typo="Typo.caption" Class="mb-1">@PartyLabel</MudText>
            <UnitySearchPicker CompanyId="@ShellSession.ActiveCompanyId"
                               UserId="@ShellState.CurrentUserId"
                               Context="@SearchScopeContext.BillVendorPicker"
                               SelectedId="@SelectedVendorId"
                               SelectedDisplayText="@SelectedVendorDisplayText"
                               CreateEntityLabel="@PartyCreateEntityLabel"
                               Placeholder="@PartySearchPlaceholder"
                               Disabled="@HeaderMutationBlocked"
                               OnOptionSelected="HandleVendorSelectedAsync"
                               OnCreateRequested="HandleCreateVendorRequestedAsync"
                               OnCleared="HandleVendorClearedAsync" />
            <div class="source-entry__field-hint">
                <i class="ti ti-sparkles" aria-hidden="true"></i>
                @PartyHelperText
            </div>
        </div>
        <MudDatePicker Label="@DocumentDateLabel" Variant="Variant.Outlined" Date="@_documentDatePicker" DateChanged="OnDocumentDateChanged" Disabled="@DraftMutationBlocked" />
        <MudDatePicker Label="@DueDateLabel" Variant="Variant.Outlined" Date="@_dueDatePicker" DateChanged="OnDueDateChanged" Disabled="@DraftMutationBlocked" />
        <MudTextField T="string" Label="Tx Currency" Variant="Variant.Outlined" Value="_txCurrency" ValueChanged="OnCurrencyChanged" Disabled="@(!ShellState.ActiveCompany.MultiCurrencyEnabled || DraftMutationBlocked)" />
        <MudTextField T="string" Label="Base Currency" Variant="Variant.Outlined" Value="_baseCurrency" Disabled="true" />
        <MudNumericField T="decimal?" Label="FX Rate" Variant="Variant.Outlined" @bind-Value="_fxRate" Disabled="@(IsIdentityFx || DraftMutationBlocked)" />
        <MudTextField T="string" Label="@MemoLabel" Variant="Variant.Outlined" @bind-Value="_memo" Disabled="@DraftMutationBlocked" />
        </div>
    </section>

    <MudPaper Class="pa-4 source-entry__section-card" Elevation="0" Style="margin-bottom:1rem;">
        <div style="display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;flex-wrap:wrap;">
            <div>
                <MudText Typo="Typo.subtitle2">AP Settlement Chain</MudText>
                <MudText Typo="Typo.h5">@ApSettlementLaneTitle</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@ApSettlementLaneSummary</MudText>
            </div>
            <MudChip T="string" Variant="Variant.Filled" Color="@ApSettlementLaneColor">@ApSettlementLaneBadge</MudChip>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));gap:1rem;margin-top:1rem;">
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Current lane</MudText>
                <MudText Typo="Typo.h6">@ApSettlementLaneCurrentStepTitle</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@ApSettlementLaneCurrentStepSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Next operator move</MudText>
                <MudText Typo="Typo.h6">@ApSettlementLaneNextStepTitle</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@ApSettlementLaneNextStepSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Procurement anchor</MudText>
                <MudText Typo="Typo.h6">@ApSettlementLaneAnchorTitle</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@ApSettlementLaneAnchorSummary</MudText>
            </MudPaper>
        </div>
        <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1rem;">
            <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="/documents/source-browser?sourceType=bill&counterpartyRole=vendor">
                Review Bill Pipeline
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@BuildPurchaseOrderBrowserLaneHref()">
                Review Purchase Orders
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" Href="@BuildPayBillLaneHref()">
                Continue to Pay Bill
            </MudButton>
        </div>
    </MudPaper>

    <MudPaper Class="pa-4 source-entry__section-card source-entry__lines-card" Elevation="0" Style="margin-bottom:1rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:.75rem;">
            <MudText Typo="Typo.h6">@LineSectionTitle</MudText>
            <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
                @if (DefaultPurchaseTaxCode is not null)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Disabled="@DraftMutationBlocked" OnClick="ApplyDefaultSetupTaxToDraft">
                        Default Tax From Setup
                    </MudButton>
                }
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Disabled="@DraftMutationBlocked" OnClick="AddLine">Add line</MudButton>
            </div>
        </div>
        @if (MissingDefaultPurchaseTaxLineCount > 0 && DefaultPurchaseTaxCode is not null)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:.75rem;">
                @MissingDefaultPurchaseTaxLineCount line(s) still show <strong>No tax</strong>. The setup default <strong>@DefaultPurchaseTaxCode.DefaultSummaryLabel</strong> is available if those lines should carry purchase tax and recoverability truth.
            </MudAlert>
        }
        <MudTable Items="_lines" Dense="true" Hover="true" Bordered="true">
            <HeaderContent>
                <MudTh>#</MudTh><MudTh>Product / Service</MudTh><MudTh>Expense</MudTh><MudTh>Description</MudTh><MudTh>Amount</MudTh><MudTh>Tax Code</MudTh><MudTh>Tax</MudTh><MudTh>Recoverable</MudTh><MudTh>Total</MudTh><MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.LineNumber</MudTd>
                <MudTd>
                    <MudSelect T="string"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Value="context.ProductServiceIdText"
                               Disabled="@DraftMutationBlocked"
                               ValueChanged="@(value => ApplyProductService(context, value))">
                        <MudSelectItem T="string" Value="@string.Empty">No product / service</MudSelectItem>
                        @foreach (var productService in _purchaseProductServices)
                        {
                            <MudSelectItem T="string" Value="@productService.Id.ToString("D")">@productService.DisplayLabel</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd>
                    <MudSelect T="string" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="context.AccountIdText" Disabled="@DraftMutationBlocked">
                        @foreach (var account in _expenseAccounts)
                        {
                            <MudSelectItem T="string" Value="@account.AccountId.ToString("D")">@account.DisplayText</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd><MudTextField T="string" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="context.Description" Disabled="@DraftMutationBlocked" /></MudTd>
                <MudTd><MudNumericField T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.01m" Immediate="true" @bind-Value="context.LineAmount" Disabled="@DraftMutationBlocked" /></MudTd>
                <MudTd>
                    <MudSelect T="string" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="context.TaxCodeIdText" Disabled="@DraftMutationBlocked">
                        <MudSelectItem T="string" Value="@string.Empty">No tax</MudSelectItem>
                        @foreach (var taxCode in _taxCodes)
                        {
                            <MudSelectItem T="string" Value="@taxCode.Id.ToString("D")">@taxCode.DisplayLabel</MudSelectItem>
                        }
                    </MudSelect>
                    @if (!string.IsNullOrWhiteSpace(GetPurchaseTaxEditorHint(context)))
                    {
                        <MudText Typo="Typo.caption" Style="display:block;margin-top:.25rem;color:#97a8b7;">
                            @GetPurchaseTaxEditorHint(context)
                        </MudText>
                    }
                </MudTd>
                <MudTd><MudNumericField T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0m" Immediate="true" @bind-Value="context.TaxAmount" Disabled="@DraftMutationBlocked" /></MudTd>
                <MudTd><MudCheckBox T="bool" @bind-Value="context.IsTaxRecoverable" Disabled="@DraftMutationBlocked" /></MudTd>
                <MudTd>@context.TotalAmount.ToString("N2")</MudTd>
                <MudTd>
                    <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Disabled="@DraftMutationBlocked" OnClick="@(() => ApplyRate(context))">Rate</MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Error" Disabled="@(_lines.Count == 1 || DraftMutationBlocked || context.IsPurchaseOrderAnchored)" OnClick="@(() => RemoveLine(context))">X</MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

    @if (SupportsInventoryReceiptHandoff)
    {
        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:.75rem;">
                <MudText Typo="Typo.h6">Inventory Receipt Hand-off</MudText>
            </div>
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:.75rem;">
                Fill these fields only when this bill line should later hand off into purchase receipt review. Bill still carries AP truth; receipt remains the authoritative inbound inventory truth.
            </MudAlert>
            @if (IncompleteInventoryHandoffLineCount > 0)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:.75rem;">
                    @IncompleteInventoryHandoffLineCount line(s) started inventory receipt hand-off but are still missing warehouse, UOM, quantity, or unit cost. Complete the hand-off set before saving or continuing into Receipt Draft.
                </MudAlert>
            }
            @if (_receiptHandoffSummary is not null)
            {
                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));gap:1rem;margin-bottom:.75rem;">
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">Receipt Match Status</MudText>
                        <MudText Typo="Typo.h6">@ReceiptHandoffStatusLabel</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@ReceiptHandoffStatusSummary</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">Bill Inbound Qty</MudText>
                        <MudText Typo="Typo.h6">@_receiptHandoffSummary.BillInboundQuantity.ToString("N2")</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@_receiptHandoffSummary.BillInboundLineCount inventory-grade line(s)</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">Receipt-covered Qty</MudText>
                        <MudText Typo="Typo.h6">@_receiptHandoffSummary.CoveredQuantity.ToString("N2")</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@_receiptHandoffSummary.ReceiptCount matched posted receipt(s)</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">Remaining Qty</MudText>
                        <MudText Typo="Typo.h6">@_receiptHandoffSummary.RemainingQuantity.ToString("N2")</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@ReceiptRemainingSummary</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">AP Posting Gate</MudText>
                        <MudText Typo="Typo.h6">@ReceiptPostHoldLabel</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@ReceiptPostHoldSummary</MudText>
                    </MudPaper>
                </div>
                <MudPaper Class="pa-3" Elevation="0" Style="margin-bottom:.75rem;background:rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.caption">Receipt Review Next Step</MudText>
                    <MudText Typo="Typo.h6">@ReceiptHandoffNextStepTitle</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@ReceiptHandoffNextStepDetail</MudText>
                    <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:.75rem;">
                        @if (CanOpenPurchaseReceiptFromBill())
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Success" Href="@BuildPurchaseReceiptHandoffHref()" Disabled="WritesBlocked">
                                Open Receipt Draft
                            </MudButton>
                        }
                        @if (_saved is not null)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Info" Href="@BuildPostedDetailHref()">
                                Review Bill Detail
                            </MudButton>
                        }
                    </div>
                </MudPaper>
                @if (_receiptHandoffSummary.RecentReceipts.Count > 0)
                {
                    <MudTable Items="_receiptHandoffSummary.RecentReceipts" Dense="true" Hover="true" Bordered="true" Style="margin-bottom:.75rem;">
                        <HeaderContent>
                            <MudTh>Receipt</MudTh>
                            <MudTh>Date</MudTh>
                            <MudTh>Matched Qty</MudTh>
                            <MudTh>Receipt Qty</MudTh>
                            <MudTh>Vendor Ref</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.DisplayNumber</MudTd>
                            <MudTd>@context.ReceiptDate.ToString("yyyy-MM-dd")</MudTd>
                            <MudTd>@context.MatchedQuantity.ToString("N2")</MudTd>
                            <MudTd>@context.ReceiptQuantity.ToString("N2")</MudTd>
                            <MudTd>@(context.VendorReference ?? "n/a")</MudTd>
                            <MudTd>@context.Status</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                @if (_receiptHandoffSummary.LineSummaries.Count > 0)
                {
                    <MudTable Items="_receiptHandoffSummary.LineSummaries" Dense="true" Hover="true" Bordered="true" Style="margin-bottom:.75rem;">
                        <HeaderContent>
                            <MudTh>Item</MudTh>
                            <MudTh>Warehouse</MudTh>
                            <MudTh>UOM</MudTh>
                            <MudTh>Bill Qty</MudTh>
                            <MudTh>Covered Qty</MudTh>
                            <MudTh>Remaining</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@($"{context.ItemCode} - {context.ItemName}")</MudTd>
                            <MudTd>@($"{context.WarehouseCode} - {context.WarehouseName}")</MudTd>
                            <MudTd>@context.UomCode</MudTd>
                            <MudTd>@context.BillQuantity.ToString("N2")</MudTd>
                            <MudTd>@context.CoveredQuantity.ToString("N2")</MudTd>
                            <MudTd>@context.RemainingQuantity.ToString("N2")</MudTd>
                            <MudTd>@FormatReceiptGroupMatchStatus(context.MatchStatus)</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                @if (_receiptHandoffSummary.Discrepancies.Count > 0)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:.75rem;">
                        @_receiptHandoffSummary.Discrepancies.Count open inbound discrepancy lane(s) still need receipt-first investigation.
                    </MudAlert>
                    <MudTable Items="_receiptHandoffSummary.Discrepancies" Dense="true" Hover="true" Bordered="true" Style="margin-bottom:.75rem;">
                        <HeaderContent>
                            <MudTh>Line</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh>Item</MudTh>
                            <MudTh>Warehouse</MudTh>
                            <MudTh>UOM</MudTh>
                            <MudTh>Remaining</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.BillLineNumber</MudTd>
                            <MudTd>@FormatReceiptDiscrepancyType(context.DiscrepancyType)</MudTd>
                            <MudTd>@($"{context.ItemCode} - {context.ItemName}")</MudTd>
                            <MudTd>@($"{context.WarehouseCode} - {context.WarehouseName}")</MudTd>
                            <MudTd>@context.UomCode</MudTd>
                            <MudTd>@context.RemainingQuantity.ToString("N2")</MudTd>
                            <MudTd>@FormatReceiptInvestigationStatus(context.InvestigationStatus)</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            }
            <MudTable Items="_lines" Dense="true" Hover="true" Bordered="true">
                <HeaderContent>
                    <MudTh>#</MudTh><MudTh>Item</MudTh><MudTh>Warehouse</MudTh><MudTh>UOM</MudTh><MudTh>Qty</MudTh><MudTh>Unit Cost</MudTh><MudTh>PO Anchor</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.LineNumber</MudTd>
                    <MudTd>
                        <MudSelect T="Guid?" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(DraftMutationBlocked || context.IsPurchaseOrderAnchored)" Value="context.ItemId" ValueChanged="@(value => ApplyInventoryItem(context, value))">
                            <MudSelectItem T="Guid?" Value="@((Guid?)null)">No inventory receipt hand-off</MudSelectItem>
                            @foreach (var item in InventoryOperationalItems)
                            {
                                <MudSelectItem T="Guid?" Value="@item.Id">@item.ItemCode - @item.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudTd>
                    <MudTd>
                        <MudSelect T="Guid?" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(DraftMutationBlocked || context.ItemId is null)" @bind-Value="context.WarehouseId">
                            @foreach (var warehouse in InventoryWarehouses)
                            {
                                <MudSelectItem T="Guid?" Value="@warehouse.Id">@warehouse.WarehouseCode - @warehouse.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudTd>
                    <MudTd>
                        <MudTextField T="string" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(DraftMutationBlocked || context.ItemId is null || context.IsPurchaseOrderAnchored)" @bind-Value="context.UomCode" />
                    </MudTd>
                    <MudTd>
                        <MudNumericField T="decimal?" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(DraftMutationBlocked || context.ItemId is null)" @bind-Value="context.Quantity" />
                    </MudTd>
                    <MudTd>
                        <MudNumericField T="decimal?" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(DraftMutationBlocked || context.ItemId is null)" @bind-Value="context.UnitCost" />
                    </MudTd>
                    <MudTd>@FormatPurchaseOrderAnchor(context)</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }

    <div class="source-entry__totals-grid">
        <MudPaper Class="pa-4 source-entry__metric-card" Elevation="0"><MudText Typo="Typo.caption">Subtotal</MudText><MudText Typo="Typo.h6">@Subtotal.ToString("N2")</MudText></MudPaper>
        <MudPaper Class="pa-4 source-entry__metric-card" Elevation="0"><MudText Typo="Typo.caption">Tax</MudText><MudText Typo="Typo.h6">@TaxTotal.ToString("N2")</MudText></MudPaper>
        <MudPaper Class="pa-4 source-entry__metric-card source-entry__metric-card--total" Elevation="0"><MudText Typo="Typo.caption">Total</MudText><MudText Typo="Typo.h6">@GrandTotal.ToString("N2")</MudText></MudPaper>
    </div>

    <div class="source-entry__action-bar">
        <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(_saving || _submitting || _posting || !CanEditDraft || WritesBlocked)" OnClick="SaveAsync">Save Draft</MudButton>
        @if (_saved is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@($"/documents/bill/{_saved.DocumentId:D}")">Open Detail</MudButton>
            @if (IsDraft)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Warning" Disabled="@(_submitting || _saving || _posting || WritesBlocked)" OnClick="SubmitAsync">Submit Draft</MudButton>
            }
            @if (CanPost)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Info" Disabled="@(_posting || _saving || WritesBlocked)" OnClick="PostAsync">Post Draft</MudButton>
            }
            @if (IsSubmitted)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Default" Disabled="@(_submitting || _saving || _posting || WritesBlocked)" OnClick="CancelSubmittedAsync">
                    Cancel Submission
                </MudButton>
            }
        }
    </div>

    @if (_saved is not null)
    {
        <MudPaper Class="pa-4" Elevation="0" Style="margin-top:1rem;">
            <MudText Typo="Typo.h6">Saved Draft</MudText>
            <MudText Typo="Typo.body2">Document Id: @_saved.DocumentId</MudText>
            <MudText Typo="Typo.body2">Display Number: @_saved.DisplayNumber</MudText>
            <MudText Typo="Typo.body2">Entity Number: @_saved.EntityNumber</MudText>
            <MudText Typo="Typo.body2">Status: @_saved.Status</MudText>
        </MudPaper>
    }

    @if (_postedResult is not null && _saved is not null)
    {
        <MudPaper Class="pa-4" Elevation="0" Style="margin-top:1rem;">
            <MudText Typo="Typo.h6">Posted Review Continuity</MudText>
            <MudText Typo="Typo.body2">Journal Entry: @_postedResult.JournalEntryDisplayNumber</MudText>
            <MudText Typo="Typo.body2">Posted At: @_postedResult.PostedAt.ToString("yyyy-MM-dd HH:mm 'UTC'")</MudText>
            <MudText Typo="Typo.body2">Status: @_postedResult.Status</MudText>
            @if (_postedResult.Warnings.Count > 0)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-top:1rem;">
                    @string.Join(" | ", _postedResult.Warnings)
                </MudAlert>
            }

            @if (IsCompanyReadyHandOff)
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true" Style="margin-top:1rem;">
                    The first bill is now posted. Continue into Pay Bill when you are ready to settle the first payable, or move back to the customer-side flow if AR goes next.
                </MudAlert>
            }

            <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1rem;">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@BuildPostedDetailHref()">
                    Open Posted Document
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@($"/gl/journal-entry/review/{_postedResult.JournalEntryId:D}")">Open Journal Entry Review</MudButton>
                @if (IsCompanyReadyHandOff)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" Href="@BuildFirstVendorPaymentHref()">
                        Continue to First Vendor Payment
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Success" Href="/documents/invoice/draft-editor?origin=company-ready">
                        Start First Invoice
                    </MudButton>
                }
            </div>
        </MudPaper>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "draftId")]
    public Guid? DraftId { get; set; }

    [SupplyParameterFromQuery(Name = "origin")]
    public string? Origin { get; set; }

    [SupplyParameterFromQuery(Name = "vendorId")]
    public Guid? VendorId { get; set; }

    [SupplyParameterFromQuery(Name = "purchaseOrderId")]
    public Guid? PurchaseOrderId { get; set; }

    [SupplyParameterFromQuery(Name = "productServiceId")]
    public Guid? ProductServiceId { get; set; }

    private readonly List<PurchaseLine> _lines = [PurchaseLine.Blank(1)];
    private IReadOnlyList<(Guid Id, string DisplayLabel, string CurrencyCode)> _vendorOptions = Array.Empty<(Guid Id, string DisplayLabel, string CurrencyCode)>();
    private IReadOnlyList<JournalEntryAccountOption> _expenseAccounts = Array.Empty<JournalEntryAccountOption>();
    private IReadOnlyList<ShellTaxCodeLookupOption> _taxCodes = Array.Empty<ShellTaxCodeLookupOption>();
    private IReadOnlyList<ShellManagedProductServiceSummary> _purchaseProductServices = Array.Empty<ShellManagedProductServiceSummary>();
    private WebShellCompanyOnboardingSummary? _onboardingSummary;
    private InventoryPurchaseReceiptDashboard? _inventoryReceiptDashboard;
    private ShellBillReceiptMatchingSummary? _receiptHandoffSummary;
    private ShellPurchaseOrderReviewSummary? _purchaseOrder;
    private Guid? _documentId;
    private ShellSourceDocumentDraftSaveResult? _saved;
    private string? _vendorIdText;
    private string _txCurrency = string.Empty;
    private string _baseCurrency = string.Empty;
    private Guid? _fxSnapshotId;
    private decimal? _fxRate;
    private string? _memo;
    private string? _error;
    private bool _saving;
    private bool _submitting;
    private bool _posting;
    private ShellSourceDocumentPostResult? _postedResult;
    private DateOnly _documentDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly _dueDate = DateOnly.FromDateTime(DateTime.Today.AddDays(30));
    private DateTime? _documentDatePicker = DateTime.Today;
    private DateTime? _dueDatePicker = DateTime.Today.AddDays(30);
    private Guid? _loadedDraftId;
    private Guid? _loadedProductServiceHintId;
    private Guid? _loadedPurchaseOrderId;

    private decimal Subtotal => _lines.Sum(static x => x.LineAmount);
    private decimal TaxTotal => _lines.Sum(static x => x.TaxAmount);
    private decimal GrandTotal => Subtotal + TaxTotal;
    private bool IsIdentityFx => string.Equals(_txCurrency, _baseCurrency, StringComparison.OrdinalIgnoreCase);
    private bool IsDraft => string.Equals(_saved?.Status, "draft", StringComparison.OrdinalIgnoreCase);
    private bool IsSubmitted => string.Equals(_saved?.Status, "submitted", StringComparison.OrdinalIgnoreCase);
    private bool IsPosted => string.Equals(_saved?.Status, "posted", StringComparison.OrdinalIgnoreCase);
    private bool IsCancelled => string.Equals(_saved?.Status, "cancelled", StringComparison.OrdinalIgnoreCase);
    private bool CanEditDraft => _saved is null || IsDraft;
    private bool CanPost => IsSubmitted && _documentId.HasValue && ReceiptHandoffAllowsBillPost;
    private bool DraftMutationBlocked => WritesBlocked || !CanEditDraft;
    private bool HeaderMutationBlocked => DraftMutationBlocked || _purchaseOrder is not null || _lines.Any(static line => line.IsPurchaseOrderAnchored);
    private bool IsCompanyReadyHandOff => string.Equals(Origin, "company-ready", StringComparison.OrdinalIgnoreCase);
    private bool IsExpenseOrigin => string.Equals(Origin, "expense", StringComparison.OrdinalIgnoreCase);
    private string EntryRootClass => IsExpenseOrigin ? "source-entry source-entry--ap source-entry--expense" : "source-entry source-entry--ap source-entry--bill";
    private string EntryPageTitle => IsExpenseOrigin ? "New Expense" : "New Bill";
    private string EntryBadge => IsExpenseOrigin ? "Expense draft" : "Bill draft";
    private string EntryTitle => IsExpenseOrigin ? "New expense" : "New bill";
    private string EntrySubtitle => IsExpenseOrigin
        ? "Record direct spend with a clean AP boundary: payee match, payment account, category lines, tax, memo, and posting continuity stay in one disciplined surface."
        : "Convert vendor obligations into governed AP truth with vendor match, purchase lines, tax recoverability, receipt hand-off, and posting review kept separate from AR.";
    private string EntryAmountTitle => IsExpenseOrigin ? "Amount" : "Balance due";
    private string PartySectionTitle => IsExpenseOrigin ? "Payee and payment context" : "Vendor and terms";
    private string PartySectionSummary => IsExpenseOrigin
        ? "UnitySearch accepts typed payee text, dropdown selection, recommendation matching, and Add new vendor/payee when no match exists."
        : "UnitySearch accepts typed supplier text, dropdown selection, recommendation matching, and Add new vendor when no match exists.";
    private string PartyLabel => IsExpenseOrigin ? "Payee" : "Vendor";
    private string PartyCreateEntityLabel => IsExpenseOrigin ? "payee" : "vendor";
    private string PartySearchPlaceholder => IsExpenseOrigin ? "Search or type payee" : "Search vendor";
    private string PartyHelperText => IsExpenseOrigin
        ? "Auto-match payee truth, or create a governed AP payee inline."
        : "Auto-match vendor truth, or create a governed AP vendor inline.";
    private string DocumentDateLabel => IsExpenseOrigin ? "Payment Date" : "Bill Date";
    private string DueDateLabel => IsExpenseOrigin ? "Clearing Date" : "Due Date";
    private string MemoLabel => IsExpenseOrigin ? "Expense memo" : "Memo";
    private string LineSectionTitle => IsExpenseOrigin ? "Expense lines" : "Bill lines";
    private bool WritesBlocked => ShellState.AreWritesBlocked;
    private bool SupportsInventoryReceiptHandoff => _onboardingSummary?.SupportsInventoryFoundation == true && _inventoryReceiptDashboard is not null;
    private IReadOnlyList<InventoryManagedItemSummary> InventoryOperationalItems =>
        _inventoryReceiptDashboard?.ActiveItems.Where(static item => item.ManageInventoryMethod == Citus.Modules.Inventory.Domain.Shared.ManageInventoryMethod.ManageStock).ToList() ?? [];
    private IReadOnlyList<InventoryManagedWarehouseSummary> InventoryWarehouses => _inventoryReceiptDashboard?.ActiveWarehouses ?? [];
    private bool HasInventoryGradeInboundLines => _lines.Any(line => line.ItemId.HasValue);
    private bool HasReadyInventoryGradeInboundLines => _lines.Any(IsInventoryReceiptHandoffReady);
    private int IncompleteInventoryHandoffLineCount => _lines.Count(line => line.ItemId.HasValue && !IsInventoryReceiptHandoffReady(line));
    private ShellTaxCodeLookupOption? DefaultPurchaseTaxCode => _taxCodes.Count == 1 ? _taxCodes[0] : null;
    private int MissingDefaultPurchaseTaxLineCount => DefaultPurchaseTaxCode is null ? 0 : _lines.Count(line => string.IsNullOrWhiteSpace(line.TaxCodeIdText));
    private string VendorTruthLabel => _vendorOptions.Count > 0 ? $"{_vendorOptions.Count} vendor option(s)" : "Vendor truth missing";
    private string VendorTruthSummary => _vendorOptions.Count > 0
        ? "At least one vendor is available in backend truth, so the first bill can bind to a real payable counterparty."
        : "No vendor options are available in the current company context. First bill creation is blocked until vendor truth exists.";
    private string TaxTruthLabel => _taxCodes.Count > 0 ? $"{_taxCodes.Count} purchase tax code(s)" : "Tax can stay empty";
    private string TaxTruthSummary => DefaultPurchaseTaxCode is not null
        ? $"A single active purchase tax code ({DefaultPurchaseTaxCode.DefaultSummaryLabel}) is available, so blank bill lines can adopt the setup default and preserve recoverability truth without forcing a second choice."
        : _taxCodes.Count > 1
            ? "Purchase tax rules are available and recoverability semantics can flow directly into bill posting, but the operator still needs to choose the right tax code per taxable line."
            : "The first bill can still be entered tax-free. Configure Tax Setup later before taxable purchases begin.";
    private string ProductServiceTruthLabel => _purchaseProductServices.Count > 0 ? $"{_purchaseProductServices.Count} purchase-ready item(s)" : "Catalog still optional";
    private string ProductServiceTruthSummary => _purchaseProductServices.Count > 0
        ? "Product and service defaults can now carry description, expense account, and default purchase tax into the first bill lines."
        : "Bill lines can still be entered manually. Product and service setup becomes useful once you want reusable expense and tax defaults.";
    private string ReceiptHandoffStatusLabel => _receiptHandoffSummary?.MatchStatus switch
    {
        "no_inventory_handoff" => "No inventory hand-off",
        "no_receipt" => "No receipt yet",
        "partially_covered" => "Partially covered",
        "fully_covered" => "Fully covered",
        _ => "Awaiting receipt review"
    };
    private string ReceiptHandoffStatusSummary => _receiptHandoffSummary?.MatchStatus switch
    {
        "no_inventory_handoff" => "This bill has not defined any complete inventory-grade inbound lines yet, so receipt matching is not active.",
        "no_receipt" => "Inventory-grade bill lines exist, but no posted first-class receipt currently covers this bill hand-off.",
        "partially_covered" => "At least one posted receipt is matched, but some inbound quantity still remains uncovered.",
        "fully_covered" => "Posted first-class receipt truth now fully covers the current bill hand-off quantity.",
        _ => "Receipt-first matching truth has not been loaded yet."
    };
    private string ReceiptRemainingSummary => _receiptHandoffSummary is null
        ? "Awaiting inventory receipt review."
        : _receiptHandoffSummary.RemainingQuantity > 0m
            ? "Quantity is still outstanding on the receipt side."
            : _receiptHandoffSummary.RemainingQuantity == 0m
                ? "Current bill hand-off quantity is fully covered."
                : "Receipt truth currently exceeds the bill hand-off quantity.";
    private string ReceiptHandoffNextStepTitle => _receiptHandoffSummary?.MatchStatus switch
    {
        "no_inventory_handoff" => "Complete bill inbound truth",
        "no_receipt" => "Post the first receipt document",
        "partially_covered" => "Continue receipt matching review",
        "fully_covered" => "Bill hand-off is covered",
        _ => "Review receipt-first matching"
    };
    private string ReceiptHandoffNextStepDetail => _receiptHandoffSummary?.MatchStatus switch
    {
        "no_inventory_handoff" => "At least one bill line still needs the full item, warehouse, UOM, quantity, and unit-cost hand-off set before receipt matching can start.",
        "no_receipt" => "Inventory-grade inbound lines exist, but no posted first-class receipt has yet been matched against this bill anchor.",
        "partially_covered" => "Receipt truth is in progress. Keep reviewing remaining quantity before AP matching assumes the inbound side is complete.",
        "fully_covered" => "Receipt-first matching now fully covers the current bill hand-off quantity. Use bill detail or downstream AP review for the next step.",
        _ => "Receipt-first matching remains the authoritative review lane for this bill."
    };
    private bool ReceiptHandoffAllowsBillPost =>
        _receiptHandoffSummary is null ||
        string.Equals(_receiptHandoffSummary.MatchStatus, "no_inventory_handoff", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(_receiptHandoffSummary.MatchStatus, "fully_covered", StringComparison.OrdinalIgnoreCase);
    private string ReceiptPostHoldLabel => _receiptHandoffSummary?.MatchStatus switch
    {
        "no_receipt" => "Post on hold: no receipt yet",
        "partially_covered" => "Post on hold: receipt still partial",
        "fully_covered" => "Post enabled",
        "no_inventory_handoff" => "Post enabled",
        _ => "Awaiting receipt review"
    };
    private string ReceiptPostHoldSummary => _receiptHandoffSummary?.MatchStatus switch
    {
        "no_receipt" => "Inventory-grade inbound lines exist, but AP posting must wait until at least one authoritative purchase receipt is posted.",
        "partially_covered" => $"AP posting stays on hold until the remaining {_receiptHandoffSummary.RemainingQuantity:N2} inbound quantity is covered by posted receipt truth.",
        "fully_covered" => "Receipt-first matching fully covers the current bill hand-off quantity, so the bill can move into formal AP posting when you are ready.",
        "no_inventory_handoff" => "This bill is not participating in receipt-first matching, so AP posting remains controlled only by the draft lifecycle lane.",
        _ => "Receipt-first matching truth has not been loaded yet."
    };
    private string ApSettlementLaneTitle => "Bill pipeline";
    private string ApSettlementLaneSummary => "Bills convert procurement demand into governed AP truth. After posting, the operator should move into Pay Bill or vendor-credit application rather than return to procurement editing.";
    private MudBlazor.Color ApSettlementLaneColor => _postedResult is not null ? MudBlazor.Color.Success : IsSubmitted ? MudBlazor.Color.Warning : MudBlazor.Color.Info;
    private string ApSettlementLaneBadge => _postedResult is not null ? "Payable truth" : IsSubmitted ? "Awaiting post" : "Draft AP lane";
    private string ApSettlementLaneCurrentStepTitle => _postedResult is not null ? "Review posted payable anchor" : IsSubmitted ? "Review submitted bill" : "Shape payable truth";
    private string ApSettlementLaneCurrentStepSummary => _postedResult is not null
        ? "This bill is already posted and can now participate in JE review and payable settlement."
        : IsSubmitted
            ? "The draft has moved into the governed submission lane. Receipt and posting guards now decide the next move."
            : "Use the bill workbench to bind vendor, expense, tax, and PO anchor truth before the payable is formalized.";
    private string ApSettlementLaneNextStepTitle => _postedResult is not null ? "Move into Pay Bill" : CanPost ? "Post into AP truth" : IsSubmitted ? "Resolve posting blockers" : "Save, submit, then post";
    private string ApSettlementLaneNextStepSummary => _postedResult is not null
        ? "The next valid AP operator move is settlement. Continue into Pay Bill once the payable should be paid."
        : CanPost
            ? "The bill is ready to move from draft/submitted review into formal AP posting."
            : IsSubmitted
                ? BillPostingPathSummary
                : "The normal bill lane is draft, submit, post, then settle in Pay Bill.";
    private string ApSettlementLaneAnchorTitle => _purchaseOrder is not null ? $"PO {_purchaseOrder.DisplayNumber}" : "PO optional";
    private string ApSettlementLaneAnchorSummary => _purchaseOrder is not null
        ? "This bill is anchored to governed purchase-order truth, so procurement and payable review stay continuous."
        : "Bills can still be entered without a PO anchor, but the procurement-first lane is to convert released purchase-order truth into payable anchors.";
    private static string FormatReceiptGroupMatchStatus(string? matchStatus) => matchStatus switch
    {
        "no_receipt" => "No receipt yet",
        "partially_covered" => "Partial",
        "fully_covered" => "Full",
        _ => "Review"
    };
    private static string FormatReceiptDiscrepancyType(string? discrepancyType) => discrepancyType switch
    {
        "missing_receipt_coverage" => "Missing coverage",
        "partial_receipt_coverage" => "Partial coverage",
        _ => "Review"
    };
    private static string FormatReceiptInvestigationStatus(string? investigationStatus) => investigationStatus switch
    {
        "open" => "Open",
        _ => "Review"
    };
    private string BillPostingPathLabel => _postedResult is not null ? "Ready for settlement" : IsPosted ? "Posted" : IsCancelled ? "Cancelled" : IsSubmitted ? (ReceiptHandoffAllowsBillPost ? "Submitted, awaiting post" : "Submitted, held by receipt review") : _saved is not null ? "Draft saved, awaiting submit" : "Draft -> Submit -> Post -> Pay Bill";
    private string BillPostingPathSummary => _postedResult is not null
        ? "The first bill is posted, so the next legal AP step is to move into Pay Bill once the payable needs settlement."
        : IsPosted
            ? "The document is already posted and can now participate in downstream AP settlement workflows."
            : IsCancelled
                ? "This submitted bill has been cancelled out of the AP draft lane. It stays available for read-only review, but no longer participates in draft or post actions."
            : IsSubmitted
                ? ReceiptHandoffAllowsBillPost
                    ? "The bill is submitted and no longer editable in the draft workbench. Post it when the AP truth is ready to become formal accounting truth."
                    : ReceiptPostHoldSummary
                : _saved is not null
                    ? "The draft is saved but not yet submitted. Submit it before posting so the bill lifecycle can move through the controlled AP lane."
                    : "The first bill path is simple: build the draft, submit it, post it, then continue into Pay Bill.";

    protected override async Task OnParametersSetAsync()
    {
        if (!await EnsureLookupLoadedAsync())
        {
            return;
        }

        if (DraftId.HasValue && DraftId != _loadedDraftId)
        {
            await LoadDraftAsync(DraftId.Value);
            return;
        }

        if (!DraftId.HasValue &&
            PurchaseOrderId.HasValue &&
            PurchaseOrderId != _loadedPurchaseOrderId)
        {
            await LoadPurchaseOrderHandoffAsync(PurchaseOrderId.Value);
        }
    }

    private void AddLine()
    {
        if (TryBlockDraftEdits()) return;
        _lines.Add(PurchaseLine.Blank(_lines.Count + 1));
    }
    private void ApplyDefaultSetupTaxToDraft()
    {
        if (TryBlockDraftEdits()) return;
        if (DefaultPurchaseTaxCode is null) return;

        foreach (var line in _lines.Where(static line => string.IsNullOrWhiteSpace(line.TaxCodeIdText)))
        {
            ApplyTaxCode(line, DefaultPurchaseTaxCode);
        }
    }
    private void RemoveLine(PurchaseLine line)
    {
        if (TryBlockDraftEdits()) return;
        if (line.IsPurchaseOrderAnchored)
        {
            _error = "PO-anchored bill lines stay with their purchase order hand-off.";
            return;
        }

        _lines.Remove(line);
        for (var i = 0; i < _lines.Count; i++) _lines[i].LineNumber = i + 1;
    }
    private void ApplyRate(PurchaseLine line)
    {
        if (TryBlockDraftEdits()) return;
        var taxCode = _taxCodes.FirstOrDefault(x => x.Id.ToString("D") == line.TaxCodeIdText) ?? DefaultPurchaseTaxCode;
        if (taxCode is null) return;
        ApplyTaxCode(line, taxCode);
    }

    private static void ApplyTaxCode(PurchaseLine line, ShellTaxCodeLookupOption taxCode)
    {
        line.TaxCodeIdText = taxCode.Id.ToString("D");
        line.TaxAmount = Math.Round(line.LineAmount * taxCode.RatePercent / 100m, 2, MidpointRounding.AwayFromZero);
        line.IsTaxRecoverable = taxCode.IsRecoverableOnPurchase;
    }

    private string? GetPurchaseTaxEditorHint(PurchaseLine line) =>
        DefaultPurchaseTaxCode is null || !string.IsNullOrWhiteSpace(line.TaxCodeIdText)
            ? null
            : $"Setup default {DefaultPurchaseTaxCode.DefaultSummaryLabel} is ready. Use Rate or Default Tax From Setup if this line should carry purchase tax.";

    private async Task SaveAsync()
    {
        if (TryBlockDraftEdits()) return;
        _error = null;
        if (!Guid.TryParse(_vendorIdText, out var vendorId)) { _error = "Vendor must be selected."; return; }
        if (!TryBuildLines(out var lines)) return;
        try
        {
            _saving = true;
            var saveResult = await Drafts.SaveBillDraftAsync(_documentId, new ShellPurchaseSourceDocumentDraftSaveRequest
            {
                CompanyId = ShellSession.ActiveCompanyId,
                UserId = ShellSession.CurrentUserId,
                VendorId = vendorId,
                DocumentDate = _documentDate,
                DueDate = _dueDate,
                TransactionCurrencyCode = _txCurrency.Trim().ToUpperInvariant(),
                BaseCurrencyCode = _baseCurrency,
                FxSnapshotId = _fxSnapshotId,
                FxRate = IsIdentityFx ? null : _fxRate,
                FxEffectiveDate = IsIdentityFx ? null : _documentDate,
                FxSource = IsIdentityFx ? null : "shell_manual",
                Memo = _memo,
                Lines = lines
            }, CancellationToken.None);
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(saveResult, CancellationToken.None)) return;
            if (saveResult.Value is null) { _error = saveResult.ErrorMessage ?? "Unable to save the bill draft."; return; }
            _saved = saveResult.Value;
            _documentId = _saved.DocumentId;
            _postedResult = null;
            await LoadReceiptHandoffSummaryAsync();
            Snackbar.Add($"Bill draft {_saved.DisplayNumber} saved.", Severity.Success);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private async Task SubmitAsync()
    {
        if (TryBlockWrites()) return;
        _error = null;
        if (!_documentId.HasValue)
        {
            _error = "Save the draft before submitting it.";
            return;
        }

        if (!IsDraft)
        {
            _error = "Only draft bills can be submitted.";
            return;
        }

        try
        {
            _submitting = true;
            var submitResult = await Drafts.SubmitBillDraftAsync(
                ShellSession.ActiveCompanyId,
                ShellSession.CurrentUserId,
                _documentId.Value,
                CancellationToken.None);
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(submitResult, CancellationToken.None)) return;
            if (submitResult.Value is null) { _error = submitResult.ErrorMessage ?? "Unable to submit the bill draft."; return; }
            _saved = submitResult.Value;
            _postedResult = null;
            await LoadReceiptHandoffSummaryAsync();
            Snackbar.Add($"Bill {_saved.DisplayNumber} submitted.", Severity.Success);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _submitting = false; }
    }

    private async Task PostAsync()
    {
        if (TryBlockWrites()) return;
        _error = null;
        if (!_documentId.HasValue)
        {
            _error = "Save the draft before posting.";
            return;
        }

        if (!IsSubmitted)
        {
            _error = "Submit the bill before posting.";
            return;
        }

        if (!ReceiptHandoffAllowsBillPost)
        {
            _error = ReceiptPostHoldSummary;
            return;
        }

        try
        {
            _posting = true;
            var postResult = await Drafts.PostBillAsync(
                ShellSession.ActiveCompanyId,
                ShellSession.CurrentUserId,
                _documentId.Value,
                _fxSnapshotId,
                CancellationToken.None);
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(postResult, CancellationToken.None)) return;
            if (postResult.Value is null) { _error = WebShellPostingFeedback.DescribeFailure(postResult.ErrorCode, postResult.ErrorMessage, "Unable to post the bill draft."); return; }
            _postedResult = postResult.Value;
            if (_saved is not null)
            {
                _saved = _saved with { Status = _postedResult.Status };
            }

            await LoadReceiptHandoffSummaryAsync();
            Snackbar.Add($"Bill posted to journal entry {_postedResult.JournalEntryDisplayNumber}.", Severity.Success);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _posting = false; }
    }

    private async Task CancelSubmittedAsync()
    {
        if (TryBlockWrites()) return;
        _error = null;
        if (!_documentId.HasValue)
        {
            _error = "Save the draft before cancelling it.";
            return;
        }

        if (!IsSubmitted)
        {
            _error = "Only submitted bills can be cancelled.";
            return;
        }

        try
        {
            _submitting = true;
            var cancelResult = await Drafts.CancelSubmittedBillAsync(
                ShellSession.ActiveCompanyId,
                ShellSession.CurrentUserId,
                _documentId.Value,
                CancellationToken.None);
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(cancelResult, CancellationToken.None)) return;
            if (cancelResult.Value is null) { _error = cancelResult.ErrorMessage ?? "Unable to cancel the submitted bill."; return; }
            _saved = cancelResult.Value;
            _postedResult = null;
            await LoadReceiptHandoffSummaryAsync();
            Snackbar.Add($"Bill {_saved.DisplayNumber} cancelled.", Severity.Success);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _submitting = false; }
    }

    private bool TryBuildLines(out IReadOnlyList<ShellPurchaseSourceDocumentDraftLineSaveRequest> lines)
    {
        var built = new List<ShellPurchaseSourceDocumentDraftLineSaveRequest>();
        foreach (var line in _lines)
        {
            if (!Guid.TryParse(line.AccountIdText, out var accountId)) { _error = $"Expense account missing on line {line.LineNumber}."; lines = []; return false; }
            if (string.IsNullOrWhiteSpace(line.Description)) { _error = $"Description missing on line {line.LineNumber}."; lines = []; return false; }
            if (line.LineAmount <= 0m) { _error = $"Line amount must be positive on line {line.LineNumber}."; lines = []; return false; }
            if (line.TaxAmount > 0m && !Guid.TryParse(line.TaxCodeIdText, out _)) { _error = $"Tax code missing on line {line.LineNumber}."; lines = []; return false; }
            if (line.ItemId.HasValue && !IsInventoryReceiptHandoffReady(line))
            {
                _error = $"Inventory receipt hand-off is incomplete on line {line.LineNumber}. Warehouse, UOM, quantity, and unit cost must all be present once an item is selected.";
                lines = [];
                return false;
            }

            built.Add(new ShellPurchaseSourceDocumentDraftLineSaveRequest
            {
                LineNumber = line.LineNumber,
                ExpenseAccountId = accountId,
                Description = line.Description.Trim(),
                LineAmount = line.LineAmount,
                TaxCodeId = Guid.TryParse(line.TaxCodeIdText, out var taxCodeId) ? taxCodeId : null,
                TaxAmount = line.TaxAmount,
                IsTaxRecoverable = line.IsTaxRecoverable,
                ItemId = line.ItemId,
                WarehouseId = line.WarehouseId,
                UomCode = string.IsNullOrWhiteSpace(line.UomCode) ? null : line.UomCode.Trim().ToUpperInvariant(),
                Quantity = line.ItemId.HasValue ? line.Quantity : null,
                UnitCost = line.ItemId.HasValue ? line.UnitCost : null,
                PurchaseOrderId = line.PurchaseOrderId,
                PurchaseOrderLineNumber = line.PurchaseOrderLineNumber
            });
        }
        if (built.Count == 0) { _error = "At least one line is required."; lines = []; return false; }
        if (!IsIdentityFx && (!_fxRate.HasValue || _fxRate <= 0m)) { _error = "Foreign-currency drafts require a positive FX rate."; lines = []; return false; }
        lines = built; return true;
    }

    private void OnDocumentDateChanged(DateTime? value) { _documentDatePicker = value; _documentDate = DateOnly.FromDateTime(value ?? DateTime.Today); }
    private void OnDueDateChanged(DateTime? value) { _dueDatePicker = value; _dueDate = DateOnly.FromDateTime(value ?? DateTime.Today); }
    private void OnCurrencyChanged(string? value)
    {
        _txCurrency = string.IsNullOrWhiteSpace(value) ? _baseCurrency : value.Trim().ToUpperInvariant();
        if (IsIdentityFx)
        {
            _fxRate = null;
            _fxSnapshotId = null;
        }
    }

    private async Task<bool> EnsureLookupLoadedAsync()
    {
        if (_vendorOptions.Count > 0 && _expenseAccounts.Count > 0 && _taxCodes.Count > 0) return true;
        if (!await EnsureWriteGateStateAsync()) return false;
        _baseCurrency = ShellState.ActiveCompany.BaseCurrencyCode;
        _txCurrency = _baseCurrency;
        _vendorOptions = await Vendors.ListVendorsAsync(ShellSession.ActiveCompanyId, CancellationToken.None);
        _expenseAccounts = (await Accounts.ListManualPostingAccountsAsync(ShellSession.ActiveCompanyId, CancellationToken.None)).Where(static x => x.TypeLabel.Contains("Expense", StringComparison.OrdinalIgnoreCase)).ToArray();
        _taxCodes = await TaxCodes.ListPurchaseTaxCodesAsync(ShellSession.ActiveCompanyId, CancellationToken.None);
        _purchaseProductServices = (await ProductServices.GetSummaryAsync(ShellSession.ActiveCompanyId, CancellationToken.None)).ActivePurchaseItems;
        var onboardingResult = await OnboardingClient.GetAsync(CancellationToken.None);
        if (!onboardingResult.RequiresSignIn && !onboardingResult.IsNotFound && string.IsNullOrWhiteSpace(onboardingResult.ErrorMessage))
        {
            _onboardingSummary = onboardingResult.Value;
        }

        if (_onboardingSummary?.SupportsInventoryFoundation == true)
        {
            _inventoryReceiptDashboard = await InventoryReceipt.GetDashboardAsync(ShellSession.ActiveCompanyId, CancellationToken.None);
        }

        if (VendorId.HasValue &&
            _vendorOptions.Any(item => item.Id == VendorId.Value))
        {
            _vendorIdText = VendorId.Value.ToString("D");
        }
        if (_vendorOptions.Count == 1 && string.IsNullOrWhiteSpace(_vendorIdText)) _vendorIdText = _vendorOptions[0].Id.ToString("D");
        if (!DraftId.HasValue &&
            ProductServiceId.HasValue &&
            ProductServiceId != _loadedProductServiceHintId &&
            _purchaseProductServices.Any(item => item.Id == ProductServiceId.Value))
        {
            ApplyProductService(_lines[0], ProductServiceId.Value.ToString("D"));
            _loadedProductServiceHintId = ProductServiceId.Value;
        }
        return true;
    }

    private async Task<bool> EnsureWriteGateStateAsync()
    {
        await ShellState.EnsureHydratedAsync();
        var probe = await SessionClient.ProbeContextAsync(CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe, CancellationToken.None)) return false;
        if (!string.IsNullOrWhiteSpace(probe.ErrorMessage)) _error = probe.ErrorMessage;
        return true;
    }

    private bool TryBlockWrites()
    {
        if (!WritesBlocked) return false;
        _error = ShellState.WriteBlockMessage;
        return true;
    }

    private bool TryBlockDraftEdits()
    {
        if (TryBlockWrites()) return true;
        if (CanEditDraft) return false;
        _error = "This bill is no longer editable in the draft workbench.";
        return true;
    }

    private string GetDraftWorkbenchLockMessage() =>
        IsCancelled
            ? "This bill has been cancelled out of the submitted lane. It is now read-only in the draft workbench."
            : "This bill is no longer editable in the draft workbench. Submitted bills can still be posted, but draft-line mutations stop once the bill is submitted.";

    private async Task LoadDraftAsync(Guid documentId)
    {
        var draftResult = await Drafts.GetBillDraftAsync(ShellSession.ActiveCompanyId, documentId, CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(draftResult, CancellationToken.None)) return;
        var draft = draftResult.Value;
        if (draft is null) { _error = draftResult.IsNotFound ? "The bill draft could not be found in the active company context." : draftResult.ErrorMessage ?? "Unable to load the bill draft."; return; }
        _documentId = draft.Id;
        _loadedDraftId = draft.Id;
        _saved = new ShellSourceDocumentDraftSaveResult { DocumentId = draft.Id, EntityNumber = draft.EntityNumber, DisplayNumber = draft.DisplayNumber, Status = draft.Status };
        _vendorIdText = draft.VendorId.ToString("D");
        _documentDate = draft.DocumentDate;
        _dueDate = draft.DueDate;
        _documentDatePicker = draft.DocumentDate.ToDateTime(TimeOnly.MinValue);
        _dueDatePicker = draft.DueDate.ToDateTime(TimeOnly.MinValue);
        _txCurrency = draft.TransactionCurrencyCode;
        _baseCurrency = draft.BaseCurrencyCode;
        _fxSnapshotId = draft.FxSnapshotId;
        _fxRate = draft.FxRate;
        _memo = draft.Memo;
        _postedResult = null;
        _lines.Clear();
        _lines.AddRange(draft.Lines.Select(static line => new PurchaseLine
        {
            LineNumber = line.LineNumber,
            AccountIdText = line.ExpenseAccountId.ToString("D"),
            Description = line.Description,
            LineAmount = line.LineAmount,
            TaxCodeIdText = line.TaxCodeId?.ToString("D") ?? string.Empty,
            TaxAmount = line.TaxAmount,
            IsTaxRecoverable = line.IsTaxRecoverable,
            ItemId = line.ItemId,
            WarehouseId = line.WarehouseId,
            UomCode = line.UomCode ?? string.Empty,
            Quantity = line.Quantity,
            UnitCost = line.UnitCost,
            PurchaseOrderId = line.PurchaseOrderId,
            PurchaseOrderLineNumber = line.PurchaseOrderLineNumber
        }));
        if (_lines.Count == 0) _lines.Add(PurchaseLine.Blank(1));
        await LoadReceiptHandoffSummaryAsync();
    }

