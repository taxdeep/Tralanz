        _documentId.HasValue
            ? $"/documents/receipt/draft-editor?billId={_documentId.Value:D}&origin=bill-receipt-handoff"
            : "/documents/receipt/draft-editor";

    private async Task LoadPurchaseOrderHandoffAsync(Guid purchaseOrderId)
    {
        var result = await ReviewClient.GetPurchaseOrderAsync(ShellSession.ActiveCompanyId, purchaseOrderId, CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
        {
            return;
        }

        var purchaseOrder = result.Value;
        if (purchaseOrder is null)
        {
            _error = result.IsNotFound ? "The purchase order could not be found in the active company context." : result.ErrorMessage ?? "Unable to load the purchase order.";
            return;
        }

        if (!CanCreateBillFromPurchaseOrder(purchaseOrder))
        {
            _error = "Only issued purchase orders can start a governed bill draft.";
            return;
        }

        _purchaseOrder = purchaseOrder;
        _loadedPurchaseOrderId = purchaseOrder.Id;
        _vendorIdText = purchaseOrder.VendorId.ToString("D");
        _memo = string.IsNullOrWhiteSpace(purchaseOrder.Memo)
            ? $"Bill hand-off from {purchaseOrder.DisplayNumber}"
            : $"Bill hand-off from {purchaseOrder.DisplayNumber}: {purchaseOrder.Memo}";
        if (purchaseOrder.ExpectedDate.HasValue)
        {
            _dueDate = purchaseOrder.ExpectedDate.Value;
            _dueDatePicker = purchaseOrder.ExpectedDate.Value.ToDateTime(TimeOnly.MinValue);
        }

        _lines.Clear();
        foreach (var line in purchaseOrder.Lines.OrderBy(static line => line.LineNumber))
        {
            var remaining = purchaseOrder.ThreeQuantity?.Lines
                .FirstOrDefault(current => current.LineNumber == line.LineNumber)
                ?.RemainingToBillQuantity;
            var quantity = remaining.HasValue && remaining.Value > 0m
                ? remaining.Value
                : line.OrderedQuantity;
            if (quantity <= 0m)
            {
                continue;
            }

            var unitCost = line.UnitCost ?? 0m;
            _lines.Add(new PurchaseLine
            {
                LineNumber = _lines.Count + 1,
                AccountIdText = ResolveDefaultExpenseAccountIdText(),
                Description = string.IsNullOrWhiteSpace(line.Description)
                    ? $"PO line {line.LineNumber}"
                    : line.Description.Trim(),
                LineAmount = decimal.Round(quantity * unitCost, 2, MidpointRounding.AwayFromZero),
                TaxCodeIdText = string.Empty,
                TaxAmount = 0m,
                IsTaxRecoverable = false,
                ItemId = line.ItemId,
                WarehouseId = InventoryWarehouses.FirstOrDefault()?.Id,
                UomCode = line.UomCode,
                Quantity = quantity,
                UnitCost = unitCost,
                PurchaseOrderId = purchaseOrder.Id,
                PurchaseOrderLineNumber = line.LineNumber
            });
        }

        if (_lines.Count == 0)
        {
            _lines.Add(PurchaseLine.Blank(1));
            _error = "The selected purchase order has no remaining billable quantity.";
        }
    }

