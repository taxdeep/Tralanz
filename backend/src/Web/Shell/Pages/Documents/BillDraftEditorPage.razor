    private async Task LoadReceiptHandoffSummaryAsync()
    {
        if (!SupportsInventoryReceiptHandoff || !_documentId.HasValue)
        {
            _receiptHandoffSummary = null;
            return;
        }

        var result = await BillReceiptMatching.GetBillSummaryAsync(
            ShellSession.ActiveCompanyId,
            _documentId.Value,
            CancellationToken.None);

        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
        {
            _receiptHandoffSummary = null;
            return;
        }

        _receiptHandoffSummary = result.Value;
        if (!string.IsNullOrWhiteSpace(result.ErrorMessage))
        {
            _error = WebShellPostingFeedback.DescribeFailure(
                result.ErrorCode,
                result.ErrorMessage,
                "Unable to load receipt-first matching truth right now.");
        }
    }

    private void ApplyProductService(PurchaseLine line, string? productServiceIdText)
    {
        if (TryBlockDraftEdits()) return;

        line.ProductServiceIdText = productServiceIdText ?? string.Empty;

        var productService = _purchaseProductServices.FirstOrDefault(
            item => string.Equals(item.Id.ToString("D"), line.ProductServiceIdText, StringComparison.OrdinalIgnoreCase));
        if (productService is null) return;

        line.Description = productService.EffectiveLineDescription;
        if (productService.PurchaseExpenseAccountId.HasValue)
        {
            line.AccountIdText = productService.PurchaseExpenseAccountId.Value.ToString("D");
        }

        if (productService.DefaultPurchaseTaxCodeId.HasValue)
        {
            var taxCode = _taxCodes.FirstOrDefault(option => option.Id == productService.DefaultPurchaseTaxCodeId.Value);
            if (taxCode is not null)
            {
                ApplyTaxCode(line, taxCode);
            }
        }
    }

    private void ApplyInventoryItem(PurchaseLine line, Guid? itemId)
    {
        if (TryBlockDraftEdits()) return;

        line.ItemId = itemId;
        if (!itemId.HasValue)
        {
            line.WarehouseId = null;
            line.UomCode = string.Empty;
            line.Quantity = null;
            line.UnitCost = null;
            return;
        }

        var item = InventoryOperationalItems.FirstOrDefault(current => current.Id == itemId.Value);
        if (item is null)
        {
            return;
        }

        line.UomCode = item.StockUomCode ?? string.Empty;
        line.Quantity ??= 1m;
        line.UnitCost ??= decimal.Round(line.LineAmount, 2, MidpointRounding.AwayFromZero);
        line.WarehouseId ??= InventoryWarehouses.FirstOrDefault()?.Id;
    }

    private static bool IsInventoryReceiptHandoffReady(PurchaseLine line) =>
        line.ItemId.HasValue &&
        line.WarehouseId.HasValue &&
        !string.IsNullOrWhiteSpace(line.UomCode) &&
        line.Quantity.HasValue &&
        line.Quantity.Value > 0m &&
        line.UnitCost.HasValue &&
        line.UnitCost.Value >= 0m;

    private static string FormatPurchaseOrderAnchor(PurchaseLine line) =>
        line.PurchaseOrderId.HasValue && line.PurchaseOrderLineNumber.HasValue
            ? $"PO line {line.PurchaseOrderLineNumber.Value}"
            : "n/a";

    private string ResolveDefaultExpenseAccountIdText() =>
        _expenseAccounts.FirstOrDefault()?.AccountId.ToString("D") ?? string.Empty;

    private static Guid? ParseOptionalGuid(string? value) =>
        Guid.TryParse(value, out var parsed) ? parsed : null;

    private static bool CanCreateBillFromPurchaseOrder(ShellPurchaseOrderReviewSummary purchaseOrder) =>
        string.Equals(purchaseOrder.Status, "issued", StringComparison.OrdinalIgnoreCase);

    private sealed class PurchaseLine
    {
        public int LineNumber { get; set; }
        public string ProductServiceIdText { get; set; } = string.Empty;
        public string AccountIdText { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public decimal LineAmount { get; set; } = 1m;
        public string TaxCodeIdText { get; set; } = string.Empty;
        public decimal TaxAmount { get; set; }
        public bool IsTaxRecoverable { get; set; }
        public Guid? ItemId { get; set; }
        public Guid? WarehouseId { get; set; }
        public string UomCode { get; set; } = string.Empty;
        public decimal? Quantity { get; set; }
        public decimal? UnitCost { get; set; }
        public Guid? PurchaseOrderId { get; set; }
        public int? PurchaseOrderLineNumber { get; set; }
        public bool IsPurchaseOrderAnchored => PurchaseOrderId.HasValue && PurchaseOrderLineNumber.HasValue;
        public decimal TotalAmount => LineAmount + TaxAmount;
        public static PurchaseLine Blank(int lineNumber) => new() { LineNumber = lineNumber };
    }
