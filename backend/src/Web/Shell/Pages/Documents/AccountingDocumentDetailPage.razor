    private bool HasReverseControlSummary() =>
        CanRequestReverse(_document) ||
        _latestReverseRequest is not null ||
        _reverseApplyReadiness is not null ||
        _reverseExecutionPlan is not null ||
        _subledgerReverseBlockers.Count > 0 ||
        _settlementApplicationReversals.Count > 0;

    private ReverseNextLegalActionSummary GetNextLegalActionSummary()
    {
        if (_latestReverseRequest is null && CanRequestReverse(_document))
        {
            return _subledgerReverseBlockers.Count == 0
                ? new ReverseNextLegalActionSummary(
                    "Request governed reverse",
                    "No governed reverse request has been recorded yet. The next legal step is to record one from this source detail before execution orchestration can continue.")
                : new ReverseNextLegalActionSummary(
                    "Request governed reverse",
                    $"No governed reverse request has been recorded yet. You can record one now, but {_subledgerReverseBlockers.Count} active subledger blocker(s) still must clear before original reverse execution becomes legal.");
        }

        if (CanSubmitReverseRequest(_latestReverseRequest))
        {
            return new ReverseNextLegalActionSummary(
                "Submit original reverse request",
                "The source reverse request is still draft. Submit it first so backend governance can treat it as the active original reverse record.");
        }

        var requestableBlockers = _subledgerReverseBlockers.Count(CanRequestBlockerUnapply);
        if (requestableBlockers > 0)
        {
            return new ReverseNextLegalActionSummary(
                "Request governed unapply",
                $"{requestableBlockers} blocker(s) still need an initial governed unapply request. Start with the blocker panel before retrying the original reverse path.");
        }

        var submittableBlockers = _subledgerReverseBlockers.Count(CanSubmitBlockerUnapply);
        if (submittableBlockers > 0)
        {
            return new ReverseNextLegalActionSummary(
                "Submit governed unapply",
                $"{submittableBlockers} blocker request(s) are still draft. Submit them so the backend can advance the blocker-clearing path.");
        }

        var executableBlockers = _subledgerReverseBlockers.Count(CanExecuteBlockerUnapply);
        if (executableBlockers > 0)
        {
            return new ReverseNextLegalActionSummary(
                "Request governed blocker execution",
                $"{executableBlockers} blocker request(s) are submitted and legally ready for governed execution. Request execution from the blocker panel before returning to the original source reverse.");
        }

        var pendingBlockerExecutions = _subledgerReverseBlockers.Count(
            blocker => string.Equals(blocker.ReverseExecutionStatus, "execution_requested", StringComparison.OrdinalIgnoreCase));
        if (pendingBlockerExecutions > 0)
        {
            return new ReverseNextLegalActionSummary(
                "Await blocker execution",
                $"{pendingBlockerExecutions} blocker execution request(s) are already in flight. Wait for backend completion so the subledger gate can reopen for the original reverse.");
        }

        if (CanExecuteOriginalReverseAfterSubledgerGate())
        {
            return new ReverseNextLegalActionSummary(
                "Execute original governed reverse",
                _reverseExecutionPlan?.Reason ??
                _reverseApplyReadiness?.Reason ??
                "The original reverse request is submitted and the subledger gate is clear. The next legal step is governed execution from this source detail.");
        }

        if (_latestReverseRequest is not null &&
            string.Equals(_latestReverseRequest.ExecutionStatus, "execution_requested", StringComparison.OrdinalIgnoreCase))
        {
            return new ReverseNextLegalActionSummary(
                "Await original reverse execution",
                "The original reverse already has an execution request on file. Wait for backend completion rather than resubmitting from the shell.");
        }

        if (_latestReverseRequest is not null &&
            string.Equals(_latestReverseRequest.ExecutionStatus, "journal_entry_reversed", StringComparison.OrdinalIgnoreCase))
        {
            return new ReverseNextLegalActionSummary(
                "Reverse already completed",
                "Governed reverse execution has already completed. Use reversal history and source/open-item drill-down for audit follow-up instead of issuing a new command.");
        }

        if (_latestReverseRequest is not null &&
            string.Equals(_latestReverseRequest.RequestStatus, "cancelled", StringComparison.OrdinalIgnoreCase))
        {
            return new ReverseNextLegalActionSummary(
                "Record a fresh reverse request",
                "The latest reverse request was cancelled. If reversal is still needed, start again with a new governed reverse request.");
        }

        return new ReverseNextLegalActionSummary(
            "No further legal reverse action",
            _reverseExecutionPlan?.Reason ??
            _reverseApplyReadiness?.Reason ??
            "This source detail does not currently expose another backend-supported reverse action from the shell.");
    }

    private string GetReverseRequestSummaryTitle()
    {
        if (_latestReverseRequest is null)
        {
            return "No active workflow";
        }

        return $"{FormatReverseRequestStatus(_latestReverseRequest.RequestStatus)} | {FormatReverseExecutionStatus(_latestReverseRequest.ExecutionStatus)}";
    }

    private string GetReverseRequestSummaryDetail()
    {
        if (_latestReverseRequest is null)
        {
            return "No governed reverse request has been recorded for this source document yet.";
        }

        if (_reverseExecutionPlan is not null)
        {
            return _reverseExecutionPlan.Reason;
        }

        return _latestReverseRequest.Reason;
    }

    private string GetSubledgerGateSummaryTitle()
    {
        if (_subledgerReverseBlockers.Count == 0)
        {
            return "Settlement clear";
        }

        return $"{_subledgerReverseBlockers.Count} blocker(s)";
    }

    private string GetSubledgerGateSummaryDetail()
    {
        if (_subledgerReverseBlockers.Count == 0)
        {
            return "No active AR/AP settlement-application blockers are stopping governed reverse execution.";
        }

        var submittedCount = _subledgerReverseBlockers.Count(blocker => string.Equals(blocker.ReverseRequestStatus, "submitted", StringComparison.OrdinalIgnoreCase));
        var executionRequestedCount = _subledgerReverseBlockers.Count(blocker => string.Equals(blocker.ReverseExecutionStatus, "execution_requested", StringComparison.OrdinalIgnoreCase));
        return $"{submittedCount} blocker request(s) submitted and {executionRequestedCount} blocker execution(s) already requested. Clear these before retrying the original reverse.";
    }

    private string GetReversalHistorySummaryTitle() =>
        _settlementApplicationReversals.Count == 0
            ? "No governed unapply history"
            : $"{_settlementApplicationReversals.Count} governed row(s)";

    private string GetReversalHistorySummaryDetail()
    {
        if (_settlementApplicationReversals.Count == 0)
        {
            return "No governed settlement-application reversal rows have been recorded for this source document yet.";
        }

        var latest = _settlementApplicationReversals
            .OrderByDescending(item => item.ReversedAt)
            .First();
        return $"Latest governed unapply row was recorded at {latest.ReversedAt:yyyy-MM-dd HH:mm:ss zzz} for {FormatApplicationType(latest.ApplicationType)}.";
    }

