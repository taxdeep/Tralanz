    private static string GetSettlementFollowUpTitle(ShellAccountingDocumentReviewSummary document)
    {
        if (string.Equals(document.Status, "draft", StringComparison.OrdinalIgnoreCase))
        {
            return "Post before settlement";
        }

        if (string.Equals(document.JournalEntryStatus, "reversed", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(document.JournalEntryStatus, "voided", StringComparison.OrdinalIgnoreCase))
        {
            return "Historical only";
        }

        return document.SourceType.Trim().ToLowerInvariant() switch
        {
            "invoice" => "Review first receipt",
            "bill" => "Review first vendor payment",
            _ => "Review settlement"
        };
    }

    private static string GetSettlementFollowUpDetail(ShellAccountingDocumentReviewSummary document)
    {
        if (string.Equals(document.Status, "draft", StringComparison.OrdinalIgnoreCase))
        {
            return "Settlement workbenches only surface posted source documents. Save and post this draft before expecting any open item to appear downstream.";
        }

        if (string.Equals(document.JournalEntryStatus, "reversed", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(document.JournalEntryStatus, "voided", StringComparison.OrdinalIgnoreCase))
        {
            return "This source document is still visible for audit, but its accounting effect has already changed. If no settlement candidate appears downstream, that is expected.";
        }

        return document.SourceType.Trim().ToLowerInvariant() switch
        {
            "invoice" => "A posted invoice should flow into Receive Payment for the same customer. If no receivable candidate appears there, verify whether another receipt already consumed the open item.",
            "bill" => "A posted bill should flow into Pay Bill for the same vendor. If no payable candidate appears there, verify whether another vendor payment already consumed the open item.",
            _ => "Posted source truth should appear in the next legal settlement workbench when an open item still exists."
        };
    }

    private static string GetCounterpartyContinuityTitle(ShellAccountingDocumentReviewSummary document) =>
        document.CounterpartyId.HasValue && !string.IsNullOrWhiteSpace(document.CounterpartyLabel)
            ? $"{document.CounterpartyLabel} linked"
            : "Counterparty link missing";

    private static string GetCounterpartyContinuityDetail(ShellAccountingDocumentReviewSummary document)
    {
        if (!document.CounterpartyId.HasValue || string.IsNullOrWhiteSpace(document.CounterpartyLabel))
        {
            return "No concrete customer/vendor link is visible in this source summary, so the shell cannot carry a specific counterparty into the next settlement step.";
        }

        return $"This {document.CounterpartyLabel.Trim().ToLowerInvariant()} stays the governing counterparty for the next settlement review step, so the operator should continue with the same counterparty selected.";
    }

    private static bool TryBuildSettlementWorkbenchHref(
        ShellAccountingDocumentReviewSummary? document,
        out string href,
        out string label)
    {
        href = string.Empty;
        label = string.Empty;
        if (document is null || !document.CounterpartyId.HasValue)
        {
            return false;
        }

        if (string.Equals(document.Status, "draft", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(document.JournalEntryStatus, "reversed", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(document.JournalEntryStatus, "voided", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        switch (document.SourceType.Trim().ToLowerInvariant())
        {
            case "invoice":
                href = $"/ar/receive-payment?origin=company-ready&customerId={document.CounterpartyId.Value:D}";
                label = "Open First Receipt";
                return true;
            case "bill":
                href = $"/ap/pay-bill?origin=company-ready&vendorId={document.CounterpartyId.Value:D}";
                label = "Open First Vendor Payment";
                return true;
            default:
                return false;
        }
    }

    private string BuildBrowserNavigationHref(string href, string origin, string returnLabel)
    {
        var requestDetailHref = $"/documents/{SourceType}/{DocumentId:D}";
        return
            $"{href}&origin={Uri.EscapeDataString(origin)}" +
            $"&returnHref={Uri.EscapeDataString(requestDetailHref)}" +
            $"&returnLabel={Uri.EscapeDataString(returnLabel)}";
    }

    private static bool TryBuildDraftEditorHref(string? sourceType, string? status, Guid documentId, out string href)
    {
        href = string.Empty;
        if (!string.Equals(status, "draft", StringComparison.OrdinalIgnoreCase) &&
            !(sourceType?.Trim().ToLowerInvariant() is "bill" or "invoice" &&
              string.Equals(status, "submitted", StringComparison.OrdinalIgnoreCase)))
        {
            return false;
        }

        href = sourceType?.Trim().ToLowerInvariant() switch
        {
            "invoice" => $"/documents/invoice/draft-editor?draftId={documentId:D}",
            "credit_note" => $"/documents/credit-note/draft-editor?draftId={documentId:D}",
            "bill" => $"/documents/bill/draft-editor?draftId={documentId:D}",
            "vendor_credit" => $"/documents/vendor-credit/draft-editor?draftId={documentId:D}",
            _ => string.Empty
        };

        return !string.IsNullOrWhiteSpace(href);
    }

    private static bool CanOpenDraftWorkbench(ShellAccountingDocumentReviewSummary document) =>
        document.CanEditDraft ||
        ((string.Equals(document.SourceType, "bill", StringComparison.OrdinalIgnoreCase) ||
          string.Equals(document.SourceType, "invoice", StringComparison.OrdinalIgnoreCase)) &&
         string.Equals(document.Status, "submitted", StringComparison.OrdinalIgnoreCase));

    private static string GetDraftWorkbenchLabel(string? sourceType, string? status) =>
        string.Equals(status, "submitted", StringComparison.OrdinalIgnoreCase)
            ? sourceType?.Trim().ToLowerInvariant() switch
            {
                "bill" => "Open Bill Workbench",
                "invoice" => "Open Invoice Workbench",
                _ => "Open Workbench"
            }
            : "Edit Draft";

    private static bool TryBuildJournalEntryLifecycleNotice(
        ShellAccountingDocumentReviewSummary document,
        out string notice)
    {
        notice = string.Empty;

        if (document.JournalEntryId is null || string.IsNullOrWhiteSpace(document.JournalEntryStatus))
        {
            return false;
        }

        if (string.Equals(document.JournalEntryStatus, "voided", StringComparison.OrdinalIgnoreCase))
        {
            notice =
                $"The linked journal entry {document.JournalEntryDisplayNumber ?? document.JournalEntryId.Value.ToString("D")} has been voided. Review the accounting timeline before treating this source document as an active posted result.";
            return true;
        }

        if (string.Equals(document.JournalEntryStatus, "reversed", StringComparison.OrdinalIgnoreCase))
        {
            notice =
                $"The linked journal entry {document.JournalEntryDisplayNumber ?? document.JournalEntryId.Value.ToString("D")} has been reversed. This source document detail remains historical, but the accounting effect has changed.";
            return true;
        }

        return false;
    }

