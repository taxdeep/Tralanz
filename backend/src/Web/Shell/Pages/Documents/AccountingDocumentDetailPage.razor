        string.Equals(request.ExecutionStatus, "journal_entry_reversed", StringComparison.OrdinalIgnoreCase)
            ? "This governed reverse request has completed linked JE reversal and any supported AR/AP settlement application unapply trail is listed below."
            : "This reverse request is a governed request record. Historical accounting truth changes only after governed execution completes.";

    private static string BuildBlockerReadinessSummary(BlockerReverseDetail detail)
    {
        if (detail.Readiness is null)
        {
            return "Readiness: unavailable";
        }

        return detail.Readiness.GovernanceReady && detail.Readiness.ApplyReady
            ? $"Readiness: ready | {FormatExecutionMode(detail.Readiness.ExecutionMode)}"
            : $"Readiness: blocked | {detail.Readiness.Reason}";
    }

    private static string BuildBlockerPlanSummary(BlockerReverseDetail detail)
    {
        if (detail.Plan is null)
        {
            return "Plan: unavailable";
        }

        var readyCount = detail.Plan.Steps.Count(step => string.Equals(step.StepStatus, "ready", StringComparison.OrdinalIgnoreCase));
        var blockedCount = detail.Plan.Steps.Count(step => string.Equals(step.StepStatus, "blocked", StringComparison.OrdinalIgnoreCase));
        return $"Plan: {FormatPlanStepStatus(detail.Plan.OverallStatus)} | {readyCount}/{detail.Plan.Steps.Count} ready | {blockedCount} blocked | {detail.Plan.Reason}";
    }

