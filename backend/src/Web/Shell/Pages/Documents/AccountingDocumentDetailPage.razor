    private static bool IsSuccessfulPurchaseOrderLifecycleStatus(string? status) =>
        status?.Trim().ToLowerInvariant() is "approved" or "issued";

    private static bool IsSettlementDocument(ShellAccountingDocumentReviewSummary? document) =>
        document?.SourceType is "receive_payment" or "credit_application" or "pay_bill" or "vendor_credit_application";

    private static bool IsApplicationDocument(ShellAccountingDocumentReviewSummary? document) =>
        document?.SourceType is "credit_application" or "vendor_credit_application";

    private static bool CanRequestReverse(ShellAccountingDocumentReviewSummary? document)
    {
        var action = FindLifecycleAction(document, "reverse_document");
        return action is not null &&
               (action.IsAvailable ||
                string.Equals(action.AvailabilityMode, "not_implemented", StringComparison.OrdinalIgnoreCase));
    }

    private static bool CanSubmitReverseRequest(ShellAccountingDocumentReverseRequestSummary? request) =>
        string.Equals(request?.RequestStatus, "draft", StringComparison.OrdinalIgnoreCase);

    private static bool CanExecuteReverseRequest(ShellAccountingDocumentReverseRequestSummary? request) =>
        request is not null &&
        string.Equals(request.RequestStatus, "submitted", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(request.ExecutionStatus, "not_requested", StringComparison.OrdinalIgnoreCase);

    private static bool CanRequestBlockerUnapply(ShellSubledgerReverseBlockerSummary blocker) =>
        blocker.ReverseRequestStatus is "" or "not_requested" or "cancelled";

    private static bool CanSubmitBlockerUnapply(ShellSubledgerReverseBlockerSummary blocker) =>
        blocker.ReverseRequestId is not null &&
        string.Equals(blocker.ReverseRequestStatus, "draft", StringComparison.OrdinalIgnoreCase);

    private static bool CanExecuteBlockerUnapply(ShellSubledgerReverseBlockerSummary blocker) =>
        blocker.ReverseRequestId is not null &&
        string.Equals(blocker.ReverseRequestStatus, "submitted", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(blocker.ReverseExecutionStatus, "not_requested", StringComparison.OrdinalIgnoreCase);

    private static bool ShouldShowSubledgerGateSummary(
        ShellAccountingDocumentReviewSummary? document,
        ShellAccountingDocumentReverseRequestSummary? request) =>
        document?.SourceType is "invoice" or "credit_note" or "bill" or "vendor_credit" &&
        request is not null &&
        !string.Equals(request.ExecutionStatus, "journal_entry_reversed", StringComparison.OrdinalIgnoreCase);

    private Severity GetSubledgerGateSummarySeverity()
    {
        if (_subledgerReverseBlockers.Count > 0)
        {
            return Severity.Warning;
        }

        return CanExecuteReverseRequest(_latestReverseRequest) ? Severity.Success : Severity.Info;
    }

    private bool CanExecuteOriginalReverseAfterSubledgerGate() =>
        _subledgerReverseBlockers.Count == 0 && CanExecuteReverseRequest(_latestReverseRequest);

    private string BuildSubledgerGateSummary()
    {
        if (_subledgerReverseBlockers.Count == 0)
        {
            return CanExecuteReverseRequest(_latestReverseRequest)
                ? "Subledger gate is clear: backend returned no active AR/AP settlement-application blockers. The original source document can now proceed through governed reverse execution from this page."
                : "Subledger gate is clear: backend returned no active AR/AP settlement-application blockers. The original reverse request still must satisfy its request/execution state gates.";
        }

        var requestedCount = _subledgerReverseBlockers.Count(blocker => !string.Equals(blocker.ReverseRequestStatus, "not_requested", StringComparison.OrdinalIgnoreCase));
        var submittedCount = _subledgerReverseBlockers.Count(blocker => string.Equals(blocker.ReverseRequestStatus, "submitted", StringComparison.OrdinalIgnoreCase));
        var executionRequestedCount = _subledgerReverseBlockers.Count(blocker => string.Equals(blocker.ReverseExecutionStatus, "execution_requested", StringComparison.OrdinalIgnoreCase));
        var completedCount = _subledgerReverseBlockers.Count(blocker => string.Equals(blocker.ReverseExecutionStatus, "journal_entry_reversed", StringComparison.OrdinalIgnoreCase));

        return $"Subledger gate still has {_subledgerReverseBlockers.Count} active blocker(s): {requestedCount} requested, {submittedCount} submitted, {executionRequestedCount} execution requested, {completedCount} completed. Clear these blockers before retrying original source reverse execution.";
    }

    private bool TryGetBlockerReverseDetail(
        ShellSubledgerReverseBlockerSummary blocker,
        out BlockerReverseDetail detail) =>
        _blockerReverseDetails.TryGetValue(blocker.SettlementApplicationId, out detail!);

