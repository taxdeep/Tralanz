    private static bool TryBuildDocumentHref(string? sourceType, Guid? documentId, out string href)
    {
        href = string.Empty;
        if (!documentId.HasValue)
        {
            return false;
        }

        href = sourceType?.Trim().ToLowerInvariant() switch
        {
            "invoice" => $"/documents/invoice/{documentId.Value:D}",
            "credit_note" => $"/documents/credit_note/{documentId.Value:D}",
            "bill" => $"/documents/bill/{documentId.Value:D}",
            "vendor_credit" => $"/documents/vendor_credit/{documentId.Value:D}",
            "receive_payment" => $"/documents/receive_payment/{documentId.Value:D}",
            "credit_application" => $"/documents/credit_application/{documentId.Value:D}",
            "pay_bill" => $"/documents/pay_bill/{documentId.Value:D}",
            "vendor_credit_application" => $"/documents/vendor_credit_application/{documentId.Value:D}",
            "purchase_order" => $"/documents/purchase_order/{documentId.Value:D}",
            _ => string.Empty
        };

        return !string.IsNullOrWhiteSpace(href);
    }

    private static bool TryBuildOpenItemHref(string? sourceType, Guid? openItemId, out string href)
    {
        href = string.Empty;
        if (!openItemId.HasValue)
        {
            return false;
        }

        var type = sourceType?.Trim().ToLowerInvariant() switch
        {
            "invoice" or "credit_note" or "receive_payment" or "credit_application" => "ar",
            "bill" or "vendor_credit" or "pay_bill" or "vendor_credit_application" => "ap",
            "ar_open_item" => "ar",
            "ap_open_item" => "ap",
            _ => null
        };

        if (type is null)
        {
            return false;
        }

        href = $"/open-items/{type}/{openItemId.Value:D}";
        return true;
    }

    private static bool TryBuildAdjustmentPolicyHref(string? sourceType, out string href)
    {
        href = sourceType?.Trim().ToLowerInvariant() switch
        {
            "invoice" or "credit_note" =>
                "/company/open-item-adjustment-account-mappings?openItemType=ar_open_item&policyScope=primary_execution",
            "bill" or "vendor_credit" =>
                "/company/open-item-adjustment-account-mappings?openItemType=ap_open_item&policyScope=primary_execution",
            _ => string.Empty
        };

        return !string.IsNullOrWhiteSpace(href);
    }

    private static bool TryBuildShipmentWorkspaceHref(string? sourceType, Guid documentId, out string href)
    {
        href = string.Empty;
        if (!string.Equals(sourceType, "invoice", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        href = $"/company/inventory-shipment?sourceType=invoice&invoiceId={documentId:D}";
        return true;
    }

    private static bool TryBuildSourceBrowserHref(string? sourceType, string? counterpartyLabel, Guid? counterpartyId, out string href)
    {
        href = string.Empty;
        if (!counterpartyId.HasValue)
        {
            return false;
        }

        var normalizedSourceType = sourceType?.Trim().ToLowerInvariant();
        var counterpartyRole = counterpartyLabel?.Trim().ToLowerInvariant() switch
        {
            "customer" => "customer",
            "vendor" => "vendor",
            _ => null
        };

        if (string.IsNullOrWhiteSpace(normalizedSourceType) || string.IsNullOrWhiteSpace(counterpartyRole))
        {
            return false;
        }

        href =
            $"/documents/source-browser?sourceType={Uri.EscapeDataString(normalizedSourceType)}" +
            $"&counterpartyRole={Uri.EscapeDataString(counterpartyRole)}" +
            $"&counterpartyId={counterpartyId.Value:D}";
        return true;
    }

    private static bool TryBuildSourceTypeBrowserHref(string? sourceType, out string href)
    {
        href = string.Empty;
        var normalizedSourceType = sourceType?.Trim().ToLowerInvariant();
        if (normalizedSourceType is not ("invoice" or "credit_note" or "bill" or "vendor_credit" or "purchase_order"))
        {
            return false;
        }

        href = $"/documents/source-browser?sourceType={Uri.EscapeDataString(normalizedSourceType)}";
        return true;
    }

