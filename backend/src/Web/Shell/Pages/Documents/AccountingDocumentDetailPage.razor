        string.Equals(document?.SourceType, "bill", StringComparison.OrdinalIgnoreCase);

    private static bool IsInvoiceShipmentReview(ShellAccountingDocumentReviewSummary? document) =>
        string.Equals(document?.SourceType, "invoice", StringComparison.OrdinalIgnoreCase);

