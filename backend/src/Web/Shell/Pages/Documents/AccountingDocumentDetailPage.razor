@page "/documents/{SourceType}/{DocumentId:guid}"
@using Citus.Modules.Inventory.Application.Contracts
@using Web.Shell.Services
@inject WebShellState ShellState
@inject WebShellBusinessSessionClient SessionClient
@inject WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject ShellAccountingDocumentReviewClient ReviewClient
@inject ShellBillReceiptMatchingClient BillReceiptMatchingClient
@inject ShellInventoryShipmentClient InventoryShipmentClient

<div style="padding:2rem 2.25rem;color:#d9e2ea;">
    <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;margin-bottom:1rem;">
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/" StartIcon="@Icons.Material.Filled.ArrowBack">
            Back to shell
        </MudButton>
        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">Read-only detail</MudChip>
    </div>

    <h1 style="margin:0 0 0.75rem 0;">@(_purchaseOrder?.DisplayNumber ?? _document?.DisplayNumber ?? GetSourceLabel(SourceType))</h1>
    <p style="margin:0 0 1rem 0;color:#97a8b7;max-width:60rem;">
        Source document review stays backend-owned and company-scoped. This page is read-only and is intended for drill-down from settlement and control flows.
    </p>

    @if (IsCompanyReadyHandOff && SupportsSettlementFollowUp(_document))
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            Company-ready hand-off carried the first source document into read-only review so the operator can confirm posting truth before moving into the first settlement workspace.
        </MudAlert>
    }

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Info" Style="margin-bottom:1rem;" />
    }

    @if (!string.IsNullOrWhiteSpace(_errorText))
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            @_errorText
        </MudAlert>
    }

    @if (WritesBlocked)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            @ShellState.WriteBlockMessage
        </MudAlert>
    }

    @if (_purchaseOrder is not null)
    {
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:1rem;">
            <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@BuildPurchaseOrderBrowserHref(_purchaseOrder)">
                Browse Purchase Orders
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Warning" Href="/documents/purchase-orders/approval-requests">
                Approval Requests
            </MudButton>
        </div>

        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            @_purchaseOrder.AnchorGovernance.Summary
        </MudAlert>

        @if (_isPurchaseOrderApprovalCommandRunning)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Warning" Style="margin-bottom:1rem;" />
        }

        @if (!string.IsNullOrWhiteSpace(_purchaseOrderApprovalCommandMessage))
        {
            <MudAlert Severity="_purchaseOrderApprovalCommandSeverity" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                @_purchaseOrderApprovalCommandMessage
            </MudAlert>
        }

        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <MudText Typo="Typo.h6" Class="mb-3">Approval Request Control</MudText>
            <div style="display:grid;grid-template-columns:minmax(18rem,1fr) auto;gap:0.75rem;align-items:end;">
                @if (CanRequestPurchaseOrderApproval())
                {
                    <MudTextField T="string"
                                  Label="Reason"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  @bind-Value="_purchaseOrderApprovalReason"
                                  Disabled="@(_isPurchaseOrderApprovalCommandRunning || WritesBlocked)" />
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.Approval"
                               OnClick="RequestPurchaseOrderApprovalAsync"
                               Disabled="@(_isPurchaseOrderApprovalCommandRunning || WritesBlocked)">
                        Request
                    </MudButton>
                }
                else if (CanSubmitPurchaseOrderApprovalRequest())
                {
                    <MudText Typo="Typo.body2">
                        @GetPurchaseOrderApprovalRequestSummary(_latestPurchaseOrderApprovalRequest)
                    </MudText>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.Send"
                               OnClick="SubmitPurchaseOrderApprovalRequestAsync"
                               Disabled="@(_isPurchaseOrderApprovalCommandRunning || WritesBlocked)">
                        Submit
                    </MudButton>
                }
                else if (CanApprovePurchaseOrderFromApprovalRequest())
                {
                    <MudText Typo="Typo.body2">
                        @GetPurchaseOrderApprovalRequestSummary(_latestPurchaseOrderApprovalRequest)
                    </MudText>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.CheckCircle"
                               OnClick="ApprovePurchaseOrderFromApprovalRequestAsync"
                               Disabled="@(_isPurchaseOrderApprovalCommandRunning || WritesBlocked)">
                        Approve
                    </MudButton>
                }
                else if (CanReleasePurchaseOrder())
                {
                    <MudText Typo="Typo.body2">
                        Approval is complete. Release moves the purchase order into issued anchor truth for Receipt and Bill workflows.
                    </MudText>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Send"
                               OnClick="ReleasePurchaseOrderAsync"
                               Disabled="@(_isPurchaseOrderApprovalCommandRunning || WritesBlocked)">
                        Release
                    </MudButton>
                }
                else
                {
                    <MudText Typo="Typo.body2">
                        @GetPurchaseOrderApprovalControlSummary()
                    </MudText>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Info"
                               Href="/documents/purchase-orders/approval-requests">
                        Review Queue
                    </MudButton>
                }
            </div>
        </MudPaper>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(16rem,1fr));gap:1rem;margin-bottom:1rem;">
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Purchase Order</MudText>
                <MudText Typo="Typo.h6">@_purchaseOrder.DisplayNumber</MudText>
                <MudText Typo="Typo.body2">@($"{_purchaseOrder.EntityNumber} | {_purchaseOrder.Status}")</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Vendor</MudText>
                <MudText Typo="Typo.h6">@_purchaseOrder.VendorId.ToString("D")</MudText>
                <MudText Typo="Typo.body2">Reference @(_purchaseOrder.VendorReference ?? "n/a")</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Order Date</MudText>
                <MudText Typo="Typo.h6">@_purchaseOrder.OrderDate.ToString("yyyy-MM-dd")</MudText>
                <MudText Typo="Typo.body2">@($"Expected {_purchaseOrder.ExpectedDate?.ToString("yyyy-MM-dd") ?? "n/a"}")</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Lines</MudText>
                <MudText Typo="Typo.h6">@_purchaseOrder.Lines.Count</MudText>
                <MudText Typo="Typo.body2">@($"{_purchaseOrder.Lines.Sum(static line => line.OrderedQuantity):N2} ordered quantity")</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Approval Threshold</MudText>
                <MudText Typo="Typo.h6">@GetPurchaseOrderApprovalThresholdTitle(_purchaseOrder)</MudText>
                <MudText Typo="Typo.body2">@_purchaseOrder.ApprovalAuthority.Summary</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Latest Approval Request</MudText>
                <MudText Typo="Typo.h6">@GetPurchaseOrderApprovalRequestTitle(_latestPurchaseOrderApprovalRequest)</MudText>
                <MudText Typo="Typo.body2">@GetPurchaseOrderApprovalRequestSummary(_latestPurchaseOrderApprovalRequest)</MudText>
            </MudPaper>
        </div>

        @if (_purchaseOrder.ThreeQuantity is not null)
        {
            <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
                <MudText Typo="Typo.h6" Class="mb-3">Three-Quantity Control</MudText>
                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));gap:1rem;">
                    <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                        <MudText Typo="Typo.caption">Ordered</MudText>
                        <MudText Typo="Typo.h6">@_purchaseOrder.ThreeQuantity.OrderedQuantity.ToString("N2")</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@FormatPurchaseOrderQuantityStatus(_purchaseOrder.ThreeQuantity.QuantityStatus)</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                        <MudText Typo="Typo.caption">Received</MudText>
                        <MudText Typo="Typo.h6">@_purchaseOrder.ThreeQuantity.ReceivedQuantity.ToString("N2")</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@FormatPurchaseOrderQuantityStatus(_purchaseOrder.ThreeQuantity.ReceiptStatus)</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                        <MudText Typo="Typo.caption">Billed</MudText>
                        <MudText Typo="Typo.h6">@_purchaseOrder.ThreeQuantity.BilledQuantity.ToString("N2")</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@FormatPurchaseOrderQuantityStatus(_purchaseOrder.ThreeQuantity.BillStatus)</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                        <MudText Typo="Typo.caption">Open Discrepancies</MudText>
                        <MudText Typo="Typo.h6">@_purchaseOrder.ThreeQuantity.OpenDiscrepancyCount</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">Backend review truth</MudText>
                    </MudPaper>
                </div>
            </MudPaper>
        }

        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <MudText Typo="Typo.h6" Class="mb-3">Lifecycle Audit Timeline</MudText>
            @if (_purchaseOrderLifecycleAudit.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    No lifecycle audit rows were returned for this purchase order yet.
                </MudAlert>
            }
            else
            {
                <MudTable Items="_purchaseOrderLifecycleAudit" Dense="true" Hover="true" Bordered="true">
                    <HeaderContent>
                        <MudTh>Time</MudTh>
                        <MudTh>Action</MudTh>
                        <MudTh>Status Movement</MudTh>
                        <MudTh>Actor</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss zzz")</MudTd>
                        <MudTd>@FormatPurchaseOrderAuditAction(context.Action)</MudTd>
                        <MudTd>@FormatStatusMovement(context.FromStatus, context.ToStatus)</MudTd>
                        <MudTd>@FormatActor(context.ActorType, context.ActorId)</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.h6" Class="mb-3">Lines</MudText>
            @if (_purchaseOrder.Lines.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    No purchase order lines were returned for this document.
                </MudAlert>
            }
            else
            {
                <MudTable Items="_purchaseOrder.Lines" Dense="true" Hover="true" Bordered="true">
                    <HeaderContent>
                        <MudTh>Line</MudTh>
                        <MudTh>Description</MudTh>
                        <MudTh>Item</MudTh>
                        <MudTh>Quantity</MudTh>
                        <MudTh>Unit Cost</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.LineNumber</MudTd>
                        <MudTd>@(string.IsNullOrWhiteSpace(context.Description) ? "No description" : context.Description)</MudTd>
                        <MudTd>@context.ItemId.ToString("D")</MudTd>
                        <MudTd>@($"{context.OrderedQuantity:N2} {context.UomCode}")</MudTd>
                        <MudTd>@(context.UnitCost?.ToString("N2") ?? "n/a")</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    }
    else if (_document is not null)
    {
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:1rem;">
            @if (CanOpenDraftWorkbench(_document) && TryBuildDraftEditorHref(_document.SourceType, _document.Status, _document.Id, out var draftEditorHref))
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Success" Href="@draftEditorHref" Disabled="WritesBlocked">
                    @GetDraftWorkbenchLabel(_document.SourceType, _document.Status)
                </MudButton>
            }
            @if (_document.JournalEntryId.HasValue)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@($"/gl/journal-entry/review/{_document.JournalEntryId.Value:D}")">
                    Open Journal Entry Review
                </MudButton>
            }
            @if (IsCompanyReadyHandOff && TryBuildSettlementWorkbenchHref(_document, out var settlementWorkbenchHref, out var settlementWorkbenchLabel))
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success" Href="@settlementWorkbenchHref">
                    @settlementWorkbenchLabel
                </MudButton>
            }
            @if (TryBuildAdjustmentPolicyHref(_document.SourceType, out var adjustmentPolicyHref))
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@adjustmentPolicyHref">
                    Review Adjustment Policy
                </MudButton>
            }
            @if (TryBuildShipmentWorkspaceHref(_document.SourceType, _document.Id, out var shipmentHref))
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" Href="@shipmentHref" Disabled="WritesBlocked">
                    Open Shipment Workspace
                </MudButton>
            }
            @if (TryBuildSourceBrowserHref(_document.SourceType, _document.CounterpartyLabel, _document.CounterpartyId, out var relatedDocumentsHref))
            {
                <MudButton Variant="Variant.Text" Color="Color.Info" Href="@BuildBrowserNavigationHref(relatedDocumentsHref, "Current source detail", "Back to source detail")">
                    Browse Related Documents
                </MudButton>
            }
            else if (TryBuildSourceTypeBrowserHref(_document.SourceType, out var sourceTypeBrowserHref))
            {
                <MudButton Variant="Variant.Text" Color="Color.Info" Href="@BuildBrowserNavigationHref(sourceTypeBrowserHref, "Current source detail", "Back to source detail")">
                    Browse Same Type
                </MudButton>
            }
            @if (_latestReverseRequest is null && CanRequestReverse(_document))
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="RequestReverseAsync" Disabled="@(_isReverseCommandRunning || WritesBlocked)">
                    Request Reverse
                </MudButton>
            }
            @if (CanSubmitReverseRequest(_latestReverseRequest))
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="SubmitReverseRequestAsync" Disabled="@(_isReverseCommandRunning || WritesBlocked)">
                    Submit Reverse Request
                </MudButton>
            }
            @if (CanExecuteReverseRequest(_latestReverseRequest))
            {
                <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="ExecuteReverseRequestAsync" Disabled="@(_isReverseCommandRunning || WritesBlocked)">
                    Execute Governed Reverse
                </MudButton>
            }
        </div>

        @if (_isReverseCommandRunning)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Warning" Style="margin-bottom:1rem;" />
        }

        @if (!string.IsNullOrWhiteSpace(_reverseCommandMessage))
        {
            <MudAlert Severity="_reverseCommandSeverity" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                @_reverseCommandMessage
            </MudAlert>
        }

        @if (TryBuildJournalEntryLifecycleNotice(_document, out var lifecycleNotice))
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                @lifecycleNotice
            </MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(_document.LifecycleReason))
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                @_document.LifecycleReason
            </MudAlert>
        }

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(16rem,1fr));gap:1rem;margin-bottom:1rem;">
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Document</MudText>
                <MudText Typo="Typo.h6">@_document.DisplayNumber</MudText>
                <MudText Typo="Typo.body2">@_document.SourceTypeLabel | @_document.Status</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Company</MudText>
                <MudText Typo="Typo.h6">@ShellState.ActiveCompany.CompanyCode</MudText>
                <MudText Typo="Typo.body2">@ShellState.ActiveCompany.CompanyName</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Total</MudText>
                <MudText Typo="Typo.h6">@FormatAmount(_document.TotalAmount)</MudText>
                <MudText Typo="Typo.body2">@_document.TransactionCurrencyCode</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Document Date</MudText>
                <MudText Typo="Typo.h6">@_document.DocumentDate.ToString("yyyy-MM-dd")</MudText>
                <MudText Typo="Typo.body2">@($"Due {_document.DueDate?.ToString("yyyy-MM-dd") ?? "n/a"}")</MudText>
            </MudPaper>
            @if (SupportsSettlementFollowUp(_document))
            {
                <MudPaper Class="pa-4" Elevation="0">
                    <MudText Typo="Typo.caption">Settlement Follow-up</MudText>
                    <MudText Typo="Typo.h6">@GetSettlementFollowUpTitle(_document)</MudText>
                    <MudText Typo="Typo.body2">@GetSettlementFollowUpDetail(_document)</MudText>
                </MudPaper>
                <MudPaper Class="pa-4" Elevation="0">
                    <MudText Typo="Typo.caption">Counterparty Continuity</MudText>
                    <MudText Typo="Typo.h6">@GetCounterpartyContinuityTitle(_document)</MudText>
                    <MudText Typo="Typo.body2">@GetCounterpartyContinuityDetail(_document)</MudText>
                </MudPaper>
            }
        </div>

        @if (IsBillReceiptReview(_document) && _billReceiptHandoffSummary is not null)
        {
            <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
                <MudText Typo="Typo.h6" Class="mb-3">Receipt-first Matching</MudText>
                <MudAlert Severity="@GetBillReceiptMatchingSeverity(_billReceiptHandoffSummary.MatchStatus)" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                    @BuildBillReceiptMatchingNotice(_billReceiptHandoffSummary)
                </MudAlert>
                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));gap:1rem;margin-bottom:1rem;">
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">Bill Inbound Qty</MudText>
                        <MudText Typo="Typo.h6">@_billReceiptHandoffSummary.BillInboundQuantity.ToString("N2")</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@_billReceiptHandoffSummary.BillInboundLineCount inventory-grade line(s)</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">Receipt-covered Qty</MudText>
                        <MudText Typo="Typo.h6">@_billReceiptHandoffSummary.CoveredQuantity.ToString("N2")</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@_billReceiptHandoffSummary.ReceiptCount matched posted receipt(s)</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">Remaining Qty</MudText>
                        <MudText Typo="Typo.h6">@_billReceiptHandoffSummary.RemainingQuantity.ToString("N2")</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@BuildBillReceiptRemainingSummary(_billReceiptHandoffSummary)</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">Match Status</MudText>
                        <MudText Typo="Typo.h6">@FormatBillReceiptMatchStatus(_billReceiptHandoffSummary.MatchStatus)</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">Receipt truth remains authoritative over AP charge truth.</MudText>
                    </MudPaper>
                </div>
                @if (_billReceiptHandoffSummary.RecentReceipts.Count > 0)
                {
                    <MudTable Items="_billReceiptHandoffSummary.RecentReceipts" Dense="true" Hover="true" Bordered="true">
                        <HeaderContent>
                            <MudTh>Receipt</MudTh>
                            <MudTh>Date</MudTh>
                            <MudTh>Matched Qty</MudTh>
                            <MudTh>Receipt Qty</MudTh>
                            <MudTh>Vendor Ref</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.DisplayNumber</MudTd>
                            <MudTd>@context.ReceiptDate.ToString("yyyy-MM-dd")</MudTd>
                            <MudTd>@context.MatchedQuantity.ToString("N2")</MudTd>
                            <MudTd>@context.ReceiptQuantity.ToString("N2")</MudTd>
                            <MudTd>@(context.VendorReference ?? "n/a")</MudTd>
                            <MudTd>@context.Status</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                @if (_billReceiptHandoffSummary.LineSummaries.Count > 0)
                {
                    <MudTable Items="_billReceiptHandoffSummary.LineSummaries" Dense="true" Hover="true" Bordered="true" Style="margin-top:1rem;">
                        <HeaderContent>
                            <MudTh>Item</MudTh>
                            <MudTh>Warehouse</MudTh>
                            <MudTh>UOM</MudTh>
                            <MudTh>Bill Qty</MudTh>
                            <MudTh>Covered Qty</MudTh>
                            <MudTh>Remaining</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@($"{context.ItemCode} - {context.ItemName}")</MudTd>
                            <MudTd>@($"{context.WarehouseCode} - {context.WarehouseName}")</MudTd>
                            <MudTd>@context.UomCode</MudTd>
                            <MudTd>@context.BillQuantity.ToString("N2")</MudTd>
                            <MudTd>@context.CoveredQuantity.ToString("N2")</MudTd>
                            <MudTd>@context.RemainingQuantity.ToString("N2")</MudTd>
                            <MudTd>@FormatBillReceiptMatchStatus(context.MatchStatus)</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                @if (_billReceiptHandoffSummary.Discrepancies.Count > 0)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-top:1rem;">
                        @_billReceiptHandoffSummary.Discrepancies.Count open inbound discrepancy lane(s) still need receipt-first investigation.
                    </MudAlert>
                    <MudTable Items="_billReceiptHandoffSummary.Discrepancies" Dense="true" Hover="true" Bordered="true" Style="margin-top:1rem;">
                        <HeaderContent>
                            <MudTh>Line</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh>Item</MudTh>
                            <MudTh>Warehouse</MudTh>
                            <MudTh>UOM</MudTh>
                            <MudTh>Remaining</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Summary</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.BillLineNumber</MudTd>
                            <MudTd>@FormatBillReceiptDiscrepancyType(context.DiscrepancyType)</MudTd>
                            <MudTd>@($"{context.ItemCode} - {context.ItemName}")</MudTd>
                            <MudTd>@($"{context.WarehouseCode} - {context.WarehouseName}")</MudTd>
                            <MudTd>@context.UomCode</MudTd>
                            <MudTd>@context.RemainingQuantity.ToString("N2")</MudTd>
                            <MudTd>@FormatBillReceiptInvestigationStatus(context.InvestigationStatus)</MudTd>
                            <MudTd>@context.Summary</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        }

        @if (IsInvoiceShipmentReview(_document) && _invoiceShipmentLaneSummary is not null)
        {
            <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
                <MudText Typo="Typo.h6" Class="mb-3">Shipment-first Matching</MudText>
                <MudAlert Severity="@GetInvoiceShipmentMatchingSeverity(_invoiceShipmentLaneSummary.ShipmentMatchStatus)" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                    @BuildInvoiceShipmentMatchingNotice(_invoiceShipmentLaneSummary)
                </MudAlert>
                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));gap:1rem;margin-bottom:1rem;">
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">Invoice Outbound Qty</MudText>
                        <MudText Typo="Typo.h6">@_invoiceShipmentLaneSummary.InvoiceOutboundQuantity.ToString("N2")</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@_invoiceShipmentLaneSummary.InvoiceOutboundLineCount inventory-grade line(s)</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">Shipped Qty</MudText>
                        <MudText Typo="Typo.h6">@_invoiceShipmentLaneSummary.ShippedQuantity.ToString("N2")</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@_invoiceShipmentLaneSummary.ShipmentCount anchored shipment(s)</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">Remaining Qty</MudText>
                        <MudText Typo="Typo.h6">@_invoiceShipmentLaneSummary.RemainingToShipQuantity.ToString("N2")</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@BuildInvoiceShipmentRemainingSummary(_invoiceShipmentLaneSummary)</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">Match Status</MudText>
                        <MudText Typo="Typo.h6">@FormatInvoiceShipmentMatchStatus(_invoiceShipmentLaneSummary.ShipmentMatchStatus)</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">Shipment owns fulfillment truth; Sales Issue remains downstream inventory and cost truth.</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">Invoice Coverage</MudText>
                        <MudText Typo="Typo.h6">@FormatInvoiceShipmentMatchStatus(_invoiceShipmentLaneSummary.InvoiceCoverageStatus)</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@BuildInvoiceCoverageSummary(_invoiceShipmentLaneSummary)</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">Issue Follow-through</MudText>
                        <MudText Typo="Typo.h6">@FormatInvoiceShipmentMatchStatus(_invoiceShipmentLaneSummary.IssueMatchStatus)</MudText>
                        <MudText Typo="Typo.body2" Class="text-secondary">@BuildInvoiceIssueFollowThroughSummary(_invoiceShipmentLaneSummary)</MudText>
                    </MudPaper>
                </div>
                @if (_invoiceShipmentLaneSummary.Discrepancies.Count > 0)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                        @foreach (var discrepancy in _invoiceShipmentLaneSummary.Discrepancies)
                        {
                            <div>@discrepancy.Summary</div>
                        }
                    </MudAlert>
                }
                <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:1rem;">
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" Href="@($"/company/inventory-shipment?sourceType=invoice&invoiceId={_document.Id:D}")">
                        Open Shipment Workspace
                    </MudButton>
                </div>
                @if (_invoiceShipmentLaneSummary.RecentShipments.Count > 0)
                {
                    <MudTable Items="_invoiceShipmentLaneSummary.RecentShipments" Dense="true" Hover="true" Bordered="true">
                        <HeaderContent>
                            <MudTh>Shipment</MudTh>
                            <MudTh>Date</MudTh>
                            <MudTh>Customer</MudTh>
                            <MudTh>Qty</MudTh>
                            <MudTh>Tracking</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.DocumentNumber</MudTd>
                            <MudTd>@context.PostingDate.ToString("yyyy-MM-dd")</MudTd>
                            <MudTd>@context.CustomerDisplayName</MudTd>
                            <MudTd>@context.TotalQuantity.ToString("N2")</MudTd>
                            <MudTd>@(context.TrackingNumber ?? "n/a")</MudTd>
                            <MudTd>@context.Status</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                @if (_invoiceShipmentLaneSummary.LineSummaries.Count > 0)
                {
                    <MudTable Items="_invoiceShipmentLaneSummary.LineSummaries" Dense="true" Hover="true" Bordered="true" Style="margin-top:1rem;">
                        <HeaderContent>
                            <MudTh>Item</MudTh>
                            <MudTh>Warehouse</MudTh>
                            <MudTh>UOM</MudTh>
                            <MudTh>Invoice Qty</MudTh>
                            <MudTh>Shipped Qty</MudTh>
                            <MudTh>Remaining To Ship</MudTh>
                            <MudTh>Shipment</MudTh>
                            <MudTh>Invoiced Qty</MudTh>
                            <MudTh>Remaining To Invoice</MudTh>
                            <MudTh>Invoice Coverage</MudTh>
                            <MudTh>Issued Qty</MudTh>
                            <MudTh>Remaining To Issue</MudTh>
                            <MudTh>Issue</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@($"{context.ItemCode} - {context.ItemName}")</MudTd>
                            <MudTd>@($"{context.WarehouseCode} - {context.WarehouseName}")</MudTd>
                            <MudTd>@context.UomCode</MudTd>
                            <MudTd>@context.InvoiceQuantity.ToString("N2")</MudTd>
                            <MudTd>@context.ShippedQuantity.ToString("N2")</MudTd>
                            <MudTd>@context.RemainingToShipQuantity.ToString("N2")</MudTd>
                            <MudTd>@FormatInvoiceShipmentMatchStatus(context.ShipmentMatchStatus)</MudTd>
                            <MudTd>@context.InvoicedQuantity.ToString("N2")</MudTd>
                            <MudTd>@context.RemainingToInvoiceQuantity.ToString("N2")</MudTd>
                            <MudTd>@FormatInvoiceShipmentMatchStatus(context.InvoiceCoverageStatus)</MudTd>
                            <MudTd>@context.IssuedQuantity.ToString("N2")</MudTd>
                            <MudTd>@context.RemainingToIssueQuantity.ToString("N2")</MudTd>
                            <MudTd>@FormatInvoiceShipmentMatchStatus(context.IssueMatchStatus)</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                @if (_invoiceShipmentLaneSummary.RecentIssues.Count > 0)
                {
                    <MudTable Items="_invoiceShipmentLaneSummary.RecentIssues" Dense="true" Hover="true" Bordered="true" Style="margin-top:1rem;">
                        <HeaderContent>
                            <MudTh>Sales Issue</MudTh>
                            <MudTh>Date</MudTh>
                            <MudTh>Qty</MudTh>
                            <MudTh>Cost</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.DocumentNumber</MudTd>
                            <MudTd>@context.PostingDate.ToString("yyyy-MM-dd")</MudTd>
                            <MudTd>@context.TotalQuantity.ToString("N2")</MudTd>
                            <MudTd>@context.TotalCostBase.ToString("N2")</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        }

        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <MudText Typo="Typo.h6" Class="mb-3">Facts</MudText>
            <MudTable Items="_factRows" Dense="true">
                <RowTemplate>
                    <MudTd DataLabel="Field">@context.Label</MudTd>
                    <MudTd DataLabel="Value">@context.Value</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <MudText Typo="Typo.h6" Class="mb-3">Lifecycle Preview</MudText>
            <MudTable Items="_document.LifecycleActions" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Action</MudTh>
                    <MudTh>Availability</MudTh>
                    <MudTh>Reason</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.ActionLabel</MudTd>
                    <MudTd>@FormatAvailabilityMode(context.AvailabilityMode, context.IsAvailable)</MudTd>
                    <MudTd>@context.Reason</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        @if (_latestReverseRequest is not null)
        {
            <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
                <MudText Typo="Typo.h6" Class="mb-3">Latest Reverse Request</MudText>
                <MudTable Items="BuildReverseRequestRows(_latestReverseRequest)" Dense="true">
                    <RowTemplate>
                        <MudTd DataLabel="Field">@context.Label</MudTd>
                        <MudTd DataLabel="Value">@context.Value</MudTd>
                    </RowTemplate>
                </MudTable>
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="margin-top:1rem;">
                    @BuildReverseRequestNotice(_latestReverseRequest)
                </MudAlert>
            </MudPaper>
        }

        @if (HasReverseControlSummary())
        {
            var nextLegalAction = GetNextLegalActionSummary();
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(14rem,1fr));gap:1rem;margin-bottom:1rem;">
                <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.caption">Operator Next Step</MudText>
                    <MudText Typo="Typo.h6">@nextLegalAction.Title</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@nextLegalAction.Detail</MudText>
                </MudPaper>
                <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.caption">Reverse Workflow</MudText>
                    <MudText Typo="Typo.h6">@GetReverseRequestSummaryTitle()</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@GetReverseRequestSummaryDetail()</MudText>
                </MudPaper>
                <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.caption">Settlement Gate</MudText>
                    <MudText Typo="Typo.h6">@GetSubledgerGateSummaryTitle()</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@GetSubledgerGateSummaryDetail()</MudText>
                </MudPaper>
                <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.caption">Governed Unapply Trail</MudText>
                    <MudText Typo="Typo.h6">@GetReversalHistorySummaryTitle()</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@GetReversalHistorySummaryDetail()</MudText>
                </MudPaper>
            </div>
        }

        @if (_reverseApplyReadiness is not null || _reverseExecutionPlan is not null)
        {
            <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
                <MudText Typo="Typo.h6" Class="mb-3">Reverse Execution Readiness</MudText>
                @if (_reverseApplyReadiness is not null)
                {
                    <MudAlert Severity="@(_reverseApplyReadiness.GovernanceReady ? Severity.Success : Severity.Warning)" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                        @_reverseApplyReadiness.Reason
                    </MudAlert>
                    <MudTable Items="BuildReverseReadinessRows(_reverseApplyReadiness)" Dense="true" Style="margin-bottom:1rem;">
                        <RowTemplate>
                            <MudTd DataLabel="Field">@context.Label</MudTd>
                            <MudTd DataLabel="Value">@context.Value</MudTd>
                        </RowTemplate>
                    </MudTable>
                }

                @if (_reverseExecutionPlan is not null)
                {
                    <MudAlert Severity="@(_reverseExecutionPlan.CanExecute ? Severity.Success : Severity.Warning)" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                        @_reverseExecutionPlan.Reason
                    </MudAlert>
                    <MudTable Items="_reverseExecutionPlan.Steps" Dense="true" Hover="true" Bordered="true">
                        <HeaderContent>
                            <MudTh>#</MudTh>
                            <MudTh>Step</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Backend Reason</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.StepNumber</MudTd>
                            <MudTd>@context.StepLabel</MudTd>
                            <MudTd>@FormatPlanStepStatus(context.StepStatus)</MudTd>
                            <MudTd>@context.Reason</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        }

        @if (ShouldShowSubledgerGateSummary(_document, _latestReverseRequest))
        {
            <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
                <MudText Typo="Typo.h6" Class="mb-3">Subledger Gate</MudText>
                <MudAlert Severity="@GetSubledgerGateSummarySeverity()" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                    @BuildSubledgerGateSummary()
                </MudAlert>
                @if (CanExecuteOriginalReverseAfterSubledgerGate())
                {
                    <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;">
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="ExecuteReverseRequestAsync" Disabled="@(_isReverseCommandRunning || WritesBlocked)">
                            Execute Original Governed Reverse
                        </MudButton>
                        <MudText Typo="Typo.caption">
                            This still calls the backend governed execution endpoint; the shell is only surfacing the next legal action.
                        </MudText>
                    </div>
                }
            </MudPaper>
        }

        @if (_subledgerReverseBlockers.Count > 0)
        {
            <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
                <MudText Typo="Typo.h6" Class="mb-3">Subledger Reverse Blockers</MudText>
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                    Backend authority found AR/AP settlement application trail for this source document. Reverse execution must be handled through the governed subledger unapply path before the source document can be reversed.
                </MudAlert>
                <MudTable Items="_subledgerReverseBlockers" Dense="true" Hover="true" Bordered="true">
                    <HeaderContent>
                        <MudTh>Blocking Application</MudTh>
                        <MudTh>Blocked Open Item</MudTh>
                        <MudTh>Applied Tx</MudTh>
                        <MudTh>Applied Base</MudTh>
                        <MudTh>Applied At</MudTh>
                        <MudTh>Unapply Request</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudStack Spacing="0">
                                @if (TryBuildDocumentHref(context.SettlementSourceType, context.SettlementSourceId, out var blockerSourceHref))
                                {
                                    <MudLink Href="@blockerSourceHref">@DisplayDocumentLink(context.SettlementSourceDisplayNumber, context.SettlementSourceType)</MudLink>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2">@DisplayDocumentLink(context.SettlementSourceDisplayNumber, context.SettlementSourceType)</MudText>
                                }
                                <MudText Typo="Typo.caption">@FormatApplicationType(context.ApplicationType) | @FormatDate(context.SettlementSourceDocumentDate)</MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd>
                            <MudStack Spacing="0">
                                @if (TryBuildDocumentHref(context.TargetSourceType, context.TargetSourceId, out var blockerTargetHref))
                                {
                                    <MudLink Href="@blockerTargetHref">@DisplayDocumentLink(context.TargetSourceDisplayNumber, context.TargetSourceType)</MudLink>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2">@DisplayDocumentLink(context.TargetSourceDisplayNumber, context.TargetSourceType)</MudText>
                                }
                                @if (TryBuildOpenItemHref(context.TargetOpenItemType, context.TargetOpenItemId, out var blockerOpenItemHref))
                                {
                                    <MudLink Href="@blockerOpenItemHref" Typo="Typo.caption">@DisplayOpenItem(context.TargetOpenItemId)</MudLink>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption">@DisplayOpenItem(context.TargetOpenItemId)</MudText>
                                }
                            </MudStack>
                        </MudTd>
                        <MudTd>@FormatAmount(context.AppliedAmountTx)</MudTd>
                        <MudTd>@FormatAmount(context.AppliedAmountBase)</MudTd>
                        <MudTd>@context.AppliedAt.ToString("yyyy-MM-dd HH:mm:ss zzz")</MudTd>
                        <MudTd>
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2">@FormatReverseRequestStatus(context.ReverseRequestStatus)</MudText>
                                <MudText Typo="Typo.caption">@FormatReverseExecutionStatus(context.ReverseExecutionStatus)</MudText>
                                @if (context.ReverseRequestedAt is not null)
                                {
                                    <MudText Typo="Typo.caption">Requested @context.ReverseRequestedAt.Value.ToString("yyyy-MM-dd HH:mm:ss zzz")</MudText>
                                }
                                @if (TryGetBlockerReverseDetail(context, out var blockerReverseDetail))
                                {
                                    <MudDivider Class="my-1" />
                                    <MudText Typo="Typo.caption">@BuildBlockerReadinessSummary(blockerReverseDetail)</MudText>
                                    <MudText Typo="Typo.caption">@BuildBlockerPlanSummary(blockerReverseDetail)</MudText>
                                }
                                <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small" Disabled="@(_isReverseCommandRunning || WritesBlocked || !CanRequestBlockerUnapply(context))" OnClick="@(() => RequestBlockerUnapplyAsync(context))">
                                    Request Governed Unapply
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small" Disabled="@(_isReverseCommandRunning || WritesBlocked || !CanSubmitBlockerUnapply(context))" OnClick="@(() => SubmitBlockerUnapplyAsync(context))">
                                    Submit Governed Unapply
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" Disabled="@(_isReverseCommandRunning || WritesBlocked || !CanExecuteBlockerUnapply(context))" OnClick="@(() => ExecuteBlockerUnapplyAsync(context))">
                                    Request Governed Execution
                                </MudButton>
                                @if (TryBuildDocumentHref(context.SettlementSourceType, context.SettlementSourceId, out var blockerActionHref))
                                {
                                    <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Href="@blockerActionHref">
                                        Open Source
                                    </MudButton>
                                }
                                @if (TryBuildSourceTypeBrowserHref(context.TargetSourceType, out var blockerTargetBrowserHref))
                                {
                                    <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Href="@BuildBrowserNavigationHref(blockerTargetBrowserHref, "Reverse blocker: blocked source type", "Back to source detail")">
                                        Browse Blocked Type
                                    </MudButton>
                                }
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }

        @if (_settlementApplicationReversals.Count > 0)
        {
            <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
                <MudText Typo="Typo.h6" Class="mb-3">Settlement Application Reversals</MudText>
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                    These rows are sourced from the governed reversal audit trail after operational settlement applications were unapplied.
                </MudAlert>
                <MudTable Items="_settlementApplicationReversals" Dense="true" Hover="true" Bordered="true">
                    <HeaderContent>
                        <MudTh>Application</MudTh>
                        <MudTh>Source</MudTh>
                        <MudTh>Target Open Item</MudTh>
                        <MudTh>Applied Tx</MudTh>
                        <MudTh>Applied Base</MudTh>
                        <MudTh>Reversed At</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2">@FormatApplicationType(context.ApplicationType)</MudText>
                                <MudText Typo="Typo.caption">Request @context.RequestId.ToString("D")</MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd>
                            <MudStack Spacing="1">
                                @if (TryBuildDocumentHref(context.SourceType, context.SourceId, out var reversalSourceHref))
                                {
                                    <MudLink Href="@reversalSourceHref">@DisplayDocumentLink(null, context.SourceType)</MudLink>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2">@DisplayDocumentLink(null, context.SourceType)</MudText>
                                }
                                <MudText Typo="Typo.caption">@context.SourceTypeLabel</MudText>
                                <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                                    @if (TryBuildDocumentHref(context.SourceType, context.SourceId, out var reversalSourceActionHref))
                                    {
                                        <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Href="@reversalSourceActionHref">
                                            Open Source
                                        </MudButton>
                                    }
                                    @if (TryBuildSourceTypeBrowserHref(context.SourceType, out var reversalSourceBrowserHref))
                                    {
                                        <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Href="@BuildBrowserNavigationHref(reversalSourceBrowserHref, "Settlement application reversal history", "Back to source detail")">
                                            Browse Source Type
                                        </MudButton>
                                    }
                                </div>
                            </MudStack>
                        </MudTd>
                        <MudTd>
                            <MudStack Spacing="0">
                                @if (TryBuildOpenItemHref(context.TargetOpenItemType, context.TargetOpenItemId, out var reversalOpenItemHref))
                                {
                                    <MudLink Href="@reversalOpenItemHref">@DisplayOpenItem(context.TargetOpenItemId)</MudLink>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2">@DisplayOpenItem(context.TargetOpenItemId)</MudText>
                                }
                                <MudText Typo="Typo.caption">@FormatOpenItemType(context.TargetOpenItemType)</MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd>@FormatAmount(context.AppliedAmountTx)</MudTd>
                        <MudTd>@FormatAmount(context.AppliedAmountBase)</MudTd>
                        <MudTd>@context.ReversedAt.ToString("yyyy-MM-dd HH:mm:ss zzz")</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }

        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.h6" Class="mb-3">Lines</MudText>
            @if (_document.Lines.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    No line details were returned for this source document.
                </MudAlert>
            }
            else if (IsSettlementDocument(_document))
            {
                <MudTable Items="_document.Lines" Dense="true" Hover="true" Bordered="true">
                    <HeaderContent>
                        <MudTh>Line</MudTh>
                        @if (IsApplicationDocument(_document))
                        {
                            <MudTh>Source</MudTh>
                        }
                        <MudTh>Target</MudTh>
                        <MudTh>Applied</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.LineNumber</MudTd>
                        @if (IsApplicationDocument(_document))
                        {
                            <MudTd>
                                <MudStack Spacing="0">
                                    @if (TryBuildDocumentHref(context.SourceDocumentType, context.SourceDocumentId, out var sourceHref))
                                    {
                                        <MudLink Href="@sourceHref">@DisplayDocumentLink(context.SourceDocumentDisplayNumber, context.SourceDocumentType)</MudLink>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2">@DisplayDocumentLink(context.SourceDocumentDisplayNumber, context.SourceDocumentType)</MudText>
                                    }
                                    @if (TryBuildOpenItemHref(context.SourceDocumentType, context.SourceOpenItemId, out var sourceOpenItemHref))
                                    {
                                        <MudLink Href="@sourceOpenItemHref" Typo="Typo.caption">@DisplayOpenItem(context.SourceOpenItemId)</MudLink>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.caption" Class="text-secondary">@DisplayOpenItem(context.SourceOpenItemId)</MudText>
                                    }
                                    @if (TryBuildSourceTypeBrowserHref(context.SourceDocumentType, out var sourceTypeBrowserHref))
                                    {
                                        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                                            <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Href="@BuildBrowserNavigationHref(sourceTypeBrowserHref, "Settlement application line source", "Back to source detail")">
                                                Browse Source Type
                                            </MudButton>
                                        </div>
                                    }
                                </MudStack>
                            </MudTd>
                        }
                        <MudTd>
                            <MudStack Spacing="0">
                                @if (TryBuildDocumentHref(context.TargetDocumentType, context.TargetDocumentId, out var targetHref))
                                {
                                    <MudLink Href="@targetHref">@DisplayDocumentLink(context.TargetDocumentDisplayNumber, context.TargetDocumentType)</MudLink>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2">@DisplayDocumentLink(context.TargetDocumentDisplayNumber, context.TargetDocumentType)</MudText>
                                }
                                @if (TryBuildOpenItemHref(context.TargetDocumentType, context.TargetOpenItemId, out var targetOpenItemHref))
                                {
                                    <MudLink Href="@targetOpenItemHref" Typo="Typo.caption">@DisplayOpenItem(context.TargetOpenItemId)</MudLink>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Class="text-secondary">@DisplayOpenItem(context.TargetOpenItemId)</MudText>
                                }
                                @if (TryBuildSourceTypeBrowserHref(context.TargetDocumentType, out var targetTypeBrowserHref))
                                {
                                    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                                        <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Href="@BuildBrowserNavigationHref(targetTypeBrowserHref, "Settlement application line target", "Back to source detail")">
                                            Browse Target Type
                                        </MudButton>
                                    </div>
                                }
                            </MudStack>
                        </MudTd>
                        <MudTd>@FormatAmount(context.LineAmount)</MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <MudTable Items="_document.Lines" Dense="true" Hover="true" Bordered="true">
                    <HeaderContent>
                        <MudTh>Line</MudTh>
                        <MudTh>Description</MudTh>
                        <MudTh>Account</MudTh>
                        <MudTh>Amount</MudTh>
                        <MudTh>Tax</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.LineNumber</MudTd>
                        <MudTd>@(string.IsNullOrWhiteSpace(context.Description) ? "No description" : context.Description)</MudTd>
                        <MudTd>@($"{context.AccountCode} {context.AccountName}")</MudTd>
                        <MudTd>@FormatAmount(context.LineAmount)</MudTd>
                        <MudTd>@FormatAmount(context.TaxAmount)</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    }
</div>

@code
{
    [Parameter]
    public string SourceType { get; set; } = string.Empty;

    [Parameter]
    public Guid DocumentId { get; set; }

    [SupplyParameterFromQuery(Name = "origin")]
    public string? Origin { get; set; }

    private bool _isLoading;
    private bool _isReverseCommandRunning;
    private bool _isPurchaseOrderApprovalCommandRunning;
    private string? _errorText;
    private string? _reverseCommandMessage;
    private Severity _reverseCommandSeverity = Severity.Info;
    private string? _purchaseOrderApprovalCommandMessage;
    private Severity _purchaseOrderApprovalCommandSeverity = Severity.Info;
    private string? _purchaseOrderApprovalReason;
    private ShellAccountingDocumentReviewSummary? _document;
    private ShellPurchaseOrderReviewSummary? _purchaseOrder;
    private IReadOnlyList<ShellPurchaseOrderLifecycleAuditEntry> _purchaseOrderLifecycleAudit = Array.Empty<ShellPurchaseOrderLifecycleAuditEntry>();
    private ShellPurchaseOrderApprovalRequestSummary? _latestPurchaseOrderApprovalRequest;
    private ShellAccountingDocumentReverseRequestSummary? _latestReverseRequest;
    private ShellAccountingDocumentReverseApplyReadinessSummary? _reverseApplyReadiness;
    private ShellAccountingDocumentReverseExecutionPlanSummary? _reverseExecutionPlan;
    private IReadOnlyList<ShellSubledgerReverseBlockerSummary> _subledgerReverseBlockers = Array.Empty<ShellSubledgerReverseBlockerSummary>();
    private IReadOnlyDictionary<Guid, BlockerReverseDetail> _blockerReverseDetails = new Dictionary<Guid, BlockerReverseDetail>();
    private IReadOnlyList<ShellSettlementApplicationReversalSummary> _settlementApplicationReversals = Array.Empty<ShellSettlementApplicationReversalSummary>();
    private ShellBillReceiptMatchingSummary? _billReceiptHandoffSummary;
    private InventoryInvoiceShipmentIssueLaneSummary? _invoiceShipmentLaneSummary;
    private IReadOnlyList<FactRow> _factRows = Array.Empty<FactRow>();
    private bool WritesBlocked => ShellState.AreWritesBlocked;
    private bool IsCompanyReadyHandOff => string.Equals(Origin, "company-ready", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnParametersSetAsync() => await LoadDocumentStateAsync(clearReverseCommandMessage: true);

    private async Task LoadDocumentStateAsync(bool clearReverseCommandMessage)
    {
        _isLoading = true;
        _errorText = null;
        if (clearReverseCommandMessage)
        {
            _reverseCommandMessage = null;
            _reverseCommandSeverity = Severity.Info;
            _purchaseOrderApprovalCommandMessage = null;
            _purchaseOrderApprovalCommandSeverity = Severity.Info;
        }

        _document = null;
        _purchaseOrder = null;
        _purchaseOrderLifecycleAudit = Array.Empty<ShellPurchaseOrderLifecycleAuditEntry>();
        _latestPurchaseOrderApprovalRequest = null;
        _latestReverseRequest = null;
        _reverseApplyReadiness = null;
        _reverseExecutionPlan = null;
        _subledgerReverseBlockers = Array.Empty<ShellSubledgerReverseBlockerSummary>();
        _blockerReverseDetails = new Dictionary<Guid, BlockerReverseDetail>();
        _settlementApplicationReversals = Array.Empty<ShellSettlementApplicationReversalSummary>();
        _billReceiptHandoffSummary = null;
        _invoiceShipmentLaneSummary = null;
        _factRows = Array.Empty<FactRow>();

        if (!await EnsureWriteGateStateAsync())
        {
            _isLoading = false;
            return;
        }

        if (IsPurchaseOrderSourceType(SourceType))
        {
            await LoadPurchaseOrderStateAsync();
            _isLoading = false;
            return;
        }

        var documentResult = await ReviewClient.GetDocumentAsync(ShellState.ActiveCompany.Id, SourceType, DocumentId);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(documentResult, CancellationToken.None))
        {
            _isLoading = false;
            return;
        }

        var document = documentResult.Value;
        if (document is null)
        {
            _errorText = documentResult.IsNotFound
                ? $"The {GetSourceLabel(SourceType).ToLowerInvariant()} could not be found in company {ShellState.ActiveCompany.CompanyCode}."
                : documentResult.ErrorMessage ?? $"Unable to load the {GetSourceLabel(SourceType).ToLowerInvariant()} detail.";
            _isLoading = false;
            return;
        }

        _document = document;
        _factRows = BuildFactRows(document);
        if (IsBillReceiptReview(document))
        {
            var matchingResult = await BillReceiptMatchingClient.GetBillSummaryAsync(
                ShellState.ActiveCompany.Id,
                document.Id,
                CancellationToken.None);
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(matchingResult, CancellationToken.None))
            {
                _isLoading = false;
                return;
            }

            _billReceiptHandoffSummary = matchingResult.Value;
            CapturePageError(matchingResult.ErrorMessage);
        }
        else if (IsInvoiceShipmentReview(document))
        {
            _invoiceShipmentLaneSummary = await InventoryShipmentClient.GetInvoiceLaneSummaryAsync(
                ShellState.ActiveCompany.Id,
                document.Id,
                CancellationToken.None);
        }

        var reverseRequestResult = await ReviewClient.GetLatestReverseRequestAsync(ShellState.ActiveCompany.Id, SourceType, DocumentId);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(reverseRequestResult, CancellationToken.None))
        {
            _isLoading = false;
            return;
        }

        _latestReverseRequest = reverseRequestResult.Value;
        if (_latestReverseRequest is null)
        {
            CapturePageError(reverseRequestResult.ErrorMessage);
        }

        if (_latestReverseRequest is not null)
        {
            var asOfDate = DateOnly.FromDateTime(DateTime.UtcNow);
            var readinessResult = await ReviewClient.GetReverseRequestApplyReadinessAsync(
                ShellState.ActiveCompany.Id,
                SourceType,
                DocumentId,
                _latestReverseRequest.RequestId,
                asOfDate);
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(readinessResult, CancellationToken.None))
            {
                _isLoading = false;
                return;
            }

            _reverseApplyReadiness = readinessResult.Value;
            if (_reverseApplyReadiness is null)
            {
                CapturePageError(readinessResult.ErrorMessage);
            }

            var executionPlanResult = await ReviewClient.GetReverseRequestExecutionPlanAsync(
                ShellState.ActiveCompany.Id,
                SourceType,
                DocumentId,
                _latestReverseRequest.RequestId,
                asOfDate);
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(executionPlanResult, CancellationToken.None))
            {
                _isLoading = false;
                return;
            }

            _reverseExecutionPlan = executionPlanResult.Value;
            if (_reverseExecutionPlan is null)
            {
                CapturePageError(executionPlanResult.ErrorMessage);
            }
        }

        var blockersResult = await ReviewClient.ListSubledgerReverseBlockersAsync(ShellState.ActiveCompany.Id, SourceType, DocumentId);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(blockersResult, CancellationToken.None))
        {
            _isLoading = false;
            return;
        }

        _subledgerReverseBlockers = blockersResult.Value ?? Array.Empty<ShellSubledgerReverseBlockerSummary>();
        CapturePageError(blockersResult.ErrorMessage);
        var blockerReverseDetails = await LoadBlockerReverseDetailsAsync(_subledgerReverseBlockers);
        if (blockerReverseDetails is null)
        {
            _isLoading = false;
            return;
        }

        _blockerReverseDetails = blockerReverseDetails;

        var reversalsResult = await ReviewClient.ListSettlementApplicationReversalsAsync(ShellState.ActiveCompany.Id, SourceType, DocumentId);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(reversalsResult, CancellationToken.None))
        {
            _isLoading = false;
            return;
        }

        _settlementApplicationReversals = reversalsResult.Value ?? Array.Empty<ShellSettlementApplicationReversalSummary>();
        CapturePageError(reversalsResult.ErrorMessage);
        _isLoading = false;
    }

    private async Task LoadPurchaseOrderStateAsync()
    {
        var documentResult = await ReviewClient.GetPurchaseOrderAsync(ShellState.ActiveCompany.Id, DocumentId, CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(documentResult, CancellationToken.None))
        {
            return;
        }

        var purchaseOrder = documentResult.Value;
        if (purchaseOrder is null)
        {
            _errorText = documentResult.IsNotFound
                ? $"The purchase order could not be found in company {ShellState.ActiveCompany.CompanyCode}."
                : documentResult.ErrorMessage ?? "Unable to load the purchase order detail.";
            return;
        }

        _purchaseOrder = purchaseOrder;
        var auditResult = await ReviewClient.ListPurchaseOrderLifecycleAuditAsync(
            ShellState.ActiveCompany.Id,
            DocumentId,
            50,
            CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(auditResult, CancellationToken.None))
        {
            return;
        }

        _purchaseOrderLifecycleAudit = auditResult.Value ?? Array.Empty<ShellPurchaseOrderLifecycleAuditEntry>();
        CapturePageError(auditResult.ErrorMessage);

        var approvalRequestResult = await ReviewClient.GetLatestPurchaseOrderApprovalRequestAsync(
            ShellState.ActiveCompany.Id,
            DocumentId,
            CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(approvalRequestResult, CancellationToken.None))
        {
            return;
        }

        _latestPurchaseOrderApprovalRequest = approvalRequestResult.Value;
        if (_latestPurchaseOrderApprovalRequest is null && !approvalRequestResult.IsNotFound)
        {
            CapturePageError(approvalRequestResult.ErrorMessage);
        }
    }

    private async Task<IReadOnlyDictionary<Guid, BlockerReverseDetail>?> LoadBlockerReverseDetailsAsync(
        IReadOnlyList<ShellSubledgerReverseBlockerSummary> blockers)
    {
        var details = new Dictionary<Guid, BlockerReverseDetail>();
        var asOfDate = DateOnly.FromDateTime(DateTime.UtcNow);

        foreach (var blocker in blockers)
        {
            if (blocker.ReverseRequestId is null)
            {
                continue;
            }

            var readinessResult = await ReviewClient.GetReverseRequestApplyReadinessAsync(
                ShellState.ActiveCompany.Id,
                blocker.SettlementSourceType,
                blocker.SettlementSourceId,
                blocker.ReverseRequestId.Value,
                asOfDate);
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(readinessResult, CancellationToken.None))
            {
                return null;
            }

            var planResult = await ReviewClient.GetReverseRequestExecutionPlanAsync(
                ShellState.ActiveCompany.Id,
                blocker.SettlementSourceType,
                blocker.SettlementSourceId,
                blocker.ReverseRequestId.Value,
                asOfDate);
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(planResult, CancellationToken.None))
            {
                return null;
            }

            details[blocker.SettlementApplicationId] = new BlockerReverseDetail(
                blocker.SettlementApplicationId,
                readinessResult.Value,
                planResult.Value);

            CapturePageError(readinessResult.ErrorMessage);
            CapturePageError(planResult.ErrorMessage);
        }

        return details;
    }

    private async Task RequestReverseAsync()
    {
        if (_document is null || TryBlockWrites())
        {
            return;
        }

        await RunReverseCommandAsync(
            () => ReviewClient.RequestReverseAsync(ShellState.ActiveCompany.Id, _document.SourceType, _document.Id),
            "Reverse request recorded.");
    }

    private async Task RequestPurchaseOrderApprovalAsync()
    {
        if (_purchaseOrder is null || TryBlockPurchaseOrderApprovalWrites())
        {
            return;
        }

        await RunPurchaseOrderApprovalCommandAsync(
            () => ReviewClient.RequestPurchaseOrderApprovalAsync(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                _purchaseOrder.Id,
                _purchaseOrderApprovalReason,
                CancellationToken.None),
            "Purchase order approval request recorded.");
    }

    private async Task SubmitPurchaseOrderApprovalRequestAsync()
    {
        if (_purchaseOrder is null || _latestPurchaseOrderApprovalRequest is null || TryBlockPurchaseOrderApprovalWrites())
        {
            return;
        }

        await RunPurchaseOrderApprovalCommandAsync(
            () => ReviewClient.SubmitPurchaseOrderApprovalRequestAsync(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                _purchaseOrder.Id,
                _latestPurchaseOrderApprovalRequest.RequestId,
                CancellationToken.None),
            "Purchase order approval request submitted.");
    }

    private async Task ApprovePurchaseOrderFromApprovalRequestAsync()
    {
        if (_purchaseOrder is null || !CanApprovePurchaseOrderFromApprovalRequest() || TryBlockPurchaseOrderApprovalWrites())
        {
            return;
        }

        await RunPurchaseOrderLifecycleCommandAsync(
            () => ReviewClient.ApprovePurchaseOrderAsync(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                _purchaseOrder.Id,
                CancellationToken.None),
            "Purchase order approved.");
    }

    private async Task ReleasePurchaseOrderAsync()
    {
        if (_purchaseOrder is null || !CanReleasePurchaseOrder() || TryBlockPurchaseOrderApprovalWrites())
        {
            return;
        }

        await RunPurchaseOrderLifecycleCommandAsync(
            () => ReviewClient.ReleasePurchaseOrderAsync(
                ShellState.ActiveCompany.Id,
                ShellState.CurrentUserId,
                _purchaseOrder.Id,
                CancellationToken.None),
            "Purchase order released.");
    }

    private async Task SubmitReverseRequestAsync()
    {
        if (_document is null || _latestReverseRequest is null || TryBlockWrites())
        {
            return;
        }

        await RunReverseCommandAsync(
            () => ReviewClient.SubmitReverseRequestAsync(ShellState.ActiveCompany.Id, _document.SourceType, _document.Id, _latestReverseRequest.RequestId),
            "Reverse request submitted.");
    }

    private async Task ExecuteReverseRequestAsync()
    {
        if (_document is null || _latestReverseRequest is null || TryBlockWrites())
        {
            return;
        }

        var asOfDate = DateOnly.FromDateTime(DateTime.UtcNow);
        await RunReverseCommandAsync(
            () => ReviewClient.ExecuteReverseRequestAsync(ShellState.ActiveCompany.Id, _document.SourceType, _document.Id, _latestReverseRequest.RequestId, asOfDate),
            "Governed reverse execution requested.");
    }

    private async Task RequestBlockerUnapplyAsync(ShellSubledgerReverseBlockerSummary blocker)
    {
        if (TryBlockWrites())
        {
            return;
        }

        await RunReverseCommandAsync(
            () => ReviewClient.RequestReverseAsync(ShellState.ActiveCompany.Id, blocker.SettlementSourceType, blocker.SettlementSourceId),
            $"Governed unapply reverse request recorded for {DisplayDocumentLink(blocker.SettlementSourceDisplayNumber, blocker.SettlementSourceType)}.");
    }

    private async Task SubmitBlockerUnapplyAsync(ShellSubledgerReverseBlockerSummary blocker)
    {
        if (blocker.ReverseRequestId is null || TryBlockWrites())
        {
            return;
        }

        await RunReverseCommandAsync(
            () => ReviewClient.SubmitReverseRequestAsync(
                ShellState.ActiveCompany.Id,
                blocker.SettlementSourceType,
                blocker.SettlementSourceId,
                blocker.ReverseRequestId.Value),
            $"Governed unapply reverse request submitted for {DisplayDocumentLink(blocker.SettlementSourceDisplayNumber, blocker.SettlementSourceType)}.");
    }

    private async Task ExecuteBlockerUnapplyAsync(ShellSubledgerReverseBlockerSummary blocker)
    {
        if (blocker.ReverseRequestId is null || TryBlockWrites())
        {
            return;
        }

        var asOfDate = DateOnly.FromDateTime(DateTime.UtcNow);
        await RunReverseCommandAsync(
            () => ReviewClient.ExecuteReverseRequestAsync(
                ShellState.ActiveCompany.Id,
                blocker.SettlementSourceType,
                blocker.SettlementSourceId,
                blocker.ReverseRequestId.Value,
                asOfDate),
            $"Governed unapply execution requested for {DisplayDocumentLink(blocker.SettlementSourceDisplayNumber, blocker.SettlementSourceType)}.");
    }

    private async Task RunReverseCommandAsync(
        Func<Task<WebShellAuthenticatedApiResult<ShellAccountingDocumentReverseCommandResultSummary>>> command,
        string fallbackSuccessMessage)
    {
        _isReverseCommandRunning = true;
        _reverseCommandMessage = null;
        _reverseCommandSeverity = Severity.Info;

        try
        {
            var result = await command();
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
            {
                return;
            }

            if (result.Value is null)
            {
                _reverseCommandSeverity = Severity.Warning;
                _reverseCommandMessage = result.ErrorMessage ?? "The reverse command did not return a response. Check API availability and business-session headers.";
            }
            else
            {
                _reverseCommandSeverity = IsReverseCommandSuccess(result.Value) ? Severity.Success : Severity.Warning;
                _reverseCommandMessage = BuildReverseCommandMessage(result.Value, fallbackSuccessMessage);
            }

            await LoadDocumentStateAsync(clearReverseCommandMessage: false);
        }
        catch (Exception ex)
        {
            _reverseCommandSeverity = Severity.Error;
            _reverseCommandMessage = ex.Message;
        }
        finally
        {
            _isReverseCommandRunning = false;
        }
    }

    private async Task RunPurchaseOrderApprovalCommandAsync(
        Func<Task<WebShellAuthenticatedApiResult<ShellPurchaseOrderApprovalRequestCommandResultSummary>>> command,
        string fallbackSuccessMessage)
    {
        _isPurchaseOrderApprovalCommandRunning = true;
        _purchaseOrderApprovalCommandMessage = null;
        _purchaseOrderApprovalCommandSeverity = Severity.Info;

        try
        {
            var result = await command();
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
            {
                return;
            }

            if (result.Value is null)
            {
                _purchaseOrderApprovalCommandSeverity = Severity.Warning;
                _purchaseOrderApprovalCommandMessage = result.ErrorMessage ?? "The purchase order approval command did not return a response.";
            }
            else
            {
                _purchaseOrderApprovalCommandSeverity = IsPurchaseOrderApprovalCommandSuccess(result.Value)
                    ? Severity.Success
                    : Severity.Warning;
                _purchaseOrderApprovalCommandMessage = string.IsNullOrWhiteSpace(result.Value.Message)
                    ? fallbackSuccessMessage
                    : result.Value.Message;
                _latestPurchaseOrderApprovalRequest = result.Value.Request;
                _purchaseOrderApprovalReason = null;
            }

            await LoadPurchaseOrderStateAsync();
        }
        catch (Exception ex)
        {
            _purchaseOrderApprovalCommandSeverity = Severity.Error;
            _purchaseOrderApprovalCommandMessage = ex.Message;
        }
        finally
        {
            _isPurchaseOrderApprovalCommandRunning = false;
        }
    }

    private async Task RunPurchaseOrderLifecycleCommandAsync(
        Func<Task<WebShellAuthenticatedApiResult<ShellSourceDocumentDraftSaveResult>>> command,
        string fallbackSuccessMessage)
    {
        _isPurchaseOrderApprovalCommandRunning = true;
        _purchaseOrderApprovalCommandMessage = null;
        _purchaseOrderApprovalCommandSeverity = Severity.Info;

        try
        {
            var result = await command();
            if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
            {
                return;
            }

            if (result.Value is null)
            {
                _purchaseOrderApprovalCommandSeverity = Severity.Warning;
                _purchaseOrderApprovalCommandMessage = result.ErrorMessage ?? "The purchase order lifecycle command did not return a response.";
            }
            else
            {
                _purchaseOrderApprovalCommandSeverity = IsSuccessfulPurchaseOrderLifecycleStatus(result.Value.Status)
                    ? Severity.Success
                    : Severity.Warning;
                _purchaseOrderApprovalCommandMessage = string.IsNullOrWhiteSpace(result.Value.DisplayNumber)
                    ? fallbackSuccessMessage
                    : $"Purchase order {result.Value.DisplayNumber} moved to {FormatPurchaseOrderQuantityStatus(result.Value.Status)}.";
            }

            await LoadPurchaseOrderStateAsync();
        }
        catch (Exception ex)
        {
            _purchaseOrderApprovalCommandSeverity = Severity.Error;
            _purchaseOrderApprovalCommandMessage = ex.Message;
        }
        finally
        {
            _isPurchaseOrderApprovalCommandRunning = false;
        }
    }

    private async Task<bool> EnsureWriteGateStateAsync()
    {
        await ShellState.EnsureHydratedAsync();
        var probe = await SessionClient.ProbeContextAsync(CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe, CancellationToken.None))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(probe.ErrorMessage))
        {
            _errorText = probe.ErrorMessage;
        }

        return true;
    }

    private void CapturePageError(string? message)
    {
        if (!string.IsNullOrWhiteSpace(message))
        {
            _errorText ??= message;
        }
    }

    private bool TryBlockWrites()
    {
        if (!WritesBlocked)
        {
            return false;
        }

        _reverseCommandSeverity = Severity.Warning;
        _reverseCommandMessage = ShellState.WriteBlockMessage;
        return true;
    }

    private bool TryBlockPurchaseOrderApprovalWrites()
    {
        if (!WritesBlocked)
        {
            return false;
        }

        _purchaseOrderApprovalCommandSeverity = Severity.Warning;
        _purchaseOrderApprovalCommandMessage = ShellState.WriteBlockMessage;
        return true;
    }

    private static string GetSourceLabel(string? sourceType) =>
        sourceType?.Trim().ToLowerInvariant() switch
        {
            "invoice" => "Invoice",
            "credit_note" => "Credit Note",
            "bill" => "Bill",
            "vendor_credit" => "Vendor Credit",
            "receive_payment" => "Receive Payment",
            "credit_application" => "Credit Application",
            "pay_bill" => "Pay Bill",
            "vendor_credit_application" => "Vendor Credit Application",
            "invoice_reversal" => "Invoice Reversal",
            "credit_note_reversal" => "Credit Note Reversal",
            "bill_reversal" => "Bill Reversal",
            "vendor_credit_reversal" => "Vendor Credit Reversal",
            "receive_payment_reversal" => "Receive Payment Reversal",
            "credit_application_reversal" => "Credit Application Reversal",
            "pay_bill_reversal" => "Pay Bill Reversal",
            "vendor_credit_application_reversal" => "Vendor Credit Application Reversal",
            "purchase_order" => "Purchase Order",
            _ => "Document"
        };

    private static bool IsPurchaseOrderSourceType(string? sourceType) =>
        string.Equals(sourceType?.Trim(), "purchase_order", StringComparison.OrdinalIgnoreCase);

    private static string BuildPurchaseOrderBrowserHref(ShellPurchaseOrderReviewSummary purchaseOrder) =>
        $"/documents/source-browser?sourceType=purchase_order&counterpartyRole=vendor&counterpartyId={purchaseOrder.VendorId:D}" +
        $"&origin={Uri.EscapeDataString("Current source detail")}" +
        $"&returnHref={Uri.EscapeDataString($"/documents/purchase_order/{purchaseOrder.Id:D}")}" +
        $"&returnLabel={Uri.EscapeDataString("Back to purchase order")}";

    private static string GetPurchaseOrderApprovalThresholdTitle(ShellPurchaseOrderReviewSummary purchaseOrder)
    {
        var estimated = purchaseOrder.ApprovalAuthority.EstimatedOrderAmount ?? purchaseOrder.EstimatedAmount;
        var amountLabel = estimated.HasValue ? estimated.Value.ToString("N2") : "n/a";
        if (!estimated.HasValue)
        {
            return $"Threshold not evaluated | {amountLabel}";
        }

        return purchaseOrder.ApprovalAuthority.RequiresGovernanceApproval
            ? $"Governance required | {amountLabel}"
            : $"Approver allowed | {amountLabel}";
    }

    private static string FormatStatusMovement(string? fromStatus, string? toStatus)
    {
        var from = string.IsNullOrWhiteSpace(fromStatus) ? "n/a" : FormatPurchaseOrderQuantityStatus(fromStatus);
        var to = string.IsNullOrWhiteSpace(toStatus) ? "n/a" : FormatPurchaseOrderQuantityStatus(toStatus);
        return $"{from} -> {to}";
    }

    private static string FormatPurchaseOrderAuditAction(string? action) =>
        action?.Trim().ToLowerInvariant() switch
        {
            "purchase_order_created" => "Created",
            "purchase_order_draft_updated" => "Draft Updated",
            "purchase_order_approved" => "Approved",
            "purchase_order_approval_reversed" => "Approval Reversed",
            "purchase_order_issued" => "Issued",
            "purchase_order_released" => "Released",
            "purchase_order_reopened_for_amendment" => "Reopened For Amendment",
            "purchase_order_closed" => "Closed",
            "purchase_order_cancelled" => "Cancelled",
            _ => string.IsNullOrWhiteSpace(action) ? "Unknown" : action
        };

    private static string FormatPurchaseOrderQuantityStatus(string? status) =>
        status?.Trim().ToLowerInvariant() switch
        {
            "draft" => "Draft",
            "approved" => "Approved",
            "issued" => "Issued",
            "closed" => "Closed",
            "cancelled" => "Cancelled",
            "submitted" => "Submitted",
            "pending" => "Pending",
            "rejected" => "Rejected",
            "not_received" => "Not Received",
            "partially_received" => "Partially Received",
            "fully_received" => "Fully Received",
            "not_billed" => "Not Billed",
            "partially_billed" => "Partially Billed",
            "fully_billed" => "Fully Billed",
            "open" => "Open",
            "complete" => "Complete",
            _ => string.IsNullOrWhiteSpace(status) ? "Unknown" : status
        };

    private static string GetPurchaseOrderApprovalRequestTitle(ShellPurchaseOrderApprovalRequestSummary? request) =>
        request is null
            ? "No request"
            : $"{FormatPurchaseOrderQuantityStatus(request.RequestStatus)} | {FormatPurchaseOrderQuantityStatus(request.ApprovalStatus)}";

    private static string GetPurchaseOrderApprovalRequestSummary(ShellPurchaseOrderApprovalRequestSummary? request)
    {
        if (request is null)
        {
            return "No approval request has been recorded for this purchase order.";
        }

        var amount = request.EstimatedAmount?.ToString("N2") ?? "n/a";
        var threshold = request.RequiresGovernanceApproval
            ? $"governance threshold required above {request.ThresholdAmount:N2}"
            : $"within temporary threshold {request.ThresholdAmount:N2}";
        var reason = string.IsNullOrWhiteSpace(request.Reason) ? "no reason recorded" : request.Reason;
        return $"{amount}; {threshold}; {reason}.";
    }

    private bool CanRequestPurchaseOrderApproval() =>
        _purchaseOrder is not null &&
        string.Equals(_purchaseOrder.Status, "draft", StringComparison.OrdinalIgnoreCase) &&
        (_latestPurchaseOrderApprovalRequest is null ||
         !string.Equals(_latestPurchaseOrderApprovalRequest.ApprovalStatus, "pending", StringComparison.OrdinalIgnoreCase));

    private bool CanSubmitPurchaseOrderApprovalRequest() =>
        _purchaseOrder is not null &&
        _latestPurchaseOrderApprovalRequest is not null &&
        string.Equals(_purchaseOrder.Status, "draft", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(_latestPurchaseOrderApprovalRequest.RequestStatus, "draft", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(_latestPurchaseOrderApprovalRequest.ApprovalStatus, "pending", StringComparison.OrdinalIgnoreCase);

    private bool CanApprovePurchaseOrderFromApprovalRequest() =>
        _purchaseOrder is not null &&
        _latestPurchaseOrderApprovalRequest is not null &&
        string.Equals(_purchaseOrder.Status, "draft", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(_latestPurchaseOrderApprovalRequest.RequestStatus, "submitted", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(_latestPurchaseOrderApprovalRequest.ApprovalStatus, "pending", StringComparison.OrdinalIgnoreCase);

    private bool CanReleasePurchaseOrder() =>
        _purchaseOrder is not null &&
        string.Equals(_purchaseOrder.Status, "approved", StringComparison.OrdinalIgnoreCase);

    private string GetPurchaseOrderApprovalControlSummary()
    {
        if (_purchaseOrder is null)
        {
            return "Purchase order approval state is unavailable.";
        }

        if (!string.Equals(_purchaseOrder.Status, "draft", StringComparison.OrdinalIgnoreCase))
        {
            return $"Approval requests are only started from draft POs. Current status is {FormatPurchaseOrderQuantityStatus(_purchaseOrder.Status)}.";
        }

        if (_latestPurchaseOrderApprovalRequest is not null &&
            string.Equals(_latestPurchaseOrderApprovalRequest.RequestStatus, "submitted", StringComparison.OrdinalIgnoreCase) &&
            string.Equals(_latestPurchaseOrderApprovalRequest.ApprovalStatus, "pending", StringComparison.OrdinalIgnoreCase))
        {
            return "The latest approval request is already submitted and waiting in the approval queue.";
        }

        return "Review the latest approval request before taking another PO approval action.";
    }

