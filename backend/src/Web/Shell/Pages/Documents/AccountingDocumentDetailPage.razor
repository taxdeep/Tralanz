        {
            "request_recording_only" => "Request Recording Only",
            "governed_execution_skeleton" => "Governed Execution Skeleton",
            "governed_execution_completed" => "Governed Execution Completed",
            "governed_execution_orchestration_plan" => "Governed Execution Plan",
            _ => string.IsNullOrWhiteSpace(executionMode) ? "Unknown" : executionMode
        };

    private static string FormatPlanStepStatus(string stepStatus) =>
        stepStatus switch
        {
            "ready" => "Ready",
            "blocked" => "Blocked",
            "planned" => "Planned",
