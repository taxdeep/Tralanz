        ShellAccountingDocumentReviewSummary? document,
        string actionCode) =>
        document?.LifecycleActions.FirstOrDefault(
            action => string.Equals(action.ActionCode, actionCode, StringComparison.OrdinalIgnoreCase));

    private static bool IsReverseCommandSuccess(ShellAccountingDocumentReverseCommandResultSummary result) =>
        result.OutcomeCode is
            "request_recorded" or
            "submitted" or
            "execution_request_recorded" or
            "journal_entry_reversed" or
            "execution_already_completed" or
            "accepted";

    private static string BuildReverseCommandMessage(
        ShellAccountingDocumentReverseCommandResultSummary result,
        string fallbackSuccessMessage)
    {
        if (!string.IsNullOrWhiteSpace(result.Message))
        {
            return result.Message;
        }

        if (!string.IsNullOrWhiteSpace(result.OutcomeCode))
        {
            return $"{fallbackSuccessMessage} Outcome: {result.OutcomeCode}.";
        }

        return fallbackSuccessMessage;
    }

    private static IReadOnlyList<FactRow> BuildFactRows(ShellAccountingDocumentReviewSummary document)
    {
        var rows = new List<FactRow>
        {
            new("Entity Number", document.EntityNumber),
            new("Status", document.Status),
            new("Lifecycle Mode", FormatLifecycleMode(document.LifecycleMode)),
            new("Document Date", document.DocumentDate.ToString("yyyy-MM-dd")),
            new("Due Date", document.DueDate?.ToString("yyyy-MM-dd") ?? "No due date"),
            new("Transaction Currency", document.TransactionCurrencyCode),
            new("Base Currency", document.BaseCurrencyCode),
            new("Memo", string.IsNullOrWhiteSpace(document.Memo) ? "No memo" : document.Memo!)
        };

        if (document.CounterpartyId is not null)
        {
            rows.Add(new(document.CounterpartyLabel, document.CounterpartyId.Value.ToString("D")));
        }

        if (document.ControlAccountId is not null)
        {
            rows.Add(new(document.ControlAccountLabel, document.ControlAccountId.Value.ToString("D")));
        }

        if (document.JournalEntryId is not null)
        {
            rows.Add(new(
                "Journal Entry",
                string.IsNullOrWhiteSpace(document.JournalEntryDisplayNumber)
                    ? document.JournalEntryId.Value.ToString("D")
                    : $"{document.JournalEntryDisplayNumber} | {document.JournalEntryId.Value:D}"));
        }

        if (!string.IsNullOrWhiteSpace(document.JournalEntryStatus))
        {
            rows.Add(new("Journal Entry Status", document.JournalEntryStatus!));
        }

        if (document.JournalEntryPostedAt is not null)
        {
            rows.Add(new("Journal Entry Posted At", document.JournalEntryPostedAt.Value.ToString("yyyy-MM-dd HH:mm:ss zzz")));
        }

        if (document.JournalEntryVoidedAt is not null)
        {
            rows.Add(new("Journal Entry Voided At", document.JournalEntryVoidedAt.Value.ToString("yyyy-MM-dd HH:mm:ss zzz")));
        }

        if (document.JournalEntryReversedAt is not null)
        {
            rows.Add(new("Journal Entry Reversed At", document.JournalEntryReversedAt.Value.ToString("yyyy-MM-dd HH:mm:ss zzz")));
        }

        return rows;
    }

    private static IReadOnlyList<FactRow> BuildReverseRequestRows(ShellAccountingDocumentReverseRequestSummary request)
    {
        var rows = new List<FactRow>
        {
            new("Request Id", request.RequestId.ToString("D")),
            new("Request Status", string.IsNullOrWhiteSpace(request.RequestStatus) ? "Unknown" : request.RequestStatus),
            new("Execution Status", string.IsNullOrWhiteSpace(request.ExecutionStatus) ? "Unknown" : request.ExecutionStatus),
            new("Requested At", request.RequestedAt.ToString("yyyy-MM-dd HH:mm:ss zzz")),
            new("Action", request.ActionLabel),
            new("Availability", FormatAvailabilityMode(request.AvailabilityMode, request.IsAvailable)),
            new("Reason", request.Reason),
            new("Requested By", FormatActor(request.RequestedByActorType, request.RequestedByActorId))
        };

        if (request.SubmittedAt is not null)
        {
            rows.Add(new("Submitted At", request.SubmittedAt.Value.ToString("yyyy-MM-dd HH:mm:ss zzz")));
            rows.Add(new("Submitted By", FormatActor(request.SubmittedByActorType, request.SubmittedByActorId)));
        }

        if (request.CancelledAt is not null)
        {
            rows.Add(new("Cancelled At", request.CancelledAt.Value.ToString("yyyy-MM-dd HH:mm:ss zzz")));
            rows.Add(new("Cancelled By", FormatActor(request.CancelledByActorType, request.CancelledByActorId)));
        }

        if (request.ExecutionRequestedAt is not null)
        {
            rows.Add(new("Execution Requested At", request.ExecutionRequestedAt.Value.ToString("yyyy-MM-dd HH:mm:ss zzz")));
            rows.Add(new("Execution Requested By", FormatActor(request.ExecutionRequestedByActorType, request.ExecutionRequestedByActorId)));
        }

        if (request.ExecutionCompletedAt is not null)
        {
            rows.Add(new("Execution Completed At", request.ExecutionCompletedAt.Value.ToString("yyyy-MM-dd HH:mm:ss zzz")));
            rows.Add(new("Execution Completed By", FormatActor(request.ExecutionCompletedByActorType, request.ExecutionCompletedByActorId)));
        }

        if (!string.IsNullOrWhiteSpace(request.CompensationJournalEntryDisplayNumber) || request.CompensationJournalEntryId is not null)
        {
            rows.Add(new(
                "Compensation Journal Entry",
                string.IsNullOrWhiteSpace(request.CompensationJournalEntryDisplayNumber)
                    ? request.CompensationJournalEntryId?.ToString("D") ?? "Unavailable"
                    : $"{request.CompensationJournalEntryDisplayNumber} | {request.CompensationJournalEntryId:D}"));
        }

        if (!string.IsNullOrWhiteSpace(request.CompensationSourceType))
        {
            rows.Add(new("Compensation Source Type", GetSourceLabel(request.CompensationSourceType)));
        }

        if (!string.IsNullOrWhiteSpace(request.JournalEntryDisplayNumber) || request.JournalEntryId is not null)
        {
            rows.Add(new(
                "Linked Journal Entry",
                string.IsNullOrWhiteSpace(request.JournalEntryDisplayNumber)
                    ? request.JournalEntryId?.ToString("D") ?? "Unavailable"
                    : $"{request.JournalEntryDisplayNumber} | {request.JournalEntryId:D}"));
        }

        if (!string.IsNullOrWhiteSpace(request.JournalEntryStatus))
        {
            rows.Add(new("Linked Journal Entry Status", request.JournalEntryStatus!));
        }

        return rows;
    }

