    private static string BuildJournalEntryReviewHref(Guid journalEntryId) =>
        $"/gl/journal-entry/review/{journalEntryId:D}";

    private static bool IsJournalBackedSource(ShellAccountingSourceDocumentBrowserItem item) =>
        item.SourceType.Trim().ToLowerInvariant() is
            "invoice" or
            "credit_note" or
            "bill" or
            "vendor_credit" or
            "receive_payment" or
            "credit_application" or
            "pay_bill" or
            "vendor_credit_application";

    private static bool ShouldShowMissingJournalEntryWarning(ShellAccountingSourceDocumentBrowserItem item) =>
        IsJournalBackedSource(item) &&
        IsJournalRequiredStatus(item.Status);

    private static bool IsJournalRequiredStatus(string? status)
    {
        var normalized = status?.Trim().ToLowerInvariant();
        return normalized is not (null or "" or "draft" or "submitted" or "cancelled" or "canceled" or "voided" or "reversed");
    }

    private static string FormatJournalEntryIdentity(ShellAccountingSourceDocumentBrowserItem item)
    {
        if (!string.IsNullOrWhiteSpace(item.JournalEntryDisplayNumber))
        {
            return item.JournalEntryDisplayNumber;
        }

        var shortId = item.JournalEntryId.HasValue
            ? item.JournalEntryId.Value.ToString("N")[..8]
            : "pending";
        return $"JE {shortId}";
    }

    private static string BuildJournalEntryCaption(ShellAccountingSourceDocumentBrowserItem item)
    {
        if (item.JournalEntryVoidedAt.HasValue)
        {
            return $"Voided {item.JournalEntryVoidedAt.Value:yyyy-MM-dd HH:mm}";
        }

        if (item.JournalEntryReversedAt.HasValue)
        {
            return $"Reversed {item.JournalEntryReversedAt.Value:yyyy-MM-dd HH:mm}";
        }

        if (item.JournalEntryPostedAt.HasValue)
        {
            return $"Posted {item.JournalEntryPostedAt.Value:yyyy-MM-dd HH:mm}";
        }

        return FormatControlStatus(item.JournalEntryStatus ?? "review");
    }

    private static Color GetJournalEntryStatusColor(string? status)
    {
        var normalized = status?.Trim().ToLowerInvariant();
        return normalized switch
        {
            "posted" => Color.Success,
            "voided" or "reversed" => Color.Warning,
            "draft" => Color.Default,
            _ => Color.Info
        };
    }

    private static bool HasPurchaseOrderAnchorGate(ShellAccountingSourceDocumentBrowserItem item) =>
        IsPurchaseOrder(item) &&
        !string.IsNullOrWhiteSpace(item.AnchorGovernanceSummary);

    private static bool HasReceiptControlStatuses(ShellAccountingSourceDocumentBrowserItem item) =>
        IsReceipt(item) &&
        (!string.IsNullOrWhiteSpace(item.ReceiptActivationStatus) ||
         !string.IsNullOrWhiteSpace(item.ReceiptValuationStatus) ||
         !string.IsNullOrWhiteSpace(item.ReceiptCostLayerEmissionStatus) ||
         !string.IsNullOrWhiteSpace(item.ReceiptGrIrBridgeStatus) ||
         !string.IsNullOrWhiteSpace(item.ReceiptGrIrSettlementStatus) ||
         !string.IsNullOrWhiteSpace(item.ReceiptPurchaseVarianceStatus));

    private static bool HasShipmentControlStatuses(ShellAccountingSourceDocumentBrowserItem item) =>
        IsShipment(item) &&
        (!string.IsNullOrWhiteSpace(item.ShipmentIssueMatchStatus) ||
         item.ShipmentIssuedQuantity.HasValue ||
         item.ShipmentRemainingToIssueQuantity.HasValue);

    private static bool HasSalesOrderOutboundStatuses(ShellAccountingSourceDocumentBrowserItem item) =>
        string.Equals(item.SourceType, "sales_order", StringComparison.OrdinalIgnoreCase) &&
        !string.IsNullOrWhiteSpace(item.SalesOrderAggregateStatus);

    private static IReadOnlyList<(string Label, string Value)> BuildReceiptControlStatusChips(ShellAccountingSourceDocumentBrowserItem item)
    {
        var statuses = new List<(string Label, string Value)>(6);
        AddReceiptStatus(statuses, "INV", item.ReceiptActivationStatus);
        AddReceiptStatus(statuses, "VAL", item.ReceiptValuationStatus);
        AddReceiptStatus(statuses, "LAYER", item.ReceiptCostLayerEmissionStatus);
        AddReceiptStatus(statuses, "GR/IR", item.ReceiptGrIrBridgeStatus);
        AddReceiptStatus(statuses, "SETTLE", item.ReceiptGrIrSettlementStatus);
        AddReceiptStatus(statuses, "PPV", item.ReceiptPurchaseVarianceStatus);
        return statuses;
    }

    private static void AddReceiptStatus(List<(string Label, string Value)> statuses, string label, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            statuses.Add(($"{label}: {FormatControlStatus(value)}", value));
        }
    }

    private static string FormatControlStatus(string status) =>
        status.Replace('_', ' ').Trim();

    private static Color GetReceiptControlStatusColor(string? status)
    {
        var normalized = status?.Trim().ToLowerInvariant();
        if (normalized is null)
        {
            return Color.Default;
        }

        if (normalized.Contains("posted", StringComparison.Ordinal) ||
            normalized.Contains("settled", StringComparison.Ordinal) ||
            normalized.Contains("cleared", StringComparison.Ordinal) ||
            normalized.Contains("emitted", StringComparison.Ordinal) ||
            normalized.Contains("valued", StringComparison.Ordinal) ||
            normalized.Contains("activated", StringComparison.Ordinal) ||
            normalized.Contains("no_variance", StringComparison.Ordinal))
        {
            return Color.Success;
        }

        if (normalized.Contains("blocked", StringComparison.Ordinal) ||
            normalized.Contains("failed", StringComparison.Ordinal) ||
            normalized.Contains("stale", StringComparison.Ordinal) ||
            normalized.Contains("exceeded", StringComparison.Ordinal))
        {
            return Color.Warning;
        }

        return Color.Info;
    }

    private static string BuildShipmentIssueSummary(ShellAccountingSourceDocumentBrowserItem item)
    {
        var issued = item.ShipmentIssuedQuantity ?? 0m;
        var remaining = item.ShipmentRemainingToIssueQuantity ?? 0m;
        var tracking = string.IsNullOrWhiteSpace(item.ShipmentTrackingNumber)
            ? "no tracking"
            : $"tracking {item.ShipmentTrackingNumber}";

        return $"{issued:N2} issued, {remaining:N2} remaining | {tracking}";
    }

    private static Color GetShipmentIssueStatusColor(string? status)
    {
        var normalized = status?.Trim().ToLowerInvariant();
        return normalized switch
        {
            "fully_issued" => Color.Success,
            "over_issued" => Color.Warning,
            "partially_issued" => Color.Info,
            "no_issue" => Color.Default,
            _ => Color.Info
        };
    }

    private static string BuildSalesOrderOutboundSummary(ShellAccountingSourceDocumentBrowserItem item)
    {
        var shipped = item.SalesOrderShippedQuantity ?? 0m;
        var shippable = item.SalesOrderShippableQuantity ?? 0m;
        var remainingShip = item.SalesOrderRemainingToShipQuantity ?? 0m;
        var invoiced = item.SalesOrderInvoicedQuantity ?? 0m;
        var remainingInvoice = item.SalesOrderRemainingToInvoiceQuantity ?? 0m;
        return $"{shipped:N2}/{shippable:N2} shipped, {remainingShip:N2} to ship | {invoiced:N2} invoiced, {remainingInvoice:N2} to invoice";
    }

    private static Color GetSalesOrderOutboundStatusColor(string? status)
    {
        var normalized = status?.Trim().ToLowerInvariant();
        return normalized switch
        {
            "closed" or "fully_shipped" or "fully_invoiced" => Color.Success,
            "over_shipped" or "over_invoiced" => Color.Warning,
            "partially_shipped" or "partially_invoiced" or "issued" => Color.Info,
            "draft" or "not_shipped" or "not_invoiced" or "no_inventory_handoff" => Color.Default,
            _ => Color.Info
        };
    }

    private static Color GetInvoiceShipmentPostingGateColor(ShellAccountingSourceDocumentBrowserItem item) =>
        item.InvoiceShipmentAllowsPost switch
        {
            true => Color.Success,
            false => string.Equals(item.InvoiceShipmentMatchStatus, "over_shipped", StringComparison.OrdinalIgnoreCase)
                ? Color.Warning
                : Color.Info,
            _ => Color.Default
        };

    private static bool TryNormalizeReturnHref(string? href, out string normalizedHref)
    {
        normalizedHref = string.Empty;
        if (string.IsNullOrWhiteSpace(href))
        {
            return false;
        }

        var trimmed = href.Trim();
        if (!trimmed.StartsWith('/', StringComparison.Ordinal))
        {
            return false;
        }

        normalizedHref = trimmed;
        return true;
    }

    private sealed record SourceTypeOption(string Value, string Label);
}
