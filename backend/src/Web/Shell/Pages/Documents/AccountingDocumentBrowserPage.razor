@page "/documents/source-browser"
@using Web.Shell.Services
@using Web.Business.AR.SettlementLookup
@using Web.Business.AP.SettlementLookup
@inject WebShellState ShellState
@inject WebShellBusinessSessionClient SessionClient
@inject WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject ShellAccountingDocumentBrowserClient BrowserClient
@inject IArSettlementLookupService ArLookupService
@inject IApSettlementLookupService ApLookupService

<div style="padding:2rem 2.25rem;color:#d9e2ea;">
    <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;margin-bottom:1rem;">
        @if (HasReturnLink)
        {
            <MudButton Variant="Variant.Text" Color="Color.Primary" Href="@ResolvedReturnHref" StartIcon="@Icons.Material.Filled.ArrowBack">
                @ResolvedReturnLabel
            </MudButton>
        }
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/" StartIcon="@Icons.Material.Filled.Home">
            Back to shell
        </MudButton>
        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">Source document browser</MudChip>
    </div>

    <h1 style="margin:0 0 0.75rem 0;">AR/AP Source Documents</h1>
    <p style="margin:0 0 1rem 0;color:#97a8b7;max-width:60rem;">
        This browser gives `Invoice`, `Bill`, `Credit Note`, and `Vendor Credit` a formal company-scoped read surface. It stays read-only and drills into the existing backend-owned document detail page.
    </p>

    @if (!string.IsNullOrWhiteSpace(QueryOrigin))
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            @($"Navigation context: {QueryOrigin}")
        </MudAlert>
    }

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(14rem,1fr));gap:0.75rem;align-items:end;margin-bottom:1rem;">
        <MudSelect T="string" Label="Source Type" Variant="Variant.Outlined" @bind-Value="_selectedSourceType">
            @foreach (var option in _sourceTypeOptions)
            {
                <MudSelectItem T="string" Value="@option.Value">@option.Label</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="string" Label="Counterparty Role" Variant="Variant.Outlined" Value="_selectedCounterpartyRole" ValueChanged="OnCounterpartyRoleChangedAsync">
            @foreach (var option in _counterpartyRoleOptions)
            {
                <MudSelectItem T="string" Value="@option.Value">@option.Label</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="string" Label="Counterparty" Variant="Variant.Outlined" @bind-Value="_selectedCounterpartyIdText" Disabled="_counterpartyOptions.Count == 0">
            @foreach (var option in _counterpartyOptions)
            {
                <MudSelectItem T="string" Value="@option.Value">@option.Label</MudSelectItem>
            }
        </MudSelect>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_isLoading" OnClick="LoadAsync">
            Refresh
        </MudButton>
    </div>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Info" Style="margin-bottom:1rem;" />
    }

    @if (!string.IsNullOrWhiteSpace(_errorText))
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            @_errorText
        </MudAlert>
    }

    @if (WritesBlocked)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            @ShellState.WriteBlockMessage
        </MudAlert>
    }

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(14rem,1fr));gap:1rem;margin-bottom:1rem;">
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.caption">Active Company</MudText>
            <MudText Typo="Typo.h6">@ShellState.ActiveCompany.CompanyCode</MudText>
            <MudText Typo="Typo.body2">@ShellState.ActiveCompany.CompanyName</MudText>
        </MudPaper>
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.caption">Business Focus</MudText>
            <MudText Typo="Typo.h6">@CurrentFocusLabel</MudText>
            <MudText Typo="Typo.body2">@CurrentFocusDescription</MudText>
        </MudPaper>
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.caption">Applied Filter</MudText>
            <MudText Typo="Typo.h6">@CurrentFilterLabel</MudText>
            <MudText Typo="Typo.body2">@($"{_items.Count} document(s)")</MudText>
        </MudPaper>
    </div>

    <MudPaper Class="pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-3">Documents</MudText>
        @if (_items.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                No source documents matched the current company context and filter.
            </MudAlert>
        }
        else
        {
            <MudTable Items="_items" Dense="true" Hover="true" Bordered="true">
                <HeaderContent>
                    <MudTh>Type</MudTh>
                    <MudTh>Display</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Date</MudTh>
                    <MudTh>Counterparty</MudTh>
                    <MudTh>Total</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.SourceTypeLabel</MudTd>
                    <MudTd>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@context.DisplayNumber</MudText>
                            <MudText Typo="Typo.caption" Class="text-secondary">@context.EntityNumber</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@context.Status</MudText>
                            @if (HasBillReceiptPostingGate(context))
                            {
                                <MudChip T="string"
                                         Variant="Variant.Outlined"
                                         Color="@GetBillReceiptPostingGateColor(context)"
                                         Size="Size.Small"
                                         Style="margin-top:.35rem;width:max-content;">
                                    @context.BillReceiptPostingGateLabel
                                </MudChip>
                                <MudText Typo="Typo.caption" Class="text-secondary" Style="margin-top:.25rem;">
                                    @context.BillReceiptPostingGateSummary
                                </MudText>
                            }
                            @if (HasInvoiceShipmentPostingGate(context))
                            {
                                <MudChip T="string"
                                         Variant="Variant.Outlined"
                                         Color="@GetInvoiceShipmentPostingGateColor(context)"
                                         Size="Size.Small"
                                         Style="margin-top:.35rem;width:max-content;">
                                    @context.InvoiceShipmentPostingGateLabel
                                </MudChip>
                                <MudText Typo="Typo.caption" Class="text-secondary" Style="margin-top:.25rem;">
                                    @context.InvoiceShipmentPostingGateSummary
                                </MudText>
                                @if (!string.IsNullOrWhiteSpace(context.InvoiceCoverageSummary))
                                {
                                    <MudText Typo="Typo.caption" Class="text-secondary" Style="margin-top:.25rem;">
                                        @context.InvoiceCoverageSummary
                                    </MudText>
                                }
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@context.DocumentDate.ToString("yyyy-MM-dd")</MudText>
                            <MudText Typo="Typo.caption" Class="text-secondary">@($"Due {context.DueDate?.ToString("yyyy-MM-dd") ?? "n/a"}")</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@($"{context.CounterpartyLabel}: {context.CounterpartyDisplayName ?? "Unavailable"}")</MudText>
                            @if (context.CounterpartyId.HasValue)
                            {
                                <MudText Typo="Typo.caption" Class="text-secondary">@context.CounterpartyId.Value.ToString("D")</MudText>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@context.TotalAmount.ToString("N2")</MudText>
                            <MudText Typo="Typo.caption" Class="text-secondary">@($"{context.TransactionCurrencyCode} | base {context.BaseCurrencyCode}")</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd>
                        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                            <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@($"/documents/{context.SourceType}/{context.Id:D}")">
                                Open Detail
                            </MudButton>
                            @if (TryBuildReceiptWorkspaceHref(context.SourceType, context.Id, out var receiptHref))
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Warning" Href="@receiptHref" Disabled="WritesBlocked">
                                    Open Receipt Workspace
                                </MudButton>
                            }
                            @if (TryBuildShipmentWorkspaceHref(context.SourceType, context.Id, out var shipmentHref))
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Warning" Href="@shipmentHref" Disabled="WritesBlocked">
                                    Open Shipment Workspace
                                </MudButton>
                            }
                            @if (TryBuildDraftEditorHref(context.SourceType, context.Status, context.Id, out var editHref))
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Success" Href="@editHref" Disabled="WritesBlocked">
                                    @GetDraftWorkbenchLabel(context.SourceType, context.Status)
                                </MudButton>
                            }
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
</div>

@code
{
    [SupplyParameterFromQuery(Name = "sourceType")]
    public string? QuerySourceType { get; set; }

    [SupplyParameterFromQuery(Name = "counterpartyRole")]
    public string? QueryCounterpartyRole { get; set; }

    [SupplyParameterFromQuery(Name = "counterpartyId")]
    public Guid? QueryCounterpartyId { get; set; }

    [SupplyParameterFromQuery(Name = "origin")]
    public string? QueryOrigin { get; set; }

    [SupplyParameterFromQuery(Name = "returnHref")]
    public string? QueryReturnHref { get; set; }

    [SupplyParameterFromQuery(Name = "returnLabel")]
    public string? QueryReturnLabel { get; set; }

    private readonly IReadOnlyList<SourceTypeOption> _sourceTypeOptions =
    [
        new(string.Empty, "All Source Documents"),
        new("invoice", "Invoices"),
        new("credit_note", "Credit Notes"),
        new("bill", "Bills"),
        new("vendor_credit", "Vendor Credits")
    ];

    private readonly IReadOnlyList<SourceTypeOption> _counterpartyRoleOptions =
    [
        new(string.Empty, "All Counterparties"),
        new("customer", "Customers"),
        new("vendor", "Vendors")
    ];

    private bool _isLoading;
    private string? _errorText;
    private string _selectedSourceType = string.Empty;
    private string _selectedCounterpartyRole = string.Empty;
    private string _selectedCounterpartyIdText = string.Empty;
    private IReadOnlyList<ShellAccountingSourceDocumentBrowserItem> _items = Array.Empty<ShellAccountingSourceDocumentBrowserItem>();
    private IReadOnlyList<SourceTypeOption> _counterpartyOptions = Array.Empty<SourceTypeOption>();
    private bool WritesBlocked => ShellState.AreWritesBlocked;
    private bool _queryFiltersApplied;
    private bool HasReturnLink => !string.IsNullOrWhiteSpace(ResolvedReturnHref);
    private string? ResolvedReturnHref => TryNormalizeReturnHref(QueryReturnHref, out var href) ? href : null;
    private string ResolvedReturnLabel => string.IsNullOrWhiteSpace(QueryReturnLabel) ? "Back to previous drill-down" : QueryReturnLabel.Trim();

    private string CurrentFilterLabel =>
        BuildFilterLabel();
    private string CurrentFocusLabel => BuildFocusLabel();
    private string CurrentFocusDescription => BuildFocusDescription();

    protected override async Task OnInitializedAsync()
    {
        ApplyQueryFiltersOnce();

        if (!await LoadCounterpartyOptionsAsync())
        {
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _errorText = null;

        if (!await EnsureWriteGateStateAsync())
        {
            _isLoading = false;
            return;
        }

        var result = await BrowserClient.GetDocumentsAsync(
            ShellState.ActiveCompany.Id,
            string.IsNullOrWhiteSpace(_selectedSourceType) ? null : _selectedSourceType,
            string.IsNullOrWhiteSpace(_selectedCounterpartyRole) ? null : _selectedCounterpartyRole,
            TryGetSelectedCounterpartyId(out var counterpartyId) ? counterpartyId : null,
            100);

        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
        {
            _items = Array.Empty<ShellAccountingSourceDocumentBrowserItem>();
            _isLoading = false;
            return;
        }

        _items = result.Value ?? Array.Empty<ShellAccountingSourceDocumentBrowserItem>();

        if (!string.IsNullOrWhiteSpace(result.ErrorMessage))
        {
            _errorText = result.ErrorMessage;
        }

        if (_items.Count == 0)
        {
            _errorText = string.IsNullOrWhiteSpace(_errorText) ? null : _errorText;
        }

        _isLoading = false;
    }

    private async Task OnCounterpartyRoleChangedAsync(string value)
    {
        _selectedCounterpartyRole = value;
        _selectedCounterpartyIdText = string.Empty;
        await LoadCounterpartyOptionsAsync();
    }

    private async Task<bool> LoadCounterpartyOptionsAsync()
    {
        if (!await EnsureWriteGateStateAsync())
        {
            return false;
        }

        if (_selectedCounterpartyRole == "customer")
        {
            var customers = await ArLookupService.ListCustomersAsync(ShellState.ActiveCompany.Id, CancellationToken.None);
            _counterpartyOptions = customers
                .Select(item => new SourceTypeOption(item.Id.ToString("D"), item.DisplayLabel))
                .ToArray();
            return true;
        }

        if (_selectedCounterpartyRole == "vendor")
        {
            var vendors = await ApLookupService.ListVendorsAsync(ShellState.ActiveCompany.Id, CancellationToken.None);
            _counterpartyOptions = vendors
                .Select(item => new SourceTypeOption(item.Id.ToString("D"), item.DisplayLabel))
                .ToArray();
            return true;
        }

        _counterpartyOptions = Array.Empty<SourceTypeOption>();
        return true;
    }

    private void ApplyQueryFiltersOnce()
    {
        if (_queryFiltersApplied)
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(QuerySourceType))
        {
            _selectedSourceType = QuerySourceType.Trim().ToLowerInvariant();
        }

        if (!string.IsNullOrWhiteSpace(QueryCounterpartyRole))
        {
            _selectedCounterpartyRole = QueryCounterpartyRole.Trim().ToLowerInvariant();
        }

        if (QueryCounterpartyId.HasValue)
        {
            _selectedCounterpartyIdText = QueryCounterpartyId.Value.ToString("D");
        }

        _queryFiltersApplied = true;
    }

    private async Task<bool> EnsureWriteGateStateAsync()
    {
        await ShellState.EnsureHydratedAsync();
        var probe = await SessionClient.ProbeContextAsync(CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe, CancellationToken.None))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(probe.ErrorMessage))
        {
            _errorText = probe.ErrorMessage;
        }

        return true;
    }

    private bool TryGetSelectedCounterpartyId(out Guid counterpartyId)
    {
        return Guid.TryParse(_selectedCounterpartyIdText, out counterpartyId);
    }

    private string BuildFilterLabel()
    {
        var sourceLabel = _sourceTypeOptions.FirstOrDefault(option => option.Value == _selectedSourceType)?.Label
            ?? "All Source Documents";
        var roleLabel = _counterpartyRoleOptions.FirstOrDefault(option => option.Value == _selectedCounterpartyRole)?.Label
            ?? "All Counterparties";
        var counterpartyLabel = _counterpartyOptions.FirstOrDefault(option => option.Value == _selectedCounterpartyIdText)?.Label;

        return string.IsNullOrWhiteSpace(counterpartyLabel)
            ? $"{sourceLabel} | {roleLabel}"
            : $"{sourceLabel} | {roleLabel}: {counterpartyLabel}";
    }

    private string BuildFocusLabel() =>
        QueryOrigin?.Trim() switch
        {
            "Open item detail" => "Open-item related source history",
            "Current source detail" => "Adjacent source-document slice",
            "Reverse blocker: blocked source type" => "Reverse-blocker follow-up",
            "Settlement application reversal history" => "Governed unapply history slice",
            "Settlement application line source" => "Settlement line source follow-up",
            "Settlement application line target" => "Settlement line target follow-up",
            _ => "General source browser"
        };

    private string BuildFocusDescription()
    {
        var sourceLabel = _sourceTypeOptions.FirstOrDefault(option => option.Value == _selectedSourceType)?.Label
            ?? "all source documents";
        var roleLabel = _counterpartyRoleOptions.FirstOrDefault(option => option.Value == _selectedCounterpartyRole)?.Label
            ?? "all counterparties";
        var counterpartyLabel = _counterpartyOptions.FirstOrDefault(option => option.Value == _selectedCounterpartyIdText)?.Label;
        var counterpartyScope = string.IsNullOrWhiteSpace(counterpartyLabel)
            ? $"{roleLabel.ToLowerInvariant()}"
            : $"{roleLabel.TrimEnd('s')}: {counterpartyLabel}";

        return QueryOrigin?.Trim() switch
        {
            "Open item detail" =>
                $"Browsing {sourceLabel.ToLowerInvariant()} for {counterpartyScope} linked to the current open-item drill-down.",
            "Current source detail" =>
                $"Browsing the {sourceLabel.ToLowerInvariant()} slice nearest the current source-document review context.",
            "Reverse blocker: blocked source type" =>
                $"Browsing the blocked {sourceLabel.ToLowerInvariant()} subset while resolving AR/AP reverse blockers.",
            "Settlement application reversal history" =>
                $"Browsing source documents referenced by governed settlement-application reversal history for {counterpartyScope}.",
            "Settlement application line source" =>
                $"Browsing source-side {sourceLabel.ToLowerInvariant()} reached from a settlement application line.",
            "Settlement application line target" =>
                $"Browsing target-side {sourceLabel.ToLowerInvariant()} reached from a settlement application line.",
            _ =>
                $"Browsing {sourceLabel.ToLowerInvariant()} under the current company scope for {counterpartyScope}."
        };
    }

    private static bool TryBuildDraftEditorHref(string? sourceType, string? status, Guid documentId, out string href)
    {
        href = string.Empty;
        if (!string.Equals(status, "draft", StringComparison.OrdinalIgnoreCase) &&
            !(sourceType?.Trim().ToLowerInvariant() is "bill" or "invoice" &&
              string.Equals(status, "submitted", StringComparison.OrdinalIgnoreCase)))
        {
            return false;
        }

        href = sourceType?.Trim().ToLowerInvariant() switch
        {
            "invoice" => $"/documents/invoice/draft-editor?draftId={documentId:D}",
            "credit_note" => $"/documents/credit-note/draft-editor?draftId={documentId:D}",
            "bill" => $"/documents/bill/draft-editor?draftId={documentId:D}",
            "vendor_credit" => $"/documents/vendor-credit/draft-editor?draftId={documentId:D}",
            _ => string.Empty
        };

        return !string.IsNullOrWhiteSpace(href);
    }

    private static string GetDraftWorkbenchLabel(string? sourceType, string? status) =>
        string.Equals(status, "submitted", StringComparison.OrdinalIgnoreCase)
            ? sourceType?.Trim().ToLowerInvariant() switch
            {
                "bill" => "Open Bill Workbench",
                "invoice" => "Open Invoice Workbench",
                _ => "Open Workbench"
            }
            : "Edit Draft";

    private static bool TryBuildReceiptWorkspaceHref(string? sourceType, Guid documentId, out string href)
    {
        href = string.Empty;
        if (!string.Equals(sourceType, "bill", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        href = $"/company/inventory-purchase-receipt?sourceType=bill&billId={documentId:D}";
        return true;
    }

    private static bool TryBuildShipmentWorkspaceHref(string? sourceType, Guid documentId, out string href)
    {
        href = string.Empty;
        if (!string.Equals(sourceType, "invoice", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        href = $"/company/inventory-shipment?sourceType=invoice&invoiceId={documentId:D}";
        return true;
    }

    private static bool HasBillReceiptPostingGate(ShellAccountingSourceDocumentBrowserItem item) =>
        string.Equals(item.SourceType, "bill", StringComparison.OrdinalIgnoreCase) &&
        !string.IsNullOrWhiteSpace(item.BillReceiptPostingGateLabel);

    private static Color GetBillReceiptPostingGateColor(ShellAccountingSourceDocumentBrowserItem item) =>
        item.BillReceiptAllowsPost switch
        {
            true => Color.Success,
            false => string.Equals(item.BillReceiptMatchStatus, "over_receipted", StringComparison.OrdinalIgnoreCase)
                ? Color.Warning
                : Color.Info,
            _ => Color.Default
        };

    private static bool HasInvoiceShipmentPostingGate(ShellAccountingSourceDocumentBrowserItem item) =>
        string.Equals(item.SourceType, "invoice", StringComparison.OrdinalIgnoreCase) &&
        !string.IsNullOrWhiteSpace(item.InvoiceShipmentPostingGateLabel);

    private static Color GetInvoiceShipmentPostingGateColor(ShellAccountingSourceDocumentBrowserItem item) =>
        item.InvoiceShipmentAllowsPost switch
        {
            true => Color.Success,
            false => string.Equals(item.InvoiceShipmentMatchStatus, "over_shipped", StringComparison.OrdinalIgnoreCase)
                ? Color.Warning
                : Color.Info,
            _ => Color.Default
        };

    private static bool TryNormalizeReturnHref(string? href, out string normalizedHref)
    {
        normalizedHref = string.Empty;
        if (string.IsNullOrWhiteSpace(href))
        {
            return false;
        }

        var trimmed = href.Trim();
        if (!trimmed.StartsWith('/', StringComparison.Ordinal))
        {
            return false;
        }

        normalizedHref = trimmed;
        return true;
    }

    private sealed record SourceTypeOption(string Value, string Label);
}
