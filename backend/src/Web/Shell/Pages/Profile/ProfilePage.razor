    private async Task RequestPasswordChangeAsync()
    {
        await RunBusyAsync(
            async () =>
            {
                if (!string.Equals(_newPassword, _confirmPassword, StringComparison.Ordinal))
                {
                    throw new InvalidOperationException("New password and confirmation must match.");
                }

                var result = await ProfileClient.RequestPasswordChangeAsync(_newPassword, CancellationToken.None);
                if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
                {
                    return;
                }

                if (!string.IsNullOrWhiteSpace(result.ErrorMessage))
                {
                    throw new InvalidOperationException(result.ErrorMessage);
                }

                var value = result.Value ?? throw new InvalidOperationException("Platform account was not found.");
                _profile = value.Profile;
                _newPassword = string.Empty;
                _confirmPassword = string.Empty;
                Snackbar.Add(
                    $"Password change code sent to {value.MaskedDestination}. Expires {value.ExpiresAtUtc:yyyy-MM-dd HH:mm:ss} UTC.",
                    Severity.Success);
            });
    }

    private async Task ConfirmPasswordChangeAsync()
    {
        await RunBusyAsync(
            async () =>
            {
                var result = await ProfileClient.ConfirmPasswordChangeAsync(_passwordChangeCode, CancellationToken.None);
                if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
                {
                    return;
                }

                if (!string.IsNullOrWhiteSpace(result.ErrorMessage))
                {
                    throw new InvalidOperationException(result.ErrorMessage);
                }

                _profile = result.Value?.Profile ?? throw new InvalidOperationException("Platform account was not found.");
                _passwordChangeCode = string.Empty;
                await RefreshShellStateAsync();
                Snackbar.Add("Password change confirmed.", Severity.Success);
            });
    }

    private async Task RunBusyAsync(Func<Task> action)
    {
        if (_isBusy)
        {
            return;
        }

        _isBusy = true;
        _errorText = null;

        try
        {
            await action();
        }
        catch (Exception ex)
        {
            _errorText = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task RefreshShellStateAsync()
    {
        await ShellState.EnsureHydratedAsync();
        var probe = await SessionClient.ProbeContextAsync();
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe))
        {
            return;
        }
    }

    private async Task RefreshMfaTimelineAsync()
    {
        var timelineResult = await ProfileClient.GetMfaTimelineAsync(CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(timelineResult, CancellationToken.None))
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(timelineResult.ErrorMessage))
        {
            throw new InvalidOperationException(timelineResult.ErrorMessage);
        }

        _mfaTimeline = timelineResult.Value ?? Array.Empty<PlatformMfaTimelineEntry>();
    }

    private static Severity GetMfaRecoverySeverity(string? status) =>
        status?.Trim().ToLowerInvariant() switch
        {
            "approved" => Severity.Success,
            "rejected" => Severity.Error,
            _ => Severity.Warning
        };

    private static Color GetTimelineColor(string? action) =>
        action?.Trim().ToLowerInvariant() switch
        {
            "profile_mfa_mode_saved" => Color.Primary,
            "account_totp_enrollment_started" => Color.Info,
            "account_totp_enrollment_confirmed" => Color.Success,
            "account_mfa_recovery_requested" => Color.Warning,
            "account_mfa_recovery_approved" => Color.Success,
            "account_mfa_recovery_rejected" => Color.Error,
            "account_mfa_recovery_executed" => Color.Secondary,
            "account_mfa_reset" => Color.Warning,
            _ => Color.Default
        };

    private string GetSaveMfaButtonLabel() =>
        string.Equals(_selectedMfaMode, "totp_app", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(_profile?.MfaMode, "totp_app", StringComparison.OrdinalIgnoreCase)
            ? _profile?.HasActiveTotpEnrollment == true ? "Restart TOTP Enrollment" : "Start TOTP Enrollment"
            : "Save MFA Mode";
}
