        _adjustmentPolicyMappings.Count == 0 ? Color.Info : Color.Success;

    private string GetAdjustmentPolicyChipLabel() =>
        _adjustmentPolicyMappings.Count == 0 ? "Structural fallback" : "Mapped execution";

    private static string GetPolicyExecutionRole(ShellOpenItemAdjustmentAccountMappingRecord mapping) =>
        mapping.BookId is null ? "Company default / fallback scope" : "Primary-book override";

    private static bool TryBuildAdjustmentPolicyHref(string? openItemType, string? adjustmentType, out string href)
    {
        var normalizedOpenItemType = NormalizeOpenItemTypeForMapping(openItemType);
        href =
            $"/company/open-item-adjustment-account-mappings?openItemType={Uri.EscapeDataString(normalizedOpenItemType)}&policyScope=primary_execution";

        if (!string.IsNullOrWhiteSpace(adjustmentType))
        {
            href += $"&adjustmentType={Uri.EscapeDataString(adjustmentType.Trim().ToLowerInvariant())}";
        }

        return true;
    }

    private static bool TryBuildSourceBrowserHref(string? sourceType, string? counterpartyRole, Guid counterpartyId, out string href)
    {
        href = string.Empty;
        var normalizedSourceType = sourceType?.Trim().ToLowerInvariant();
        if (string.IsNullOrWhiteSpace(normalizedSourceType))
        {
            return false;
        }

        var normalizedCounterpartyRole = counterpartyRole?.Trim().ToLowerInvariant();
        href =
            $"/documents/source-browser?sourceType={Uri.EscapeDataString(normalizedSourceType)}" +
            $"&counterpartyRole={Uri.EscapeDataString(normalizedCounterpartyRole ?? string.Empty)}" +
            $"&counterpartyId={counterpartyId:D}";
        return true;
    }

    private string BuildBrowserNavigationHref(string href, string origin, string returnLabel)
    {
        var openItemHref = $"/open-items/{OpenItemType}/{OpenItemId:D}";
        return
            $"{href}&origin={Uri.EscapeDataString(origin)}" +
            $"&returnHref={Uri.EscapeDataString(openItemHref)}" +
            $"&returnLabel={Uri.EscapeDataString(returnLabel)}";
    }

