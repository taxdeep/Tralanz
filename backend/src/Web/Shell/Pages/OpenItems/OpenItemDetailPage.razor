    private string GetApplicationTrailSummaryTitle(ShellOpenItemDetail item)
    {
        if (_response?.Applications.Count is not > 0)
        {
            return "Unapplied";
        }

        return item.OpenAmountTx == 0m ? "Fully applied" : "Partially applied";
    }

    private string GetApplicationTrailSummaryDetail(ShellOpenItemDetail item)
    {
        if (_response?.Applications.Count is not > 0)
        {
            return "No settlement or credit application rows are currently consuming this open item.";
        }

        var lastAppliedAt = _response.Applications.Max(static application => application.CreatedAt);
        return $"Latest application row was recorded at {lastAppliedAt:yyyy-MM-dd HH:mm 'UTC'}.";
    }

    private string GetApplicationTrailCountTitle() =>
        _response?.Applications.Count is > 0
            ? $"{_response.Applications.Count} row(s)"
            : "0 rows";

    private string GetApplicationTrailCountDetail()
    {
        if (_response?.Applications.Count is not > 0)
        {
            return "No receive-payment, credit-application, pay-bill, or vendor-credit-application rows are linked yet.";
        }

        var grouped = _response.Applications
            .GroupBy(application => GetApplicationLabel(application.ApplicationType))
            .Select(group => $"{group.Key}: {group.Count()}")
            .ToArray();
        return string.Join(" | ", grouped);
    }

    private string GetApplicationTrailCoverageTitle(ShellOpenItemDetail item)
    {
        var appliedAmountTx = item.OriginalAmountTx - item.OpenAmountTx;
        return $"{FormatAmount(appliedAmountTx)} applied";
    }

    private string GetApplicationTrailCoverageDetail(ShellOpenItemDetail item)
    {
        if (item.OriginalAmountTx == 0m)
        {
            return "Original amount is zero, so no application coverage ratio is available.";
        }

        var appliedAmountTx = item.OriginalAmountTx - item.OpenAmountTx;
        var coverage = appliedAmountTx / item.OriginalAmountTx;
        return $"{coverage:P0} of original {FormatAmount(item.OriginalAmountTx)} has been consumed; {FormatAmount(item.OpenAmountTx)} remains open.";
    }

    private ApplicationTrailNextActionSummary GetApplicationTrailNextActionSummary(ShellOpenItemDetail item)
    {
        if (_response?.Applications.Count is not > 0)
        {
            return new ApplicationTrailNextActionSummary(
                "No trail follow-up needed",
                "No settlement or application rows currently consume this open item. Use related-source browsing only if you want adjacent AR/AP context before requesting an adjustment.");
        }

        if (item.OpenAmountTx == 0m)
        {
            return new ApplicationTrailNextActionSummary(
                "Review fully applied history",
                $"{_response.Applications.Count} application row(s) have fully consumed the original amount. Open linked source documents if you need audit follow-up before treating this item as closed out.");
        }

        return new ApplicationTrailNextActionSummary(
            "Review consuming applications",
            $"{_response.Applications.Count} application row(s) still consume part of this open item. Review the trail and related source documents before deciding whether a residual write-off or small-balance adjustment is still appropriate.");
    }

    private string GetAdjustmentPolicySummaryTitle() =>
        _adjustmentPolicyMappings.Count == 0 ? "Structural guard" : "Mapped execution";

    private string GetAdjustmentPolicySummaryDetail()
    {
        if (_adjustmentPolicyMappings.Count == 0)
        {
            return $"No primary-execution mapping is active for {FormatAdjustmentType(_adjustmentType)}. Backend uses structural account validation.";
        }

        var preferred = _adjustmentPolicyMappings.FirstOrDefault(static mapping => mapping.BookId is not null) ?? _adjustmentPolicyMappings[0];
        return $"{preferred.ScopeLabel} routes {FormatAdjustmentType(_adjustmentType).ToLowerInvariant()} into {preferred.AccountLabel}.";
    }

    private string GetAdjustmentRequestSummaryTitle()
    {
        if (_latestAdjustmentRequest is null)
        {
            return "No active workflow";
        }

        return $"{FormatAdjustmentRequestStatus(_latestAdjustmentRequest.RequestStatus)} | {FormatAdjustmentExecutionStatus(_latestAdjustmentRequest.ExecutionStatus)}";
    }

    private string GetAdjustmentRequestSummaryDetail()
    {
        if (_latestAdjustmentRequest is null)
        {
            return "No governed write-off or small-balance request has been recorded for this open item.";
        }

        if (_latestAdjustmentRequest.RequiresApproval)
        {
            return $"Approval: {FormatApprovalStatus(_latestAdjustmentRequest.ApprovalStatus)}. {(_latestAdjustmentRequest.Reason ?? "Review the latest governed request record for operator-entered context.")}";
        }

        return $"Requested {FormatAmount(_latestAdjustmentRequest.RequestedAdjustmentAmountTx)} on {_latestAdjustmentRequest.AdjustmentDate:yyyy-MM-dd}.";
    }

    private string GetAdjustmentExecutionSummaryTitle()
    {
        if (_adjustmentExecutionResult is not null)
        {
            return "Posting completed";
        }

        if (_adjustmentExecutionPlan is not null)
        {
            return _adjustmentExecutionPlan.CanExecute ? "Execution ready" : "Execution blocked";
        }

        if (_adjustmentReadiness is not null)
        {
            return _adjustmentReadiness.IsAvailable ? "Readiness available" : "Readiness blocked";
        }

        return "Preview pending";
    }

    private string GetAdjustmentExecutionSummaryDetail()
    {
        if (_adjustmentExecutionResult is not null)
        {
            return $"Posted as {_adjustmentExecutionResult.JournalEntryDisplayNumber ?? "linked JE"} for {FormatAmount(_adjustmentExecutionResult.AdjustmentAmountTx)}.";
        }

        if (_adjustmentExecutionPlan is not null)
        {
            var readyCount = _adjustmentExecutionPlan.Steps.Count(step => string.Equals(step.StepStatus, "ready", StringComparison.OrdinalIgnoreCase));
            return $"{readyCount}/{_adjustmentExecutionPlan.Steps.Count} execution steps are ready. {_adjustmentExecutionPlan.Reason}";
        }

        if (_adjustmentReadiness is not null)
        {
            return _adjustmentReadiness.Reason;
        }

        return "Refresh preview to evaluate current governance, open-item, and posting execution state.";
    }

    private IReadOnlyList<string> GetAdjustmentOperatorBulletSummary()
    {
        var bullets = new List<string>();

        if (_adjustmentExecutionResult is not null)
        {
            bullets.Add(
                $"Latest governed adjustment already posted as {_adjustmentExecutionResult.JournalEntryDisplayNumber ?? "a linked journal entry"}.");
            return bullets;
        }

        if (_adjustmentPreview is not null)
        {
            bullets.Add(
                _adjustmentPreview.IsAvailable
                    ? $"Preview is structurally available for {FormatAdjustmentType(_adjustmentType).ToLowerInvariant()} on the current residual amount."
                    : $"Preview is currently blocked: {_adjustmentPreview.Reason}");
        }

        if (_adjustmentReadiness is not null)
        {
            if (!_adjustmentReadiness.GovernanceReady)
            {
                bullets.Add("Governance state is not yet ready for final posting execution.");
            }

            if (!_adjustmentReadiness.OpenItemReady)
            {
                bullets.Add("Open-item state still needs attention before backend adjustment execution can proceed.");
            }

            if (!_adjustmentReadiness.PostingExecutionReady)
            {
                bullets.Add("Posting Engine execution is still blocked on the current request/readiness state.");
            }

            if (_adjustmentReadiness.IsAvailable)
            {
                bullets.Add("Readiness probe is available, so the next decision should come from request workflow or execution planning rather than guessing from balances alone.");
            }
        }

        if (_adjustmentExecutionPlan is not null)
        {
            var blockedCount = _adjustmentExecutionPlan.Steps.Count(step => string.Equals(step.StepStatus, "blocked", StringComparison.OrdinalIgnoreCase));
            var readyCount = _adjustmentExecutionPlan.Steps.Count(step => string.Equals(step.StepStatus, "ready", StringComparison.OrdinalIgnoreCase));

            if (_adjustmentExecutionPlan.CanExecute)
            {
                bullets.Add(
                    $"Execution plan is clear with {readyCount}/{_adjustmentExecutionPlan.Steps.Count} steps ready.");
            }
            else
            {
                bullets.Add(
                    $"Execution plan still has {blockedCount} blocked step(s) and {readyCount}/{_adjustmentExecutionPlan.Steps.Count} ready step(s).");
            }
        }

        if (!HasSelectedGovernedAdjustmentAccount() && (_adjustmentExecutionPlan?.CanExecute == true || _adjustmentReadiness?.PostingExecutionReady == true))
        {
            bullets.Add("Select a governed adjustment account before requesting final posting execution from this shell.");
        }

        return bullets;
    }

    private AdjustmentNextLegalActionSummary GetAdjustmentNextLegalActionSummary()
    {
        if (WritesBlocked)
        {
            return new AdjustmentNextLegalActionSummary(
                "Writes blocked",
                ShellState.WriteBlockMessage ?? "Company or platform write gate is currently blocking governed adjustment actions.");
        }

        if (_isAdjustmentCommandRunning)
        {
            return new AdjustmentNextLegalActionSummary(
                "Command in progress",
                "Wait for the current governed adjustment command to finish before issuing another action from this page.");
        }

        if (_adjustmentExecutionResult is not null ||
            string.Equals(_latestAdjustmentRequest?.ExecutionStatus, "journal_entry_posted", StringComparison.OrdinalIgnoreCase))
        {
            return new AdjustmentNextLegalActionSummary(
                "Adjustment already posted",
                "Posting Engine execution already completed for the latest governed adjustment. Use source-document and journal-entry drill-down for audit follow-up instead of issuing a new command.");
        }

        if (CanExecuteAdjustment())
        {
            return new AdjustmentNextLegalActionSummary(
                "Execute posting adjustment",
                _adjustmentExecutionPlan?.Reason ??
                "The governed request is submitted, execution is ready, and a valid governed offset account is selected.");
        }

        if (string.Equals(_latestAdjustmentRequest?.ExecutionStatus, "execution_requested", StringComparison.OrdinalIgnoreCase))
        {
            return new AdjustmentNextLegalActionSummary(
                "Await posting execution",
                "A governed execution request is already on file for the latest adjustment. Wait for backend posting completion instead of resubmitting from the shell.");
        }

        if ((_adjustmentExecutionPlan?.CanExecute == true || _adjustmentReadiness?.PostingExecutionReady == true) &&
            !HasSelectedGovernedAdjustmentAccount())
        {
            return new AdjustmentNextLegalActionSummary(
                "Select governed adjustment account",
                "Backend execution is otherwise ready, but this shell still needs a valid governed offset account selection before it can request posting execution.");
        }

        if (CanApproveAdjustment() || CanRejectAdjustment())
        {
            return new AdjustmentNextLegalActionSummary(
                "Review submitted request",
                $"The latest governed request is awaiting approval review. Current approval state: {FormatApprovalStatus(_latestAdjustmentRequest?.ApprovalStatus)}.");
        }

        if (CanSubmitAdjustment())
        {
            return new AdjustmentNextLegalActionSummary(
                "Submit governed request",
                "The latest adjustment request is still draft. Submit it so backend governance can treat it as the active request record.");
        }

        if (CanRequestAdjustment())
        {
            return (_response?.Applications.Count ?? 0) > 0
                ? new AdjustmentNextLegalActionSummary(
                    "Request governed adjustment",
                    $"Preview says a governed adjustment is available even though {_response!.Applications.Count} application row(s) already touch this item. If that residual action is intended, request it from this page and keep the application trail in view.")
                : new AdjustmentNextLegalActionSummary(
                    "Request governed adjustment",
                    "Preview is available and no active governed request currently blocks you. Record the write-off or small-balance request from this page.");
        }

        if (string.Equals(_latestAdjustmentRequest?.ApprovalStatus, "rejected", StringComparison.OrdinalIgnoreCase))
        {
            return new AdjustmentNextLegalActionSummary(
                "Record a fresh request",
                "The latest governed adjustment request was rejected. If adjustment is still needed, revise the inputs and record a new request.");
        }

        if (string.Equals(_latestAdjustmentRequest?.RequestStatus, "cancelled", StringComparison.OrdinalIgnoreCase))
        {
            return new AdjustmentNextLegalActionSummary(
                "Refresh preview or start again",
                "The last governed request was cancelled. Refresh preview if inputs changed, then record a fresh request if adjustment is still needed.");
        }

        if (_adjustmentExecutionPlan is not null)
        {
            return new AdjustmentNextLegalActionSummary(
                "Resolve execution blockers",
                _adjustmentExecutionPlan.Reason);
        }

        if (_adjustmentReadiness is not null)
        {
            return new AdjustmentNextLegalActionSummary(
                _adjustmentReadiness.IsAvailable ? "Refresh execution plan" : "Resolve readiness blockers",
                _adjustmentReadiness.Reason);
        }

        return new AdjustmentNextLegalActionSummary(
            "Refresh preview",
            "Start by refreshing preview so this page can reload the current governed request, readiness, and posting-execution truth for this open item.");
    }

    private bool HasSelectedGovernedAdjustmentAccount() =>
        Guid.TryParse(_adjustmentAccountIdText, out var adjustmentAccountId) &&
        _accountOptions.Any(account => account.AccountId == adjustmentAccountId);

