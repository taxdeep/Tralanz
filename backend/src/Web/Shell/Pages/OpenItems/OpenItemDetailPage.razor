    private async Task<bool> LoadAdjustmentPolicyAsync()
    {
        _adjustmentPolicyMappings.Clear();
        _adjustmentPolicyMessage = null;

        var policyResult = await MappingClient.ListAsync(
            ShellState.ActiveCompany.Id,
            NormalizeOpenItemTypeForMapping(OpenItemType),
            _adjustmentType,
            includeInactive: false,
            bookId: null,
            policyScope: "primary_execution",
            searchText: null,
            limit: 20,
            CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(policyResult, CancellationToken.None))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(policyResult.ErrorMessage))
        {
            _adjustmentPolicyMessage = policyResult.ErrorMessage;
            return true;
        }

        _adjustmentPolicyMappings.AddRange(policyResult.Value?.Mappings ?? Array.Empty<ShellOpenItemAdjustmentAccountMappingRecord>());
        if (_adjustmentPolicyMappings.Count == 0)
        {
            _adjustmentPolicyMessage =
                $"No active {FormatOpenItemType(NormalizeOpenItemTypeForMapping(OpenItemType))} mapping exists for {FormatAdjustmentType(_adjustmentType)}. Backend execution will keep using the structural adjustment-account guard until governance activates a mapping.";
            return true;
        }

        var preferred = _adjustmentPolicyMappings.FirstOrDefault(static mapping => mapping.BookId is not null) ?? _adjustmentPolicyMappings[0];
        _adjustmentPolicyMessage =
            $"Primary execution currently resolves to {preferred.AccountLabel} via {preferred.ScopeLabel}. Backend execution will enforce this active mapping scope.";

        if (_accountOptions.Any(option => option.AccountId == preferred.AdjustmentAccountId) &&
            !string.Equals(_adjustmentAccountIdText, preferred.AdjustmentAccountId.ToString("D"), StringComparison.OrdinalIgnoreCase))
        {
            _adjustmentAccountIdText = preferred.AdjustmentAccountId.ToString("D");
        }

        return true;
    }

