    private static JournalEntryAccountOption? ResolveDefaultAdjustmentAccount(IReadOnlyList<JournalEntryAccountOption> accounts) =>
        accounts.FirstOrDefault(IsPreferredAdjustmentAccountCandidate)
        ?? accounts.FirstOrDefault(static account => string.Equals(account.RootType, "expense", StringComparison.OrdinalIgnoreCase))
        ?? accounts.FirstOrDefault(static account => string.Equals(account.RootType, "revenue", StringComparison.OrdinalIgnoreCase))
        ?? accounts.FirstOrDefault();

    private static bool IsGovernedAdjustmentAccountCandidate(JournalEntryAccountOption account) =>
        account.AllowManualPosting &&
        account.RootType is "revenue" or "cost_of_sales" or "expense";

    private static bool IsPreferredAdjustmentAccountCandidate(JournalEntryAccountOption account)
    {
        var searchText = $"{account.Code} {account.Name} {account.DetailType} {account.TypeLabel}".ToLowerInvariant();
        return searchText.Contains("write") ||
               searchText.Contains("bad debt") ||
               searchText.Contains("adjust") ||
               searchText.Contains("rounding");
    }

