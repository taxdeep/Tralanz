        new("Requested Adjustment Base", $"{FormatAmount(preview.RequestedAdjustmentAmountBase)} {preview.BaseCurrencyCode}"),
        new("Remaining Tx After Execution", $"{FormatAmount(preview.RemainingAmountTx)} {preview.DocumentCurrencyCode}"),
        new("Approval", preview.RequiresApproval ? $"Required | {preview.ApprovalStatus}" : "Not required"),
