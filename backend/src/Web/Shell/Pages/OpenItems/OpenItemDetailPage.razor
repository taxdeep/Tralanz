@page "/open-items/{OpenItemType}/{OpenItemId:guid}"
@using Modules.GL.JournalEntry
@using Web.Shell.Services
@inject WebShellState ShellState
@inject WebShellBusinessSessionClient SessionClient
@inject WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject ShellOpenItemDrillDownClient DrillDownClient
@inject ShellOpenItemAdjustmentAccountMappingClient MappingClient
@inject IJournalEntryAccountCatalog Accounts

<div style="padding:2rem 2.25rem;color:#d9e2ea;">
    <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;margin-bottom:1rem;">
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/" StartIcon="@Icons.Material.Filled.ArrowBack">
            Back to shell
        </MudButton>
        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">Open item drill-down</MudChip>
    </div>

    <h1 style="margin:0 0 0.75rem 0;">@(_response?.OpenItem?.SourceDocumentDisplayNumber ?? "Open Item Detail")</h1>
    <p style="margin:0 0 1rem 0;color:#97a8b7;max-width:60rem;">
        This page keeps source document truth, current open balance, and settlement/application trail on one read-only surface.
    </p>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Info" Style="margin-bottom:1rem;" />
    }

    @if (!string.IsNullOrWhiteSpace(_errorText))
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            @_errorText
        </MudAlert>
    }

    @if (WritesBlocked)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            @ShellState.WriteBlockMessage
        </MudAlert>
    }

    @if (_response?.OpenItem is not null)
    {
        var item = _response.OpenItem;

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(16rem,1fr));gap:1rem;margin-bottom:1rem;">
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Open Item</MudText>
                <MudText Typo="Typo.h6">@item.SourceDocumentDisplayNumber</MudText>
                <MudText Typo="Typo.body2">@GetSourceLabel(item.SourceType) | @item.Status</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Party</MudText>
                <MudText Typo="Typo.h6">@item.PartyDisplayName</MudText>
                <MudText Typo="Typo.body2">@item.PartyEntityNumber | @GetPartyLabel(item.PartyRole)</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Open Tx</MudText>
                <MudText Typo="Typo.h6">@FormatAmount(item.OpenAmountTx)</MudText>
                <MudText Typo="Typo.body2">@item.DocumentCurrencyCode</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Open Base</MudText>
                <MudText Typo="Typo.h6">@FormatAmount(item.OpenAmountBase)</MudText>
                <MudText Typo="Typo.body2">@item.BaseCurrencyCode</MudText>
            </MudPaper>
        </div>

        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <MudText Typo="Typo.h6" Class="mb-3">Facts</MudText>
            <MudTable Items="_factRows" Dense="true">
                <RowTemplate>
                    <MudTd DataLabel="Field">@context.Label</MudTd>
                    <MudTd DataLabel="Value">@context.Value</MudTd>
                </RowTemplate>
            </MudTable>

            <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:1rem;">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@($"/documents/{item.SourceType}/{item.SourceDocumentId:D}")">
                    Open Source Document
                </MudButton>
                @if (TryBuildSourceBrowserHref(item.SourceType, item.PartyRole, item.PartyId, out var relatedDocumentsHref))
                {
                    <MudButton Variant="Variant.Text" Color="Color.Info" Href="@BuildBrowserNavigationHref(relatedDocumentsHref, "Open item detail", "Back to open item")">
                        Browse Related Documents
                    </MudButton>
                }
            </div>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:1rem;">
                <div>
                    <MudText Typo="Typo.h6">Open Item Adjustment Control</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        Request and execute write-off or small-balance adjustment through backend governance and the Posting Engine.
                    </MudText>
                </div>
                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Warning">Backend-owned execution</MudChip>
            </div>

            @if (_isAdjustmentCommandRunning)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Warning" Style="margin-bottom:1rem;" />
            }

            @if (!string.IsNullOrWhiteSpace(_adjustmentCommandMessage))
            {
                <MudAlert Severity="_adjustmentCommandSeverity" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                    @_adjustmentCommandMessage
                </MudAlert>
            }

            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(14rem,1fr));gap:1rem;margin-bottom:1rem;">
                <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.caption">Operator Next Step</MudText>
                    <MudText Typo="Typo.h6">@GetAdjustmentNextLegalActionSummary().Title</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@GetAdjustmentNextLegalActionSummary().Detail</MudText>
                </MudPaper>
                <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.caption">Adjustment Policy</MudText>
                    <MudText Typo="Typo.h6">@GetAdjustmentPolicySummaryTitle()</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@GetAdjustmentPolicySummaryDetail()</MudText>
                </MudPaper>
                <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.caption">Request Workflow</MudText>
                    <MudText Typo="Typo.h6">@GetAdjustmentRequestSummaryTitle()</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@GetAdjustmentRequestSummaryDetail()</MudText>
                </MudPaper>
                <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.caption">Posting Readiness</MudText>
                    <MudText Typo="Typo.h6">@GetAdjustmentExecutionSummaryTitle()</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@GetAdjustmentExecutionSummaryDetail()</MudText>
                </MudPaper>
            </div>

            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(14rem,1fr));gap:1rem;margin-bottom:1rem;">
                <MudSelect T="string" Label="Adjustment Type" Variant="Variant.Outlined" Value="_adjustmentType" ValueChanged="OnAdjustmentTypeChangedAsync" Disabled="@(_isAdjustmentCommandRunning || WritesBlocked)">
                    <MudSelectItem T="string" Value="@("write_off")">Write-off</MudSelectItem>
                    <MudSelectItem T="string" Value="@("small_balance_adjustment")">Small balance adjustment</MudSelectItem>
                </MudSelect>
                <MudDatePicker Label="Adjustment Date" Variant="Variant.Outlined" Date="_adjustmentDatePicker" DateChanged="OnAdjustmentDateChanged" Disabled="@(_isAdjustmentCommandRunning || WritesBlocked)" />
                <MudNumericField T="decimal?" Label="Adjustment Amount" Variant="Variant.Outlined" Min="0m" @bind-Value="_adjustmentAmountTx" Disabled="@(_isAdjustmentCommandRunning || WritesBlocked)" />
                <MudTextField T="string" Label="Reason" Variant="Variant.Outlined" @bind-Value="_adjustmentReason" Disabled="@(_isAdjustmentCommandRunning || WritesBlocked)" />
                <MudSelect T="string" Label="Adjustment Account" Variant="Variant.Outlined" @bind-Value="_adjustmentAccountIdText" Disabled="@(_isAdjustmentCommandRunning || WritesBlocked || _accountOptions.Count == 0)">
                    @foreach (var account in _accountOptions)
                    {
                        <MudSelectItem T="string" Value="@account.AccountId.ToString("D")">@FormatAdjustmentAccountOption(account)</MudSelectItem>
                    }
                </MudSelect>
            </div>

                <MudText Typo="Typo.caption" Class="text-secondary" Style="display:block;margin-bottom:1rem;">
                    Adjustment account candidates are restricted to active manual-posting revenue, cost-of-sales, or expense accounts. Bank, AR/AP control, tax, asset, liability, and equity accounts are intentionally excluded from this shell picker.
                </MudText>

            <MudPaper Class="pa-3" Elevation="0" Style="margin-bottom:1rem;background:rgba(255,255,255,0.02);">
                <div style="display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;align-items:flex-start;margin-bottom:0.75rem;">
                    <div>
                        <MudText Typo="Typo.subtitle1">Execution Policy</MudText>
                        <MudText Typo="Typo.caption" Class="text-secondary">
                            Backend primary-execution scope for @FormatOpenItemType(item.OpenItemType) / @FormatAdjustmentType(_adjustmentType).
                        </MudText>
                    </div>
                    <MudChip T="string" Variant="Variant.Outlined" Color="@GetAdjustmentPolicyChipColor()">
                        @GetAdjustmentPolicyChipLabel()
                    </MudChip>
                </div>

                @if (!string.IsNullOrWhiteSpace(_adjustmentPolicyMessage))
                {
                    <MudAlert Severity="@GetAdjustmentPolicySeverity()" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:0.75rem;">
                        @_adjustmentPolicyMessage
                    </MudAlert>
                }

                @if (_adjustmentPolicyMappings.Count > 0)
                {
                    <MudTable Items="_adjustmentPolicyMappings" Dense="true" Hover="true" Bordered="true">
                        <HeaderContent>
                            <MudTh>Scope</MudTh>
                            <MudTh>Offset Account</MudTh>
                            <MudTh>Execution Role</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.ScopeLabel</MudTd>
                            <MudTd>@context.AccountLabel</MudTd>
                            <MudTd>@GetPolicyExecutionRole(context)</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>

            <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:1rem;">
                <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="RefreshAdjustmentPreviewAsync" Disabled="_isAdjustmentCommandRunning">
                    Refresh Preview
                </MudButton>
                @if (TryBuildAdjustmentPolicyHref(OpenItemType, _adjustmentType, out var adjustmentPolicyHref))
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@adjustmentPolicyHref">
                        Review Mapping Policy
                    </MudButton>
                }
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="RequestAdjustmentAsync" Disabled="@(!CanRequestAdjustment())">
                    Request Adjustment
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="SubmitAdjustmentRequestAsync" Disabled="@(!CanSubmitAdjustment())">
                    Submit Request
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="CancelAdjustmentRequestAsync" Disabled="@(!CanCancelAdjustment())">
                    Cancel Request
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="ApproveAdjustmentRequestAsync" Disabled="@(!CanApproveAdjustment())">
                    Approve Request
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="RejectAdjustmentRequestAsync" Disabled="@(!CanRejectAdjustment())">
                    Reject Request
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="ExecuteAdjustmentRequestAsync" Disabled="@(!CanExecuteAdjustment())">
                    Execute Posting Adjustment
                </MudButton>
            </div>

            @{
                var adjustmentOperatorBullets = GetAdjustmentOperatorBulletSummary();
            }
            @if (adjustmentOperatorBullets.Count > 0)
            {
                <MudPaper Class="pa-3" Elevation="0" Style="margin-bottom:1rem;background:rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Operator Summary</MudText>
                    <ul style="margin:0;padding-left:1.25rem;color:#97a8b7;">
                        @foreach (var bullet in adjustmentOperatorBullets)
                        {
                            <li style="margin-bottom:0.35rem;">@bullet</li>
                        }
                    </ul>
                </MudPaper>
            }

            @if (_adjustmentPreview is not null)
            {
                <MudAlert Severity="@(_adjustmentPreview.IsAvailable ? Severity.Success : Severity.Warning)" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                    @_adjustmentPreview.Reason
                </MudAlert>
                <MudTable Items="BuildAdjustmentPreviewRows(_adjustmentPreview)" Dense="true" Style="margin-bottom:1rem;">
                    <RowTemplate>
                        <MudTd DataLabel="Field">@context.Label</MudTd>
                        <MudTd DataLabel="Value">@context.Value</MudTd>
                    </RowTemplate>
                </MudTable>
            }

            @if (_latestAdjustmentRequest is not null)
            {
                <MudText Typo="Typo.subtitle1" Class="mb-2">Latest Adjustment Request</MudText>
                <MudTable Items="BuildAdjustmentRequestRows(_latestAdjustmentRequest)" Dense="true" Style="margin-bottom:1rem;">
                    <RowTemplate>
                        <MudTd DataLabel="Field">@context.Label</MudTd>
                        <MudTd DataLabel="Value">@context.Value</MudTd>
                    </RowTemplate>
                </MudTable>
            }

            @if (_adjustmentReadiness is not null)
            {
                <MudAlert Severity="@(_adjustmentReadiness.IsAvailable ? Severity.Success : Severity.Warning)" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                    @_adjustmentReadiness.Reason
                </MudAlert>
                <MudTable Items="BuildAdjustmentReadinessRows(_adjustmentReadiness)" Dense="true" Style="margin-bottom:1rem;">
                    <RowTemplate>
                        <MudTd DataLabel="Field">@context.Label</MudTd>
                        <MudTd DataLabel="Value">@context.Value</MudTd>
                    </RowTemplate>
                </MudTable>
            }

            @if (_adjustmentExecutionPlan is not null)
            {
                <MudAlert Severity="@(_adjustmentExecutionPlan.CanExecute ? Severity.Success : Severity.Warning)" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
                    @_adjustmentExecutionPlan.Reason
                </MudAlert>
                <MudTable Items="_adjustmentExecutionPlan.Steps" Dense="true" Hover="true" Bordered="true" Style="margin-bottom:1rem;">
                    <HeaderContent>
                        <MudTh>#</MudTh>
                        <MudTh>Step</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Backend Reason</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.StepNumber</MudTd>
                        <MudTd>@context.StepLabel</MudTd>
                        <MudTd>@FormatPlanStepStatus(context.StepStatus)</MudTd>
                        <MudTd>@context.Reason</MudTd>
                    </RowTemplate>
                </MudTable>
            }

            @if (_adjustmentExecutionResult is not null)
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Dense="true">
                    Adjustment posted as @_adjustmentExecutionResult.JournalEntryDisplayNumber. The backend has reduced or closed the open item and appended audit completion.
                </MudAlert>
            }
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.h6" Class="mb-3">Settlement / Application Trail</MudText>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(14rem,1fr));gap:1rem;margin-bottom:1rem;">
                <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.caption">Operator Follow-up</MudText>
                    <MudText Typo="Typo.h6">@GetApplicationTrailNextActionSummary(item).Title</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@GetApplicationTrailNextActionSummary(item).Detail</MudText>
                </MudPaper>
                <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.caption">Settlement State</MudText>
                    <MudText Typo="Typo.h6">@GetApplicationTrailSummaryTitle(item)</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@GetApplicationTrailSummaryDetail(item)</MudText>
                </MudPaper>
                <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.caption">Linked Applications</MudText>
                    <MudText Typo="Typo.h6">@GetApplicationTrailCountTitle()</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@GetApplicationTrailCountDetail()</MudText>
                </MudPaper>
                <MudPaper Class="pa-3" Elevation="0" Style="background:rgba(255,255,255,0.02);">
                    <MudText Typo="Typo.caption">Consumed Coverage</MudText>
                    <MudText Typo="Typo.h6">@GetApplicationTrailCoverageTitle(item)</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">@GetApplicationTrailCoverageDetail(item)</MudText>
                </MudPaper>
            </div>
            @if (_response.Applications.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    No settlement or application rows were found for this open item yet.
                </MudAlert>
            }
            else
            {
                <MudTable Items="_response.Applications" Dense="true" Hover="true" Bordered="true">
                    <HeaderContent>
                        <MudTh>Application</MudTh>
                        <MudTh>Source Document</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Applied Tx</MudTh>
                        <MudTh>Applied Base</MudTh>
                        <MudTh>FX</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@GetApplicationLabel(context.ApplicationType)</MudTd>
                        <MudTd>
                            <MudStack Spacing="0">
                                <MudLink Href="@($"/documents/{context.SourceType}/{context.SourceDocumentId:D}")">
                                    @($"{context.SourceDocumentDisplayNumber} | {GetSourceLabel(context.SourceType)}")
                                </MudLink>
                                <MudText Typo="Typo.caption" Class="text-secondary">@context.CreatedAt.ToString("yyyy-MM-dd HH:mm 'UTC'")</MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd>@context.SourceDocumentDate.ToString("yyyy-MM-dd")</MudTd>
                        <MudTd>@FormatAmount(context.AppliedAmountTx)</MudTd>
                        <MudTd>@FormatAmount(context.AppliedAmountBase)</MudTd>
                        <MudTd>
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2">@(context.SettlementFxRate?.ToString("0.######") ?? "No FX rate")</MudText>
                                <MudText Typo="Typo.caption" Class="text-secondary">Realized FX @(context.RealizedFxAmount?.ToString("N2") ?? "n/a")</MudText>
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    }
</div>

@code
{
    [Parameter]
    public string OpenItemType { get; set; } = string.Empty;

    [Parameter]
    public Guid OpenItemId { get; set; }

    private bool _isLoading;
    private string? _errorText;
    private ShellOpenItemDrillDownResponse? _response;
    private IReadOnlyList<FactRow> _factRows = Array.Empty<FactRow>();
    private IReadOnlyList<JournalEntryAccountOption> _accountOptions = Array.Empty<JournalEntryAccountOption>();
    private readonly List<ShellOpenItemAdjustmentAccountMappingRecord> _adjustmentPolicyMappings = [];
    private ShellOpenItemAdjustmentPreviewSummary? _adjustmentPreview;
    private ShellOpenItemAdjustmentRequestSummary? _latestAdjustmentRequest;
    private ShellOpenItemAdjustmentReadinessSummary? _adjustmentReadiness;
    private ShellOpenItemAdjustmentExecutionPlanSummary? _adjustmentExecutionPlan;
    private ShellOpenItemAdjustmentExecutionResultSummary? _adjustmentExecutionResult;
    private string? _adjustmentPolicyMessage;
    private bool _isAdjustmentCommandRunning;
    private string? _adjustmentCommandMessage;
    private Severity _adjustmentCommandSeverity = Severity.Info;
    private string _adjustmentType = "write_off";
    private string? _adjustmentReason;
    private string? _adjustmentAccountIdText;
    private decimal? _adjustmentAmountTx;
    private DateTime? _adjustmentDatePicker = DateTime.Today;
    private bool WritesBlocked => ShellState.AreWritesBlocked;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorText = null;
        _response = null;
        _factRows = Array.Empty<FactRow>();
        _adjustmentPreview = null;
        _latestAdjustmentRequest = null;
        _adjustmentReadiness = null;
        _adjustmentExecutionPlan = null;
        _adjustmentExecutionResult = null;
        _adjustmentPolicyMappings.Clear();
        _adjustmentPolicyMessage = null;
        _adjustmentCommandMessage = null;
        _adjustmentType = GetDefaultAdjustmentType(OpenItemType);

        if (!await EnsureWriteGateStateAsync())
        {
            _isLoading = false;
            return;
        }

        var responseResult = await DrillDownClient.GetAsync(ShellState.ActiveCompany.Id, OpenItemType, OpenItemId);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(responseResult, CancellationToken.None))
        {
            _isLoading = false;
            return;
        }

        var response = responseResult.Value;
        if (response?.OpenItem is null)
        {
            _errorText = responseResult.IsNotFound
                ? $"The requested {OpenItemType.ToUpperInvariant()} open item could not be found in company {ShellState.ActiveCompany.CompanyCode}."
                : responseResult.ErrorMessage ?? $"Unable to load the requested {OpenItemType.ToUpperInvariant()} open item.";
            _isLoading = false;
            return;
        }

        _response = response;
        _adjustmentAmountTx ??= response.OpenItem.OpenAmountTx;
        _factRows = BuildFactRows(response.OpenItem);
        var manualAccounts = await Accounts.ListManualPostingAccountsAsync(ShellState.ActiveCompany.Id, CancellationToken.None);
        _accountOptions = manualAccounts
            .Where(IsGovernedAdjustmentAccountCandidate)
            .OrderByDescending(IsPreferredAdjustmentAccountCandidate)
            .ThenBy(static account => account.Code, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        _adjustmentAccountIdText = ResolveDefaultAdjustmentAccount(_accountOptions)?.AccountId.ToString("D") ?? _accountOptions.FirstOrDefault()?.AccountId.ToString("D");
        if (!await LoadAdjustmentFlowAsync())
        {
            _isLoading = false;
            return;
        }

        _isLoading = false;
    }

    private static IReadOnlyList<FactRow> BuildFactRows(ShellOpenItemDetail item) =>
    [
        new("Open Item Id", item.OpenItemId.ToString("D")),
        new("Balance Side", item.BalanceSide),
        new("Document Date", item.DocumentDate.ToString("yyyy-MM-dd")),
        new("Due Date", item.DueDate?.ToString("yyyy-MM-dd") ?? "No due date"),
        new("Original Tx", $"{FormatAmount(item.OriginalAmountTx)} {item.DocumentCurrencyCode}"),
        new("Original Base", $"{FormatAmount(item.OriginalAmountBase)} {item.BaseCurrencyCode}"),
        new("Open Tx", $"{FormatAmount(item.OpenAmountTx)} {item.DocumentCurrencyCode}"),
        new("Open Base", $"{FormatAmount(item.OpenAmountBase)} {item.BaseCurrencyCode}")
    ];

    private async Task<bool> LoadAdjustmentFlowAsync()
    {
        if (!await LoadAdjustmentPolicyAsync())
        {
            return false;
        }

        var companyId = ShellState.ActiveCompany.Id;
        var adjustmentDate = GetAdjustmentDate();
        var previewResult = await DrillDownClient.GetAdjustmentPreviewAsync(
            companyId,
            OpenItemType,
            OpenItemId,
            _adjustmentType,
            adjustmentDate,
            GetAdjustmentAmount());
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(previewResult, CancellationToken.None))
        {
            return false;
        }

        _adjustmentPreview = previewResult.Value;
        CapturePageError(previewResult.ErrorCode, previewResult.ErrorMessage, "Unable to load the adjustment preview.");

        var latestRequestResult = await DrillDownClient.GetLatestAdjustmentRequestAsync(companyId, OpenItemType, OpenItemId);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(latestRequestResult, CancellationToken.None))
        {
            return false;
        }

        _latestAdjustmentRequest = latestRequestResult.Value;
        CapturePageError(latestRequestResult.ErrorCode, latestRequestResult.ErrorMessage, "Unable to load the latest adjustment request.");
        if (_latestAdjustmentRequest is null || string.Equals(_latestAdjustmentRequest.RequestStatus, "cancelled", StringComparison.OrdinalIgnoreCase))
        {
            _adjustmentReadiness = null;
            _adjustmentExecutionPlan = null;
            return true;
        }

        var readinessResult = await DrillDownClient.GetAdjustmentReadinessAsync(
            companyId,
            OpenItemType,
            OpenItemId,
            _latestAdjustmentRequest.RequestId,
            adjustmentDate);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(readinessResult, CancellationToken.None))
        {
            return false;
        }

        _adjustmentReadiness = readinessResult.Value;
        CapturePageError(readinessResult.ErrorCode, readinessResult.ErrorMessage, "Unable to load adjustment readiness.");

        var executionPlanResult = await DrillDownClient.GetAdjustmentExecutionPlanAsync(
            companyId,
            OpenItemType,
            OpenItemId,
            _latestAdjustmentRequest.RequestId,
            adjustmentDate);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(executionPlanResult, CancellationToken.None))
        {
            return false;
        }

        _adjustmentExecutionPlan = executionPlanResult.Value;
        CapturePageError(executionPlanResult.ErrorCode, executionPlanResult.ErrorMessage, "Unable to load the adjustment execution plan.");
        return true;
    }

