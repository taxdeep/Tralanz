    private static string GetDefaultAdjustmentType(string? openItemType) =>
        string.Equals(openItemType, "ap", StringComparison.OrdinalIgnoreCase)
            ? "small_balance_adjustment"
            : "write_off";

    private static JournalEntryAccountOption? ResolveDefaultAdjustmentAccount(IReadOnlyList<JournalEntryAccountOption> accounts) =>
        accounts.FirstOrDefault(IsPreferredAdjustmentAccountCandidate)
        ?? accounts.FirstOrDefault(static account => string.Equals(account.RootType, "expense", StringComparison.OrdinalIgnoreCase))
        ?? accounts.FirstOrDefault(static account => string.Equals(account.RootType, "revenue", StringComparison.OrdinalIgnoreCase))
        ?? accounts.FirstOrDefault();

    private static bool IsGovernedAdjustmentAccountCandidate(JournalEntryAccountOption account) =>
        account.AllowManualPosting &&
        account.RootType is "revenue" or "cost_of_sales" or "expense";

    private static bool IsPreferredAdjustmentAccountCandidate(JournalEntryAccountOption account)
    {
        var searchText = $"{account.Code} {account.Name} {account.DetailType} {account.TypeLabel}".ToLowerInvariant();
        return searchText.Contains("write") ||
               searchText.Contains("bad debt") ||
               searchText.Contains("adjust") ||
               searchText.Contains("rounding");
    }

    private static string FormatAdjustmentAccountOption(JournalEntryAccountOption account)
    {
        var rootLabel = FormatRootType(account.RootType);
        return $"{account.DisplayText} | {rootLabel} / {account.TypeLabel}";
    }

    private static string FormatRootType(string? rootType) =>
        rootType?.Trim().ToLowerInvariant() switch
        {
            "revenue" => "Revenue",
            "cost_of_sales" => "Cost of Sales",
            "expense" => "Expense",
            _ => string.IsNullOrWhiteSpace(rootType) ? "Unknown" : rootType
        };

    private static string FormatAdjustmentType(string? adjustmentType) =>
        adjustmentType?.Trim().ToLowerInvariant() switch
        {
            "write_off" => "Write-off",
            "small_balance_adjustment" => "Small balance adjustment",
            _ => string.IsNullOrWhiteSpace(adjustmentType) ? "Adjustment" : adjustmentType
        };

    private static string FormatExecutionMode(string? executionMode) =>
        executionMode?.Trim().ToLowerInvariant() switch
        {
            "posting_engine_adjustment" => "Posting Engine Adjustment",
            "request_recording_only" => "Request Recording Only",
            "governed_execution_skeleton" => "Governed Execution Skeleton",
            _ => string.IsNullOrWhiteSpace(executionMode) ? "Unknown" : executionMode
        };

    private static string FormatAvailabilityMode(string? availabilityMode, bool isAvailable) =>
        availabilityMode?.Trim().ToLowerInvariant() switch
        {
            "available_for_execution" => "Available for execution",
            "available_now" => "Available now",
            "blocked" => isAvailable ? "Available" : "Blocked",
            "not_implemented" => "Not implemented",
            _ => isAvailable ? "Available" : availabilityMode ?? "Unknown"
        };

    private static string FormatPlanStepStatus(string? stepStatus) =>
        stepStatus?.Trim().ToLowerInvariant() switch
        {
            "ready" => "Ready",
            "blocked" => "Blocked",
            "planned" => "Planned",
            _ => string.IsNullOrWhiteSpace(stepStatus) ? "Unknown" : stepStatus
        };

    private static string FormatActor(string? actorType, Guid? actorId) =>
        actorId.HasValue
            ? $"{actorType ?? "actor"} | {actorId.Value:D}"
            : actorType ?? "Unknown";

    private sealed record class AdjustmentCommandOutcome(
        bool Continue,
        string? Message,
        Severity? OverrideSeverity = null);

    private sealed record class FactRow(string Label, string Value);
