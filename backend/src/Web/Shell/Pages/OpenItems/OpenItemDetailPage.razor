    private bool CanRequestAdjustment() =>
        !WritesBlocked &&
        !_isAdjustmentCommandRunning &&
        _adjustmentPreview?.IsAvailable == true &&
        (_latestAdjustmentRequest is null || string.Equals(_latestAdjustmentRequest.RequestStatus, "cancelled", StringComparison.OrdinalIgnoreCase));

    private bool CanSubmitAdjustment() =>
        !WritesBlocked &&
        !_isAdjustmentCommandRunning &&
        string.Equals(_latestAdjustmentRequest?.RequestStatus, "draft", StringComparison.OrdinalIgnoreCase);

    private bool CanCancelAdjustment() =>
        !WritesBlocked &&
        !_isAdjustmentCommandRunning &&
        _latestAdjustmentRequest is not null &&
        (string.Equals(_latestAdjustmentRequest.RequestStatus, "draft", StringComparison.OrdinalIgnoreCase) ||
         string.Equals(_latestAdjustmentRequest.RequestStatus, "submitted", StringComparison.OrdinalIgnoreCase)) &&
        !string.Equals(_latestAdjustmentRequest.ExecutionStatus, "execution_requested", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(_latestAdjustmentRequest.ExecutionStatus, "journal_entry_posted", StringComparison.OrdinalIgnoreCase);

    private bool CanApproveAdjustment() =>
        !WritesBlocked &&
        !_isAdjustmentCommandRunning &&
        _latestAdjustmentRequest?.RequiresApproval == true &&
        string.Equals(_latestAdjustmentRequest.RequestStatus, "submitted", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(_latestAdjustmentRequest.ApprovalStatus, "approved", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(_latestAdjustmentRequest.ExecutionStatus, "execution_requested", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(_latestAdjustmentRequest.ExecutionStatus, "journal_entry_posted", StringComparison.OrdinalIgnoreCase);

    private bool CanRejectAdjustment() =>
        !WritesBlocked &&
        !_isAdjustmentCommandRunning &&
        _latestAdjustmentRequest?.RequiresApproval == true &&
        string.Equals(_latestAdjustmentRequest.RequestStatus, "submitted", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(_latestAdjustmentRequest.ApprovalStatus, "rejected", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(_latestAdjustmentRequest.ExecutionStatus, "execution_requested", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(_latestAdjustmentRequest.ExecutionStatus, "journal_entry_posted", StringComparison.OrdinalIgnoreCase);

    private bool CanExecuteAdjustment() =>
        !WritesBlocked &&
        !_isAdjustmentCommandRunning &&
        _adjustmentExecutionPlan?.CanExecute == true &&
        string.Equals(_latestAdjustmentRequest?.RequestStatus, "submitted", StringComparison.OrdinalIgnoreCase) &&
        Guid.TryParse(_adjustmentAccountIdText, out var adjustmentAccountId) &&
        _accountOptions.Any(account => account.AccountId == adjustmentAccountId);

    private async Task<bool> EnsureWriteGateStateAsync()
    {
        await ShellState.EnsureHydratedAsync();
        var probe = await SessionClient.ProbeContextAsync(CancellationToken.None);
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe, CancellationToken.None))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(probe.ErrorMessage))
        {
            _errorText = WebShellPostingFeedback.DescribeFailure(
                null,
                probe.ErrorMessage,
                "Unable to probe the latest open item state.");
        }

        return true;
    }

    private void CapturePageError(string? errorCode, string? message, string fallbackMessage)
    {
        if (!string.IsNullOrWhiteSpace(message) || !string.IsNullOrWhiteSpace(errorCode))
        {
            _errorText ??= WebShellPostingFeedback.DescribeFailure(errorCode, message, fallbackMessage);
        }
    }

