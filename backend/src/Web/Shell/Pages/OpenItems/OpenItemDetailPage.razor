    private async Task ExecuteAdjustmentRequestAsync()
    {
        if (TryBlockWrites())
        {
            return;
        }

        if (_latestAdjustmentRequest is null || !Guid.TryParse(_adjustmentAccountIdText, out var adjustmentAccountId))
        {
            _adjustmentCommandSeverity = Severity.Warning;
            _adjustmentCommandMessage = "Select a governed adjustment account before execution.";
            return;
        }

        await RunAdjustmentCommandAsync(
            async () =>
            {
                var result = await DrillDownClient.ExecuteAdjustmentRequestAsync(
                    ShellState.ActiveCompany.Id,
                    ShellState.CurrentUserId,
                    OpenItemType,
                    OpenItemId,
                    _latestAdjustmentRequest.RequestId,
                    adjustmentAccountId,
                    GetAdjustmentDate());
                if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(result, CancellationToken.None))
                {
                    return new AdjustmentCommandOutcome(false, null);
                }

                if (result.Value is null)
                {
                    if (!await LoadAdjustmentFlowAsync())
                    {
                        return new AdjustmentCommandOutcome(false, null);
                    }

                    return new AdjustmentCommandOutcome(
                        true,
                        result.ErrorMessage ?? "Unable to execute the adjustment.",
                        Severity.Warning);
                }

                _adjustmentExecutionResult = result.Value;
                if (!await ReloadOpenItemAfterAdjustmentAsync())
                {
                    return new AdjustmentCommandOutcome(false, null);
                }

                return new AdjustmentCommandOutcome(
                    true,
                    $"Adjustment posted as {result.Value.JournalEntryDisplayNumber ?? result.Value.JournalEntryId?.ToString("D") ?? "journal entry unavailable"}.");
            });
    }

    private async Task<bool> ReloadOpenItemAfterAdjustmentAsync()
    {
        var responseResult = await DrillDownClient.GetAsync(ShellState.ActiveCompany.Id, OpenItemType, OpenItemId);
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(responseResult, CancellationToken.None))
        {
            return false;
        }

        if (responseResult.Value?.OpenItem is not null)
        {
            _response = responseResult.Value;
            _factRows = BuildFactRows(responseResult.Value.OpenItem);
        }
        else
        {
        CapturePageError(responseResult.ErrorCode, responseResult.ErrorMessage, "Unable to reload the latest open item state.");
        }

        return await LoadAdjustmentFlowAsync();
    }

    private async Task RunAdjustmentCommandAsync(
        Func<Task<AdjustmentCommandOutcome>> operation,
        Severity successSeverity = Severity.Success)
    {
        _isAdjustmentCommandRunning = true;
        _adjustmentCommandMessage = null;
        _adjustmentCommandSeverity = successSeverity;

        try
        {
            var outcome = await operation();
            if (!outcome.Continue)
            {
                return;
            }

            _adjustmentCommandMessage = outcome.Message;
            if (outcome.OverrideSeverity.HasValue)
            {
                _adjustmentCommandSeverity = outcome.OverrideSeverity.Value;
            }
            else if (_adjustmentCommandSeverity != Severity.Warning)
            {
                _adjustmentCommandSeverity = successSeverity;
            }
        }
        catch (Exception ex)
        {
            _adjustmentCommandSeverity = Severity.Error;
            _adjustmentCommandMessage = ex.Message;
        }
        finally
        {
            _isAdjustmentCommandRunning = false;
        }
    }

