@page "/login"

@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject Web.Shell.Services.WebShellBusinessSessionClient SessionClient
@inject WebShellState ShellState

<PageTitle>Login | Citus Web Shell</PageTitle>

<MudPaper Class="pa-6 mt-10 ws-login">
    <MudStack Spacing="2">
        <MudText Typo="Typo.overline" Class="text-secondary">Business App</MudText>
        <MudText Typo="Typo.h4">Sign In</MudText>
        <MudText Typo="Typo.body2" Class="text-secondary">
            Platform account login followed by CompanyAccess-resolved active company context.
        </MudText>
    </MudStack>

    <MudForm Class="mt-6" @ref="_form">
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_login"
                          Label="Email or username"
                          Variant="Variant.Outlined"
                          Required="true"
                          Immediate="true" />
            <MudTextField @bind-Value="_password"
                          Label="Password"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Required="true" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="_isSubmitting"
                       OnClick="SignInAsync">
                @(_isSubmitting ? "Signing in..." : "Sign in")
            </MudButton>

            @if (_mfaChallengeId.HasValue)
            {
                <MudDivider />
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    @GetSecondFactorPrompt()
                    @if (_mfaChallengeExpiresAtUtc.HasValue)
                    {
                        <text> Challenge expires @_mfaChallengeExpiresAtUtc.Value.ToString("yyyy-MM-dd HH:mm:ss 'UTC'").</text>
                    }
                </MudAlert>
                <MudTextField @bind-Value="_mfaVerificationCode"
                              Label="@GetSecondFactorFieldLabel()"
                              Variant="Variant.Outlined"
                              Immediate="true" />
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           Disabled="_isSubmitting"
                           OnClick="CompleteSecondFactorAsync">
                    @(_isSubmitting ? "Verifying..." : "Complete MFA")
                </MudButton>
            }
        </MudStack>
    </MudForm>
</MudPaper>

@code
{
    private MudForm? _form;
    private string _login = string.Empty;
    private string _password = string.Empty;
    private Guid? _mfaChallengeId;
    private DateTimeOffset? _mfaChallengeExpiresAtUtc;
    private string _mfaVerificationCode = string.Empty;
    private string _requiredSecondFactor = string.Empty;
    private bool _isSubmitting;

    private async Task SignInAsync()
    {
        if (_form is not null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid)
            {
                return;
            }
        }

        _isSubmitting = true;

        try
        {
            var (result, error) = await SessionClient.SignInAsync(_login, _password);
            if (result?.RequiresSecondFactor == true)
            {
                _mfaChallengeId = Guid.TryParse(result.MfaChallengeId, out var challengeId) ? challengeId : null;
                _mfaChallengeExpiresAtUtc = result.MfaChallengeExpiresAtUtc;
                _mfaVerificationCode = string.Empty;
                _requiredSecondFactor = result.AvailableSecondFactors.FirstOrDefault()?.Trim().ToLowerInvariant() ?? string.Empty;
                var availableFactors = result.AvailableSecondFactors.Count == 0
                    ? "configured second factor"
                    : string.Join(", ", result.AvailableSecondFactors.Select(FormatSecondFactor));
                Snackbar.Add(
                    $"Primary authentication succeeded. MFA challenge is required before session issuance. Available factor(s): {availableFactors}.",
                    Severity.Info);
                return;
            }

            if (result is null || string.IsNullOrWhiteSpace(result.SessionToken) || result.Context is null)
            {
                Snackbar.Add(
                    string.IsNullOrWhiteSpace(error)
                        ? "Unable to sign in. Check account status, credentials, and company membership."
                        : error,
                    Severity.Warning);
                return;
            }

            await CompleteAuthenticatedSessionAsync(result);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task CompleteSecondFactorAsync()
    {
        if (!_mfaChallengeId.HasValue)
        {
            Snackbar.Add("No active MFA challenge is pending.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_mfaVerificationCode))
        {
            Snackbar.Add("Verification code is required.", Severity.Warning);
            return;
        }

        _isSubmitting = true;

        try
        {
            var (result, error) = await SessionClient.CompleteSecondFactorAsync(
                _mfaChallengeId.Value,
                _mfaVerificationCode);

            if (result is null || string.IsNullOrWhiteSpace(result.SessionToken) || result.Context is null)
            {
                Snackbar.Add(
                    string.IsNullOrWhiteSpace(error)
                        ? "Unable to complete MFA verification."
                        : error,
                    Severity.Warning);
                return;
            }

            await CompleteAuthenticatedSessionAsync(result);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task CompleteAuthenticatedSessionAsync(Web.Shell.Services.WebShellBusinessSignInResponse result)
    {
        _mfaChallengeId = null;
        _mfaChallengeExpiresAtUtc = null;
        _mfaVerificationCode = string.Empty;
        _requiredSecondFactor = string.Empty;

        ShellState.ApplyAuthenticatedSession(result.SessionToken, result.Context!, result.ExpiresAtUtc);
        await JS.InvokeVoidAsync("citusBusinessAuth.setSessionToken", result.SessionToken);

        Snackbar.Add(
            $"Signed in as {result.Context!.User.DisplayName} in {result.Context.ActiveCompany.CompanyName}.",
            Severity.Success);
        NavigationManager.NavigateTo("/");
    }

    private static string FormatSecondFactor(string factor) =>
        factor.Trim().ToLowerInvariant() switch
        {
            "email_code" => "Email verification code",
            "totp_app" => "Authenticator app (TOTP)",
            _ => factor
        };

    private string GetSecondFactorPrompt() =>
        string.Equals(_requiredSecondFactor, "totp_app", StringComparison.OrdinalIgnoreCase)
            ? "Authenticator app confirmation is required before session issuance."
            : "Second factor is required before session issuance.";

    private string GetSecondFactorFieldLabel() =>
        string.Equals(_requiredSecondFactor, "totp_app", StringComparison.OrdinalIgnoreCase)
            ? "Authenticator app code"
            : "Verification code";
}
