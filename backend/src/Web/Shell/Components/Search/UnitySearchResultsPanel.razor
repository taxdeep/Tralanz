@using Citus.Modules.UnitySearch.Application.Contracts

@if ((Groups?.Count ?? 0) > 0 || (RecentQueries?.Count ?? 0) > 0 || (RecentSelections?.Count ?? 0) > 0)
{
    <div class="unity-search-panel" role="listbox" aria-label="Search results">
        @if ((RecentQueries?.Count ?? 0) > 0)
        {
            <section class="unity-search-panel__group">
                <div class="unity-search-panel__heading">Recent queries</div>
                <div class="unity-search-panel__chips">
                    @foreach (var recentQuery in RecentQueries!)
                    {
                        <button type="button"
                                class="unity-search-panel__chip"
                                @onclick="@(() => OnRecentQuerySelected.InvokeAsync(recentQuery.QueryText))">
                            <i class="ti ti-history" aria-hidden="true"></i>
                            <span>@recentQuery.QueryText</span>
                        </button>
                    }
                </div>
            </section>
        }

        @if ((RecentSelections?.Count ?? 0) > 0)
        {
            <section class="unity-search-panel__group">
                <div class="unity-search-panel__heading">Recently opened</div>
                <div class="unity-search-panel__items">
                    @foreach (var item in RecentSelections!)
                    {
                        <button type="button"
                                class="unity-search-panel__item"
                                @onclick="@(() => OnRecentSelectionSelected.InvokeAsync(item))">
                            <span class="unity-search-panel__primary">@item.PrimaryText</span>
                            @if (!string.IsNullOrWhiteSpace(item.SecondaryText))
                            {
                                <span class="unity-search-panel__secondary">@item.SecondaryText</span>
                            }
                            <span class="unity-search-panel__meta">@item.EntityType.Replace('_', ' ') · @item.ClickCount click(s)</span>
                        </button>
                    }
                </div>
            </section>
        }

        @foreach (var group in Groups!)
        {
            if (group.Items.Count == 0)
            {
                continue;
            }

            <section class="unity-search-panel__group">
                <div class="unity-search-panel__heading">@group.Title</div>
                <div class="unity-search-panel__items">
                    @foreach (var item in group.Items)
                    {
                        <button type="button"
                                class="unity-search-panel__item"
                                @onclick="@(() => OnItemSelected.InvokeAsync(item))">
                            <span class="unity-search-panel__primary">@item.PrimaryText</span>
                            @if (!string.IsNullOrWhiteSpace(item.SecondaryText))
                            {
                                <span class="unity-search-panel__secondary">@item.SecondaryText</span>
                            }
                        </button>
                    }
                </div>
            </section>
        }
    </div>
}

@code
{
    [Parameter]
    public IReadOnlyList<UnitySearchGroupResult>? Groups { get; set; }

    [Parameter]
    public EventCallback<UnitySearchSuggestion> OnItemSelected { get; set; }

    [Parameter]
    public IReadOnlyList<UnitySearchRecentQueryRecord>? RecentQueries { get; set; }

    [Parameter]
    public EventCallback<string> OnRecentQuerySelected { get; set; }

    [Parameter]
    public IReadOnlyList<UnitySearchRecentSelectionRecord>? RecentSelections { get; set; }

    [Parameter]
    public EventCallback<UnitySearchRecentSelectionRecord> OnRecentSelectionSelected { get; set; }
}
