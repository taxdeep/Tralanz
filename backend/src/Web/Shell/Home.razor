@page "/"
@inject WebShellState ShellState
@inject Web.Shell.Services.WebShellBusinessSessionClient SessionClient
@inject Web.Shell.Services.WebShellCompanyOnboardingClient OnboardingClient
@inject Web.Shell.Services.WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject NavigationManager NavigationManager

@code {
    private Citus.Ui.Shared.Business.BusinessSessionContextSummary? _apiSessionContext;
    private string? _apiSessionWarning;
    private bool WritesBlocked => ShellState.AreWritesBlocked;

    protected override async Task OnInitializedAsync()
    {
        await ShellState.EnsureHydratedAsync();
        var onboardingResult = await OnboardingClient.GetAsync();
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(onboardingResult))
        {
            return;
        }

        if (!onboardingResult.RequiresSignIn &&
            !onboardingResult.IsNotFound &&
            string.IsNullOrWhiteSpace(onboardingResult.ErrorMessage) &&
            onboardingResult.Value?.RequiresOnboarding == true)
        {
            NavigationManager.NavigateTo("/company/ready", replace: true);
            return;
        }

        var probe = await SessionClient.ProbeContextAsync();
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe))
        {
            return;
        }

        _apiSessionContext = probe.Context;
        if (_apiSessionContext is null)
        {
            _apiSessionWarning = probe.ErrorMessage ?? "Accounting API did not accept the current shell session context. Future API-backed business pages will stay blocked until session configuration and membership truth align.";
            return;
        }
    }
}

<div style="padding:2rem 2.25rem;color:#d9e2ea;">
    <h1 style="margin:0 0 0.75rem 0;font-size:1.5rem;">Citus Web Shell</h1>
    <p style="margin:0 0 1rem 0;color:#97a8b7;max-width:48rem;">
        This shell hosts whitelist-compliant business workspaces. The current priority surfaces are the dark-mode Journal Entry workbench, the governed Multi-Book control area, the first API-backed AR/AP settlement preparation pages, and the new source-document draft editors.
    </p>
    <p style="margin:0 0 1rem 0;color:#aac0cf;max-width:48rem;">
        Active company: <strong>@ShellState.ActiveCompany.CompanyName</strong> (@ShellState.ActiveCompany.CompanyCode).
        Available shell companies: <strong>@ShellState.AvailableCompanies.Count</strong>.
        Context source: <strong>@ShellState.ContextSource</strong>.
    </p>
    <p style="margin:0 0 1rem 0;color:#8bb5d6;max-width:48rem;">
        API session probe:
        <strong>@(_apiSessionContext is null ? "unavailable" : $"{_apiSessionContext.ActiveCompany.CompanyName} ({_apiSessionContext.ActiveCompany.CompanyCode})")</strong>.
    </p>
    @if (!string.IsNullOrWhiteSpace(_apiSessionWarning))
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin:0 0 1rem 0;max-width:60rem;">
            @_apiSessionWarning
        </MudAlert>
    }
    @if (WritesBlocked)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin:0 0 1rem 0;max-width:60rem;">
            @ShellState.WriteBlockMessage
        </MudAlert>
    }
    <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="/company/book-governance">
            Open Multi-Book governance
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/company/bank-and-cash-setup">
            Open Bank & Cash Setup
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Href="/company/tax-setup">
            Open Tax Setup
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Tertiary" Href="/ar/receive-payment">
            Open Receive Payment
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Info" Href="/ap/pay-bill">
            Open Pay Bill
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/gl/journal-entry/editor" Disabled="WritesBlocked">
            Open Journal Entry workbench
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/documents/source-browser">
            Open Source Documents
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Success" Href="/documents/invoice/draft-editor" Disabled="WritesBlocked">
            New Invoice Draft
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Href="/documents/credit-note/draft-editor" Disabled="WritesBlocked">
            New Credit Note Draft
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="/documents/bill/draft-editor" Disabled="WritesBlocked">
            New Bill Draft
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/documents/vendor-credit/draft-editor" Disabled="WritesBlocked">
            New Vendor Credit Draft
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="/ar/credit-application">
            Open Credit Application
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Href="/ap/vendor-credit-application">
            Open Vendor Credit Application
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/profile">
            Open Profile
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="/settings/user-preferences/system-setup">
            User Preferences
        </MudButton>
    </div>
</div>
