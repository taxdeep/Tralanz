@page "/"
@inject WebShellState ShellState
@inject Web.Shell.Services.WebShellBusinessSessionClient SessionClient
@inject Web.Shell.Services.WebShellCompanyOnboardingClient OnboardingClient
@inject Web.Shell.Services.WebShellSessionExpirationCoordinator SessionExpirationCoordinator
@inject NavigationManager NavigationManager

<PageTitle>Workspace | Balanciz</PageTitle>

<section class="bz-home">
    <header class="bz-home__hero">
        <div class="bz-home__hero-copy">
            <div class="bz-home__eyebrow">Balanciz operator workspace</div>
            <h1>@ShellState.ActiveCompany.CompanyName</h1>
            <p class="bz-home__hero-text">
                Run commercial workflows, receivable and payable operations, and accounting control from one operator-grade workspace.
            </p>
            <div class="bz-home__meta">
                <span>@ShellState.ActiveCompany.CompanyCode</span>
                <span>@ShellState.ActiveCompany.BaseCurrencyCode</span>
                <span>@(ShellState.ActiveCompany.MultiCurrencyEnabled ? "Multi-currency" : "Single currency")</span>
                <span>@FormatStatus(ShellState.ActiveCompany.Status)</span>
            </div>
        </div>
        <div class="bz-home__hero-panel">
            <div class="bz-home__hero-panel-label">Balanciz</div>
            <div class="bz-home__hero-panel-title">Business control cockpit</div>
            <div class="bz-home__hero-panel-text">
                Use the top status bar for operator context, the left rail for pipelines, and this workspace to move between source truth, settlement, and review.
            </div>
            <div class="bz-home__hero-actions">
                <a class="bz-btn bz-btn--primary @(WritesBlocked ? "bz-btn--disabled" : string.Empty)"
                   href="@(WritesBlocked ? null : "/documents/invoice/draft-editor")"
                   aria-disabled="@WritesBlocked">
                    <i class="ti ti-file-invoice" aria-hidden="true"></i>
                    <span>New invoice</span>
                </a>
                <a class="bz-btn bz-btn--secondary" href="/documents/source-browser">
                    <i class="ti ti-files" aria-hidden="true"></i>
                    <span>Documents</span>
                </a>
            </div>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_apiSessionWarning))
    {
        <div class="bz-home__alert bz-home__alert--warning">
            <i class="ti ti-alert-triangle" aria-hidden="true"></i>
            <span>@_apiSessionWarning</span>
        </div>
    }
    @if (WritesBlocked)
    {
        <div class="bz-home__alert bz-home__alert--warning">
            <i class="ti ti-lock" aria-hidden="true"></i>
            <span>@ShellState.WriteBlockMessage</span>
        </div>
    }

    <div class="bz-home__status-grid">
        @foreach (var item in StatusItems)
        {
            <article class="bz-home__status-card">
                <div class="bz-home__status-icon @($"bz-home__status-icon--{item.Theme}")">
                    <i class="@item.IconClass" aria-hidden="true"></i>
                </div>
                <div>
                    <div class="bz-home__status-label">@item.Label</div>
                    <div class="bz-home__status-value">@item.Value</div>
                </div>
            </article>
        }
    </div>

    <div class="bz-home__content-grid">
        <section class="bz-home__panel">
            <div class="bz-home__panel-head">
                <div>
                    <h2>Daily work</h2>
                    <p>Receivables, payables, drafts, and governed review surfaces.</p>
                </div>
                <span class="bz-home__panel-tag">
                    <i class="ti ti-sparkles" aria-hidden="true"></i>
                    Operator actions
                </span>
            </div>

            <div class="bz-home__action-grid">
                @foreach (var action in PrimaryActions)
                {
                    @if (action.Disabled)
                    {
                        <span class="@GetActionClass(action)" aria-disabled="true">
                            <span class="bz-home__action-icon">
                                <i class="@action.IconClass" aria-hidden="true"></i>
                            </span>
                            <span>
                                <strong>@action.Title</strong>
                                <small>@action.Detail</small>
                            </span>
                        </span>
                    }
                    else
                    {
                        <a class="@GetActionClass(action)" href="@action.Href">
                            <span class="bz-home__action-icon">
                                <i class="@action.IconClass" aria-hidden="true"></i>
                            </span>
                            <span>
                                <strong>@action.Title</strong>
                                <small>@action.Detail</small>
                            </span>
                        </a>
                    }
                }
            </div>
        </section>

        <section class="bz-home__panel">
            <div class="bz-home__panel-head">
                <div>
                    <h2>Control surfaces</h2>
                    <p>Governance, setup, and review surfaces grouped by operator concern.</p>
                </div>
                <span class="bz-home__panel-tag">
                    <i class="ti ti-layout-grid" aria-hidden="true"></i>
                    Domain groups
                </span>
            </div>

            <div class="bz-home__module-grid">
                @foreach (var module in Modules)
                {
                    <section class="bz-home__module">
                        <div class="bz-home__module-head">
                            <span class="bz-home__module-icon">
                                <i class="@module.IconClass" aria-hidden="true"></i>
                            </span>
                            <h3>@module.Title</h3>
                        </div>
                        <div class="bz-home__module-links">
                            @foreach (var link in module.Links)
                            {
                                @if (link.Disabled)
                                {
                                    <span class="bz-home__module-link bz-home__module-link--disabled">
                                        <i class="@link.IconClass" aria-hidden="true"></i>
                                        <span>@link.Title</span>
                                    </span>
                                }
                                else
                                {
                                    <a class="bz-home__module-link" href="@link.Href">
                                        <i class="@link.IconClass" aria-hidden="true"></i>
                                        <span>@link.Title</span>
                                    </a>
                                }
                            }
                        </div>
                    </section>
                }
            </div>
        </section>
    </div>
</section>

@code {
    private Citus.Ui.Shared.Business.BusinessSessionContextSummary? _apiSessionContext;
    private Web.Shell.Services.WebShellCompanyOnboardingSummary? _onboardingSummary;
    private string? _apiSessionWarning;
    private bool WritesBlocked => ShellState.AreWritesBlocked;

    private IReadOnlyList<StatusItem> StatusItems =>
    [
        new("Session", _apiSessionContext is null ? "Checking" : "Connected", "ti ti-shield-check", "emerald"),
        new("Companies", ShellState.AvailableCompanies.Count.ToString(), "ti ti-building-bank", "blue"),
        new("Chart", _onboardingSummary?.HasStarterChart == true ? $"{_onboardingSummary.StarterAccountCount} accounts" : "Review", "ti ti-hierarchy-3", "violet"),
        new("Tax", _onboardingSummary?.HasActiveTaxCodes == true ? $"{_onboardingSummary.ActiveTaxCodeCount} active" : "Setup", "ti ti-receipt-tax", "amber")
    ];

    private IReadOnlyList<ActionTile> PrimaryActions =>
    [
        new("Receive Payment", "Apply AR cash receipts", "/ar/receive-payment", "ti ti-cash-register", "emerald"),
        new("AR Aging", "Review receivable exposure", "/ar/aging", "ti ti-chart-bar-popular", "amber"),
        new("Quote Draft", "Start customer offer truth", "/documents/quote/draft-editor", "ti ti-file-pencil", "blue", WritesBlocked),
        new("Quote Pipeline", "Review offer truth", "/documents/source-browser?sourceType=quote", "ti ti-file-text-ai", "blue"),
        new("Sales Order Draft", "Commit customer demand", "/documents/sales-order/draft-editor", "ti ti-file-pencil", "emerald", WritesBlocked),
        new("Sales Orders", "Review SO pipeline", "/documents/source-browser?sourceType=sales_order", "ti ti-file-check", "emerald"),
        new("Invoice Pipeline", "Review posted receivable anchors", "/documents/source-browser?sourceType=invoice&counterpartyRole=customer", "ti ti-file-invoice", "amber"),
        new("Pay Bill", "Prepare AP settlement", "/ap/pay-bill", "ti ti-credit-card-pay", "blue"),
        new("Vendor Credit Application", "Offset AP with vendor credit", "/ap/vendor-credit-application", "ti ti-credit-card-refund", "violet"),
        new("AP Aging", "Review payable exposure", "/ap/aging", "ti ti-chart-donut-2", "amber"),
        new("Purchase Order Draft", "Start ordered truth", "/documents/purchase-order/draft-editor", "ti ti-file-pencil", "blue", WritesBlocked),
        new("Purchase Orders", "Review PO lifecycle audit", "/documents/source-browser?sourceType=purchase_order", "ti ti-clipboard-list", "blue"),
        new("Bill Pipeline", "Review payable anchors", "/documents/source-browser?sourceType=bill&counterpartyRole=vendor", "ti ti-file-description", "violet"),
        new("Receipt Draft", "Start inbound receipt truth", "/documents/receipt/draft-editor", "ti ti-file-pencil", "emerald", WritesBlocked),
        new("Receipts", "Review receipt controls", "/documents/source-browser?sourceType=receipt", "ti ti-package-import", "blue"),
        new("PO Approvals", "Review approval requests", "/documents/purchase-orders/approval-requests", "ti ti-checklist", "amber"),
        new("Journal Entry", "Review GL and create entries", "/gl/journal-entries", "ti ti-writing-sign", "blue"),
        new("Source Documents", "Browse posted business documents", "/documents/source-browser", "ti ti-files", "emerald"),
        new("Invoice Draft", "Start a customer invoice", "/documents/invoice/draft-editor", "ti ti-file-pencil", "emerald", WritesBlocked),
        new("Bill Draft", "Start a vendor bill", "/documents/bill/draft-editor", "ti ti-file-pencil", "violet", WritesBlocked)
    ];

    private IReadOnlyList<ModulePanel> Modules =>
    [
        new(
            "Company Control",
            "ti ti-shield-cog",
            [
                new("Book Governance", "/company/book-governance", "ti ti-book-2"),
                new("Bank & Cash", "/company/bank-and-cash-setup", "ti ti-building-bank"),
                new("Tax Setup", "/company/tax-setup", "ti ti-percentage"),
                new("Memberships", "/company/membership-permissions", "ti ti-users")
            ]),
        new(
            "Trading Setup",
            "ti ti-building-store",
            [
                new("Customers & Vendors", "/company/customer-vendor-setup", "ti ti-users-group"),
                new("Products & Services", "/company/product-service-setup", "ti ti-package"),
                new("Inventory Foundation", "/company/inventory-foundation", "ti ti-building-warehouse"),
                new("Availability", "/company/inventory-availability", "ti ti-clipboard-data")
            ]),
        new(
            "Profile",
            "ti ti-user-cog",
            [
                new("User Profile", "/profile", "ti ti-user-circle"),
                new("Preferences", "/settings/user-preferences/system-setup", "ti ti-adjustments-horizontal"),
                new("Adjustment Mapping", "/company/open-item-adjustment-account-mappings", "ti ti-schema")
            ])
    ];

    protected override async Task OnInitializedAsync()
    {
        await ShellState.EnsureHydratedAsync();
        var onboardingResult = await OnboardingClient.GetAsync();
        if (await SessionExpirationCoordinator.HandleAuthenticatedApiResultAsync(onboardingResult))
        {
            return;
        }

        if (!onboardingResult.RequiresSignIn &&
            !onboardingResult.IsNotFound &&
            string.IsNullOrWhiteSpace(onboardingResult.ErrorMessage) &&
            onboardingResult.Value?.RequiresOnboarding == true)
        {
            NavigationManager.NavigateTo("/company/ready", replace: true);
            return;
        }

        if (!onboardingResult.RequiresSignIn &&
            !onboardingResult.IsNotFound &&
            string.IsNullOrWhiteSpace(onboardingResult.ErrorMessage))
        {
            _onboardingSummary = onboardingResult.Value;
        }

        var probe = await SessionClient.ProbeContextAsync();
        if (await SessionExpirationCoordinator.HandleProbeAsync(probe))
        {
            return;
        }

        _apiSessionContext = probe.Context;
        if (_apiSessionContext is null)
        {
            _apiSessionWarning = probe.ErrorMessage ?? "Accounting API did not accept the current shell session context.";
        }
    }

    private static string FormatStatus(string status) =>
        string.IsNullOrWhiteSpace(status)
            ? "Inactive"
            : char.ToUpperInvariant(status[0]) + status[1..].ToLowerInvariant();

    private static string GetActionClass(ActionTile action) =>
        action.Disabled
            ? "bz-home__action bz-home__action--disabled"
            : $"bz-home__action bz-home__action--{action.Theme}";

    private sealed record StatusItem(string Label, string Value, string IconClass, string Theme);

    private sealed record ActionTile(
        string Title,
        string Detail,
        string Href,
        string IconClass,
        string Theme,
        bool Disabled = false);

    private sealed record ModulePanel(
        string Title,
        string IconClass,
        IReadOnlyList<ModuleLink> Links);

    private sealed record ModuleLink(
        string Title,
        string Href,
        string IconClass,
        bool Disabled = false);
}
