@using Modules.GL.JournalEntry

<div class="je-totals-footer">
    @if (Totals.ShowBaseTotals)
    {
        <div class="je-totals-footer__caption">
            Posting truth remains in @Totals.BaseCurrencyCode. Transaction amounts are source amounts used to derive base amounts.
        </div>
    }

    <div class="je-totals-footer__row">
        <div class="je-totals-footer__label">Total @Totals.TransactionCurrencyCode</div>
        <div class="je-totals-footer__amount">@FormatAmount(Totals.TransactionDebitTotal)</div>
        <div class="je-totals-footer__amount">@FormatAmount(Totals.TransactionCreditTotal)</div>
    </div>

    @if (Totals.ShowBaseTotals)
    {
        <div class="je-totals-footer__row je-totals-footer__row--base">
            <div class="je-totals-footer__label">Total @Totals.BaseCurrencyCode</div>
            <div class="je-totals-footer__amount">@FormatAmount(Totals.BaseDebitTotal)</div>
            <div class="je-totals-footer__amount">@FormatAmount(Totals.BaseCreditTotal)</div>
        </div>
    }
</div>

@code
{
    [Parameter, EditorRequired]
    public JournalEntryGridTotals Totals { get; set; } = default!;

    private static string FormatAmount(decimal amount) => amount.ToString("N2");
}
