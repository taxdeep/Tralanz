@page "/gl/journal-entry/editor"
@using Engines.FX.FxRateLookup
@using Engines.Numbering.JournalEntry
@using Modules.CompanyAccess.SessionContext
@using Modules.Company.MultiCurrency
@using Modules.GL.JournalEntry
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using SharedKernel.Company
@inject IFxRateResolver FxRateResolver
@inject IFxRateSelectionService FxRateSelectionService
@inject ICompanyCurrencyGovernanceWorkflow CompanyCurrencyGovernanceWorkflow
@inject ICompanyAccessShellSession ShellSession
@inject IJournalEntryNumberLookup JournalEntryNumberLookup
@inject IJournalEntryWorkflow JournalEntryWorkflow
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>@_state.Draft.Title</PageTitle>

<div class="je-editor">
    <div class="je-editor-shell">
        <div class="je-workbench-title">
            <div class="je-workbench-title__text">
                <MudIcon Icon="@Icons.Material.Outlined.History" Size="Size.Small" />
                <span>@_state.Draft.Title</span>
            </div>
            <div class="je-workbench-title__meta">
                <MudChip T="string" Variant="Variant.Text" Color="Color.Success">Dark mode</MudChip>
                <MudChip T="string" Variant="Variant.Text" Color="Color.Info">Excel-style grid</MudChip>
            </div>
        </div>

        @if (WritesBlocked)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-4">
                @ShellSession.WriteBlockMessage
            </MudAlert>
        }

        <JournalEntryHeaderBand State="_state"
                                IsFxBusy="_isFxBusy"
                                FxErrorText="@_fxErrorText"
                                OnCurrencyChanged="HandleCurrencyChanged"
                                OnFxRateChanged="HandleFxRateChanged"
                                OnJournalDateChanged="HandleJournalDateChanged" />

        @if (_companyCurrencyProfile is not null)
        {
            <div class="je-company-currency-bar">
                <div class="je-company-currency-bar__summary">
                    <div class="je-company-currency-bar__label">Company currencies</div>
                    <div class="je-company-currency-bar__chips">
                        @foreach (var currency in _companyCurrencyProfile.EnabledCurrencies)
                        {
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Variant="Variant.Outlined"
                                     Color="@(currency.IsBaseCurrency ? Color.Success : Color.Info)">
                                @(currency.IsBaseCurrency ? $"{currency.CurrencyCode} base" : currency.CurrencyCode)
                            </MudChip>
                        }
                    </div>
                </div>

                @if (_state.CanEditJournal && !WritesBlocked && _companyCurrencyProfile.Currencies.Any(currency => !currency.IsEnabled))
                {
                    <div class="je-company-currency-bar__enable">
                        <MudSelect T="string"
                                   Value="_enableCurrencyCode"
                                   ValueChanged="HandleEnableCurrencySelectionChanged"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Dense="true"
                                   Disabled="@_isCurrencyGovernanceBusy"
                                   Class="je-select je-select--compact">
                            @foreach (var currency in _companyCurrencyProfile.Currencies.Where(currency => !currency.IsEnabled))
                            {
                                <MudSelectItem T="string" Value="@currency.CurrencyCode">@currency.DisplayText</MudSelectItem>
                            }
                        </MudSelect>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Info"
                                   Disabled="@(_isCurrencyGovernanceBusy || string.IsNullOrWhiteSpace(_enableCurrencyCode))"
                                   OnClick="HandleEnableCurrencyAsync">
                            Enable currency
                        </MudButton>
                    </div>
                }
            </div>
        }

        <JournalEntryFxReviewPanel State="_state" SelectionData="_fxSelectionData" />

        @if (_state.Draft.IsForeignCurrency && _state.CanEditJournal && !WritesBlocked)
        {
            <JournalEntryFxSelectionPanel State="_state"
                                          SelectionData="_fxSelectionData"
                                          IsBusy="_isFxBusy"
                                          OnUseSnapshot="HandleUseSnapshotAsync"
                                          OnUseMarketRate="HandleUseMarketRateAsync"
                                          OnPersistManualSnapshot="HandlePersistManualSnapshotAsync" />
        }

        <JournalEntryGrid State="_state" OnChanged="HandleChanged" />

        <div class="je-bottom-panels">
            <div class="je-panel">
                <div class="je-panel__label">Memo</div>
                <MudTextField T="string"
                              @bind-Value="_state.Draft.Memo"
                              Lines="4"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              FullWidth="true" />
            </div>

            <div class="je-panel">
                <div class="je-panel__label">Attachments</div>
                <div class="je-attachment-dropzone">
                    <div class="je-attachment-dropzone__title">Add attachment</div>
                    <div class="je-attachment-dropzone__hint">Max file size: 20 MB</div>
                    <MudButton Variant="Variant.Text" Color="Color.Info">Show existing</MudButton>
                </div>
            </div>
        </div>

        <div class="je-action-bar">
            <div class="je-action-bar__left">
                <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="/">Cancel</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Info" Disabled="@(!_state.CanEditJournal || WritesBlocked)" OnClick="ClearLines">Clear</MudButton>
            </div>

            <div class="je-action-bar__center">
                <MudChip T="string" Variant="Variant.Text" Color="@(_state.Draft.Status == "posted" ? Color.Success : Color.Info)">
                    @(_state.Draft.Status == "posted" ? "Posted" : "Draft")
                </MudChip>
                @if (!string.IsNullOrWhiteSpace(_state.Draft.DocumentNumber))
                {
                    <MudChip T="string" Variant="Variant.Text" Color="Color.Default">@_state.Draft.DocumentNumber</MudChip>
                }
                @if (_postedJournalEntryId.HasValue)
                {
                    <MudButton Variant="Variant.Text"
                               Color="Color.Info"
                               Href="@BuildReviewHref(_postedJournalEntryId.Value)">
                        Open review
                    </MudButton>
                }
            </div>

            <div class="je-action-bar__right">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Success"
                           Disabled="@(_isSaving || _isPosting || !_state.CanEditJournal || WritesBlocked)"
                           OnClick="HandleSaveClickAsync">
                    Save
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Warning"
                           Disabled="@(_isSaving || _isPosting || !_state.CanEditJournal || WritesBlocked)"
                           OnClick="PostDraftAsync">
                    Post
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           Disabled="@(_isSaving || _isPosting || !_state.CanEditJournal || WritesBlocked)"
                           OnClick="HandleSaveAndCloseClickAsync">
                    Save and close
                </MudButton>
            </div>
        </div>
    </div>
</div>

@code
{
    private readonly JournalEntryEditorState _state = JournalEntryEditorState.CreateDarkModeDemo();
    private FxRateSelectionData _fxSelectionData = new([], []);
    private CompanyCurrencyProfile? _companyCurrencyProfile;
    private bool _isCurrencyGovernanceBusy;
    private bool _isFxBusy;
    private bool _isSaving;
    private bool _isPosting;
    private string? _fxErrorText;
    private string? _enableCurrencyCode;
    private Guid? _postedJournalEntryId;
    private bool WritesBlocked => ShellSession.AreWritesBlocked;
    private Guid CurrentUserId => ShellSession.CurrentUserId;

    protected override async Task OnInitializedAsync()
    {
        await EnsureWriteGateStateAsync();
        _state.Draft.CompanyId = ShellSession.ActiveCompanyId;
        _state.Draft.JournalDate = DateOnly.FromDateTime(DateTime.Today);
        await LoadCompanyCurrencyProfileAsync();
        var accountOptions = await JournalEntryWorkflow.LoadAccountOptionsAsync(_state.Draft.CompanyId, CancellationToken.None);
        _state.ReplaceAccountOptions(accountOptions);
        _state.SetJournalNumber(await JournalEntryNumberLookup.GetNextDisplayNumberAsync(_state.Draft.CompanyId, CancellationToken.None));
        await RefreshFxRateAsync();
    }

    private Task HandleChanged()
    {
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task HandleCurrencyChanged(string currencyCode)
    {
        _state.SetCurrency(currencyCode);
        await RefreshFxRateAsync();
    }

    private Task HandleEnableCurrencySelectionChanged(string? currencyCode)
    {
        _enableCurrencyCode = currencyCode;
        return Task.CompletedTask;
    }

    private async Task HandleJournalDateChanged(DateOnly journalDate)
    {
        _state.SetJournalDate(journalDate);
        await RefreshFxRateAsync();
    }

    private Task HandleFxRateChanged(decimal fxRate)
    {
        _state.ApplyManualFxRate(fxRate);
        _ = LoadFxSelectionDataAsync();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task ClearLines()
    {
        if (TryBlockWrites())
        {
            return Task.CompletedTask;
        }

        _state.ClearAllLines();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandleSaveClickAsync() => SaveDraftCoreAsync();

    private async Task HandleSaveAndCloseClickAsync()
    {
        var saved = await SaveDraftCoreAsync();
        if (saved)
        {
            Navigation.NavigateTo("/");
        }
    }

    private async Task<bool> SaveDraftCoreAsync()
    {
        if (TryBlockWrites())
        {
            return false;
        }

        try
        {
            _isSaving = true;
            StateHasChanged();

            var result = await JournalEntryWorkflow.SaveDraftAsync(_state.Draft, CurrentUserId, CancellationToken.None);
            _state.Draft.DocumentId = result.DocumentId;
            _state.Draft.DocumentNumber = result.DocumentNumber;
            _state.Draft.Status = result.Status;
            Snackbar.Add($"Draft saved as {result.DocumentNumber}.", Severity.Success);
            return true;
        }
        catch (Exception ex)
        {
            Snackbar.Add(DescribeEditorFailure(ex), Severity.Error);
            return false;
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task PostDraftAsync()
    {
        if (TryBlockWrites())
        {
            return;
        }

        try
        {
            _isPosting = true;
            StateHasChanged();

            var result = await JournalEntryWorkflow.PostDraftAsync(_state.Draft, CurrentUserId, CancellationToken.None);
            _state.Draft.DocumentId = result.DocumentId;
            _state.Draft.DocumentNumber = result.DocumentNumber;
            _state.Draft.JournalNumber = result.JournalDisplayNumber;
            _state.Draft.Status = "posted";
            _postedJournalEntryId = result.JournalEntryId;
            Snackbar.Add($"Posted as {result.JournalDisplayNumber}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(DescribeEditorFailure(ex), Severity.Error);
        }
        finally
        {
            _isPosting = false;
            StateHasChanged();
        }
    }

    private async Task RefreshFxRateAsync()
    {
        _fxErrorText = null;

        if (!_state.Draft.IsForeignCurrency)
        {
            _state.ApplyIdentityFxRate();
            _fxSelectionData = new FxRateSelectionData([], []);
            StateHasChanged();
            return;
        }

        try
        {
            _isFxBusy = true;
            StateHasChanged();

            var resolution = await FxRateResolver.ResolveAsync(
                new FxRateLookupRequest(
                    _state.Draft.CompanyId,
                    CurrentUserId,
                    _state.Draft.CurrencyCode,
                    _state.Draft.BaseCurrencyCode,
                    _state.Draft.JournalDate,
                    _state.Draft.FxProviderKey,
                    7,
                    _state.Draft.FxRateType,
                    _state.Draft.FxQuoteBasis,
                    _state.Draft.FxRateUseCase,
                    _state.Draft.FxPostingReason),
                CancellationToken.None);

            _state.ApplyResolvedFxRate(resolution);
            await LoadFxSelectionDataAsync();
        }
        catch (Exception ex)
        {
            _fxErrorText = DescribeEditorFailure(ex);
        }
        finally
        {
            _isFxBusy = false;
            StateHasChanged();
        }
    }

    private async Task HandleUseSnapshotAsync(Guid snapshotId)
    {
        if (TryBlockWrites())
        {
            return;
        }

        try
        {
            _isFxBusy = true;
            StateHasChanged();

            var resolution = await FxRateSelectionService.UseCompanySnapshotAsync(
                _state.Draft.CompanyId,
                snapshotId,
                CancellationToken.None);

            _state.ApplyResolvedFxRate(resolution);
            await LoadFxSelectionDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(DescribeEditorFailure(ex), Severity.Error);
        }
        finally
        {
            _isFxBusy = false;
            StateHasChanged();
        }
    }

    private async Task HandleUseMarketRateAsync(Guid marketRateId)
    {
        if (TryBlockWrites())
        {
            return;
        }

        try
        {
            _isFxBusy = true;
            StateHasChanged();

            var resolution = await FxRateSelectionService.UseMarketRateAsync(
                BuildSelectionRequest(),
                marketRateId,
                CancellationToken.None);

            _state.ApplyResolvedFxRate(resolution);
            await LoadFxSelectionDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(DescribeEditorFailure(ex), Severity.Error);
        }
        finally
        {
            _isFxBusy = false;
            StateHasChanged();
        }
    }

    private async Task HandlePersistManualSnapshotAsync()
    {
        if (TryBlockWrites())
        {
            return;
        }

        try
        {
            _isFxBusy = true;
            StateHasChanged();

            var resolution = await FxRateSelectionService.PersistManualSnapshotAsync(
                BuildSelectionRequest(),
                _state.Draft.FxRate,
                CancellationToken.None);

            _state.ApplyResolvedFxRate(resolution);
            await LoadFxSelectionDataAsync();
            Snackbar.Add("Manual FX snapshot persisted.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(DescribeEditorFailure(ex), Severity.Error);
        }
        finally
        {
            _isFxBusy = false;
            StateHasChanged();
        }
    }

    private async Task LoadFxSelectionDataAsync()
    {
        if (!_state.Draft.IsForeignCurrency)
        {
            _fxSelectionData = new FxRateSelectionData([], []);
            return;
        }

        _fxSelectionData = await FxRateSelectionService.LoadAsync(BuildSelectionRequest(), CancellationToken.None);
    }

    private async Task HandleEnableCurrencyAsync()
    {
        if (TryBlockWrites())
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_enableCurrencyCode))
        {
            return;
        }

        try
        {
            _isCurrencyGovernanceBusy = true;
            StateHasChanged();

            var result = await CompanyCurrencyGovernanceWorkflow.EnableCurrencyAsync(
                _state.Draft.CompanyId,
                _enableCurrencyCode,
                CurrentUserId,
                CancellationToken.None);

            _companyCurrencyProfile = result.Profile;
            _state.ApplyCompanyCurrencyProfile(result.Profile);

            var enabledCurrencyCode = _enableCurrencyCode;
            _enableCurrencyCode = _companyCurrencyProfile.Currencies.FirstOrDefault(currency => !currency.IsEnabled)?.CurrencyCode;

            if (!string.IsNullOrWhiteSpace(enabledCurrencyCode))
            {
                _state.SetCurrency(enabledCurrencyCode);
                await RefreshFxRateAsync();
            }

            var createdCount = result.ProvisionedControlAccounts.Count(static account => account.WasCreated);
            Snackbar.Add(
                createdCount > 0
                    ? $"Enabled {enabledCurrencyCode} and provisioned {createdCount} governed control account(s)."
                    : $"Enabled {enabledCurrencyCode}. Governed control accounts were already present.",
                Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(DescribeEditorFailure(ex), Severity.Error);
        }
        finally
        {
            _isCurrencyGovernanceBusy = false;
            StateHasChanged();
        }
    }

    private async Task LoadCompanyCurrencyProfileAsync()
    {
        _companyCurrencyProfile = await CompanyCurrencyGovernanceWorkflow.GetProfileAsync(_state.Draft.CompanyId, CancellationToken.None);
        _state.ApplyCompanyCurrencyProfile(_companyCurrencyProfile);
        _enableCurrencyCode = _companyCurrencyProfile.Currencies.FirstOrDefault(currency => !currency.IsEnabled)?.CurrencyCode;
    }

    private FxRateSelectionRequest BuildSelectionRequest() =>
        new(
            _state.Draft.CompanyId,
            CurrentUserId,
            _state.Draft.CurrencyCode,
            _state.Draft.BaseCurrencyCode,
            _state.Draft.JournalDate,
            _state.Draft.FxProviderKey,
            7,
            _state.Draft.FxRateType,
            _state.Draft.FxQuoteBasis,
            _state.Draft.FxRateUseCase,
            _state.Draft.FxPostingReason);

    private static string BuildReviewHref(Guid journalEntryId) =>
        $"/gl/journal-entry/review/{journalEntryId:D}";

    private async Task EnsureWriteGateStateAsync()
    {
        await ShellSession.RefreshAsync(CancellationToken.None);
    }

    private bool TryBlockWrites()
    {
        if (!WritesBlocked)
        {
            return false;
        }

        Snackbar.Add(ShellSession.WriteBlockMessage, Severity.Warning);
        return true;
    }

    private static string DescribeEditorFailure(Exception ex)
    {
        if (ex is JournalEntryWorkflowException workflowEx)
        {
            return workflowEx.ErrorCode switch
            {
                "posting_period_closed" => "The journal date falls inside a closed period for the active primary book. Move the journal date into an open period or adjust the lock in Book Governance.",
                "invalid_document_status" => "This manual journal is no longer in an editable draft state. Refresh the editor and continue from the latest document status.",
                "not_found" => "The manual journal draft is no longer available in the active company context. Return to the workbench and reopen or recreate it.",
                "invalid_currency_configuration" => "The selected transaction/base currency setup is not currently valid for this company. Review company currency governance and then retry the journal.",
                "invalid_fx_configuration" => "The journal's FX setup is incomplete or inconsistent. Persist a valid FX snapshot and effective date before saving or posting.",
                "invalid_draft_shape" => workflowEx.Message,
                _ => workflowEx.Message
            };
        }

        return ex.Message;
    }
}
