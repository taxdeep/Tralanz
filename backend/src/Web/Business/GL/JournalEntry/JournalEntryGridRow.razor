@using Modules.GL.JournalEntry
@using MudBlazor

<tr class="je-grid-row">
    <td class="je-grid-row__action">
        <MudIconButton Icon="@Icons.Material.Outlined.AddCircle"
                       Size="Size.Small"
                       Color="Color.Success"
                       OnClick="InsertBlankAfter" />
    </td>
    <td class="je-grid-row__index">@Line.LineNumber</td>
    <td class="je-grid-row__account">
        <JournalEntryAccountCell State="State" Line="Line" OnChanged="NotifyChanged" />
    </td>
    <td class="je-grid-row__amount">
        <JournalEntryAmountCell Value="@Line.DebitAmount"
                                ValueChanged="OnDebitChanged"
                                PreviewValue="@State.ConvertToBase(Line.DebitAmount)"
                                PreviewLabel="@State.Draft.BaseCurrencyCode"
                                ShowPreview="@State.ShouldShowBasePreview(Line.DebitAmount)" />
    </td>
    <td class="je-grid-row__amount">
        <JournalEntryAmountCell Value="@Line.CreditAmount"
                                ValueChanged="OnCreditChanged"
                                PreviewValue="@State.ConvertToBase(Line.CreditAmount)"
                                PreviewLabel="@State.Draft.BaseCurrencyCode"
                                ShowPreview="@State.ShouldShowBasePreview(Line.CreditAmount)" />
    </td>
    <td class="je-grid-row__description">
        <MudTextField T="string"
                      Value="@Line.Description"
                      ValueChanged="OnDescriptionChanged"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Placeholder="Description"
                      Class="je-cell-input"
                      Immediate="true" />
    </td>
    <td class="je-grid-row__name">
        <MudSelect T="string"
                   Value="@Line.Name"
                   ValueChanged="OnNameChanged"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Dense="true"
                   Class="je-cell-input">
            @foreach (var option in State.NameOptions)
            {
                <MudSelectItem T="string" Value="@option">@option</MudSelectItem>
            }
        </MudSelect>
    </td>
    <td class="je-grid-row__tax">
        <MudSelect T="string"
                   Value="@Line.SalesTax"
                   ValueChanged="OnSalesTaxChanged"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Dense="true"
                   Class="je-cell-input">
            @foreach (var option in State.SalesTaxOptions)
            {
                <MudSelectItem T="string" Value="@option">@option</MudSelectItem>
            }
        </MudSelect>
    </td>
    <td class="je-grid-row__icon">
        <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy"
                       Size="Size.Small"
                       Color="Color.Default"
                       OnClick="DuplicateLine" />
    </td>
    <td class="je-grid-row__icon">
        <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline"
                       Size="Size.Small"
                       Color="Color.Default"
                       OnClick="DeleteLine" />
    </td>
</tr>

@code
{
    [Parameter, EditorRequired]
    public JournalEntryEditorState State { get; set; } = default!;

    [Parameter, EditorRequired]
    public JournalEntryDraftLine Line { get; set; } = default!;

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private Task NotifyChanged() => OnChanged.InvokeAsync();

    private Task InsertBlankAfter()
    {
        State.InsertBlankAfter(Line.LineNumber);
        return NotifyChanged();
    }

    private Task DuplicateLine()
    {
        State.DuplicateLine(Line.LineNumber);
        return NotifyChanged();
    }

    private Task DeleteLine()
    {
        State.DeleteLine(Line.LineNumber);
        return NotifyChanged();
    }

    private Task OnDebitChanged(decimal? value)
    {
        Line.DebitAmount = value;
        return NotifyChanged();
    }

    private Task OnCreditChanged(decimal? value)
    {
        Line.CreditAmount = value;
        return NotifyChanged();
    }

    private Task OnDescriptionChanged(string value)
    {
        Line.Description = value;
        return NotifyChanged();
    }

    private Task OnNameChanged(string value)
    {
        Line.Name = value;
        return NotifyChanged();
    }

    private Task OnSalesTaxChanged(string value)
    {
        Line.SalesTax = value;
        return NotifyChanged();
    }
}
