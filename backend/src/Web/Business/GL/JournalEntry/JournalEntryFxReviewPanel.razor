@using Engines.FX.FxRateLookup
@using Modules.GL.JournalEntry
@using MudBlazor
@using SharedKernel.FX

@if (State.Draft.IsForeignCurrency)
{
    var currentSnapshot = SelectionData.CompanySnapshots.FirstOrDefault(snapshot => State.IsCurrentSnapshot(snapshot.Id));
    var currentMarketRate = SelectionData.MarketRates.FirstOrDefault(rate => State.IsCurrentMarketRate(rate.Id, SelectionData.CompanySnapshots));

    <div class="je-fx-review-panel @(State.IsPosted ? "je-fx-review-panel--posted" : string.Empty)">
        <div class="je-fx-review-panel__header">
            <div>
                <div class="je-fx-review-panel__title">@State.GetFxReviewTitle()</div>
                <div class="je-fx-review-panel__subtitle">@State.GetFxReviewCaption()</div>
            </div>

            <div class="je-fx-review-panel__chips">
                <MudChip T="string" Variant="Variant.Text" Color="Color.Info">@State.Draft.FxSourceSemantics</MudChip>
                @if (State.IsPosted)
                {
                    <MudChip T="string" Variant="Variant.Text" Color="Color.Success">Read-only</MudChip>
                }
            </div>
        </div>

        <div class="je-fx-review-grid">
            <div class="je-fx-review-cell">
                <span class="je-fx-review-cell__label">Transaction currency</span>
                <span class="je-fx-review-cell__value">@State.Draft.CurrencyCode</span>
            </div>
            <div class="je-fx-review-cell">
                <span class="je-fx-review-cell__label">Base currency</span>
                <span class="je-fx-review-cell__value">@State.Draft.BaseCurrencyCode</span>
            </div>
            <div class="je-fx-review-cell">
                <span class="je-fx-review-cell__label">Exchange rate</span>
                <span class="je-fx-review-cell__value">@State.Draft.FxRate.ToString("N6")</span>
            </div>
            <div class="je-fx-review-cell">
                <span class="je-fx-review-cell__label">Effective date</span>
                <span class="je-fx-review-cell__value">@State.Draft.FxEffectiveDate.ToString("yyyy-MM-dd")</span>
            </div>
            <div class="je-fx-review-cell">
                <span class="je-fx-review-cell__label">Snapshot</span>
                <span class="je-fx-review-cell__value">@State.GetFxSnapshotLabel()</span>
            </div>
            <div class="je-fx-review-cell">
                <span class="je-fx-review-cell__label">Status</span>
                <span class="je-fx-review-cell__value">@State.Draft.FxStatusLabel</span>
            </div>

            @if (currentSnapshot is not null)
            {
                <div class="je-fx-review-cell">
                    <span class="je-fx-review-cell__label">Snapshot semantics</span>
                    <span class="je-fx-review-cell__value">@currentSnapshot.SnapshotSemantics</span>
                </div>
                <div class="je-fx-review-cell">
                    <span class="je-fx-review-cell__label">Row origin</span>
                    <span class="je-fx-review-cell__value">@currentSnapshot.RowOrigin</span>
                </div>
            }

            @if (currentMarketRate is not null)
            {
                <div class="je-fx-review-cell">
                    <span class="je-fx-review-cell__label">Linked market date</span>
                    <span class="je-fx-review-cell__value">@currentMarketRate.MarketDate.ToString("yyyy-MM-dd")</span>
                </div>
                <div class="je-fx-review-cell">
                    <span class="je-fx-review-cell__label">Linked provider</span>
                    <span class="je-fx-review-cell__value">@currentMarketRate.ProviderKey</span>
                </div>
            }
        </div>
    </div>
}

@code
{
    [Parameter, EditorRequired]
    public JournalEntryEditorState State { get; set; } = default!;

    [Parameter, EditorRequired]
    public FxRateSelectionData SelectionData { get; set; } = default!;
}
