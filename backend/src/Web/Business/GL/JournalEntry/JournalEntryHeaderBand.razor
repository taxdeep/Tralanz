@using Modules.GL.JournalEntry
@using MudBlazor

<div class="je-header-band">
    <div class="je-header-band__left">
        <div class="je-field-stack">
            <label class="je-field-stack__label">Currency</label>
            <MudSelect T="string"
                       Value="@State.Draft.CurrencyCode"
                       ValueChanged="HandleCurrencyChanged"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Dense="true"
                       Disabled="@(!State.CanEditJournal)"
                       Class="je-select">
                @foreach (var option in State.CurrencyOptions)
                {
                    <MudSelectItem T="string" Value="@option.Code">@option.DisplayText</MudSelectItem>
                }
            </MudSelect>
        </div>

        @if (State.Draft.IsForeignCurrency)
        {
            <div class="je-fx-card">
                <div class="je-fx-card__rate">
                    <span>1 @State.Draft.CurrencyCode</span>
                    <MudNumericField T="decimal"
                                     Value="@State.Draft.FxRate"
                                     ValueChanged="HandleFxRateChanged"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="true"
                                     Disabled="@(!State.CanEditJournal)"
                                     Class="je-fx-rate" />
                    <span>@State.Draft.BaseCurrencyCode</span>
                </div>

                <div class="je-fx-card__meta">
                    @if (IsFxBusy)
                    {
                        <span>Refreshing local/provider FX...</span>
                    }
                    else if (!string.IsNullOrWhiteSpace(FxErrorText))
                    {
                        <span class="je-fx-strip__meta--error">@FxErrorText</span>
                    }
                    else
                    {
                        <span>@State.Draft.FxStatusLabel</span>
                        <span>Source: @State.Draft.FxSourceSemantics</span>
                        <span>Effective: @State.Draft.FxEffectiveDate.ToString("yyyy-MM-dd")</span>
                        <span>@State.GetFxSnapshotLabel()</span>
                    }
                </div>
            </div>
        }

        <div class="je-field-stack">
            <label class="je-field-stack__label">Journal date</label>
            <MudDatePicker Date="@_journalDate"
                           DateChanged="HandleJournalDateChanged"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Editable="true"
                           Disabled="@(!State.CanEditJournal)"
                           Class="je-date-picker" />
        </div>
    </div>

    <div class="je-header-band__right">
        <div class="je-field-stack je-field-stack--number">
            <label class="je-field-stack__label">JE#</label>
            <MudTextField T="string"
                          Value="@State.Draft.JournalNumber"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          ReadOnly="true"
                          Class="je-number-input" />
        </div>
    </div>
</div>

@code
{
    [Parameter, EditorRequired]
    public JournalEntryEditorState State { get; set; } = default!;

    [Parameter]
    public EventCallback<string> OnCurrencyChanged { get; set; }

    [Parameter]
    public EventCallback<decimal> OnFxRateChanged { get; set; }

    [Parameter]
    public EventCallback<DateOnly> OnJournalDateChanged { get; set; }

    [Parameter]
    public bool IsFxBusy { get; set; }

    [Parameter]
    public string? FxErrorText { get; set; }

    private DateTime? _journalDate => State.Draft.JournalDate.ToDateTime(TimeOnly.MinValue);

    private Task HandleCurrencyChanged(string currencyCode)
    {
        return OnCurrencyChanged.InvokeAsync(currencyCode);
    }

    private Task HandleFxRateChanged(decimal fxRate)
    {
        return OnFxRateChanged.InvokeAsync(fxRate);
    }

    private Task HandleJournalDateChanged(DateTime? journalDate)
    {
        if (journalDate.HasValue)
        {
            return OnJournalDateChanged.InvokeAsync(DateOnly.FromDateTime(journalDate.Value));
        }

        return Task.CompletedTask;
    }
}
