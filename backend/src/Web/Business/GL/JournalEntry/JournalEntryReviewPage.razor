@page "/gl/journal-entry/review/{JournalEntryId:guid}"
@using Microsoft.AspNetCore.Components.Web
@using Modules.CompanyAccess.SessionContext
@using Modules.GL.JournalEntry
@using MudBlazor
@inject ICompanyAccessShellSession ShellSession
@inject IJournalEntryReviewStore JournalEntryReviewStore
@inject IManualJournalSourceReviewStore ManualJournalSourceReviewStore
@inject IJournalEntryLifecycleWorkflow JournalEntryLifecycleWorkflow
@inject JournalEntrySourceDocumentTraceClient SourceDocumentTraceClient
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>@(_review?.Title ?? "Journal Entry review")</PageTitle>

<div class="je-review">
    <div class="je-review-shell">
        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mb-4" />
        }
        else if (!string.IsNullOrWhiteSpace(_errorText))
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                @_errorText
            </MudAlert>
        }
        else if (_review is not null)
        {
            <div class="je-review-title">
                <div class="je-review-title__text">
                    <MudIcon Icon="@Icons.Material.Outlined.LibraryBooks" Size="Size.Small" />
                    <span>@_review.Title</span>
                </div>
                <div class="je-review-title__meta">
                    <MudChip T="string" Variant="Variant.Text" Color="Color.Info">Read-only review</MudChip>
                    <MudChip T="string" Variant="Variant.Text" Color="@GetStatusColor(_review.Status)">@_review.Status</MudChip>
                    <MudChip T="string" Variant="Variant.Text" Color="Color.Secondary">@_review.SourceTypeLabel</MudChip>
                </div>
            </div>

            @if (_review.HasLifecycleAlert)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
                    @_review.LifecycleAlert
                </MudAlert>
            }

            @if (WritesBlocked)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
                    @ShellSession.WriteBlockMessage
                </MudAlert>
            }

            <div class="je-review-summary-grid">
                <div class="je-review-card">
                    <div class="je-review-card__label">Journal</div>
                    <div class="je-review-card__value">@_review.DisplayNumber</div>
                    <div class="je-review-card__hint">@_review.EntityNumber</div>
                </div>

                <div class="je-review-card">
                    <div class="je-review-card__label">Posted at</div>
                    <div class="je-review-card__value">@FormatTimestamp(_review.PostedAt)</div>
                    <div class="je-review-card__hint">Backend-owned posting truth</div>
                </div>

                <div class="je-review-card">
                    <div class="je-review-card__label">Transaction total</div>
                    <div class="je-review-card__value">@FormatAmount(_review.TotalTransactionDebit) @(_review.TransactionCurrencyCode)</div>
                    <div class="je-review-card__hint">Credit @FormatAmount(_review.TotalTransactionCredit) @(_review.TransactionCurrencyCode)</div>
                </div>

                <div class="je-review-card">
                    <div class="je-review-card__label">Base total</div>
                    <div class="je-review-card__value">@FormatAmount(_review.TotalDebit) @(_review.BaseCurrencyCode)</div>
                    <div class="je-review-card__hint">Credit @FormatAmount(_review.TotalCredit) @(_review.BaseCurrencyCode)</div>
                </div>
            </div>

            <div class="je-review-layout">
                <div class="je-review-stack">
                    <div class="je-review-panel">
                        <div class="je-review-panel__header">
                            <div>
                                <div class="je-review-panel__title">@_review.FxReviewTitle</div>
                                <div class="je-review-panel__caption">@_review.FxReviewCaption</div>
                            </div>
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Secondary">@_review.FxSnapshotLabel</MudChip>
                        </div>

                        <div class="je-review-facts">
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Rate source</span>
                                <span class="je-review-fact__value">@_review.ExchangeRateSource</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Rate type</span>
                                <span class="je-review-fact__value">@_review.FxRateTypeLabel</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Quote basis</span>
                                <span class="je-review-fact__value">@_review.FxQuoteBasisLabel</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Effective date</span>
                                <span class="je-review-fact__value">@_review.ExchangeRateDate.ToString("yyyy-MM-dd")</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Exchange rate</span>
                                <span class="je-review-fact__value">@_review.ExchangeRate.ToString("0.######")</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Use case</span>
                                <span class="je-review-fact__value">@_review.FxRateUseCaseLabel</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Posting reason</span>
                                <span class="je-review-fact__value">@_review.FxPostingReasonLabel</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Snapshot semantics</span>
                                <span class="je-review-fact__value">@_review.FxSnapshotSemanticsLabel</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Row origin</span>
                                <span class="je-review-fact__value">@_review.FxSnapshotRowOriginLabel</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Linked provider</span>
                                <span class="je-review-fact__value">@_review.FxProviderLabel</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Snapshot id</span>
                                <span class="je-review-fact__value">@(_review.FxSnapshotId?.ToString("D") ?? "No persisted snapshot")</span>
                            </div>
                        </div>
                    </div>

                    <div class="je-review-panel">
                        <div class="je-review-panel__header">
                            <div>
                                <div class="je-review-panel__title">Journal lines</div>
                                <div class="je-review-panel__caption">Transaction and base currency stay visible on the same row.</div>
                            </div>
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">@($"{_review.LineCount} lines")</MudChip>
                        </div>

                        <MudTable Items="_review.Lines" Dense="true" Hover="true" Class="je-review-table">
                            <HeaderContent>
                                <MudTh>#</MudTh>
                                <MudTh>Account</MudTh>
                                <MudTh>Tx debit</MudTh>
                                <MudTh>Tx credit</MudTh>
                                <MudTh>Debit</MudTh>
                                <MudTh>Credit</MudTh>
                                <MudTh>Description</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="#">@context.LineNumber</MudTd>
                                <MudTd DataLabel="Account">
                                    <div class="je-review-account">
                                        <span class="je-review-account__code">@context.AccountCode</span>
                                        <span class="je-review-account__name">@context.AccountName</span>
                                        <span class="je-review-account__type">@context.RootType</span>
                                    </div>
                                </MudTd>
                                <MudTd DataLabel="Tx debit">@FormatAmount(context.TransactionDebit)</MudTd>
                                <MudTd DataLabel="Tx credit">@FormatAmount(context.TransactionCredit)</MudTd>
                                <MudTd DataLabel="Debit">@FormatAmount(context.Debit)</MudTd>
                                <MudTd DataLabel="Credit">@FormatAmount(context.Credit)</MudTd>
                                <MudTd DataLabel="Description">
                                    <div class="je-review-line-detail">
                                        <span>@context.DisplayDescription</span>
                                        @if (!string.IsNullOrWhiteSpace(BuildMarkers(context)))
                                        {
                                            <span class="je-review-line-detail__meta">@BuildMarkers(context)</span>
                                        }
                                    </div>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>

                    @if (_review.Lines.Any(static line => line.IsRealizedFxLine))
                    {
                        <div class="je-review-panel">
                            <div class="je-review-panel__header">
                                <div>
                                    <div class="je-review-panel__title">Settlement FX effect</div>
                                    <div class="je-review-panel__caption">These lines carry the realized FX result produced by settlement or application posting.</div>
                                </div>
                            </div>

                            <MudTable Items="_review.Lines.Where(static line => line.IsRealizedFxLine)" Dense="true" Hover="true" Class="je-review-table">
                                <HeaderContent>
                                    <MudTh>Line</MudTh>
                                    <MudTh>Account</MudTh>
                                    <MudTh>Debit</MudTh>
                                    <MudTh>Credit</MudTh>
                                    <MudTh>Description</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Line">@context.LineNumber</MudTd>
                                    <MudTd DataLabel="Account">@context.AccountCode @context.AccountName</MudTd>
                                    <MudTd DataLabel="Debit">@FormatAmount(context.Debit)</MudTd>
                                    <MudTd DataLabel="Credit">@FormatAmount(context.Credit)</MudTd>
                                    <MudTd DataLabel="Description">@context.DisplayDescription</MudTd>
                                </RowTemplate>
                            </MudTable>
                        </div>
                    }
                </div>

                <div class="je-review-stack">
                    <div class="je-review-panel">
                        <div class="je-review-panel__header">
                            <div>
                                <div class="je-review-panel__title">Lifecycle control</div>
                                <div class="je-review-panel__caption">Void and reversal preserve history by creating a compensating posted JE.</div>
                            </div>
                        </div>

                        <div class="je-review-facts">
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Current status</span>
                                <span class="je-review-fact__value">@_review.Status</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Voided at</span>
                                <span class="je-review-fact__value">@FormatTimestamp(_review.VoidedAt)</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Reversed at</span>
                                <span class="je-review-fact__value">@FormatTimestamp(_review.ReversedAt)</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Source type</span>
                                <span class="je-review-fact__value">@_review.SourceTypeLabel</span>
                            </div>
                        </div>

                        <div class="je-review-links">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Warning"
                                       Disabled="@(!_review.CanVoid || _isApplyingLifecycle || WritesBlocked)"
                                       OnClick="HandleVoidAsync">
                                Void
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Error"
                                       Disabled="@(!_review.CanReverse || _isApplyingLifecycle || WritesBlocked)"
                                       OnClick="HandleReverseAsync">
                                Reverse
                            </MudButton>
                        </div>
                    </div>

                    <div class="je-review-panel">
                        <div class="je-review-panel__header">
                            <div>
                                <div class="je-review-panel__title">Related journal chain</div>
                                <div class="je-review-panel__caption">Original and compensation entries stay linked by source truth.</div>
                            </div>
                        </div>

                        <MudTable Items="_review.RelatedEntries" Dense="true" Hover="true" Class="je-review-table">
                            <HeaderContent>
                                <MudTh>Journal</MudTh>
                                <MudTh>Meaning</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Posted at</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Journal">@context.DisplayNumber</MudTd>
                                <MudTd DataLabel="Meaning">@context.SourceTypeLabel</MudTd>
                                <MudTd DataLabel="Status">@context.Status</MudTd>
                                <MudTd DataLabel="Posted at">@FormatTimestamp(context.PostedAt)</MudTd>
                                <MudTd DataLabel="">
                                    @if (context.Id != _review.Id)
                                    {
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Info"
                                                   Href="@BuildReviewHref(context.Id)">
                                            Open
                                        </MudButton>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>

                    <div class="je-review-panel">
                        <div class="je-review-panel__header">
                            <div>
                                <div class="je-review-panel__title">Source trace</div>
                                <div class="je-review-panel__caption">Journal, source document, and FX snapshot are tied to the same persisted posting truth.</div>
                            </div>
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">@_review.SourceTraceLabel</MudChip>
                        </div>

                        <div class="je-review-facts">
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Source document id</span>
                                <span class="je-review-fact__value">@_review.SourceId.ToString("D")</span>
                            </div>
                            @if (_sourceTrace is not null)
                            {
                                <div class="je-review-fact">
                                    <span class="je-review-fact__label">Source number</span>
                                    <span class="je-review-fact__value">@_sourceTrace.DisplayNumber</span>
                                </div>
                                <div class="je-review-fact">
                                    <span class="je-review-fact__label">Source status</span>
                                    <span class="je-review-fact__value">@_sourceTrace.Status</span>
                                </div>
                            }
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Source type</span>
                                <span class="je-review-fact__value">@_review.SourceTypeLabel</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Created by</span>
                                <span class="je-review-fact__value">@_review.CreatedByUserId.ToString("D")</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">FX trace</span>
                                <span class="je-review-fact__value">@_review.FxTraceLabel</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Base balanced</span>
                                <span class="je-review-fact__value">@(_review.IsBalanced ? "Yes" : "No")</span>
                            </div>
                            <div class="je-review-fact">
                                <span class="je-review-fact__label">Line count</span>
                                <span class="je-review-fact__value">@_review.LineCount</span>
                            </div>
                        </div>

                        @if (_sourceTrace is not null)
                        {
                            var reconciliation = BuildSourceReconciliation(_review, _sourceTrace);

                            <MudAlert Severity="@reconciliation.Severity" Variant="Variant.Outlined" Dense="true" Class="mt-3">
                                @reconciliation.Message
                            </MudAlert>

                            <div class="je-review-facts mt-3">
                                <div class="je-review-fact">
                                    <span class="je-review-fact__label">Document date</span>
                                    <span class="je-review-fact__value">@_sourceTrace.DocumentDate.ToString("yyyy-MM-dd")</span>
                                </div>
                                <div class="je-review-fact">
                                    <span class="je-review-fact__label">Due date</span>
                                    <span class="je-review-fact__value">@(_sourceTrace.DueDate?.ToString("yyyy-MM-dd") ?? "n/a")</span>
                                </div>
                                <div class="je-review-fact">
                                    <span class="je-review-fact__label">@DisplayTraceText(_sourceTrace.CounterpartyLabel)</span>
                                    <span class="je-review-fact__value">@(_sourceTrace.CounterpartyId?.ToString("D") ?? "n/a")</span>
                                </div>
                                <div class="je-review-fact">
                                    <span class="je-review-fact__label">Source total</span>
                                    <span class="je-review-fact__value">@FormatAmount(_sourceTrace.TotalAmount) @_sourceTrace.TotalCurrencyCode</span>
                                </div>
                                <div class="je-review-fact">
                                    <span class="je-review-fact__label">Compared JE total</span>
                                    <span class="je-review-fact__value">@FormatAmount(reconciliation.JournalTotal) @reconciliation.CurrencyCode</span>
                                </div>
                                <div class="je-review-fact">
                                    <span class="je-review-fact__label">Lifecycle</span>
                                    <span class="je-review-fact__value">@DisplayTraceText(_sourceTrace.LifecycleMode)</span>
                                </div>
                                <div class="je-review-fact">
                                    <span class="je-review-fact__label">Source lines</span>
                                    <span class="je-review-fact__value">@_sourceTrace.Lines.Count</span>
                                </div>
                                <div class="je-review-fact">
                                    <span class="je-review-fact__label">Line subtotal</span>
                                    <span class="je-review-fact__value">@FormatAmount(reconciliation.SourceLineTotal) @reconciliation.CurrencyCode</span>
                                </div>
                                <div class="je-review-fact">
                                    <span class="je-review-fact__label">Tax total</span>
                                    <span class="je-review-fact__value">@FormatAmount(reconciliation.SourceTaxTotal) @reconciliation.CurrencyCode</span>
                                </div>
                                <div class="je-review-fact">
                                    <span class="je-review-fact__label">Source accounts mapped</span>
                                    <span class="je-review-fact__value">@reconciliation.MappedSourceAccountCount / @reconciliation.SourceAccountCount</span>
                                </div>
                                <div class="je-review-fact">
                                    <span class="je-review-fact__label">Amount delta</span>
                                    <span class="je-review-fact__value">@FormatSignedAmount(reconciliation.AmountDelta) @reconciliation.CurrencyCode</span>
                                </div>
                                <div class="je-review-fact">
                                    <span class="je-review-fact__label">Line delta</span>
                                    <span class="je-review-fact__value">@reconciliation.LineDelta</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(reconciliation.UnmappedSourceAccountLabel))
                                {
                                    <div class="je-review-fact">
                                        <span class="je-review-fact__label">Unmapped source accounts</span>
                                        <span class="je-review-fact__value">@reconciliation.UnmappedSourceAccountLabel</span>
                                    </div>
                                }
                            </div>

                            @if (reconciliation.PostingRoleRows.Count > 0)
                            {
                                <MudTable Items="reconciliation.PostingRoleRows" Dense="true" Hover="true" Class="je-review-table mt-3">
                                    <HeaderContent>
                                        <MudTh>Posting role</MudTh>
                                        <MudTh>Lines</MudTh>
                                        <MudTh>Tx debit</MudTh>
                                        <MudTh>Tx credit</MudTh>
                                        <MudTh>Debit</MudTh>
                                        <MudTh>Credit</MudTh>
                                        <MudTh>Evidence</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Posting role">@context.RoleLabel</MudTd>
                                        <MudTd DataLabel="Lines">@context.LineCount</MudTd>
                                        <MudTd DataLabel="Tx debit">@FormatAmount(context.TransactionDebit)</MudTd>
                                        <MudTd DataLabel="Tx credit">@FormatAmount(context.TransactionCredit)</MudTd>
                                        <MudTd DataLabel="Debit">@FormatAmount(context.Debit)</MudTd>
                                        <MudTd DataLabel="Credit">@FormatAmount(context.Credit)</MudTd>
                                        <MudTd DataLabel="Evidence">@context.Evidence</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }

                            @if (_sourceTrace.Lines.Count > 0)
                            {
                                <MudTable Items="_sourceTrace.Lines" Dense="true" Hover="true" Class="je-review-table mt-3">
                                    <HeaderContent>
                                        <MudTh>#</MudTh>
                                        <MudTh>Source account</MudTh>
                                        <MudTh>Amount</MudTh>
                                        <MudTh>Tax</MudTh>
                                        <MudTh>Tx debit</MudTh>
                                        <MudTh>Tx credit</MudTh>
                                        <MudTh>Description</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="#">@context.LineNumber</MudTd>
                                        <MudTd DataLabel="Source account">
                                            <div class="je-review-account">
                                                <span class="je-review-account__code">@DisplayTraceText(context.AccountCode)</span>
                                                <span class="je-review-account__name">@DisplayTraceText(context.AccountName)</span>
                                            </div>
                                        </MudTd>
                                        <MudTd DataLabel="Amount">@FormatAmount(context.LineAmount) @_sourceTrace.TotalCurrencyCode</MudTd>
                                        <MudTd DataLabel="Tax">@FormatAmount(context.TaxAmount)</MudTd>
                                        <MudTd DataLabel="Tx debit">@FormatNullableAmount(context.TxDebit)</MudTd>
                                        <MudTd DataLabel="Tx credit">@FormatNullableAmount(context.TxCredit)</MudTd>
                                        <MudTd DataLabel="Description">@DisplayTraceText(context.Description)</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                        }
                        else if (!string.IsNullOrWhiteSpace(_sourceTraceErrorText))
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-3">
                                @_sourceTraceErrorText
                            </MudAlert>
                        }

                        @if (_review.SourceId != Guid.Empty && TryBuildSourceReviewHref(_review.SourceType, _review.SourceId, out var traceSourceHref))
                        {
                            <div class="je-review-links">
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Info"
                                           Href="@traceSourceHref">
                                    Open source
                                </MudButton>
                            </div>
                        }
                    </div>

                    @if (_review.SourceId != Guid.Empty && TryBuildSourceReviewHref(_review.SourceType, _review.SourceId, out var sourceHref))
                    {
                        <div class="je-review-panel">
                            <div class="je-review-panel__header">
                                <div>
                                    <div class="je-review-panel__title">Source document</div>
                                    <div class="je-review-panel__caption">The posted JE stays linked to the backend-owned source review path.</div>
                                </div>
                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Secondary">@_review.SourceTypeLabel</MudChip>
                            </div>

                            <div class="je-review-facts">
                                <div class="je-review-fact">
                                    <span class="je-review-fact__label">Source document id</span>
                                    <span class="je-review-fact__value">@_review.SourceId.ToString("D")</span>
                                </div>
                                @if (_sourceReview is not null)
                                {
                                    <div class="je-review-fact">
                                        <span class="je-review-fact__label">Entry date</span>
                                        <span class="je-review-fact__value">@_sourceReview.EntryDate.ToString("yyyy-MM-dd")</span>
                                    </div>
                                    <div class="je-review-fact">
                                        <span class="je-review-fact__label">Source status</span>
                                        <span class="je-review-fact__value">@_sourceReview.Status</span>
                                    </div>
                                    <div class="je-review-fact je-review-fact--wide">
                                        <span class="je-review-fact__label">Memo</span>
                                        <span class="je-review-fact__value">@DisplayMemo(_sourceReview.Memo)</span>
                                    </div>
                                }
                            </div>

                            <div class="je-review-links">
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Info"
                                           Href="@sourceHref">
                                    Open source review
                                </MudButton>
                            </div>
                        </div>
                    }

                    <div class="je-review-panel">
                        <div class="je-review-panel__header">
                            <div>
                                <div class="je-review-panel__title">Read path meaning</div>
                                <div class="je-review-panel__caption">This page is for review, not mutation.</div>
                            </div>
                        </div>

                        <ul class="je-review-notes">
                            <li>Posted journal entries stay read-only.</li>
                            <li>FX semantics are taken from the persisted journal header, not recalculated in the UI.</li>
                            <li>Transaction and base amounts are shown together so reviewers can reconcile both views quickly.</li>
                            <li>Void and reversal preserve auditability by adding a compensation JE instead of deleting history.</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="je-review-action-bar">
                <MudButton Variant="Variant.Text" Color="Color.Default" Href="/gl/journal-entries">
                    Journal workbench
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="HandleBackToEditor" Disabled="WritesBlocked">
                    New journal entry
                </MudButton>
            </div>
        }
    </div>
</div>

@code
{
    [Parameter]
    public Guid JournalEntryId { get; set; }

    private JournalEntryReview? _review;
    private ManualJournalSourceReview? _sourceReview;
    private JournalEntrySourceDocumentTraceSummary? _sourceTrace;
    private bool _isLoading;
    private bool _isApplyingLifecycle;
    private string? _errorText;
    private string? _sourceTraceErrorText;
    private bool WritesBlocked => ShellSession.AreWritesBlocked;

    protected override Task OnParametersSetAsync() => LoadReviewAsync();

    private async Task LoadReviewAsync()
    {
        _isLoading = true;
        _errorText = null;
        _review = null;
        _sourceReview = null;
        _sourceTrace = null;
        _sourceTraceErrorText = null;

        try
        {
            await ShellSession.RefreshAsync(CancellationToken.None);
            _review = await JournalEntryReviewStore.GetAsync(ShellSession.ActiveCompanyId, JournalEntryId, CancellationToken.None);

            if (_review is null)
            {
                _errorText = $"Journal entry {JournalEntryId:D} could not be found in the active company context.";
            }
            else if (string.Equals(_review.SourceType, "manual_journal", StringComparison.OrdinalIgnoreCase) &&
                     _review.SourceId != Guid.Empty)
            {
                _sourceReview = await ManualJournalSourceReviewStore.GetAsync(ShellSession.ActiveCompanyId, _review.SourceId, CancellationToken.None);
            }

            if (_review is not null)
            {
                await LoadSourceTraceAsync(_review);
            }
        }
        catch (Exception ex)
        {
            _errorText = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadSourceTraceAsync(JournalEntryReview review)
    {
        var result = await SourceDocumentTraceClient.GetAsync(
            ShellSession.ActiveCompanyId,
            review.SourceType,
            review.SourceId,
            CancellationToken.None);

        if (result.RequiresSignIn)
        {
            Snackbar.Add(result.ErrorMessage ?? "Your business session has expired. Please sign in again.", Severity.Warning);
            Navigation.NavigateTo("login", replace: true);
            return;
        }

        if (result.Value is not null && string.IsNullOrWhiteSpace(result.ErrorMessage))
        {
            _sourceTrace = result.Value;
            return;
        }

        _sourceTraceErrorText = result.ErrorMessage;
    }

    private async Task HandleVoidAsync()
    {
        if (_review is null || TryBlockWrites())
        {
            return;
        }

        await ApplyLifecycleAsync(() => JournalEntryLifecycleWorkflow.VoidAsync(ShellSession.ActiveCompanyId, _review.Id, ShellSession.CurrentUserId, CancellationToken.None), "Journal entry voided.");
    }

    private async Task HandleReverseAsync()
    {
        if (_review is null || TryBlockWrites())
        {
            return;
        }

        await ApplyLifecycleAsync(() => JournalEntryLifecycleWorkflow.ReverseAsync(ShellSession.ActiveCompanyId, _review.Id, ShellSession.CurrentUserId, CancellationToken.None), "Journal entry reversed.");
    }

    private async Task ApplyLifecycleAsync(
        Func<Task<JournalEntryLifecycleResult>> action,
        string successMessage)
    {
        try
        {
            _isApplyingLifecycle = true;
            StateHasChanged();

            var result = await action();
            Snackbar.Add($"{successMessage} Compensation JE {result.CompensationDisplayNumber} created.", Severity.Success);
            await LoadReviewAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isApplyingLifecycle = false;
            StateHasChanged();
        }
    }

    private void HandleBackToEditor()
    {
        if (WritesBlocked)
        {
            Snackbar.Add(ShellSession.WriteBlockMessage, Severity.Warning);
            return;
        }

        Navigation.NavigateTo("/gl/journal-entry/editor");
    }

    private bool TryBlockWrites()
    {
        if (!WritesBlocked)
        {
            return false;
        }

        Snackbar.Add(ShellSession.WriteBlockMessage, Severity.Warning);
        return true;
    }

    private static string FormatAmount(decimal amount) => amount.ToString("N2");

    private static string FormatSignedAmount(decimal amount) =>
        amount >= 0m ? $"+{amount:N2}" : amount.ToString("N2");

    private static string FormatNullableAmount(decimal? amount) =>
        amount.HasValue ? FormatAmount(amount.Value) : "n/a";

    private static string FormatTimestamp(DateTimeOffset? value) =>
        value?.ToString("yyyy-MM-dd HH:mm 'UTC'") ?? "Unavailable";

    private static string DisplayMemo(string memo) =>
        string.IsNullOrWhiteSpace(memo) ? "No memo was stored on the source document." : memo;

    private static string DisplayTraceText(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "n/a" : value;

    private static string BuildReviewHref(Guid journalEntryId) =>
        $"/gl/journal-entry/review/{journalEntryId:D}";

    private static SourceTraceReconciliation BuildSourceReconciliation(
        JournalEntryReview review,
        JournalEntrySourceDocumentTraceSummary sourceTrace)
    {
        var currencyCode = sourceTrace.TotalCurrencyCode;
        var journalTotal = string.Equals(currencyCode, review.BaseCurrencyCode, StringComparison.OrdinalIgnoreCase)
            ? review.TotalDebit
            : review.TotalTransactionDebit;
        var sourceLineTotal = sourceTrace.Lines.Sum(static line => line.LineAmount);
        var sourceTaxTotal = sourceTrace.Lines.Sum(static line => line.TaxAmount);
        var journalAccountCodes = review.Lines
            .Select(static line => line.AccountCode)
            .Where(static accountCode => !string.IsNullOrWhiteSpace(accountCode))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var sourceAccountCodes = sourceTrace.Lines
            .Select(static line => line.AccountCode)
            .Where(static accountCode => !string.IsNullOrWhiteSpace(accountCode))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Order(StringComparer.OrdinalIgnoreCase)
            .ToArray();
        var unmappedSourceAccounts = sourceAccountCodes
            .Where(accountCode => !journalAccountCodes.Contains(accountCode))
            .ToArray();
        var mappedSourceAccountCount = sourceAccountCodes.Length - unmappedSourceAccounts.Length;
        var postingRoleRows = BuildPostingRoleRows(review, sourceAccountCodes).ToArray();
        var unmappedSourceAccountLabel = unmappedSourceAccounts.Length == 0
            ? string.Empty
            : string.Join(", ", unmappedSourceAccounts.Take(4));
        if (unmappedSourceAccounts.Length > 4)
        {
            unmappedSourceAccountLabel = $"{unmappedSourceAccountLabel}, +{unmappedSourceAccounts.Length - 4}";
        }

        var amountDelta = Math.Round(journalTotal - sourceTrace.TotalAmount, 2, MidpointRounding.ToEven);
        var lineDelta = review.LineCount - sourceTrace.Lines.Count;

        if (amountDelta == 0m && lineDelta == 0)
        {
            return new SourceTraceReconciliation(
                Severity.Success,
                "Source trace matches the generated journal by visible amount and line count.",
                currencyCode,
                journalTotal,
                sourceLineTotal,
                sourceTaxTotal,
                sourceAccountCodes.Length,
                mappedSourceAccountCount,
                unmappedSourceAccountLabel,
                postingRoleRows,
                amountDelta,
                lineDelta);
        }

        if (amountDelta == 0m)
        {
            return new SourceTraceReconciliation(
                Severity.Info,
                "Source amount matches the generated journal; line count differs because posting may add control, tax, FX, or offset lines.",
                currencyCode,
                journalTotal,
                sourceLineTotal,
                sourceTaxTotal,
                sourceAccountCodes.Length,
                mappedSourceAccountCount,
                unmappedSourceAccountLabel,
                postingRoleRows,
                amountDelta,
                lineDelta);
        }

        return new SourceTraceReconciliation(
            Severity.Warning,
            "Source amount differs from the generated journal total. Review source lines, tax/control/FX lines, and posting fragments before relying on this entry.",
            currencyCode,
            journalTotal,
            sourceLineTotal,
            sourceTaxTotal,
            sourceAccountCodes.Length,
            mappedSourceAccountCount,
            unmappedSourceAccountLabel,
            postingRoleRows,
            amountDelta,
            lineDelta);
    }

    private static IEnumerable<SourceTracePostingRoleRow> BuildPostingRoleRows(
        JournalEntryReview review,
        IReadOnlyCollection<string> sourceAccountCodes)
    {
        var sourceAccountCodeSet = sourceAccountCodes.ToHashSet(StringComparer.OrdinalIgnoreCase);

        return review.Lines
            .Select(line => new
            {
                Role = ClassifyPostingRole(line, sourceAccountCodeSet),
                Line = line
            })
            .GroupBy(item => item.Role)
            .OrderBy(group => group.Key.SortOrder)
            .ThenBy(group => group.Key.Label, StringComparer.OrdinalIgnoreCase)
            .Select(group =>
            {
                var lines = group.Select(item => item.Line).ToArray();
                return new SourceTracePostingRoleRow(
                    group.Key.Label,
                    lines.Length,
                    lines.Sum(static line => line.TransactionDebit),
                    lines.Sum(static line => line.TransactionCredit),
                    lines.Sum(static line => line.Debit),
                    lines.Sum(static line => line.Credit),
                    BuildRoleEvidence(lines));
            });
    }

    private static PostingRoleKey ClassifyPostingRole(
        JournalEntryReviewLine line,
        IReadOnlySet<string> sourceAccountCodes)
    {
        if (sourceAccountCodes.Contains(line.AccountCode))
        {
            return new PostingRoleKey(10, "Source account");
        }

        if (!string.IsNullOrWhiteSpace(line.ControlRole))
        {
            return new PostingRoleKey(20, $"Control: {line.ControlRole}");
        }

        if (!string.IsNullOrWhiteSpace(line.TaxComponentType))
        {
            return new PostingRoleKey(30, $"Tax: {line.TaxComponentType}");
        }

        if (line.IsRealizedFxLine)
        {
            return new PostingRoleKey(40, "Realized FX");
        }

        if (ContainsToken(line.AccountSystemRole, "unrealized") ||
            ContainsToken(line.AccountSystemKey, "unrealized") ||
            ContainsToken(line.AccountSystemRole, "fx") ||
            ContainsToken(line.AccountSystemKey, "fx"))
        {
            return new PostingRoleKey(45, "FX revaluation");
        }

        if (!string.IsNullOrWhiteSpace(line.AccountSystemRole))
        {
            return new PostingRoleKey(50, $"System: {line.AccountSystemRole}");
        }

        return new PostingRoleKey(90, $"Other {line.RootType}");
    }

    private static string BuildRoleEvidence(IReadOnlyCollection<JournalEntryReviewLine> lines)
    {
        var accounts = lines
            .Select(static line => line.AccountCode)
            .Where(static accountCode => !string.IsNullOrWhiteSpace(accountCode))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Order(StringComparer.OrdinalIgnoreCase)
            .Take(4)
            .ToArray();

        if (accounts.Length == 0)
        {
            return "No account code";
        }

        var suffix = lines
            .Select(static line => line.AccountCode)
            .Where(static accountCode => !string.IsNullOrWhiteSpace(accountCode))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count() > accounts.Length
            ? ", ..."
            : string.Empty;

        return string.Join(", ", accounts) + suffix;
    }

    private static bool ContainsToken(string? value, string token) =>
        !string.IsNullOrWhiteSpace(value) &&
        value.Contains(token, StringComparison.OrdinalIgnoreCase);

    private static Color GetStatusColor(string status) =>
        status switch
        {
            "posted" => Color.Success,
            "voided" => Color.Warning,
            "reversed" => Color.Warning,
            _ => Color.Info
        };

    private static string BuildMarkers(JournalEntryReviewLine line)
    {
        var markers = new List<string>();

        if (!string.IsNullOrWhiteSpace(line.ControlRole))
        {
            markers.Add($"control: {line.ControlRole}");
        }

        if (!string.IsNullOrWhiteSpace(line.TaxComponentType))
        {
            markers.Add($"tax: {line.TaxComponentType}");
        }

        if (line.PartyId.HasValue)
        {
            markers.Add($"party: {line.PartyId.Value:D}");
        }

        if (line.IsRealizedFxLine)
        {
            markers.Add("realized fx");
        }

        return string.Join(" | ", markers);
    }

    private static bool TryBuildSourceReviewHref(string sourceType, Guid documentId, out string href)
    {
        href = sourceType switch
        {
            "manual_journal" => $"/gl/journal-entry/source/{documentId:D}",
            "invoice" => $"/documents/invoice/{documentId:D}",
            "credit_note" => $"/documents/credit_note/{documentId:D}",
            "bill" => $"/documents/bill/{documentId:D}",
            "vendor_credit" => $"/documents/vendor_credit/{documentId:D}",
            "receive_payment" => $"/documents/receive_payment/{documentId:D}",
            "credit_application" => $"/documents/credit_application/{documentId:D}",
            "pay_bill" => $"/documents/pay_bill/{documentId:D}",
            "vendor_credit_application" => $"/documents/vendor_credit_application/{documentId:D}",
            "fx_revaluation" => $"/gl/fx-revaluation/{documentId:D}",
            _ => string.Empty
        };

        return !string.IsNullOrWhiteSpace(href);
    }

    private sealed record SourceTraceReconciliation(
        Severity Severity,
        string Message,
        string CurrencyCode,
        decimal JournalTotal,
        decimal SourceLineTotal,
        decimal SourceTaxTotal,
        int SourceAccountCount,
        int MappedSourceAccountCount,
        string UnmappedSourceAccountLabel,
        IReadOnlyList<SourceTracePostingRoleRow> PostingRoleRows,
        decimal AmountDelta,
        int LineDelta);

    private sealed record SourceTracePostingRoleRow(
        string RoleLabel,
        int LineCount,
        decimal TransactionDebit,
        decimal TransactionCredit,
        decimal Debit,
        decimal Credit,
        string Evidence);

    private readonly record struct PostingRoleKey(int SortOrder, string Label);
}
