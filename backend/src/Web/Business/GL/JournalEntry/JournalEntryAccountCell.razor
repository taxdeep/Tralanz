@using Modules.GL.JournalEntry
@using Citus.Modules.UnitySearch.Blazor
@using Citus.Modules.UnitySearch.Domain.Shared
@using MudBlazor

<UnitySearchPicker CompanyId="@State.Draft.CompanyId"
                   Context="@SearchScopeContext.JournalEntryAccountPicker"
                   SelectedId="@(Line.Account?.AccountId)"
                   SelectedDisplayText="@(Line.Account?.DisplayText)"
                   Placeholder="Search account"
                   OnOptionSelected="HandleAccountSelectedAsync"
                   OnCleared="HandleAccountClearedAsync" />

@code
{
    [Parameter, EditorRequired]
    public JournalEntryEditorState State { get; set; } = default!;

    [Parameter, EditorRequired]
    public JournalEntryDraftLine Line { get; set; } = default!;

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private Task HandleAccountSelectedAsync(UnitySearchPickerOption option)
    {
        Line.Account = State.AccountOptions.FirstOrDefault(account => account.AccountId == option.SourceId);
        return OnChanged.InvokeAsync();
    }

    private Task HandleAccountClearedAsync()
    {
        Line.Account = null;
        return OnChanged.InvokeAsync();
    }
}
