@page "/ar/aging"
@inject Modules.CompanyAccess.SessionContext.ICompanyAccessShellSession ShellSession
@inject Aging.ArAgingReportClient ReportClient

<PageTitle>AR Aging</PageTitle>

<div style="padding:2rem 2.25rem;color:#d9e2ea;">
    <h1 style="margin:0 0 .75rem 0;">AR Aging</h1>
    <p style="margin:0 0 1rem 0;color:#97a8b7;max-width:60rem;">
        Review open receivable exposure by customer and open item, then continue into source-document detail, open-item drill-down, and JE-backed settlement lanes.
    </p>

    <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
        <div style="display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;flex-wrap:wrap;">
            <div>
                <MudText Typo="Typo.subtitle2">AR Delivery Surface</MudText>
                <MudText Typo="Typo.h5">@AgingStageLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@AgingStageSummary</MudText>
            </div>
            <MudChip T="string" Variant="Variant.Filled" Color="@AgingStageColor">@AgingStageBadge</MudChip>
        </div>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));gap:1rem;margin-top:1rem;">
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Current next step</MudText>
                <MudText Typo="Typo.h6">@AgingNextStepTitle</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@AgingNextStepSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Source continuity</MudText>
                <MudText Typo="Typo.h6">@AgingSourceContinuityLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@AgingSourceContinuitySummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Settlement continuity</MudText>
                <MudText Typo="Typo.h6">@AgingSettlementContinuityLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@AgingSettlementContinuitySummary</MudText>
            </MudPaper>
        </div>

        <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1rem;">
            <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="/documents/source-browser?sourceType=invoice&counterpartyRole=customer">
                Review Invoices
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Success" Href="/documents/source-browser?sourceType=credit_note&counterpartyRole=customer">
                Review Credit Notes
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/ar/receive-payment">
                Open Receive Payment
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Warning" Href="/ar/credit-application">
                Open Credit Application
            </MudButton>
        </div>
    </MudPaper>

    @if (WritesBlocked)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            @ShellSession.WriteBlockMessage
        </MudAlert>
    }

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(16rem,1fr));gap:1rem;align-items:end;margin-bottom:1rem;">
        <MudDatePicker Label="As Of Date"
                       Variant="Variant.Outlined"
                       Editable="true"
                       Date="@_asOfDatePicker"
                       DateChanged="OnAsOfDateChanged" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_isLoading" OnClick="LoadAsync">
            Refresh Aging
        </MudButton>
    </div>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Info" Style="margin-bottom:1rem;" />
    }

    @if (!string.IsNullOrWhiteSpace(_errorText))
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            @_errorText
        </MudAlert>
    }

    @if (_report is not null)
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));gap:1rem;margin-bottom:1rem;">
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Customers</MudText>
                <MudText Typo="Typo.h6">@_report.CustomerCount</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@_report.OpenItemCount open item(s)</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Outstanding</MudText>
                <MudText Typo="Typo.h6">@FormatAmount(_report.TotalOutstandingAmountBase)</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@_report.BaseCurrencyCode base</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Overdue</MudText>
                <MudText Typo="Typo.h6">@FormatAmount(_report.TotalOverdueAmountBase)</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">Past due total</MudText>
            </MudPaper>
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.caption">Oldest bucket</MudText>
                <MudText Typo="Typo.h6">@FormatAmount(_report.DaysOver90AmountBase)</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">Over 90 days</MudText>
            </MudPaper>
        </div>

        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <MudText Typo="Typo.h6" Class="mb-3">Bucket Summary</MudText>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(10rem,1fr));gap:1rem;">
                @foreach (var bucket in BucketCards)
                {
                    <MudPaper Class="pa-3" Elevation="0">
                        <MudText Typo="Typo.caption">@bucket.Label</MudText>
                        <MudText Typo="Typo.h6">@FormatAmount(bucket.Amount)</MudText>
                    </MudPaper>
                }
            </div>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <MudText Typo="Typo.h6" Class="mb-3">Customer Exposure</MudText>
            <MudTable Items="_report.CustomerRows" Dense="true" Hover="true" Bordered="true">
                <HeaderContent>
                    <MudTh>Customer</MudTh>
                    <MudTh>Open Items</MudTh>
                    <MudTh>Oldest Due</MudTh>
                    <MudTh>Overdue</MudTh>
                    <MudTh>Outstanding</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@context.CustomerDisplayName</MudText>
                            <MudText Typo="Typo.caption" Class="text-secondary">@context.CustomerEntityNumber</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd>@context.OpenItemCount</MudTd>
                    <MudTd>@(context.OldestDueDate?.ToString("yyyy-MM-dd") ?? "No due date")</MudTd>
                    <MudTd>@FormatAmount(context.TotalOverdueAmountBase)</MudTd>
                    <MudTd>@FormatAmount(context.TotalOutstandingAmountBase)</MudTd>
                    <MudTd>
                        <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
                            <MudButton Variant="Variant.Text" Color="Color.Info" Href="@BuildCustomerInvoiceBrowserHref(context.CustomerId)">
                                Invoices
                            </MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Success" Href="@BuildCustomerReceivePaymentHref(context.CustomerId)">
                                Receive Payment
                            </MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Warning" Href="@BuildCustomerCreditApplicationHref(context.CustomerId)">
                                Credit Apply
                            </MudButton>
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.h6" Class="mb-3">Open Item Detail</MudText>
            <MudTable Items="_report.DetailRows" Dense="true" Hover="true" Bordered="true">
                <HeaderContent>
                    <MudTh>Customer</MudTh>
                    <MudTh>Document</MudTh>
                    <MudTh>Bucket</MudTh>
                    <MudTh>Due</MudTh>
                    <MudTh>Open Tx</MudTh>
                    <MudTh>Open Base</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@context.CustomerDisplayName</MudText>
                            <MudText Typo="Typo.caption" Class="text-secondary">@context.CustomerEntityNumber</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@context.DisplayNumber</MudText>
                            <MudText Typo="Typo.caption" Class="text-secondary">@FormatSourceType(context.SourceType)</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd>@FormatBucket(context.AgingBucket)</MudTd>
                    <MudTd>@(context.DueDate?.ToString("yyyy-MM-dd") ?? "No due date")</MudTd>
                    <MudTd>@context.OpenAmountTx.ToString("N2") @context.DocumentCurrencyCode</MudTd>
                    <MudTd>@FormatAmount(context.OpenAmountBase)</MudTd>
                    <MudTd>
                        <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
                            @if (TryBuildDocumentHref(context.SourceType, context.SourceDocumentId, out var documentHref))
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Info" Href="@documentHref">Source</MudButton>
                            }
                            <MudButton Variant="Variant.Text" Color="Color.Success" Href="@($"/open-items/ar/{context.OpenItemId:D}")">Open Item</MudButton>
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</div>

@code {
    private DateOnly _asOfDate = DateOnly.FromDateTime(DateTime.Today);
    private DateTime? _asOfDatePicker = DateTime.Today;
    private bool _isLoading;
    private string? _errorText;
    private Aging.ArAgingReportViewModel? _report;

    private bool WritesBlocked => ShellSession.AreWritesBlocked;

    private IReadOnlyList<(string Label, decimal Amount)> BucketCards =>
    [
        ("Current", _report?.CurrentAmountBase ?? 0m),
        ("1-30", _report?.Days1To30AmountBase ?? 0m),
        ("31-60", _report?.Days31To60AmountBase ?? 0m),
        ("61-90", _report?.Days61To90AmountBase ?? 0m),
        ("90+", _report?.DaysOver90AmountBase ?? 0m)
    ];

    private string AgingStageLabel => _report is not null
        ? "AR aging workbench active"
        : "Load aging exposure";

    private string AgingStageSummary => _report is not null
        ? "Customer exposure and open-item truth are now visible in one AR-facing surface, with direct links back into source and settlement lanes."
        : "This page closes the AR aging product gap by turning the backend report into an operator-facing workbench.";

    private string AgingStageBadge => _report is not null ? "Active" : "New";

    private Color AgingStageColor => _report is not null ? Color.Success : Color.Info;

    private string AgingNextStepTitle => _report is not null
        ? "Review customer exposure"
        : "Refresh aging";

    private string AgingNextStepSummary => _report is not null
        ? "Use customer-level exposure first, then drill into open items to decide whether the next move belongs in source review, Receive Payment, or Credit Application."
        : "Load one as-of date to turn AR open-item truth into a usable operator report.";

    private string AgingSourceContinuityLabel => _report is not null
        ? "Source and open-item drill-down available"
        : "Awaiting report load";

    private string AgingSourceContinuitySummary => _report is not null
        ? "Every detail row can route back into the original invoice or credit note and into the governed AR open-item drill-down."
        : "Once loaded, aging rows will route directly into the source and open-item surfaces instead of becoming a dead-end report.";

    private string AgingSettlementContinuityLabel => _report is not null
        ? "Settlement lanes linked"
        : "Settlement continuity pending";

    private string AgingSettlementContinuitySummary => _report is not null
        ? "Each customer row can continue straight into Receive Payment or Credit Application using the same customer-scoped open-item truth."
        : "Once the report is loaded, customer exposure should hand off cleanly into settlement workflows.";

    protected override async Task OnInitializedAsync()
    {
        await EnsureWriteGateStateAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _isLoading = true;
            _errorText = null;
            _report = null;

            var result = await ReportClient.GetAsync(ShellSession.ActiveCompanyId, _asOfDate, CancellationToken.None);
            if (result.IsNotFound)
            {
                _errorText = result.ErrorMessage ?? "The active company is not provisioned in the accounting core yet.";
                return;
            }

            if (!string.IsNullOrWhiteSpace(result.ErrorMessage))
            {
                _errorText = result.ErrorMessage;
                return;
            }

            _report = result.Value;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task EnsureWriteGateStateAsync()
    {
        await ShellSession.RefreshAsync(CancellationToken.None);
    }

    private void OnAsOfDateChanged(DateTime? value)
    {
        _asOfDatePicker = value;
        _asOfDate = DateOnly.FromDateTime(value ?? DateTime.Today);
    }

    private static string FormatAmount(decimal amount) => amount.ToString("N2");

    private static string FormatBucket(string bucket) =>
        string.IsNullOrWhiteSpace(bucket)
            ? "Unbucketed"
            : bucket.Replace('_', ' ');

    private static string FormatSourceType(string sourceType) =>
        sourceType switch
        {
            "credit_note" => "Credit Note",
            "invoice" => "Invoice",
            _ => sourceType
        };

    private static bool TryBuildDocumentHref(string sourceType, Guid documentId, out string href)
    {
        href = sourceType switch
        {
            "invoice" => $"/documents/invoice/{documentId:D}",
            "credit_note" => $"/documents/credit_note/{documentId:D}",
            _ => string.Empty
        };

        return !string.IsNullOrWhiteSpace(href);
    }

    private static string BuildCustomerInvoiceBrowserHref(Guid customerId) =>
        $"/documents/source-browser?sourceType=invoice&counterpartyRole=customer&counterpartyId={customerId:D}";

    private static string BuildCustomerReceivePaymentHref(Guid customerId) =>
        $"/ar/receive-payment?customerId={customerId:D}";

    private static string BuildCustomerCreditApplicationHref(Guid customerId) =>
        $"/ar/credit-application?customerId={customerId:D}";
}
