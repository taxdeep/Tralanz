        SelectedCustomerId.HasValue
            ? $"/documents/invoice/draft-editor?origin=company-ready&customerId={SelectedCustomerId.Value:D}"
            : "/documents/invoice/draft-editor?origin=company-ready";

    private string BuildCustomerBrowserHref() =>
        SelectedCustomerId.HasValue
            ? $"/documents/source-browser?origin=company-ready&sourceType=invoice&counterpartyRole=customer&counterpartyId={SelectedCustomerId.Value:D}"
            : "/documents/source-browser?origin=company-ready&sourceType=invoice&counterpartyRole=customer";

    private string BuildInvoiceBrowserHref() =>
        SelectedCustomerId.HasValue
            ? $"/documents/source-browser?sourceType=invoice&counterpartyRole=customer&counterpartyId={SelectedCustomerId.Value:D}"
            : "/documents/source-browser?sourceType=invoice&counterpartyRole=customer";

    private string BuildCreditApplicationHref() =>
        SelectedCustomerId.HasValue
            ? $"/ar/credit-application?customerId={SelectedCustomerId.Value:D}"
            : "/ar/credit-application";

    private string BuildPostedReceivePaymentDetailHref() =>
        _preparedDraft is null
            ? string.Empty
            : $"/documents/receive_payment/{_preparedDraft.DocumentId:D}";

    private sealed class RowState
    {
        public RowState(ReceivePaymentOpenItemCandidate source)
        {
            OpenItemId = source.OpenItemId;
            SourceType = source.SourceType;
            SourceId = source.SourceId;
            DisplayNumber = source.DisplayNumber;
            DueDate = source.DueDate;
            DocumentCurrencyCode = source.DocumentCurrencyCode;
            OpenAmountTx = source.OpenAmountTx;
            OpenAmountBase = source.OpenAmountBase;
        }

        public Guid OpenItemId { get; }
        public string SourceType { get; }
        public Guid SourceId { get; }
        public string DisplayNumber { get; }
        public DateOnly? DueDate { get; }
        public string DocumentCurrencyCode { get; }
        public decimal OpenAmountTx { get; }
        public decimal OpenAmountBase { get; }
        public decimal AppliedAmountTx { get; set; }
    }

    private static bool TryBuildDocumentHref(string sourceType, Guid documentId, out string href)
    {
        href = sourceType switch
        {
            "invoice" => $"/documents/invoice/{documentId:D}",
            "credit_note" => $"/documents/credit_note/{documentId:D}",
            "receive_payment" => $"/documents/receive_payment/{documentId:D}",
            _ => string.Empty
        };

        return !string.IsNullOrWhiteSpace(href);
    }

    private static string DisplayDocumentLabel(string displayNumber, string sourceType) =>
        sourceType switch
        {
            "invoice" => $"{displayNumber} | Invoice",
            "credit_note" => $"{displayNumber} | Credit Note",
            "receive_payment" => $"{displayNumber} | Receive Payment",
            _ => displayNumber
        };
}
