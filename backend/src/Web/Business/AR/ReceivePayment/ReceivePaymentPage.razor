@page "/ar/receive-payment"
@using Modules.AR.ReceivePayment
@using Web.Business.AR.SettlementPosting
@inject ICompanyAccessShellSession ShellSession
@inject IArSettlementLookupService LookupService
@inject IReceivePaymentDraftPreparationWorkflow Workflow
@inject ArSettlementPostingClient PostingClient
@inject ISnackbar Snackbar

<PageTitle>Receive Payment</PageTitle>

<div style="padding:2rem 2.25rem;color:#d9e2ea;">
    <h1 style="margin:0 0 0.75rem 0;">Receive Payment</h1>
    <p style="margin:0 0 1rem 0;color:#97a8b7;max-width:56rem;">
        Prepare governed AR receipt drafts from existing open receivables in the active company context.
    </p>

    <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
        <div style="display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;flex-wrap:wrap;">
            <div>
                <MudText Typo="Typo.subtitle2">AR Settlement Chain</MudText>
                <MudText Typo="Typo.h5">@SettlementStageLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@SettlementStageSummary</MudText>
            </div>
            <MudChip T="string" Variant="Variant.Filled" Color="@SettlementStageColor">@SettlementStageBadge</MudChip>
        </div>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));gap:1rem;margin-top:1rem;">
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Source receivable lane</MudText>
                <MudText Typo="Typo.h6">@SettlementSourceLaneLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@SettlementSourceLaneSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Current next step</MudText>
                <MudText Typo="Typo.h6">@SettlementNextStepTitle</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@SettlementNextStepSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Related AR lane</MudText>
                <MudText Typo="Typo.h6">@SettlementRelatedLaneLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@SettlementRelatedLaneSummary</MudText>
            </MudPaper>
        </div>

        <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1rem;">
            <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@BuildInvoiceBrowserHref()">
                Review Invoices
            </MudButton>
            @if (SelectedCustomerId.HasValue)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="@BuildCreditApplicationHref()">
                    Open Credit Application
                </MudButton>
            }
            @if (_postedResult is not null && _preparedDraft is not null)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success" Href="@BuildPostedReceivePaymentDetailHref()">
                    Continue Posted Receipt Review
                </MudButton>
            }
        </div>
    </MudPaper>

    @if (IsCompanyReadyHandOff)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            Company-ready hand-off opened the AR settlement workbench so you can continue from the first invoice stage into the first receipt stage once customers, bank accounts, and posted receivables exist.
        </MudAlert>

        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <MudText Typo="Typo.subtitle2" Class="mb-2">First-company continuity</MudText>
            <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/documents/invoice/draft-editor?origin=company-ready">
                    Start First Invoice
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Success" Href="/company/customer-vendor-setup?origin=company-ready">
                    Review Customer Truth
                </MudButton>
                @if (SelectedCustomerId.HasValue)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@BuildCustomerBrowserHref()">
                        Browse Selected Customer Documents
                    </MudButton>
                }
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/company/bank-and-cash-setup?origin=company-ready">
                    Review Bank &amp; Cash Setup
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" Href="/company/ready">
                    Back to Company Ready
                </MudButton>
            </div>
        </MudPaper>
    }

    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
        Active company: @ShellSession.ActiveCompanyId
        <br />
        Current user: @ShellSession.CurrentUserId
    </MudAlert>

    @if (WritesBlocked)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-bottom:1rem;">
            @ShellSession.WriteBlockMessage
        </MudAlert>
    }

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(14rem,1fr));gap:1rem;margin-bottom:1rem;">
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.caption">Bank Readiness</MudText>
            <MudText Typo="Typo.h6">@BankReadinessLabel</MudText>
            <MudText Typo="Typo.body2" Class="text-secondary">@BankReadinessSummary</MudText>
        </MudPaper>
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.caption">Customer Readiness</MudText>
            <MudText Typo="Typo.h6">@CustomerReadinessLabel</MudText>
            <MudText Typo="Typo.body2" Class="text-secondary">@CustomerReadinessSummary</MudText>
        </MudPaper>
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.caption">Receivable Trail</MudText>
            <MudText Typo="Typo.h6">@ReceivableTrailLabel</MudText>
            <MudText Typo="Typo.body2" Class="text-secondary">@ReceivableTrailSummary</MudText>
        </MudPaper>
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.caption">Settlement Availability</MudText>
            <MudText Typo="Typo.h6">@SettlementAvailabilityLabel</MudText>
            <MudText Typo="Typo.body2" Class="text-secondary">@SettlementAvailabilitySummary</MudText>
        </MudPaper>
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.caption">Source Follow-up</MudText>
            <MudText Typo="Typo.h6">@SourceFollowUpLabel</MudText>
            <MudText Typo="Typo.body2" Class="text-secondary">@SourceFollowUpSummary</MudText>
        </MudPaper>
    </div>

    @if (IsCompanyReadyHandOff)
    {
        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Recommended next operator steps</MudText>
            <MudList T="string" Dense="true">
                <MudListItem Text="1">
                    <ChildContent><MudText Typo="Typo.body2">@GetFirstCompanyStepOne()</MudText></ChildContent>
                </MudListItem>
                <MudListItem Text="2">
                    <ChildContent><MudText Typo="Typo.body2">@GetFirstCompanyStepTwo()</MudText></ChildContent>
                </MudListItem>
                <MudListItem Text="3">
                    <ChildContent><MudText Typo="Typo.body2">@GetFirstCompanyStepThree()</MudText></ChildContent>
                </MudListItem>
            </MudList>
        </MudPaper>

        @if (ShouldShowSettlementGapPanel)
        {
            <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
                <MudText Typo="Typo.subtitle2" Class="mb-2">First receipt gap</MudText>
                <MudText Typo="Typo.body2" Class="mb-3">@ReceiptGapSummary</MudText>
                <MudList T="string" Dense="true" Class="mb-3">
                    @foreach (var step in ReceiptGapChecklist)
                    {
                        <MudListItem>
                            <ChildContent><MudText Typo="Typo.body2">@step</MudText></ChildContent>
                        </MudListItem>
                    }
                </MudList>
                <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
                    @if (_customers.Count == 0)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Success" Href="/company/customer-vendor-setup?origin=company-ready">
                            Create First Customer
                        </MudButton>
                    }
                    else if (SelectedCustomerId.HasValue)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@BuildCustomerInvoiceHref()">
                            Open Matching Invoice Flow
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@BuildCustomerBrowserHref()">
                            Browse Matching Source Documents
                        </MudButton>
                    }
                </div>
            </MudPaper>
        }
    }

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(16rem,1fr));gap:1rem;margin-bottom:1rem;">
        <MudSelect T="string" Label="Customer" Variant="Variant.Outlined" @bind-Value="_selectedCustomerIdText">
            @foreach (var customer in _customers)
            {
                <MudSelectItem T="string" Value="@customer.Id.ToString()">@customer.DisplayLabel</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="string" Label="Bank Account" Variant="Variant.Outlined" @bind-Value="_selectedBankAccountIdText">
            @foreach (var bankAccount in _bankAccounts)
            {
                <MudSelectItem T="string" Value="@bankAccount.Id.ToString()">@bankAccount.DisplayLabel</MudSelectItem>
            }
        </MudSelect>
        <MudDatePicker Label="Payment Date" Variant="Variant.Outlined" Editable="true" Date="@_paymentDatePicker" DateChanged="OnPaymentDateChanged" />
        <MudTextField T="string" Label="Memo" Variant="Variant.Outlined" @bind-Value="_memo" />
    </div>

    <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:1rem;">
        <MudButton Variant="Variant.Outlined" Color="Color.Info" Disabled="_isBusy" OnClick="LoadCandidatesAsync">Load Open Receivables</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(_isBusy || _rows.Count == 0 || WritesBlocked)" OnClick="PrepareDraftAsync">Prepare Draft</MudButton>
    </div>

    @if (!string.IsNullOrWhiteSpace(_errorText))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Style="margin-bottom:1rem;">@_errorText</MudAlert>
    }

    @if (_rows.Count > 0)
    {
        <MudTable Items="_rows" Dense="true" Hover="true" Bordered="true" Style="margin-bottom:1rem;">
            <HeaderContent>
                <MudTh>Document</MudTh>
                <MudTh>Currency</MudTh>
                <MudTh>Open Tx</MudTh>
                <MudTh>Open Base</MudTh>
                <MudTh>Apply Amount</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.DisplayNumber</MudTd>
                <MudTd>@context.DocumentCurrencyCode</MudTd>
                <MudTd>@context.OpenAmountTx</MudTd>
                <MudTd>@context.OpenAmountBase</MudTd>
                <MudTd>
                    <MudNumericField T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Max="@context.OpenAmountTx" Immediate="true" @bind-Value="context.AppliedAmountTx" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

    @if (_rows.Any(static row => row.AppliedAmountTx > 0))
    {
        <MudPaper Class="pa-4" Elevation="0" Style="margin-bottom:1rem;">
            <MudText Typo="Typo.h6">Apply Preview</MudText>
            <MudText Typo="Typo.body2" Class="mb-3">
                @($"{_rows.Count(static row => row.AppliedAmountTx > 0)} open item(s) selected | Total apply {_rows.Where(static row => row.AppliedAmountTx > 0).Sum(static row => row.AppliedAmountTx):N2}")
            </MudText>
            <MudTable Items="@_rows.Where(static row => row.AppliedAmountTx > 0)" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Source Document</MudTh>
                    <MudTh>Open Item</MudTh>
                    <MudTh>Due Date</MudTh>
                    <MudTh>Apply Amount</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        @if (TryBuildDocumentHref(context.SourceType, context.SourceId, out var href))
                        {
                            <MudLink Href="@href">@DisplayDocumentLabel(context.DisplayNumber, context.SourceType)</MudLink>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">@DisplayDocumentLabel(context.DisplayNumber, context.SourceType)</MudText>
                        }
                    </MudTd>
                    <MudTd>
                        <MudLink Href="@($"/open-items/ar/{context.OpenItemId:D}")"><span class="citus-inline-code">@context.OpenItemId</span></MudLink>
                    </MudTd>
                    <MudTd>@(context.DueDate?.ToString("yyyy-MM-dd") ?? "No due date")</MudTd>
                    <MudTd>@context.AppliedAmountTx.ToString("N2")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }

    @if (_preparedDraft is not null)
    {
        <MudPaper Class="pa-4" Elevation="0">
            <MudText Typo="Typo.h6">Prepared Draft</MudText>
            <MudText Typo="Typo.body2">Document Id: @_preparedDraft.DocumentId</MudText>
            <MudText Typo="Typo.body2">Payment: @_preparedDraft.PaymentNumber</MudText>
            <MudText Typo="Typo.body2">Entity Number: @_preparedDraft.EntityNumber</MudText>
            <MudText Typo="Typo.body2">Currency: @_preparedDraft.DocumentCurrencyCode</MudText>
            <MudText Typo="Typo.body2">FX: @_preparedDraft.FxRate (@_preparedDraft.FxSource)</MudText>
            <MudText Typo="Typo.body2">Total: @_preparedDraft.TotalAmount</MudText>
            <MudText Typo="Typo.body2">Status: @_preparedDraft.Status</MudText>

            <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:1rem;">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@($"/documents/receive_payment/{_preparedDraft.DocumentId:D}")">
                    Open Prepared Draft Detail
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           Disabled="@(_isBusy || WritesBlocked)"
                           OnClick="PostDraftAsync">
                    Post Draft
                </MudButton>
            </div>

            @if (SelectedRows.Count > 0)
            {
                <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Applied Source Documents</MudText>
                <MudTable Items="SelectedRows" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Source Document</MudTh>
                        <MudTh>Open Item</MudTh>
                        <MudTh>Due Date</MudTh>
                        <MudTh>Applied</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            @if (TryBuildDocumentHref(context.SourceType, context.SourceId, out var href))
                            {
                                <MudLink Href="@href">@DisplayDocumentLabel(context.DisplayNumber, context.SourceType)</MudLink>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2">@DisplayDocumentLabel(context.DisplayNumber, context.SourceType)</MudText>
                            }
                        </MudTd>
                        <MudTd>
                            <MudLink Href="@($"/open-items/ar/{context.OpenItemId:D}")"><span class="citus-inline-code">@context.OpenItemId</span></MudLink>
                        </MudTd>
                        <MudTd>@(context.DueDate?.ToString("yyyy-MM-dd") ?? "No due date")</MudTd>
                        <MudTd>@context.AppliedAmountTx.ToString("N2")</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    }

    @if (_postedResult is not null)
    {
        <MudPaper Class="pa-4" Elevation="0" Style="margin-top:1rem;">
            <MudText Typo="Typo.h6">Posted Review Continuity</MudText>
            <MudText Typo="Typo.body2">Journal Entry: @_postedResult.JournalEntryDisplayNumber</MudText>
            <MudText Typo="Typo.body2">Posted At: @_postedResult.PostedAt.ToString("yyyy-MM-dd HH:mm 'UTC'")</MudText>
            <MudText Typo="Typo.body2">Status: @_postedResult.Status</MudText>
            @if (_postedResult.Warnings.Count > 0)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Style="margin-top:1rem;">
                    @string.Join(" | ", _postedResult.Warnings)
                </MudAlert>
            }
            <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:1rem;">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@BuildPostedReceivePaymentDetailHref()">
                    Open Posted Document
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@($"/gl/journal-entry/review/{_postedResult.JournalEntryId:D}")">
                    Open Journal Entry Review
                </MudButton>
                @if (SelectedCustomerId.HasValue)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="@BuildCreditApplicationHref()">
                        Continue to Credit Application
                    </MudButton>
                }
            </div>
        </MudPaper>
    }
</div>

@code {
    private List<(Guid Id, string DisplayLabel, string CurrencyCode)> _customers = [];
    private List<(Guid Id, string DisplayLabel)> _bankAccounts = [];
    private string? _selectedCustomerIdText;
    private string? _selectedBankAccountIdText;
    private string? _memo;
    private bool _isBusy;
    private string? _errorText;
    private DateOnly _paymentDate = DateOnly.FromDateTime(DateTime.Today);
    private DateTime? _paymentDatePicker = DateTime.Today;
    private readonly List<RowState> _rows = [];
    private ReceivePaymentDraftResult? _preparedDraft;
    private ArSettlementPostingResult? _postedResult;
    private IReadOnlyList<RowState> SelectedRows => _rows.Where(static row => row.AppliedAmountTx > 0m).ToArray();
    [SupplyParameterFromQuery(Name = "origin")]
    public string? Origin { get; set; }
    [SupplyParameterFromQuery(Name = "customerId")]
    public Guid? CustomerId { get; set; }

    private bool IsCompanyReadyHandOff => string.Equals(Origin, "company-ready", StringComparison.OrdinalIgnoreCase);
    private Guid? SelectedCustomerId => Guid.TryParse(_selectedCustomerIdText, out var value) ? value : null;
    private string BankReadinessLabel => _bankAccounts.Count > 0 ? $"{_bankAccounts.Count} active bank account(s)" : "Bank setup required";
    private string BankReadinessSummary => _bankAccounts.Count > 0
        ? "An active bank-detail account is available, so receipt settlement drafts can anchor against a real cash account."
        : "No active bank-detail account is available yet. Complete Bank & Cash Setup before preparing the first receipt draft.";
    private string CustomerReadinessLabel => _customers.Count > 0 ? $"{_customers.Count} customer option(s)" : "Customer setup pending";
    private string CustomerReadinessSummary => _customers.Count > 0
        ? CustomerId.HasValue && SelectedCustomerId == CustomerId
            ? "The customer carried forward from the first-invoice flow is already selected. Load receivables to check whether the first posted document is ready to settle."
            : "Customer lookups are available. Select one customer, then load receivables to see what can be settled."
        : "No customers are available yet. Post the first invoice before expecting receivable settlement candidates here.";
    private string ReceivableTrailLabel => _rows.Count switch
    {
        > 0 => $"{_rows.Count} open receivable candidate(s)",
        _ when SelectedCustomerId is null => "Customer not selected",
        _ => "No open receivables loaded"
    };
    private string ReceivableTrailSummary => _rows.Count switch
    {
        > 0 => "Open receivable candidates are loaded. Enter apply amounts, prepare the draft, and continue into posting.",
        _ when SelectedCustomerId is null => "Select a customer first so the workbench can check for posted invoices or credit notes that still have open receivables.",
        _ => "The selected customer currently has no open receivable candidates loaded. If the first invoice has not been posted yet, start there before returning here."
    };
    private string SettlementAvailabilityLabel => _rows.Count switch
    {
        > 0 => "Ready to settle",
        _ when _bankAccounts.Count == 0 => "Bank anchor missing",
        _ when _customers.Count == 0 => "Customer truth missing",
        _ when SelectedCustomerId is null => "Counterparty not selected",
        _ when CustomerId.HasValue && SelectedCustomerId == CustomerId => "Likely waiting for first post",
        _ => "Needs source-document review"
    };
    private string SettlementAvailabilitySummary => _rows.Count switch
    {
        > 0 => "At least one receivable open item is available, so the first receipt chain can proceed legally.",
        _ when _bankAccounts.Count == 0 => "Settlement cannot begin until one active bank-detail account exists to anchor the cash side of the receipt.",
        _ when _customers.Count == 0 => "There is no company-scoped customer truth yet, so no receivable owner can appear in the settlement workbench.",
        _ when SelectedCustomerId is null => "The workbench still needs one concrete customer selection before it can look for open receivables.",
        _ when CustomerId.HasValue && SelectedCustomerId == CustomerId => "The selected customer came from the first-invoice flow. If no candidate appears, the most likely gap is that the invoice is not posted yet or already fully consumed.",
        _ => "A customer is selected, but settlement still needs a posted invoice or credit note that currently carries an open receivable."
    };
    private string SourceFollowUpLabel => _rows.Count switch
    {
        > 0 => "Posted source confirmed",
        _ when _customers.Count == 0 => "Create customer truth first",
        _ when SelectedCustomerId is null => "Choose one receivable owner",
        _ when CustomerId.HasValue && SelectedCustomerId == CustomerId => "Check first invoice status",
        _ => "Review matching source history"
    };
    private string SourceFollowUpSummary => _rows.Count switch
    {
        > 0 => "Open-item truth already exists for the selected customer, so source posting is no longer the blocker.",
        _ when _customers.Count == 0 => "Without a real customer record, the first invoice cannot produce a receivable owner that later appears in Receive Payment.",
        _ when SelectedCustomerId is null => "Pick the customer tied to the posted invoice or credit note before diagnosing why no settlement candidate is visible.",
        _ when CustomerId.HasValue && SelectedCustomerId == CustomerId => "Because this customer came from the first-invoice hand-off, the next check is whether the first invoice is still draft, has been reversed, or was already consumed by another receipt path.",
        _ => "The next legal check is the matching source-document history for this customer: posted invoice, posted credit note, reversal trail, or prior receipt consumption."
    };
    private string SettlementStageLabel => _postedResult is not null
        ? "Receipt posted into settlement truth"
        : _preparedDraft is not null
            ? "Receipt draft prepared"
            : SelectedRows.Count > 0
                ? "Receivable selected for settlement"
                : _rows.Count > 0
                    ? "Receivable candidates loaded"
                    : "Start receipt settlement";
    private string SettlementStageSummary => _postedResult is not null
        ? "Cash settlement truth and its journal entry already exist. Continue with posted-document review or move into adjacent AR application lanes."
        : _preparedDraft is not null
            ? "The governed draft is ready. Post it when the customer receipt should become formal settlement truth."
            : SelectedRows.Count > 0
                ? "Settlement intent is defined. Prepare the draft so the receipt can move into the governed posting lane."
                : _rows.Count > 0
                    ? "Open receivables are visible. Select applied amounts to continue the receipt chain."
                    : "This lane consumes posted invoice or credit-note receivables and turns them into governed cash settlement truth.";
    private string SettlementStageBadge => _postedResult is not null
        ? "Posted"
        : _preparedDraft is not null
            ? "Prepared"
            : SelectedRows.Count > 0
                ? "Selected"
                : _rows.Count > 0
                    ? "Loaded"
                    : "New";
    private Color SettlementStageColor => _postedResult is not null
        ? Color.Success
        : _preparedDraft is not null
            ? Color.Info
            : SelectedRows.Count > 0
                ? Color.Warning
                : _rows.Count > 0
                    ? Color.Info
                    : Color.Default;
    private string SettlementSourceLaneLabel => _rows.Count > 0 || SelectedCustomerId.HasValue
        ? "Posted invoice / credit note receivables"
        : "Source still unknown";
    private string SettlementSourceLaneSummary => _rows.Count > 0
        ? "These open items already came from posted AR source documents, so Receive Payment is now operating on formal receivable truth."
        : SelectedCustomerId.HasValue
            ? "Select or load the posted invoice and credit-note receivables for this customer before cash settlement can begin."
            : "Choose the customer that owns the receivable before diagnosing the source side of settlement.";
    private string SettlementNextStepTitle => _postedResult is not null
        ? "Review posted receipt"
        : _preparedDraft is not null
            ? "Post the receipt draft"
            : SelectedRows.Count > 0
                ? "Prepare the receipt draft"
                : _rows.Count > 0
                    ? "Select apply amounts"
                    : "Load open receivables";
    private string SettlementNextStepSummary => _postedResult is not null
        ? "Use the posted document and JE review to confirm continuity, then move into adjacent AR flows only if more settlement work remains."
        : _preparedDraft is not null
            ? "Posting will formalize cash settlement truth and create the linked journal entry."
            : SelectedRows.Count > 0
                ? "Preparation turns your selected receivable applications into a governed source document."
                : _rows.Count > 0
                    ? "The workbench already found candidates. Pick concrete applied amounts so settlement intent becomes explicit."
                    : "No settlement can begin until the workbench sees posted open receivables for the selected customer.";
    private string SettlementRelatedLaneLabel => SelectedCustomerId.HasValue
        ? "Credit application lane available"
        : "Choose customer first";
    private string SettlementRelatedLaneSummary => SelectedCustomerId.HasValue
        ? "If the customer also has open credit notes, continue into Credit Application to consume them against invoice truth."
        : "Credit Application follows the same customer-scoped open-item truth, so it becomes useful once one counterparty is selected.";
    private bool ShouldShowSettlementGapPanel => _customers.Count == 0 || SelectedCustomerId is null || (_rows.Count == 0 && SelectedCustomerId.HasValue);
    private string ReceiptGapSummary => _customers.Count switch
    {
        0 => "No customer truth exists yet, so there is no legal receivable owner to carry into the first receipt flow.",
        _ when SelectedCustomerId is null => "A customer list exists, but no specific customer is selected yet, so the workbench cannot look for matching receivable open items.",
        _ when CustomerId.HasValue && SelectedCustomerId == CustomerId => "The selected customer came directly from the first-invoice flow, but no open receivables are visible yet. In practice that usually means the first invoice still needs posting, or that the receivable was already consumed by another receipt path.",
        _ => "The selected customer is set, but no open receivables are visible yet. Usually that means the first invoice has not been posted for this same customer, or the receivable has already been consumed."
    };
    private IReadOnlyList<string> ReceiptGapChecklist => _customers.Count switch
    {
        0 =>
        [
            "Create one real customer record first so the first invoice can bind to company-scoped counterparty truth.",
            "Return to the invoice workbench after customer setup, then post the first invoice before opening Receive Payment again."
        ],
        _ when SelectedCustomerId is null =>
        [
            "Select the customer that owns the first posted invoice or credit note.",
            "Then load open receivables to confirm whether that counterparty now has a settlement candidate."
        ],
        _ when CustomerId.HasValue && SelectedCustomerId == CustomerId =>
        [
            "Open the matching invoice flow and confirm the first invoice is already posted rather than just saved as draft.",
            "If it is posted, browse matching source documents to check whether another receipt already consumed the open receivable."
        ],
        _ =>
        [
            "Browse matching source documents for this customer and confirm at least one invoice or credit note is posted.",
            "If posted source exists, check whether the resulting open receivable has already been settled or reversed elsewhere."
        ]
    };

    protected override async Task OnInitializedAsync()
    {
        await EnsureWriteGateStateAsync();
        await LoadLookupOptionsAsync();
    }

    private async Task LoadLookupOptionsAsync()
    {
        try
        {
            _customers = (await LookupService.ListCustomersAsync(ShellSession.ActiveCompanyId, CancellationToken.None)).ToList();
            _bankAccounts = (await LookupService.ListBankAccountsAsync(ShellSession.ActiveCompanyId, CancellationToken.None)).ToList();

            if (CustomerId.HasValue &&
                _customers.Any(item => item.Id == CustomerId.Value))
            {
                _selectedCustomerIdText = CustomerId.Value.ToString();
            }

            if (_customers.Count == 1)
            {
                _selectedCustomerIdText = _customers[0].Id.ToString();
            }

            if (_bankAccounts.Count == 1)
            {
                _selectedBankAccountIdText = _bankAccounts[0].Id.ToString();
            }
        }
        catch (Exception ex)
        {
            _errorText = ex.Message;
        }
    }

    private async Task LoadCandidatesAsync()
    {
        _preparedDraft = null;
        _postedResult = null;
        _errorText = null;
        if (!TryParseRequiredGuid(_selectedCustomerIdText, "Customer", out var customerId)) return;

        try
        {
            _isBusy = true;
            var candidates = await Workflow.ListOpenItemCandidatesAsync(ShellSession.ActiveCompanyId, customerId, CancellationToken.None);
            _rows.Clear();
            _rows.AddRange(candidates.Select(static candidate => new RowState(candidate)));
        }
        catch (Exception ex)
        {
            _errorText = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task PrepareDraftAsync()
    {
        if (TryBlockWrites())
        {
            return;
        }

        _errorText = null;
        _preparedDraft = null;
        _postedResult = null;
        if (!TryParseRequiredGuid(_selectedCustomerIdText, "Customer", out var customerId) ||
            !TryParseRequiredGuid(_selectedBankAccountIdText, "Bank Account", out var bankAccountId)) return;

        var lines = _rows.Where(static row => row.AppliedAmountTx > 0).Select(static row => new ReceivePaymentDraftLine(row.OpenItemId, row.AppliedAmountTx)).ToArray();
        if (lines.Length == 0)
        {
            _errorText = "Enter at least one applied amount.";
            return;
        }

        try
        {
            _isBusy = true;
            _preparedDraft = await Workflow.PrepareDraftAsync(
                new ReceivePaymentDraftContext(ShellSession.ActiveCompanyId, ShellSession.CurrentUserId, customerId, bankAccountId, _paymentDate, null, null, _memo),
                lines,
                CancellationToken.None);
            Snackbar.Add($"Prepared receive payment draft {_preparedDraft.PaymentNumber}.", Severity.Success);
        }
        catch (Exception ex)
        {
            _errorText = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task PostDraftAsync()
    {
        if (TryBlockWrites())
        {
            return;
        }

        if (_preparedDraft is null)
        {
            _errorText = "Prepare a draft before posting.";
            return;
        }

        try
        {
            _isBusy = true;
            _errorText = null;
            _postedResult = await PostingClient.PostReceivePaymentAsync(
                ShellSession.ActiveCompanyId,
                ShellSession.CurrentUserId,
                _preparedDraft.DocumentId,
                _preparedDraft.FxSnapshotId,
                CancellationToken.None);
            Snackbar.Add($"Posted receive payment to journal entry {_postedResult?.JournalEntryDisplayNumber}.", Severity.Success);
        }
        catch (Exception ex)
        {
            _errorText = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void OnPaymentDateChanged(DateTime? value)
    {
        _paymentDatePicker = value;
        _paymentDate = DateOnly.FromDateTime(value ?? DateTime.Today);
    }

    private bool TryParseRequiredGuid(string? text, string label, out Guid value)
    {
        if (Guid.TryParse(text, out value)) return true;
        _errorText = $"{label} must be selected.";
        return false;
    }

    private bool WritesBlocked => ShellSession.AreWritesBlocked;

    private async Task EnsureWriteGateStateAsync()
    {
        await ShellSession.RefreshAsync(CancellationToken.None);
    }

    private bool TryBlockWrites()
    {
        if (!WritesBlocked)
        {
            return false;
        }

        _errorText = ShellSession.WriteBlockMessage;
        return true;
    }

    private string GetFirstCompanyStepOne() =>
        _bankAccounts.Count == 0
            ? "Provision at least one active bank-detail account first so the receipt draft has a valid settlement anchor."
            : "Keep the active starter bank selected unless you intentionally want to settle receipts into another cash account.";

    private string GetFirstCompanyStepTwo() =>
        _customers.Count == 0
            ? "Create and post the first invoice before expecting any receivable settlement candidates here."
            : CustomerId.HasValue && SelectedCustomerId == CustomerId
                ? "The customer from the first posted invoice is already selected. Load receivables now to confirm the new open item is available for settlement."
                : SelectedCustomerId is null
                ? "Pick the customer that owns the first posted invoice or credit note, then load open receivables."
                : "Load open receivables for the selected customer to confirm there is a posted source document waiting to be settled.";

    private string GetFirstCompanyStepThree() =>
        _rows.Count > 0
            ? "Once the right receivables appear, enter applied amounts and continue through draft preparation and posting."
            : "If no receivables appear after loading, go back to the invoice workbench, post the first invoice, then return here.";

