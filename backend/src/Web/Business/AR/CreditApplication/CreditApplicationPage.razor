@page "/ar/credit-application"
@using Modules.AR.CreditApplication
@using Web.Business.AR.SettlementPosting
@inject ICompanyAccessShellSession ShellSession
@inject IArSettlementLookupService LookupService
@inject ICreditApplicationDraftPreparationWorkflow Workflow
@inject ArSettlementPostingClient PostingClient
@inject ISnackbar Snackbar

<PageTitle>Credit Application</PageTitle>

<section class="bz-flow-page">
    <header class="bz-flow-page__hero">
        <div>
            <div class="bz-flow-page__eyebrow">
                <i class="ti ti-arrows-exchange" aria-hidden="true"></i>
                AR settlement workbench
            </div>
            <h1 class="bz-flow-page__title">Credit Application</h1>
            <p class="bz-flow-page__description">
                Prepare governed AR credit applications from open customer items in the active company context.
            </p>
        </div>
        <div class="bz-flow-page__hero-status">
            <div class="bz-flow-page__hero-status-label">Stage</div>
            <div class="bz-flow-page__hero-status-value">@CreditApplicationStageBadge</div>
        </div>
    </header>

    <MudPaper Class="pa-4 bz-flow-page__card bz-flow-page__chain" Elevation="0" Style="margin-bottom:1rem;">
        <div style="display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;flex-wrap:wrap;">
            <div>
                <MudText Typo="Typo.subtitle2">AR Settlement Chain</MudText>
                <MudText Typo="Typo.h5">@CreditApplicationStageLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@CreditApplicationStageSummary</MudText>
            </div>
            <MudChip T="string" Variant="Variant.Filled" Color="@CreditApplicationStageColor">@CreditApplicationStageBadge</MudChip>
        </div>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));gap:1rem;margin-top:1rem;">
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Source credit lane</MudText>
                <MudText Typo="Typo.h6">@CreditApplicationSourceLaneLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@CreditApplicationSourceLaneSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Current next step</MudText>
                <MudText Typo="Typo.h6">@CreditApplicationNextStepTitle</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@CreditApplicationNextStepSummary</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="0">
                <MudText Typo="Typo.caption">Related AR lane</MudText>
                <MudText Typo="Typo.h6">@CreditApplicationRelatedLaneLabel</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary">@CreditApplicationRelatedLaneSummary</MudText>
            </MudPaper>
        </div>

        <div class="bz-flow-page__actions">
            <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@BuildCreditNoteBrowserHref()">
                Review Credit Notes
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Success" Href="@BuildInvoiceBrowserHref()">
                Review Invoices
            </MudButton>
            @if (SelectedCustomerId.HasValue)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="@BuildReceivePaymentHref()">
                    Open Receive Payment
                </MudButton>
            }
            @if (_postedResult is not null && _preparedDraft is not null)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success" Href="@BuildPostedCreditApplicationDetailHref()">
                    Continue Posted Application Review
                </MudButton>
            }
        </div>
    </MudPaper>

    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="bz-flow-page__alert">
        Active company: @ShellSession.ActiveCompanyId
        <br />
        Current user: @ShellSession.CurrentUserId
    </MudAlert>

    @if (WritesBlocked)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="bz-flow-page__alert">
            @ShellSession.WriteBlockMessage
        </MudAlert>
    }

    <div class="bz-flow-page__form-grid">
        <MudSelect T="string" Label="Customer" Variant="Variant.Outlined" @bind-Value="_selectedCustomerIdText">
            @foreach (var customer in _customers)
            {
                <MudSelectItem T="string" Value="@customer.Id.ToString()">@customer.DisplayLabel</MudSelectItem>
            }
        </MudSelect>
        <MudDatePicker Label="Application Date" Variant="Variant.Outlined" Editable="true" Date="@_applicationDatePicker" DateChanged="OnApplicationDateChanged" />
        <MudTextField T="string" Label="Memo" Variant="Variant.Outlined" @bind-Value="_memo" />
    </div>

    <div class="bz-flow-page__toolbar">
        <MudButton Variant="Variant.Outlined" Color="Color.Info" Disabled="_isBusy" OnClick="LoadCandidatesAsync">Load Open Items</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(_isBusy || _sourceCredits.Count == 0 || _targetInvoices.Count == 0 || WritesBlocked)" OnClick="PrepareDraftAsync">Prepare Draft</MudButton>
    </div>

    @if (!string.IsNullOrWhiteSpace(_errorText))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Class="bz-flow-page__alert">@_errorText</MudAlert>
    }

    @if (_sourceCredits.Count > 0 || _targetInvoices.Count > 0)
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(18rem,1fr));gap:1rem;margin-bottom:1rem;">
            <MudSelect T="string" Label="Source Credit Note Open Item" Variant="Variant.Outlined" @bind-Value="_selectedSourceOpenItemIdText">
                @foreach (var source in _sourceCredits)
                {
                    <MudSelectItem T="string" Value="@source.OpenItemId.ToString()">
                        @($"{source.DisplayNumber} | {source.OpenAmountTx} {source.DocumentCurrencyCode}")
                    </MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="string" Label="Target Invoice Open Item" Variant="Variant.Outlined" @bind-Value="_selectedTargetOpenItemIdText">
                @foreach (var target in _targetInvoices)
                {
                    <MudSelectItem T="string" Value="@target.OpenItemId.ToString()">
                        @($"{target.DisplayNumber} | {target.OpenAmountTx} {target.DocumentCurrencyCode}")
                    </MudSelectItem>
                }
            </MudSelect>
            <MudNumericField T="decimal" Label="Apply Amount" Variant="Variant.Outlined" Min="0" Immediate="true" @bind-Value="_appliedAmountTx" />
        </div>

        <MudTable Items="_sourceCredits" Dense="true" Hover="true" Bordered="true" Style="margin-bottom:1rem;">
            <HeaderContent>
                <MudTh>Credit Source</MudTh>
                <MudTh>Currency</MudTh>
                <MudTh>Open Tx</MudTh>
                <MudTh>Open Base</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.DisplayNumber</MudTd>
                <MudTd>@context.DocumentCurrencyCode</MudTd>
                <MudTd>@context.OpenAmountTx</MudTd>
                <MudTd>@context.OpenAmountBase</MudTd>
            </RowTemplate>
        </MudTable>

        <MudTable Items="_targetInvoices" Dense="true" Hover="true" Bordered="true" Style="margin-bottom:1rem;">
            <HeaderContent>
                <MudTh>Invoice Target</MudTh>
                <MudTh>Currency</MudTh>
                <MudTh>Open Tx</MudTh>
                <MudTh>Open Base</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.DisplayNumber</MudTd>
                <MudTd>@context.DocumentCurrencyCode</MudTd>
                <MudTd>@context.OpenAmountTx</MudTd>
                <MudTd>@context.OpenAmountBase</MudTd>
            </RowTemplate>
        </MudTable>
    }

    @if (TryGetSelectedSourceCredit(out var selectedSource) && TryGetSelectedTargetInvoice(out var selectedTarget) && _appliedAmountTx > 0m)
    {
        <MudPaper Class="pa-4 bz-flow-page__card" Elevation="0" Style="margin-bottom:1rem;">
            <MudText Typo="Typo.h6">Apply Preview</MudText>
            <MudText Typo="Typo.body2" Class="mb-3">@($"Planned application {_appliedAmountTx:N2} {selectedSource.DocumentCurrencyCode}")</MudText>
            <MudTable Items="new[] { selectedSource, selectedTarget }" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Role</MudTh>
                    <MudTh>Document</MudTh>
                    <MudTh>Open Item</MudTh>
                    <MudTh>Open Tx</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@(context.OpenItemId == selectedSource.OpenItemId ? "Source Credit" : "Target Invoice")</MudTd>
                    <MudTd>
                        @if (TryBuildDocumentHref(context.SourceType, context.SourceId, out var href))
                        {
                            <MudLink Href="@href">@DisplayDocumentLabel(context.DisplayNumber, context.SourceType)</MudLink>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">@DisplayDocumentLabel(context.DisplayNumber, context.SourceType)</MudText>
                        }
                    </MudTd>
                    <MudTd>
                        <MudLink Href="@($"/open-items/ar/{context.OpenItemId:D}")"><span class="citus-inline-code">@context.OpenItemId</span></MudLink>
                    </MudTd>
                    <MudTd>@context.OpenAmountTx.ToString("N2")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }

    @if (_preparedDraft is not null)
    {
        <MudPaper Class="pa-4 bz-flow-page__card" Elevation="0">
            <MudText Typo="Typo.h6">Prepared Draft</MudText>
            <MudText Typo="Typo.body2">Document Id: @_preparedDraft.DocumentId</MudText>
            <MudText Typo="Typo.body2">Application: @_preparedDraft.ApplicationNumber</MudText>
            <MudText Typo="Typo.body2">Entity Number: @_preparedDraft.EntityNumber</MudText>
            <MudText Typo="Typo.body2">Currency: @_preparedDraft.DocumentCurrencyCode</MudText>
            <MudText Typo="Typo.body2">Total: @_preparedDraft.TotalAmount</MudText>
            <MudText Typo="Typo.body2">Realized FX Base: @_preparedDraft.RealizedFxAmountBase</MudText>
            <MudText Typo="Typo.body2">Status: @_preparedDraft.Status</MudText>

            <div class="bz-flow-page__actions">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@($"/documents/credit_application/{_preparedDraft.DocumentId:D}")">
                    Open Prepared Draft Detail
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           Disabled="@(_isBusy || WritesBlocked)"
                           OnClick="PostDraftAsync">
                    Post Draft
                </MudButton>
            </div>

            @if (TryGetSelectedSourceCredit(out var selectedSource) && TryGetSelectedTargetInvoice(out var selectedTarget))
            {
                <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Applied Source And Target</MudText>
                <MudTable Items="new[] { selectedSource, selectedTarget }" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Role</MudTh>
                        <MudTh>Document</MudTh>
                        <MudTh>Open Item</MudTh>
                        <MudTh>Applied</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@(context.OpenItemId == selectedSource.OpenItemId ? "Source Credit" : "Target Invoice")</MudTd>
                        <MudTd>
                            @if (TryBuildDocumentHref(context.SourceType, context.SourceId, out var href))
                            {
                                <MudLink Href="@href">@DisplayDocumentLabel(context.DisplayNumber, context.SourceType)</MudLink>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2">@DisplayDocumentLabel(context.DisplayNumber, context.SourceType)</MudText>
                            }
                        </MudTd>
                        <MudTd>
                            <MudLink Href="@($"/open-items/ar/{context.OpenItemId:D}")"><span class="citus-inline-code">@context.OpenItemId</span></MudLink>
                        </MudTd>
                        <MudTd>@_appliedAmountTx.ToString("N2")</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    }

    @if (_postedResult is not null)
    {
        <MudPaper Class="pa-4 bz-flow-page__card" Elevation="0" Style="margin-top:1rem;">
            <MudText Typo="Typo.h6">Posted Review Continuity</MudText>
            <MudText Typo="Typo.body2">Journal Entry: @_postedResult.JournalEntryDisplayNumber</MudText>
            <MudText Typo="Typo.body2">Posted At: @_postedResult.PostedAt.ToString("yyyy-MM-dd HH:mm 'UTC'")</MudText>
            <MudText Typo="Typo.body2">Status: @_postedResult.Status</MudText>
            <div class="bz-flow-page__actions">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@($"/documents/credit_application/{_preparedDraft!.DocumentId:D}")">
                    Open Posted Document
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="@($"/gl/journal-entry/review/{_postedResult.JournalEntryId:D}")">
                    Open Journal Entry Review
                </MudButton>
                @if (SelectedCustomerId.HasValue)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="@BuildReceivePaymentHref()">
                        Back to Receive Payment
                    </MudButton>
                }
            </div>
        </MudPaper>
    }
</section>

@code {
    private List<(Guid Id, string DisplayLabel, string CurrencyCode)> _customers = [];
    private string? _selectedCustomerIdText;
    private string? _memo;
    private bool _isBusy;
    private string? _errorText;
    private DateOnly _applicationDate = DateOnly.FromDateTime(DateTime.Today);
    private DateTime? _applicationDatePicker = DateTime.Today;
    private readonly List<RowState> _sourceCredits = [];
    private readonly List<RowState> _targetInvoices = [];
    private string? _selectedSourceOpenItemIdText;
    private string? _selectedTargetOpenItemIdText;
    private decimal _appliedAmountTx;
    private CreditApplicationDraftResult? _preparedDraft;
    private ArSettlementPostingResult? _postedResult;
    [SupplyParameterFromQuery(Name = "customerId")]
    public Guid? CustomerId { get; set; }
    private Guid? SelectedCustomerId => Guid.TryParse(_selectedCustomerIdText, out var value) ? value : null;
    private string CreditApplicationStageLabel => _postedResult is not null
        ? "Credit application posted"
        : _preparedDraft is not null
            ? "Application draft prepared"
            : TryGetSelectedSourceCredit(out _) && TryGetSelectedTargetInvoice(out _) && _appliedAmountTx > 0m
                ? "Application intent selected"
                : _sourceCredits.Count > 0 || _targetInvoices.Count > 0
                    ? "Open credit and invoice candidates loaded"
                    : "Start credit application";
    private string CreditApplicationStageSummary => _postedResult is not null
        ? "The credit application is now formal AR settlement truth and can be reviewed through the posted document and JE lane."
        : _preparedDraft is not null
            ? "The governed application draft is ready. Post it when the credit should formally offset invoice truth."
            : TryGetSelectedSourceCredit(out _) && TryGetSelectedTargetInvoice(out _) && _appliedAmountTx > 0m
                ? "Source credit and target invoice are chosen. Prepare the governed document so offset truth becomes explicit."
                : _sourceCredits.Count > 0 || _targetInvoices.Count > 0
                    ? "The workbench found candidates. Choose one credit, one invoice, and the amount to apply."
                    : "This lane consumes posted credit notes against posted invoices for the same customer.";
    private string CreditApplicationStageBadge => _postedResult is not null
        ? "Posted"
        : _preparedDraft is not null
            ? "Prepared"
            : TryGetSelectedSourceCredit(out _) && TryGetSelectedTargetInvoice(out _) && _appliedAmountTx > 0m
                ? "Selected"
                : _sourceCredits.Count > 0 || _targetInvoices.Count > 0
                    ? "Loaded"
                    : "New";
    private Color CreditApplicationStageColor => _postedResult is not null
        ? Color.Success
        : _preparedDraft is not null
            ? Color.Info
            : TryGetSelectedSourceCredit(out _) && TryGetSelectedTargetInvoice(out _) && _appliedAmountTx > 0m
                ? Color.Warning
                : _sourceCredits.Count > 0 || _targetInvoices.Count > 0
                    ? Color.Info
                    : Color.Default;
    private string CreditApplicationSourceLaneLabel => _sourceCredits.Count switch
    {
        > 0 => $"{_sourceCredits.Count} source credit candidate(s)",
        _ when SelectedCustomerId is null => "Customer not selected",
        _ => "No open credit notes loaded"
    };
    private string CreditApplicationSourceLaneSummary => _sourceCredits.Count switch
    {
        > 0 => "Posted credit-note open items are available and can legally offset posted invoice truth.",
        _ when SelectedCustomerId is null => "Pick the customer first so the workbench can discover matching credit notes and invoices.",
        _ => "No posted credit notes with open credit balance are currently available for this customer."
    };
    private string CreditApplicationNextStepTitle => _postedResult is not null
        ? "Review posted application"
        : _preparedDraft is not null
            ? "Post the application draft"
            : TryGetSelectedSourceCredit(out _) && TryGetSelectedTargetInvoice(out _) && _appliedAmountTx > 0m
                ? "Prepare the application draft"
                : _sourceCredits.Count > 0 || _targetInvoices.Count > 0
                    ? "Choose credit + invoice + amount"
                    : "Load open items";
    private string CreditApplicationNextStepSummary => _postedResult is not null
        ? "Use posted document review and JE review to confirm continuity, then return to adjacent AR settlement lanes only if more work remains."
        : _preparedDraft is not null
            ? "Posting will formalize the offset between credit-note truth and invoice truth."
            : TryGetSelectedSourceCredit(out _) && TryGetSelectedTargetInvoice(out _) && _appliedAmountTx > 0m
                ? "Preparation turns the selected source/target pair into a governed application document."
                : _sourceCredits.Count > 0 || _targetInvoices.Count > 0
                    ? "The candidates are here; now choose the exact source credit, target invoice, and amount to apply."
                    : "No application can start until this customer has both posted open credits and posted open invoices.";
    private string CreditApplicationRelatedLaneLabel => SelectedCustomerId.HasValue
        ? "Receive payment still available"
        : "Choose customer first";
    private string CreditApplicationRelatedLaneSummary => SelectedCustomerId.HasValue
        ? "If cash settlement is also needed for this customer, return to Receive Payment. Both lanes operate on the same customer-scoped open-item truth."
        : "Receive Payment and Credit Application share the same customer-scoped AR truth, so customer selection is the first gate.";

    protected override async Task OnInitializedAsync()
    {
        await EnsureWriteGateStateAsync();
        try
        {
            _customers = (await LookupService.ListCustomersAsync(ShellSession.ActiveCompanyId, CancellationToken.None)).ToList();
            if (CustomerId.HasValue && _customers.Any(item => item.Id == CustomerId.Value))
            {
                _selectedCustomerIdText = CustomerId.Value.ToString();
            }
            if (_customers.Count == 1)
            {
                _selectedCustomerIdText = _customers[0].Id.ToString();
            }
        }
        catch (Exception ex)
        {
            _errorText = ex.Message;
        }
    }

    private async Task LoadCandidatesAsync()
    {
        _preparedDraft = null;
        _postedResult = null;
        _errorText = null;
        if (!TryParseRequiredGuid(_selectedCustomerIdText, "Customer", out var customerId)) return;

        try
        {
            _isBusy = true;
            var candidates = await Workflow.ListOpenItemCandidatesAsync(ShellSession.ActiveCompanyId, customerId, CancellationToken.None);
            _sourceCredits.Clear();
            _targetInvoices.Clear();
            _selectedSourceOpenItemIdText = null;
            _selectedTargetOpenItemIdText = null;
            _appliedAmountTx = 0m;
            _sourceCredits.AddRange(candidates.Where(static candidate => candidate.SourceType == "credit_note" && candidate.BalanceSide == "credit").Select(static candidate => new RowState(candidate)));
            _targetInvoices.AddRange(candidates.Where(static candidate => candidate.SourceType == "invoice" && candidate.BalanceSide == "debit").Select(static candidate => new RowState(candidate)));
        }
        catch (Exception ex)
        {
            _errorText = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task PrepareDraftAsync()
    {
        if (TryBlockWrites())
        {
            return;
        }

        _errorText = null;
        _preparedDraft = null;
        _postedResult = null;
        if (!TryParseRequiredGuid(_selectedCustomerIdText, "Customer", out var customerId)) return;
        if (!TryParseRequiredGuid(_selectedSourceOpenItemIdText, "Source Credit Open Item", out var sourceOpenItemId) ||
            !TryParseRequiredGuid(_selectedTargetOpenItemIdText, "Target Invoice Open Item", out var targetOpenItemId))
        {
            return;
        }
        if (_appliedAmountTx <= 0m)
        {
            _errorText = "Apply Amount must be greater than zero.";
            return;
        }

        var lines = new[] { new CreditApplicationDraftLine(sourceOpenItemId, targetOpenItemId, _appliedAmountTx) };

        try
        {
            _isBusy = true;
            _preparedDraft = await Workflow.PrepareDraftAsync(
                new CreditApplicationDraftContext(ShellSession.ActiveCompanyId, ShellSession.CurrentUserId, customerId, _applicationDate, null, _memo),
                lines,
                CancellationToken.None);
            Snackbar.Add($"Prepared credit application {_preparedDraft.ApplicationNumber}.", Severity.Success);
        }
        catch (Exception ex)
        {
            _errorText = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task PostDraftAsync()
    {
        if (TryBlockWrites())
        {
            return;
        }

        if (_preparedDraft is null)
        {
            _errorText = "Prepare a draft before posting.";
            return;
        }

        try
        {
            _isBusy = true;
            _errorText = null;
            _postedResult = await PostingClient.PostCreditApplicationAsync(
                ShellSession.ActiveCompanyId,
                ShellSession.CurrentUserId,
                _preparedDraft.DocumentId,
                CancellationToken.None);
            Snackbar.Add($"Posted credit application to journal entry {_postedResult?.JournalEntryDisplayNumber}.", Severity.Success);
        }
        catch (Exception ex)
        {
            _errorText = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void OnApplicationDateChanged(DateTime? value)
    {
        _applicationDatePicker = value;
        _applicationDate = DateOnly.FromDateTime(value ?? DateTime.Today);
    }

    private bool TryParseRequiredGuid(string? text, string label, out Guid value)
    {
        if (Guid.TryParse(text, out value)) return true;
        _errorText = $"{label} must be a valid GUID.";
        return false;
    }

    private bool WritesBlocked => ShellSession.AreWritesBlocked;

    private async Task EnsureWriteGateStateAsync()
    {
        await ShellSession.RefreshAsync(CancellationToken.None);
    }

    private bool TryBlockWrites()
    {
        if (!WritesBlocked)
        {
            return false;
        }

        _errorText = ShellSession.WriteBlockMessage;
        return true;
    }

    private sealed class RowState
    {
        public RowState(CreditApplicationOpenItemCandidate source)
        {
            OpenItemId = source.OpenItemId;
            DisplayNumber = source.DisplayNumber;
            SourceType = source.SourceType;
            SourceId = source.SourceId;
            DocumentCurrencyCode = source.DocumentCurrencyCode;
            OpenAmountTx = source.OpenAmountTx;
            OpenAmountBase = source.OpenAmountBase;
            BalanceSide = source.BalanceSide;
        }

        public Guid OpenItemId { get; }
        public string DisplayNumber { get; }
        public string SourceType { get; }
        public Guid SourceId { get; }
        public string DocumentCurrencyCode { get; }
        public decimal OpenAmountTx { get; }
        public decimal OpenAmountBase { get; }
        public string BalanceSide { get; }
    }

    private bool TryGetSelectedSourceCredit(out RowState row)
    {
        row = _sourceCredits.FirstOrDefault(candidate => candidate.OpenItemId.ToString() == _selectedSourceOpenItemIdText)!;
        return row is not null;
    }

    private bool TryGetSelectedTargetInvoice(out RowState row)
    {
        row = _targetInvoices.FirstOrDefault(candidate => candidate.OpenItemId.ToString() == _selectedTargetOpenItemIdText)!;
        return row is not null;
    }

    private static bool TryBuildDocumentHref(string sourceType, Guid documentId, out string href)
    {
        href = sourceType switch
        {
            "invoice" => $"/documents/invoice/{documentId:D}",
            "credit_note" => $"/documents/credit_note/{documentId:D}",
            "credit_application" => $"/documents/credit_application/{documentId:D}",
            _ => string.Empty
        };

        return !string.IsNullOrWhiteSpace(href);
    }

    private static string DisplayDocumentLabel(string displayNumber, string sourceType) =>
        sourceType switch
        {
            "invoice" => $"{displayNumber} | Invoice",
            "credit_note" => $"{displayNumber} | Credit Note",
            "credit_application" => $"{displayNumber} | Credit Application",
            _ => displayNumber
        };

    private string BuildCreditNoteBrowserHref() =>
        SelectedCustomerId.HasValue
            ? $"/documents/source-browser?sourceType=credit_note&counterpartyRole=customer&counterpartyId={SelectedCustomerId.Value:D}"
            : "/documents/source-browser?sourceType=credit_note&counterpartyRole=customer";

    private string BuildInvoiceBrowserHref() =>
        SelectedCustomerId.HasValue
            ? $"/documents/source-browser?sourceType=invoice&counterpartyRole=customer&counterpartyId={SelectedCustomerId.Value:D}"
            : "/documents/source-browser?sourceType=invoice&counterpartyRole=customer";

    private string BuildReceivePaymentHref() =>
        SelectedCustomerId.HasValue
            ? $"/ar/receive-payment?customerId={SelectedCustomerId.Value:D}"
            : "/ar/receive-payment";

    private string BuildPostedCreditApplicationDetailHref() =>
        _preparedDraft is null
            ? string.Empty
            : $"/documents/credit_application/{_preparedDraft.DocumentId:D}";
}
