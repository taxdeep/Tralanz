<Window x:Class="Aiseworks.ServerConsole.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aiseworks Server Console"
        Width="1120"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterScreen">
    <DockPanel Background="#F7F8FA">
        <Border DockPanel.Dock="Top"
                Background="#FFFFFF"
                BorderBrush="#D6DAE0"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Text="Aiseworks Server Console" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#6B7280"
                               Text="Dedicated administrator surface for service lifecycle, database connectivity, backups, and diagnostics." />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock Foreground="#6B7280"
                               FontSize="12"
                               Text="Runtime target" />
                    <TextBlock x:Name="RuntimeTargetTextBlock"
                               Margin="0,3,0,0"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Text="Docker test stack" />
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="#FFFFFF"
                BorderBrush="#D6DAE0"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterStatusTextBlock"
                           VerticalAlignment="Center"
                           Foreground="#4B5563"
                           Text="Ready" />
                <TextBlock x:Name="LastCheckedTextBlock"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="#6B7280"
                           Text="Last checked: never" />
            </Grid>
        </Border>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.ColumnSpan="2"
                    Background="#FFFFFF"
                    BorderBrush="#D6DAE0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Foreground="#6B7280"
                                   FontSize="12"
                                   Text="Mode" />
                        <TextBlock x:Name="ProfileModeTextBlock"
                                   Margin="0,3,0,0"
                                   FontWeight="SemiBold"
                                   Text="Mode: unknown" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Foreground="#6B7280"
                                   FontSize="12"
                                   Text="Service" />
                        <TextBlock x:Name="ServiceStatusTextBlock"
                                   Margin="0,3,0,0"
                                   FontWeight="SemiBold"
                                   Text="Not checked" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Foreground="#6B7280"
                                   FontSize="12"
                                   Text="Database" />
                        <TextBlock x:Name="PostgresStatusTextBlock"
                                   Margin="0,3,0,0"
                                   FontWeight="SemiBold"
                                   Text="Not checked" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,0,14,0">
                <Border Background="#FFFFFF"
                        BorderBrush="#D6DAE0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="Service Lifecycle" />
                        <TextBlock x:Name="ServiceTargetTextBlock"
                                   Margin="0,4,0,12"
                                   Foreground="#6B7280"
                                   Text="Target: not selected" />
                        <UniformGrid Columns="3">
                            <Button x:Name="StartButton"
                                    Margin="0,0,8,0"
                                    Padding="12,8"
                                    Click="StartButton_Click"
                                    Content="Start" />
                            <Button x:Name="StopButton"
                                    Margin="4,0,4,0"
                                    Padding="12,8"
                                    Click="StopButton_Click"
                                    Content="Stop" />
                            <Button x:Name="RestartButton"
                                    Margin="8,0,0,0"
                                    Padding="12,8"
                                    Click="RestartButton_Click"
                                    Content="Restart" />
                        </UniformGrid>
                        <Button x:Name="CheckButton"
                                Margin="0,12,0,0"
                                Padding="12,8"
                                Click="CheckButton_Click"
                                Content="Check all" />
                    </StackPanel>
                </Border>

                <Border Background="#FFFFFF"
                        BorderBrush="#D6DAE0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Text="Database" />
                            <Button x:Name="EditDatabaseButton"
                                    Grid.Column="1"
                                    Padding="10,4"
                                    Click="EditDatabaseButton_Click"
                                    Content="Edit" />
                        </Grid>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Foreground="#6B7280"
                                       Text="Postgres" />
                            <TextBlock x:Name="PostgresTargetTextBlock"
                                       Grid.Row="0"
                                       Grid.Column="1"
                                       Margin="18,0,0,0"
                                       Text="-" />
                            <TextBlock Grid.Row="1"
                                       Margin="0,8,0,0"
                                       Foreground="#6B7280"
                                       Text="Accounting API" />
                            <TextBlock x:Name="AccountingStatusTextBlock"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       Margin="18,8,0,0"
                                       Text="Not checked" />
                            <TextBlock Grid.Row="2"
                                       Margin="0,8,0,0"
                                       Foreground="#6B7280"
                                       Text="SysAdmin API" />
                            <TextBlock x:Name="SysAdminStatusTextBlock"
                                       Grid.Row="2"
                                       Grid.Column="1"
                                       Margin="18,8,0,0"
                                       Text="Not checked" />
                        </Grid>
                        <Border x:Name="DatabaseEditPanel"
                                Visibility="Collapsed"
                                Margin="0,12,0,0"
                                Padding="12"
                                Background="#F9FAFB"
                                BorderBrush="#D6DAE0"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock Foreground="#6B7280"
                                           FontSize="12"
                                           Text="PostgreSQL connection" />
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Foreground="#6B7280"
                                                   FontSize="12"
                                                   Text="Host" />
                                        <TextBox x:Name="PostgresHostTextBox"
                                                 Margin="0,4,0,0"
                                                 VerticalContentAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Foreground="#6B7280"
                                                   FontSize="12"
                                                   Text="Port" />
                                        <TextBox x:Name="PostgresPortTextBox"
                                                 Margin="0,4,0,0"
                                                 VerticalContentAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Padding="12,6"
                                            Margin="0,0,8,0"
                                            Click="SaveDatabaseButton_Click"
                                            Content="Save" />
                                    <Button Padding="12,6"
                                            Click="CancelDatabaseButton_Click"
                                            Content="Cancel" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <Button x:Name="CheckDatabaseButton"
                                Margin="0,12,0,0"
                                Padding="12,8"
                                Click="CheckDatabaseButton_Click"
                                Content="Check database connection" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Row="1"
                  Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="#FFFFFF"
                        BorderBrush="#D6DAE0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="Backup and Diagnostics" />
                        <TextBlock x:Name="BackupStatusTextBlock"
                                   Margin="0,4,0,12"
                                   Foreground="#6B7280"
                                   Text="Backup: none" />
                        <WrapPanel>
                            <Button x:Name="BackupButton"
                                    Padding="12,8"
                                    Margin="0,0,8,0"
                                    Click="BackupButton_Click"
                                    Content="Backup test DB" />
                            <Button x:Name="OpenBackupFolderButton"
                                    Padding="12,8"
                                    Margin="0,0,8,0"
                                    Click="OpenBackupFolderButton_Click"
                                    Content="Open folder" />
                            <Button x:Name="LogsButton"
                                    Padding="12,8"
                                    Click="LogsButton_Click"
                                    Content="Show logs" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="#111827"
                        BorderBrush="#111827"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <TextBox x:Name="LogTextBox"
                             Background="#111827"
                             Foreground="#E5E7EB"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="12"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" />
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
