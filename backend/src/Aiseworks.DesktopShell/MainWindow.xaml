<Window x:Class="Aiseworks.DesktopShell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Aiseworks"
        Width="1280"
        Height="820"
        MinWidth="960"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <DockPanel Background="#F7F8FA">
        <DockPanel DockPanel.Dock="Top">
            <Menu DockPanel.Dock="Top"
                  Background="#FFFFFF"
                  BorderBrush="#D6DAE0"
                  BorderThickness="0,0,0,1">
                <MenuItem Header="_System">
                    <MenuItem Header="_Hybrid host"
                              InputGestureText="Ctrl+Shift+H"
                              Click="HybridHostMenuItem_Click" />
                    <MenuItem Header="_Status"
                              Click="SystemStatusMenuItem_Click" />
                    <MenuItem Header="_Session"
                              Click="SystemSessionMenuItem_Click" />
                    <MenuItem Header="_Check health"
                              Click="CheckServicesButton_Click" />
                    <Separator />
                    <MenuItem Header="_Bridge test"
                              Click="SystemBridgeTestMenuItem_Click" />
                </MenuItem>
                <MenuItem Header="_Navigate">
                    <MenuItem x:Name="BackMenuItem"
                              Header="_Back"
                              Click="BackButton_Click" />
                    <MenuItem x:Name="ForwardMenuItem"
                              Header="_Forward"
                              Click="ForwardButton_Click" />
                    <MenuItem Header="_Reload"
                              Click="RefreshButton_Click" />
                    <MenuItem Header="_Home"
                              Click="HomeButton_Click" />
                    <Separator />
                    <MenuItem Header="_Business"
                              Click="BusinessButton_Click" />
                    <MenuItem Header="S_ysAdmin"
                              Click="SysAdminButton_Click" />
                </MenuItem>
                <MenuItem Header="S_erver">
                    <MenuItem x:Name="StartServerMenuItem"
                              Header="_Start"
                              Click="StartStackButton_Click" />
                    <MenuItem x:Name="StopServerMenuItem"
                              Header="S_top"
                              Click="StopStackButton_Click" />
                    <MenuItem x:Name="RestartServerMenuItem"
                              Header="_Restart"
                              Click="RestartStackButton_Click" />
                    <Separator />
                    <MenuItem x:Name="ShowLogsMenuItem"
                              Header="_Logs"
                              Click="ShowLogsButton_Click" />
                    <MenuItem x:Name="BackupDatabaseMenuItem"
                              Header="_Backup database"
                              Click="BackupDatabaseButton_Click" />
                    <MenuItem Header="Backup _folder"
                              Click="OpenBackupFolderButton_Click" />
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem x:Name="ShowBrowserControlsMenuItem"
                              Header="Show _browser controls"
                              IsCheckable="True"
                              Click="ShowBrowserControlsMenuItem_Click" />
                    <MenuItem Header="_Open in browser"
                              Click="OpenBusinessButton_Click" />
                </MenuItem>
            </Menu>

            <Border x:Name="BrowserToolbar"
                    Visibility="Collapsed"
                    BorderBrush="#D6DAE0"
                    BorderThickness="0,0,0,1"
                    Background="#FFFFFF"
                    Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal">
                        <Button x:Name="BackButton"
                                Width="54"
                                Margin="0,0,6,0"
                                Click="BackButton_Click"
                                ToolTip="Back"
                                Content="Back" />
                        <Button x:Name="ForwardButton"
                                Width="54"
                                Margin="0,0,6,0"
                                Click="ForwardButton_Click"
                                ToolTip="Forward"
                                Content="Next" />
                        <Button Width="58"
                                Margin="0,0,6,0"
                                Click="RefreshButton_Click"
                                ToolTip="Refresh"
                                Content="Reload" />
                        <Button Width="54"
                                Margin="0,0,14,0"
                                Click="HomeButton_Click"
                                ToolTip="Home"
                                Content="Home" />
                        <Button x:Name="BusinessButton"
                                Width="82"
                                Margin="0,0,6,0"
                                Click="BusinessButton_Click"
                                Content="Business" />
                        <Button x:Name="SysAdminButton"
                                Width="82"
                                Click="SysAdminButton_Click"
                                Content="SysAdmin" />
                    </StackPanel>

                    <DockPanel Grid.Column="1"
                               Margin="14,0">
                        <Button DockPanel.Dock="Right"
                                Width="42"
                                Margin="6,0,0,0"
                                Click="GoButton_Click"
                                Content="Go" />
                        <TextBox x:Name="AddressTextBox"
                                 MinWidth="260"
                                 VerticalContentAlignment="Center"
                                 KeyDown="AddressTextBox_KeyDown" />
                    </DockPanel>

                    <TextBlock x:Name="StatusTextBlock"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Foreground="#4B5563"
                               Text="Starting" />
                    <Button x:Name="CheckServicesButton"
                            Grid.Column="3"
                            Width="98"
                            Click="CheckServicesButton_Click"
                            Content="Check server" />
                </Grid>
            </Border>
        </DockPanel>

        <Border DockPanel.Dock="Bottom"
                BorderBrush="#D6DAE0"
                BorderThickness="0,1,0,0"
                Background="#FFFFFF"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="#374151"
                               FontWeight="SemiBold"
                               Text="Health" />
                    <TextBlock x:Name="HealthSummaryTextBlock"
                               Margin="8,0,0,0"
                               FontWeight="SemiBold"
                               Foreground="#6B7280"
                               Text="Unknown" />
                    <TextBlock Margin="18,0,0,0"
                               Foreground="#374151"
                               FontWeight="SemiBold"
                               Text="Bridge" />
                    <TextBlock x:Name="BridgeStatusTextBlock"
                               Margin="8,0,0,0"
                               Foreground="#6B7280"
                               Text="Waiting" />
                </StackPanel>
                <TextBlock x:Name="WebStatusTextBlock"
                           Grid.Column="1"
                           Margin="18,0,0,0"
                           HorizontalAlignment="Right"
                           Foreground="#6B7280"
                           TextTrimming="CharacterEllipsis"
                           Text="Ready" />

                <StackPanel Visibility="Collapsed">
                    <ComboBox x:Name="ServerProfileComboBox"
                              DisplayMemberPath="Name"
                              SelectionChanged="ServerProfileComboBox_SelectionChanged" />
                    <TextBlock x:Name="ProfileModeTextBlock"
                               Text="Mode: unknown" />
                    <TextBlock x:Name="ServiceStatusTextBlock"
                               Text="N/A" />
                    <TextBlock x:Name="PostgresHealthTextBlock"
                               Text="Unknown" />
                    <TextBlock x:Name="AccountingApiHealthTextBlock"
                               Text="Unknown" />
                    <TextBlock x:Name="BusinessHealthTextBlock"
                               Text="Unknown" />
                    <TextBlock x:Name="SysAdminApiHealthTextBlock"
                               Text="Unknown" />
                    <TextBlock x:Name="SysAdminHealthTextBlock"
                               Text="Unknown" />
                    <TextBlock x:Name="LastBackupTextBlock"
                               Text="Backup: none" />
                    <TextBlock x:Name="DockerStatusTextBlock"
                               Text="Server: not checked" />

                        <Button x:Name="DiagnosticsButton"
                                Click="DiagnosticsButton_Click"
                                Content="Report" />
                        <Button x:Name="ConnectionDetailsButton"
                                Click="ConnectionDetailsButton_Click"
                                Content="Connection" />
                        <Button x:Name="ShowLogsButton"
                                Click="ShowLogsButton_Click"
                                Content="Logs" />
                        <Button x:Name="OpenBusinessButton"
                                Click="OpenBusinessButton_Click"
                                Content="Browser" />
                        <Button x:Name="StartStackButton"
                                Click="StartStackButton_Click"
                                Content="Start" />
                        <Button x:Name="StopStackButton"
                                Click="StopStackButton_Click"
                                Content="Stop" />
                        <Button x:Name="RestartStackButton"
                                Click="RestartStackButton_Click"
                                Content="Restart" />
                        <Button x:Name="BackupDatabaseButton"
                                Click="BackupDatabaseButton_Click"
                                Content="Test DB" />
                        <Button x:Name="OpenBackupFolderButton"
                                Click="OpenBackupFolderButton_Click"
                                Content="Folder" />
                </StackPanel>
            </Grid>
        </Border>

        <wv2:WebView2 x:Name="Browser" />
    </DockPanel>
</Window>
