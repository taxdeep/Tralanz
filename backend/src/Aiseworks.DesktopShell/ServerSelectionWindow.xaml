<Window x:Class="Aiseworks.DesktopShell.ServerSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect to Aiseworks Server"
        Width="430"
        Height="245"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <DockPanel Background="#F7F9FC">
        <Border DockPanel.Dock="Top"
                Background="#FFFFFF"
                BorderBrush="#D6DAE0"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="42"
                        Height="42"
                        CornerRadius="8"
                        Background="#E8F0FE"
                        BorderBrush="#B8C7E6"
                        BorderThickness="1">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="23"
                               Text="▣" />
                </Border>
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#0F3E8A"
                               Text="Aiseworks" />
                    <TextBlock Margin="0,-2,0,0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#0F3E8A"
                               Text="Server Connection" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="10,12,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="78" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="Computer:" />
            <ComboBox x:Name="ServerComboBox"
                      Grid.Row="0"
                      Grid.Column="1"
                      Height="25"
                      IsEditable="True"
                      IsTextSearchEnabled="False"
                      StaysOpenOnEdit="True"
                      KeyDown="ServerComboBox_KeyDown" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Margin="0,10,0,0"
                       VerticalAlignment="Top"
                       Text="Status:" />
            <TextBlock x:Name="StatusTextBlock"
                       Grid.Row="1"
                       Grid.Column="1"
                       Margin="0,10,0,0"
                       Foreground="#4B5563"
                       TextWrapping="Wrap"
                       Text="Choose a server or type an IP / host. Use host:port for a custom Business UI port." />

            <TextBlock x:Name="ErrorTextBlock"
                       Grid.Row="2"
                       Grid.Column="1"
                       Margin="0,8,0,0"
                       Foreground="#B91C1C"
                       TextWrapping="Wrap" />

            <StackPanel Grid.Row="3"
                        Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="82"
                        Height="25"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="ConnectButton_Click"
                        Content="Connect" />
                <Button Width="72"
                        Height="25"
                        IsCancel="True"
                        Content="Cancel" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
