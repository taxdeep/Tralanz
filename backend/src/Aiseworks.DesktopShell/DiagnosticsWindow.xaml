<Window x:Class="Aiseworks.DesktopShell.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aiseworks Diagnostics"
        Width="980"
        Height="640"
        MinWidth="720"
        MinHeight="420"
        WindowStartupLocation="CenterOwner">
    <DockPanel Background="#F7F8FA">
        <Border DockPanel.Dock="Top"
                BorderBrush="#D6DAE0"
                BorderThickness="0,0,0,1"
                Background="#FFFFFF"
                Padding="12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <Button Width="92"
                            Margin="0,0,8,0"
                            Click="CopyButton_Click"
                            Content="Copy" />
                    <Button Width="92"
                            Margin="0,0,8,0"
                            Click="SaveButton_Click"
                            Content="Save" />
                    <Button Width="92"
                            Click="CloseButton_Click"
                            Content="Close" />
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="HeadingTextBlock"
                               Text="Aiseworks local stack diagnostics"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,4,0,0"
                               Foreground="#6B7280"
                               Text="Ready" />
                </StackPanel>
            </DockPanel>
        </Border>

        <TextBox x:Name="DiagnosticsTextBox"
                 Margin="12"
                 Padding="10"
                 FontFamily="Consolas"
                 FontSize="12"
                 IsReadOnly="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto" />
    </DockPanel>
</Window>
