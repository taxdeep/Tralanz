<Window x:Class="Aiseworks.DesktopShell.SystemStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Status"
        Width="760"
        Height="520"
        MinWidth="640"
        MinHeight="420"
        WindowStartupLocation="CenterOwner">
    <DockPanel Background="#F7F8FA">
        <Border DockPanel.Dock="Top"
                Background="#FFFFFF"
                BorderBrush="#D6DAE0"
                BorderThickness="0,0,0,1"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Text="System Status" />
                    <TextBlock x:Name="LastCheckedTextBlock"
                               Margin="0,4,0,0"
                               Foreground="#6B7280"
                               Text="Last checked: Never" />
                </StackPanel>
                <Border Grid.Column="1"
                        Padding="10,4"
                        CornerRadius="12"
                        Background="#ECFDF3"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="HealthSummaryTextBlock"
                               FontWeight="SemiBold"
                               Foreground="#057A55"
                               Text="Online" />
                </Border>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="#FFFFFF"
                BorderBrush="#D6DAE0"
                BorderThickness="0,1,0,0"
                Padding="12">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Width="92"
                        Padding="10,6"
                        Click="CloseButton_Click"
                        Content="Close" />
            </DockPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <Border Background="#FFFFFF"
                        BorderBrush="#D6DAE0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Text="Profile" />
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Foreground="#6B7280"
                                       Text="Name" />
                            <TextBlock x:Name="ProfileNameTextBlock"
                                       Grid.Row="0"
                                       Grid.Column="1"
                                       FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1"
                                       Margin="0,8,0,0"
                                       Foreground="#6B7280"
                                       Text="Mode" />
                            <TextBlock x:Name="ModeTextBlock"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       Margin="0,8,0,0"
                                       FontWeight="SemiBold" />
                            <TextBlock Grid.Row="2"
                                       Margin="0,8,0,0"
                                       Foreground="#6B7280"
                                       Text="Description" />
                            <TextBlock x:Name="ProfileDescriptionTextBlock"
                                       Grid.Row="2"
                                       Grid.Column="1"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#FFFFFF"
                        BorderBrush="#D6DAE0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14">
                    <StackPanel>
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Text="Health Targets" />
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Foreground="#6B7280" Text="Service" />
                            <TextBlock x:Name="ServiceStatusTextBlock" Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" />
                            <TextBlock x:Name="ServiceTargetTextBlock" Grid.Row="0" Grid.Column="2" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="1" Margin="0,8,0,0" Foreground="#6B7280" Text="DB" />
                            <TextBlock x:Name="PostgresStatusTextBlock" Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" FontWeight="SemiBold" />
                            <TextBlock x:Name="PostgresTargetTextBlock" Grid.Row="1" Grid.Column="2" Margin="0,8,0,0" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2" Margin="0,8,0,0" Foreground="#6B7280" Text="Accounting" />
                            <TextBlock x:Name="AccountingStatusTextBlock" Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" FontWeight="SemiBold" />
                            <TextBlock x:Name="AccountingTargetTextBlock" Grid.Row="2" Grid.Column="2" Margin="0,8,0,0" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="3" Margin="0,8,0,0" Foreground="#6B7280" Text="Business" />
                            <TextBlock x:Name="BusinessStatusTextBlock" Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" FontWeight="SemiBold" />
                            <TextBlock x:Name="BusinessTargetTextBlock" Grid.Row="3" Grid.Column="2" Margin="0,8,0,0" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="4" Margin="0,8,0,0" Foreground="#6B7280" Text="SysAdmin API" />
                            <TextBlock x:Name="SysAdminApiStatusTextBlock" Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" FontWeight="SemiBold" />
                            <TextBlock x:Name="SysAdminApiTargetTextBlock" Grid.Row="4" Grid.Column="2" Margin="0,8,0,0" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="5" Margin="0,8,0,0" Foreground="#6B7280" Text="SysAdmin UI" />
                            <TextBlock x:Name="SysAdminStatusTextBlock" Grid.Row="5" Grid.Column="1" Margin="0,8,0,0" FontWeight="SemiBold" />
                            <TextBlock x:Name="SysAdminTargetTextBlock" Grid.Row="5" Grid.Column="2" Margin="0,8,0,0" TextWrapping="Wrap" />
                        </Grid>
                        <TextBlock x:Name="ServiceDetailTextBlock"
                                   Margin="0,14,0,0"
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
