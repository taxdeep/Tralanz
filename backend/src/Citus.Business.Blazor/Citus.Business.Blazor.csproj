<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Citus.Ui.Shared\Citus.Ui.Shared.csproj" />
    <ProjectReference Include="..\Infrastructure\PostgreSQL\Infrastructure.PostgreSQL.csproj" />
    <ProjectReference Include="..\Modules\UnitySearch\Blazor\Citus.Modules.UnitySearch.Blazor.csproj" />
  </ItemGroup>

  <!-- Spike: Radzen.Blazor for high-volume report grids (Trial Balance first).
       Coexists with AntDesign — different namespaces, no global style fights
       expected. If the spike pans out, we can extend to other report tables
       and charts. Pinned floor-version; dotnet restore picks the latest
       compatible release in the 5.x line for net10.0. -->
  <ItemGroup>
    <PackageReference Include="Radzen.Blazor" Version="[5.0.0,7.0.0)" />
  </ItemGroup>

  <Target Name="BuildCss" BeforeTargets="BeforeBuild" Condition="'$(SkipCssBuild)' != 'true'">
    <Exec Command="pnpm --silent run css:build:business"
          WorkingDirectory="$(MSBuildProjectDirectory)\..\..\frontend"
          IgnoreExitCode="false" />
  </Target>

</Project>
