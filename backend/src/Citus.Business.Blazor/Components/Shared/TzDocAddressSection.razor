@*
    TzDocAddressSection — Bill-to / Ship-to flat textarea-style address boxes
    (no card) for the Tralanz document canvas (tz-doc-*). Edit fires
    OnEditAddress; the AddressEditor drawer + working-copy state live on the
    parent page. Lifted from the invoice editor — already document-agnostic.
*@

<div class="flex flex-col gap-2">
    <div class="tz-doc-address-head">
        <span class="tz-doc-field__label">Bill to / Ship to</span>
        <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small"
                     LeadingIcon="IconName.Pencil" OnClick="OnEditAddress">Edit</CitusButton>
    </div>
    <div class="tz-doc-field">
        <label class="tz-doc-field__label">Bill to</label>
        <div class="tz-doc-address-box @(Billing.IsEmpty ? "tz-doc-address-box--empty" : null)">
            <AddressDisplay Address="Billing" EmptyHint="No billing address set." />
        </div>
    </div>
    <div class="tz-doc-field">
        <label class="tz-doc-field__label">Ship to</label>
        @if (ShippingMode == ShippingMode.SameAsBilling)
        {
            <div class="tz-doc-address-box tz-doc-address-box--empty">Same as billing</div>
        }
        else
        {
            <div class="tz-doc-address-box @(Shipping.IsEmpty ? "tz-doc-address-box--empty" : null)">
                <AddressDisplay Address="Shipping" EmptyHint="No shipping address set." />
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public AddressDraft Billing { get; set; } = AddressDraft.Empty;
    [Parameter] public AddressDraft Shipping { get; set; } = AddressDraft.Empty;
    [Parameter] public ShippingMode ShippingMode { get; set; } = ShippingMode.SameAsBilling;
    [Parameter] public EventCallback OnEditAddress { get; set; }
}
