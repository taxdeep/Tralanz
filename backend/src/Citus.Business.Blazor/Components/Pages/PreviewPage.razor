@*
    /preview — P0 smoke page. Demonstrates that AntDesign + Tailwind v4 +
    Tabler sprite + ThemeService all work together. Will be removed (or
    locked behind dev-only) once we have real pages built on the new
    primitives. Not in any nav menu.
*@

@page "/preview"
@inject IThemeService ThemeService
@implements IDisposable

<PageTitle>Preview · Tralanz Books</PageTitle>

<section class="flex flex-col gap-6 p-6">
    <header class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-semibold text-fg">Citus design preview</h1>
            <p class="text-sm text-fg-muted">P0 smoke surface — atoms, icons, tokens, theme.</p>
        </div>
        <div class="flex items-center gap-2">
            <CitusButton Variant="CitusButtonVariant.Default" Size="CitusButtonSize.Small"
                         LeadingIcon="IconName.Sun" OnClick="() => SetTheme(ThemeMode.Light)">
                Light
            </CitusButton>
            <CitusButton Variant="CitusButtonVariant.Default" Size="CitusButtonSize.Small"
                         LeadingIcon="IconName.Moon" OnClick="() => SetTheme(ThemeMode.Dark)">
                Dark
            </CitusButton>
            <CitusButton Variant="CitusButtonVariant.Ghost" Size="CitusButtonSize.Small"
                         OnClick="() => SetTheme(ThemeMode.System)">
                System
            </CitusButton>
        </div>
    </header>

    <article class="rounded-lg border border-border bg-bg-elevated p-5 shadow-sm">
        <h2 class="mb-3 text-lg font-semibold text-fg">Buttons</h2>
        <div class="flex flex-wrap gap-3">
            <CitusButton Variant="CitusButtonVariant.Primary" LeadingIcon="IconName.Plus">Primary</CitusButton>
            <CitusButton Variant="CitusButtonVariant.Default" LeadingIcon="IconName.Pencil">Default</CitusButton>
            <CitusButton Variant="CitusButtonVariant.Ghost" LeadingIcon="IconName.Eye">Ghost</CitusButton>
            <CitusButton Variant="CitusButtonVariant.Link">Link only</CitusButton>
            <CitusButton Variant="CitusButtonVariant.Primary" Danger="true" LeadingIcon="IconName.Trash">Delete</CitusButton>
        </div>
    </article>

    <article class="rounded-lg border border-border bg-bg-elevated p-5 shadow-sm">
        <h2 class="mb-3 text-lg font-semibold text-fg">Inputs</h2>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <CitusInput TValue="string" @bind-Value="_search"
                        Placeholder="Search invoices…"
                        LeadingIcon="IconName.Search" />
            <CitusInput TValue="string" @bind-Value="_email"
                        Placeholder="email@citus.local"
                        HelperText="Tabular numbers + Inter render here." />
        </div>
    </article>

    <article class="rounded-lg border border-border bg-bg-elevated p-5 shadow-sm">
        <h2 class="mb-3 text-lg font-semibold text-fg">Empty state</h2>
        <CitusEmpty Icon="IconName.Receipt"
                    Title="还没有凭证"
                    Description="进入凭证草稿后这里会按时间顺序显示最近 50 条。" />
    </article>

    <article class="rounded-lg border border-border bg-bg-elevated p-5 shadow-sm">
        <h2 class="mb-3 text-lg font-semibold text-fg">Token sample</h2>
        <div class="flex flex-wrap gap-3">
            @foreach (var swatch in Swatches)
            {
                <div class="flex flex-col items-start gap-1">
                    <div class="h-12 w-24 rounded-md border border-border" style="@($"background: var({swatch.Token});")"></div>
                    <code class="text-xs text-fg-muted">@swatch.Token</code>
                </div>
            }
        </div>
        <p class="mt-3 text-xs text-fg-subtle">Active mode: @(ThemeService.IsDark ? "Dark" : "Light") (preference: @ThemeService.Mode)</p>
    </article>
</section>

@code {
    private string? _search;
    private string? _email;

    private static readonly (string Token, string Label)[] Swatches =
    {
        ("--citus-color-primary", "Primary"),
        ("--citus-color-success", "Success"),
        ("--citus-color-warning", "Warning"),
        ("--citus-color-danger", "Danger"),
        ("--citus-color-info", "Info"),
        ("--citus-color-bg-elevated", "Surface")
    };

    protected override void OnInitialized()
    {
        ThemeService.ThemeChanged += HandleThemeChanged;
    }

    private async Task SetTheme(ThemeMode mode)
    {
        await ThemeService.SetModeAsync(mode);
    }

    private void HandleThemeChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.ThemeChanged -= HandleThemeChanged;
    }
}
