@page "/error"
@using System.Diagnostics

<PageTitle>Error | Citus Business</PageTitle>

<CitusAlert Severity="CitusAlertSeverity.Error"
                 ShowIcon="true"
                 Message="The business shell encountered an unhandled error."
                 Class="mb-6" />

@if (ShowRequestId)
{
    <p class="text-sm mb-4">
        Request ID: <span class="citus-inline-code">@RequestId</span>
    </p>
}

<CitusEmptyState
    Icon="IconName.AlertTriangle"
    Title="Runtime error"
    Message="Switch to Development locally for diagnostic detail. Production deployments should keep the business surface tight and controlled."
    ActionLabel="Return to dashboard"
    ActionHref="dashboard" />

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }

    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized()
    {
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
    }
}
