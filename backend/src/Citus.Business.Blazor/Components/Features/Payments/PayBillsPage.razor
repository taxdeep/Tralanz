@page "/pay-bills"

@inject BusinessShellState ShellState
@inject BusinessWriteFlowClient WriteFlow
@inject NavigationManager NavigationManager
@inject AntDesign.IMessageService Message

<PageTitle>Pay Bills | Citus Business</PageTitle>

<CitusPageHeader Model="_header" />

@if (ShellState.AreWritesBlocked)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" ShowIcon="true" Message="@ShellState.WriteBlockMessage" Class="mb-4" />
}

@if (!string.IsNullOrWhiteSpace(_validation))
{
    <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_validation" ShowIcon="true" Class="mb-4" />
}

@if (_lastResult is not null)
{
    <CitusAlert Severity="CitusAlertSeverity.Info" ShowIcon="true" Class="mb-4">
        <MessageTemplate>
            <strong>@_lastResult.Operation</strong>
            <div class="text-fg-muted text-sm mt-1">@_lastResult.Message</div>
        </MessageTemplate>
    </CitusAlert>
}

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <div class="lg:col-span-8 flex flex-col gap-6">
        <section class="citus-panel">
            <h2 class="citus-panel__title">Payment header</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="text-sm font-medium block mb-1">Date</label>
                    <RadzenDatePicker TValue="DateTime?" @bind-Value="_date" Style="width: 100%;" />
                </div>
                <div>
                    <label class="text-sm font-medium block mb-1">Currency</label>
                    <CitusInput TValue="string" @bind-Value="_currency" Placeholder="USD" />
                </div>
                <div>
                    <label class="text-sm font-medium block mb-1">Vendor (id)</label>
                    <CitusInput TValue="string" @bind-Value="_vendorIdInput" Placeholder="@("00000000-0000-0000-0000-000000000000")" />
                </div>
                <div>
                    <label class="text-sm font-medium block mb-1">Amount paid</label>
                    <RadzenNumeric TValue="decimal" @bind-Value="_amount" Min="0" Style="width: 100%;" />
                </div>
                <div class="md:col-span-2">
                    <label class="text-sm font-medium block mb-1">Memo</label>
                    <CitusInput TValue="string" @bind-Value="_memo" Placeholder="Reference / cheque number / wire memo" />
                </div>
            </div>
        </section>

        <section class="citus-panel">
            <header class="citus-panel__header">
                <h2 class="citus-panel__title">Apply to open bills</h2>
                <CitusButton LeadingIcon="IconName.Plus" Size="CitusButtonSize.Small" OnClick="AddApplication">Add application</CitusButton>
            </header>

            <p class="text-fg-muted text-sm mb-3">
                Each row applies part of the payment against a specific A/P open item.
            </p>

            <table class="citus-data-table">
                <thead>
                    <tr>
                        <th>Bill</th>
                        <th style="width: 14rem">Open item id</th>
                        <th class="text-right" style="width: 10rem">Applied</th>
                        <th style="width: 3rem"></th>
                    </tr>
                </thead>
                <tbody>
                    @for (var index = 0; index < _applications.Count; index++)
                    {
                        var i = index;
                        var app = _applications[i];
                        <tr>
                            <td><CitusInput TValue="string" Value="@app.DocumentDisplayNumber" ValueChanged="@(v => Update(i, a => a with { DocumentDisplayNumber = v ?? string.Empty }))" Size="CitusButtonSize.Small" Placeholder="BILL-000123" /></td>
                            <td><CitusInput TValue="string" Value="@(app.OpenItemId == Guid.Empty ? string.Empty : app.OpenItemId.ToString("D"))" ValueChanged="@(v => Update(i, a => a with { OpenItemId = ParseGuid(v) }))" Size="CitusButtonSize.Small" Placeholder="@("uuid")" /></td>
                            <td><RadzenNumeric TValue="decimal" Value="@app.AppliedAmount" ValueChanged="@(v => Update(i, a => a with { AppliedAmount = v }))" Min="0" Style="width: 100%;" /></td>
                            <td>
                                <button type="button" class="citus-icon-button" title="Remove" @onclick="() => RemoveApplication(i)">
                                    <CitusIcon Name="IconName.Trash" Size="IconSize.Inline" />
                                </button>
                            </td>
                        </tr>
                    }
                    <tr class="citus-data-table__total">
                        <td colspan="2" class="text-right font-medium">Applied total</td>
                        <td class="text-right font-semibold">@FormatAmount(_appliedTotal)</td>
                        <td></td>
                    </tr>
                </tbody>
            </table>

            @if (_amount > 0 && _appliedTotal != _amount)
            {
                <p class="text-warning text-sm mt-3">
                    Difference: <span class="citus-inline-code">@FormatAmount(_amount - _appliedTotal)</span>. Posting requires applied total to match payment amount.
                </p>
            }
        </section>
    </div>

    <div class="lg:col-span-4 flex flex-col gap-6">
        <section class="citus-panel">
            <h2 class="citus-panel__title">Summary</h2>
            <table class="citus-keyvalue">
                <tbody>
                    <tr><th>Vendor</th><td>@(_vendorIdInput.Length > 8 ? _vendorIdInput[..8] + "..." : "(not set)")</td></tr>
                    <tr><th>Amount</th><td>@FormatAmount(_amount) @_currency.ToUpperInvariant()</td></tr>
                    <tr><th>Applied</th><td>@FormatAmount(_appliedTotal)</td></tr>
                    <tr><th>Remaining</th><td>@FormatAmount(_amount - _appliedTotal)</td></tr>
                </tbody>
            </table>
        </section>

        <section class="citus-panel">
            <h2 class="citus-panel__title">Post payment</h2>
            <p class="text-fg-muted text-sm mb-3">
                Posting closes AP open items proportional to applied amounts. Unapplied cash becomes a vendor prepayment.
            </p>
            <CitusButton Variant="CitusButtonVariant.Primary" Block="true"
                         Disabled="@(_amount <= 0 || _applications.Count == 0 || ShellState.AreWritesBlocked || _isSubmitting)"
                         OnClick="PostAsync">
                @(_isSubmitting ? "Posting..." : "Post pay bill")
            </CitusButton>
        </section>
    </div>
</div>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Expense & Bills",
        Title = "Pay bills",
        Subtitle = "Apply outgoing cash to one or more open bills. Backend tracks remaining balances and reservation."
    };

    private DateTime? _date = DateTime.Today;
    private string _vendorIdInput = string.Empty;
    private string _currency = string.Empty;
    private decimal _amount;
    private string _memo = string.Empty;
    private readonly List<SettlementApplicationDraft> _applications = new() { new SettlementApplicationDraft() };
    private bool _isSubmitting;
    private string? _validation;
    private WriteFlowResult? _lastResult;

    private decimal _appliedTotal => _applications.Sum(a => a.AppliedAmount);

    protected override void OnInitialized() => _currency = ShellState.ActiveCompany.BaseCurrencyCode;

    private void AddApplication() => _applications.Add(new SettlementApplicationDraft());
    private void RemoveApplication(int i) { if (i >= 0 && i < _applications.Count) _applications.RemoveAt(i); }
    private void Update(int i, Func<SettlementApplicationDraft, SettlementApplicationDraft> mutate) { if (i >= 0 && i < _applications.Count) _applications[i] = mutate(_applications[i]); }

    private static Guid ParseGuid(string? s) => Guid.TryParse(s, out var g) ? g : Guid.Empty;

    private async Task PostAsync()
    {
        _validation = null;
        _lastResult = null;

        if (_amount <= 0) { _validation = "Payment amount must be greater than zero."; return; }
        if (_applications.Count == 0) { _validation = "Apply the payment to at least one open bill."; return; }
        if (_appliedTotal != _amount) { _validation = "Applied total must equal the payment amount."; return; }
        if (_applications.Any(a => a.OpenItemId == Guid.Empty)) { _validation = "Every application row needs an open-item id."; return; }

        Guid? vendorId = null;
        if (Guid.TryParse(_vendorIdInput, out var parsed)) vendorId = parsed;

        _isSubmitting = true;
        try
        {
            var draft = new PayBillDraft
            {
                Date = DateOnly.FromDateTime((_date ?? DateTime.Today).Date),
                VendorId = vendorId,
                Amount = _amount,
                TransactionCurrencyCode = _currency.Trim().ToUpperInvariant(),
                Memo = _memo.Trim(),
                Applications = _applications.ToArray()
            };
            _lastResult = await WriteFlow.PostPayBillAsync(draft);
            if (_lastResult.Succeeded) { await Message.SuccessAsync("Pay bill posted."); NavigationManager.NavigateTo("dashboard"); }
            else { await Message.InfoAsync(_lastResult.Message); }
        }
        finally { _isSubmitting = false; }
    }

    private static string FormatAmount(decimal amount) => amount.ToString("N2");
}
