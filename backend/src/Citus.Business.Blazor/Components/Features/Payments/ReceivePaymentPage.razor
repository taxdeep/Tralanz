@page "/receive-payment"

@using Citus.Modules.UnitySearch.Blazor
@using Citus.Modules.UnitySearch.Domain.Shared

@inject BusinessShellState ShellState
@inject BusinessWriteFlowClient WriteFlow
@inject AccountClient AccountClient
@inject CustomerClient CustomerClient
@inject OpenReceivablesClient OpenReceivablesClient
@inject NavigationManager NavigationManager
@inject CitusToastService Message

<PageTitle>Receive Payment | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header" />

@if (ShellState.AreWritesBlocked)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" ShowIcon="true" Message="@ShellState.WriteBlockMessage" Class="mb-4" />
}

@if (!string.IsNullOrWhiteSpace(_validation))
{
    <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_validation" ShowIcon="true" Class="mb-4" />
}

@if (_lastResult is not null)
{
    <CitusAlert Severity="@(_lastResult.Succeeded ? CitusAlertSeverity.Success : CitusAlertSeverity.Info)"
                ShowIcon="true"
                Class="mb-4">
        <MessageTemplate>
            <strong>@_lastResult.Operation</strong>
            <div class="text-fg-muted text-sm mt-1">@_lastResult.Message</div>
        </MessageTemplate>
    </CitusAlert>
}

<div class="flex flex-col gap-6">
    <AiseFormSection Title="Customer & date">
        <AiseFormGrid Columns="3">
            <div>
                <label class="citus-form-field__label">Customer *</label>
                <CustomerPicker CompanyId="@ShellState.ActiveCompany.Id"
                                   UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                   Placeholder="Search customers…"
                                   Take="8"
                                   SourceRoute="/receive-payment"
                                   SelectedId="@(_customerId == Guid.Empty ? null : _customerId)"
                                   SelectedDisplayText="@_customerDisplay"
                                   OnCustomerSelected="OnCustomerSelected"
                                   OnCleared="OnCustomerCleared" />
            </div>
            <div>
                <label class="citus-form-field__label">Payment date</label>
                <input type="date"
                       class="citus-form-field__input"
                       value="@(_date?.ToString("yyyy-MM-dd"))"
                       @onchange="OnDateChanged" />
            </div>
            <div>
                <label class="citus-form-field__label">Currency</label>
                <input type="text"
                       class="citus-form-field__input"
                       value="@_currency"
                       placeholder="USD"
                       @oninput="@(e => _currency = e.Value?.ToString() ?? string.Empty)"
                       disabled="@(_isCurrencyLocked || !ShellState.ActiveCompany.MultiCurrencyEnabled)" />
                @if (_isCurrencyLocked)
                {
                    @* Per the spec: each customer is single-currency. When the
                       operator picks a customer, the form locks Currency to
                       that customer's default — a customer who needs both USD
                       and CAD lives as two separate customer records (e.g.
                       "Acme — USD" and "Acme — CAD"). Keeps cash math, FX,
                       and AR balances unambiguous downstream. *@
                    <p class="text-fg-subtle text-xs mt-1">
                        Locked to <strong>@_currency</strong> — this customer's default currency.
                    </p>
                }
                else if (!ShellState.ActiveCompany.MultiCurrencyEnabled)
                {
                    <p class="text-fg-subtle text-xs mt-1">
                        Multi-currency is off — enable in Settings to choose another currency.
                    </p>
                }
            </div>
        </AiseFormGrid>
    </AiseFormSection>

    <AiseFormSection Title="Deposit">
        <AiseFormGrid Columns="3">
            <div>
                <label class="citus-form-field__label">Deposit to (Bank) *</label>
                <select class="citus-form-field__input"
                        value="@_bankAccountId"
                        @onchange="OnBankAccountChanged">
                    <option value="">— Select —</option>
                    @foreach (var account in _bankAccounts)
                    {
                        <option value="@account.Id">@account.Code @account.Name</option>
                    }
                </select>
            </div>
            <div>
                <label class="citus-form-field__label">Total to Bank *</label>
                <input type="text"
                       inputmode="decimal"
                       class="citus-form-field__input"
                       value="@FormatDecimalForInput(_totalToBank)"
                       @oninput="OnTotalToBankInput" />
                <p class="text-fg-subtle text-xs mt-1">
                    @* Auto-calculated from ticked invoice balances when blank;
                       once you type a number, the system switches to cash-driven
                       mode and allocates that total to the invoices you tick. *@
                    @(_isCashDriven
                        ? "Cash-driven: clear this field to switch back to selection-driven."
                        : "Selection-driven: tick invoices below and this fills automatically.")
                </p>
            </div>
            <div>
                <label class="citus-form-field__label">Extra → New Deposit</label>
                <input type="text"
                       readonly
                       class="citus-form-field__input"
                       value="@FormatAmount(_extraNewDeposit)" />
                <p class="text-fg-subtle text-xs mt-1">
                    Overpayment parked as a future credit for this customer.
                </p>
            </div>
            <div class="md:col-span-3">
                <label class="citus-form-field__label">Memo</label>
                <input type="text"
                       class="citus-form-field__input"
                       placeholder="Optional reference note"
                       value="@_memo"
                       @oninput="@(e => _memo = e.Value?.ToString() ?? string.Empty)" />
            </div>
        </AiseFormGrid>
    </AiseFormSection>

    <section class="citus-panel">
        <header class="citus-panel__header">
            <h2 class="citus-panel__title">Apply to invoices</h2>
            <span class="text-fg-muted text-sm">
                Tick rows to apply payment. Tick order = priority — the first invoice
                you tick gets cash first, the next gets whatever's left, capped at each
                invoice's balance.
            </span>
        </header>

        @if (_customerId == Guid.Empty)
        {
            <p class="text-fg-muted text-sm">Pick a customer first to load their open invoices.</p>
        }
        else if (_isLoadingItems)
        {
            <CitusLoadingBar />
        }
        else if (_items.Count == 0)
        {
            <p class="text-fg-muted text-sm">No open invoices for this customer.</p>
        }
        else
        {
            <table class="citus-data-table">
                <thead>
                    <tr>
                        <th style="width: 2.5rem"></th>
                        <th>Document No.</th>
                        <th style="width: 7rem">Type</th>
                        <th style="width: 7rem">Date</th>
                        <th style="width: 7rem">Due Date</th>
                        <th class="text-right" style="width: 8rem">Original</th>
                        <th class="text-right" style="width: 8rem">Balance</th>
                        <th class="text-right" style="width: 10rem">Payment</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _items)
                    {
                        var captured = row;
                        <tr>
                            <td>
                                <input type="checkbox"
                                       checked="@captured.IsTicked"
                                       @onchange="@(e => OnRowTicked(captured.OpenItemId, (bool)(e.Value ?? false)))" />
                            </td>
                            <td><span class="citus-inline-code">@captured.DisplayNumber</span></td>
                            <td><CitusBadge Color="@("blue")">@HumanizeSourceType(captured.SourceType)</CitusBadge></td>
                            <td>@captured.DocumentDate.ToString("yyyy-MM-dd")</td>
                            <td>@(captured.DueDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                            <td class="text-right">@FormatAmount(captured.OriginalAmountTx)</td>
                            <td class="text-right font-semibold">@FormatAmount(captured.OpenAmountTx)</td>
                            <td>
                                <input type="text"
                                       inputmode="decimal"
                                       class="citus-form-field__input text-right"
                                       value="@FormatDecimalForInput(captured.Payment)"
                                       disabled="@(!captured.IsTicked)"
                                       @oninput="@(e => OnPaymentEdited(captured.OpenItemId, e.Value?.ToString()))" />
                            </td>
                        </tr>
                    }
                    <tr class="citus-data-table__total">
                        <td colspan="6" class="text-right font-medium">Totals</td>
                        <td class="text-right font-semibold">@FormatAmount(_items.Where(r => r.IsTicked).Sum(r => r.OpenAmountTx))</td>
                        <td class="text-right font-semibold">@FormatAmount(_appliedTotal)</td>
                    </tr>
                </tbody>
            </table>
        }
    </section>

    <section class="citus-panel">
        <header class="citus-panel__header">
            <h2 class="citus-panel__title">Post</h2>
            <span class="text-fg-muted text-sm">
                Posting prepares + posts the receive-payment document and settles the
                ticked AR open items by the applied amount. Overpayment as Customer Deposit
                is pending in the next release — for now keep Total to Bank ≤ applied total.
            </span>
        </header>
        <AiseButtonGroup Align="end">
            <CitusButton Variant="CitusButtonVariant.Ghost" OnClick="ResetForm">Reset</CitusButton>
            <CitusButton Variant="CitusButtonVariant.Primary"
                         Disabled="@(_customerId == Guid.Empty || _bankAccountId == Guid.Empty || _appliedTotal <= 0 || ShellState.AreWritesBlocked || _isSubmitting)"
                         OnClick="PostAsync">
                @(_isSubmitting ? "Posting…" : "Post receive payment")
            </CitusButton>
        </AiseButtonGroup>
    </section>
</div>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Sales & Get Paid",
        Title = "Receive payment",
        Subtitle = "Apply customer cash to one or more open invoices. Tick order drives allocation priority."
    };

    private DateTime? _date = DateTime.Today;
    private string _currency = string.Empty;
    /// <summary>
    /// True once a customer is selected — the form pins Currency to that
    /// customer's default and disables the input. Per the per-customer
    /// single-currency rule, a customer with mixed-currency dealings is
    /// modelled as separate customer records.
    /// </summary>
    private bool _isCurrencyLocked;
    private string _memo = string.Empty;
    private Guid _customerId;
    private string _customerDisplay = string.Empty;
    private Guid _bankAccountId;
    private IReadOnlyList<AccountSummary> _bankAccounts = Array.Empty<AccountSummary>();

    private decimal _totalToBank;
    /// <summary>
    /// Cash-driven mode is on whenever the user has typed a positive Total
    /// to Bank. In that mode, ticking an invoice doesn't sum into Total —
    /// it draws cash from Total in tick order, capped at the invoice's
    /// balance, and the remainder lands on Extra → New Deposit.
    ///
    /// Selection-driven mode (the default when Total is blank or zero) does
    /// the opposite: each tick adds the invoice's balance to Total and the
    /// Payment column auto-fills with the full balance.
    /// </summary>
    private bool _isCashDriven;

    private List<ApplyRow> _items = new();
    private bool _isLoadingItems;

    /// <summary>
    /// Tick order = priority. We push to this list in the order the user
    /// ticked invoices; allocation walks it head-first so the *first* tick
    /// gets full cash, the next gets the remainder, and so on.
    /// </summary>
    private readonly List<Guid> _tickOrder = new();

    /// <summary>
    /// Open-item ids whose Payment cell the user has manually edited. The
    /// allocator skips these (preserving the user's override) and only
    /// re-allocates over the unlocked rows. Cleared when the form resets
    /// or when Total is cleared back to selection-driven mode.
    /// </summary>
    private readonly HashSet<Guid> _lockedPayments = new();

    private bool _isSubmitting;
    private string? _validation;
    private WriteFlowResult? _lastResult;

    private decimal _appliedTotal => _items.Where(r => r.IsTicked).Sum(r => r.Payment);

    private decimal _extraNewDeposit
    {
        get
        {
            if (!_isCashDriven) return 0m;
            var diff = _totalToBank - _appliedTotal;
            return diff > 0 ? diff : 0m;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;
        await LoadBankAccountsAsync();
    }

    private async Task LoadBankAccountsAsync()
    {
        // Receive Payment lands cash in a bank, cash, or credit-card account
        // (the same set Expense's Payment Account picker uses, scoped here
        // by client-side filter so we don't need a dedicated endpoint).
        var all = await AccountClient.ListAsync(rootType: "asset", includeInactive: false);
        _bankAccounts = all
            .Where(a => a.AllowManualPosting)
            .Where(a => a.DetailType is "bank" or "cash" or "credit_card")
            .OrderBy(a => a.Code, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private void OnDateChanged(ChangeEventArgs args)
    {
        if (DateTime.TryParse(args.Value?.ToString(), out var parsed))
        {
            _date = parsed;
        }
    }

    private void OnBankAccountChanged(ChangeEventArgs args)
    {
        var raw = args.Value?.ToString();
        _bankAccountId = Guid.TryParse(raw, out var parsed) ? parsed : Guid.Empty;
    }

    private async Task OnCustomerSelected(UnitySearchPickerOption option)
    {
        _customerId = option.SourceId;
        _customerDisplay = option.DisplayText;

        // Lock currency to the customer's default. The fetch is best-effort:
        // if the lookup fails (transient network blip), fall back to base
        // currency so the form stays usable, but keep the lock indicator
        // off so the operator knows what's going on.
        var customer = await CustomerClient.GetByIdAsync(_customerId);
        if (customer is not null && !string.IsNullOrWhiteSpace(customer.DefaultCurrencyCode))
        {
            _currency = customer.DefaultCurrencyCode;
            _isCurrencyLocked = true;
        }

        await LoadOpenItemsAsync();
    }

    private void OnCustomerCleared()
    {
        _customerId = Guid.Empty;
        _customerDisplay = string.Empty;
        _items = new List<ApplyRow>();
        _tickOrder.Clear();
        _lockedPayments.Clear();
        // Restore base currency + unlock: the operator might pick a
        // different customer next, with its own default currency.
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;
        _isCurrencyLocked = false;
        Reallocate();
    }

    private async Task LoadOpenItemsAsync()
    {
        _isLoadingItems = true;
        _tickOrder.Clear();
        _lockedPayments.Clear();
        try
        {
            var rows = await OpenReceivablesClient.ListAsync(ShellState.ActiveCompany.Id, _customerId);
            _items = rows
                // v1 scope: invoices only (positive credit-side balances).
                // Customer deposits (negative-side rows) are deferred to the
                // commit that wires submit + auto-creates a Deposit on
                // overpayment — they need their own +/- math in the table.
                .Where(r => r.OpenAmountTx > 0m)
                .OrderBy(r => r.DocumentDate)
                .Select(r => new ApplyRow(r))
                .ToList();
        }
        finally
        {
            _isLoadingItems = false;
            Reallocate();
        }
    }

    private void OnRowTicked(Guid openItemId, bool isTicked)
    {
        var row = _items.FirstOrDefault(r => r.OpenItemId == openItemId);
        if (row is null) return;

        row.IsTicked = isTicked;
        if (isTicked)
        {
            // Tick order is priority for cash-driven allocation. Append to
            // the list (ignoring re-ticks of already-recorded ids).
            if (!_tickOrder.Contains(openItemId))
            {
                _tickOrder.Add(openItemId);
            }
        }
        else
        {
            _tickOrder.Remove(openItemId);
            _lockedPayments.Remove(openItemId);
            row.Payment = 0m;
        }

        Reallocate();
    }

    private void OnTotalToBankInput(ChangeEventArgs args)
    {
        var raw = args.Value?.ToString();
        var parsed = ParseDecimal(raw);
        _totalToBank = parsed;
        // Mode flips on every keystroke: any positive value puts us in
        // cash-driven mode; clearing back to zero / blank reverts to
        // selection-driven and wipes manual locks so the next tick
        // round starts clean.
        var nowCashDriven = parsed > 0m;
        if (!nowCashDriven && _isCashDriven)
        {
            _lockedPayments.Clear();
        }
        _isCashDriven = nowCashDriven;
        Reallocate();
    }

    private void OnPaymentEdited(Guid openItemId, string? raw)
    {
        var row = _items.FirstOrDefault(r => r.OpenItemId == openItemId);
        if (row is null || !row.IsTicked) return;

        var typed = ParseDecimal(raw);
        // Cap manual entry at the invoice's open balance — over-paying a
        // single line on the Apply table doesn't make sense; if the user
        // wants to send extra cash, that goes on Extra → New Deposit via
        // a higher Total to Bank.
        if (typed > row.OpenAmountTx) typed = row.OpenAmountTx;
        if (typed < 0m) typed = 0m;

        row.Payment = typed;
        _lockedPayments.Add(openItemId);
        Reallocate();
    }

    /// <summary>
    /// Walks the ticked rows and fills the Payment column according to the
    /// active mode:
    ///
    /// * Selection-driven: every unlocked ticked row gets its full balance.
    ///   Total to Bank = sum of payments (we mirror the user's tick choices
    ///   straight into the total).
    ///
    /// * Cash-driven: walk in tick order; each unlocked row gets
    ///   min(remaining_cash, balance), then remaining shrinks. After the
    ///   walk, anything left in remaining lands on Extra → New Deposit.
    ///   Locked rows (the user manually edited their Payment) keep their
    ///   value and consume cash up-front.
    /// </summary>
    private void Reallocate()
    {
        if (!_isCashDriven)
        {
            foreach (var row in _items)
            {
                if (!row.IsTicked)
                {
                    row.Payment = 0m;
                    continue;
                }
                if (_lockedPayments.Contains(row.OpenItemId))
                {
                    continue; // user override — leave alone
                }
                row.Payment = row.OpenAmountTx;
            }
            _totalToBank = _items.Where(r => r.IsTicked).Sum(r => r.Payment);
            return;
        }

        // Cash-driven path. Reserve cash for locked rows first so they're
        // honored verbatim, then distribute the remainder in tick order.
        var lockedSum = _items
            .Where(r => r.IsTicked && _lockedPayments.Contains(r.OpenItemId))
            .Sum(r => r.Payment);
        var remaining = _totalToBank - lockedSum;
        if (remaining < 0m) remaining = 0m;

        foreach (var openItemId in _tickOrder)
        {
            var row = _items.FirstOrDefault(r => r.OpenItemId == openItemId);
            if (row is null || !row.IsTicked) continue;
            if (_lockedPayments.Contains(openItemId)) continue;

            var allocate = Math.Min(row.OpenAmountTx, remaining);
            if (allocate < 0m) allocate = 0m;
            row.Payment = allocate;
            remaining -= allocate;
        }

        // Anything not ticked stays at 0.
        foreach (var row in _items)
        {
            if (!row.IsTicked) row.Payment = 0m;
        }
    }

    private async Task PostAsync()
    {
        _validation = null;
        _lastResult = null;

        if (_customerId == Guid.Empty) { _validation = "Pick a customer first."; return; }
        if (_bankAccountId == Guid.Empty) { _validation = "Pick the bank/cash account the deposit lands in."; return; }
        var ticked = _items.Where(r => r.IsTicked && r.Payment > 0m).ToArray();
        if (ticked.Length == 0) { _validation = "Tick at least one invoice with a payment amount."; return; }

        // Prepare endpoint validates that sum(lines) == receive-payment total
        // — overpayment isn't accepted by the existing pipeline. Until a
        // Customer Deposit document type ships (Commit C), block submit when
        // Extra > 0 and tell the user how to proceed. The Apply table still
        // shows the breakdown so they can either lower Total to Bank or
        // apply more invoices to absorb the cash.
        if (_isCashDriven && _extraNewDeposit > 0m)
        {
            _validation =
                $"Overpayment of {FormatAmount(_extraNewDeposit)} {_currency.ToUpperInvariant()} would create a Customer Deposit, " +
                "which is pending in the next release. For now, lower Total to Bank to match the applied total, " +
                "or tick additional invoices to absorb the cash.";
            return;
        }

        _isSubmitting = true;
        try
        {
            var draft = new ReceivePaymentDraft
            {
                CompanyId = ShellState.ActiveCompany.Id,
                UserId = ShellState.User.Id,
                BankAccountId = _bankAccountId,
                Date = DateOnly.FromDateTime((_date ?? DateTime.Today).Date),
                CustomerId = _customerId,
                Amount = _totalToBank,
                TransactionCurrencyCode = _currency.Trim().ToUpperInvariant(),
                Memo = _memo.Trim(),
                Applications = ticked.Select(r => new SettlementApplicationDraft
                {
                    OpenItemId = r.OpenItemId,
                    AppliedAmount = r.Payment,
                    DocumentDisplayNumber = r.DisplayNumber,
                }).ToArray()
            };
            _lastResult = await WriteFlow.PostReceivePaymentAsync(draft);
            if (_lastResult.Succeeded)
            {
                await Message.SuccessAsync(_lastResult.Message);
                NavigationManager.NavigateTo("dashboard");
            }
            else
            {
                await Message.InfoAsync(_lastResult.Message);
            }
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void ResetForm()
    {
        _totalToBank = 0m;
        _isCashDriven = false;
        _memo = string.Empty;
        _tickOrder.Clear();
        _lockedPayments.Clear();
        foreach (var row in _items)
        {
            row.IsTicked = false;
            row.Payment = 0m;
        }
        _validation = null;
        _lastResult = null;
    }

    private static decimal ParseDecimal(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return 0m;
        return decimal.TryParse(raw, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : 0m;
    }

    private static string FormatDecimalForInput(decimal amount) =>
        amount == 0m ? string.Empty : amount.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private static string FormatAmount(decimal amount) => amount.ToString("N2");

    private static string HumanizeSourceType(string sourceType) => sourceType switch
    {
        "invoice" => "Invoice",
        "credit_note" => "Credit",
        "customer_deposit" => "Deposit",
        _ => sourceType,
    };

    private sealed class ApplyRow
    {
        public ApplyRow(OpenReceivableSummary summary)
        {
            OpenItemId = summary.OpenItemId;
            DisplayNumber = summary.DisplayNumber;
            SourceType = summary.SourceType;
            DocumentDate = summary.DocumentDate;
            DueDate = summary.DueDate;
            OriginalAmountTx = summary.OriginalAmountTx;
            OpenAmountTx = summary.OpenAmountTx;
            CurrencyCode = summary.DocumentCurrencyCode;
        }

        public Guid OpenItemId { get; }
        public string DisplayNumber { get; }
        public string SourceType { get; }
        public DateOnly DocumentDate { get; }
        public DateOnly? DueDate { get; }
        public decimal OriginalAmountTx { get; }
        public decimal OpenAmountTx { get; }
        public string CurrencyCode { get; }

        public bool IsTicked { get; set; }
        public decimal Payment { get; set; }
    }
}
