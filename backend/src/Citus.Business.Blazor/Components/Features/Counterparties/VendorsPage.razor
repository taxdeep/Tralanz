@page "/vendors"

@using Radzen
@using Radzen.Blazor

@inject BusinessShellState ShellState
@inject BusinessWriteFlowClient WriteFlow
@inject VendorClient VendorClient
@inject PaymentTermClient PaymentTermClient
@inject CitusToastService Message

<PageTitle>Vendors | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusButton Variant="CitusButtonVariant.Primary"
                     LeadingIcon="IconName.Plus"
                     OnClick="StartCreate">New vendor</CitusButton>
    </Actions>
</CitusPageHeader>

@if (_lastResult is not null)
{
    <CitusAlert Severity="CitusAlertSeverity.Info" ShowIcon="true" Class="mb-4">
        <MessageTemplate>
            <strong>@_lastResult.Operation</strong>
            <div class="text-fg-muted text-sm mt-1">@_lastResult.Message</div>
        </MessageTemplate>
    </CitusAlert>
}

@if (_isCreating)
{
    @if (!string.IsNullOrWhiteSpace(_validation))
    {
        <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_validation" ShowIcon="true" Class="mb-4" />
    }
    <CounterpartyForm Draft="_draft"
                      DraftChanged="@(v => _draft = v)"
                      EntityNumberLabel="Vendor #"
                      EntityNumberPlaceholder="VEN-000001"
                      PaymentTerms="_paymentTerms" />
    <div class="flex gap-2 mt-4">
        <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_isSubmitting" OnClick="SaveAsync">
            @(_isSubmitting ? "Saving..." : "Save vendor")
        </CitusButton>
        <CitusButton OnClick="CancelCreate">Cancel</CitusButton>
    </div>
}
else
{
    <CitusFormSection Title="Vendors">
        <CitusAsyncBoundary IsLoading="@_isLoading"
                            IsEmpty="@(_vendors.Count == 0)"
                            EmptyIcon="IconName.BuildingStore"
                            EmptyTitle="No vendors yet"
                            EmptyMessage="Create one with the New vendor button. Vendor master data unblocks bills, expenses, and AP aging.">
            <RadzenDataGrid TItem="VendorRow"
                            Data="@_rows"
                            AllowSorting="true"
                            AllowFiltering="true"
                            AllowColumnResize="true"
                            AllowPaging="true"
                            PageSize="50"
                            FilterMode="FilterMode.Simple"
                            class="citus-radzen-grid">
                <Columns>
                    <RadzenDataGridColumn TItem="VendorRow" Property="@nameof(VendorRow.VendorId)" Title="Vendor ID" Width="180px">
                        <Template Context="row">
                            <a class="citus-link" href="@($"vendors/{row.Id:D}")">
                                <span class="citus-inline-code">@row.VendorId</span>
                            </a>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="VendorRow" Property="@nameof(VendorRow.Name)" Title="Name">
                        <Template Context="row">
                            <a class="citus-link" href="@($"vendors/{row.Id:D}")">@row.Name</a>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="VendorRow" Property="@nameof(VendorRow.Currency)" Title="Currency" Width="110px" />
                    <RadzenDataGridColumn TItem="VendorRow" Property="@nameof(VendorRow.PaymentTerm)" Title="Payment Term" Width="170px">
                        <Template Context="row">
                            @(string.IsNullOrEmpty(row.PaymentTerm) ? "—" : row.PaymentTerm)
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="VendorRow" Property="@nameof(VendorRow.Email)" Title="Email">
                        <Template Context="row">
                            @(string.IsNullOrEmpty(row.Email) ? "—" : row.Email)
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="VendorRow" Property="@nameof(VendorRow.Address)" Title="Address">
                        <Template Context="row">
                            @(string.IsNullOrEmpty(row.Address) ? "—" : row.Address)
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </CitusAsyncBoundary>
    </CitusFormSection>
}

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Expense & Bills",
        Title = "Vendors",
        Subtitle = "Vendor master records that anchor bills, pay-bill settlement, and AP aging."
    };

    private IReadOnlyList<VendorSummary> _vendors = Array.Empty<VendorSummary>();
    private IReadOnlyList<PaymentTermSummary> _paymentTerms = Array.Empty<PaymentTermSummary>();
    private List<VendorRow> _rows = new();
    private CounterpartyDraft _draft = new();
    private bool _isCreating;
    private bool _isSubmitting;
    private bool _isLoading = true;
    private string? _validation;
    private WriteFlowResult? _lastResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            var vendorsTask = VendorClient.ListAsync();
            var termsTask = PaymentTermClient.ListAsync(includeInactive: true);
            await Task.WhenAll(vendorsTask, termsTask);
            _vendors = vendorsTask.Result;
            _paymentTerms = termsTask.Result;
            // VendorNumber (VEN-NNNNNN from the vendor-display numbering
            // scope) is the operator-facing code. Pre-scope rows still
            // show EntityNumber via the ?? fallback so legacy data stays
            // readable.
            _rows = _vendors.Select(v => new VendorRow(
                Id: v.Id,
                VendorId: v.VendorNumber ?? v.EntityNumber,
                Name: v.DisplayName,
                Currency: v.DefaultCurrencyCode,
                PaymentTerm: ResolveTermLabel(v.PaymentTermId),
                Email: v.Email ?? string.Empty,
                Address: FormatAddress(v))).ToList();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string ResolveTermLabel(Guid? paymentTermId)
    {
        if (paymentTermId is null) return string.Empty;
        var term = _paymentTerms.FirstOrDefault(t => t.Id == paymentTermId.Value);
        return term is null ? string.Empty : $"{term.Name} (Net {term.NetDays})";
    }

    private static string FormatAddress(VendorSummary v)
    {
        var parts = new List<string>(5);
        if (!string.IsNullOrWhiteSpace(v.AddressLine)) parts.Add(v.AddressLine);
        if (!string.IsNullOrWhiteSpace(v.City)) parts.Add(v.City);
        if (!string.IsNullOrWhiteSpace(v.ProvinceState)) parts.Add(v.ProvinceState);
        if (!string.IsNullOrWhiteSpace(v.PostalCode)) parts.Add(v.PostalCode);
        if (!string.IsNullOrWhiteSpace(v.Country)) parts.Add(v.Country);
        return string.Join(", ", parts);
    }

    private void StartCreate()
    {
        _isCreating = true;
        _draft = new CounterpartyDraft { PreferredCurrencyCode = ShellState.ActiveCompany.BaseCurrencyCode, Country = "Canada" };
        _validation = null;
    }

    private void CancelCreate() { _isCreating = false; _validation = null; }

    private async Task SaveAsync()
    {
        _validation = null;
        _lastResult = null;
        if (string.IsNullOrWhiteSpace(_draft.DisplayName)) { _validation = "Display name is required."; return; }

        _isSubmitting = true;
        try
        {
            _lastResult = await WriteFlow.SaveVendorAsync(_draft);
            if (_lastResult.Succeeded)
            {
                await Message.SuccessAsync("Vendor saved.");
                _isCreating = false;
                await LoadAsync();
            }
            else
            {
                await Message.InfoAsync(_lastResult.Message);
            }
        }
        finally { _isSubmitting = false; }
    }

    private sealed record VendorRow(
        Guid Id,
        string VendorId,
        string Name,
        string Currency,
        string PaymentTerm,
        string Email,
        string Address);
}
