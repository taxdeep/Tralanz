@*
    Shared form for customer / vendor master data. The Customer and
    Vendor pages render this with the right title and submit handler.
*@

@inject CompanyCurrencyClient CompanyCurrencyClient

<section class="citus-panel">
    <h2 class="citus-panel__title">Identity</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <div>
            <label class="text-sm font-medium block mb-1">Display name</label>
            <CitusInput TValue="string" Value="@Draft.DisplayName" ValueChanged="@(v => Mutate(d => d with { DisplayName = v ?? string.Empty }))" Placeholder="Name shown on invoices and bills" />
        </div>
        <div>
            @* Operators see this as "Customer #" or "Vendor #" depending
               on which page renders the form; the Customer/Vendor pages
               pass the contextual label. The underlying Draft.EntityNumber
               binding is unchanged. *@
            <label class="text-sm font-medium block mb-1">@EntityNumberLabel</label>
            <CitusInput TValue="string" Value="@Draft.EntityNumber" ValueChanged="@(v => Mutate(d => d with { EntityNumber = v ?? string.Empty }))" Placeholder="@(EntityNumberPlaceholder)" />
        </div>
        <div>
            <label class="text-sm font-medium block mb-1">Email</label>
            <CitusInput TValue="string" Value="@Draft.Email" ValueChanged="@(v => Mutate(d => d with { Email = v ?? string.Empty }))" Placeholder="contact@example.com" />
        </div>
        <div>
            <label class="text-sm font-medium block mb-1">Phone</label>
            <CitusInput TValue="string" Value="@Draft.Phone" ValueChanged="@(v => Mutate(d => d with { Phone = v ?? string.Empty }))" Placeholder="+1 555 0100" />
        </div>
        <div class="md:col-span-2">
            <label class="text-sm font-medium block mb-1">Address line</label>
            <CitusInput TValue="string" Value="@Draft.AddressLine" ValueChanged="@(v => Mutate(d => d with { AddressLine = v ?? string.Empty }))" Placeholder="Street + suite" />
        </div>
        <div>
            <label class="text-sm font-medium block mb-1">City</label>
            <CitusInput TValue="string" Value="@Draft.City" ValueChanged="@(v => Mutate(d => d with { City = v ?? string.Empty }))" />
        </div>
        <div>
            <label class="text-sm font-medium block mb-1">Province / State</label>
            <CitusInput TValue="string" Value="@Draft.ProvinceState" ValueChanged="@(v => Mutate(d => d with { ProvinceState = v ?? string.Empty }))" />
        </div>
        <div>
            <label class="text-sm font-medium block mb-1">Postal code</label>
            <CitusInput TValue="string" Value="@Draft.PostalCode" ValueChanged="@(v => Mutate(d => d with { PostalCode = v ?? string.Empty }))" />
        </div>
        <div>
            <label class="text-sm font-medium block mb-1">Country</label>
            <CitusInput TValue="string" Value="@Draft.Country" ValueChanged="@(v => Mutate(d => d with { Country = v ?? string.Empty }))" Placeholder="Canada" />
        </div>
        <div>
            <label class="text-sm font-medium block mb-1">Tax id</label>
            <CitusInput TValue="string" Value="@Draft.TaxId" ValueChanged="@(v => Mutate(d => d with { TaxId = v ?? string.Empty }))" Placeholder="GST/HST number, EIN, ..." />
        </div>
        <div>
            <label class="text-sm font-medium block mb-1">Preferred currency</label>
            @* Per the per-customer / per-vendor single-currency rule, the
               picker only offers currencies the company has enabled in
               Settings → Multi-currency. The base currency is always in
               the list (since it's enabled by definition). If the active
               record carries a legacy currency that's no longer enabled,
               we still surface it tagged "(no longer enabled)" so editing
               doesn't silently lose data. *@
            <select class="citus-form-field__input"
                    value="@Draft.PreferredCurrencyCode"
                    @onchange="OnCurrencyChanged"
                    disabled="@_isLoadingCurrencies">
                @foreach (var entry in _enabledCurrencies)
                {
                    <option value="@entry.CurrencyCode">
                        @entry.CurrencyCode — @entry.CurrencyName@(entry.IsBaseCurrency ? " (base)" : "")
                    </option>
                }
                @if (!string.IsNullOrWhiteSpace(Draft.PreferredCurrencyCode)
                     && _enabledCurrencies.All(c => !string.Equals(c.CurrencyCode, Draft.PreferredCurrencyCode, StringComparison.OrdinalIgnoreCase)))
                {
                    <option value="@Draft.PreferredCurrencyCode">
                        @Draft.PreferredCurrencyCode (no longer enabled)
                    </option>
                }
            </select>
        </div>
        @if (PaymentTerms is { Count: > 0 })
        {
            <div>
                <label class="text-sm font-medium block mb-1">Payment term</label>
                <select class="citus-form-field__input"
                        value="@(Draft.PaymentTermId?.ToString() ?? string.Empty)"
                        @onchange="OnPaymentTermChanged">
                    <option value="">None</option>
                    @foreach (var term in PaymentTerms)
                    {
                        <option value="@term.Id">@term.Name (Net @term.NetDays)</option>
                    }
                </select>
            </div>
        }
        <div class="md:col-span-2">
            <label class="text-sm font-medium block mb-1">Notes</label>
            <CitusInput TValue="string" Value="@Draft.Notes" ValueChanged="@(v => Mutate(d => d with { Notes = v ?? string.Empty }))" Placeholder="Internal notes" />
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public CounterpartyDraft Draft { get; set; } = new();

    [Parameter] public EventCallback<CounterpartyDraft> DraftChanged { get; set; }

    [Parameter] public string EntityNumberPlaceholder { get; set; } = "CUS-000001";

    /// <summary>
    /// Customer-facing label for the audit-number field. Defaults to the
    /// generic platform term; the Customers / Vendors pages pass
    /// "Customer #" / "Vendor #" so the form reads naturally on each side.
    /// </summary>
    [Parameter] public string EntityNumberLabel { get; set; } = "Entity number";

    /// <summary>
    /// Optional. When supplied (vendor side), renders a Payment Term
    /// picker between Preferred currency and Notes. Customer side leaves
    /// this null and the picker stays hidden.
    /// </summary>
    [Parameter] public IReadOnlyList<PaymentTermSummary>? PaymentTerms { get; set; }

    private IReadOnlyList<CompanyCurrencyEntry> _enabledCurrencies = Array.Empty<CompanyCurrencyEntry>();
    private bool _isLoadingCurrencies = true;

    protected override async Task OnInitializedAsync()
    {
        // Fetch the company's currency profile and keep only the enabled
        // entries (base + opted-in foreign). Best-effort: a transient
        // failure leaves the list empty and the select disabled, so the
        // form doesn't lock the operator into an invalid state — the
        // legacy-value option above still surfaces whatever is on the
        // draft.
        try
        {
            var profile = await CompanyCurrencyClient.GetAsync();
            if (profile is not null)
            {
                _enabledCurrencies = profile.Currencies
                    .Where(c => c.IsEnabled)
                    .OrderByDescending(c => c.IsBaseCurrency)
                    .ThenBy(c => c.CurrencyCode, StringComparer.OrdinalIgnoreCase)
                    .ToArray();

                // Snap the draft's currency to the company base when blank
                // — happens on a fresh New customer / New vendor click
                // before the list has loaded; once the list arrives we
                // make sure the bound value matches an option so the
                // dropdown doesn't render in a weird empty state.
                if (string.IsNullOrWhiteSpace(Draft.PreferredCurrencyCode)
                    && !string.IsNullOrWhiteSpace(profile.BaseCurrencyCode))
                {
                    await Mutate(d => d with { PreferredCurrencyCode = profile.BaseCurrencyCode });
                }
            }
        }
        finally
        {
            _isLoadingCurrencies = false;
        }
    }

    private Task Mutate(Func<CounterpartyDraft, CounterpartyDraft> mutate) =>
        DraftChanged.InvokeAsync(mutate(Draft));

    private Task OnCurrencyChanged(ChangeEventArgs args)
    {
        var next = args.Value?.ToString() ?? string.Empty;
        return Mutate(d => d with { PreferredCurrencyCode = next });
    }

    private Task OnPaymentTermChanged(ChangeEventArgs args)
    {
        var raw = args.Value?.ToString();
        Guid? next = Guid.TryParse(raw, out var parsed) ? parsed : null;
        return Mutate(d => d with { PaymentTermId = next });
    }
}
