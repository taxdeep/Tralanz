@page "/customers"

@inject BusinessShellState ShellState
@inject BusinessWriteFlowClient WriteFlow
@inject CustomerClient CustomerClient
@inject PaymentTermClient PaymentTermClient
@inject CitusToastService Message

<PageTitle>Customers | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusButton Variant="CitusButtonVariant.Primary"
                     LeadingIcon="IconName.Plus"
                     OnClick="StartCreate">New customer</CitusButton>
    </Actions>
</CitusPageHeader>

@if (_lastResult is not null)
{
    <CitusAlert Severity="CitusAlertSeverity.Info" ShowIcon="true" Class="mb-4">
        <MessageTemplate>
            <strong>@_lastResult.Operation</strong>
            <div class="text-fg-muted text-sm mt-1">@_lastResult.Message</div>
        </MessageTemplate>
    </CitusAlert>
}

@if (_isCreating)
{
    @if (!string.IsNullOrWhiteSpace(_validation))
    {
        <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_validation" ShowIcon="true" Class="mb-4" />
    }
    <CounterpartyForm Draft="_draft"
                      DraftChanged="@(v => _draft = v)"
                      EntityNumberLabel="Customer #"
                      EntityNumberPlaceholder="CUS000001"
                      PaymentTerms="_paymentTerms" />
    @* Buttons right-aligned and reordered (Cancel | Primary) so the
       primary action sits at the form's natural visual terminus and
       Cancel reads as the safe secondary, matching the Cancel/OK
       convention used elsewhere in the shell. *@
    <div class="flex justify-end gap-2 mt-4">
        <CitusButton OnClick="CancelCreate">Cancel</CitusButton>
        <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_isSubmitting" OnClick="SaveAsync">
            @(_isSubmitting ? "Saving..." : "Save customer")
        </CitusButton>
    </div>
}
else
{
    <section class="citus-panel">
        <CitusAsyncBoundary IsLoading="@_isLoading"
                            IsEmpty="@(_customers.Count == 0)"
                            EmptyIcon="IconName.Users"
                            EmptyTitle="No customers yet"
                            EmptyMessage="Create one with the New customer button. Customer master data unblocks invoicing and AR open-item tracking.">
            <table class="citus-data-table">
                <thead>
                    <tr>
                        <th>Customer</th>
                        @* "Customer #" reads more naturally than the raw
                           "Entity number" platform label — operators look
                           up customers by this code, the EN+YYYY+5base36
                           shape is just the storage format. *@
                        <th>Customer #</th>
                        <th>Email</th>
                        <th>Country</th>
                        <th>Currency</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in _customers)
                    {
                        <tr>
                            <td><a class="citus-link" href="@($"customers/{c.Id:D}")">@c.DisplayName</a></td>
                            <td>
                                @* CustomerNumber (CUSNNNNNN from the
                                   customer-display numbering scope) is
                                   the operator-facing code. Pre-scope
                                   rows still show EntityNumber via the
                                   ?? fallback so legacy data stays
                                   readable. *@
                                <a class="citus-link" href="@($"customers/{c.Id:D}")">
                                    <span class="citus-inline-code">@DisplayCustomerCode(c)</span>
                                </a>
                            </td>
                            <td>@c.Email</td>
                            <td>@c.Country</td>
                            <td>@c.DefaultCurrencyCode</td>
                        </tr>
                    }
                </tbody>
            </table>
        </CitusAsyncBoundary>
    </section>
}

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Sales & Get Paid",
        Title = "Customers",
        Subtitle = "Customer master records that anchor invoices, receive-payment settlement, and AR aging."
    };

    private IReadOnlyList<CustomerSummary> _customers = Array.Empty<CustomerSummary>();
    private IReadOnlyList<PaymentTermSummary> _paymentTerms = Array.Empty<PaymentTermSummary>();
    private CounterpartyDraft _draft = new();
    private bool _isCreating;
    private bool _isSubmitting;
    private bool _isLoading = true;
    private string? _validation;
    private WriteFlowResult? _lastResult;

    private static string DisplayCustomerCode(CustomerSummary customer) =>
        NormalizeCustomerNumber(customer.CustomerNumber) ?? customer.EntityNumber;

    private static string? NormalizeCustomerNumber(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var trimmed = value.Trim();
        return trimmed.StartsWith("CUS-", StringComparison.OrdinalIgnoreCase)
            ? string.Concat(trimmed.AsSpan(0, 3), trimmed.AsSpan(4))
            : trimmed;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            var customersTask = CustomerClient.ListAsync();
            var termsTask = PaymentTermClient.ListAsync(includeInactive: false);
            await Task.WhenAll(customersTask, termsTask);
            _customers = customersTask.Result;
            _paymentTerms = termsTask.Result;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void StartCreate()
    {
        _isCreating = true;
        _draft = new CounterpartyDraft { PreferredCurrencyCode = ShellState.ActiveCompany.BaseCurrencyCode, Country = "Canada" };
        _validation = null;
    }

    private void CancelCreate() { _isCreating = false; _validation = null; }

    private async Task SaveAsync()
    {
        _validation = null;
        _lastResult = null;
        if (string.IsNullOrWhiteSpace(_draft.DisplayName)) { _validation = "Display name is required."; return; }

        _isSubmitting = true;
        try
        {
            _lastResult = await WriteFlow.SaveCustomerAsync(_draft);
            if (_lastResult.Succeeded)
            {
                await Message.SuccessAsync("Customer saved.");
                _isCreating = false;
                await LoadAsync();
            }
            else
            {
                await Message.InfoAsync(_lastResult.Message);
            }
        }
        finally { _isSubmitting = false; }
    }
}
