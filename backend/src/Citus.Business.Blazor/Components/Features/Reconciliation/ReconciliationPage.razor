@page "/reconciliation"

@inject BusinessShellState ShellState
@inject AccountClient AccountClient
@inject BankReconciliationClient ReconciliationClient
@inject CitusToastService Message

<PageTitle>Reconciliation | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusBadge Color="@(IsZero(_difference) ? "green" : "orange")">
            @(IsZero(_difference) ? "Difference cleared" : "Difference outstanding")
        </CitusBadge>
    </Actions>
</CitusPageHeader>

@if (ShellState.AreWritesBlocked)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" ShowIcon="true" Message="@ShellState.WriteBlockMessage" Class="mb-4" />
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_error" ShowIcon="true" Class="mb-4" />
}

@if (_completed is not null)
{
    <CitusAlert Severity="CitusAlertSeverity.Success"
                ShowIcon="true"
                Message="@($"Reconciliation completed for {_completed.LineCount} ledger entries. Difference {_completed.Difference:N2}.")"
                Class="mb-4" />
}

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <div class="lg:col-span-8 flex flex-col gap-6">
        <section class="citus-panel">
            <header class="citus-panel__header">
                <h2 class="citus-panel__title">Statement</h2>
                <CitusButton LeadingIcon="IconName.Refresh" Size="CitusButtonSize.Small" Disabled="@(!_selectedAccountId.HasValue || _isLoading)" OnClick="LoadEntriesAsync">
                    @(_isLoading ? "Loading..." : "Load ledger")
                </CitusButton>
            </header>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="text-sm font-medium block mb-1">Statement account</label>
                    <select class="citus-form-field__input"
                            value="@(_selectedAccountId?.ToString("D") ?? string.Empty)"
                            @onchange="OnAccountChanged">
                        <option value="">Select bank, cash, or credit card account</option>
                        @foreach (var account in _bankAccounts)
                        {
                            <option value="@account.Id.ToString("D")">@account.Code @account.Name (@FormatAccountKind(account)) - @(account.CurrencyCode ?? ShellState.ActiveCompany.BaseCurrencyCode)</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="text-sm font-medium block mb-1">Statement date</label>
                    <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_statementDate" Class="citus-control-full" />
                </div>
                <div>
                    <label class="text-sm font-medium block mb-1">Statement opening balance</label>
                    <RadzenNumeric TValue="decimal" @bind-Value="_openingBalance" Format="@MoneyFormat.EditFormat(ShellState.MoneyDecimals)" Class="citus-control-full" />
                </div>
                <div>
                    <label class="text-sm font-medium block mb-1">Statement ending balance</label>
                    <RadzenNumeric TValue="decimal" @bind-Value="_endingBalance" Format="@MoneyFormat.EditFormat(ShellState.MoneyDecimals)" Class="citus-control-full" />
                </div>
                <div class="md:col-span-2">
                    <label class="text-sm font-medium block mb-1">Notes</label>
                    <CitusInput TValue="string" @bind-Value="_notes" Placeholder="Statement reference or review note" />
                </div>
            </div>
        </section>

        <section class="citus-panel">
            <header class="citus-panel__header">
                <h2 class="citus-panel__title">Unreconciled ledger entries</h2>
                <CitusBadge Color="blue">@_selectedCount selected</CitusBadge>
            </header>
            @if (!_selectedAccountId.HasValue)
            {
                <p class="text-fg-muted text-sm">Pick a bank, cash, or credit card account, then load ledger entries.</p>
            }
            else if (_rows.Count == 0)
            {
                <p class="text-fg-muted text-sm">No unreconciled posted ledger entries found up to the statement date.</p>
            }
            else
            {
                <table class="citus-data-table">
                    <thead>
                        <tr>
                            <th style="width: 3rem">Clear</th>
                            <th>Date</th>
                            <th>Source</th>
                            <th>Memo</th>
                            <th class="text-right" style="width: 9rem">@IncreaseLabel</th>
                            <th class="text-right" style="width: 9rem">@DecreaseLabel</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _rows)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox"
                                           checked="@row.Selected"
                                           @onchange="e => row.Selected = e.Value is true" />
                                </td>
                                <td>@row.Entry.PostingDate.ToString("yyyy-MM-dd")</td>
                                <td>@row.Entry.DisplayNumber</td>
                                <td>@(string.IsNullOrWhiteSpace(row.Entry.Description) ? row.Entry.SourceType : row.Entry.Description)</td>
                                <td class="text-right">@FormatAmount(row.Entry.SignedAmountBase > 0m ? row.Entry.SignedAmountBase : 0m)</td>
                                <td class="text-right">@FormatAmount(row.Entry.SignedAmountBase < 0m ? Math.Abs(row.Entry.SignedAmountBase) : 0m)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </section>
    </div>

    <div class="lg:col-span-4 flex flex-col gap-6">
        <section class="citus-panel">
            <h2 class="citus-panel__title">Summary</h2>
            <table class="citus-keyvalue">
                <tbody>
                    <tr><th>Opening</th><td>@FormatAmount(_openingBalance)</td></tr>
                    <tr><th>+ @IncreaseLabel</th><td>@FormatAmount(_clearedIncrease)</td></tr>
                    <tr><th>- @DecreaseLabel</th><td>@FormatAmount(_clearedDecrease)</td></tr>
                    <tr><th>Calculated ending</th><td>@FormatAmount(_calculatedEnding)</td></tr>
                    <tr><th>Statement ending</th><td>@FormatAmount(_endingBalance)</td></tr>
                    <tr>
                        <th>Difference</th>
                        <td class="@(IsZero(_difference) ? "text-success" : "text-warning")">
                            <strong>@FormatAmount(_difference)</strong>
                        </td>
                    </tr>
                </tbody>
            </table>
        </section>

        <section class="citus-panel">
            <h2 class="citus-panel__title">Complete reconciliation</h2>
            <p class="text-fg-muted text-sm mb-3">
                Completion locks the selected posted ledger entries and writes a reconciliation snapshot. It is only available when the difference is zero.
            </p>
            <CitusButton Variant="CitusButtonVariant.Primary"
                         Block="true"
                         Disabled="@(!CanComplete)"
                         OnClick="CompleteAsync">
                @(_isCompleting ? "Completing..." : "Complete reconciliation")
            </CitusButton>
            @if (!IsZero(_difference))
            {
                <p class="text-fg-subtle text-xs mt-2">Adjust selected entries or statement balances until the difference is zero.</p>
            }
        </section>
    </div>
</div>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Banking",
        Title = "Reconciliation",
        Subtitle = "Match posted bank, cash, or credit-card ledger entries to the statement and lock them when the difference is zero."
    };

    private DateTime? _statementDate = DateTime.Today;
    private decimal _openingBalance;
    private decimal _endingBalance;
    private string _notes = string.Empty;
    private string? _error;
    private bool _isLoading;
    private bool _isCompleting;
    private Guid? _selectedAccountId;
    private IReadOnlyList<AccountSummary> _bankAccounts = Array.Empty<AccountSummary>();
    private readonly List<ReconciliationRow> _rows = new();
    private BankReconciliationSummaryDto? _completed;

    private AccountSummary? SelectedAccount => _selectedAccountId is { } id
        ? _bankAccounts.FirstOrDefault(a => a.Id == id)
        : null;
    private bool SelectedAccountIsCreditCard => SelectedAccount?.DetailType == "credit_card";
    private string IncreaseLabel => SelectedAccountIsCreditCard ? "Charges" : "Inflow";
    private string DecreaseLabel => SelectedAccountIsCreditCard ? "Payments / credits" : "Outflow";
    private int _selectedCount => _rows.Count(r => r.Selected);
    private decimal _clearedIncrease => _rows.Where(r => r.Selected && r.Entry.SignedAmountBase > 0m).Sum(r => r.Entry.SignedAmountBase);
    private decimal _clearedDecrease => _rows.Where(r => r.Selected && r.Entry.SignedAmountBase < 0m).Sum(r => Math.Abs(r.Entry.SignedAmountBase));
    private decimal _calculatedEnding => _openingBalance + _clearedIncrease - _clearedDecrease;
    private decimal _difference => _endingBalance - _calculatedEnding;
    private DateOnly StatementDate => DateOnly.FromDateTime((_statementDate ?? DateTime.Today).Date);
    private bool CanComplete =>
        _selectedAccountId.HasValue &&
        _selectedCount > 0 &&
        IsZero(_difference) &&
        !_isCompleting &&
        !ShellState.AreWritesBlocked;

    protected override async Task OnInitializedAsync()
    {
        var accounts = await AccountClient.ListAsync(rootType: "asset");
        _bankAccounts = accounts
            .Where(a => a.IsActive && ((a.RootType == "asset" && a.DetailType is "bank" or "cash") ||
                                       (a.RootType == "liability" && a.DetailType == "credit_card")))
            .OrderBy(a => a.Code, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private async Task OnAccountChanged(ChangeEventArgs args)
    {
        _completed = null;
        _rows.Clear();
        _selectedAccountId = Guid.TryParse(args.Value?.ToString(), out var id) ? id : null;

        // Carry forward from the account's last completed reconciliation:
        // opening balance picks up where the prior statement ended, and the
        // statement date rolls one month on. An account that has never been
        // reconciled falls back to a clean slate (0 / today). The operator can
        // still override either field before loading the ledger.
        if (_selectedAccountId is { } accountId)
        {
            var last = await ReconciliationClient.GetLastCompletedAsync(accountId);
            if (last is not null)
            {
                _openingBalance = last.EndingBalance;
                _statementDate = last.StatementDate.AddMonths(1).ToDateTime(TimeOnly.MinValue);
            }
            else
            {
                _openingBalance = 0m;
                _statementDate = DateTime.Today;
            }
        }
    }

    private async Task LoadEntriesAsync()
    {
        if (!_selectedAccountId.HasValue)
        {
            _error = "Select a bank, cash, or credit card account first.";
            return;
        }

        _error = null;
        _isLoading = true;
        try
        {
            var outcome = await ReconciliationClient.ListLedgerEntriesAsync(_selectedAccountId.Value, StatementDate);
            if (!outcome.Succeeded)
            {
                _error = outcome.ErrorMessage;
                return;
            }

            _rows.Clear();
            _rows.AddRange(outcome.Entries.Select(static e => new ReconciliationRow(e)));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CompleteAsync()
    {
        if (!CanComplete || !_selectedAccountId.HasValue)
        {
            return;
        }

        _error = null;
        _completed = null;
        _isCompleting = true;
        try
        {
            var payload = new BankReconciliationCompletePayload(
                _selectedAccountId.Value,
                StatementDate,
                _openingBalance,
                _endingBalance,
                _rows.Where(r => r.Selected).Select(r => r.Entry.LedgerEntryId).ToArray(),
                string.IsNullOrWhiteSpace(_notes) ? null : _notes.Trim());

            var outcome = await ReconciliationClient.CompleteAsync(payload);
            if (!outcome.Succeeded)
            {
                _error = outcome.ErrorMessage;
                return;
            }

            _completed = outcome.Summary;
            await Message.SuccessAsync("Reconciliation completed.");
            await LoadEntriesAsync();
        }
        finally
        {
            _isCompleting = false;
        }
    }

    private bool IsZero(decimal value) =>
        Math.Round(Math.Abs(value), ShellState.MoneyDecimals, MidpointRounding.AwayFromZero) == 0m;
    private string FormatAmount(decimal amount) => MoneyFormat.Amount(amount, ShellState.MoneyDecimals);
    private static string FormatAccountKind(AccountSummary account) => account.DetailType switch
    {
        "bank" => "Bank",
        "cash" => "Cash",
        "credit_card" => "Credit card",
        _ => "Account"
    };

    private sealed class ReconciliationRow(BankReconciliationLedgerEntrySummary entry)
    {
        public BankReconciliationLedgerEntrySummary Entry { get; } = entry;
        public bool Selected { get; set; }
    }
}
