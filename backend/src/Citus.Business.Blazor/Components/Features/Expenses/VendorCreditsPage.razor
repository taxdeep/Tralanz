@page "/vendor-credits"

@inject BusinessShellState ShellState
@inject VendorCreditClient VendorCreditClient

<PageTitle>Vendor Credits | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusLinkButton Href="vendor-credits/new"
                         Variant="CitusButtonVariant.Primary"
                         LeadingIcon="IconName.Plus">
            New vendor credit
        </CitusLinkButton>
    </Actions>
</CitusPageHeader>

<CitusFormSection Title="Vendor credits">
    <HeaderActions>
        <label class="inline-flex items-center gap-2 text-sm">
            <input type="checkbox" checked="@_includeDrafts" @onchange="OnIncludeDraftsChanged" />
            <span>Include drafts</span>
        </label>
    </HeaderActions>
    <ChildContent>
    @if (_isLoading)
    {
        <CitusSkeleton Variant="SkeletonVariant.List" />
    }
    else if (_rows.Count == 0)
    {
        <CitusEmpty Title="No vendor credits yet"
                    Description="Vendor-side credits will appear here once posted."
                    Icon="IconName.FileText" />
    }
    else
    {
        <table class="citus-data-table">
            <thead>
                <tr>
                    <th>Credit #</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th class="text-right">Total</th>
                    <th>Currency</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _rows)
                {
                    <tr>
                        <td><a class="citus-link" href="@($"vendor-credits/{row.Id:D}")">@row.DisplayNumber</a></td>
                        <td>@row.DocumentDate.ToString("yyyy-MM-dd")</td>
                        <td>@HumanizeStatus(row.Status)</td>
                        <td class="text-right">@row.TotalAmount.ToString("N2")</td>
                        <td>@row.TransactionCurrencyCode</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    </ChildContent>
</CitusFormSection>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Expense & Bills",
        Title = "Vendor credits",
        Subtitle = "Vendor-side credits — reduce open AP against the vendor."
    };

    private IReadOnlyList<VendorCreditSummaryDto> _rows = Array.Empty<VendorCreditSummaryDto>();
    private bool _isLoading = true;
    private bool _includeDrafts = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task OnIncludeDraftsChanged(ChangeEventArgs e)
    {
        _includeDrafts = (bool)(e.Value ?? false);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            _rows = await VendorCreditClient.ListAsync(ShellState.ActiveCompany.Id, _includeDrafts);
        }
        finally { _isLoading = false; }
    }

    private static string HumanizeStatus(string status) => status switch
    {
        "draft" => "Draft", "posted" => "Posted", "voided" => "Voided", "reversed" => "Reversed", _ => status
    };
}
