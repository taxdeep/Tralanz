@page "/vendor-credits/{CreditId:guid}"

@inject BusinessShellState ShellState
@inject VendorCreditClient VendorCreditClient
@inject AccountClient AccountClient
@inject VendorClient VendorClient
@inject NavigationManager Navigation

<PageTitle>@($"{_pageTitle} | Tralanz Books")</PageTitle>

<CitusPageHeader Model="_header">
    <TitleSuffix>
        @if (_doc is not null)
        {
            <CitusDocumentStatusBadge Status="@_doc.Status" />
        }
    </TitleSuffix>
    <Actions>
        <CitusLinkButton Href="vendor-credits/new"
                         Variant="CitusButtonVariant.Ghost"
                         LeadingIcon="IconName.Plus">
            New vendor credit
        </CitusLinkButton>
    </Actions>
</CitusPageHeader>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_error" ShowIcon="true" Class="mb-4" />
}

@if (_isLoading)
{
    <CitusSkeleton Variant="SkeletonVariant.Detail" />
}
else if (_doc is null)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="Vendor credit not found in this company." ShowIcon="true" />
}
else
{
    <div class="citus-detail-overview">
        <CitusFormSection Title="Supplier">
            <CitusKeyValueTable>
                <CitusKeyValueRow Label="Name">@_vendorName</CitusKeyValueRow>
                <CitusKeyValueRow Label="Credit no."><span class="citus-inline-code">@_doc.DisplayNumber</span></CitusKeyValueRow>
                <CitusKeyValueRow Label="Internal #"><span class="citus-inline-code">@_doc.EntityNumber</span></CitusKeyValueRow>
            </CitusKeyValueTable>
        </CitusFormSection>

        <CitusStatCard Label="Total" Value="@($"{_doc.TotalAmount:N2} {_doc.TransactionCurrencyCode}")"
                       Description="@($"Subtotal {_doc.SubtotalAmount:N2} + tax {_doc.TaxAmount:N2}")"
                       Icon="IconName.Coin" Tone="StatTone.Success" />
        <CitusStatCard Label="Credit date" Value="@_doc.DocumentDate.ToString("yyyy-MM-dd")"
                       Description="@($"Due {_doc.DueDate:yyyy-MM-dd}")"
                       Icon="IconName.Calendar" Tone="StatTone.Neutral" />
    </div>

    @* Copy A3 Phase 3: actions bar with the standard More menu. *@
    <CitusActionsPanel MoreMenuItems="@_moreItems" />

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-8">
            <CitusFormSection Title="Lines">
                <table class="citus-data-table">
                    <thead>
                        <tr>
                            <th style="width: 3rem">#</th>
                            <th>Expense account</th>
                            <th>Description</th>
                            <th class="text-right" style="width: 7rem">Tax</th>
                            <th class="text-right" style="width: 9rem">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in _doc.Lines)
                        {
                            <tr>
                                <td>@line.LineNumber</td>
                                <td>@ResolveAccountLabel(line.ExpenseAccountId)</td>
                                <td>@(string.IsNullOrEmpty(line.Description) ? "—" : line.Description)</td>
                                <td class="text-right">@line.TaxAmount.ToString("N2")</td>
                                <td class="text-right">@line.LineAmount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </CitusFormSection>

            @if (!string.IsNullOrWhiteSpace(_doc.Memo))
            {
                <CitusFormSection Title="Memo">
                    <p class="text-fg-muted text-sm m-0">@_doc.Memo</p>
                </CitusFormSection>
            }
        </div>

        <aside class="lg:col-span-4 flex flex-col gap-6">
            <CitusFormSection Title="Document">
                <CitusKeyValueTable>
                    <CitusKeyValueRow Label="Credit date">@_doc.DocumentDate.ToString("yyyy-MM-dd")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Due date">@_doc.DueDate.ToString("yyyy-MM-dd")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Currency">@_doc.TransactionCurrencyCode</CitusKeyValueRow>
                    @if (!string.Equals(_doc.TransactionCurrencyCode, _doc.BaseCurrencyCode, StringComparison.OrdinalIgnoreCase))
                    {
                        <CitusKeyValueRow Label="Base">@_doc.BaseCurrencyCode</CitusKeyValueRow>
                    }
                    <CitusKeyValueRow Label="Payable">@ResolveAccountLabel(_doc.PayableAccountId)</CitusKeyValueRow>
                </CitusKeyValueTable>
            </CitusFormSection>

            <CitusFormSection Title="Totals">
                <CitusKeyValueTable>
                    <CitusKeyValueRow Label="Subtotal" ValueAlignRight="true">@_doc.SubtotalAmount.ToString("N2")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Tax" ValueAlignRight="true">@_doc.TaxAmount.ToString("N2")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Total" ValueAlignRight="true"><strong>@_doc.TotalAmount.ToString("N2") @_doc.TransactionCurrencyCode</strong></CitusKeyValueRow>
                </CitusKeyValueTable>
            </CitusFormSection>
        </aside>
    </div>
}

@code {
    [Parameter] public Guid CreditId { get; set; }

    private VendorCreditRecordDto? _doc;
    private string _vendorName = "—";
    private IReadOnlyList<AccountSummary> _accounts = Array.Empty<AccountSummary>();
    private bool _isLoading = true;
    private string? _error;
    private string _pageTitle = "Vendor credit";
    private PageHeaderModel _header = new() { Eyebrow = "Expense & Bills", Title = "Vendor credit", Subtitle = "Credit detail" };

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override async Task OnParametersSetAsync()
    {
        if (_doc is not null && _doc.Id != CreditId) await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            var docTask = VendorCreditClient.GetByIdAsync(CreditId, ShellState.ActiveCompany.Id);
            var accountsTask = AccountClient.ListAsync();
            await Task.WhenAll(docTask, accountsTask);
            _doc = docTask.Result;
            _accounts = accountsTask.Result;
            if (_doc is not null)
            {
                var vendor = await VendorClient.GetByIdAsync(_doc.VendorId);
                _vendorName = vendor?.DisplayName ?? "—";
            }
            ApplyHeader();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _isLoading = false; }
    }

    private void ApplyHeader()
    {
        if (_doc is null) return;
        _pageTitle = _doc.DisplayNumber;
        _header = new PageHeaderModel
        {
            Eyebrow = "Expense & Bills",
            Title = _doc.DisplayNumber,
            Subtitle = $"{_vendorName} · {HumanizeStatus(_doc.Status)}"
        };
    }

    private string ResolveAccountLabel(Guid accountId)
    {
        var account = _accounts.FirstOrDefault(a => a.Id == accountId);
        return account is null ? accountId.ToString("D") : $"{account.Code}  {account.Name}";
    }

    // Copy A3 Phase 3.
    private void CopyAsync()
    {
        if (_doc is null) return;
        Navigation.NavigateTo($"vendor-credits/new?copyFrom={_doc.Id:D}");
    }

    private IReadOnlyList<CitusMoreMenuItem> _moreItems => _doc is null
        ? Array.Empty<CitusMoreMenuItem>()
        : new[]
        {
            new CitusMoreMenuItem { Label = "Copy", OnClick = EventCallback.Factory.Create(this, CopyAsync) }
        };

    private static string HumanizeStatus(string status) => status switch
    {
        "draft" => "Draft", "posted" => "Posted", "voided" => "Voided", "reversed" => "Reversed", _ => status
    };
}
