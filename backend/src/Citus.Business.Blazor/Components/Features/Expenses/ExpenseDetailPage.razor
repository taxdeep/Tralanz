@page "/expenses/{ExpenseId:guid}"

@inject BusinessShellState ShellState
@inject ExpenseClient ExpenseClient
@inject AccountClient AccountClient
@inject CitusToastService Message
@inject NavigationManager Navigation

<PageTitle>@($"{_pageTitle} | Tralanz Books")</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusLinkButton Href="expenses"
                         Variant="CitusButtonVariant.Ghost"
                         LeadingIcon="IconName.ArrowLeft">
            Back to expenses
        </CitusLinkButton>
    </Actions>
</CitusPageHeader>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_error" ShowIcon="true" Class="mb-4" />
}

@if (_isLoading)
{
    <CitusSkeleton Variant="SkeletonVariant.Detail" />
}
else if (_expense is null)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="Expense not found in this company." ShowIcon="true" />
}
else
{
    <CitusStatCardGrid Columns="4">
        <CitusStatCard Label="Expense #" Value="@_expense.ExpenseNumber" Description="@_expense.PayeeNameFreeform"
                       Icon="IconName.Wallet" Tone="StatTone.Primary" />
        <CitusStatCard Label="Status" Value="@HumanizeStatus(_expense.Status)"
                       Description="@(_expense.VoidedAt is { } v ? $"Voided {v.ToLocalTime():yyyy-MM-dd HH:mm}" : "Posted")"
                       Icon="IconName.Eye" Tone="@CitusDocumentStatusBadge.ResolveTone(_expense.Status)" />
        <CitusStatCard Label="Total" Value="@($"{_expense.TotalAmount:N2} {_expense.TransactionCurrencyCode}")"
                       Description="@($"Paid via {HumanizeMethod(_expense.PaymentMethod)}")"
                       Icon="IconName.Coin" Tone="StatTone.Success" />
        <CitusStatCard Label="Payment date"
                       Value="@_expense.PaymentDate.ToString("yyyy-MM-dd")"
                       Description="@_expense.PaymentAccountLabel"
                       Icon="IconName.Calendar" Tone="StatTone.Neutral" />
    </CitusStatCardGrid>

    @* Copy A3 Phase 1: secondary actions collapse into the More
       menu. Copy is always available (even on voided expenses —
       you may want to revive the spend with corrections); Void
       only available on posted (server still re-checks). The
       Void label intentionally NOT promoted to a top-level
       button so the action bar stays single-row uncluttered. *@
    <CitusActionsPanel MoreMenuItems="@_moreItems">
        @if (_expense.SourcePurchaseOrderId is { } poId)
        {
            <CitusLinkButton Href="@($"purchase-orders/{poId:D}")"
                             Variant="CitusButtonVariant.Ghost">
                View source PO
            </CitusLinkButton>
        }
        @if (_expense.Status != "posted")
        {
            <span class="text-fg-muted text-sm">This expense is voided.</span>
        }
    </CitusActionsPanel>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-8">
            <CitusFormSection Title="Lines">
                <table class="citus-data-table">
                    <thead>
                        <tr>
                            <th style="width: 3rem">#</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th class="text-right" style="width: 5rem">Qty</th>
                            <th class="text-right" style="width: 7rem">Rate</th>
                            <th class="text-right" style="width: 8rem">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in _expense.Lines)
                        {
                            <tr>
                                <td>@line.Sequence</td>
                                <td>@ResolveAccountLabel(line.ExpenseAccountId)</td>
                                <td>@(string.IsNullOrEmpty(line.Description) ? "—" : line.Description)</td>
                                <td class="text-right">@line.Quantity.ToString("0.##")</td>
                                <td class="text-right">@line.UnitPrice.ToString("0.0000")</td>
                                <td class="text-right">@line.LineTotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </CitusFormSection>

            @if (!string.IsNullOrWhiteSpace(_expense.Memo) || !string.IsNullOrWhiteSpace(_expense.InternalNote))
            {
                <CitusFormSection Title="Notes">
                    <CitusKeyValueTable>
                        @if (!string.IsNullOrWhiteSpace(_expense.Memo))
                        {
                            <CitusKeyValueRow Label="Memo">@_expense.Memo</CitusKeyValueRow>
                        }
                        @if (!string.IsNullOrWhiteSpace(_expense.InternalNote))
                        {
                            <CitusKeyValueRow Label="Internal note">@_expense.InternalNote</CitusKeyValueRow>
                        }
                    </CitusKeyValueTable>
                </CitusFormSection>
            }
        </div>

        <aside class="lg:col-span-4 flex flex-col gap-6">
            <CitusFormSection Title="Payment">
                <CitusKeyValueTable>
                    <CitusKeyValueRow Label="Payee">@(string.IsNullOrEmpty(_expense.PayeeNameFreeform) ? "—" : _expense.PayeeNameFreeform)</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Paid from">@_expense.PaymentAccountLabel</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Method">@HumanizeMethod(_expense.PaymentMethod)</CitusKeyValueRow>
                    @if (!string.IsNullOrEmpty(_expense.ChequeNumber))
                    {
                        <CitusKeyValueRow Label="Cheque #"><span class="citus-inline-code">@_expense.ChequeNumber</span></CitusKeyValueRow>
                    }
                    @if (!string.IsNullOrEmpty(_expense.RefNo))
                    {
                        <CitusKeyValueRow Label="Reference #"><span class="citus-inline-code">@_expense.RefNo</span></CitusKeyValueRow>
                    }
                    <CitusKeyValueRow Label="Currency">
                        @_expense.TransactionCurrencyCode
                        @(_expense.TransactionCurrencyCode == _expense.BaseCurrencyCode ? "" : $"@ {_expense.FxRate}")
                    </CitusKeyValueRow>
                    <CitusKeyValueRow Label="Source PO">@(string.IsNullOrEmpty(_expense.SourcePurchaseOrderNumber) ? "—" : _expense.SourcePurchaseOrderNumber)</CitusKeyValueRow>
                </CitusKeyValueTable>
            </CitusFormSection>

            <CitusFormSection Title="Totals">
                <CitusKeyValueTable>
                    <CitusKeyValueRow Label="Subtotal" ValueAlignRight="true">@_expense.SubtotalAmount.ToString("N2")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Discount" ValueAlignRight="true">−@_expense.DiscountAmount.ToString("N2")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Tax" ValueAlignRight="true">@_expense.TaxAmount.ToString("N2")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Total" ValueAlignRight="true"><strong>@_expense.TotalAmount.ToString("N2") @_expense.TransactionCurrencyCode</strong></CitusKeyValueRow>
                    @if (_expense.TransactionCurrencyCode != _expense.BaseCurrencyCode)
                    {
                        <CitusKeyValueRow Label="@($"Total ({_expense.BaseCurrencyCode})")" ValueAlignRight="true">@((_expense.TotalAmount * _expense.FxRate).ToString("N2"))</CitusKeyValueRow>
                    }
                </CitusKeyValueTable>
            </CitusFormSection>
        </aside>
    </div>
}

@code {
    [Parameter] public Guid ExpenseId { get; set; }

    private ExpenseRecordDto? _expense;
    private IReadOnlyList<AccountSummary> _accounts = Array.Empty<AccountSummary>();
    private bool _isLoading = true;
    private bool _isMutating;
    private string? _error;

    private PageHeaderModel _header = new() { Eyebrow = "Expense & Bills", Title = "Expense", Subtitle = "Expense detail" };
    private string _pageTitle = "Expense";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override async Task OnParametersSetAsync()
    {
        if (_expense is not null && _expense.Id != ExpenseId)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            var expenseTask = ExpenseClient.GetByIdAsync(ExpenseId);
            var accountsTask = AccountClient.ListAsync();
            await Task.WhenAll(expenseTask, accountsTask);
            _expense = expenseTask.Result;
            _accounts = accountsTask.Result;
            ApplyHeader();
        }
        finally { _isLoading = false; }
    }

    private void ApplyHeader()
    {
        if (_expense is null)
        {
            _pageTitle = "Expense";
            _header = new PageHeaderModel { Eyebrow = "Expense & Bills", Title = "Expense", Subtitle = "Expense detail" };
            return;
        }
        _pageTitle = _expense.ExpenseNumber;
        _header = new PageHeaderModel
        {
            Eyebrow = "Expense & Bills",
            Title = _expense.ExpenseNumber,
            Subtitle = $"{_expense.PayeeNameFreeform} · {HumanizeStatus(_expense.Status)}"
        };
    }

    private string ResolveAccountLabel(Guid accountId)
    {
        var account = _accounts.FirstOrDefault(a => a.Id == accountId);
        return account is null ? accountId.ToString("D") : $"{account.Code}  {account.Name}";
    }

    private async Task VoidAsync()
    {
        if (_expense is null || _isMutating) return;
        _isMutating = true;
        try
        {
            var outcome = await ExpenseClient.VoidAsync(_expense.Id);
            if (!outcome.Succeeded)
            {
                _error = outcome.ErrorMessage ?? "Void failed.";
                await Message.WarningAsync(_error);
                return;
            }
            _expense = outcome.Saved;
            ApplyHeader();
            await Message.SuccessAsync("Expense voided.");
        }
        finally { _isMutating = false; }
    }

    // Copy A3 Phase 1: navigate to the Create page with the source id
    // as a query param. The Create page hydrates its form fields from
    // the source's ExpenseRecordDto and resets the payment date to
    // today. We deliberately don't gate Copy on the status — copying a
    // voided expense is a valid workflow ("re-issue with corrections")
    // and the new entity is independent of the source's state.
    private void CopyAsync()
    {
        if (_expense is null) return;
        Navigation.NavigateTo($"expenses/new?copyFrom={_expense.Id:D}");
    }

    private IReadOnlyList<CitusMoreMenuItem> _moreItems => _expense is null
        ? Array.Empty<CitusMoreMenuItem>()
        : new[]
        {
            new CitusMoreMenuItem
            {
                Label = "Copy",
                OnClick = EventCallback.Factory.Create(this, CopyAsync),
                Disabled = _isMutating
            },
            new CitusMoreMenuItem
            {
                Label = "Void",
                Danger = true,
                Disabled = _expense.Status != "posted" || _isMutating,
                OnClick = EventCallback.Factory.Create(this, VoidAsync)
            }
        };

    private static string HumanizeStatus(string status) => status switch
    {
        "posted" => "Posted",
        "voided" => "Voided",
        _ => status
    };

    private static string HumanizeMethod(string method) => method switch
    {
        "cash" => "Cash",
        "cheque" => "Cheque",
        "credit_card" => "Credit Card",
        "wire" => "Wire",
        "direct_deposit" => "Direct Deposit",
        "eft" => "EFT",
        "other" => "Other",
        _ => method
    };
}
