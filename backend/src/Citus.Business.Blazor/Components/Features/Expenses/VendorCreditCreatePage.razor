@page "/vendor-credits/new"

@using Citus.Modules.UnitySearch.Blazor
@using Citus.Modules.UnitySearch.Domain.Shared

@inject BusinessShellState ShellState
@inject BusinessWriteFlowClient WriteFlow
@inject VendorClient VendorClient
@inject VendorCreditClient VendorCreditClient
@inject AccountClient AccountClient
@inject NavigationManager NavigationManager
@inject CitusToastService Message

@*
    VendorCreditCreatePage — AP-side mirror of CreditMemoCreatePage.
    Same structure, vendor instead of customer, expense / asset
    accounts on the lines instead of revenue.

    GL on post:
      Cr Expense / Asset (per line)  | reverses the original bill's debit row
      Cr Tax Receivable (ITC) row    | reversal of the original input tax credit
      Dr Accounts Payable            | reduces what we owe the vendor
*@

<PageTitle>New Vendor Credit | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusLinkButton Href="bills"
                         Variant="CitusButtonVariant.Ghost"
                         LeadingIcon="IconName.ArrowLeft">
            Back to bills
        </CitusLinkButton>
    </Actions>
</CitusPageHeader>

@if (ShellState.AreWritesBlocked)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" ShowIcon="true" Message="@ShellState.WriteBlockMessage" Class="mb-4" />
}

@if (_isFromCopy)
{
    <CitusAlert Severity="CitusAlertSeverity.Info" ShowIcon="true" Class="mb-4"
                Message="This is a copy. Revise as needed and save to create a new vendor credit; the original is unchanged." />
}

@if (!string.IsNullOrWhiteSpace(_validation))
{
    <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_validation" ShowIcon="true" Class="mb-4" />
}

<WriteFlowResultAlert Result="@_lastResult" />

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <div class="lg:col-span-8 flex flex-col gap-6">
        <CitusFormSection Title="Header">
            <CitusFormGrid Columns="2">
                <CitusFormField Label="Credit date">
                    <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_documentDate" Class="citus-control-full" />
                </CitusFormField>
                <CitusFormField Label="Vendor">
                    <VendorPicker CompanyId="@ShellState.ActiveCompany.Id"
                                       UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                       Placeholder="Search vendors…"
                                       Take="8"
                                       SourceRoute="/vendor-credits/new"
                                       SelectedId="@(_vendorId == Guid.Empty ? null : _vendorId)"
                                       SelectedDisplayText="@_vendorDisplay"
                                       OnVendorSelected="OnVendorSelected"
                                       OnCleared="OnVendorCleared" />
                </CitusFormField>
                <CitusFormField Label="Exchange rate">
                    @if (_vendorId == Guid.Empty)
                    {
                        <div class="citus-form-field__input citus-form-field__input--readonly flex items-center">
                            <span class="text-fg-subtle">Pick a vendor first</span>
                        </div>
                    }
                    else
                    {
                        <FxRateInline DocumentDate="@(DateOnly.FromDateTime((_documentDate ?? DateTime.Today).Date))"
                                      BaseCurrencyCode="@ShellState.ActiveCompany.BaseCurrencyCode"
                                      QuoteCurrencyCode="@_currency"
                                      @bind-Rate="_fxRate" />
                    }
                </CitusFormField>
                @* Same lookup contract as CreditMemo's apply-to-
                   invoice: backend resolves (company_id, bill
                   display_number) at post-time. Leaving blank
                   issues a standalone vendor credit. *@
                <CitusFormField Label="Apply to bill (optional)">
                    <CitusInput TValue="string" @bind-Value="_appliedToBillNumber" Placeholder="e.g. BILL-2026-0042" />
                    @if (!string.IsNullOrWhiteSpace(_appliedToBillNumber) && !LooksLikeDocumentNumber(_appliedToBillNumber))
                    {
                        <p class="text-fg-warning text-xs mt-1">
                            Use the bill's display number (alphanumerics, dashes, underscores). Backend will reject anything it can't resolve in this company.
                        </p>
                    }
                </CitusFormField>
            </CitusFormGrid>
            <CitusFormField Label="Reason" Class="mt-4">
                <CitusInput TValue="string" @bind-Value="_reason" Placeholder="Return / quality issue / volume rebate / dispute..." />
            </CitusFormField>
            <CitusFormField Label="Memo" Class="mt-4">
                <CitusInput TValue="string" @bind-Value="_memo" Placeholder="Internal note; optional." />
            </CitusFormField>
        </CitusFormSection>

        <CitusFormSection Title="Lines">
            <HeaderActions>
                <CitusButton LeadingIcon="IconName.Plus" Size="CitusButtonSize.Small" OnClick="AddLine">Add line</CitusButton>
            </HeaderActions>
            <ChildContent>
            <table class="citus-data-table citus-data-table--compact">
                <thead>
                    <tr>
                        <th style="width: 2.25rem"></th>
                        <th>Description</th>
                        <th class="text-right" style="width: 6rem">Qty</th>
                        <th class="text-right" style="width: 9rem">Unit price</th>
                        <th style="width: 7rem">Account</th>
                        <th style="width: 6rem">Tax</th>
                        <th class="text-right" style="width: 9rem">Line total</th>
                        <th style="width: 3rem"></th>
                    </tr>
                </thead>
                <tbody>
                    @for (var index = 0; index < _lines.Count; index++)
                    {
                        var i = index;
                        var line = _lines[i];
                        <tr>
                            <td>
                                <button type="button" class="citus-icon-button" title="Insert line below" @onclick="() => InsertLineAfter(i)">
                                    <CitusIcon Name="IconName.Plus" Size="IconSize.Inline" />
                                </button>
                            </td>
                            <td><CitusInput TValue="string" Value="@line.Description" ValueChanged="@(v => Update(i, l => l with { Description = v ?? string.Empty }))" Size="CitusButtonSize.Small" Placeholder="Free-form description" /></td>
                            <td><RadzenNumeric TValue="decimal" Value="@line.Quantity" ValueChanged="@(v => Update(i, l => l with { Quantity = v }))" Min="0" Class="citus-control-full" /></td>
                            <td><RadzenNumeric TValue="decimal" Value="@line.UnitPrice" ValueChanged="@(v => Update(i, l => l with { UnitPrice = v }))" Min="0" Class="citus-control-full" /></td>
                            <td>
                                @* Same expense filter as ExpenseCreatePage line-Category — never surface revenue accounts on a vendor credit. *@
                                <AccountPicker CompanyId="@ShellState.ActiveCompany.Id"
                                               UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                               Context="vendor_credit.line.category"
                                               AllowedRootTypes="expense,asset,cost_of_sales"
                                               SelectedId="@line.AccountId"
                                               SelectedDisplayText="@line.AccountDisplay"
                                               Placeholder="Pick a category..."
                                               DefaultCurrencyCode="@ShellState.ActiveCompany.BaseCurrencyCode"
                                               OnAccountSelected="@(account => OnAccountSelected(i, account))"
                                               OnCleared="@(() => OnAccountCleared(i))" />
                            </td>
                            <td>
                                <TaxCodePicker SelectedId="@line.TaxCodeId"
                                               SelectedDisplayText="@line.TaxCode"
                                               AppliesTo="purchase"
                                               Placeholder="Tax"
                                               OnTaxCodeSelected="@(tax => OnTaxCodeSelected(i, tax))"
                                               OnCleared="@(() => OnTaxCodeCleared(i))" />
                            </td>
                            <td class="text-right">@FormatAmount(line.Quantity * line.UnitPrice)</td>
                            <td>
                                <button type="button" class="citus-icon-button" title="Remove line" @onclick="() => RemoveLine(i)">
                                    <CitusIcon Name="IconName.Trash" Size="IconSize.Inline" />
                                </button>
                            </td>
                        </tr>
                    }
                    <tr class="citus-data-table__total">
                        <td colspan="6" class="text-right font-medium">Total</td>
                        <td class="text-right font-semibold">@FormatAmount(_total)</td>
                        <td></td>
                    </tr>
                </tbody>
            </table>
            </ChildContent>
        </CitusFormSection>
    </div>

    <div class="lg:col-span-4 flex flex-col gap-6">
        <CitusFormSection Title="Summary">
            <CitusKeyValueTable>
                <CitusKeyValueRow Label="Company">@ShellState.ActiveCompany.CompanyName</CitusKeyValueRow>
                <CitusKeyValueRow Label="Lines">@_lines.Count</CitusKeyValueRow>
                <CitusKeyValueRow Label="Subtotal">@FormatAmount(_total)</CitusKeyValueRow>
                <CitusKeyValueRow Label="Currency">@_currency.ToUpperInvariant()</CitusKeyValueRow>
                @if (!string.IsNullOrWhiteSpace(_appliedToBillNumber))
                {
                    <CitusKeyValueRow Label="Applied to">@_appliedToBillNumber</CitusKeyValueRow>
                }
                @if (!string.Equals(_currency, ShellState.ActiveCompany.BaseCurrencyCode, StringComparison.OrdinalIgnoreCase))
                {
                    <CitusKeyValueRow Label="FX rate">@(_fxRate.HasValue ? _fxRate.Value.ToString("0.000000") : "—")</CitusKeyValueRow>
                }
            </CitusKeyValueTable>
        </CitusFormSection>

        <CitusFormSection Title="Post vendor credit">
            <p class="text-fg-muted text-sm m-0">
                Posting reverses the line expense / asset entries, reverses the input-tax (ITC) row, and debits AP
                @(string.IsNullOrWhiteSpace(_appliedToBillNumber)
                    ? " — issued as a standalone vendor credit."
                    : $" — applied directly against {_appliedToBillNumber}.")
            </p>
        </CitusFormSection>
    </div>
</div>

@* Sticky Post action — single primary button (no Cancel; vendor
   credits have no Save Draft pathway, Back navigates away). *@
<CitusFormActions Sticky="true"
                  PrimaryLabel="Post vendor credit"
                  SavingLabel="Posting..."
                  CancelVisible="false"
                  IsSaving="@_isSubmitting"
                  Disabled="@(_lines.Count == 0 || _total <= 0 || ShellState.AreWritesBlocked)"
                  ErrorHint="@(string.IsNullOrWhiteSpace(_validation) ? null : "Fix errors above")"
                  OnSave="PostAsync" />

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Expense & Bills",
        Title = "New vendor credit",
        Subtitle = "Purchase-side reversal. Posting debits AP (or applies against a specific bill)."
    };

    private DateTime? _documentDate = DateTime.Today;
    private Guid _vendorId;
    private string _vendorDisplay = string.Empty;
    private string _currency = string.Empty;
    private decimal? _fxRate;
    private string _appliedToBillNumber = string.Empty;
    private string _reason = string.Empty;
    private string _memo = string.Empty;

    private sealed record VendorCreditLineEditState(
        string Description = "",
        decimal Quantity = 1m,
        decimal UnitPrice = 0m,
        Guid? AccountId = null,
        string AccountDisplay = "",
        string AccountCode = "",
        Guid? TaxCodeId = null,
        string TaxCode = "")
    {
        public bool HasContent =>
            !string.IsNullOrWhiteSpace(Description)
            || !string.IsNullOrWhiteSpace(AccountCode)
            || !string.IsNullOrWhiteSpace(TaxCode)
            || UnitPrice > 0m;
    }

    private readonly List<VendorCreditLineEditState> _lines = new() { new VendorCreditLineEditState() };
    private bool _isSubmitting;
    private string? _validation;
    private WriteFlowResult? _lastResult;
    // Phase 3.1
    private bool _isFromCopy;

    [SupplyParameterFromQuery(Name = "copyFrom")] public Guid? CopyFromCreditId { get; set; }

    private decimal _total => _lines.Sum(l => l.Quantity * l.UnitPrice);

    protected override async Task OnInitializedAsync()
    {
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;
        if (CopyFromCreditId is { } id && id != Guid.Empty)
        {
            await TryHydrateFromCopySourceAsync(id);
        }
    }

    /// <summary>Phase 3.1: hydrate from an existing vendor credit.</summary>
    private async Task TryHydrateFromCopySourceAsync(Guid sourceId)
    {
        VendorCreditRecordDto? source;
        try
        {
            source = await VendorCreditClient.GetByIdAsync(sourceId, ShellState.ActiveCompany.Id);
        }
        catch { return; }
        if (source is null)
        {
            _validation = "The vendor credit you copied from is not visible in this company.";
            return;
        }

        var vendor = await VendorClient.GetByIdAsync(source.VendorId);
        var accounts = await AccountClient.ListAsync();
        var byId = accounts.ToDictionary(a => a.Id);

        _isFromCopy = true;
        _vendorId = source.VendorId;
        _vendorDisplay = vendor?.DisplayName ?? string.Empty;
        _currency = source.TransactionCurrencyCode;
        _documentDate = DateTime.Today;
        _fxRate = null;
        _memo = source.Memo ?? string.Empty;
        _appliedToBillNumber = string.Empty;  // Don't carry the apply-to link
        _reason = string.Empty;

        _lines.Clear();
        foreach (var line in source.Lines.OrderBy(l => l.LineNumber))
        {
            var displ = line.ExpenseAccountId is { } rid && byId.TryGetValue(rid, out var a) ? $"{a.Code}  {a.Name}" : string.Empty;
            var code = line.ExpenseAccountId is { } rid2 && byId.TryGetValue(rid2, out var a2) ? a2.Code : string.Empty;
            // VendorCreditLineDto carries only LineAmount (no per-unit
            // Qty/Price split), so we copy the line total as a 1×price row.
            _lines.Add(new VendorCreditLineEditState(
                Description: line.Description ?? string.Empty,
                Quantity: 1m, UnitPrice: line.LineAmount,
                AccountId: line.ExpenseAccountId, AccountDisplay: displ, AccountCode: code,
                TaxCodeId: null, TaxCode: string.Empty));
        }
        if (_lines.Count == 0) _lines.Add(new VendorCreditLineEditState());
    }

    private async Task OnVendorSelected(UnitySearchPickerOption option)
    {
        _vendorId = option.SourceId;
        _vendorDisplay = option.DisplayText;
        var vendor = await VendorClient.GetByIdAsync(_vendorId);
        if (vendor is not null && !string.IsNullOrWhiteSpace(vendor.DefaultCurrencyCode))
        {
            _currency = vendor.DefaultCurrencyCode;
        }
    }

    private void OnVendorCleared()
    {
        _vendorId = Guid.Empty;
        _vendorDisplay = string.Empty;
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;
    }

    private void AddLine() => _lines.Add(new VendorCreditLineEditState());

    private void RemoveLine(int i)
    {
        if (i < 0 || i >= _lines.Count) return;
        _lines.RemoveAt(i);
        if (_lines.Count == 0) _lines.Add(new VendorCreditLineEditState());
    }

    private void InsertLineAfter(int i)
    {
        if (i < 0 || i >= _lines.Count) return;
        _lines.Insert(i + 1, new VendorCreditLineEditState());
    }

    private void Update(int i, Func<VendorCreditLineEditState, VendorCreditLineEditState> mutate)
    {
        if (i < 0 || i >= _lines.Count) return;
        _lines[i] = mutate(_lines[i]);
        EnsureTrailingBlankLine();
    }

    private void EnsureTrailingBlankLine()
    {
        if (_lines.Count == 0) { _lines.Add(new VendorCreditLineEditState()); return; }
        if (_lines[^1].HasContent) _lines.Add(new VendorCreditLineEditState());
    }

    private void OnAccountSelected(int i, AccountSummary account)
    {
        Update(i, l => l with
        {
            AccountId = account.Id,
            AccountDisplay = $"{account.Code} {account.Name}",
            AccountCode = account.Code
        });
    }

    private void OnAccountCleared(int i)
        => Update(i, l => l with { AccountId = null, AccountDisplay = string.Empty, AccountCode = string.Empty });

    private void OnTaxCodeSelected(int i, TaxCodeSummary tax)
        => Update(i, l => l with { TaxCodeId = tax.Id, TaxCode = tax.Code });

    private void OnTaxCodeCleared(int i)
        => Update(i, l => l with { TaxCodeId = null, TaxCode = string.Empty });

    private async Task PostAsync()
    {
        _validation = null;
        _lastResult = null;

        if (_vendorId == Guid.Empty) { _validation = "Pick a vendor first."; return; }
        var meaningful = _lines.Where(l => l.HasContent).ToArray();
        if (meaningful.Length == 0) { _validation = "Add at least one line."; return; }
        if (meaningful.Any(l => string.IsNullOrWhiteSpace(l.Description))) { _validation = "Every line needs a description."; return; }
        if (meaningful.Any(l => string.IsNullOrWhiteSpace(l.AccountCode))) { _validation = "Every line needs a category account code."; return; }
        var total = meaningful.Sum(l => l.Quantity * l.UnitPrice);
        if (total <= 0) { _validation = "Vendor credit total must be greater than zero."; return; }

        _isSubmitting = true;
        try
        {
            if (meaningful.Any(l => l.AccountId is null || l.AccountId == Guid.Empty))
            {
                _validation = "Every line needs a category account picked from the dropdown (not a free-typed code).";
                return;
            }

            var draft = new VendorCreditDraft
            {
                CompanyId = ShellState.ActiveCompany.Id,
                UserId = ShellState.User.Id,
                DocumentDate = DateOnly.FromDateTime((_documentDate ?? DateTime.Today).Date),
                VendorId = _vendorId,
                TransactionCurrencyCode = _currency.Trim().ToUpperInvariant(),
                BaseCurrencyCode = ShellState.ActiveCompany.BaseCurrencyCode.Trim().ToUpperInvariant(),
                FxRate = _fxRate,
                AppliedToBillNumber = _appliedToBillNumber.Trim(),
                Reason = _reason.Trim(),
                Memo = _memo.Trim(),
                Lines = meaningful.Select((l, idx) => new VendorCreditLineDraft
                {
                    LineNumber = idx + 1,
                    ExpenseAccountId = l.AccountId!.Value,
                    Description = l.Description,
                    LineAmount = l.Quantity * l.UnitPrice,
                    TaxCodeId = l.TaxCodeId,
                    TaxAmount = 0m,
                }).ToArray()
            };
            _lastResult = await WriteFlow.PostVendorCreditAsync(draft);
            if (_lastResult.Succeeded)
            {
                await Message.SuccessAsync("Vendor credit posted.");
                NavigationManager.NavigateTo(_lastResult.DocumentId is { } id ? $"vendor-credits/{id:D}" : "vendor-credits");
            }
            else { await Message.InfoAsync(_lastResult.Message); }
        }
        finally { _isSubmitting = false; }
    }

    private static string FormatAmount(decimal amount) => amount.ToString("N2");

    /// <summary>
    /// Twin of CreditMemoCreatePage.LooksLikeDocumentNumber — keeping
    /// the helpers per-page (rather than a shared static) makes the
    /// validation rules visible at the call site. If a third page
    /// adopts the same gate, hoist to a shared util at that point.
    /// </summary>
    private static bool LooksLikeDocumentNumber(string value) =>
        System.Text.RegularExpressions.Regex.IsMatch(value.Trim(), @"^[A-Za-z0-9_\-./]+$");
}
