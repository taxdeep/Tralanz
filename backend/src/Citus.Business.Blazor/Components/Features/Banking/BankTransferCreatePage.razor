@page "/bank-transfers/new"

@inject BusinessShellState ShellState
@inject BusinessWriteFlowClient WriteFlow
@inject NavigationManager NavigationManager
@inject CitusToastService Message

@*
    BankTransferCreatePage — internal asset-account transfer.
    Operating → Savings, USD wallet → CAD wallet, etc. The whole
    thing is one journal entry: debit the destination, credit the
    source. Cross-currency transfers carry an FX rate so the base-
    currency rows balance even when the typed amounts on the two
    accounts differ.

    Built from scratch (not a line-item document); the shell + atom
    rhythm matches the rest of the app though, so the operator
    feels at home.
*@

<PageTitle>New Account Transfer | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusLinkButton Href="reconciliation"
                         Variant="CitusButtonVariant.Ghost"
                         LeadingIcon="IconName.ArrowLeft">
            Back to banking
        </CitusLinkButton>
    </Actions>
</CitusPageHeader>

@if (ShellState.AreWritesBlocked)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" ShowIcon="true" Message="@ShellState.WriteBlockMessage" Class="mb-4" />
}

@if (!string.IsNullOrWhiteSpace(_validation))
{
    <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_validation" ShowIcon="true" Class="mb-4" />
}

<WriteFlowResultAlert Result="@_lastResult" />

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <div class="lg:col-span-8 flex flex-col gap-6">
        <CitusFormSection Title="Transfer">
            <CitusFormGrid Columns="2">
                <CitusFormField Label="Transfer date">
                    <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_documentDate" Class="citus-control-full" />
                </CitusFormField>
                <CitusFormField Label="Reference #">
                    <CitusInput TValue="string" @bind-Value="_referenceNo" Placeholder="Bank transfer ID, wire ref, etc." />
                </CitusFormField>

                @* Source account — credited (money leaves). Asset
                   only: bank / cash / credit-card / wallet. *@
                <CitusFormField Label="From account">
                    <AccountPicker CompanyId="@ShellState.ActiveCompany.Id"
                                   UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                   Context="bank_transfer.from"
                                   AllowedRootTypes="asset"
                                   SelectedId="@_fromAccountId"
                                   SelectedDisplayText="@_fromAccountDisplay"
                                   Placeholder="Source bank / cash / wallet…"
                                   OnAccountSelected="OnFromAccountSelected"
                                   OnCleared="OnFromAccountCleared" />
                </CitusFormField>
                @* Destination — debited. Same asset filter; UI
                   blocks picking the same account on both sides
                   (clientside validation only — backend re-checks). *@
                <CitusFormField Label="To account">
                    <AccountPicker CompanyId="@ShellState.ActiveCompany.Id"
                                   UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                   Context="bank_transfer.to"
                                   AllowedRootTypes="asset"
                                   SelectedId="@_toAccountId"
                                   SelectedDisplayText="@_toAccountDisplay"
                                   Placeholder="Destination bank / cash / wallet…"
                                   OnAccountSelected="OnToAccountSelected"
                                   OnCleared="OnToAccountCleared" />
                </CitusFormField>

                <CitusFormField Label="@($"Amount{(string.IsNullOrEmpty(_fromCurrency) ? string.Empty : $" ({_fromCurrency})")}")">
                    <input type="text"
                           inputmode="decimal"
                           class="citus-form-field__input"
                           value="@FormatDecimal(_amount)"
                           @oninput="OnAmountInput" />
                </CitusFormField>
                @* FX shows only when the two currencies differ —
                   same convention as Invoice / Bill. *@
                @if (NeedsFx)
                {
                    <CitusFormField Label="@($"FX rate ({_fromCurrency} → {_toCurrency})")">
                        <FxRateInline DocumentDate="@(DateOnly.FromDateTime((_documentDate ?? DateTime.Today).Date))"
                                      BaseCurrencyCode="@_fromCurrency"
                                      QuoteCurrencyCode="@_toCurrency"
                                      @bind-Rate="_fxRate" />
                    </CitusFormField>
                }
                else if (string.IsNullOrEmpty(_fromCurrency) || string.IsNullOrEmpty(_toCurrency))
                {
                    <CitusFormField Label="FX rate">
                        <div class="citus-form-field__input citus-form-field__input--readonly flex items-center">
                            <span class="text-fg-subtle">Pick both accounts first</span>
                        </div>
                    </CitusFormField>
                }
                else
                {
                    <CitusFormField Label="FX rate">
                        <div class="citus-form-field__input citus-form-field__input--readonly flex items-center">
                            <span class="text-fg-subtle">Same currency — no FX needed</span>
                        </div>
                    </CitusFormField>
                }
            </CitusFormGrid>
            <CitusFormField Label="Memo" Class="mt-4">
                <CitusInput TValue="string" @bind-Value="_memo" Placeholder="Internal note; optional." />
            </CitusFormField>
        </CitusFormSection>
    </div>

    <div class="lg:col-span-4 flex flex-col gap-6">
        <CitusFormSection Title="Summary">
            <CitusKeyValueTable>
                <CitusKeyValueRow Label="Company">@ShellState.ActiveCompany.CompanyName</CitusKeyValueRow>
                <CitusKeyValueRow Label="From">@(string.IsNullOrEmpty(_fromAccountDisplay) ? "—" : _fromAccountDisplay)</CitusKeyValueRow>
                <CitusKeyValueRow Label="To">@(string.IsNullOrEmpty(_toAccountDisplay) ? "—" : _toAccountDisplay)</CitusKeyValueRow>
                <CitusKeyValueRow Label="Amount out">@FormatAmount(_amount) @_fromCurrency</CitusKeyValueRow>
                @if (NeedsFx && _fxRate.HasValue)
                {
                    var converted = Math.Round(_amount * _fxRate.Value, 2);
                    <CitusKeyValueRow Label="Amount in">@FormatAmount(converted) @_toCurrency</CitusKeyValueRow>
                }
                else if (!NeedsFx && !string.IsNullOrEmpty(_toCurrency))
                {
                    <CitusKeyValueRow Label="Amount in">@FormatAmount(_amount) @_toCurrency</CitusKeyValueRow>
                }
            </CitusKeyValueTable>
        </CitusFormSection>

        <CitusFormSection Title="Post transfer">
            <p class="text-fg-muted text-sm m-0">
                Posting credits the source account and debits the
                destination. No counterparty, no AR / AP — purely
                internal cash movement.
            </p>
        </CitusFormSection>
    </div>
</div>

@* Sticky Post action — single primary button (no Cancel; bank
   transfers have no Save Draft pathway, Back navigates away). *@
<CitusFormActions Sticky="true"
                  PrimaryLabel="Post transfer"
                  SavingLabel="Posting..."
                  CancelVisible="false"
                  IsSaving="@_isSubmitting"
                  Disabled="@(_amount <= 0 || _fromAccountId is null || _toAccountId is null || _fromAccountId == _toAccountId || (NeedsFx && !_fxRate.HasValue) || ShellState.AreWritesBlocked)"
                  ErrorHint="@(string.IsNullOrWhiteSpace(_validation) ? null : "Fix errors above")"
                  OnSave="PostAsync" />

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Banking",
        Title = "Account transfer",
        Subtitle = "Move funds between asset accounts. One journal — credit source, debit destination."
    };

    private DateTime? _documentDate = DateTime.Today;
    private string _referenceNo = string.Empty;
    private string _memo = string.Empty;

    private Guid? _fromAccountId;
    private string _fromAccountDisplay = string.Empty;
    private string _fromAccountCode = string.Empty;
    private string _fromCurrency = string.Empty;

    private Guid? _toAccountId;
    private string _toAccountDisplay = string.Empty;
    private string _toAccountCode = string.Empty;
    private string _toCurrency = string.Empty;

    private decimal _amount;
    private decimal? _fxRate;

    private bool _isSubmitting;
    private string? _validation;
    private WriteFlowResult? _lastResult;

    private bool NeedsFx =>
        !string.IsNullOrEmpty(_fromCurrency) &&
        !string.IsNullOrEmpty(_toCurrency) &&
        !string.Equals(_fromCurrency, _toCurrency, StringComparison.OrdinalIgnoreCase);

    private void OnFromAccountSelected(AccountSummary account)
    {
        _fromAccountId = account.Id;
        _fromAccountDisplay = $"{account.Code} {account.Name}";
        _fromAccountCode = account.Code;
        _fromCurrency = account.CurrencyCode ?? ShellState.ActiveCompany.BaseCurrencyCode;
    }

    private void OnFromAccountCleared()
    {
        _fromAccountId = null;
        _fromAccountDisplay = string.Empty;
        _fromAccountCode = string.Empty;
        _fromCurrency = string.Empty;
    }

    private void OnToAccountSelected(AccountSummary account)
    {
        _toAccountId = account.Id;
        _toAccountDisplay = $"{account.Code} {account.Name}";
        _toAccountCode = account.Code;
        _toCurrency = account.CurrencyCode ?? ShellState.ActiveCompany.BaseCurrencyCode;
    }

    private void OnToAccountCleared()
    {
        _toAccountId = null;
        _toAccountDisplay = string.Empty;
        _toAccountCode = string.Empty;
        _toCurrency = string.Empty;
    }

    private void OnAmountInput(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? string.Empty;
        _amount = decimal.TryParse(raw, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : 0m;
    }

    private async Task PostAsync()
    {
        _validation = null;
        _lastResult = null;

        if (_fromAccountId is null) { _validation = "Pick a source account."; return; }
        if (_toAccountId is null) { _validation = "Pick a destination account."; return; }
        if (_fromAccountId == _toAccountId) { _validation = "Source and destination must be different accounts."; return; }
        if (_amount <= 0) { _validation = "Transfer amount must be greater than zero."; return; }
        if (NeedsFx && (!_fxRate.HasValue || _fxRate.Value <= 0)) { _validation = "Pick an FX rate for cross-currency transfers."; return; }

        _isSubmitting = true;
        try
        {
            var draft = new BankTransferDraft
            {
                CompanyId = ShellState.ActiveCompany.Id,
                UserId = ShellState.User.Id,
                DocumentDate = DateOnly.FromDateTime((_documentDate ?? DateTime.Today).Date),
                FromAccountId = _fromAccountId,
                FromAccountCode = _fromAccountCode,
                FromCurrencyCode = _fromCurrency,
                ToAccountId = _toAccountId,
                ToAccountCode = _toAccountCode,
                ToCurrencyCode = _toCurrency,
                Amount = _amount,
                FxRate = NeedsFx ? _fxRate : null,
                ReferenceNo = _referenceNo.Trim(),
                Memo = _memo.Trim(),
            };
            _lastResult = await WriteFlow.PostBankTransferAsync(draft);
            if (_lastResult.Succeeded)
            {
                await Message.SuccessAsync("Transfer posted.");
                NavigationManager.NavigateTo(_lastResult.DocumentId is { } id ? $"bank-transfers/{id:D}" : "bank-transfers");
            }
            else { await Message.InfoAsync(_lastResult.Message); }
        }
        finally { _isSubmitting = false; }
    }

    private static string FormatAmount(decimal amount) => amount.ToString("N2");
    private static string FormatDecimal(decimal value) => value == 0m ? string.Empty : value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
}
