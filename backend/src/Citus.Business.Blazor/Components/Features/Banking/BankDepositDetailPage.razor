@page "/bank-deposits/{DepositId:guid}"

@inject BusinessShellState ShellState
@inject BankDepositClient BankDepositClient
@inject AccountClient AccountClient

<PageTitle>@($"{_pageTitle} | Tralanz Books")</PageTitle>

<CitusPageHeader Model="_header">
    <TitleSuffix>
        @if (_doc is not null)
        {
            <CitusDocumentStatusBadge Status="@_doc.Status" />
        }
    </TitleSuffix>
    <Actions>
        <CitusLinkButton Href="bank-deposits/new"
                         Variant="CitusButtonVariant.Ghost"
                         LeadingIcon="IconName.Plus">
            New deposit
        </CitusLinkButton>
    </Actions>
</CitusPageHeader>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_error" ShowIcon="true" Class="mb-4" />
}

@if (_isLoading)
{
    <CitusSkeleton Variant="SkeletonVariant.Detail" />
}
else if (_doc is null)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="Bank deposit not found in this company." ShowIcon="true" />
}
else
{
    <div class="citus-detail-overview">
        <CitusFormSection Title="Deposit">
            <CitusKeyValueTable>
                <CitusKeyValueRow Label="Deposit #"><span class="citus-inline-code">@_doc.DisplayNumber</span></CitusKeyValueRow>
                <CitusKeyValueRow Label="Deposit to">@ResolveAccountLabel(_doc.DepositToAccountId)</CitusKeyValueRow>
                <CitusKeyValueRow Label="Holding account">@ResolveAccountLabel(_doc.UndepositedFundsAccountId)</CitusKeyValueRow>
            </CitusKeyValueTable>
        </CitusFormSection>

        <CitusStatCard Label="Total" Value="@($"{_doc.TotalAmount:N2} {_doc.TransactionCurrencyCode}")"
                       Description="@($"{_doc.Items.Count} item(s)")"
                       Icon="IconName.Coin" Tone="StatTone.Success" />
        <CitusStatCard Label="Deposit date" Value="@_doc.DepositDate.ToString("yyyy-MM-dd")"
                       Description="from Undeposited Funds"
                       Icon="IconName.Calendar" Tone="StatTone.Neutral" />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-8">
            <CitusFormSection Title="Items deposited">
                <table class="citus-data-table">
                    <thead>
                        <tr>
                            <th style="width: 3rem">#</th>
                            <th>Source</th>
                            <th>Payer</th>
                            <th>Method</th>
                            <th>Reference</th>
                            <th class="text-right" style="width: 9rem">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _doc.Items)
                        {
                            <tr>
                                <td>@item.LineNumber</td>
                                <td><span class="citus-inline-code">@item.SourceItemDisplayNumber</span></td>
                                <td>@(string.IsNullOrEmpty(item.PayerName) ? "—" : item.PayerName)</td>
                                <td>@(string.IsNullOrEmpty(item.PaymentMethod) ? "—" : item.PaymentMethod)</td>
                                <td>@(string.IsNullOrEmpty(item.ReferenceNo) ? "—" : item.ReferenceNo)</td>
                                <td class="text-right">@item.Amount.ToString("N2")</td>
                            </tr>
                        }
                        <tr class="citus-data-table__total">
                            <td colspan="5" class="text-right font-medium">Total</td>
                            <td class="text-right font-semibold">@_doc.TotalAmount.ToString("N2")</td>
                        </tr>
                    </tbody>
                </table>
            </CitusFormSection>

            @if (!string.IsNullOrWhiteSpace(_doc.Memo))
            {
                <CitusFormSection Title="Memo">
                    <p class="text-fg-muted text-sm m-0">@_doc.Memo</p>
                </CitusFormSection>
            }
        </div>

        <aside class="lg:col-span-4">
            <CitusFormSection Title="Document">
                <CitusKeyValueTable>
                    <CitusKeyValueRow Label="Internal #"><span class="citus-inline-code">@_doc.EntityNumber</span></CitusKeyValueRow>
                    <CitusKeyValueRow Label="Date">@_doc.DepositDate.ToString("yyyy-MM-dd")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Currency">@_doc.TransactionCurrencyCode</CitusKeyValueRow>
                    @if (!string.IsNullOrWhiteSpace(_doc.ReferenceNo))
                    {
                        <CitusKeyValueRow Label="Reference">@_doc.ReferenceNo</CitusKeyValueRow>
                    }
                </CitusKeyValueTable>
            </CitusFormSection>
        </aside>
    </div>
}

@code {
    [Parameter] public Guid DepositId { get; set; }

    private BankDepositRecordDto? _doc;
    private IReadOnlyList<AccountSummary> _accounts = Array.Empty<AccountSummary>();
    private bool _isLoading = true;
    private string? _error;
    private string _pageTitle = "Bank deposit";
    private PageHeaderModel _header = new() { Eyebrow = "Banking", Title = "Bank deposit", Subtitle = "Deposit detail" };

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override async Task OnParametersSetAsync()
    {
        if (_doc is not null && _doc.Id != DepositId) await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            var docTask = BankDepositClient.GetByIdAsync(DepositId, ShellState.ActiveCompany.Id);
            var accountsTask = AccountClient.ListAsync();
            await Task.WhenAll(docTask, accountsTask);
            _doc = docTask.Result;
            _accounts = accountsTask.Result;
            if (_doc is not null)
            {
                _pageTitle = _doc.DisplayNumber;
                _header = new PageHeaderModel { Eyebrow = "Banking", Title = _doc.DisplayNumber, Subtitle = HumanizeStatus(_doc.Status) };
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _isLoading = false; }
    }

    private string ResolveAccountLabel(Guid accountId)
    {
        var account = _accounts.FirstOrDefault(a => a.Id == accountId);
        return account is null ? accountId.ToString("D") : $"{account.Code}  {account.Name}";
    }

    private static string HumanizeStatus(string status) => status switch
    {
        "draft" => "Draft", "posted" => "Posted", "voided" => "Voided", "reversed" => "Reversed", _ => status
    };
}
