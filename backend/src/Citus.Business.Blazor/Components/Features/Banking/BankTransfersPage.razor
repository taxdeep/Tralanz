@page "/bank-transfers"

@inject BusinessShellState ShellState
@inject BankTransferClient BankTransferClient

<PageTitle>Bank Transfers | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <a class="citus-button" href="bank-transfers/new">
            <CitusIcon Name="IconName.Plus" Size="IconSize.Inline" />
            <span>New transfer</span>
        </a>
    </Actions>
</CitusPageHeader>

<section class="citus-panel">
    <header class="citus-panel__header">
        <h2 class="citus-panel__title">Bank transfers</h2>
        <label class="inline-flex items-center gap-2 text-sm">
            <input type="checkbox" checked="@_includeDrafts" @onchange="OnIncludeDraftsChanged" />
            <span>Include drafts</span>
        </label>
    </header>

    @if (_isLoading)
    {
        <CitusSkeleton Variant="SkeletonVariant.List" />
    }
    else if (_rows.Count == 0)
    {
        <CitusEmpty Title="No transfers yet"
                    Description="Internal account movements will appear here once posted."
                    Icon="IconName.ArrowRight" />
    }
    else
    {
        <table class="citus-data-table">
            <thead>
                <tr>
                    <th>Transfer #</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>From → To</th>
                    <th class="text-right">Amount</th>
                    <th class="text-right">FX rate</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _rows)
                {
                    <tr>
                        <td><a class="citus-link" href="@($"bank-transfers/{row.Id:D}")">@row.DisplayNumber</a></td>
                        <td>@row.TransferDate.ToString("yyyy-MM-dd")</td>
                        <td>@HumanizeStatus(row.Status)</td>
                        <td>@row.FromCurrencyCode → @row.ToCurrencyCode</td>
                        <td class="text-right">@row.Amount.ToString("N2") @row.FromCurrencyCode</td>
                        <td class="text-right">@(row.FxRate is { } r ? r.ToString("0.000000") : "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Banking",
        Title = "Bank transfers",
        Subtitle = "Internal account movements — same- and cross-currency."
    };

    private IReadOnlyList<BankTransferSummaryDto> _rows = Array.Empty<BankTransferSummaryDto>();
    private bool _isLoading = true;
    private bool _includeDrafts = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task OnIncludeDraftsChanged(ChangeEventArgs e)
    {
        _includeDrafts = (bool)(e.Value ?? false);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            _rows = await BankTransferClient.ListAsync(ShellState.ActiveCompany.Id, _includeDrafts);
        }
        finally { _isLoading = false; }
    }

    private static string HumanizeStatus(string status) => status switch
    {
        "draft" => "Draft", "posted" => "Posted", "voided" => "Voided", "reversed" => "Reversed", _ => status
    };
}
