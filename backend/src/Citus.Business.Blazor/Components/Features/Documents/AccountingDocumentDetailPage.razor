@page "/documents/{SourceType}/{DocumentId:guid}"

@inject BusinessShellState ShellState
@inject AccountingDocumentReviewClient AccountingDocumentReviewClient
@inject JournalEntryReviewClient JournalEntryReviewClient
@inject IJSRuntime JS
@inject CitusToastService Message

<PageTitle>@($"{_header.Title} | Tralanz Books")</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <a class="citus-button citus-button--ghost" href="@_backHref">
            <CitusIcon Name="IconName.ArrowLeft" Size="IconSize.Inline" />
            <span>@_backLabel</span>
        </a>
        @if (IsInvoice)
        {
            <CitusButton Variant="CitusButtonVariant.Ghost"
                         Disabled="_isDownloadingPdf"
                         OnClick="DownloadInvoicePdfAsync">
                <CitusIcon Name="IconName.Download" Size="IconSize.Inline" />
                <span>@(_isDownloadingPdf ? "Generating…" : "Download PDF")</span>
            </CitusButton>
            <CitusButton Variant="CitusButtonVariant.Primary"
                         Disabled="_isSendDialogOpen || _isSendingEmail"
                         OnClick="OpenSendDialog">
                <span>Send invoice</span>
            </CitusButton>
        }
        <CitusBadge Color="@("blue")">Read-only review</CitusBadge>
    </Actions>
</CitusPageHeader>

@if (IsInvoice && _lastSent is { } lastSent)
{
    <CitusAlert Severity="@(lastSent.Status == "sent" ? CitusAlertSeverity.Success : CitusAlertSeverity.Warning)"
                ShowIcon="true"
                Class="mb-4">
        <MessageTemplate>
            @if (lastSent.Status == "sent")
            {
                <span>Sent to <strong>@lastSent.ToEmail</strong> on @lastSent.SentAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm").</span>
            }
            else
            {
                <span>Last send attempt to <strong>@lastSent.ToEmail</strong> failed at @lastSent.SentAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")@(string.IsNullOrWhiteSpace(lastSent.ErrorMessage) ? "." : $": {lastSent.ErrorMessage}")</span>
            }
        </MessageTemplate>
    </CitusAlert>
}

@if (_isSendDialogOpen && _document is not null)
{
    <section class="citus-panel mb-4">
        <header class="citus-panel__header">
            <h2 class="citus-panel__title">Send invoice @_document.DisplayNumber</h2>
            <button type="button" class="citus-icon-button" title="Close" @onclick="CloseSendDialog">
                <CitusIcon Name="IconName.X" Size="IconSize.Inline" />
            </button>
        </header>

        @if (!string.IsNullOrWhiteSpace(_sendError))
        {
            <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_sendError" ShowIcon="true" Class="mb-3" />
        }

        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <label class="citus-form-field">
                <span class="citus-form-field__label">To</span>
                <input type="email"
                       class="citus-form-field__input"
                       placeholder="customer@example.com"
                       value="@_sendTo"
                       @oninput="@(e => _sendTo = e.Value?.ToString() ?? string.Empty)"
                       disabled="@_isSendingEmail" />
            </label>
            <label class="citus-form-field">
                <span class="citus-form-field__label">CC (optional, comma-separated)</span>
                <input type="text"
                       class="citus-form-field__input"
                       placeholder="cfo@example.com, ops@example.com"
                       value="@_sendCc"
                       @oninput="@(e => _sendCc = e.Value?.ToString() ?? string.Empty)"
                       disabled="@_isSendingEmail" />
            </label>
            <label class="citus-form-field">
                <span class="citus-form-field__label">BCC (optional)</span>
                <input type="text"
                       class="citus-form-field__input"
                       placeholder="archive@yourcompany.com"
                       value="@_sendBcc"
                       @oninput="@(e => _sendBcc = e.Value?.ToString() ?? string.Empty)"
                       disabled="@_isSendingEmail" />
            </label>
            <label class="citus-form-field md:col-span-2">
                <span class="citus-form-field__label">Personal message (optional)</span>
                <textarea class="citus-form-field__input"
                          rows="4"
                          placeholder="Anything you want the customer to read in the email body. The PDF total + due date + payment instructions are already included automatically."
                          @oninput="@(e => _sendMessage = e.Value?.ToString() ?? string.Empty)"
                          disabled="@_isSendingEmail">@_sendMessage</textarea>
            </label>
        </div>

        <div class="flex items-center gap-3 mt-4">
            <CitusButton Variant="CitusButtonVariant.Primary"
                         Disabled="_isSendingEmail || string.IsNullOrWhiteSpace(_sendTo)"
                         OnClick="SubmitSendAsync">
                @(_isSendingEmail ? "Sending…" : "Send email")
            </CitusButton>
            <CitusButton Variant="CitusButtonVariant.Ghost"
                         Disabled="_isSendingEmail"
                         OnClick="CloseSendDialog">
                Cancel
            </CitusButton>
            <span class="text-fg-subtle text-xs ml-auto">
                Subject + body are composed from the invoice. The PDF is attached automatically.
            </span>
        </div>
    </section>
}

@if (_isLoading)
{
    <div class="mb-4"><CitusLoadingBar /></div>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_error" ShowIcon="true" Class="mb-4" />
}

@if (_document is not null)
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <CitusStatCard
            Label="Document"
            Value="@_document.DisplayNumber"
            Description="@($"{_document.SourceTypeLabel} | status {_document.Status}")"
            Icon="IconName.FileText"
            Tone="StatTone.Primary" />
        <CitusStatCard
            Label="Company"
            Value="@ShellState.ActiveCompany.CompanyCode"
            Description="@ShellState.ActiveCompany.CompanyName"
            Icon="IconName.BuildingSkyscraper"
            Tone="StatTone.Info" />
        <CitusStatCard
            Label="Total"
            Value="@FormatAmount(_document.TotalAmount)"
            Description="@($"{_document.TransactionCurrencyCode} transaction currency")"
            Icon="IconName.Receipt"
            Tone="StatTone.Success" />
        <CitusStatCard
            Label="Due date"
            Value="@(_document.DueDate?.ToString("yyyy-MM-dd") ?? "No due date")"
            Description="@($"Document date {_document.DocumentDate:yyyy-MM-dd}")"
            Icon="IconName.Calendar"
            Tone="StatTone.Neutral" />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-7 flex flex-col gap-6">
            <section class="citus-panel">
                <h2 class="citus-panel__title">Document review</h2>
                <table class="citus-keyvalue">
                    <tbody>
                        @foreach (var fact in _factRows)
                        {
                            <tr><th>@fact.Label</th><td>@fact.Value</td></tr>
                        }
                    </tbody>
                </table>
            </section>

            <section class="citus-panel">
                <header class="citus-panel__header">
                    <h2 class="citus-panel__title">Lines</h2>
                    <CitusBadge Color="@("default")">@($"{_document.Lines.Count} lines")</CitusBadge>
                </header>

                @if (_document.Lines.Count == 0)
                {
                    <CitusAlert Severity="CitusAlertSeverity.Info" Message="No line rows were returned for this source document in the current review dataset." ShowIcon="true" />
                }
                else if (IsManualJournal(_document))
                {
                    <table class="citus-data-table">
                        <thead>
                            <tr>
                                <th>Line</th>
                                <th>Account</th>
                                <th>Description</th>
                                <th class="text-right">Tx debit</th>
                                <th class="text-right">Tx credit</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in _document.Lines)
                            {
                                <tr>
                                    <td>@line.LineNumber</td>
                                    <td>
                                        <div><span class="citus-inline-code">@line.AccountCode</span> @line.AccountName</div>
                                        <div class="text-fg-subtle text-xs">@line.AccountLabel</div>
                                    </td>
                                    <td>@DisplayDescription(line.Description)</td>
                                    <td class="text-right">@(line.TxDebit is null ? "-" : FormatAmount(line.TxDebit.Value))</td>
                                    <td class="text-right">@(line.TxCredit is null ? "-" : FormatAmount(line.TxCredit.Value))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else if (IsSettlementDocument(_document))
                {
                    <table class="citus-data-table">
                        <thead>
                            <tr>
                                <th>Line</th>
                                @if (IsApplicationDocument(_document))
                                {
                                    <th>Source</th>
                                }
                                <th>Target</th>
                                <th class="text-right">Applied amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in _document.Lines)
                            {
                                <tr>
                                    <td>@line.LineNumber</td>
                                    @if (IsApplicationDocument(_document))
                                    {
                                        <td>
                                            @if (TryBuildDocumentHref(line.SourceDocumentType, line.SourceDocumentId, out var sourceHref))
                                            {
                                                <a class="citus-link" href="@sourceHref">@DisplayDocumentLink(line.SourceDocumentDisplayNumber, line.SourceDocumentType)</a>
                                            }
                                            else
                                            {
                                                <span>@DisplayDocumentLink(line.SourceDocumentDisplayNumber, line.SourceDocumentType)</span>
                                            }
                                            <div class="text-fg-subtle text-xs">@DisplayOpenItem(line.SourceOpenItemId)</div>
                                        </td>
                                    }
                                    <td>
                                        @if (TryBuildDocumentHref(line.TargetDocumentType, line.TargetDocumentId, out var targetHref))
                                        {
                                            <a class="citus-link" href="@targetHref">@DisplayDocumentLink(line.TargetDocumentDisplayNumber, line.TargetDocumentType)</a>
                                        }
                                        else
                                        {
                                            <span>@DisplayDocumentLink(line.TargetDocumentDisplayNumber, line.TargetDocumentType)</span>
                                        }
                                        <div class="text-fg-subtle text-xs">@DisplayOpenItem(line.TargetOpenItemId)</div>
                                    </td>
                                    <td class="text-right">
                                        <div>@FormatAmount(line.LineAmount)</div>
                                        <div class="text-fg-subtle text-xs">@_document.TransactionCurrencyCode</div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <table class="citus-data-table">
                        <thead>
                            <tr>
                                <th>Line</th>
                                <th>Description</th>
                                <th>Account</th>
                                <th class="text-right">Quantity</th>
                                <th class="text-right">Unit price</th>
                                <th class="text-right">Line amount</th>
                                <th class="text-right">Tax</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in _document.Lines)
                            {
                                <tr>
                                    <td>@line.LineNumber</td>
                                    <td>
                                        <div>@DisplayDescription(line.Description)</div>
                                        @if (line.IsTaxRecoverable is not null)
                                        {
                                            <div class="text-fg-subtle text-xs">
                                                @(line.IsTaxRecoverable.Value ? "Recoverable tax" : "Non-recoverable tax")
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <div><span class="citus-inline-code">@line.AccountCode</span> @line.AccountName</div>
                                        <div class="text-fg-subtle text-xs">@line.AccountLabel | <span class="citus-inline-code">@line.AccountId</span></div>
                                    </td>
                                    <td class="text-right">@(line.Quantity is null ? "-" : line.Quantity.Value.ToString("N2"))</td>
                                    <td class="text-right">@(line.UnitPrice is null ? "-" : FormatAmount(line.UnitPrice.Value))</td>
                                    <td class="text-right">@FormatAmount(line.LineAmount)</td>
                                    <td class="text-right">
                                        <div>@FormatAmount(line.TaxAmount)</div>
                                        @if (line.TaxAccountId is not null)
                                        {
                                            <div class="text-fg-subtle text-xs"><span class="citus-inline-code">@line.TaxAccountId.Value</span></div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </section>
        </div>

        <div class="lg:col-span-5 flex flex-col gap-6">
            <section class="citus-panel">
                <h2 class="citus-panel__title">Why this page exists</h2>
                <ul class="citus-bullet-list">
                    <li>Report drill-down stays read-only so review never turns into an accidental edit path.</li>
                    <li>Company scope remains fixed to the active business session.</li>
                    <li>Users review source truth before any future workflow branches into posting or settlement actions.</li>
                </ul>

                @if (_relatedJournalEntryHref is not null)
                {
                    <a class="citus-button citus-button--ghost mt-4" href="@_relatedJournalEntryHref">
                        <CitusIcon Name="IconName.Eye" Size="IconSize.Inline" />
                        <span>Open related journal entry</span>
                    </a>
                }
            </section>

            <section class="citus-panel">
                <h2 class="citus-panel__title">Amounts</h2>
                <table class="citus-keyvalue">
                    <tbody>
                        @foreach (var amount in _amountRows)
                        {
                            <tr><th>@amount.Label</th><td>@amount.Value</td></tr>
                        }
                    </tbody>
                </table>
            </section>
        </div>
    </div>
}

@code {
    [Parameter]
    public string SourceType { get; set; } = string.Empty;

    [Parameter]
    public Guid DocumentId { get; set; }

    private PageHeaderModel _header = new()
    {
        Eyebrow = "Reports",
        Title = "Document review",
        Subtitle = "Read-only drill-down keeps report navigation aligned with backend-owned source truth."
    };

    private AccountingDocumentReviewSummary? _document;
    private bool _isLoading;
    private bool _isDownloadingPdf;
    private string? _error;

    // Invoice send dialog state.
    private bool _isSendDialogOpen;
    private bool _isSendingEmail;
    private string _sendTo = string.Empty;
    private string _sendCc = string.Empty;
    private string _sendBcc = string.Empty;
    private string _sendMessage = string.Empty;
    private string? _sendError;
    private InvoiceSendHistoryEntry? _lastSent;

    private bool IsInvoice =>
        _document is not null
        && string.Equals(_document.SourceType, "invoice", StringComparison.OrdinalIgnoreCase);

    private void OpenSendDialog()
    {
        if (_document is null) return;

        // Default the Cc / Bcc to whatever was used last time so re-sends
        // pick up the same internal recipients without retyping. Message
        // intentionally clears so the operator types fresh context.
        _sendTo = _lastSent?.ToEmail ?? string.Empty;
        _sendCc = _lastSent?.CcEmails ?? string.Empty;
        _sendBcc = _lastSent?.BccEmails ?? string.Empty;
        _sendMessage = string.Empty;
        _sendError = null;
        _isSendDialogOpen = true;
    }

    private void CloseSendDialog()
    {
        _isSendDialogOpen = false;
        _sendError = null;
    }

    private async Task SubmitSendAsync()
    {
        if (_document is null || _isSendingEmail) return;

        var to = _sendTo.Trim();
        if (string.IsNullOrWhiteSpace(to) || !to.Contains('@', StringComparison.Ordinal))
        {
            _sendError = "Enter a valid recipient email.";
            return;
        }

        _isSendingEmail = true;
        _sendError = null;
        try
        {
            var outcome = await AccountingDocumentReviewClient.SendInvoiceAsync(
                ShellState.ActiveCompany.Id,
                _document.Id,
                new InvoiceSendRequest(
                    ToEmail: to,
                    Cc: NullIfBlank(_sendCc),
                    Bcc: NullIfBlank(_sendBcc),
                    Message: NullIfBlank(_sendMessage)));

            if (!outcome.Succeeded)
            {
                _sendError = outcome.ErrorMessage ?? "Email delivery failed.";
                await LoadSendHistoryAsync();
                return;
            }

            await LoadSendHistoryAsync();
            _isSendDialogOpen = false;
            await Message.SuccessAsync($"Invoice sent to {to}.");
        }
        finally
        {
            _isSendingEmail = false;
        }
    }

    private async Task LoadSendHistoryAsync()
    {
        if (_document is null) return;

        var history = await AccountingDocumentReviewClient.GetInvoiceSendHistoryAsync(
            ShellState.ActiveCompany.Id,
            _document.Id);

        _lastSent = history.Count > 0 ? history[0] : null;
    }

    private static string? NullIfBlank(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private async Task DownloadInvoicePdfAsync()
    {
        if (_document is null || _isDownloadingPdf) return;

        _isDownloadingPdf = true;
        try
        {
            var download = await AccountingDocumentReviewClient.GetInvoicePdfAsync(
                ShellState.ActiveCompany.Id,
                _document.Id);

            if (download is null)
            {
                await Message.WarningAsync("Invoice PDF could not be generated. Please try again.");
                return;
            }

            var base64 = Convert.ToBase64String(download.Bytes);
            await JS.InvokeVoidAsync(
                "citusDownloads.saveBinaryFile",
                download.FileName,
                base64,
                "application/pdf");
        }
        finally
        {
            _isDownloadingPdf = false;
        }
    }
    private IReadOnlyList<FactRow> _factRows = Array.Empty<FactRow>();
    private IReadOnlyList<FactRow> _amountRows = Array.Empty<FactRow>();
    private string? _relatedJournalEntryHref;
    private string _backHref = "reports";
    private string _backLabel = "Back to reports";

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _error = null;
        _document = null;
        _factRows = Array.Empty<FactRow>();
        _amountRows = Array.Empty<FactRow>();
        _relatedJournalEntryHref = null;
        _backHref = "reports";
        _backLabel = "Back to reports";

        var sourceLabel = AccountingDocumentReviewRouteCatalog.GetSourceLabel(SourceType);

        if (!AccountingDocumentReviewRouteCatalog.IsSupported(SourceType))
        {
            _header = new PageHeaderModel
            {
                Eyebrow = "Reports",
                Title = $"{sourceLabel} review",
                Subtitle = "This drill-down route is not supported yet for the selected source type."
            };
            _error = $"The source type '{SourceType}' is not yet supported by the document review surface.";
            _isLoading = false;
            return;
        }

        var document = await AccountingDocumentReviewClient.GetDocumentAsync(
            ShellState.ActiveCompany.Id,
            SourceType,
            DocumentId);

        if (document is null)
        {
            _header = new PageHeaderModel
            {
                Eyebrow = "Reports",
                Title = $"{sourceLabel} review",
                Subtitle = "The requested source document was not found in the active company context."
            };
            _error = $"The {sourceLabel.ToLowerInvariant()} could not be found in company {ShellState.ActiveCompany.CompanyCode}.";
            _isLoading = false;
            return;
        }

        _document = document;
        _header = new PageHeaderModel
        {
            Eyebrow = "Reports",
            Title = document.DisplayNumber,
            Subtitle = $"{document.SourceTypeLabel} review stays read-only and company-scoped under backend-owned source truth."
        };
        _factRows = BuildFactRows(document);
        _amountRows = BuildAmountRows(document);

        if (IsManualJournal(document))
        {
            _backHref = "journal-entry";
            _backLabel = "Back to journal entries";
        }

        var relatedJournalEntry = await JournalEntryReviewClient.FindBySourceAsync(
            ShellState.ActiveCompany.Id,
            document.SourceType,
            document.Id);

        if (relatedJournalEntry is not null)
        {
            _relatedJournalEntryHref = $"journal-entry/review/{relatedJournalEntry.Id:D}";
        }

        // Pull the latest send-history row so the "Last sent" badge can
        // render alongside the document review fact rows. Best-effort —
        // if the call fails we just don't show the badge.
        if (IsInvoice)
        {
            await LoadSendHistoryAsync();
        }
        else
        {
            _lastSent = null;
        }

        _isLoading = false;
    }

    private static string FormatAmount(decimal amount) => amount.ToString("N2");

    private static string DisplayDescription(string? description) =>
        string.IsNullOrWhiteSpace(description) ? "No description" : description;

    private static bool IsManualJournal(AccountingDocumentReviewSummary? document) =>
        document?.SourceType == "manual_journal";

    private static bool IsSettlementDocument(AccountingDocumentReviewSummary? document) =>
        document?.SourceType is "receive_payment" or "credit_application" or "pay_bill" or "vendor_credit_application";

    private static bool IsApplicationDocument(AccountingDocumentReviewSummary? document) =>
        document?.SourceType is "credit_application" or "vendor_credit_application";

    private static string DisplayDocumentLink(string? displayNumber, string? sourceType)
    {
        var label = string.IsNullOrWhiteSpace(displayNumber) ? "Unavailable document" : displayNumber;
        var typeLabel = AccountingDocumentReviewRouteCatalog.GetSourceLabel(sourceType);
        return $"{label} | {typeLabel}";
    }

    private static string DisplayOpenItem(Guid? openItemId) =>
        openItemId.HasValue ? $"Open item {openItemId.Value:D}" : "Open item unavailable";

    private static bool TryBuildDocumentHref(string? sourceType, Guid? documentId, out string href)
    {
        href = string.Empty;

        if (!documentId.HasValue)
        {
            return false;
        }

        return AccountingDocumentReviewRouteCatalog.TryBuildReviewHref(sourceType, documentId.Value, out href);
    }

    private static IReadOnlyList<FactRow> BuildFactRows(AccountingDocumentReviewSummary document)
    {
        var rows = new List<FactRow>
        {
            new("Entity number", document.EntityNumber),
            new("Status", document.Status),
            new("Document date", document.DocumentDate.ToString("yyyy-MM-dd")),
            new("Due date", document.DueDate?.ToString("yyyy-MM-dd") ?? "No due date")
        };

        if (document.CounterpartyId is not null)
        {
            rows.Add(new(document.CounterpartyLabel, document.CounterpartyId.Value.ToString("D")));
        }

        if (document.ControlAccountId is not null)
        {
            rows.Add(new(document.ControlAccountLabel, document.ControlAccountId.Value.ToString("D")));
        }

        rows.Add(new("Memo", string.IsNullOrWhiteSpace(document.Memo) ? "No memo" : document.Memo!));
        return rows;
    }

    private static IReadOnlyList<FactRow> BuildAmountRows(AccountingDocumentReviewSummary document) =>
        IsManualJournal(document)
            ?
            [
                new("Tx debit total", $"{FormatAmount(document.SubtotalAmount)} {document.TransactionCurrencyCode}"),
                new("Tx credit total", $"{FormatAmount(document.TotalAmount)} {document.TransactionCurrencyCode}"),
                new("Base currency", document.BaseCurrencyCode)
            ]
            :
            [
                new("Subtotal", $"{FormatAmount(document.SubtotalAmount)} {document.TransactionCurrencyCode}"),
                new("Tax", $"{FormatAmount(document.TaxAmount)} {document.TransactionCurrencyCode}"),
                new("Total", $"{FormatAmount(document.TotalAmount)} {document.TransactionCurrencyCode}"),
                new("Base currency", document.BaseCurrencyCode)
            ];

    private sealed record class FactRow(string Label, string Value);
}
