@page "/tasks"

@using Citus.Modules.Tasks.Domain.Shared
@using TaskStatus = Citus.Modules.Tasks.Domain.Shared.TaskStatus

@inject BusinessShellState ShellState
@inject TaskClient TaskClient
@inject NavigationManager NavigationManager
@inject CitusToastService Toast

<PageTitle>Tasks | Tralanz Books</PageTitle>

@if (!ShellState.IsModuleEnabled("task"))
{
    @* Belt-and-suspenders: the nav menu already hides this section
       when the module is off, but a direct URL hit would otherwise
       just render an empty grid. *@
    <CitusPageHeader Model="_disabledHeader" />
    <CitusEmptyState
        Icon="IconName.Puzzle"
        Title="Task module is not enabled"
        Message="Ask your platform administrator to enable the Task module for this company in SysAdmin → Companies → Features."
        ActionLabel="Back to dashboard"
        ActionHref="dashboard" />
}
else
{
    <CitusPageHeader Model="_header">
        <Actions>
            @if (CanViewMargin)
            {
                <CitusButton Variant="CitusButtonVariant.Ghost"
                             LeadingIcon="IconName.ReportAnalytics"
                             OnClick="@(() => NavigationManager.NavigateTo("tasks/reports/margin"))">
                    Margin report
                </CitusButton>
            }
            @if (CanCreate)
            {
                <CitusButton Variant="CitusButtonVariant.Primary"
                             LeadingIcon="IconName.Plus"
                             OnClick="@(() => NavigationManager.NavigateTo("tasks/new"))">New task</CitusButton>
            }
        </Actions>
    </CitusPageHeader>

    <div class="flex flex-wrap gap-2 mb-4">
        <select class="citus-form-field__input citus-input--small" @bind="_statusFilter" @bind:after="ReloadAsync">
            <option value="">All statuses</option>
            <option value="0">Open</option>
            <option value="1">Completed</option>
            <option value="4">Partially billed</option>
            <option value="2">Billed</option>
            <option value="3">Canceled</option>
        </select>
        <CitusButton Size="CitusButtonSize.Small" Variant="CitusButtonVariant.Ghost" OnClick="ReloadAsync">
            Refresh
        </CitusButton>
    </div>

    @if (_isLoading)
    {
        <div class="mb-4"><CitusLoadingBar /></div>
    }
    else if (_tasks.Count == 0)
    {
        <CitusEmptyState
            Icon="IconName.Activity"
            Title="No tasks yet"
            Message="@(string.IsNullOrEmpty(_statusFilter) ? "Create the first task to start tracking billable work." : "No tasks match the selected status. Clear the filter to see everything.")" />
    }
    else
    {
        <CitusFormSection Title="Tasks">
            <table class="citus-data-table">
                <thead>
                    <tr>
                        <th>Task #</th>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Service date</th>
                        <th class="text-right">Billable value</th>
                        <th>Updated</th>
                        <th style="width: 14rem"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in _tasks)
                    {
                        var taskId = task.Id;
                        var status = task.Status;
                        var hasCustomer = task.CustomerId.HasValue;
                        <tr class="cursor-pointer" @onclick="@(() => OpenTask(taskId))">
                            <td>@task.TaskNo</td>
                            <td>@task.Title</td>
                            <td>
                                <CitusDocumentStatusBadge Status="@status.ToString()" />
                            </td>
                            <td>@(task.ServiceDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                            <td class="text-right">@($"{task.TotalBillableValue:N2} {task.CurrencyCode}")</td>
                            <td>@task.UpdatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            @* Cell-level stopPropagation keeps row-action clicks from
                               also opening the task. Cost → pre-fills /expenses/new.
                               Complete / Invoice mirror the TaskDetailPage header
                               affordances so an operator can move a task forward
                               without first opening it. *@
                            <td class="text-right" @onclick:stopPropagation="true">
                                <div class="inline-flex gap-2 justify-end">
                                    <CitusButton Variant="CitusButtonVariant.Ghost"
                                                 Size="CitusButtonSize.Small"
                                                 LeadingIcon="IconName.Receipt"
                                                 OnClick="@(() => AddCostFor(taskId))">Cost</CitusButton>
                                    @if (status == TaskStatus.Open && CanComplete)
                                    {
                                        <CitusButton Variant="CitusButtonVariant.Ghost"
                                                     Size="CitusButtonSize.Small"
                                                     LeadingIcon="IconName.CircleCheck"
                                                     Disabled="@_busyTaskId.Equals(taskId)"
                                                     OnClick="@(() => CompleteAsync(taskId))">Complete</CitusButton>
                                    }
                                    else if ((status == TaskStatus.Completed || status == TaskStatus.PartiallyBilled) && CanBill && hasCustomer)
                                    {
                                        <CitusButton Variant="CitusButtonVariant.Ghost"
                                                     Size="CitusButtonSize.Small"
                                                     LeadingIcon="IconName.FileInvoice"
                                                     OnClick="@(() => InvoiceFrom(taskId))">
                                            @(status == TaskStatus.PartiallyBilled ? "Bill remaining" : "Invoice")
                                        </CitusButton>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </CitusFormSection>
    }
}

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Operations",
        Title = "Tasks",
        Subtitle = "Service-delivery execution units. Records billable work, ready-to-bill, and (later) directly-attributed AP cost."
    };

    private readonly PageHeaderModel _disabledHeader = new()
    {
        Eyebrow = "Operations",
        Title = "Tasks",
        Subtitle = "The Task module is not enabled for this company."
    };

    private bool _isLoading = true;
    private string? _statusFilter;
    private IReadOnlyList<TaskSummary> _tasks = Array.Empty<TaskSummary>();
    private Guid _busyTaskId = Guid.Empty;

    private bool CanCreate => ShellState.User.Roles.Contains("task.create", StringComparer.Ordinal);

    private bool CanViewMargin => ShellState.User.Roles.Contains("task.report.margin", StringComparer.Ordinal);

    private bool CanComplete => ShellState.User.Roles.Contains("task.complete", StringComparer.Ordinal);

    private bool CanBill => ShellState.User.Roles.Contains("task.bill", StringComparer.Ordinal);

    protected override Task OnInitializedAsync() => ReloadAsync();

    private async Task ReloadAsync()
    {
        _isLoading = true;
        try
        {
            TaskStatus? status = !string.IsNullOrEmpty(_statusFilter) && int.TryParse(_statusFilter, out var raw)
                ? (TaskStatus)raw
                : null;
            _tasks = await TaskClient.ListAsync(status: status);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenTask(Guid taskId) => NavigationManager.NavigateTo($"tasks/{taskId:D}");

    // "Cost" shortcut — opens the standard expense form with the task
    // pre-attached on line 1. ExpenseCreatePage reads ?taskId and resolves
    // the display label via TaskClient.LookupDisplayAsync. Backend already
    // gates expense.create, so we don't second-guess permission here.
    private void AddCostFor(Guid taskId) =>
        NavigationManager.NavigateTo($"expenses/new?taskId={taskId:D}");

    // "Invoice" / "Bill remaining" shortcut — hands off to the AR invoice
    // create page with ?FromTaskId. The create page pre-fills customer +
    // lines + currency from the task, and the post handler flips the
    // task to Billed (or keeps it PartiallyBilled) on a successful post.
    private void InvoiceFrom(Guid taskId) =>
        NavigationManager.NavigateTo($"invoices/new?FromTaskId={taskId:D}");

    // "Complete" shortcut — calls the same workflow as TaskDetailPage's
    // "Mark completed" button. Server rejects when the task has no lines;
    // we surface the error as a toast and leave the row in place so the
    // operator can open the task and add lines.
    private async Task CompleteAsync(Guid taskId)
    {
        if (_busyTaskId != Guid.Empty) return;
        _busyTaskId = taskId;
        try
        {
            var outcome = await TaskClient.CompleteAsync(taskId, reason: null);
            if (!outcome.Succeeded)
            {
                await Toast.ErrorAsync(outcome.ErrorMessage ?? "Unable to complete the task.");
                return;
            }
            await Toast.SuccessAsync("Task marked completed.");
            await ReloadAsync();
        }
        finally
        {
            _busyTaskId = Guid.Empty;
        }
    }
}
