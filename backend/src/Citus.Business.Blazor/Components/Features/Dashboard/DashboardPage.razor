@page "/dashboard"

@inject BusinessShellState ShellState
@inject AccountingHealthClient AccountingHealthClient

<PageTitle>Home | Aiseworks</PageTitle>

<div class="aise-home">
    <div class="aise-home__topline">
        <div>
            <p class="aise-home__eyebrow">Home</p>
            <h1 class="aise-home__title">@ShellState.ActiveCompany.CompanyName</h1>
        </div>
        <div class="aise-home__status-strip">
            <span>@ShellState.ActiveCompany.CompanyCode</span>
            <span>@ShellState.ActiveCompany.BaseCurrencyCode</span>
            <span>@(_health?.Status ?? "API unavailable")</span>
        </div>
    </div>

    <div class="aise-home__tabs" aria-label="Dashboard views">
        <span class="aise-home__tab aise-home__tab--active">Home Page</span>
        <span class="aise-home__tab">Insights</span>
    </div>

    <div class="aise-home__layout">
        <div class="aise-home__main">
            <section class="aise-flow-panel aise-flow-panel--vendors">
                <span class="aise-flow-panel__label">Vendors</span>
                <div class="aise-flow-canvas aise-flow-canvas--vendors">
                    <div class="aise-flow-line aise-flow-line--vendor-top"></div>
                    <div class="aise-flow-line aise-flow-line--vendor-bill"></div>
                    <div class="aise-flow-line aise-flow-line--vendor-pay"></div>
                    <div class="aise-flow-line aise-flow-line--vendor-inventory"></div>

                    <a class="aise-flow-node aise-flow-node--vendor-po" href="purchase-orders/new">
                        <CitusIcon Name="IconName.FileText" Size="IconSize.Action" />
                        <span>Purchase<br />Orders</span>
                    </a>
                    <a class="aise-flow-node aise-flow-node--vendor-receive" href="company/warehouses">
                        <CitusIcon Name="IconName.Truck" Size="IconSize.Action" />
                        <span>Receive<br />Inventory</span>
                    </a>
                    <a class="aise-flow-node aise-flow-node--vendor-bill" href="bills/new">
                        <CitusIcon Name="IconName.Receipt" Size="IconSize.Action" />
                        <span>Enter Bills<br />Against Inventory</span>
                    </a>
                    <a class="aise-flow-node aise-flow-node--vendor-enter" href="bills/new">
                        <CitusIcon Name="IconName.FileInvoice" Size="IconSize.Action" />
                        <span>Enter Bills</span>
                    </a>
                    <a class="aise-flow-node aise-flow-node--vendor-pay" href="pay-bills">
                        <CitusIcon Name="IconName.Wallet" Size="IconSize.Action" />
                        <span>Pay Bills</span>
                    </a>
                    <a class="aise-flow-node aise-flow-node--vendor-sales-tax" href="settings/sales-tax">
                        <CitusIcon Name="IconName.Coin" Size="IconSize.Action" />
                        <span>Manage<br />Sales Tax</span>
                    </a>
                </div>
            </section>

            <section class="aise-flow-panel aise-flow-panel--customers">
                <span class="aise-flow-panel__label">Customers</span>
                <div class="aise-flow-canvas aise-flow-canvas--customers">
                    <div class="aise-flow-line aise-flow-line--customer-main"></div>
                    <div class="aise-flow-line aise-flow-line--customer-invoice"></div>
                    <div class="aise-flow-line aise-flow-line--customer-receipt"></div>
                    <div class="aise-flow-line aise-flow-line--customer-statements"></div>

                    <a class="aise-flow-node aise-flow-node--customer-estimates" href="quotes/new">
                        <CitusIcon Name="IconName.FileText" Size="IconSize.Action" />
                        <span>Estimates</span>
                    </a>
                    <a class="aise-flow-node aise-flow-node--customer-invoices" href="invoices/new">
                        <CitusIcon Name="IconName.FileInvoice" Size="IconSize.Action" />
                        <span>Create<br />Invoices</span>
                    </a>
                    <a class="aise-flow-node aise-flow-node--customer-receive" href="receive-payment">
                        <CitusIcon Name="IconName.Cash" Size="IconSize.Action" />
                        <span>Receive<br />Payments</span>
                    </a>
                    <a class="aise-flow-node aise-flow-node--customer-sales-receipts" href="sales-receipts/new">
                        <CitusIcon Name="IconName.Receipt" Size="IconSize.Action" />
                        <span>Create Sales<br />Receipts</span>
                    </a>
                    <a class="aise-flow-node aise-flow-node--customer-deposits" href="bank-deposits/new">
                        <CitusIcon Name="IconName.BuildingBank" Size="IconSize.Action" />
                        <span>Record<br />Deposits</span>
                    </a>
                    <a class="aise-flow-node aise-flow-node--customer-statements" href="invoices">
                        <CitusIcon Name="IconName.Report" Size="IconSize.Action" />
                        <span>Statements</span>
                    </a>
                    <a class="aise-flow-node aise-flow-node--customer-refunds" href="credit-memos/new">
                        <CitusIcon Name="IconName.Refresh" Size="IconSize.Action" />
                        <span>Refunds<br />& Credits</span>
                    </a>
                </div>
            </section>

            <section class="aise-flow-panel aise-flow-panel--employees">
                <span class="aise-flow-panel__label">Tasks</span>
                <div class="aise-flow-canvas aise-flow-canvas--tasks">
                    <div class="aise-flow-line aise-flow-line--task-main"></div>

                    <a class="aise-flow-node aise-flow-node--task-new" href="tasks/new">
                        <CitusIcon Name="IconName.Activity" Size="IconSize.Action" />
                        <span>Enter<br />Task</span>
                    </a>
                    <a class="aise-flow-node aise-flow-node--task-cost" href="expenses/new">
                        <CitusIcon Name="IconName.Wallet" Size="IconSize.Action" />
                        <span>Record<br />Cost</span>
                    </a>
                    <a class="aise-flow-node aise-flow-node--task-margin" href="tasks/reports/margin">
                        <CitusIcon Name="IconName.ReportAnalytics" Size="IconSize.Action" />
                        <span>Margin<br />Report</span>
                    </a>
                </div>
            </section>
        </div>

        <aside class="aise-home__side">
            <section class="aise-flow-panel aise-flow-panel--side">
                <span class="aise-flow-panel__label">Company</span>
                <div class="aise-shortcut-grid">
                    <a class="aise-shortcut" href="chart-of-accounts">
                        <CitusIcon Name="IconName.BuildingBank" Size="IconSize.Action" />
                        <span>Chart of<br />Accounts</span>
                    </a>
                    <a class="aise-shortcut" href="items">
                        <CitusIcon Name="IconName.Briefcase" Size="IconSize.Action" />
                        <span>Items &<br />Services</span>
                    </a>
                    <a class="aise-shortcut" href="settings">
                        <CitusIcon Name="IconName.Settings" Size="IconSize.Action" />
                        <span>Company<br />Settings</span>
                    </a>
                    <a class="aise-shortcut" href="reports">
                        <CitusIcon Name="IconName.ReportAnalytics" Size="IconSize.Action" />
                        <span>Reports</span>
                    </a>
                </div>
            </section>

            <section class="aise-flow-panel aise-flow-panel--side">
                <span class="aise-flow-panel__label">Banking</span>
                <div class="aise-shortcut-grid">
                    <a class="aise-shortcut" href="bank-deposits/new">
                        <CitusIcon Name="IconName.Cash" Size="IconSize.Action" />
                        <span>Record<br />Deposits</span>
                    </a>
                    <a class="aise-shortcut" href="reconciliation">
                        <CitusIcon Name="IconName.CircleCheck" Size="IconSize.Action" />
                        <span>Reconcile</span>
                    </a>
                    <a class="aise-shortcut" href="bank-transfers/new">
                        <CitusIcon Name="IconName.ArrowRight" Size="IconSize.Action" />
                        <span>Transfer<br />Funds</span>
                    </a>
                    <a class="aise-shortcut" href="expenses/new">
                        <CitusIcon Name="IconName.Wallet" Size="IconSize.Action" />
                        <span>Write<br />Expense</span>
                    </a>
                </div>
            </section>
        </aside>
    </div>
</div>

@code {
    private ServiceHealthStatus? _health;

    protected override async Task OnInitializedAsync()
    {
        _health = await AccountingHealthClient.GetHealthAsync();
    }
}
