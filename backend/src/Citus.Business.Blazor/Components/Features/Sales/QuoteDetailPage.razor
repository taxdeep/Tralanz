@page "/quotes/{QuoteId:guid}"

@inject BusinessShellState ShellState
@inject QuoteClient QuoteClient
@inject CitusToastService Message
@inject NavigationManager Navigation

<PageTitle>@($"{_pageTitle} | Tralanz Books")</PageTitle>

<CitusPageHeader Model="_header">
    <TitleSuffix>
        @if (_quote is not null)
        {
            <CitusDocumentStatusBadge Status="@_quote.Status" />
        }
    </TitleSuffix>
    <Actions>
        <CitusLinkButton Href="quotes"
                         Variant="CitusButtonVariant.Ghost"
                         LeadingIcon="IconName.ArrowLeft">
            Back to quotes
        </CitusLinkButton>
    </Actions>
</CitusPageHeader>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_error" ShowIcon="true" Class="mb-4" />
}

@if (_isLoading)
{
    <CitusSkeleton Variant="SkeletonVariant.Detail" />
}
else if (_quote is null)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning"
                Message="Quote not found in this company."
                ShowIcon="true" />
}
else
{
    <div class="citus-detail-overview">
        <CitusFormSection Title="Customer">
            <CitusKeyValueTable>
                @if (!string.IsNullOrWhiteSpace(_quote.CustomerNumber))
                {
                    <CitusKeyValueRow Label="Customer Reference #"><span class="citus-inline-code">@_quote.CustomerNumber</span></CitusKeyValueRow>
                }
                <CitusKeyValueRow Label="Name">@_quote.CustomerName</CitusKeyValueRow>
                @if (HasAddress(_quote))
                {
                    <CitusKeyValueRow Label="Billing address">@FormatAddress(_quote.BillingAddressLine, _quote.BillingCity, _quote.BillingProvinceState, _quote.BillingPostalCode, _quote.BillingCountry)</CitusKeyValueRow>
                    @if (!string.IsNullOrWhiteSpace(_quote.ShippingAddressLine))
                    {
                        <CitusKeyValueRow Label="Shipping address">@FormatAddress(_quote.ShippingAddressLine, _quote.ShippingCity, _quote.ShippingProvinceState, _quote.ShippingPostalCode, _quote.ShippingCountry)</CitusKeyValueRow>
                    }
                }
            </CitusKeyValueTable>
        </CitusFormSection>

        <CitusStatCard Label="Total" Value="@($"{_quote.TotalAmount:N2} {_quote.TransactionCurrencyCode}")"
                       Description="@($"Subtotal {_quote.SubtotalAmount:N2} − discount {_quote.DiscountAmount:N2}")"
                       Icon="IconName.Coin" Tone="StatTone.Success" />
        <CitusStatCard Label="Expires"
                       Value="@(_quote.ExpirationDate?.ToString("yyyy-MM-dd") ?? "—")"
                       Description="@($"Issued {_quote.DocumentDate:yyyy-MM-dd}")"
                       Icon="IconName.Calendar" Tone="StatTone.Neutral" />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-8">
            <CitusFormSection Title="Lines">
                <table class="citus-data-table">
                    <thead>
                        <tr>
                            <th style="width: 3rem">#</th>
                            <th style="width: 7rem">Service</th>
                            <th>Description</th>
                            <th class="text-right" style="width: 5rem">Qty</th>
                            <th class="text-right" style="width: 7rem">Rate</th>
                            <th class="text-right" style="width: 8rem">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in _quote.Lines)
                        {
                            <tr>
                                <td>@line.Sequence</td>
                                <td>@(line.ServiceDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                                <td>@(string.IsNullOrEmpty(line.Description) ? "—" : line.Description)</td>
                                <td class="text-right">@line.Quantity.ToString("0.##")</td>
                                <td class="text-right">@line.UnitPrice.ToString("0.0000")</td>
                                <td class="text-right">@line.LineTotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </CitusFormSection>

            @if (!string.IsNullOrWhiteSpace(_quote.MemoToCustomer) || !string.IsNullOrWhiteSpace(_quote.InternalNote))
            {
                <CitusFormSection Title="Notes">
                    <CitusKeyValueTable>
                        @if (!string.IsNullOrWhiteSpace(_quote.MemoToCustomer))
                        {
                            <CitusKeyValueRow Label="Customer message">@_quote.MemoToCustomer</CitusKeyValueRow>
                        }
                        @if (!string.IsNullOrWhiteSpace(_quote.InternalNote))
                        {
                            <CitusKeyValueRow Label="Internal note">@_quote.InternalNote</CitusKeyValueRow>
                        }
                    </CitusKeyValueTable>
                </CitusFormSection>
            }
        </div>

        <aside class="lg:col-span-4 flex flex-col gap-6">
            <CitusFormSection Title="Totals">
                <CitusKeyValueTable>
                    <CitusKeyValueRow Label="Subtotal" ValueAlignRight="true">@_quote.SubtotalAmount.ToString("N2")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Discount" ValueAlignRight="true">−@_quote.DiscountAmount.ToString("N2")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Shipping" ValueAlignRight="true">@((_quote.ShippingAmount ?? 0m).ToString("N2"))</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Tax" ValueAlignRight="true">@_quote.TaxAmount.ToString("N2")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Total" ValueAlignRight="true"><strong>@_quote.TotalAmount.ToString("N2") @_quote.TransactionCurrencyCode</strong></CitusKeyValueRow>
                </CitusKeyValueTable>
            </CitusFormSection>
        </aside>
    </div>

    @if (HasAnyAction(_quote))
    {
        <div class="citus-form-actions citus-form-actions--sticky citus-detail-actions">
            @if (IsEditable(_quote.Status))
            {
                <CitusLinkButton Href="@($"quotes/{_quote.Id:D}/edit")"
                                 Variant="CitusButtonVariant.Ghost"
                                 LeadingIcon="IconName.Pencil">
                    Edit
                </CitusLinkButton>
            }
            @if (_quote.Status == "draft")
            {
                <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_isMutating"
                             OnClick="@(() => SetStatusAsync("pending", "Quote sent."))">Send</CitusButton>
            }
            @if (_quote.Status == "pending")
            {
                <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_isMutating"
                             OnClick="@(() => SetStatusAsync("accepted", "Marked as accepted."))">Mark Accepted</CitusButton>
                <CitusButton Variant="CitusButtonVariant.Ghost" Disabled="_isMutating"
                             OnClick="@(() => SetStatusAsync("rejected", "Marked as rejected."))">Mark Rejected</CitusButton>
                <CitusButton Variant="CitusButtonVariant.Ghost" Disabled="_isMutating"
                             OnClick="@(() => SetStatusAsync("expired", "Marked as expired."))">Mark Expired</CitusButton>
            }
            @if (_quote.Status == "accepted")
            {
                <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_isMutating" OnClick="ConvertAsync">
                    Convert to Sales Order
                </CitusButton>
            }
            @if (_quote.Status == "converted" && _quote.ConvertedSalesOrderId is { } soId)
            {
                <CitusLinkButton Href="@($"sales-orders/{soId:D}")">Open Sales Order</CitusLinkButton>
            }
            @if (!IsTerminal(_quote.Status))
            {
                <CitusButton Variant="CitusButtonVariant.Ghost" Danger="true" Disabled="_isMutating"
                             OnClick="@(() => SetStatusAsync("void", "Quote voided."))">Void</CitusButton>
            }
        </div>
    }
}

@code {
    [Parameter] public Guid QuoteId { get; set; }

    private QuoteRecordDto? _quote;
    private bool _isLoading = true;
    private bool _isMutating;
    private string? _error;

    private PageHeaderModel _header = new() { Eyebrow = "Sales & Get Paid", Title = "Quote", Subtitle = "Quote detail" };
    private string _pageTitle = "Quote";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override async Task OnParametersSetAsync()
    {
        if (_quote is not null && _quote.Id != QuoteId)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            _quote = await QuoteClient.GetByIdAsync(QuoteId);
            ApplyHeader();
        }
        finally { _isLoading = false; }
    }

    private void ApplyHeader()
    {
        if (_quote is null)
        {
            _pageTitle = "Quote";
            _header = new PageHeaderModel { Eyebrow = "Sales & Get Paid", Title = "Quote", Subtitle = "Quote detail" };
            return;
        }
        _pageTitle = _quote.QuoteNumber;
        _header = new PageHeaderModel
        {
            Eyebrow = "Sales & Get Paid",
            Title = _quote.QuoteNumber
        };
    }

    private async Task SetStatusAsync(string newStatus, string successMessage)
    {
        if (_quote is null || _isMutating) return;
        _isMutating = true;
        try
        {
            var outcome = await QuoteClient.SetStatusAsync(_quote.Id, newStatus);
            if (!outcome.Succeeded)
            {
                _error = outcome.ErrorMessage ?? "Status change failed.";
                await Message.WarningAsync(_error);
                return;
            }
            _quote = outcome.Saved;
            ApplyHeader();
            await Message.SuccessAsync(successMessage);
        }
        finally { _isMutating = false; }
    }

    private async Task ConvertAsync()
    {
        if (_quote is null || _isMutating) return;
        _isMutating = true;
        try
        {
            var outcome = await QuoteClient.ConvertToSalesOrderAsync(_quote.Id);
            if (!outcome.Succeeded || outcome.Saved is null)
            {
                _error = outcome.ErrorMessage ?? "Convert failed.";
                await Message.WarningAsync(_error);
                return;
            }
            await Message.SuccessAsync($"Sales Order {outcome.Saved.SalesOrderNumber} created.");
            Navigation.NavigateTo($"sales-orders/{outcome.Saved.Id:D}");
        }
        finally { _isMutating = false; }
    }

    private static bool IsEditable(string status) => status is "draft" or "pending";
    private static bool IsTerminal(string status) => status is "rejected" or "converted" or "void";

    // The sticky action bar renders only when at least one button applies:
    // !IsTerminal covers Edit / status-change / Void (draft, pending, accepted,
    // expired); converted keeps the "Open Sales Order" link.
    private static bool HasAnyAction(QuoteRecordDto quote) =>
        !IsTerminal(quote.Status)
        || (quote.Status == "converted" && quote.ConvertedSalesOrderId is not null);

    private static bool HasAddress(QuoteRecordDto quote) =>
        !string.IsNullOrWhiteSpace(quote.BillingAddressLine) || !string.IsNullOrWhiteSpace(quote.BillingCity);

    private static string FormatAddress(string? line, string? city, string? prov, string? postal, string? country)
    {
        var parts = new List<string>(5);
        if (!string.IsNullOrWhiteSpace(line)) parts.Add(line);
        if (!string.IsNullOrWhiteSpace(city)) parts.Add(city);
        if (!string.IsNullOrWhiteSpace(prov)) parts.Add(prov);
        if (!string.IsNullOrWhiteSpace(postal)) parts.Add(postal);
        if (!string.IsNullOrWhiteSpace(country)) parts.Add(country);
        return parts.Count == 0 ? "—" : string.Join(", ", parts);
    }
}
