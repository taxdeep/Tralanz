@page "/sales-receipts"

@inject BusinessShellState ShellState
@inject SalesReceiptClient SalesReceiptClient

<PageTitle>Sales Receipts | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusLinkButton Href="sales-receipts/new"
                         Variant="CitusButtonVariant.Primary"
                         LeadingIcon="IconName.Plus">
            New sales receipt
        </CitusLinkButton>
    </Actions>
</CitusPageHeader>

<CitusFormSection Title="Sales receipts">
    <HeaderActions>
        <label class="inline-flex items-center gap-2 text-sm">
            <input type="checkbox" checked="@_includeDrafts" @onchange="OnIncludeDraftsChanged" />
            <span>Include drafts</span>
        </label>
    </HeaderActions>
    <ChildContent>
    @if (_isLoading)
    {
        <CitusSkeleton Variant="SkeletonVariant.List" />
    }
    else if (_rows.Count == 0)
    {
        <CitusEmpty Title="No sales receipts yet"
                    Description="Cash-in-hand sales will appear here once posted."
                    Icon="IconName.Cash" />
    }
    else
    {
        <table class="citus-data-table">
            <thead>
                <tr>
                    <th>Receipt #</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Method</th>
                    <th>Customer PO</th>
                    <th class="text-right">Total</th>
                    <th>Currency</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _rows)
                {
                    <tr>
                        <td><a class="citus-link" href="@($"sales-receipts/{row.Id:D}")">@row.DisplayNumber</a></td>
                        <td>@row.ReceiptDate.ToString("yyyy-MM-dd")</td>
                        <td>@HumanizeStatus(row.Status)</td>
                        <td>@row.PaymentMethod</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(row.CustomerPoNumber))
                            {
                                <span class="text-fg-subtle">—</span>
                            }
                            else
                            {
                                <span class="citus-inline-code">@row.CustomerPoNumber</span>
                            }
                        </td>
                        <td class="text-right">@row.TotalAmount.ToString("N2")</td>
                        <td>@row.TransactionCurrencyCode</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    </ChildContent>
</CitusFormSection>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Sales & Get Paid",
        Title = "Sales receipts",
        Subtitle = "Cash-in-hand sales — posted directly with no AR step."
    };

    private IReadOnlyList<SalesReceiptSummaryDto> _rows = Array.Empty<SalesReceiptSummaryDto>();
    private bool _isLoading = true;
    private bool _includeDrafts = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task OnIncludeDraftsChanged(ChangeEventArgs e)
    {
        _includeDrafts = (bool)(e.Value ?? false);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            _rows = await SalesReceiptClient.ListAsync(ShellState.ActiveCompany.Id, _includeDrafts);
        }
        finally { _isLoading = false; }
    }

    private static string HumanizeStatus(string status) => status switch
    {
        "draft" => "Draft", "posted" => "Posted", "voided" => "Voided", "reversed" => "Reversed", _ => status
    };
}
