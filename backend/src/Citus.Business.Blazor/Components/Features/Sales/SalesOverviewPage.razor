@page "/sales-overview"

@inject BusinessShellState ShellState
@inject NavigationManager Nav
@inject CustomerClient CustomerClient
@inject ArAgingClient ArAgingClient
@inject SalesOverviewClient OverviewClient

<PageTitle>Sales Overview | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusButton Disabled="_isLoading" OnClick="LoadAsync">Refresh</CitusButton>
    </Actions>
</CitusPageHeader>

@if (_isLoading)
{
    <CitusSkeleton Variant="SkeletonVariant.Detail" />
}
else
{
    @* === Block 1: Flow diagram + Customer balances ======================
         items-start keeps the Customers panel from stretching to match the
         taller Sales flow panel — without it, an empty customer list
         leaves a large blank band on the right that visually crowds the
         Cash flow band below. *@
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6 mb-6 items-start">
        <section class="citus-panel">
            <h2 class="citus-panel__title">Sales flow</h2>
            <p class="text-fg-muted text-sm mb-3">
                Click any of the lit nodes (Customers, Quotes, Sales Orders,
                Sales Invoices, Receipts) to jump to that module. Dashed
                nodes mark upcoming surfaces (Projects, Delivery Orders,
                Time Slips).
            </p>
            <div class="sales-flow">
                <svg class="sales-flow__edges" viewBox="0 0 720 460" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
                    <defs>
                        <marker id="sales-flow-arrow" viewBox="0 0 10 10" refX="9" refY="5"
                                markerWidth="8" markerHeight="8" orient="auto-start-reverse">
                            <path d="M0,0 L10,5 L0,10 z" fill="currentColor" />
                        </marker>
                    </defs>
                    <g class="sales-flow__edge-group">
                        @* Quotes -> Sales Orders *@
                        <path d="M 175 220 L 285 220" />
                        @* Sales Orders -> Delivery Orders *@
                        <path d="M 355 220 L 485 220" />
                        @* Sales Orders -> Sales Invoices (down then right) *@
                        <path d="M 320 250 L 320 360 L 405 360" />
                        @* Delivery Orders -> Sales Invoices (down then left) *@
                        <path d="M 520 250 L 520 340 L 475 360" />
                        @* Time Slips -> Sales Invoices *@
                        <path d="M 175 380 L 405 380" />
                        @* Sales Invoices -> Receipts *@
                        <path d="M 475 380 L 585 380" />
                    </g>
                </svg>

                @RenderNode(120, 60, IconName.Users, "Customers", "customers")
                @RenderNode(440, 60, IconName.Briefcase, "Projects", null, ghost: true)
                @RenderNode(120, 220, IconName.FileText, "Quotes", "quotes")
                @RenderNode(320, 220, IconName.Receipt, "Sales Orders", "sales-orders")
                @RenderNode(520, 220, IconName.Truck, "Delivery Orders", null, ghost: true)
                @RenderNode(120, 380, IconName.Clock, "Time Slips", null, ghost: true)
                @RenderNode(440, 380, IconName.FileInvoice, "Sales Invoices", "invoices")
                @RenderNode(620, 380, IconName.Cash, "Receipts", "receive-payment")
            </div>
        </section>

        <section class="citus-panel">
            <div class="flex items-center justify-between mb-3">
                <h2 class="citus-panel__title m-0">Customers</h2>
                <span class="text-fg-subtle text-xs">
                    Balances as of @_asOfDate.ToString("yyyy-MM-dd")
                </span>
            </div>

            <label class="inline-flex items-center gap-2 text-sm mb-3">
                <input type="checkbox"
                       checked="@_includeInactive"
                       @onchange="@OnIncludeInactiveChanged" />
                <span>Include inactive customers</span>
            </label>

            <div class="overflow-x-auto citus-scroll-y-md">
                <table class="citus-data-table">
                    <thead>
                        <tr>
                            <th class="cursor-pointer select-none"
                                @onclick="@(() => ToggleSort(CustomerSort.Name))">
                                Customer Name @SortIndicator(CustomerSort.Name)
                            </th>
                            <th class="text-right cursor-pointer select-none"
                                @onclick="@(() => ToggleSort(CustomerSort.Balance))">
                                Balance @SortIndicator(CustomerSort.Balance)
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_displayedCustomers.Count == 0)
                        {
                            <tr><td colspan="2" class="text-fg-subtle text-sm py-4">No customers to show.</td></tr>
                        }
                        else
                        {
                            @foreach (var row in _displayedCustomers)
                            {
                                <tr>
                                    <td>
                                        <a class="citus-link" href="@($"customers/{row.CustomerId:D}")">
                                            @row.DisplayName
                                        </a>
                                    </td>
                                    <td class="text-right citus-tabular">
                                        @FormatCurrency(row.CurrencyCode, row.Balance)
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    @* === Block 2: Cash Flow band ======================================== *@
    <section class="citus-panel mb-6">
        <h2 class="citus-panel__title">Cash flow</h2>
        <p class="text-fg-muted text-sm mb-3">
            Past 10 months of cash received, the current month's running total,
            and a 3-month forecast computed from open invoices' due dates
            (invoice + payment term). All values in @_baseCurrencyCode.
        </p>

        @if (_cashFlow is null || _cashFlow.Months.Count == 0)
        {
            <p class="text-fg-subtle text-sm">No cash-flow data yet.</p>
        }
        else
        {
            <RadzenChart Class="citus-chart--md">
                <RadzenColumnSeries Data="@_cashFlowReceivedPoints"
                                    CategoryProperty="Label"
                                    ValueProperty="Amount"
                                    Title="@($"Received ({_baseCurrencyCode})")"
                                    Fill="var(--citus-color-info)">
                    <RadzenSeriesDataLabels Visible="true" />
                </RadzenColumnSeries>
                <RadzenColumnSeries Data="@_cashFlowForecastPoints"
                                    CategoryProperty="Label"
                                    ValueProperty="Amount"
                                    Title="@($"Forecast ({_baseCurrencyCode})")"
                                    Fill="var(--citus-color-primary-border)">
                    <RadzenSeriesDataLabels Visible="true" />
                </RadzenColumnSeries>
                <RadzenColumnOptions Radius="2" />
                <RadzenCategoryAxis Padding="20">
                    <RadzenAxisTitle Text="" />
                </RadzenCategoryAxis>
                <RadzenValueAxis>
                    <RadzenAxisTitle Text="@_baseCurrencyCode" />
                </RadzenValueAxis>
                <RadzenLegend Position="LegendPosition.Bottom" />
            </RadzenChart>
        }
    </section>

    @* === Block 3: Income over time ====================================== *@
    <section class="citus-panel">
        <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
            <h2 class="citus-panel__title m-0">Income over time</h2>
            <div class="flex items-center gap-3 text-sm">
                <label class="flex items-center gap-2">
                    Duration:
                    <select class="citus-form-field__input citus-inline-control--md"
                            value="@_duration"
                            @onchange="@(e => OnDurationChanged(e.Value?.ToString() ?? "last_12_months"))">
                        <option value="this_month">This month</option>
                        <option value="this_quarter">This quarter</option>
                        <option value="ytd">Year to date</option>
                        <option value="last_12_months">Last 12 months</option>
                    </select>
                </label>
                <label class="flex items-center gap-2">
                    <input type="checkbox"
                           checked="@_compareToPreviousYear"
                           @onchange="@OnCompareChanged" />
                    Compare to previous year
                </label>
            </div>
        </div>
        <p class="text-fg-muted text-sm mb-3">
            Posted invoice totals by month — accrual-basis revenue, base currency.
        </p>

        @if (_income is null)
        {
            <p class="text-fg-subtle text-sm">No income data yet.</p>
        }
        else
        {
            <RadzenChart Class="citus-chart--md">
                <RadzenLineSeries Data="@_incomePoints"
                                  CategoryProperty="Label"
                                  ValueProperty="Amount"
                                  Title="@($"This year ({_baseCurrencyCode})")"
                                  Smooth="true"
                                  LineType="LineType.Solid">
                    <RadzenMarkers MarkerType="MarkerType.Circle" />
                </RadzenLineSeries>
                @if (_compareToPreviousYear && _previousIncomePoints.Count > 0)
                {
                    <RadzenLineSeries Data="@_previousIncomePoints"
                                      CategoryProperty="Label"
                                      ValueProperty="Amount"
                                      Title="Previous year"
                                      Smooth="true"
                                      LineType="LineType.Dashed">
                        <RadzenMarkers MarkerType="MarkerType.Circle" />
                    </RadzenLineSeries>
                }
                <RadzenCategoryAxis Padding="20" />
                <RadzenValueAxis>
                    <RadzenAxisTitle Text="@_baseCurrencyCode" />
                </RadzenValueAxis>
                <RadzenLegend Position="LegendPosition.Bottom" />
            </RadzenChart>
        }
    </section>
}

<style>
    /* Sales flow — SVG holds the arrows, HTML/Tabler icons sit on top
       at absolute coords matching the SVG viewBox (720 x 460). The
       wrapper keeps a 720:460 aspect ratio so the icon coords line up
       with the lines at any screen width. min-height keeps the content
       readable on very narrow viewports where 460 * (panel_width /
       720) collapses too tightly. */
    .sales-flow {
        position: relative;
        width: 100%;
        max-width: 720px;
        margin: 0 auto;
        aspect-ratio: 720 / 460;
        min-height: 380px;
    }

    .sales-flow__edges {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        color: var(--citus-color-fg-subtle);
        pointer-events: none;
    }

    .sales-flow__edge-group path {
        fill: none;
        stroke: currentColor;
        stroke-width: 1.5;
        marker-end: url(#sales-flow-arrow);
    }

    .sales-flow__node {
        position: absolute;
        transform: translate(-50%, -50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
        background: transparent;
        border: 0;
        padding: 0;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
        font: inherit;
    }

    .sales-flow__node-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: var(--citus-color-primary-bg);
        color: var(--citus-color-primary);
        border: 1.5px solid var(--citus-color-primary-border);
        transition: transform 120ms ease, box-shadow 120ms ease, background 120ms ease;
    }

    .sales-flow__node:hover .sales-flow__node-icon {
        transform: scale(1.08);
        box-shadow: var(--citus-shadow-2);
        background: var(--citus-color-primary);
        color: var(--citus-color-on-primary, #ffffff);
        border-color: var(--citus-color-primary);
    }

    .sales-flow__node:hover .sales-flow__node-label {
        color: var(--citus-color-primary);
        font-weight: 500;
    }

    .sales-flow__node-label {
        font-size: var(--citus-text-sm);
        color: var(--citus-color-fg-muted);
        white-space: nowrap;
    }

    .sales-flow__node--ghost {
        cursor: not-allowed;
    }

    .sales-flow__node--ghost .sales-flow__node-icon {
        background: var(--citus-color-bg-muted);
        color: var(--citus-color-fg-subtle);
        border-style: dashed;
        border-color: var(--citus-color-border);
    }

    .sales-flow__node--ghost:hover .sales-flow__node-icon {
        transform: none;
        box-shadow: none;
        background: var(--citus-color-bg-muted);
    }

    .sales-flow__node--ghost .sales-flow__node-label {
        color: var(--citus-color-fg-subtle);
    }
</style>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Sales & Get Paid",
        Title = "Overview",
        Subtitle = "Sales workflow at a glance — flow, customer balances, cash band, and revenue trend."
    };

    private DateOnly _asOfDate = DateOnly.FromDateTime(DateTime.UtcNow);
    private string _baseCurrencyCode = string.Empty;

    private IReadOnlyList<CustomerSummary> _customers = Array.Empty<CustomerSummary>();
    private ArAgingReportSummary? _aging;
    private SalesCashFlowSummary? _cashFlow;
    private IncomeOverTimeSummary? _income;

    private bool _isLoading = true;
    private bool _includeInactive;
    private bool _compareToPreviousYear;
    private string _duration = "last_12_months";

    private CustomerSort _sortKey = CustomerSort.Balance;
    private bool _sortDescending = true;

    private List<CustomerBalanceRow> _displayedCustomers = new();
    private List<IncomeChartPoint> _incomePoints = new();
    private List<IncomeChartPoint> _previousIncomePoints = new();
    private List<CashFlowChartPoint> _cashFlowReceivedPoints = new();
    private List<CashFlowChartPoint> _cashFlowForecastPoints = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            _asOfDate = DateOnly.FromDateTime(DateTime.UtcNow);
            var companyId = ShellState.ActiveCompany.Id;
            _baseCurrencyCode = ShellState.ActiveCompany.BaseCurrencyCode ?? string.Empty;

            var customersTask = CustomerClient.ListAsync(includeInactive: _includeInactive);
            var agingTask = ArAgingClient.GetReportAsync(companyId, _asOfDate);
            var cashFlowTask = OverviewClient.GetCashFlowAsync(companyId, _asOfDate);
            var (incomeFrom, incomeTo) = ResolveIncomeWindow();
            var incomeTask = OverviewClient.GetIncomeOverTimeAsync(
                companyId, incomeFrom, incomeTo, _compareToPreviousYear);

            await Task.WhenAll(customersTask, agingTask, cashFlowTask, incomeTask);

            _customers = customersTask.Result;
            _aging = agingTask.Result;
            _cashFlow = cashFlowTask.Result;
            _income = incomeTask.Result;

            if (_cashFlow is not null && !string.IsNullOrWhiteSpace(_cashFlow.BaseCurrencyCode))
            {
                _baseCurrencyCode = _cashFlow.BaseCurrencyCode;
            }

            RebuildCustomerRows();
            RebuildIncomePoints();
            RebuildCashFlowPoints();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnIncludeInactiveChanged(ChangeEventArgs e)
    {
        _includeInactive = e.Value is bool checkedValue && checkedValue;
        // Refetch customers because the API may exclude inactive ones.
        _customers = await CustomerClient.ListAsync(includeInactive: _includeInactive);
        RebuildCustomerRows();
    }

    private async Task OnDurationChanged(string duration)
    {
        _duration = duration;
        await ReloadIncomeAsync();
    }

    private async Task OnCompareChanged(ChangeEventArgs e)
    {
        _compareToPreviousYear = e.Value is bool checkedValue && checkedValue;
        await ReloadIncomeAsync();
    }

    private async Task ReloadIncomeAsync()
    {
        var companyId = ShellState.ActiveCompany.Id;
        var (incomeFrom, incomeTo) = ResolveIncomeWindow();
        _income = await OverviewClient.GetIncomeOverTimeAsync(
            companyId, incomeFrom, incomeTo, _compareToPreviousYear);
        RebuildIncomePoints();
    }

    private (DateOnly From, DateOnly To) ResolveIncomeWindow()
    {
        var today = _asOfDate;
        var monthStart = new DateOnly(today.Year, today.Month, 1);
        return _duration switch
        {
            "this_month" => (monthStart, today),
            "this_quarter" => (
                new DateOnly(today.Year, ((today.Month - 1) / 3) * 3 + 1, 1),
                today),
            "ytd" => (new DateOnly(today.Year, 1, 1), today),
            _ => (monthStart.AddMonths(-11), today),
        };
    }

    private void ToggleSort(CustomerSort key)
    {
        if (_sortKey == key)
        {
            _sortDescending = !_sortDescending;
        }
        else
        {
            _sortKey = key;
            _sortDescending = key == CustomerSort.Balance;
        }
        RebuildCustomerRows();
    }

    private string SortIndicator(CustomerSort key) =>
        _sortKey != key ? string.Empty : (_sortDescending ? " ▼" : " ▲");

    private void RebuildCustomerRows()
    {
        // Index aging rows by customer id for O(1) lookup.
        var agingByCustomer = (_aging?.CustomerRows ?? Array.Empty<ArAgingCustomerSummary>())
            .ToDictionary(row => row.CustomerId);

        var rows = new List<CustomerBalanceRow>(_customers.Count);
        foreach (var c in _customers)
        {
            agingByCustomer.TryGetValue(c.Id, out var aging);

            string currency = c.DefaultCurrencyCode;
            decimal balance = 0m;

            if (aging is not null && aging.OpenItems.Count > 0)
            {
                // Pick the dominant transaction currency among open items;
                // sum signed-open-tx in that currency. Mixed-currency
                // customers fall back to base-currency total.
                var byCurrency = aging.OpenItems
                    .GroupBy(i => i.DocumentCurrencyCode)
                    .Select(g => new
                    {
                        Currency = g.Key,
                        Total = g.Sum(i => i.SignedOpenAmountTx),
                        Count = g.Count(),
                    })
                    .OrderByDescending(g => g.Count)
                    .ToList();

                if (byCurrency.Count == 1)
                {
                    currency = byCurrency[0].Currency;
                    balance = byCurrency[0].Total;
                }
                else if (byCurrency.Count > 1)
                {
                    currency = _baseCurrencyCode;
                    balance = aging.TotalOutstandingAmountBase;
                }
            }

            rows.Add(new CustomerBalanceRow(
                CustomerId: c.Id,
                DisplayName: c.DisplayName,
                CurrencyCode: string.IsNullOrWhiteSpace(currency) ? _baseCurrencyCode : currency,
                Balance: balance,
                IsActive: c.IsActive));
        }

        IEnumerable<CustomerBalanceRow> ordered = _sortKey switch
        {
            CustomerSort.Balance => _sortDescending
                ? rows.OrderByDescending(r => r.Balance).ThenBy(r => r.DisplayName, StringComparer.OrdinalIgnoreCase)
                : rows.OrderBy(r => r.Balance).ThenBy(r => r.DisplayName, StringComparer.OrdinalIgnoreCase),
            _ => _sortDescending
                ? rows.OrderByDescending(r => r.DisplayName, StringComparer.OrdinalIgnoreCase)
                : rows.OrderBy(r => r.DisplayName, StringComparer.OrdinalIgnoreCase),
        };
        _displayedCustomers = ordered.ToList();
    }

    private void RebuildIncomePoints()
    {
        _incomePoints = (_income?.Months ?? Array.Empty<IncomeOverTimeMonthSummary>())
            .Select(m => new IncomeChartPoint(
                Label: m.MonthStart.ToString("yyyy MMM"),
                Amount: (double)m.AmountBase))
            .ToList();
        _previousIncomePoints = (_income?.PreviousYearMonths ?? Array.Empty<IncomeOverTimeMonthSummary>())
            .Select(m => new IncomeChartPoint(
                Label: m.MonthStart.AddYears(1).ToString("yyyy MMM"),
                Amount: (double)m.AmountBase))
            .ToList();
    }

    private void RebuildCashFlowPoints()
    {
        // Two parallel series so Radzen renders Received + Forecast in
        // distinct colors with their own legend entries. Both arrays
        // span all 14 months so the x-axis stays aligned; entries that
        // don't apply to a bucket get null so the chart skips them
        // (no zero-height column drawn).
        var received = new List<CashFlowChartPoint>();
        var forecast = new List<CashFlowChartPoint>();

        if (_cashFlow is null)
        {
            _cashFlowReceivedPoints = received;
            _cashFlowForecastPoints = forecast;
            return;
        }

        foreach (var bucket in _cashFlow.Months)
        {
            var label = bucket.MonthStart.ToString("MMM yy");
            received.Add(new CashFlowChartPoint(
                Label: label,
                Amount: bucket.IsForecast ? null : (double?)bucket.ReceivedAmountBase));
            forecast.Add(new CashFlowChartPoint(
                Label: label,
                Amount: bucket.IsForecast ? (double?)bucket.ForecastAmountBase : null));
        }

        _cashFlowReceivedPoints = received;
        _cashFlowForecastPoints = forecast;
    }

    private static string FormatCurrency(string? currencyCode, decimal amount)
    {
        var prefix = ResolveCurrencySymbol(currencyCode);
        var sign = amount < 0 ? "-" : string.Empty;
        var abs = Math.Abs(amount);
        return $"{sign}{prefix}{abs:N2}";
    }

    private static string ResolveCurrencySymbol(string? code) =>
        (code ?? string.Empty).Trim().ToUpperInvariant() switch
        {
            "USD" => "US$",
            "CAD" => "Can$",
            "EUR" => "€",
            "GBP" => "£",
            "CNY" or "RMB" => "RMB",
            "JPY" => "¥",
            "AUD" => "A$",
            "" => string.Empty,
            var c => $"{c} ",
        };

    @* Flow-diagram node — HTML/CSS so we can drop a Tabler icon inside.
       Coords (cx, cy) are in the SVG viewBox space (720 x 460); the
       wrapper's aspect-ratio keeps the percentages aligned with the
       arrow paths. Solid nodes navigate; ghost nodes get a "Coming
       soon" tooltip and no click handler. *@
    private RenderFragment RenderNode(int cx, int cy, IconName icon, string label, string? href, bool ghost = false) => builder =>
    {
        var leftPercent = (cx / 720.0 * 100).ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
        var topPercent = (cy / 460.0 * 100).ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
        var style = $"left: {leftPercent}%; top: {topPercent}%;";
        var cssClass = ghost ? "sales-flow__node sales-flow__node--ghost" : "sales-flow__node";
        var seq = 0;

        if (ghost || string.IsNullOrEmpty(href))
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", cssClass);
            builder.AddAttribute(seq++, "style", style);
            if (ghost) builder.AddAttribute(seq++, "title", "Coming soon");
        }
        else
        {
            builder.OpenElement(seq++, "button");
            builder.AddAttribute(seq++, "type", "button");
            builder.AddAttribute(seq++, "class", cssClass);
            builder.AddAttribute(seq++, "style", style);
            var target = href!;
            builder.AddAttribute(seq++, "onclick",
                EventCallback.Factory.Create<MouseEventArgs>(this, _ => Nav.NavigateTo(target)));
        }

        builder.OpenElement(seq++, "span");
        builder.AddAttribute(seq++, "class", "sales-flow__node-icon");
        builder.OpenComponent<CitusIcon>(seq++);
        builder.AddAttribute(seq++, "Name", icon);
        builder.AddAttribute(seq++, "Size", IconSize.Display);
        builder.CloseComponent();
        builder.CloseElement(); // span.icon

        builder.OpenElement(seq++, "span");
        builder.AddAttribute(seq++, "class", "sales-flow__node-label");
        builder.AddContent(seq++, label);
        builder.CloseElement(); // span.label

        builder.CloseElement(); // button or div
    };

    private enum CustomerSort { Name, Balance }

    private sealed record CustomerBalanceRow(
        Guid CustomerId,
        string DisplayName,
        string CurrencyCode,
        decimal Balance,
        bool IsActive);

    private sealed record IncomeChartPoint(string Label, double Amount);

    private sealed record CashFlowChartPoint(string Label, double? Amount);
}
