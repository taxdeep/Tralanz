@page "/quotes/new"
@page "/quotes/{QuoteId:guid}/edit"

@using Radzen
@using Radzen.Blazor
@using Citus.Modules.UnitySearch.Blazor

@inject BusinessShellState ShellState
@inject CustomerClient CustomerClient
@inject ItemClient ItemClient
@inject TaxCodeClient TaxCodeClient
@inject PaymentTermClient PaymentTermClient
@inject QuoteClient QuoteClient
@inject CitusToastService Message
@inject NavigationManager Navigation

@*
    Quote create / edit page. Same component handles both cases:
      • /quotes/new — empty draft
      • /quotes/{id}/edit — loads existing quote (must be Draft or Pending)

    Save = silent draft (status untouched). Send = transitions Draft to
    Pending and routes back to detail. The user does not see "Save as
    draft" — Draft is a system state, not a button label.
*@

<PageTitle>@(_quoteId is null ? "New quote" : $"Edit {_quoteNumber}") | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusLinkButton Href="quotes"
                         Variant="CitusButtonVariant.Ghost"
                         LeadingIcon="IconName.ArrowLeft">
            Back to quotes
        </CitusLinkButton>
    </Actions>
</CitusPageHeader>

@if (ShellState.AreWritesBlocked)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" ShowIcon="true" Message="@ShellState.WriteBlockMessage" Class="mb-4" />
}

@if (!string.IsNullOrWhiteSpace(_validation))
{
    <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_validation" ShowIcon="true" Class="mb-4" />
}

@if (_isLoading)
{
    <CitusSkeleton Variant="SkeletonVariant.Form" />
}
else
{
    <div class="flex flex-col gap-6">
            <CitusFormSection Title="Customer">
                @if (!string.IsNullOrWhiteSpace(_quoteNumber))
                {
                    <CitusFormField Label="Quote no." Class="mb-4">
                        <div class="citus-inline-code">@_quoteNumber</div>
                    </CitusFormField>
                }
                <CitusFormGrid Columns="2">
                    <CitusFormField Label="Customer">
                        <CustomerPicker CompanyId="@ShellState.ActiveCompany.Id"
                                        SelectedId="@_customerId"
                                        SelectedDisplayText="@_customerDisplay"
                                        Placeholder="Search customers…"
                                        OnCustomerSelected="OnCustomerSelected"
                                        OnCleared="OnCustomerCleared" />
                    </CitusFormField>
                    <CitusFormField Label="Email">
                        <CitusInput TValue="string" @bind-Value="_email" Placeholder="customer@example.com" />
                    </CitusFormField>
                    <CitusFormField Label="Estimate date">
                        <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false"
                                          @bind-Value="_documentDate" Class="citus-control-full" />
                    </CitusFormField>
                    <CitusFormField Label="Expiration date">
                        <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false"
                                          @bind-Value="_expirationDate" Class="citus-control-full" />
                    </CitusFormField>
                    <CitusFormField Label="Transaction currency">
                        <CitusInput TValue="string"
                                    @bind-Value="_currency"
                                    Placeholder="USD"
                                    Disabled="@(!ShellState.ActiveCompany.MultiCurrencyEnabled)" />
                    </CitusFormField>
                    <CitusFormField Label="Exchange rate">
                        <FxRateInline DocumentDate="@(DateOnly.FromDateTime((_documentDate ?? DateTime.Today).Date))"
                                      BaseCurrencyCode="@ShellState.ActiveCompany.BaseCurrencyCode"
                                      QuoteCurrencyCode="@_currency"
                                      @bind-Rate="_fxRate" />
                    </CitusFormField>
                </CitusFormGrid>

                <div class="mt-6">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="text-fg-muted text-sm font-medium m-0">Address</h3>
                        <CitusButton Variant="CitusButtonVariant.Ghost"
                                     Size="CitusButtonSize.Small"
                                     LeadingIcon="IconName.Pencil"
                                     OnClick="OpenAddressDrawer">Edit</CitusButton>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <h4 class="text-fg-muted text-xs font-medium mb-2 uppercase">Billing</h4>
                            <AddressDisplay Address="_billing" EmptyHint="No billing address set." />
                        </div>
                        <div>
                            <h4 class="text-fg-muted text-xs font-medium mb-2 uppercase">Shipping</h4>
                            @if (_shippingMode == ShippingMode.SameAsBilling)
                            {
                                <p class="text-fg-muted text-sm m-0">Same as billing</p>
                            }
                            else
                            {
                                <AddressDisplay Address="_shipping" EmptyHint="No shipping address set." />
                            }
                        </div>
                    </div>
                </div>
            </CitusFormSection>

            <CitusDrawer @bind-IsOpen="_addressDrawerOpen"
                         Title="Edit address"
                         Width="CitusDrawerWidth.Medium"
                         IsDirty="@AddressDraftIsDirty"
                         OnSave="SaveAddressDrawer">
                <AddressEditor @bind-Billing="_draftBilling"
                               @bind-Shipping="_draftShipping"
                               @bind-Mode="_draftMode"
                               CustomerId="_customerId" />
            </CitusDrawer>

            <CitusFormSection Title="Lines">
                <HeaderActions>
                    <select class="citus-form-field__input citus-inline-control--auto" value="@_taxMode" @onchange="OnTaxModeChanged">
                        <option value="exclusive">Tax exclusive</option>
                        <option value="inclusive">Tax inclusive</option>
                    </select>
                </HeaderActions>
                <ChildContent>
                <table class="citus-data-table citus-data-table--compact">
                    <thead>
                        <tr>
                            <th style="width: 2rem"></th>
                            <th style="width: 2.5rem">#</th>
                            <th style="width: 11rem">Service date</th>
                            <th style="width: 14rem">Product / Service</th>
                            <th>Description</th>
                            <th style="width: 6rem" class="text-right">Qty</th>
                            <th style="width: 8rem" class="text-right">Rate</th>
                            <th style="width: 8rem" class="text-right">Amount</th>
                            <th style="width: 9rem">Tax</th>
                            <th style="width: 3rem"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < _lines.Count; i++)
                        {
                            var index = i;
                            var line = _lines[index];
                            <tr @key="line"
                                ondragover="event.preventDefault()"
                                @ondrop="@(() => OnDropRow(index))"
                                class="@(_dragIndex == index ? "citus-line-row--dragging" : null)">
                                <td class="citus-line-grip" draggable="true" title="Drag to reorder"
                                    @ondragstart="@(() => _dragIndex = index)"
                                    @ondragend="@(() => _dragIndex = null)">
                                    <i class="ti ti-grip-vertical" aria-hidden="true"></i>
                                </td>
                                <td>@(index + 1)</td>
                                <td>
                                    <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd"
                                                      Value="@(line.ServiceDate?.ToDateTime(TimeOnly.MinValue))"
                                                      Change="@(args => UpdateLineServiceDate(index, args as DateTime?))"
                                                      ShowTime="false" Class="citus-control-full" />
                                </td>
                                <td>
                                    <RadzenDropDown TValue="Guid?"
                                                    Data="@_items"
                                                    Value="@line.ItemId"
                                                    Change="@(v => OnLineItemChanged(index, v as Guid?))"
                                                    TextProperty="Name"
                                                    ValueProperty="Id"
                                                    AllowFiltering="true"
                                                    AllowClear="true"
                                                    Class="citus-control-full">
                                        <Template Context="item">
                                            @{ var it = (ItemSummary)item; }
                                            <div class="citus-item-option">
                                                <span>@it.Name</span>
                                                @if (!string.IsNullOrWhiteSpace(it.ItemCode))
                                                {
                                                    <span class="citus-item-option__code">@it.ItemCode</span>
                                                }
                                            </div>
                                        </Template>
                                    </RadzenDropDown>
                                </td>
                                <td>
                                    <CitusInput TValue="string"
                                                Value="@line.Description"
                                                ValueChanged="@(v => UpdateLine(index, l => l with { Description = v ?? string.Empty }))" />
                                </td>
                                <td>
                                    <RadzenNumeric TValue="decimal" Value="@line.Quantity"
                                                   Change="@(v => UpdateLine(index, l => l with { Quantity = v }))"
                                                   Format="0.##" Class="citus-control-full" />
                                </td>
                                <td>
                                    <RadzenNumeric TValue="decimal" Value="@line.UnitPrice"
                                                   Change="@(v => UpdateLine(index, l => l with { UnitPrice = v }))"
                                                   Format="0.0000" Class="citus-control-full" />
                                </td>
                                <td class="text-right">@FormatAmount(line.Quantity * line.UnitPrice)</td>
                                <td>
                                    <RadzenDropDown TValue="Guid?"
                                                    Data="@_taxCodes"
                                                    Value="@line.TaxCodeId"
                                                    Change="@(v => UpdateLine(index, l => l with { TaxCodeId = v as Guid? }))"
                                                    TextProperty="Code"
                                                    ValueProperty="Id"
                                                    AllowClear="true"
                                                    Class="citus-control-full" />
                                </td>
                                <td>
                                    <CitusButton Variant="CitusButtonVariant.Ghost" Size="CitusButtonSize.Small"
                                                 OnClick="@(() => RemoveLine(index))"><i class="ti ti-trash" aria-hidden="true"></i></CitusButton>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="flex gap-2 mt-3">
                    <CitusButton Variant="CitusButtonVariant.Ghost" Size="CitusButtonSize.Small" OnClick="AddLine">+ Add line</CitusButton>
                    <CitusButton Variant="CitusButtonVariant.Ghost" Size="CitusButtonSize.Small" OnClick="ClearLines">Clear all lines</CitusButton>
                </div>
                </ChildContent>
            </CitusFormSection>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <CitusFormSection Title="Message + notes">
                    <CitusFormField Label="Message displayed on quote">
                        <CitusInput TValue="string" @bind-Value="_memoToCustomer" Placeholder="Visible to the customer." />
                    </CitusFormField>
                    <CitusFormField Label="Internal note" Class="mt-4">
                        <CitusInput TValue="string" @bind-Value="_internalNote" Placeholder="Private to your team." />
                    </CitusFormField>
                </CitusFormSection>

                @* Totals — Discount + Shipping inputs sit inline on their own
                   rows next to the computed amount (QuickBooks-style), so each
                   value appears once instead of being duplicated across a
                   separate "Discount + shipping" card and the totals readout.
                   Bindings + Subtotal/DiscountAmount/Total are unchanged. *@
                <CitusFormSection Title="Totals">
                    <div class="citus-quote-totals">
                        <div class="citus-quote-totals__row">
                            <span class="citus-quote-totals__label">Subtotal</span>
                            <span class="citus-quote-totals__amount">@FormatAmount(Subtotal)</span>
                        </div>
                        <div class="citus-quote-totals__row">
                            <span class="citus-quote-totals__label">Discount</span>
                            <div class="citus-quote-totals__controls">
                                <RadzenNumeric TValue="decimal?" Value="@_discountValue" Change="@OnDiscountValueChanged" Format="0.##" Class="citus-quote-totals__input" />
                                <div class="citus-discount-toggle" role="group" aria-label="Discount type">
                                    <button type="button" class="@(_discountKind != "amount" ? "is-active" : null)" @onclick="@(() => SetDiscountKind("percent"))">%</button>
                                    <button type="button" class="@(_discountKind == "amount" ? "is-active" : null)" @onclick="@(() => SetDiscountKind("amount"))">$</button>
                                </div>
                                <span class="citus-quote-totals__amount">−@FormatAmount(DiscountAmount)</span>
                            </div>
                        </div>
                        <div class="citus-quote-totals__row">
                            <span class="citus-quote-totals__label">Shipping</span>
                            <div class="citus-quote-totals__controls">
                                <RadzenNumeric TValue="decimal?" @bind-Value="_shippingAmount" Format="0.00" Class="citus-quote-totals__input" />
                                <span class="citus-quote-totals__amount">@FormatAmount(_shippingAmount ?? 0m)</span>
                            </div>
                        </div>
                        <div class="citus-quote-totals__row citus-quote-totals__row--total">
                            <span class="citus-quote-totals__label">Total</span>
                            <strong class="citus-quote-totals__amount">@FormatAmount(Total) @_currency</strong>
                        </div>
                    </div>
                </CitusFormSection>
            </div>
    </div>

    @* Sticky Send / Save draft / Cancel — Send is the primary, Save
       draft is a secondary in ExtraContent, Cancel routes back. The
       "Send" button is hidden once the quote is past Draft (matches
       the original inline footer's @if guard). *@
    <CitusFormActions Sticky="true"
                      Class="citus-form-actions--save-right"
                      PrimaryLabel="Send"
                      IsSaving="@_isSaving"
                      Disabled="@(!(_status == "draft" || _quoteId is null))"
                      ErrorHint="@(string.IsNullOrWhiteSpace(_validation) ? null : "Fix errors above")"
                      OnSave="@(() => SaveAsync(send: true))"
                      OnCancel="Cancel">
        <ExtraContent>
            <CitusButton Variant="CitusButtonVariant.Ghost"
                         Disabled="@_isSaving"
                         OnClick="@(() => SaveAsync(send: false))">
                @(_isSaving ? "Saving…" : "Save")
            </CitusButton>
        </ExtraContent>
    </CitusFormActions>
}

@code {
    [Parameter] public Guid? QuoteId { get; set; }

    private Guid? _quoteId;
    private string? _quoteNumber;
    private string _status = "draft";

    private IReadOnlyList<CustomerSummary> _customers = Array.Empty<CustomerSummary>();
    private IReadOnlyList<ItemSummary> _items = Array.Empty<ItemSummary>();
    private IReadOnlyList<TaxCodeSummary> _taxCodes = Array.Empty<TaxCodeSummary>();
    private IReadOnlyList<PaymentTermSummary> _paymentTerms = Array.Empty<PaymentTermSummary>();

    private Guid? _customerId;
    private string _customerDisplay = string.Empty;
    private string _email = string.Empty;
    private AddressDraft _billing = AddressDraft.Empty;
    private AddressDraft _shipping = AddressDraft.Empty;
    private ShippingMode _shippingMode = ShippingMode.SameAsBilling;

    // Drawer working copies. Populated when OpenAddressDrawer runs;
    // committed back to _billing / _shipping / _shippingMode on Save,
    // dropped on Cancel. AddressDraftIsDirty drives the drawer's
    // discard-confirmation prompt.
    private bool _addressDrawerOpen;
    private AddressDraft _draftBilling = AddressDraft.Empty;
    private AddressDraft _draftShipping = AddressDraft.Empty;
    private ShippingMode _draftMode = ShippingMode.SameAsBilling;

    private bool AddressDraftIsDirty =>
        _draftBilling != _billing ||
        _draftShipping != _shipping ||
        _draftMode != _shippingMode;
    private DateTime? _documentDate = DateTime.Today;
    private DateTime? _expirationDate;
    private string _currency = string.Empty;
    private decimal? _fxRate;
    private string _taxMode = "exclusive";
    private string? _discountKind;
    private decimal? _discountValue;
    private decimal? _shippingAmount;
    private string _memoToCustomer = string.Empty;
    private string _internalNote = string.Empty;
    private string _customerPoNumber = string.Empty;

    private List<LineDraft> _lines = new() { new LineDraft() };

    private bool _isLoading = true;
    private bool _isSaving;
    private string? _validation;
    // Optimistic-concurrency token; same pattern as BillCreatePage.
    private DateTimeOffset? _expectedUpdatedAt;
    private PageHeaderModel _header = new() { Eyebrow = "Sales & Get Paid", Title = "New quote", Subtitle = "Draft an estimate for a customer." };

    private decimal Subtotal => _lines.Sum(l => Math.Round(l.Quantity * l.UnitPrice, 4));
    private decimal DiscountAmount =>
        _discountKind == "percent" && _discountValue is { } pct ? Math.Round(Subtotal * pct / 100m, 4)
        : _discountKind == "amount" && _discountValue is { } amt ? Math.Round(amt, 4)
        : 0m;
    private decimal Total => Math.Round(Subtotal - DiscountAmount + (_shippingAmount ?? 0m), 4);

    protected override async Task OnInitializedAsync()
    {
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;
        await LoadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (QuoteId.HasValue && _quoteId != QuoteId)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            var customersTask = CustomerClient.ListAsync();
            var itemsTask = ItemClient.ListAsync();
            var taxTask = TaxCodeClient.ListAsync(appliesTo: "sales");
            var termsTask = PaymentTermClient.ListAsync(includeInactive: false);
            await Task.WhenAll(customersTask, itemsTask, taxTask, termsTask);
            _customers = customersTask.Result;
            _items = itemsTask.Result;
            _taxCodes = taxTask.Result;
            _paymentTerms = termsTask.Result;

            _quoteId = QuoteId;
            if (QuoteId is { } id)
            {
                var quote = await QuoteClient.GetByIdAsync(id);
                if (quote is null)
                {
                    _validation = "Quote not found.";
                    return;
                }
                ApplyExisting(quote);
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplyExisting(QuoteRecordDto quote)
    {
        _quoteNumber = quote.QuoteNumber;
        _status = quote.Status;
        _expectedUpdatedAt = quote.UpdatedAt;
        _header = new PageHeaderModel
        {
            Eyebrow = "Sales & Get Paid",
            Title = $"Edit {quote.QuoteNumber}",
            Subtitle = $"Status: {quote.Status}"
        };
        _customerId = quote.CustomerId;
        _customerDisplay = _customers.FirstOrDefault(c => c.Id == quote.CustomerId)?.DisplayName ?? string.Empty;
        _billing = new AddressDraft
        {
            AddressLine = quote.BillingAddressLine,
            City = quote.BillingCity,
            ProvinceState = quote.BillingProvinceState,
            PostalCode = quote.BillingPostalCode,
            Country = quote.BillingCountry,
        };
        _shipping = new AddressDraft
        {
            AddressLine = quote.ShippingAddressLine,
            City = quote.ShippingCity,
            ProvinceState = quote.ShippingProvinceState,
            PostalCode = quote.ShippingPostalCode,
            Country = quote.ShippingCountry,
        };
        // If the persisted shipping equals the billing (or shipping is
        // empty), default the editor to "Same as billing" so the
        // collapsed-state shows the simpler hint.
        _shippingMode = (_shipping.IsEmpty || _shipping == _billing)
            ? ShippingMode.SameAsBilling
            : ShippingMode.Different;
        _documentDate = quote.DocumentDate.ToDateTime(TimeOnly.MinValue);
        _expirationDate = quote.ExpirationDate?.ToDateTime(TimeOnly.MinValue);
        _currency = quote.TransactionCurrencyCode;
        _fxRate = quote.FxRate;
        _taxMode = quote.TaxMode;
        _discountKind = quote.DiscountKind;
        _discountValue = quote.DiscountValue;
        _shippingAmount = quote.ShippingAmount;
        _memoToCustomer = quote.MemoToCustomer ?? string.Empty;
        _internalNote = quote.InternalNote ?? string.Empty;
        _customerPoNumber = quote.CustomerPoNumber ?? string.Empty;
        _lines = quote.Lines.Select(l => new LineDraft
        {
            Sequence = l.Sequence,
            ServiceDate = l.ServiceDate,
            ItemId = l.ItemId,
            Description = l.Description,
            Quantity = l.Quantity,
            UnitPrice = l.UnitPrice,
            TaxCodeId = l.TaxCodeId,
            AccountCode = l.AccountCode
        }).ToList();
        if (_lines.Count == 0) _lines.Add(new LineDraft());
    }

    private void OnCustomerSelected(UnitySearchPickerOption option)
    {
        _customerId = option.SourceId;
        _customerDisplay = option.DisplayText;
        OnCustomerChanged();
    }

    private void OnCustomerCleared()
    {
        _customerId = null;
        _customerDisplay = string.Empty;
    }

    private void OnCustomerChanged()
    {
        if (_customerId is null) return;
        var customer = _customers.FirstOrDefault(c => c.Id == _customerId.Value);
        if (customer is null) return;

        _email = customer.Email ?? _email;
        // Auto-prefill billing from the customer master, but only if
        // the operator hasn't already typed an address — replacing a
        // partial typing is more annoying than helpful.
        if (_billing.IsEmpty)
        {
            _billing = new AddressDraft
            {
                AddressLine = customer.AddressLine,
                City = customer.City,
                ProvinceState = customer.ProvinceState,
                PostalCode = customer.PostalCode,
                Country = customer.Country,
            };
        }
        _currency = customer.DefaultCurrencyCode;
        if (customer.PaymentTermId is { } termId)
        {
            var term = _paymentTerms.FirstOrDefault(t => t.Id == termId);
            if (term is not null && _documentDate is { } docDate)
            {
                _expirationDate = docDate.AddDays(term.NetDays);
            }
        }
    }

    private void OnLineItemChanged(int index, Guid? itemId)
    {
        if (index < 0 || index >= _lines.Count) return;
        var line = _lines[index];
        line.ItemId = itemId;
        if (itemId is null) return;
        var item = _items.FirstOrDefault(i => i.Id == itemId.Value);
        if (item is null) return;
        if (string.IsNullOrWhiteSpace(line.Description)) line.Description = item.Name;
        if (line.UnitPrice == 0m) line.UnitPrice = item.DefaultSalesPrice ?? 0m;
        if (line.TaxCodeId is null) line.TaxCodeId = item.DefaultSalesTaxCodeId;
    }

    private void UpdateLine(int index, Func<LineDraft, LineDraft> mutate)
    {
        if (index < 0 || index >= _lines.Count) return;
        var current = _lines[index];
        var updated = mutate(current);
        current.ServiceDate = updated.ServiceDate;
        current.ItemId = updated.ItemId;
        current.Description = updated.Description;
        current.Quantity = updated.Quantity;
        current.UnitPrice = updated.UnitPrice;
        current.TaxCodeId = updated.TaxCodeId;
        current.AccountCode = updated.AccountCode;
    }

    private void UpdateLineServiceDate(int index, DateTime? value)
    {
        if (index < 0 || index >= _lines.Count) return;
        _lines[index].ServiceDate = value is null ? null : DateOnly.FromDateTime(value.Value);
    }

    private void AddLine() => _lines.Add(new LineDraft());

    // Frontend-only drag-to-reorder: the grip cell is the drag source, each
    // row is the drop target. Sequence is still assigned from list order at
    // save time, so the payload / backend contract is unchanged.
    private int? _dragIndex;
    private void OnDropRow(int targetIndex)
    {
        if (_dragIndex is not { } src) return;
        _dragIndex = null;
        if (src == targetIndex || src < 0 || src >= _lines.Count || targetIndex < 0 || targetIndex >= _lines.Count) return;
        var moved = _lines[src];
        _lines.RemoveAt(src);
        _lines.Insert(targetIndex, moved);
    }

    private void RemoveLine(int index)
    {
        if (index < 0 || index >= _lines.Count) return;
        _lines.RemoveAt(index);
        if (_lines.Count == 0) _lines.Add(new LineDraft());
    }

    private void ClearLines() { _lines.Clear(); _lines.Add(new LineDraft()); }

    private void OnTaxModeChanged(ChangeEventArgs args) =>
        _taxMode = args.Value?.ToString() ?? "exclusive";

    private void SetDiscountKind(string kind) => _discountKind = kind;

    private void OnDiscountValueChanged(decimal? value)
    {
        _discountValue = value;
        // First value entered defaults the kind to percent (the toggle shows %
        // by default); an empty value keeps kind null = no discount, as before.
        if (value is not null && _discountKind is null) _discountKind = "percent";
    }

    private void OpenAddressDrawer()
    {
        // Snapshot current state into the drawer's working copy so
        // Cancel can drop edits cleanly. Mode + records are value
        // types so this is a cheap copy.
        _draftBilling = _billing;
        _draftShipping = _shipping;
        _draftMode = _shippingMode;
        _addressDrawerOpen = true;
    }

    private void SaveAddressDrawer()
    {
        _billing = _draftBilling;
        _shipping = _draftShipping;
        _shippingMode = _draftMode;
        _addressDrawerOpen = false;
    }

    private async Task SaveAsync(bool send)
    {
        _validation = null;
        if (_customerId is null)
        {
            _validation = "Please pick a customer.";
            return;
        }
        if (_lines.All(l => l.Quantity == 0 && l.UnitPrice == 0 && string.IsNullOrWhiteSpace(l.Description)))
        {
            _validation = "Add at least one line with quantity / rate.";
            return;
        }

        _isSaving = true;
        try
        {
            var payload = new QuoteUpsertPayload(
                CustomerId: _customerId.Value,
                DocumentDate: DateOnly.FromDateTime((_documentDate ?? DateTime.Today).Date),
                ExpirationDate: _expirationDate is { } exp ? DateOnly.FromDateTime(exp.Date) : null,
                TransactionCurrencyCode: string.IsNullOrWhiteSpace(_currency) ? ShellState.ActiveCompany.BaseCurrencyCode : _currency,
                FxRate: _fxRate,
                BillingAddressLine: _billing.AddressLine,
                BillingCity: _billing.City,
                BillingProvinceState: _billing.ProvinceState,
                BillingPostalCode: _billing.PostalCode,
                BillingCountry: _billing.Country,
                // SameAsBilling persists with billing copied into shipping
                // so a downstream PDF / email always has a populated
                // shipping block without needing to re-derive at render
                // time.
                ShippingAddressLine: (_shippingMode == ShippingMode.SameAsBilling ? _billing : _shipping).AddressLine,
                ShippingCity: (_shippingMode == ShippingMode.SameAsBilling ? _billing : _shipping).City,
                ShippingProvinceState: (_shippingMode == ShippingMode.SameAsBilling ? _billing : _shipping).ProvinceState,
                ShippingPostalCode: (_shippingMode == ShippingMode.SameAsBilling ? _billing : _shipping).PostalCode,
                ShippingCountry: (_shippingMode == ShippingMode.SameAsBilling ? _billing : _shipping).Country,
                ShipVia: null,
                ShippingDate: null,
                TrackingNo: null,
                TaxMode: _taxMode,
                DiscountKind: _discountKind,
                DiscountValue: _discountValue,
                ShippingAmount: _shippingAmount,
                ShippingTaxCodeId: null,
                MemoToCustomer: NullIfEmpty(_memoToCustomer),
                InternalNote: NullIfEmpty(_internalNote),
                CustomerPoNumber: NullIfEmpty(_customerPoNumber),
                Lines: _lines
                    .Where(l => l.Quantity > 0 || l.UnitPrice > 0 || !string.IsNullOrWhiteSpace(l.Description) || l.ItemId is not null)
                    .Select((l, i) => new QuoteLinePayload(
                        Sequence: i + 1,
                        ServiceDate: l.ServiceDate,
                        ItemId: l.ItemId,
                        Description: l.Description ?? string.Empty,
                        Quantity: l.Quantity,
                        UnitPrice: l.UnitPrice,
                        TaxCodeId: l.TaxCodeId,
                        AccountCode: l.AccountCode))
                    .ToArray(),
                ExpectedUpdatedAt: _quoteId is null ? null : _expectedUpdatedAt);

            QuoteMutationOutcome outcome = _quoteId is null
                ? await QuoteClient.CreateAsync(payload)
                : await QuoteClient.UpdateAsync(_quoteId.Value, payload);

            if (!outcome.Succeeded || outcome.Saved is null)
            {
                if (outcome.IsConcurrencyConflict)
                {
                    _validation = outcome.ErrorMessage
                        ?? "This quote was modified by another session. Reload the page to see the latest version, then re-apply your changes.";
                    await Message.WarningAsync(_validation);
                    return;
                }
                _validation = outcome.ErrorMessage ?? "Could not save the quote.";
                return;
            }

            var saved = outcome.Saved;
            // Refresh the token from the just-saved row so consecutive
            // saves in this same editor session don't self-conflict.
            _expectedUpdatedAt = saved.UpdatedAt;
            if (send && saved.Status == "draft")
            {
                var sentOutcome = await QuoteClient.SetStatusAsync(saved.Id, "pending");
                if (!sentOutcome.Succeeded)
                {
                    _validation = sentOutcome.ErrorMessage ?? "Saved, but could not transition to Pending.";
                    await Message.WarningAsync(_validation);
                }
                else
                {
                    await Message.SuccessAsync($"Quote {saved.QuoteNumber} sent.");
                }
            }
            else
            {
                await Message.SuccessAsync($"Quote {saved.QuoteNumber} saved.");
            }

            Navigation.NavigateTo($"quotes/{saved.Id:D}");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Cancel() => Navigation.NavigateTo(_quoteId is null ? "quotes" : $"quotes/{_quoteId:D}");

    private static string FormatAmount(decimal value) =>
        value.ToString("N2", System.Globalization.CultureInfo.InvariantCulture);

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed record LineDraft
    {
        public int Sequence { get; set; }
        public DateOnly? ServiceDate { get; set; }
        public Guid? ItemId { get; set; }
        public string Description { get; set; } = string.Empty;
        public decimal Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public Guid? TaxCodeId { get; set; }
        public string? AccountCode { get; set; }
    }
}
