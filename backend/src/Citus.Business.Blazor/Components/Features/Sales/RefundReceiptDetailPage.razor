@page "/refund-receipts/{RefundId:guid}"

@inject BusinessShellState ShellState
@inject RefundReceiptClient RefundReceiptClient
@inject AccountClient AccountClient
@inject CustomerClient CustomerClient
@inject NavigationManager Navigation

<PageTitle>@($"{_pageTitle} | Tralanz Books")</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusLinkButton Href="refund-receipts/new"
                         Variant="CitusButtonVariant.Ghost"
                         LeadingIcon="IconName.Plus">
            New refund receipt
        </CitusLinkButton>
    </Actions>
</CitusPageHeader>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_error" ShowIcon="true" Class="mb-4" />
}

@if (_isLoading)
{
    <CitusSkeleton Variant="SkeletonVariant.Detail" />
}
else if (_doc is null)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="Refund receipt not found in this company." ShowIcon="true" />
}
else
{
    <CitusStatCardGrid Columns="4">
        <CitusStatCard Label="Refund #" Value="@_doc.DisplayNumber" Description="@_customerName"
                       Icon="IconName.ArrowLeft" Tone="StatTone.Warning" />
        <CitusStatCard Label="Status" Value="@HumanizeStatus(_doc.Status)" Description="@StatusHint(_doc.Status)"
                       Icon="IconName.Eye" Tone="@StatusTone(_doc.Status)" />
        <CitusStatCard Label="Total refunded" Value="@($"-{_doc.TotalAmount:N2} {_doc.TransactionCurrencyCode}")"
                       Description="@($"Subtotal {_doc.SubtotalAmount:N2} + tax {_doc.TaxAmount:N2}")"
                       Icon="IconName.Coin" Tone="StatTone.Warning" />
        <CitusStatCard Label="Refund date" Value="@_doc.RefundDate.ToString("yyyy-MM-dd")"
                       Description="@_doc.PaymentMethod"
                       Icon="IconName.Calendar" Tone="StatTone.Neutral" />
    </CitusStatCardGrid>

    @* Copy A3 Phase 3: actions bar with the standard More menu. *@
    <CitusActionsPanel MoreMenuItems="@_moreItems" />

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-8">
            <CitusFormSection Title="Lines reversed">
                <table class="citus-data-table">
                    <thead>
                        <tr>
                            <th style="width: 3rem">#</th>
                            <th>Account</th>
                            <th>Description</th>
                            <th class="text-right" style="width: 5rem">Qty</th>
                            <th class="text-right" style="width: 8rem">Unit price</th>
                            <th class="text-right" style="width: 7rem">Tax</th>
                            <th class="text-right" style="width: 9rem">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in _doc.Lines)
                        {
                            <tr>
                                <td>@line.LineNumber</td>
                                <td>@ResolveAccountLabel(line.RevenueAccountId)</td>
                                <td>@(string.IsNullOrEmpty(line.Description) ? "—" : line.Description)</td>
                                <td class="text-right">@line.Quantity.ToString("0.##")</td>
                                <td class="text-right">@line.UnitPrice.ToString("N2")</td>
                                <td class="text-right">@line.TaxAmount.ToString("N2")</td>
                                <td class="text-right">@line.LineAmount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </CitusFormSection>

            @if (!string.IsNullOrWhiteSpace(_doc.Memo) || !string.IsNullOrWhiteSpace(_doc.Reason))
            {
                <CitusFormSection Title="@(string.IsNullOrWhiteSpace(_doc.Reason) ? null : "Reason")">
                    @if (!string.IsNullOrWhiteSpace(_doc.Reason))
                    {
                        <p class="text-fg-muted text-sm mb-3">@_doc.Reason</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(_doc.Memo))
                    {
                        <h3 class="text-sm font-semibold mt-3">Memo</h3>
                        <p class="text-fg-muted text-sm">@_doc.Memo</p>
                    }
                </CitusFormSection>
            }
        </div>

        <aside class="lg:col-span-4 flex flex-col gap-6">
            <CitusFormSection Title="Document">
                <CitusKeyValueTable>
                    <CitusKeyValueRow Label="Refund no."><span class="citus-inline-code">@_doc.DisplayNumber</span></CitusKeyValueRow>
                    <CitusKeyValueRow Label="Internal #"><span class="citus-inline-code">@_doc.EntityNumber</span></CitusKeyValueRow>
                    <CitusKeyValueRow Label="Customer">@_customerName</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Refund date">@_doc.RefundDate.ToString("yyyy-MM-dd")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Currency">@_doc.TransactionCurrencyCode</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Method">@_doc.PaymentMethod</CitusKeyValueRow>
                    @if (!string.IsNullOrWhiteSpace(_doc.ReferenceNo))
                    {
                        <CitusKeyValueRow Label="Reference">@_doc.ReferenceNo</CitusKeyValueRow>
                    }
                    @if (!string.IsNullOrWhiteSpace(_doc.CustomerPoNumber))
                    {
                        <CitusKeyValueRow Label="Customer PO #"><span class="citus-inline-code">@_doc.CustomerPoNumber</span></CitusKeyValueRow>
                    }
                    <CitusKeyValueRow Label="Refunded from">@ResolveAccountLabel(_doc.RefundFromAccountId)</CitusKeyValueRow>
                </CitusKeyValueTable>
            </CitusFormSection>

            <CitusFormSection Title="Totals">
                <CitusKeyValueTable>
                    <CitusKeyValueRow Label="Subtotal" ValueAlignRight="true">@_doc.SubtotalAmount.ToString("N2")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Tax" ValueAlignRight="true">@_doc.TaxAmount.ToString("N2")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Total" ValueAlignRight="true"><strong>@_doc.TotalAmount.ToString("N2") @_doc.TransactionCurrencyCode</strong></CitusKeyValueRow>
                </CitusKeyValueTable>
            </CitusFormSection>
        </aside>
    </div>
}

@code {
    [Parameter] public Guid RefundId { get; set; }

    private RefundReceiptRecordDto? _doc;
    private string _customerName = "—";
    private IReadOnlyList<AccountSummary> _accounts = Array.Empty<AccountSummary>();
    private bool _isLoading = true;
    private string? _error;
    private string _pageTitle = "Refund receipt";
    private PageHeaderModel _header = new() { Eyebrow = "Sales & Get Paid", Title = "Refund receipt", Subtitle = "Refund detail" };

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override async Task OnParametersSetAsync()
    {
        if (_doc is not null && _doc.Id != RefundId) await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            var docTask = RefundReceiptClient.GetByIdAsync(RefundId, ShellState.ActiveCompany.Id);
            var accountsTask = AccountClient.ListAsync();
            await Task.WhenAll(docTask, accountsTask);
            _doc = docTask.Result;
            _accounts = accountsTask.Result;
            if (_doc is not null)
            {
                var customer = await CustomerClient.GetByIdAsync(_doc.CustomerId);
                _customerName = customer?.DisplayName ?? "—";
            }
            if (_doc is not null)
            {
                _pageTitle = _doc.DisplayNumber;
                _header = new PageHeaderModel { Eyebrow = "Sales & Get Paid", Title = _doc.DisplayNumber, Subtitle = $"{_customerName} · {HumanizeStatus(_doc.Status)}" };
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _isLoading = false; }
    }

    private string ResolveAccountLabel(Guid accountId)
    {
        var account = _accounts.FirstOrDefault(a => a.Id == accountId);
        return account is null ? accountId.ToString("D") : $"{account.Code}  {account.Name}";
    }

    // Copy A3 Phase 3.
    private void CopyAsync()
    {
        if (_doc is null) return;
        Navigation.NavigateTo($"refund-receipts/new?copyFrom={_doc.Id:D}");
    }

    private IReadOnlyList<CitusMoreMenuItem> _moreItems => _doc is null
        ? Array.Empty<CitusMoreMenuItem>()
        : new[]
        {
            new CitusMoreMenuItem { Label = "Copy", OnClick = EventCallback.Factory.Create(this, CopyAsync) }
        };

    private static string HumanizeStatus(string status) => status switch
    {
        "draft" => "Draft", "posted" => "Posted", "voided" => "Voided", "reversed" => "Reversed", _ => status
    };

    private static string StatusHint(string status) => status switch
    {
        "draft" => "Not posted yet.",
        "posted" => "Refund disbursed; GL posted.",
        "voided" => "Voided.",
        "reversed" => "Reversed.",
        _ => string.Empty
    };

    private static StatTone StatusTone(string status) => status switch
    {
        "draft" => StatTone.Neutral,
        "posted" => StatTone.Warning,
        "voided" => StatTone.Neutral,
        "reversed" => StatTone.Warning,
        _ => StatTone.Neutral
    };
}
