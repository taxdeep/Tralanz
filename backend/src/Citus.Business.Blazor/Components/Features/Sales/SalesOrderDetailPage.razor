@page "/sales-orders/{SalesOrderId:guid}"

@inject BusinessShellState ShellState
@inject SalesOrderClient SalesOrderClient
@inject CustomerDepositClient CustomerDepositClient
@inject CitusToastService Message
@inject NavigationManager Navigation

@* M5 wrap-up: show deposit balance + per-deposit detail when deposits
   exist on this SO. *@

<PageTitle>@($"{_pageTitle} | Tralanz Books")</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <a class="citus-button citus-button--ghost" href="sales-orders">
            <CitusIcon Name="IconName.ArrowLeft" Size="IconSize.Inline" />
            <span>Back to sales orders</span>
        </a>
        @if (_so is not null && IsEditable(_so.Status))
        {
            <a class="citus-button" href="@($"sales-orders/{_so.Id:D}/edit")">
                <CitusIcon Name="IconName.Pencil" Size="IconSize.Inline" />
                <span>Edit</span>
            </a>
        }
    </Actions>
</CitusPageHeader>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_error" ShowIcon="true" Class="mb-4" />
}

@if (_isLoading)
{
    <CitusSkeleton Variant="SkeletonVariant.Detail" />
}
else if (_so is null)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="Sales order not found in this company." ShowIcon="true" />
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <CitusStatCard Label="Sales Order" Value="@_so.SalesOrderNumber" Description="@_so.CustomerName"
                       Icon="IconName.Receipt" Tone="StatTone.Primary" />
        <CitusStatCard Label="Status" Value="@HumanizeStatus(_so.Status)" Description="@StatusHint(_so.Status)"
                       Icon="IconName.Eye" Tone="@StatusTone(_so.Status)" />
        <CitusStatCard Label="Total" Value="@($"{_so.TotalAmount:N2} {_so.TransactionCurrencyCode}")"
                       Description="@($"Subtotal {_so.SubtotalAmount:N2}")"
                       Icon="IconName.Coin" Tone="StatTone.Success" />
        <CitusStatCard Label="Source"
                       Value="@(_so.SourceQuoteNumber ?? "Direct")"
                       Description="@(_so.SourceQuoteId is null ? "Created directly." : "Converted from quote.")"
                       Icon="IconName.FileText" Tone="StatTone.Neutral" />
    </div>

    <section class="citus-panel mb-6">
        <h2 class="citus-panel__title">Actions</h2>
        <div class="flex flex-wrap gap-2 items-center">
            @if (_so.Status == "open")
            {
                @* M5 iter 1: confirming reserves on-hand stock per line and
                   flips status to 'confirmed'. Items with backorder_mode=
                   'disallow' fail with a precise shortage message. *@
                <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_isMutating" OnClick="ConfirmAsync">
                    <CitusIcon Name="IconName.CircleCheck" Size="IconSize.Inline" />
                    <span>Confirm</span>
                </CitusButton>

                @* Direct-invoice path stays available for SOs that don't
                   need reservation tracking (services, single-shot). The new
                   invoice carries this SO's id as a back-link, which drives
                   the M3 iter 3 auto-COGS bridge on post. *@
                <a class="citus-button citus-button--ghost" href="@($"invoices/new?fromSalesOrderId={_so.Id:D}")">
                    <CitusIcon Name="IconName.FileInvoice" Size="IconSize.Inline" />
                    <span>Create Invoice</span>
                </a>

                @* Manual mark — for "I billed this in another system". *@
                <CitusInput TValue="string" @bind-Value="_invoiceNumberInput" Placeholder="External invoice #…" />
                <CitusButton Variant="CitusButtonVariant.Ghost" Disabled="_isMutating" OnClick="MarkInvoicedAsync">
                    Mark Invoiced
                </CitusButton>
                <CitusButton Variant="CitusButtonVariant.Ghost" Disabled="_isMutating" OnClick="CancelAsync">
                    Cancel
                </CitusButton>
            }
            else if (_so.Status == "confirmed")
            {
                @* Confirmed: reservations are in place. Operator goes
                   straight to invoicing, or can still mark / cancel. M5
                   iter 5 will wire reservation release on cancel. *@
                <a class="citus-button citus-button--primary" href="@($"invoices/new?fromSalesOrderId={_so.Id:D}")">
                    <CitusIcon Name="IconName.FileInvoice" Size="IconSize.Inline" />
                    <span>Create Invoice</span>
                </a>
                <CitusInput TValue="string" @bind-Value="_invoiceNumberInput" Placeholder="External invoice #…" />
                <CitusButton Variant="CitusButtonVariant.Ghost" Disabled="_isMutating" OnClick="MarkInvoicedAsync">
                    Mark Invoiced
                </CitusButton>
                <CitusButton Variant="CitusButtonVariant.Ghost" Disabled="_isMutating" OnClick="CancelAsync">
                    Cancel
                </CitusButton>
                @if (_so.ConfirmedAt is { } confirmedAt)
                {
                    <span class="text-fg-subtle text-xs">Confirmed @confirmedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm").</span>
                }
            }
            else if (_so.Status == "invoiced")
            {
                <span class="text-fg-muted text-sm">Invoiced as <strong>@_so.InvoiceNumber</strong>.</span>
            }
            @if (_so.SourceQuoteId is { } quoteId)
            {
                <a class="citus-button citus-button--ghost" href="@($"quotes/{quoteId:D}")">View source quote</a>
            }
        </div>
    </section>

    @* M5 iter 3: standalone customer deposit. Available while the SO is
       not yet billed — captures a prepayment that lands as a Customer
       Deposit liability (24700) instead of touching AR. M5 iter 4 will
       pro-rata clear these against shipments / invoices. *@
    @if (_so.Status is "open" or "confirmed")
    {
        <section class="citus-panel mb-6">
            <h2 class="citus-panel__title">Receive Customer Deposit</h2>
            <p class="text-fg-muted text-sm mb-3">
                Capture a prepayment from @_so.CustomerName for this Sales Order.
                The cash lands on the Customer Deposit liability (account 24700);
                no invoice or AR row is created. V1 supports same-currency only.
            </p>

            @if (!string.IsNullOrWhiteSpace(_depositError))
            {
                <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_depositError" ShowIcon="true" Class="mb-3" />
            }

            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                <div class="md:col-span-2">
                    <label class="text-sm font-medium block mb-1">Deposit to (bank / cash)</label>
                    <AccountPicker CompanyId="@ShellState.ActiveCompany.Id"
                                   UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                   Context="customer_deposit.deposit_to"
                                   AllowedRootTypes="asset"
                                   SelectedId="@_depositBankAccountId"
                                   SelectedDisplayText="@_depositBankAccountDisplay"
                                   Placeholder="Select bank / cash / credit card…"
                                   DefaultCurrencyCode="@_so.TransactionCurrencyCode"
                                   OnAccountSelected="OnDepositBankSelected"
                                   OnCleared="OnDepositBankCleared" />
                </div>
                <div>
                    <label class="text-sm font-medium block mb-1">Amount (@_so.TransactionCurrencyCode)</label>
                    <RadzenNumeric TValue="decimal" @bind-Value="_depositAmount" Min="0" Format="0.00" Class="citus-control-full" />
                </div>
                <div class="md:col-span-3">
                    <label class="text-sm font-medium block mb-1">Memo</label>
                    <CitusInput TValue="string" @bind-Value="_depositMemo" Placeholder="Optional note (e.g. 'Down payment per signed PO')." />
                </div>
            </div>

            <div class="flex gap-2 items-center mt-3">
                <CitusButton Variant="CitusButtonVariant.Primary"
                             Disabled="@(_depositSubmitting || _depositAmount <= 0 || _depositBankAccountId is null)"
                             OnClick="ReceiveDepositAsync">
                    @(_depositSubmitting ? "Posting…" : "Receive deposit")
                </CitusButton>
                @if (_depositAmount > 0 && _depositBankAccountId is null)
                {
                    <span class="text-fg-subtle text-sm">Pick a bank / cash account first.</span>
                }
            </div>
        </section>
    }

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-8">
            <section class="citus-panel">
                <h2 class="citus-panel__title">Lines</h2>
                <table class="citus-data-table">
                    <thead>
                        <tr>
                            <th style="width: 3rem">#</th>
                            <th>Description</th>
                            <th class="text-right" style="width: 5rem">Qty</th>
                            @* Show reservation columns only once any line has a non-zero
                               reserved/backorder/shipped — keeps the table compact for
                               unconfirmed / service-only SOs. *@
                            @if (_showReservationColumns)
                            {
                                <th class="text-right" style="width: 6rem">Reserved</th>
                                <th class="text-right" style="width: 6rem">Backorder</th>
                                <th class="text-right" style="width: 6rem">Shipped</th>
                            }
                            <th class="text-right" style="width: 7rem">Rate</th>
                            <th class="text-right" style="width: 8rem">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in _so.Lines)
                        {
                            <tr>
                                <td>@line.Sequence</td>
                                <td>@(string.IsNullOrEmpty(line.Description) ? "—" : line.Description)</td>
                                <td class="text-right">@line.Quantity.ToString("0.##")</td>
                                @if (_showReservationColumns)
                                {
                                    <td class="text-right tabular-nums">@FormatQty(line.ReservedQty)</td>
                                    <td class="text-right tabular-nums">@FormatQty(line.BackorderQty)</td>
                                    <td class="text-right tabular-nums">@FormatQty(line.ShippedQty)</td>
                                }
                                <td class="text-right">@line.UnitPrice.ToString("0.0000")</td>
                                <td class="text-right">@line.LineTotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>

            @* M5 wrap-up: Customer Deposits balance panel. Shown only when
               at least one deposit has been received against this SO; the
               summary line surfaces collected / applied / remaining + a
               per-deposit table for full visibility. *@
            @if (_depositSummary is { Deposits.Count: > 0 } depSummary)
            {
                <section class="citus-panel mt-6">
                    <header class="citus-panel__header">
                        <h2 class="citus-panel__title">Customer Deposits</h2>
                        <span class="text-fg-subtle text-xs">@_so.TransactionCurrencyCode</span>
                    </header>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-3">
                        <CitusStatCard Label="Collected" Value="@FormatMoney(depSummary.TotalOriginalBase)"
                                       Description="Total received against this SO"
                                       Icon="IconName.Cash" Tone="StatTone.Primary" />
                        <CitusStatCard Label="Applied" Value="@FormatMoney(depSummary.TotalAppliedBase)"
                                       Description="Cleared against invoices"
                                       Icon="IconName.CircleCheck" Tone="StatTone.Success" />
                        <CitusStatCard Label="Remaining" Value="@FormatMoney(depSummary.TotalOpenBase)"
                                       Description="Open liability — apply or refund"
                                       Icon="IconName.Coin"
                                       Tone="@(depSummary.TotalOpenBase > 0m ? StatTone.Info : StatTone.Neutral)" />
                    </div>
                    <table class="citus-data-table">
                        <thead>
                            <tr>
                                <th>Deposit #</th>
                                <th style="width: 8rem">Date</th>
                                <th class="text-right" style="width: 8rem">Original</th>
                                <th class="text-right" style="width: 8rem">Applied</th>
                                <th class="text-right" style="width: 8rem">Remaining</th>
                                <th style="width: 8rem">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var dep in depSummary.Deposits)
                            {
                                <tr>
                                    <td><span class="citus-inline-code">@dep.DisplayNumber</span></td>
                                    <td>@dep.DepositDate.ToString("yyyy-MM-dd")</td>
                                    <td class="text-right tabular-nums">@FormatMoney(dep.OriginalAmountBase)</td>
                                    <td class="text-right tabular-nums">@FormatMoney(dep.AppliedAmountBase)</td>
                                    <td class="text-right tabular-nums">@FormatMoney(dep.OpenAmountBase)</td>
                                    <td>
                                        <CitusBadge Color="@DepositStatusColor(dep.Status)">@HumanizeDepositStatus(dep.Status)</CitusBadge>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </section>
            }
        </div>

        <aside class="lg:col-span-4 flex flex-col gap-6">
            <section class="citus-panel">
                <h2 class="citus-panel__title">Customer</h2>
                <table class="citus-keyvalue">
                    <tbody>
                        <tr><th>Name</th><td>@_so.CustomerName</td></tr>
                        @if (!string.IsNullOrWhiteSpace(_so.CustomerPoNumber))
                        {
                            <tr><th>Customer PO #</th><td><span class="citus-inline-code">@_so.CustomerPoNumber</span></td></tr>
                        }
                        @if (HasAddress(_so))
                        {
                            <tr><th>Billing address</th><td>@FormatAddress(_so.BillingAddressLine, _so.BillingCity, _so.BillingProvinceState, _so.BillingPostalCode, _so.BillingCountry)</td></tr>
                        }
                    </tbody>
                </table>
            </section>

            <section class="citus-panel">
                <h2 class="citus-panel__title">Totals</h2>
                <table class="citus-keyvalue">
                    <tbody>
                        <tr><th>Subtotal</th><td class="text-right">@_so.SubtotalAmount.ToString("N2")</td></tr>
                        <tr><th>Discount</th><td class="text-right">−@_so.DiscountAmount.ToString("N2")</td></tr>
                        <tr><th>Shipping</th><td class="text-right">@((_so.ShippingAmount ?? 0m).ToString("N2"))</td></tr>
                        <tr><th>Total</th><td class="text-right"><strong>@_so.TotalAmount.ToString("N2") @_so.TransactionCurrencyCode</strong></td></tr>
                    </tbody>
                </table>
            </section>
        </aside>
    </div>
}

@code {
    [Parameter] public Guid SalesOrderId { get; set; }

    private SalesOrderRecordDto? _so;
    private string _invoiceNumberInput = string.Empty;
    private bool _isLoading = true;
    private bool _isMutating;
    private string? _error;

    private PageHeaderModel _header = new() { Eyebrow = "Sales & Get Paid", Title = "Sales order", Subtitle = "Sales order detail" };
    private string _pageTitle = "Sales order";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override async Task OnParametersSetAsync()
    {
        if (_so is not null && _so.Id != SalesOrderId)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            // Load SO + deposit summary in parallel — deposit lookup is a
            // separate roundtrip but cheap (single JOIN on indexed cols).
            var soTask = SalesOrderClient.GetByIdAsync(SalesOrderId);
            var depositTask = CustomerDepositClient.GetForSalesOrderAsync(SalesOrderId);
            await Task.WhenAll(soTask, depositTask);
            _so = soTask.Result;
            _depositSummary = depositTask.Result;
            ApplyHeader();
        }
        finally { _isLoading = false; }
    }

    private void ApplyHeader()
    {
        if (_so is null)
        {
            _pageTitle = "Sales order";
            _header = new PageHeaderModel { Eyebrow = "Sales & Get Paid", Title = "Sales order", Subtitle = "Sales order detail" };
            return;
        }
        _pageTitle = _so.SalesOrderNumber;
        _header = new PageHeaderModel
        {
            Eyebrow = "Sales & Get Paid",
            Title = _so.SalesOrderNumber,
            Subtitle = $"{_so.CustomerName} · {HumanizeStatus(_so.Status)}"
        };
    }

    /// <summary>
    /// True when any line carries a non-zero reserved/backorder/shipped
    /// counter — reveals the M5 reservation columns in the lines table.
    /// </summary>
    private bool _showReservationColumns =>
        _so?.Lines.Any(l => l.ReservedQty > 0 || l.BackorderQty > 0 || l.ShippedQty > 0) ?? false;

    private static string FormatQty(decimal qty) =>
        qty == 0m ? "—" : qty.ToString("0.##");

    // M5 iter 3: customer-deposit form state.
    private decimal _depositAmount;
    private Guid? _depositBankAccountId;
    private string _depositBankAccountDisplay = string.Empty;
    private string _depositMemo = string.Empty;
    private bool _depositSubmitting;
    private string? _depositError;

    // M5 wrap-up: deposit balance summary loaded after the SO loads.
    private SalesOrderCustomerDepositSummaryDto? _depositSummary;

    private static string FormatMoney(decimal amount) => amount.ToString("N2");

    private static string DepositStatusColor(string status) => status switch
    {
        "open" => "blue",
        "partially_applied" => "geekblue",
        "closed" => "green",
        "voided" => "default",
        _ => "default"
    };

    private static string HumanizeDepositStatus(string status) => status switch
    {
        "open" => "Open",
        "partially_applied" => "Partially applied",
        "closed" => "Closed",
        "voided" => "Voided",
        _ => status
    };

    private void OnDepositBankSelected(AccountSummary account)
    {
        _depositBankAccountId = account.Id;
        _depositBankAccountDisplay = $"{account.Code} {account.Name}";
    }

    private void OnDepositBankCleared()
    {
        _depositBankAccountId = null;
        _depositBankAccountDisplay = string.Empty;
    }

    private async Task ReceiveDepositAsync()
    {
        if (_so is null || _depositSubmitting) return;
        if (_depositBankAccountId is null) { _depositError = "Pick a bank / cash account."; return; }
        if (_depositAmount <= 0) { _depositError = "Amount must be greater than zero."; return; }

        _depositError = null;
        _depositSubmitting = true;
        try
        {
            var outcome = await CustomerDepositClient.PostAsync(
                _so.Id,
                new CustomerDepositPostRequest(
                    DepositToAccountId: _depositBankAccountId.Value,
                    AmountTx: _depositAmount,
                    DocumentDate: DateOnly.FromDateTime(DateTime.Today),
                    Memo: string.IsNullOrWhiteSpace(_depositMemo) ? null : _depositMemo.Trim()));

            if (!outcome.Succeeded || outcome.Saved is null)
            {
                _depositError = outcome.ErrorMessage ?? "Could not post the deposit.";
                await Message.WarningAsync(_depositError);
                return;
            }

            var saved = outcome.Saved;
            await Message.SuccessAsync(
                $"Deposit {saved.DisplayNumber} posted ({saved.AmountBase:N2}). " +
                $"Journal entry {saved.JournalEntryDisplayNumber}.");

            // Reset the form for the next deposit; reload SO so any future
            // M5 iter 4 surface (cleared deposits, balance summary) refreshes.
            _depositAmount = 0;
            _depositMemo = string.Empty;
            await LoadAsync();
        }
        finally { _depositSubmitting = false; }
    }

    /// <summary>
    /// M5 iter 5: cancellation. Calls the orchestrator endpoint that
    /// releases reservations and surfaces a deposit warning if open
    /// deposits remain pointed at this SO.
    /// </summary>
    private async Task CancelAsync()
    {
        if (_so is null || _isMutating) return;
        _isMutating = true;
        try
        {
            var outcome = await SalesOrderClient.CancelAsync(_so.Id);
            if (!outcome.Succeeded || outcome.Saved is null)
            {
                _error = outcome.ErrorMessage ?? "Cancel failed.";
                await Message.WarningAsync(_error);
                return;
            }
            _so = outcome.Saved;
            ApplyHeader();

            if (outcome.OpenDepositCount > 0)
            {
                await Message.WarningAsync(
                    $"Sales order cancelled. {outcome.OpenDepositCount} open customer deposit(s) " +
                    $"totaling {outcome.OpenDepositTotalBase:N2} remain — issue a Refund Receipt or " +
                    $"apply them to another SO as needed.");
            }
            else
            {
                await Message.SuccessAsync("Sales order cancelled.");
            }
        }
        finally { _isMutating = false; }
    }

    private async Task ConfirmAsync()
    {
        if (_so is null || _isMutating) return;
        _isMutating = true;
        try
        {
            var outcome = await SalesOrderClient.ConfirmAsync(_so.Id);
            if (!outcome.Succeeded)
            {
                _error = outcome.ErrorMessage ?? "Confirm failed.";
                await Message.WarningAsync(_error);
                return;
            }
            _so = outcome.Saved;
            ApplyHeader();

            // Compose a per-line summary in the toast so the operator sees
            // exactly what got reserved vs queued for backorder.
            var totalReserved = _so?.Lines.Sum(l => l.ReservedQty) ?? 0m;
            var totalBackorder = _so?.Lines.Sum(l => l.BackorderQty) ?? 0m;
            var msg = totalBackorder > 0m
                ? $"Sales Order confirmed — reserved {totalReserved:0.##}, on backorder {totalBackorder:0.##}."
                : $"Sales Order confirmed — reserved {totalReserved:0.##} units.";
            await Message.SuccessAsync(msg);
        }
        finally { _isMutating = false; }
    }

    private async Task SetStatusAsync(string newStatus, string successMessage)
    {
        if (_so is null || _isMutating) return;
        _isMutating = true;
        try
        {
            var outcome = await SalesOrderClient.SetStatusAsync(_so.Id, newStatus);
            if (!outcome.Succeeded)
            {
                _error = outcome.ErrorMessage ?? "Status change failed.";
                await Message.WarningAsync(_error);
                return;
            }
            _so = outcome.Saved;
            ApplyHeader();
            await Message.SuccessAsync(successMessage);
        }
        finally { _isMutating = false; }
    }

    private async Task MarkInvoicedAsync()
    {
        if (_so is null || _isMutating) return;
        if (string.IsNullOrWhiteSpace(_invoiceNumberInput))
        {
            _error = "Enter the invoice number first.";
            await Message.WarningAsync(_error);
            return;
        }
        _isMutating = true;
        try
        {
            var outcome = await SalesOrderClient.MarkInvoicedAsync(_so.Id, _invoiceNumberInput.Trim());
            if (!outcome.Succeeded)
            {
                _error = outcome.ErrorMessage ?? "Could not mark invoiced.";
                await Message.WarningAsync(_error);
                return;
            }
            _so = outcome.Saved;
            ApplyHeader();
            _invoiceNumberInput = string.Empty;
            await Message.SuccessAsync($"Sales Order marked as invoiced.");
        }
        finally { _isMutating = false; }
    }

    private static bool IsEditable(string status) => status is "open";

    private static string HumanizeStatus(string status) => status switch
    {
        "open" => "Open",
        "confirmed" => "Confirmed",
        "invoiced" => "Invoiced",
        "cancelled" => "Cancelled",
        _ => status
    };

    private static string StatusHint(string status) => status switch
    {
        "open" => "Awaiting confirmation or direct billing.",
        "confirmed" => "Stock reserved; awaiting fulfillment / billing.",
        "invoiced" => "Customer has been billed.",
        "cancelled" => "Cancelled.",
        _ => string.Empty
    };

    private static StatTone StatusTone(string status) => status switch
    {
        "open" => StatTone.Info,
        "confirmed" => StatTone.Success,
        "invoiced" => StatTone.Success,
        "cancelled" => StatTone.Neutral,
        _ => StatTone.Neutral
    };

    private static bool HasAddress(SalesOrderRecordDto so) =>
        !string.IsNullOrWhiteSpace(so.BillingAddressLine) || !string.IsNullOrWhiteSpace(so.BillingCity);

    private static string FormatAddress(string? line, string? city, string? prov, string? postal, string? country)
    {
        var parts = new List<string>(5);
        if (!string.IsNullOrWhiteSpace(line)) parts.Add(line);
        if (!string.IsNullOrWhiteSpace(city)) parts.Add(city);
        if (!string.IsNullOrWhiteSpace(prov)) parts.Add(prov);
        if (!string.IsNullOrWhiteSpace(postal)) parts.Add(postal);
        if (!string.IsNullOrWhiteSpace(country)) parts.Add(country);
        return parts.Count == 0 ? "—" : string.Join(", ", parts);
    }

}
