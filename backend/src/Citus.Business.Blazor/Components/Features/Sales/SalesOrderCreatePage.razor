@page "/sales-orders/new"
@page "/sales-orders/{SalesOrderId:guid}/edit"

@using Radzen
@using Radzen.Blazor
@using Citus.Modules.UnitySearch.Blazor

@inject BusinessShellState ShellState
@inject CustomerClient CustomerClient
@inject ItemClient ItemClient
@inject TaxCodeClient TaxCodeClient
@inject TaxCodeSetClient TaxCodeSetClient
@inject SalesOrderClient SalesOrderClient
@inject CitusToastService Message
@inject NavigationManager Navigation

@*
    Sales Order create / edit. Mirrors QuoteCreatePage minus the
    expiration-date field (SOs don't expire) plus an immutable
    "Source quote" link when the SO came from a Quote conversion.
    Save persists the SO; SOs don't have a Draft state.
*@

<PageTitle>@(_salesOrderId is null ? "New sales order" : $"Edit {_soNumber}") | Tralanz Books</PageTitle>

<div class="tz-doc-editor-page">
    <TzDocToolbar Title="@_header.Title" Subtitle="@_header.Subtitle" BackHref="sales-orders" BackLabel="Back to sales orders" />

    @if (ShellState.AreWritesBlocked || !string.IsNullOrWhiteSpace(_validation))
    {
        <div class="px-4 pt-3 flex flex-col gap-2">
            @if (ShellState.AreWritesBlocked)
            {
                <CitusAlert Severity="CitusAlertSeverity.Warning" ShowIcon="true" Message="@ShellState.WriteBlockMessage" />
            }
            @if (!string.IsNullOrWhiteSpace(_validation))
            {
                <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_validation" ShowIcon="true" />
            }
        </div>
    }

    @if (_isLoading)
    {
        <CitusSkeleton Variant="SkeletonVariant.Form" />
    }
    else
    {
        <div class="tz-doc-surface">
            <div class="tz-doc-region">
                <div class="tz-doc-header-grid">
                    <div class="tz-doc-zone">
                        <div class="tz-doc-field">
                            <label class="tz-doc-field__label">Customer</label>
                            <CustomerPicker CompanyId="@ShellState.ActiveCompany.Id"
                                            SelectedId="@_customerId"
                                            SelectedDisplayText="@_customerDisplay"
                                            Placeholder="Search customers…"
                                            OnCustomerSelected="OnCustomerSelected"
                                            OnCleared="OnCustomerCleared" />
                        </div>
                        <TzDocAddressSection Billing="_billing" Shipping="_shipping" ShippingMode="_shippingMode" OnEditAddress="OpenAddressDrawer" />
                    </div>
                    <div class="tz-doc-zone">
                        <div class="tz-doc-field-row">
                            @if (!string.IsNullOrWhiteSpace(_soNumber))
                            {
                                <div class="tz-doc-field">
                                    <label class="tz-doc-field__label">Sales order no.</label>
                                    <div class="citus-form-field__input citus-form-field__input--readonly flex items-center"><span class="citus-inline-code">@_soNumber</span></div>
                                </div>
                            }
                            <div class="tz-doc-field">
                                <label class="tz-doc-field__label">Source quote</label>
                                <div class="citus-form-field__input citus-form-field__input--readonly flex items-center"><span class="text-fg-muted text-sm">@(string.IsNullOrEmpty(_sourceQuoteNumber) ? "Direct (no source quote)" : $"From quote {_sourceQuoteNumber}")</span></div>
                            </div>
                            <div class="tz-doc-field">
                                <label class="tz-doc-field__label">Document date</label>
                                <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_documentDate" Class="citus-control-full" />
                            </div>
                            <div class="tz-doc-field">
                                <label class="tz-doc-field__label">Customer PO #</label>
                                <CitusInput TValue="string" @bind-Value="_customerPoNumber" Placeholder="Optional" MaxLength="64" />
                            </div>
                            <div class="tz-doc-field">
                                <label class="tz-doc-field__label">Transaction currency</label>
                                <CitusInput TValue="string" @bind-Value="_currency" Disabled="@(!ShellState.ActiveCompany.MultiCurrencyEnabled)" />
                            </div>
                            <div class="tz-doc-field">
                                <label class="tz-doc-field__label">Exchange rate</label>
                                <FxRateInline DocumentDate="@(DateOnly.FromDateTime((_documentDate ?? DateTime.Today).Date))"
                                              BaseCurrencyCode="@ShellState.ActiveCompany.BaseCurrencyCode"
                                              QuoteCurrencyCode="@_currency"
                                              @bind-Rate="_fxRate" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tz-doc-region">
                <div class="tz-doc-line-grid">
                    <div class="flex items-center justify-end mb-2">
                        <select class="citus-form-field__input citus-inline-control--auto" value="@_taxMode" @onchange="OnTaxModeChanged">
                            <option value="exclusive">Tax exclusive</option>
                            <option value="inclusive">Tax inclusive</option>
                        </select>
                    </div>
                    <div class="tz-doc-line-grid__scroll">
                <table class="citus-data-table citus-data-table--compact">
                    <thead>
                        <tr>
                            <th style="width: 2rem"></th>
                            <th style="width: 2.5rem">#</th>
                            <th style="width: 14rem">Product / Service</th>
                            <th>Description</th>
                            <th style="width: 6rem" class="text-right">Qty</th>
                            <th style="width: 8rem" class="text-right">Rate</th>
                            <th style="width: 8rem" class="text-right">Amount</th>
                            <th style="width: 9rem">Tax</th>
                            <th style="width: 3rem"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < _lines.Count; i++)
                        {
                            var index = i;
                            var line = _lines[index];
                            <tr @key="line"
                                ondragover="event.preventDefault()"
                                @ondrop="@(() => OnDropRow(index))"
                                class="@(_dragIndex == index ? "citus-line-row--dragging" : null)">
                                <td class="citus-line-grip" draggable="true" title="Drag to reorder"
                                    @ondragstart="@(() => _dragIndex = index)"
                                    @ondragend="@(() => _dragIndex = null)">
                                    <i class="ti ti-grip-vertical" aria-hidden="true"></i>
                                </td>
                                <td>@(index + 1)</td>
                                <td>
                                    <RadzenDropDown TValue="Guid?"
                                                    Data="@_items"
                                                    Value="@line.ItemId"
                                                    Change="@(v => OnLineItemChanged(index, v as Guid?))"
                                                    TextProperty="Name"
                                                    ValueProperty="Id"
                                                    AllowFiltering="true"
                                                    AllowClear="true"
                                                    Class="citus-control-full citus-line-product">
                                        <Template Context="item">
                                            @{ var it = (ItemSummary)item; }
                                            <div class="citus-item-option">
                                                <span>@it.Name</span>
                                                @if (!string.IsNullOrWhiteSpace(it.ItemCode))
                                                {
                                                    <span class="citus-item-option__code">@it.ItemCode</span>
                                                }
                                            </div>
                                        </Template>
                                    </RadzenDropDown>
                                </td>
                                <td>
                                    <CitusInput TValue="string"
                                                Value="@line.Description"
                                                ValueChanged="@(v => UpdateLine(index, l => l with { Description = v ?? string.Empty }))" />
                                </td>
                                <td>
                                    <RadzenNumeric TValue="decimal" Value="@line.Quantity"
                                                   Change="@(v => UpdateLine(index, l => l with { Quantity = v }))"
                                                   Format="0.##" Class="citus-control-full" />
                                </td>
                                <td>
                                    <RadzenNumeric TValue="decimal" Value="@line.UnitPrice"
                                                   Change="@(v => UpdateLine(index, l => l with { UnitPrice = v }))"
                                                   Format="0.0000" Class="citus-control-full" />
                                </td>
                                <td class="text-right">@FormatAmount(line.Quantity * line.UnitPrice)</td>
                                <td>
                                    <RadzenDropDown TValue="Guid?"
                                                    Data="@_taxCodeSets"
                                                    Value="@line.TaxCodeSetId"
                                                    Change="@(v => UpdateLine(index, l => l with { TaxCodeSetId = v as Guid? }))"
                                                    TextProperty="Code"
                                                    ValueProperty="Id"
                                                    AllowClear="true"
                                                    Class="citus-control-full" />
                                </td>
                                <td>
                                    <CitusButton Variant="CitusButtonVariant.Ghost" Size="CitusButtonSize.Small"
                                                 OnClick="@(() => RemoveLine(index))"><i class="ti ti-trash" aria-hidden="true"></i></CitusButton>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                    </div>
                    <div class="tz-doc-line-grid__tools">
                        <button type="button" class="tz-doc-line-grid__tool" @onclick="AddLine"><CitusIcon Name="IconName.Plus" Size="IconSize.Inline" /> Add line</button>
                        <button type="button" class="tz-doc-line-grid__tool" @onclick="ClearLines"><CitusIcon Name="IconName.Trash" Size="IconSize.Inline" /> Clear all lines</button>
                    </div>
                </div>
            </div>

            <div class="tz-doc-region">
                <div class="tz-doc-lower-grid">
                    <div class="tz-doc-lower-grid__left">
                        <div class="tz-doc-field">
                            <label class="tz-doc-field__label">Message displayed on sales order</label>
                            <CitusInput TValue="string" @bind-Value="_memoToCustomer" />
                        </div>
                        <div class="tz-doc-field">
                            <label class="tz-doc-field__label">Internal note</label>
                            <CitusInput TValue="string" @bind-Value="_internalNote" />
                        </div>
                    </div>
                    @* Totals — interactive Discount (%/$) + Shipping inputs kept verbatim;
                       only the visual wrapper moves to the shared tz-doc-totals-* canvas. *@
                    <div class="tz-doc-totals-panel">
                        <div class="tz-doc-totals-row"><span>Subtotal</span><span>@FormatAmount(Subtotal)</span></div>
                        <div class="tz-doc-totals-row">
                            <span>Discount</span>
                            <span class="flex items-center gap-2">
                                <span class="citus-discount-toggle" role="group" aria-label="Discount type">
                                    <button type="button" class="@(_discountKind != "amount" ? "is-active" : null)" @onclick="@(() => SetDiscountKind("percent"))">%</button>
                                    <button type="button" class="@(_discountKind == "amount" ? "is-active" : null)" @onclick="@(() => SetDiscountKind("amount"))">$</button>
                                </span>
                                <RadzenNumeric TValue="decimal?" Value="@_discountValue" Change="@OnDiscountValueChanged" Format="0.##" Class="citus-quote-totals__input" />
                                <span>−@FormatAmount(DiscountAmount)</span>
                            </span>
                        </div>
                        @foreach (var taxRow in TaxBreakdown)
                        {
                            <div class="tz-doc-totals-row"><span>@taxRow.Label</span><span>@FormatAmount(taxRow.Amount)</span></div>
                        }
                        <div class="tz-doc-totals-row">
                            <span>Shipping</span>
                            <span class="flex items-center gap-2">
                                <RadzenNumeric TValue="decimal?" @bind-Value="_shippingAmount" Format="0.00" Class="citus-quote-totals__input" />
                                <span>@FormatAmount(_shippingAmount ?? 0m)</span>
                            </span>
                        </div>
                        <div class="tz-doc-totals-row tz-doc-totals-row--grand"><span>Total</span><strong>@FormatAmount(Total) @_currency</strong></div>
                    </div>
                </div>
            </div>
        </div>

        @* Address editor drawer — working-copy + dirty state stay on the page. *@
        <CitusDrawer @bind-IsOpen="_addressDrawerOpen"
                     Title="Edit address"
                     Width="CitusDrawerWidth.Medium"
                     IsDirty="@AddressDraftIsDirty"
                     OnSave="SaveAddressDrawer">
            <AddressEditor @bind-Billing="_draftBilling"
                           @bind-Shipping="_draftShipping"
                           @bind-Mode="_draftMode"
                           CustomerId="_customerId" />
        </CitusDrawer>

        @* Sticky Save (primary) + Cancel (left). SOs have no Draft state. *@
        <TzDocActionBar PrimaryLabel="Save"
                        IsSaving="_isSaving"
                        ErrorHint="@(string.IsNullOrWhiteSpace(_validation) ? null : "Fix errors above")"
                        OnSave="SaveAsync">
            <LeftActions>
                <CitusButton Variant="CitusButtonVariant.Ghost" Size="CitusButtonSize.Small" Disabled="@_isSaving" OnClick="Cancel">Cancel</CitusButton>
            </LeftActions>
        </TzDocActionBar>
    }
</div>

@code {
    [Parameter] public Guid? SalesOrderId { get; set; }

    private Guid? _salesOrderId;
    private string? _soNumber;
    private string? _sourceQuoteNumber;
    private Guid? _sourceQuoteId;

    private IReadOnlyList<CustomerSummary> _customers = Array.Empty<CustomerSummary>();
    private IReadOnlyList<ItemSummary> _items = Array.Empty<ItemSummary>();
    private IReadOnlyList<TaxCodeSummary> _taxCodes = Array.Empty<TaxCodeSummary>();
    private IReadOnlyList<TaxCodeSetSummary> _taxCodeSets = Array.Empty<TaxCodeSetSummary>();

    private Guid? _customerId;
    private string _customerDisplay = string.Empty;
    private AddressDraft _billing = AddressDraft.Empty;
    private AddressDraft _shipping = AddressDraft.Empty;
    private ShippingMode _shippingMode = ShippingMode.SameAsBilling;

    // Drawer working copies — committed to _billing/_shipping/_shippingMode on Save.
    private bool _addressDrawerOpen;
    private AddressDraft _draftBilling = AddressDraft.Empty;
    private AddressDraft _draftShipping = AddressDraft.Empty;
    private ShippingMode _draftMode = ShippingMode.SameAsBilling;

    private bool AddressDraftIsDirty =>
        _draftBilling != _billing ||
        _draftShipping != _shipping ||
        _draftMode != _shippingMode;
    private DateTime? _documentDate = DateTime.Today;
    private string _currency = string.Empty;
    private decimal? _fxRate;
    private string _taxMode = "exclusive";
    private string? _discountKind;
    private decimal? _discountValue;
    private decimal? _shippingAmount;
    private string _memoToCustomer = string.Empty;
    private string _internalNote = string.Empty;
    private string _customerPoNumber = string.Empty;

    private List<LineDraft> _lines = new() { new LineDraft() };

    private bool _isLoading = true;
    private bool _isSaving;
    private string? _validation;
    // Optimistic-concurrency token; same pattern as BillCreatePage.
    private DateTimeOffset? _expectedUpdatedAt;
    private PageHeaderModel _header = new() { Eyebrow = "Sales & Get Paid", Title = "New sales order", Subtitle = "Open commitment to deliver." };

    private decimal Subtotal => _lines.Sum(l => Math.Round(l.Quantity * l.UnitPrice, 4));
    private decimal DiscountAmount =>
        _discountKind == "percent" && _discountValue is { } pct ? Math.Round(Subtotal * pct / 100m, 4)
        : _discountKind == "amount" && _discountValue is { } amt ? Math.Round(amt, 4)
        : 0m;

    // Estimate-only per-rule tax breakdown across all lines (e.g. GST 3.00 /
    // PST-BC 4.20), aggregated from each line's selected Tax Code member rules.
    // Sales orders don't post tax; inclusive mode extracts the embedded portion.
    private decimal TaxAmount => TaxBreakdown.Sum(t => t.Amount);

    private IReadOnlyList<(string Label, decimal Amount)> TaxBreakdown
    {
        get
        {
            var inclusive = string.Equals(_taxMode, "inclusive", StringComparison.OrdinalIgnoreCase);
            var byRule = new Dictionary<Guid, (string Label, int Seq, decimal Amount)>();
            foreach (var line in _lines)
            {
                if (line.TaxCodeSetId is not { } setId) continue;
                var set = _taxCodeSets.FirstOrDefault(s => s.Id == setId);
                if (set is null || set.Members.Count == 0) continue;
                var amount = Math.Round(line.Quantity * line.UnitPrice, 4);
                if (amount == 0m) continue;

                var taxBase = amount;
                if (inclusive)
                {
                    var combined = set.Members.Sum(m => m.RatePercent) / 100m;
                    taxBase = combined <= -1m ? 0m : amount / (1m + combined);
                }

                decimal running = 0m;
                foreach (var member in set.Members.OrderBy(m => m.Sequence))
                {
                    var taxable = (!inclusive && member.IsCompound) ? taxBase + running : taxBase;
                    var memberTax = Math.Round(taxable * member.RatePercent / 100m, 4);
                    running += memberTax;
                    byRule[member.RuleId] = byRule.TryGetValue(member.RuleId, out var ex)
                        ? (ex.Label, ex.Seq, ex.Amount + memberTax)
                        : (member.RuleCode, member.Sequence, memberTax);
                }
            }
            return byRule.Values.OrderBy(v => v.Seq).Select(v => (v.Label, v.Amount)).ToList();
        }
    }

    private decimal Total => Math.Round(
        Subtotal - DiscountAmount
        + (string.Equals(_taxMode, "inclusive", StringComparison.OrdinalIgnoreCase) ? 0m : TaxAmount)
        + (_shippingAmount ?? 0m), 4);

    protected override async Task OnInitializedAsync()
    {
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;
        await LoadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (SalesOrderId.HasValue && _salesOrderId != SalesOrderId)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            var customersTask = CustomerClient.ListAsync();
            var itemsTask = ItemClient.ListAsync();
            var taxTask = TaxCodeClient.ListAsync(appliesTo: "sales");
            var taxSetTask = TaxCodeSetClient.ListAsync(appliesTo: "sales");
            await Task.WhenAll(customersTask, itemsTask, taxTask, taxSetTask);
            _customers = customersTask.Result;
            _items = itemsTask.Result;
            _taxCodes = taxTask.Result;
            _taxCodeSets = taxSetTask.Result;

            _salesOrderId = SalesOrderId;
            if (SalesOrderId is { } id)
            {
                var so = await SalesOrderClient.GetByIdAsync(id);
                if (so is null) { _validation = "Sales order not found."; return; }
                ApplyExisting(so);
            }
        }
        finally { _isLoading = false; }
    }

    private void ApplyExisting(SalesOrderRecordDto so)
    {
        _expectedUpdatedAt = so.UpdatedAt;
        _soNumber = so.SalesOrderNumber;
        _sourceQuoteNumber = so.SourceQuoteNumber;
        _sourceQuoteId = so.SourceQuoteId;
        _header = new PageHeaderModel
        {
            Eyebrow = "Sales & Get Paid",
            Title = $"Edit {so.SalesOrderNumber}",
            Subtitle = $"Status: {so.Status}"
        };
        _customerId = so.CustomerId;
        _customerDisplay = _customers.FirstOrDefault(c => c.Id == so.CustomerId)?.DisplayName ?? string.Empty;
        _billing = new AddressDraft
        {
            AddressLine = so.BillingAddressLine,
            City = so.BillingCity,
            ProvinceState = so.BillingProvinceState,
            PostalCode = so.BillingPostalCode,
            Country = so.BillingCountry,
        };
        _shipping = new AddressDraft
        {
            AddressLine = so.ShippingAddressLine,
            City = so.ShippingCity,
            ProvinceState = so.ShippingProvinceState,
            PostalCode = so.ShippingPostalCode,
            Country = so.ShippingCountry,
        };
        _shippingMode = (_shipping.IsEmpty || _shipping == _billing)
            ? ShippingMode.SameAsBilling
            : ShippingMode.Different;
        _documentDate = so.DocumentDate.ToDateTime(TimeOnly.MinValue);
        _currency = so.TransactionCurrencyCode;
        _fxRate = so.FxRate;
        _taxMode = so.TaxMode;
        _discountKind = so.DiscountKind;
        _discountValue = so.DiscountValue;
        _shippingAmount = so.ShippingAmount;
        _memoToCustomer = so.MemoToCustomer ?? string.Empty;
        _internalNote = so.InternalNote ?? string.Empty;
        _customerPoNumber = so.CustomerPoNumber ?? string.Empty;
        _lines = so.Lines.Select(l => new LineDraft
        {
            ItemId = l.ItemId,
            Description = l.Description,
            Quantity = l.Quantity,
            UnitPrice = l.UnitPrice,
            TaxCodeId = l.TaxCodeId,
            TaxCodeSetId = l.TaxCodeSetId,
            AccountCode = l.AccountCode
        }).ToList();
        if (_lines.Count == 0) _lines.Add(new LineDraft());
    }

    private void OnCustomerSelected(UnitySearchPickerOption option)
    {
        _customerId = option.SourceId;
        _customerDisplay = option.DisplayText;
        OnCustomerChanged();
    }

    private void OnCustomerCleared()
    {
        _customerId = null;
        _customerDisplay = string.Empty;
    }

    private void OnCustomerChanged()
    {
        if (_customerId is null) return;
        var customer = _customers.FirstOrDefault(c => c.Id == _customerId.Value);
        if (customer is null) return;
        if (_billing.IsEmpty)
        {
            _billing = new AddressDraft
            {
                AddressLine = customer.AddressLine,
                City = customer.City,
                ProvinceState = customer.ProvinceState,
                PostalCode = customer.PostalCode,
                Country = customer.Country,
            };
        }
        _currency = customer.DefaultCurrencyCode;
    }

    private void OpenAddressDrawer()
    {
        _draftBilling = _billing;
        _draftShipping = _shipping;
        _draftMode = _shippingMode;
        _addressDrawerOpen = true;
    }

    private void SaveAddressDrawer()
    {
        _billing = _draftBilling;
        _shipping = _draftShipping;
        _shippingMode = _draftMode;
        _addressDrawerOpen = false;
    }

    private void OnLineItemChanged(int index, Guid? itemId)
    {
        if (index < 0 || index >= _lines.Count) return;
        var line = _lines[index];
        line.ItemId = itemId;
        if (itemId is null) return;
        var item = _items.FirstOrDefault(i => i.Id == itemId.Value);
        if (item is null) return;
        if (string.IsNullOrWhiteSpace(line.Description)) line.Description = item.Name;
        if (line.UnitPrice == 0m) line.UnitPrice = item.DefaultSalesPrice ?? 0m;
        if (line.TaxCodeId is null) line.TaxCodeId = item.DefaultSalesTaxCodeId;
    }

    private void UpdateLine(int index, Func<LineDraft, LineDraft> mutate)
    {
        if (index < 0 || index >= _lines.Count) return;
        var current = _lines[index];
        var updated = mutate(current);
        current.ItemId = updated.ItemId;
        current.Description = updated.Description;
        current.Quantity = updated.Quantity;
        current.UnitPrice = updated.UnitPrice;
        current.TaxCodeId = updated.TaxCodeId;
        current.TaxCodeSetId = updated.TaxCodeSetId;
        current.AccountCode = updated.AccountCode;
    }

    private void AddLine() => _lines.Add(new LineDraft());

    // Frontend-only drag-to-reorder: the grip cell is the drag source, each
    // row is the drop target. Sequence is still assigned from list order at
    // save time, so the payload / backend contract is unchanged.
    private int? _dragIndex;
    private void OnDropRow(int targetIndex)
    {
        if (_dragIndex is not { } src) return;
        _dragIndex = null;
        if (src == targetIndex || src < 0 || src >= _lines.Count || targetIndex < 0 || targetIndex >= _lines.Count) return;
        var moved = _lines[src];
        _lines.RemoveAt(src);
        _lines.Insert(targetIndex, moved);
    }

    private void RemoveLine(int index)
    {
        if (index < 0 || index >= _lines.Count) return;
        _lines.RemoveAt(index);
        if (_lines.Count == 0) _lines.Add(new LineDraft());
    }

    private void ClearLines() { _lines.Clear(); _lines.Add(new LineDraft()); }

    private void OnTaxModeChanged(ChangeEventArgs args) =>
        _taxMode = args.Value?.ToString() ?? "exclusive";

    private void SetDiscountKind(string kind) => _discountKind = kind;

    private void OnDiscountValueChanged(decimal? value)
    {
        _discountValue = value;
        // First value entered defaults the kind to percent (the toggle shows %
        // by default); an empty value keeps kind null = no discount, as before.
        if (value is not null && _discountKind is null) _discountKind = "percent";
    }

    private async Task SaveAsync()
    {
        _validation = null;
        if (_customerId is null) { _validation = "Please pick a customer."; return; }
        if (_lines.All(l => l.Quantity == 0 && l.UnitPrice == 0 && string.IsNullOrWhiteSpace(l.Description)))
        {
            _validation = "Add at least one line with quantity / rate.";
            return;
        }

        _isSaving = true;
        try
        {
            var payload = new SalesOrderUpsertPayload(
                CustomerId: _customerId.Value,
                DocumentDate: DateOnly.FromDateTime((_documentDate ?? DateTime.Today).Date),
                TransactionCurrencyCode: string.IsNullOrWhiteSpace(_currency) ? ShellState.ActiveCompany.BaseCurrencyCode : _currency,
                FxRate: _fxRate,
                BillingAddressLine: _billing.AddressLine,
                BillingCity: _billing.City,
                BillingProvinceState: _billing.ProvinceState,
                BillingPostalCode: _billing.PostalCode,
                BillingCountry: _billing.Country,
                ShippingAddressLine: (_shippingMode == ShippingMode.SameAsBilling ? _billing : _shipping).AddressLine,
                ShippingCity: (_shippingMode == ShippingMode.SameAsBilling ? _billing : _shipping).City,
                ShippingProvinceState: (_shippingMode == ShippingMode.SameAsBilling ? _billing : _shipping).ProvinceState,
                ShippingPostalCode: (_shippingMode == ShippingMode.SameAsBilling ? _billing : _shipping).PostalCode,
                ShippingCountry: (_shippingMode == ShippingMode.SameAsBilling ? _billing : _shipping).Country,
                ShipVia: null,
                ShippingDate: null,
                TrackingNo: null,
                TaxMode: _taxMode,
                DiscountKind: _discountKind,
                DiscountValue: _discountValue,
                ShippingAmount: _shippingAmount,
                ShippingTaxCodeId: null,
                MemoToCustomer: NullIfEmpty(_memoToCustomer),
                InternalNote: NullIfEmpty(_internalNote),
                SourceQuoteId: _sourceQuoteId,
                CustomerPoNumber: NullIfEmpty(_customerPoNumber),
                Lines: _lines
                    .Where(l => l.Quantity > 0 || l.UnitPrice > 0 || !string.IsNullOrWhiteSpace(l.Description) || l.ItemId is not null)
                    .Select((l, i) => new SalesOrderLinePayload(
                        Sequence: i + 1,
                        ServiceDate: null,
                        ItemId: l.ItemId,
                        Description: l.Description ?? string.Empty,
                        Quantity: l.Quantity,
                        UnitPrice: l.UnitPrice,
                        TaxCodeId: l.TaxCodeId,
                        TaxCodeSetId: l.TaxCodeSetId,
                        AccountCode: l.AccountCode))
                    .ToArray(),
                ExpectedUpdatedAt: _salesOrderId is null ? null : _expectedUpdatedAt);

            SalesOrderMutationOutcome outcome = _salesOrderId is null
                ? await SalesOrderClient.CreateAsync(payload)
                : await SalesOrderClient.UpdateAsync(_salesOrderId.Value, payload);

            if (!outcome.Succeeded || outcome.Saved is null)
            {
                if (outcome.IsConcurrencyConflict)
                {
                    _validation = outcome.ErrorMessage
                        ?? "This sales order was modified by another session. Reload the page to see the latest version, then re-apply your changes.";
                    await Message.WarningAsync(_validation);
                    return;
                }
                _validation = outcome.ErrorMessage ?? "Could not save the sales order.";
                return;
            }
            // Refresh the token from the saved row so consecutive saves
            // in the same editor don't self-conflict.
            _expectedUpdatedAt = outcome.Saved.UpdatedAt;
            await Message.SuccessAsync($"Sales Order {outcome.Saved.SalesOrderNumber} saved.");
            Navigation.NavigateTo($"sales-orders/{outcome.Saved.Id:D}");
        }
        finally { _isSaving = false; }
    }

    private void Cancel() => Navigation.NavigateTo(_salesOrderId is null ? "sales-orders" : $"sales-orders/{_salesOrderId:D}");

    private static string FormatAmount(decimal value) =>
        value.ToString("N2", System.Globalization.CultureInfo.InvariantCulture);

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed record LineDraft
    {
        public Guid? ItemId { get; set; }
        public string Description { get; set; } = string.Empty;
        public decimal Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public Guid? TaxCodeId { get; set; }
        public Guid? TaxCodeSetId { get; set; }
        public string? AccountCode { get; set; }
    }
}
