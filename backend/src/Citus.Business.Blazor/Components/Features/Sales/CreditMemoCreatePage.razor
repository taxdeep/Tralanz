@page "/credit-memos/new"

@using Citus.Modules.UnitySearch.Blazor
@using Citus.Modules.UnitySearch.Domain.Shared

@inject BusinessShellState ShellState
@inject BusinessWriteFlowClient WriteFlow
@inject CustomerClient CustomerClient
@inject InvoiceClient InvoiceClient
@inject CreditMemoClient CreditMemoClient
@inject AccountClient AccountClient
@inject TaskClient TaskClient
@inject NavigationManager NavigationManager
@inject CitusToastService Message

@*
    CreditMemoCreatePage — sales-side reversal of an invoice. Same line
    shape as Invoice; the only structural addition is the "Apply to
    invoice" header field, which is optional. With a linked invoice,
    posting trims that invoice's AR open item directly. Without one,
    the credit lands as a standalone credit balance on the customer
    that can be applied via Receive Payment later.

    GL on post (handled by backend Posting Engine):
      Dr Revenue (per line)         | matches the invoice's credit row
      Dr Tax Payable (per line)     | reversal of the original output tax
      Cr Accounts Receivable        | reduces what the customer owes

    UX is deliberately a near-mirror of InvoiceCreatePage so the
    operator's mental model carries over. The two pages are twins —
    edit them together when the line shape changes.
*@

<PageTitle>New Credit Memo | Tralanz Books</PageTitle>

<div class="tz-doc-editor-page">
    <TzDocToolbar Title="@_header.Title" Subtitle="@_header.Subtitle" BackHref="invoices" BackLabel="Back to invoices" />

    <div class="px-4 pt-3 flex flex-col gap-2">
        @if (ShellState.AreWritesBlocked)
        {
            <CitusAlert Severity="CitusAlertSeverity.Warning" ShowIcon="true" Message="@ShellState.WriteBlockMessage" />
        }
        @if (_isFromCopy)
        {
            <CitusAlert Severity="CitusAlertSeverity.Info" ShowIcon="true" Message="This is a copy. Revise as needed and save to create a new credit memo; the original is unchanged." />
        }
        @if (!string.IsNullOrWhiteSpace(_validation))
        {
            <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_validation" ShowIcon="true" />
        }
        @* Task-rollback warning — posting rolls task_id lines Billed -> Completed. *@
        @if (ShellState.IsModuleEnabled("task") && _impactedTaskIds.Count > 0)
        {
            <CitusAlert Severity="CitusAlertSeverity.Warning" ShowIcon="true">
                <MessageTemplate>
                    <strong>Posting this credit memo will roll back @_impactedTaskIds.Count task@(_impactedTaskIds.Count == 1 ? "" : "s") to Completed:</strong>
                    <span class="ms-1">@TaskLabelList()</span>
                </MessageTemplate>
            </CitusAlert>
        }
        <WriteFlowResultAlert Result="@_lastResult" />
    </div>

    <div class="tz-doc-surface">
        <div class="tz-doc-region">
            <div class="tz-doc-field-row">
                <div class="tz-doc-field">
                    <label class="tz-doc-field__label">Memo date</label>
                    <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_documentDate" Class="citus-control-full" />
                </div>
                <div class="tz-doc-field">
                    <label class="tz-doc-field__label">Customer</label>
                    <CustomerPicker CompanyId="@ShellState.ActiveCompany.Id"
                                       UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                       Placeholder="Search customers…"
                                       Take="8"
                                       SourceRoute="/credit-memos/new"
                                       SelectedId="@(_customerId == Guid.Empty ? null : _customerId)"
                                       SelectedDisplayText="@_customerDisplay"
                                       OnCustomerSelected="OnCustomerSelected"
                                       OnCleared="OnCustomerCleared" />
                </div>
                <div class="tz-doc-field">
                    <label class="tz-doc-field__label">Exchange rate</label>
                    @if (_customerId == Guid.Empty)
                    {
                        <div class="citus-form-field__input citus-form-field__input--readonly flex items-center"><span class="text-fg-subtle">Pick a customer first</span></div>
                    }
                    else
                    {
                        <FxRateInline DocumentDate="@(DateOnly.FromDateTime((_documentDate ?? DateTime.Today).Date))" BaseCurrencyCode="@ShellState.ActiveCompany.BaseCurrencyCode" QuoteCurrencyCode="@_currency" @bind-Rate="_fxRate" />
                    }
                </div>
                <div class="tz-doc-field">
                    <label class="tz-doc-field__label">Apply to invoice (optional)</label>
                    <CitusInput TValue="string" @bind-Value="_appliedToInvoiceNumber" Placeholder="e.g. INV-2026-0042" />
                    @if (!string.IsNullOrWhiteSpace(_appliedToInvoiceNumber) && !LooksLikeDocumentNumber(_appliedToInvoiceNumber))
                    {
                        <p class="text-fg-warning text-xs mt-1">Use the invoice's display number. Backend will reject anything it can't resolve in this company.</p>
                    }
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mt-3">
                <div class="tz-doc-field">
                    <label class="tz-doc-field__label">Reason</label>
                    <CitusInput TValue="string" @bind-Value="_reason" Placeholder="Return / pricing correction / RMA #..." />
                </div>
                <div class="tz-doc-field">
                    <label class="tz-doc-field__label">Memo</label>
                    <CitusInput TValue="string" @bind-Value="_memo" Placeholder="Visible to customer; optional." />
                </div>
                <div class="tz-doc-field">
                    <label class="tz-doc-field__label">Customer PO #</label>
                    <CitusInput TValue="string" @bind-Value="_customerPoNumber" Placeholder="Customer's PO reference" MaxLength="64" />
                </div>
            </div>
        </div>

        <div class="tz-doc-region">
            <div class="tz-doc-line-grid">
                <div class="tz-doc-line-grid__scroll">
            <table class="citus-data-table citus-data-table--compact">
                <thead>
                    <tr>
                        <th style="width: 2.25rem"></th>
                        <th style="width: 16rem">Item / Service</th>
                        <th>Description</th>
                        <th class="text-right" style="width: 6rem">Qty</th>
                        <th class="text-right" style="width: 9rem">Unit price</th>
                        <th style="width: 7rem">Account</th>
                        <th style="width: 6rem">Tax</th>
                        <th class="text-right" style="width: 9rem">Line total</th>
                        <th style="width: 3rem"></th>
                    </tr>
                </thead>
                <tbody>
                    @for (var index = 0; index < _lines.Count; index++)
                    {
                        var i = index;
                        var line = _lines[i];
                        <tr>
                            <td>
                                <button type="button" class="citus-icon-button" title="Insert line below" @onclick="() => InsertLineAfter(i)">
                                    <CitusIcon Name="IconName.Plus" Size="IconSize.Inline" />
                                </button>
                            </td>
                            <td>
                                <ItemServicePicker CompanyId="@ShellState.ActiveCompany.Id"
                                                   UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                                   Placeholder="Search items…"
                                                   Take="6"
                                                   SourceRoute="/credit-memos/new"
                                                   SelectedId="@(line.ItemId == Guid.Empty ? null : line.ItemId)"
                                                   SelectedDisplayText="@line.ItemDisplay"
                                                   OnItemSelected="@(option => OnItemPicked(i, option))"
                                                   OnCleared="@(() => OnItemCleared(i))" />
                            </td>
                            <td><CitusInput TValue="string" Value="@line.Description" ValueChanged="@(v => Update(i, l => l with { Description = v ?? string.Empty }))" Size="CitusButtonSize.Small" Placeholder="Free-form description" /></td>
                            <td><RadzenNumeric TValue="decimal" Value="@line.Quantity" ValueChanged="@(v => Update(i, l => l with { Quantity = v }))" Min="0" Class="citus-control-full" /></td>
                            <td><RadzenNumeric TValue="decimal" Value="@line.UnitPrice" ValueChanged="@(v => Update(i, l => l with { UnitPrice = v }))" Min="0" Class="citus-control-full" /></td>
                            <td>
                                <AccountPicker CompanyId="@ShellState.ActiveCompany.Id"
                                               UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                               Context="credit_memo.line.revenue"
                                               AllowedRootTypes="revenue"
                                               SelectedId="@line.AccountId"
                                               SelectedDisplayText="@line.AccountDisplay"
                                               Placeholder="Revenue account..."
                                               DefaultCurrencyCode="@ShellState.ActiveCompany.BaseCurrencyCode"
                                               OnAccountSelected="@(account => OnAccountSelected(i, account))"
                                               OnCleared="@(() => OnAccountCleared(i))" />
                            </td>
                            <td>
                                <TaxCodePicker SelectedId="@line.TaxCodeId"
                                               SelectedDisplayText="@line.TaxCode"
                                               AppliesTo="sales"
                                               Placeholder="Tax"
                                               OnTaxCodeSelected="@(tax => OnTaxCodeSelected(i, tax))"
                                               OnCleared="@(() => OnTaxCodeCleared(i))" />
                            </td>
                            <td class="text-right">@FormatAmount(line.Quantity * line.UnitPrice)</td>
                            <td>
                                <button type="button" class="citus-icon-button" title="Remove line" @onclick="() => RemoveLine(i)">
                                    <CitusIcon Name="IconName.Trash" Size="IconSize.Inline" />
                                </button>
                            </td>
                        </tr>
                    }
                    <tr class="citus-data-table__total">
                        <td colspan="7" class="text-right font-medium">Total</td>
                        <td class="text-right font-semibold">@FormatAmount(_total)</td>
                        <td></td>
                    </tr>
                </tbody>
            </table>
                </div>
                <div class="tz-doc-line-grid__tools">
                    <button type="button" class="tz-doc-line-grid__tool" @onclick="AddLine"><CitusIcon Name="IconName.Plus" Size="IconSize.Inline" /> Add line</button>
                </div>
            </div>
        </div>

        <div class="tz-doc-region">
            <div class="tz-doc-lower-grid">
                <div class="tz-doc-lower-grid__left">
                    <p class="text-fg-muted text-sm m-0">
                        Posting reverses revenue + tax-payable and credits AR@(string.IsNullOrWhiteSpace(_appliedToInvoiceNumber) ? " — issued as a standalone customer credit." : $" — applied directly against {_appliedToInvoiceNumber}.")
                    </p>
                </div>
                <TzDocTotalsPanel Rows="_cmTotalsRows" />
            </div>
        </div>
    </div>

    <TzDocActionBar PrimaryLabel="Post credit memo"
                    IsSaving="_isSubmitting"
                    Disabled="@(_lines.Count == 0 || _total <= 0 || ShellState.AreWritesBlocked)"
                    ErrorHint="@(string.IsNullOrWhiteSpace(_validation) ? null : "Fix errors above")"
                    OnSave="PostAsync" />
</div>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Sales & Get Paid",
        Title = "New credit memo",
        Subtitle = "Sales-side reversal. Posting credits AR (or applies against a specific invoice)."
    };

    private DateTime? _documentDate = DateTime.Today;
    private Guid _customerId;
    private string _customerDisplay = string.Empty;
    private string _currency = string.Empty;
    private decimal? _fxRate;
    private string _appliedToInvoiceNumber = string.Empty;
    private string _reason = string.Empty;
    private string _memo = string.Empty;
    private string _customerPoNumber = string.Empty;

    private sealed record CreditMemoLineEditState(
        Guid ItemId = default,
        string ItemDisplay = "",
        string Description = "",
        decimal Quantity = 1m,
        decimal UnitPrice = 0m,
        Guid? AccountId = null,
        string AccountDisplay = "",
        string AccountCode = "",
        Guid? TaxCodeId = null,
        string TaxCode = "",
        // Optional Task back-link. Propagated from the source invoice
        // line when this credit memo was opened via "Issue credit memo"
        // — drives the credit-note post handler's Step 2 task rollback.
        Guid? TaskId = null)
    {
        public bool HasContent =>
            ItemId != Guid.Empty
            || !string.IsNullOrWhiteSpace(Description)
            || !string.IsNullOrWhiteSpace(AccountCode)
            || !string.IsNullOrWhiteSpace(TaxCode)
            || UnitPrice > 0m;
    }

    private readonly List<CreditMemoLineEditState> _lines = new() { new CreditMemoLineEditState() };
    private bool _isSubmitting;
    private string? _validation;
    private WriteFlowResult? _lastResult;
    // Phase 3.1
    private bool _isFromCopy;

    [SupplyParameterFromQuery(Name = "copyFrom")] public Guid? CopyFromMemoId { get; set; }
    // Distinct task ids the operator's current lines will roll back on
    // post. Populated by the "From invoice" prefill (or by any future
    // path that attributes per-line task_id); displayed in the
    // task-rollback warning banner above the form so the side-effect
    // isn't hidden behind a Post click.
    private IReadOnlyDictionary<Guid, string> _taskLabels = new Dictionary<Guid, string>();
    private IReadOnlyList<Guid> _impactedTaskIds = Array.Empty<Guid>();

    private decimal _total => _lines.Sum(l => l.Quantity * l.UnitPrice);

    // Rows for the shared TzDocTotalsPanel (read-only — same content the
    // inline Summary card showed).
    private IReadOnlyList<(string Label, string Value, bool Emphasis, bool Todo)> _cmTotalsRows
    {
        get
        {
            var rows = new List<(string, string, bool, bool)>
            {
                ("Lines", _lines.Count.ToString(), false, false),
                ("Subtotal", FormatAmount(_total), true, false),
                ("Currency", _currency.ToUpperInvariant(), false, false),
            };
            if (!string.IsNullOrWhiteSpace(_appliedToInvoiceNumber))
            {
                rows.Add(("Applied to", _appliedToInvoiceNumber, false, false));
            }
            if (!string.Equals(_currency, ShellState.ActiveCompany.BaseCurrencyCode, StringComparison.OrdinalIgnoreCase))
            {
                rows.Add(("FX rate", _fxRate.HasValue ? _fxRate.Value.ToString("0.000000") : "—", false, false));
            }
            return rows;
        }
    }

    /// <summary>
    /// Optional source-invoice id passed via query string. When present
    /// the create page pre-fills customer + currency + lines from the
    /// invoice, copies per-line task_id back-links, and stamps the
    /// invoice's display number into "Applied to invoice #". Posting
    /// then triggers the server-side Step 2 rollback that flips every
    /// linked task back to Completed.
    /// </summary>
    [SupplyParameterFromQuery] public Guid? FromInvoiceId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;

        if (FromInvoiceId is { } invoiceId && invoiceId != Guid.Empty)
        {
            await PrefillFromInvoiceAsync(invoiceId);
        }
        else if (CopyFromMemoId is { } copyId && copyId != Guid.Empty)
        {
            await TryHydrateFromCopySourceAsync(copyId);
        }
    }

    /// <summary>Phase 3.1: hydrate from an existing credit memo (no invoice link).</summary>
    private async Task TryHydrateFromCopySourceAsync(Guid sourceId)
    {
        CreditMemoRecordDto? source;
        try
        {
            source = await CreditMemoClient.GetByIdAsync(sourceId, ShellState.ActiveCompany.Id);
        }
        catch { return; }
        if (source is null)
        {
            _validation = "The credit memo you copied from is not visible in this company.";
            return;
        }

        var customer = await CustomerClient.GetByIdAsync(source.CustomerId);
        var accounts = await AccountClient.ListAsync();
        var byId = accounts.ToDictionary(a => a.Id);

        _isFromCopy = true;
        _customerId = source.CustomerId;
        _customerDisplay = customer?.DisplayName ?? string.Empty;
        _currency = source.TransactionCurrencyCode;
        _documentDate = DateTime.Today;
        _fxRate = null;
        _memo = source.Memo ?? string.Empty;
        _customerPoNumber = string.Empty;
        _appliedToInvoiceNumber = string.Empty; // Don't carry the apply-to link on copy
        _reason = string.Empty;

        _lines.Clear();
        foreach (var line in source.Lines.OrderBy(l => l.LineNumber))
        {
            var displ = line.RevenueAccountId is { } rid && byId.TryGetValue(rid, out var a) ? $"{a.Code}  {a.Name}" : string.Empty;
            var code = line.RevenueAccountId is { } rid2 && byId.TryGetValue(rid2, out var a2) ? a2.Code : string.Empty;
            _lines.Add(new CreditMemoLineEditState(
                ItemId: Guid.Empty, ItemDisplay: string.Empty,
                Description: line.Description ?? string.Empty,
                Quantity: line.Quantity, UnitPrice: line.UnitPrice,
                AccountId: line.RevenueAccountId, AccountDisplay: displ, AccountCode: code,
                TaxCodeId: null, TaxCode: string.Empty,
                TaskId: null));  // Task back-link not copied
        }
        if (_lines.Count == 0) _lines.Add(new CreditMemoLineEditState());
    }

    /// <summary>
    /// Pre-fills the form from a posted invoice. Mirror of the SO / Task
    /// prefill on InvoiceCreatePage: header copies customer + currency
    /// + reason, lines mirror invoice lines (same quantities, same unit
    /// prices — a full credit; operator can adjust quantities to credit
    /// a partial invoice), and per-line task_id back-links carry over
    /// so the post handler can roll the source tasks back to Completed.
    /// </summary>
    private async Task PrefillFromInvoiceAsync(Guid invoiceId)
    {
        var invoice = await InvoiceClient.GetByIdAsync(invoiceId, ShellState.ActiveCompany.Id);
        if (invoice is null)
        {
            await Message.WarningAsync("Source invoice not found in this company; starting a blank credit memo.");
            return;
        }

        // Header pre-fill — fetch customer for display + currency fallback.
        var customer = await CustomerClient.GetByIdAsync(invoice.CustomerId);
        _customerId = invoice.CustomerId;
        _customerDisplay = customer?.DisplayName ?? string.Empty;
        _currency = !string.IsNullOrWhiteSpace(invoice.TransactionCurrencyCode)
            ? invoice.TransactionCurrencyCode
            : (customer?.DefaultCurrencyCode ?? _currency);
        _appliedToInvoiceNumber = invoice.DisplayNumber;
        _reason = $"Credit for {invoice.DisplayNumber}";
        _customerPoNumber = invoice.CustomerPoNumber ?? string.Empty;

        _lines.Clear();
        foreach (var line in invoice.Lines.OrderBy(l => l.LineNumber))
        {
            _lines.Add(new CreditMemoLineEditState(
                ItemId: Guid.Empty,
                ItemDisplay: string.Empty,
                Description: line.Description ?? string.Empty,
                Quantity: line.Quantity,
                UnitPrice: line.UnitPrice,
                // RevenueAccountId comes back as a Guid? from the GET.
                // Operator re-picks if it's missing; we copy it across
                // best-effort but cannot show a label without an account
                // lookup (matches the SO prefill behaviour).
                AccountId: line.RevenueAccountId,
                AccountDisplay: line.RevenueAccountId is { } a ? $"Account {a:D}"[..15] + "…" : string.Empty,
                AccountCode: line.RevenueAccountId is { } ? "preset" : string.Empty,
                TaxCodeId: null,
                TaxCode: string.Empty,
                TaskId: line.TaskId));
        }

        // Keep one trailing blank line so the operator can append a
        // "restocking fee" / "shipping reversal" / etc. without an
        // extra "Add line" click.
        if (_lines.Count == 0 || _lines[^1].HasContent)
        {
            _lines.Add(new CreditMemoLineEditState());
        }

        // Resolve "TSK-000123 - Title" labels for any per-line task_ids
        // the prefill carried over, so the rollback warning banner
        // shows real task numbers rather than raw GUIDs.
        await RefreshImpactedTaskLabelsAsync();
    }

    /// <summary>
    /// Recomputes <see cref="_impactedTaskIds"/> + <see cref="_taskLabels"/>
    /// from the current line set. Cheap on no-op (no task ids → no
    /// HTTP call); single batched lookup when ids are present.
    /// </summary>
    private async Task RefreshImpactedTaskLabelsAsync()
    {
        var distinct = _lines
            .Where(l => l.TaskId.HasValue && l.HasContent)
            .Select(l => l.TaskId!.Value)
            .Distinct()
            .ToArray();

        _impactedTaskIds = distinct;
        if (distinct.Length == 0)
        {
            _taskLabels = new Dictionary<Guid, string>();
            return;
        }

        _taskLabels = await TaskClient.LookupDisplayAsync(distinct);
    }

    /// <summary>Comma-separated list of resolved task labels (or short-GUID fallbacks).</summary>
    private string TaskLabelList() =>
        string.Join(", ", _impactedTaskIds.Select(id =>
            _taskLabels.TryGetValue(id, out var label) ? label : $"task {id:D}"[..13] + "…"));

    private async Task OnCustomerSelected(UnitySearchPickerOption option)
    {
        _customerId = option.SourceId;
        _customerDisplay = option.DisplayText;
        var customer = await CustomerClient.GetByIdAsync(_customerId);
        if (customer is not null && !string.IsNullOrWhiteSpace(customer.DefaultCurrencyCode))
        {
            _currency = customer.DefaultCurrencyCode;
        }
    }

    private void OnCustomerCleared()
    {
        _customerId = Guid.Empty;
        _customerDisplay = string.Empty;
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;
    }

    private void AddLine() => _lines.Add(new CreditMemoLineEditState());

    private void RemoveLine(int i)
    {
        if (i < 0 || i >= _lines.Count) return;
        _lines.RemoveAt(i);
        if (_lines.Count == 0) _lines.Add(new CreditMemoLineEditState());
    }

    private void InsertLineAfter(int i)
    {
        if (i < 0 || i >= _lines.Count) return;
        _lines.Insert(i + 1, new CreditMemoLineEditState());
    }

    private void Update(int i, Func<CreditMemoLineEditState, CreditMemoLineEditState> mutate)
    {
        if (i < 0 || i >= _lines.Count) return;
        _lines[i] = mutate(_lines[i]);
        EnsureTrailingBlankLine();
    }

    private void EnsureTrailingBlankLine()
    {
        if (_lines.Count == 0) { _lines.Add(new CreditMemoLineEditState()); return; }
        if (_lines[^1].HasContent) _lines.Add(new CreditMemoLineEditState());
    }

    private void OnItemPicked(int i, UnitySearchPickerOption option)
    {
        Update(i, l => l with
        {
            ItemId = option.SourceId,
            ItemDisplay = option.DisplayText,
            Description = string.IsNullOrWhiteSpace(l.Description) ? option.PrimaryText : l.Description,
        });
    }

    private void OnItemCleared(int i)
        => Update(i, l => l with { ItemId = Guid.Empty, ItemDisplay = string.Empty });

    private void OnAccountSelected(int i, AccountSummary account)
    {
        Update(i, l => l with
        {
            AccountId = account.Id,
            AccountDisplay = $"{account.Code} {account.Name}",
            AccountCode = account.Code
        });
    }

    private void OnAccountCleared(int i)
        => Update(i, l => l with { AccountId = null, AccountDisplay = string.Empty, AccountCode = string.Empty });

    private void OnTaxCodeSelected(int i, TaxCodeSummary tax)
        => Update(i, l => l with { TaxCodeId = tax.Id, TaxCode = tax.Code });

    private void OnTaxCodeCleared(int i)
        => Update(i, l => l with { TaxCodeId = null, TaxCode = string.Empty });

    private async Task PostAsync()
    {
        _validation = null;
        _lastResult = null;

        if (_customerId == Guid.Empty) { _validation = "Pick a customer first."; return; }
        var meaningful = _lines.Where(l => l.HasContent).ToArray();
        if (meaningful.Length == 0) { _validation = "Add at least one line."; return; }
        if (meaningful.Any(l => string.IsNullOrWhiteSpace(l.Description))) { _validation = "Every line needs a description."; return; }
        if (meaningful.Any(l => string.IsNullOrWhiteSpace(l.AccountCode))) { _validation = "Every line needs a revenue account code."; return; }
        var total = meaningful.Sum(l => l.Quantity * l.UnitPrice);
        if (total <= 0) { _validation = "Credit memo total must be greater than zero."; return; }

        _isSubmitting = true;
        try
        {
            if (meaningful.Any(l => l.AccountId is null || l.AccountId == Guid.Empty))
            {
                _validation = "Every line needs a revenue account picked from the dropdown (not a free-typed code).";
                return;
            }

            var draft = new CreditMemoDraft
            {
                CompanyId = ShellState.ActiveCompany.Id,
                UserId = ShellState.User.Id,
                DocumentDate = DateOnly.FromDateTime((_documentDate ?? DateTime.Today).Date),
                CustomerId = _customerId,
                TransactionCurrencyCode = _currency.Trim().ToUpperInvariant(),
                BaseCurrencyCode = ShellState.ActiveCompany.BaseCurrencyCode.Trim().ToUpperInvariant(),
                FxRate = _fxRate,
                AppliedToInvoiceNumber = _appliedToInvoiceNumber.Trim(),
                Reason = _reason.Trim(),
                Memo = _memo.Trim(),
                CustomerPoNumber = _customerPoNumber.Trim(),
                Lines = meaningful.Select((l, idx) => new CreditMemoLineDraft
                {
                    LineNumber = idx + 1,
                    RevenueAccountId = l.AccountId!.Value,
                    Description = l.Description,
                    Quantity = l.Quantity,
                    UnitPrice = l.UnitPrice,
                    TaxCodeId = l.TaxCodeId,
                    TaxAmount = 0m,
                    TaskId = l.TaskId,
                }).ToArray()
            };
            _lastResult = await WriteFlow.PostCreditMemoAsync(draft);
            if (_lastResult.Succeeded)
            {
                await Message.SuccessAsync("Credit memo posted.");
                NavigationManager.NavigateTo(_lastResult.DocumentId is { } id ? $"credit-memos/{id:D}" : "credit-memos");
            }
            else { await Message.InfoAsync(_lastResult.Message); }
        }
        finally { _isSubmitting = false; }
    }

    private static string FormatAmount(decimal amount) => amount.ToString("N2");

    /// <summary>
    /// Cheap client-side gate so the operator catches obvious typos
    /// before the backend (company_id, display_number) lookup. The
    /// canonical resolution lives on the server — we only filter out
    /// strings that clearly aren't a document number (whitespace,
    /// stray punctuation, multi-line paste, etc.).
    /// </summary>
    private static bool LooksLikeDocumentNumber(string value) =>
        System.Text.RegularExpressions.Regex.IsMatch(value.Trim(), @"^[A-Za-z0-9_\-./]+$");
}
