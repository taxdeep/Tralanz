@page "/credit-memos"

@inject BusinessShellState ShellState
@inject CreditMemoClient CreditMemoClient

<PageTitle>Credit Memos | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <a class="citus-button" href="credit-memos/new">
            <CitusIcon Name="IconName.Plus" Size="IconSize.Inline" />
            <span>New credit memo</span>
        </a>
    </Actions>
</CitusPageHeader>

<section class="citus-panel">
    <header class="citus-panel__header">
        <h2 class="citus-panel__title">Credit memos</h2>
        <label class="inline-flex items-center gap-2 text-sm">
            <input type="checkbox" checked="@_includeDrafts" @onchange="OnIncludeDraftsChanged" />
            <span>Include drafts</span>
        </label>
    </header>

    @if (_isLoading)
    {
        <CitusSkeleton Variant="SkeletonVariant.List" />
    }
    else if (_rows.Count == 0)
    {
        <CitusEmpty Title="No credit memos yet"
                    Description="Customer-side credits will appear here once posted."
                    Icon="IconName.FileText" />
    }
    else
    {
        <table class="citus-data-table">
            <thead>
                <tr>
                    <th>Memo #</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Customer PO</th>
                    <th class="text-right">Total</th>
                    <th>Currency</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _rows)
                {
                    <tr>
                        <td><a class="citus-link" href="@($"credit-memos/{row.Id:D}")">@row.DisplayNumber</a></td>
                        <td>@row.DocumentDate.ToString("yyyy-MM-dd")</td>
                        <td>@HumanizeStatus(row.Status)</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(row.CustomerPoNumber))
                            {
                                <span class="text-fg-subtle">—</span>
                            }
                            else
                            {
                                <span class="citus-inline-code">@row.CustomerPoNumber</span>
                            }
                        </td>
                        <td class="text-right">@row.TotalAmount.ToString("N2")</td>
                        <td>@row.TransactionCurrencyCode</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Sales & Get Paid",
        Title = "Credit memos",
        Subtitle = "Customer-side credits — reduce open AR or queue a refund."
    };

    private IReadOnlyList<CreditMemoSummaryDto> _rows = Array.Empty<CreditMemoSummaryDto>();
    private bool _isLoading = true;
    private bool _includeDrafts = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task OnIncludeDraftsChanged(ChangeEventArgs e)
    {
        _includeDrafts = (bool)(e.Value ?? false);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            _rows = await CreditMemoClient.ListAsync(ShellState.ActiveCompany.Id, _includeDrafts);
        }
        finally { _isLoading = false; }
    }

    private static string HumanizeStatus(string status) => status switch
    {
        "draft" => "Draft", "posted" => "Posted", "voided" => "Voided", "reversed" => "Reversed", _ => status
    };
}
