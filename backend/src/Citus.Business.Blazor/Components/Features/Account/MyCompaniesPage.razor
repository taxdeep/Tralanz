@page "/account/companies"

@inject BusinessShellState ShellState
@inject NavigationManager Navigation
@inject CitusToastService Message
@inject Citus.Business.Blazor.Services.BusinessSessionClient BusinessSessionClient
@inject Citus.Business.Blazor.Services.BusinessAuthenticationClient BusinessAuthenticationClient
@inject Citus.Business.Blazor.Services.CompanyProvisioningClient CompanyProvisioning

@*
    MyCompaniesPage — reachable from the topbar avatar dropdown.

    Surfaces every company the signed-in user belongs to so they can:
      * Filter by name (client-side, instant)
      * Switch the active company (real — reuses ShellState.TrySetActiveCompany
        + BusinessSessionClient.GetContextAsync, same flow the topbar dropdown
        already uses)
      * Create a new company — wired to POST /accounting/companies
        (PlatformAdditionalCompanyProvisioningRepository), which seeds the
        canonical chart of accounts and adds an owner membership for the
        signed-in user. On success the shell auto-switches to the new
        company and lands on the dashboard.
      * Join a company — placeholder until the invitation pipeline lands
        (token + approval + membership write-through).

    Plan label is hardcoded "Plan: Business" because the platform has no
    subscription concept yet. Per-company role is rendered as "Member" for
    the same reason — BusinessCompanySummary doesn't carry the membership
    role and User.Roles is a merged permissions array, not a per-company
    label.
*@

<PageTitle>My Companies | Tralanz Books</PageTitle>

<div class="citus-page-narrow">
    <CitusPageHeader Model="_header">
        <Actions>
            <CitusButton Variant="CitusButtonVariant.Ghost" OnClick="OnJoinClickedAsync">
                <CitusIcon Name="IconName.Users" Size="IconSize.Inline" />
                <span>Join a company</span>
            </CitusButton>
            <CitusButton Variant="CitusButtonVariant.Primary" OnClick="StartCreate" Disabled="_isCreating">
                <CitusIcon Name="IconName.Plus" Size="IconSize.Inline" />
                <span>New Company</span>
            </CitusButton>
        </Actions>
    </CitusPageHeader>

    @if (_isCreating)
    {
        @if (!string.IsNullOrWhiteSpace(_validation))
        {
            <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_validation" ShowIcon="true" Class="mb-4" />
        }

        <section class="citus-panel mb-6">
            <h2 class="citus-panel__title">New company</h2>
            <p class="text-fg-muted text-sm mb-4">
                Seeds the canonical chart of accounts and books for a new company you'll own.
                You'll be switched to it automatically when it's ready.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="citus-form-field__label">Company legal name</label>
                    <input class="citus-form-field__input"
                           value="@_draft.CompanyName"
                           @oninput="@(e => _draft.CompanyName = e.Value?.ToString() ?? string.Empty)" />
                </div>
                <div>
                    <label class="citus-form-field__label">Entity type</label>
                    <select class="citus-form-field__input"
                            value="@_draft.EntityType"
                            @onchange="@(e => _draft.EntityType = e.Value?.ToString() ?? "corporation")">
                        <option value="corporation">Corporation</option>
                        <option value="partnership">Partnership</option>
                        <option value="sole_proprietorship">Sole proprietorship</option>
                    </select>
                </div>
                <div>
                    <label class="citus-form-field__label">Industry</label>
                    <select class="citus-form-field__input"
                            value="@_draft.Industry"
                            @onchange="@(e => _draft.Industry = e.Value?.ToString() ?? "general")">
                        <option value="general">General services</option>
                        <option value="trading">Trading</option>
                        <option value="property_rental">Property rental</option>
                    </select>
                </div>
                <div>
                    <label class="citus-form-field__label">Country</label>
                    <select class="citus-form-field__input"
                            value="@_draft.Country"
                            @onchange="@(e => _draft.Country = e.Value?.ToString() ?? "Canada")">
                        <option value="Canada">Canada</option>
                        <option value="United States">United States</option>
                        <option value="United Kingdom">United Kingdom</option>
                        <option value="Australia">Australia</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div>
                    <label class="citus-form-field__label">Base currency</label>
                    <select class="citus-form-field__input"
                            value="@_draft.BaseCurrencyCode"
                            @onchange="@(e => _draft.BaseCurrencyCode = e.Value?.ToString() ?? "USD")">
                        <option value="USD">USD — US Dollar</option>
                        <option value="CAD">CAD — Canadian Dollar</option>
                        <option value="EUR">EUR — Euro</option>
                        <option value="GBP">GBP — British Pound</option>
                        <option value="CNY">CNY — Chinese Yuan</option>
                        <option value="AUD">AUD — Australian Dollar</option>
                        <option value="JPY">JPY — Japanese Yen</option>
                        <option value="HKD">HKD — Hong Kong Dollar</option>
                    </select>
                </div>
                <div>
                    <label class="citus-form-field__label">Incorporated on</label>
                    <input type="date"
                           class="citus-form-field__input"
                           value="@_draft.IncorporatedOn.ToString("yyyy-MM-dd")"
                           @onchange="@(e => _draft.IncorporatedOn = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : _draft.IncorporatedOn)" />
                </div>
                <div>
                    <label class="citus-form-field__label">Fiscal year end (MM-DD)</label>
                    <input class="citus-form-field__input"
                           placeholder="12-31"
                           value="@_draft.FiscalYearEnd"
                           @oninput="@(e => _draft.FiscalYearEnd = e.Value?.ToString() ?? string.Empty)" />
                </div>
                <div>
                    <label class="citus-form-field__label">Account code length</label>
                    <select class="citus-form-field__input"
                            value="@_draft.AccountCodeLength"
                            @onchange="@(e => _draft.AccountCodeLength = int.TryParse(e.Value?.ToString(), out var n) ? n : 5)">
                        <option value="4">4 digits</option>
                        <option value="5">5 digits (recommended)</option>
                        <option value="6">6 digits</option>
                        <option value="7">7 digits</option>
                    </select>
                </div>
            </div>

            <div class="flex justify-end gap-2 mt-6">
                <CitusButton OnClick="CancelCreate" Disabled="_isSubmitting">Cancel</CitusButton>
                <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_isSubmitting" OnClick="SaveAsync">
                    @(_isSubmitting ? "Creating…" : "Create company")
                </CitusButton>
            </div>
        </section>
    }
    else
    {
        <section class="citus-panel mb-6">
            <h2 class="citus-panel__title">Search</h2>
            <div class="flex gap-2">
                <input type="search"
                       class="citus-form-field__input flex-1"
                       placeholder="Company name…"
                       value="@_query"
                       @oninput="@(e => _query = e.Value?.ToString() ?? string.Empty)" />
                @* Search button is cosmetic — the input filters live as you
                   type, but the button matches the design and gives a clear
                   target for a future server-side search if the list grows
                   beyond what fits client-side. *@
                <CitusButton Variant="CitusButtonVariant.Primary" OnClick="OnSearchSubmitted">Search</CitusButton>
            </div>
        </section>

        @if (Filtered.Count == 0)
        {
            <CitusEmptyState
                Icon="IconName.BuildingSkyscraper"
                Title="No companies match."
                Message="@(string.IsNullOrWhiteSpace(_query) ? "You don't have access to any companies yet. Use the actions above to create one or join one." : "Try a different search, or clear the filter to see every company you belong to.")" />
        }
        else
        {
            <ul class="citus-company-list">
                @foreach (var company in Filtered)
                {
                    <li class="citus-company-card">
                        <div class="citus-company-card__icon">
                            <CitusIcon Name="IconName.BuildingSkyscraper" Size="IconSize.Action" />
                        </div>
                        <div class="citus-company-card__body">
                            <div class="citus-company-card__title-row">
                                <span class="citus-company-card__name">@company.CompanyName</span>
                                @if (IsActive(company))
                                {
                                    <CitusBadge Color="@("blue")">Active</CitusBadge>
                                }
                                @if (company.IsReadOnly)
                                {
                                    <CitusBadge Color="@("orange")">Read-only</CitusBadge>
                                }
                            </div>
                            <div class="citus-company-card__meta">@RoleLabelFor(company)</div>
                        </div>
                        <div class="citus-company-card__action">
                            @if (IsActive(company))
                            {
                                <span class="citus-company-card__current">Current</span>
                            }
                            else
                            {
                                <CitusButton Variant="CitusButtonVariant.Default"
                                             Disabled="_switchingTo != null"
                                             OnClick="@(() => OnSwitchAsync(company.Id))">
                                    @(_switchingTo == company.Id ? "Switching…" : "Switch")
                                </CitusButton>
                            }
                        </div>
                    </li>
                }
            </ul>
        }
    }
</div>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Plan: Business",
        Title = "My Companies",
        Subtitle = "Switch between the companies you belong to, or create / join another."
    };

    private string _query = string.Empty;
    private CompanyId? _switchingTo;

    private bool _isCreating;
    private bool _isSubmitting;
    private string? _validation;
    private CreateCompanyDraft _draft = new();

    private IReadOnlyList<BusinessCompanySummary> Filtered
    {
        get
        {
            var available = ShellState.AvailableCompanies;
            if (string.IsNullOrWhiteSpace(_query))
            {
                return available;
            }

            var trimmed = _query.Trim();
            return available
                .Where(c =>
                    c.CompanyName.Contains(trimmed, StringComparison.OrdinalIgnoreCase) ||
                    c.CompanyCode.Contains(trimmed, StringComparison.OrdinalIgnoreCase))
                .ToArray();
        }
    }

    private bool IsActive(BusinessCompanySummary company) =>
        company.Id == ShellState.ActiveCompany.Id;

    // Per-company role isn't carried on BusinessCompanySummary today. We
    // render "Owner" for the active company as a heuristic (most users
    // who can sign in to a company at the Business shell are owners or
    // admins) and "Member" elsewhere. Replace with the real value once the
    // session API surfaces membership.role.
    private string RoleLabelFor(BusinessCompanySummary _) => "Member";

    // Cosmetic — input already filters live. Hook left in case we need to
    // bind a server-side search keyword later.
    private void OnSearchSubmitted() { }

    private async Task OnSwitchAsync(CompanyId companyId)
    {
        if (_switchingTo is not null) return;
        if (companyId.Value is null || companyId == ShellState.ActiveCompany.Id) return;

        _switchingTo = companyId;
        try
        {
            // M17 (AUDIT_2026-05-20 P2-4): call the server's switch
            // endpoint FIRST so business_sessions.active_company_id
            // gets updated; flip ShellState only on success. See
            // BusinessTopBar.OnCompanyChangedAsync for the same flow
            // — both surfaces have to call the bind-aware endpoint
            // now that the route guard rejects header/DB mismatches.
            var outcome = await BusinessAuthenticationClient.SwitchActiveCompanyAsync(companyId);
            if (!outcome.Succeeded || outcome.Session is null)
            {
                await Message.WarningAsync(outcome.ErrorMessage
                    ?? "Unable to switch active company. Please try again.");
                return;
            }

            ShellState.ApplyAuthenticatedSession(ShellState.SessionToken, outcome.Session);
            await Message.SuccessAsync($"Active company switched to {outcome.Session.ActiveCompany.CompanyName}.");
            Navigation.NavigateTo("dashboard");
        }
        finally
        {
            _switchingTo = null;
        }
    }

    private void StartCreate()
    {
        _isCreating = true;
        _validation = null;
        _draft = new CreateCompanyDraft
        {
            BaseCurrencyCode = ShellState.ActiveCompany.BaseCurrencyCode ?? "USD",
            Country = "Canada",
            EntityType = "corporation",
            Industry = "general",
            FiscalYearEnd = "12-31",
            IncorporatedOn = DateTime.Today,
            AccountCodeLength = 5
        };
    }

    private void CancelCreate()
    {
        _isCreating = false;
        _validation = null;
    }

    private async Task SaveAsync()
    {
        _validation = null;

        if (string.IsNullOrWhiteSpace(_draft.CompanyName))
        {
            _validation = "Company legal name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_draft.FiscalYearEnd))
        {
            _validation = "Fiscal year end is required (MM-DD).";
            return;
        }

        _isSubmitting = true;
        try
        {
            var payload = new Citus.Business.Blazor.Services.CreateCompanyPayload(
                CompanyName: _draft.CompanyName.Trim(),
                EntityType: _draft.EntityType,
                Industry: _draft.Industry,
                IncorporatedOn: _draft.IncorporatedOn,
                FiscalYearEnd: _draft.FiscalYearEnd.Trim(),
                Country: _draft.Country,
                BaseCurrencyCode: _draft.BaseCurrencyCode,
                AccountCodeLength: _draft.AccountCodeLength);

            var outcome = await CompanyProvisioning.CreateAsync(payload);
            if (!outcome.Succeeded || outcome.Saved is null)
            {
                _validation = outcome.ErrorMessage ?? "Unable to create the company.";
                return;
            }

            // Auto-switch into the new company. M17 (AUDIT_2026-05-20 P2-4):
            // call the server's switch endpoint FIRST. The repository
            // resolves the membership freshly so the brand-new company
            // (owner = current user) is recognised even though it
            // wasn't in ShellState.AvailableCompanies before this
            // request. The returned summary includes the refreshed
            // AvailableCompanies list, so ShellState ends up consistent.
            if (CompanyId.TryParse(outcome.Saved.CompanyId, out var newCompanyId))
            {
                var switchOutcome = await BusinessAuthenticationClient.SwitchActiveCompanyAsync(newCompanyId);
                if (switchOutcome.Succeeded && switchOutcome.Session is not null)
                {
                    ShellState.ApplyAuthenticatedSession(ShellState.SessionToken, switchOutcome.Session);
                }
                else
                {
                    // Auto-switch failed — company is created but the
                    // user is still on the old active company. Tell
                    // them how to switch manually.
                    await Message.SuccessAsync(
                        $"Company '{outcome.Saved.CompanyName}' created. Switch into it from this page if it doesn't appear automatically.");
                    var refreshed = await BusinessSessionClient.GetContextAsync();
                    if (refreshed is not null)
                    {
                        ShellState.ApplySessionContext(refreshed);
                    }
                    _isCreating = false;
                    StateHasChanged();
                    return;
                }
            }

            await Message.SuccessAsync($"Company '{outcome.Saved.CompanyName}' created. Switched in.");
            _isCreating = false;
            Navigation.NavigateTo("dashboard");
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private Task OnJoinClickedAsync() =>
        Message.InfoAsync(
            "Joining an existing company by invitation is coming soon. " +
            "For now, ask a SysAdmin operator to add your account to the company's membership.");

    private sealed class CreateCompanyDraft
    {
        public string CompanyName { get; set; } = string.Empty;
        public string EntityType { get; set; } = "corporation";
        public string Industry { get; set; } = "general";
        public string Country { get; set; } = "Canada";
        public string BaseCurrencyCode { get; set; } = "USD";
        public DateTime IncorporatedOn { get; set; } = DateTime.Today;
        public string FiscalYearEnd { get; set; } = "12-31";
        public int AccountCodeLength { get; set; } = 5;
    }
}
