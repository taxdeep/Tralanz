@page "/session"

@inject BusinessShellState ShellState

<PageTitle>Session | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header" />

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <CitusFormSection Title="Business identity">
        <CitusKeyValueTable>
            @foreach (var fact in _userFacts)
            {
                <CitusKeyValueRow Label="@fact.Label">@fact.Value</CitusKeyValueRow>
            }
        </CitusKeyValueTable>
    </CitusFormSection>

    <CitusFormSection Title="Company context">
        <CitusKeyValueTable>
            @foreach (var fact in _companyFacts)
            {
                <CitusKeyValueRow Label="@fact.Label">@fact.Value</CitusKeyValueRow>
            }
        </CitusKeyValueTable>
    </CitusFormSection>
</div>

<CitusFormSection Title="Accessible companies">
    <HeaderActions>
        <CitusBadge Color="@("blue")">
            @ShellState.AvailableCompanies.Count memberships
        </CitusBadge>
    </HeaderActions>
    <ChildContent>
        <table class="citus-data-table">
            <thead>
                <tr>
                    <th>Company</th>
                    <th>Id</th>
                    <th>Base currency</th>
                    <th>Multi-currency</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var company in ShellState.AvailableCompanies)
                {
                    <tr>
                        <td>
                            @company.CompanyName <span class="text-fg-muted">(@company.CompanyCode)</span>
                        </td>
                        <td><span class="citus-inline-code">@FormatGuid(company.Id)</span></td>
                        <td>@company.BaseCurrencyCode</td>
                        <td>@(company.MultiCurrencyEnabled ? "Enabled" : "Disabled")</td>
                    </tr>
                }
            </tbody>
        </table>
    </ChildContent>
</CitusFormSection>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Session",
        Title = "Business session context",
        Subtitle = "This shell keeps active company selection explicit and visible."
    };

    private IReadOnlyList<FactRow> _userFacts =>
    [
        new("Display name", ShellState.User.DisplayName),
        new("Username", ShellState.User.Username),
        new("Email", ShellState.User.Email),
        // Surface the underlying Guid so support / ops can confirm the
        // session-header pipeline is hydrating real identity (not Guid.Empty).
        new("User Id", FormatGuid(ShellState.User.Id)),
        new("Roles", string.Join(", ", ShellState.User.Roles)),
        new("Session token", string.IsNullOrEmpty(ShellState.SessionToken)
            ? "(none)"
            : $"{ShellState.SessionToken[..Math.Min(8, ShellState.SessionToken.Length)]}…")
    ];

    private IReadOnlyList<FactRow> _companyFacts =>
    [
        new("Company", $"{ShellState.ActiveCompany.CompanyName} ({ShellState.ActiveCompany.CompanyCode})"),
        // Same intent as User Id — verify the active-company-id sent to
        // the API in headers / query strings is a real Guid.
        new("Company Id", FormatGuid(ShellState.ActiveCompany.Id)),
        new("Base currency", ShellState.ActiveCompany.BaseCurrencyCode),
        new("Multi-currency", ShellState.ActiveCompany.MultiCurrencyEnabled ? "Enabled" : "Disabled"),
        new("Read-only", ShellState.IsCompanyReadOnly ? "Yes" : "No"),
        new("Maintenance", ShellState.MaintenanceState.Enabled ? ShellState.MaintenanceState.Message : "Disabled")
    ];

    private static string FormatGuid(CompanyId value) =>
        string.IsNullOrEmpty(value.Value)
            ? "(empty — not hydrated)"
            : value.Value;

    private static string FormatGuid(UserId value) =>
        string.IsNullOrEmpty(value.Value)
            ? "(empty — not hydrated)"
            : value.Value;

    private sealed record class FactRow(string Label, string Value);
}
