@page "/purchase-orders/{PurchaseOrderId:guid}"

@inject BusinessShellState ShellState
@inject PurchaseOrderClient PurchaseOrderClient
@inject AccountClient AccountClient
@inject CitusToastService Message
@inject NavigationManager Navigation

<PageTitle>@($"{_pageTitle} | Tralanz Books")</PageTitle>

<CitusPageHeader Model="_header">
    <TitleSuffix>
        @if (_po is not null)
        {
            <CitusDocumentStatusBadge Status="@_po.Status" />
        }
    </TitleSuffix>
    <Actions>
        <CitusLinkButton Href="purchase-orders"
                         Variant="CitusButtonVariant.Ghost"
                         LeadingIcon="IconName.ArrowLeft">
            Back to POs
        </CitusLinkButton>
    </Actions>
</CitusPageHeader>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_error" ShowIcon="true" Class="mb-4" />
}

@if (_isLoading)
{
    <CitusSkeleton Variant="SkeletonVariant.Detail" />
}
else if (_po is null)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="Purchase order not found in this company." ShowIcon="true" />
}
else
{
    <div class="citus-detail-overview">
        <CitusFormSection Title="Vendor">
            <CitusKeyValueTable>
                <CitusKeyValueRow Label="PO #"><span class="citus-inline-code">@_po.PurchaseOrderNumber</span></CitusKeyValueRow>
                <CitusKeyValueRow Label="Name">@_po.VendorName</CitusKeyValueRow>
                @if (HasAddress(_po))
                {
                    <CitusKeyValueRow Label="Billing address">@FormatAddress(_po.BillingAddressLine, _po.BillingCity, _po.BillingProvinceState, _po.BillingPostalCode, _po.BillingCountry)</CitusKeyValueRow>
                    @if (!string.IsNullOrWhiteSpace(_po.ShippingAddressLine))
                    {
                        <CitusKeyValueRow Label="Ship to">@FormatAddress(_po.ShippingAddressLine, _po.ShippingCity, _po.ShippingProvinceState, _po.ShippingPostalCode, _po.ShippingCountry)</CitusKeyValueRow>
                    }
                }
            </CitusKeyValueTable>
        </CitusFormSection>

        <CitusStatCard Label="Total" Value="@($"{_po.TotalAmount:N2} {_po.TransactionCurrencyCode}")"
                       Description="@($"Subtotal {_po.SubtotalAmount:N2} − discount {_po.DiscountAmount:N2}")"
                       Icon="IconName.Coin" Tone="StatTone.Success" />
        <CitusStatCard Label="Expected delivery"
                       Value="@(_po.ExpectedDeliveryDate?.ToString("yyyy-MM-dd") ?? "—")"
                       Description="@($"Ordered {_po.OrderDate:yyyy-MM-dd}")"
                       Icon="IconName.Calendar" Tone="StatTone.Neutral" />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-8">
            <CitusFormSection Title="Lines">
                <table class="citus-data-table">
                    <thead>
                        <tr>
                            <th style="width: 3rem">#</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th class="text-right" style="width: 5rem">Qty</th>
                            <th class="text-right" style="width: 7rem">Rate</th>
                            <th class="text-right" style="width: 8rem">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in _po.Lines)
                        {
                            <tr>
                                <td>@line.Sequence</td>
                                <td>@(line.ExpenseAccountId is { } accId ? ResolveAccountLabel(accId) : "—")</td>
                                <td>@(string.IsNullOrEmpty(line.Description) ? "—" : line.Description)</td>
                                <td class="text-right">@line.Quantity.ToString("0.##")</td>
                                <td class="text-right">@line.UnitPrice.ToString("0.0000")</td>
                                <td class="text-right">@line.LineTotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </CitusFormSection>

            @if (!string.IsNullOrWhiteSpace(_po.MemoToSupplier) || !string.IsNullOrWhiteSpace(_po.InternalNote))
            {
                <CitusFormSection Title="Notes">
                    <CitusKeyValueTable>
                        @if (!string.IsNullOrWhiteSpace(_po.MemoToSupplier))
                        {
                            <CitusKeyValueRow Label="Memo to supplier">@_po.MemoToSupplier</CitusKeyValueRow>
                        }
                        @if (!string.IsNullOrWhiteSpace(_po.InternalNote))
                        {
                            <CitusKeyValueRow Label="Internal note">@_po.InternalNote</CitusKeyValueRow>
                        }
                    </CitusKeyValueTable>
                </CitusFormSection>
            }
        </div>

        <aside class="lg:col-span-4 flex flex-col gap-6">
            <CitusFormSection Title="Totals">
                <CitusKeyValueTable>
                    <CitusKeyValueRow Label="Subtotal" ValueAlignRight="true">@_po.SubtotalAmount.ToString("N2")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Discount" ValueAlignRight="true">−@_po.DiscountAmount.ToString("N2")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Shipping" ValueAlignRight="true">@((_po.ShippingAmount ?? 0m).ToString("N2"))</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Tax" ValueAlignRight="true">@_po.TaxAmount.ToString("N2")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Total" ValueAlignRight="true"><strong>@_po.TotalAmount.ToString("N2") @_po.TransactionCurrencyCode</strong></CitusKeyValueRow>
                </CitusKeyValueTable>
            </CitusFormSection>
        </aside>
    </div>

    @* Sticky bottom action bar — same pattern as the invoice / SO detail
       pages (the mid-page Actions panel is gone). Primary action varies
       by lifecycle; Edit moved here from the page header. *@
    @if (_po.Status == "draft")
    {
        <CitusFormActions Sticky="true"
                          PrimaryLabel="Send"
                          SavingLabel="Sending…"
                          CancelVisible="false"
                          IsSaving="@_isMutating"
                          Disabled="@ShellState.AreWritesBlocked"
                          OnSave="@(() => SetStatusAsync("open", "PO sent (Open)."))">
            <ExtraContent>
                <CitusLinkButton Href="@($"purchase-orders/{_po.Id:D}/edit")" Variant="CitusButtonVariant.Ghost" LeadingIcon="IconName.Pencil">Edit</CitusLinkButton>
                <CitusButton Variant="CitusButtonVariant.Ghost" Disabled="@_isMutating" OnClick="CopyAsync">Copy</CitusButton>
                <CitusButton Variant="CitusButtonVariant.Ghost" Disabled="@_isMutating" OnClick="@(() => SetStatusAsync("cancelled", "PO cancelled."))">Cancel PO</CitusButton>
                <CitusButton Variant="CitusButtonVariant.Ghost" Disabled="@_isMutating" OnClick="@(() => SetStatusAsync("void", "PO voided."))">Void</CitusButton>
            </ExtraContent>
        </CitusFormActions>
    }
    else if (_po.Status is "open" or "closed")
    {
        <CitusFormActions Sticky="true"
                          PrimaryLabel="Convert to Bill"
                          SavingLabel="Converting…"
                          CancelVisible="false"
                          IsSaving="@_isMutating"
                          Disabled="@ShellState.AreWritesBlocked"
                          OnSave="ConvertToBillAsync">
            <ExtraContent>
                @if (IsEditable(_po.Status))
                {
                    <CitusLinkButton Href="@($"purchase-orders/{_po.Id:D}/edit")" Variant="CitusButtonVariant.Ghost" LeadingIcon="IconName.Pencil">Edit</CitusLinkButton>
                }
                <CitusLinkButton Href="@($"purchase-orders/{_po.Id:D}/convert-to-expense")" Variant="CitusButtonVariant.Ghost">Convert to Expense</CitusLinkButton>
                <CitusButton Variant="CitusButtonVariant.Ghost" Disabled="@_isMutating" OnClick="CopyAsync">Copy</CitusButton>
                @if (_po.Status == "open")
                {
                    <CitusButton Variant="CitusButtonVariant.Ghost" Disabled="@_isMutating" OnClick="@(() => SetStatusAsync("cancelled", "PO cancelled."))">Cancel PO</CitusButton>
                }
                <CitusButton Variant="CitusButtonVariant.Ghost" Disabled="@_isMutating" OnClick="@(() => SetStatusAsync("void", "PO voided."))">Void</CitusButton>
            </ExtraContent>
        </CitusFormActions>
    }
    else
    {
        <CitusFormActions Sticky="true"
                          PrimaryLabel="Copy PO"
                          CancelVisible="false"
                          OnSave="CopyAsync" />
    }
}

@code {
    [Parameter] public Guid PurchaseOrderId { get; set; }

    private PurchaseOrderRecordDto? _po;
    private IReadOnlyList<AccountSummary> _accounts = Array.Empty<AccountSummary>();
    private bool _isLoading = true;
    private bool _isMutating;
    private string? _error;

    private PageHeaderModel _header = new() { Eyebrow = "Expense & Bills", Title = "PO", Subtitle = "Purchase order detail" };
    private string _pageTitle = "PO";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override async Task OnParametersSetAsync()
    {
        if (_po is not null && _po.Id != PurchaseOrderId)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            var poTask = PurchaseOrderClient.GetByIdAsync(PurchaseOrderId);
            var accountsTask = AccountClient.ListAsync();
            await Task.WhenAll(poTask, accountsTask);
            _po = poTask.Result;
            _accounts = accountsTask.Result;
            ApplyHeader();
        }
        finally { _isLoading = false; }
    }

    private void ApplyHeader()
    {
        if (_po is null)
        {
            _pageTitle = "PO";
            _header = new PageHeaderModel { Eyebrow = "Expense & Bills", Title = "PO", Subtitle = "Purchase order detail" };
            return;
        }
        _pageTitle = _po.PurchaseOrderNumber;
        _header = new PageHeaderModel
        {
            Eyebrow = "Expense & Bills",
            Title = _po.PurchaseOrderNumber,
            // Status lives in the header badge; repeating it here read twice.
            Subtitle = _po.VendorName
        };
    }

    private string ResolveAccountLabel(Guid accountId)
    {
        var account = _accounts.FirstOrDefault(a => a.Id == accountId);
        return account is null ? accountId.ToString("D") : $"{account.Code}  {account.Name}";
    }

    private async Task SetStatusAsync(string newStatus, string successMessage)
    {
        if (_po is null || _isMutating) return;
        _isMutating = true;
        try
        {
            var outcome = await PurchaseOrderClient.SetStatusAsync(_po.Id, newStatus);
            if (!outcome.Succeeded)
            {
                _error = outcome.ErrorMessage ?? "Status change failed.";
                await Message.WarningAsync(_error);
                return;
            }
            _po = outcome.Saved;
            ApplyHeader();
            await Message.SuccessAsync(successMessage);
        }
        finally { _isMutating = false; }
    }

    private async Task ConvertToBillAsync()
    {
        if (_po is null || _isMutating) return;
        _isMutating = true;
        try
        {
            var outcome = await PurchaseOrderClient.ConvertToBillAsync(_po.Id);
            if (!outcome.Succeeded || outcome.Saved is null)
            {
                _error = outcome.ErrorMessage ?? "Convert to Bill failed.";
                await Message.WarningAsync(_error);
                return;
            }
            await Message.SuccessAsync($"Bill {outcome.Saved.BillNumber} created from PO. Update the supplier's invoice number, then post it.");
            Navigation.NavigateTo($"bills/{outcome.Saved.Id:D}/edit");
        }
        finally { _isMutating = false; }
    }

    private static bool IsEditable(string status) => status is "draft" or "open";

    private static bool HasAddress(PurchaseOrderRecordDto po) =>
        !string.IsNullOrWhiteSpace(po.BillingAddressLine) || !string.IsNullOrWhiteSpace(po.BillingCity);

    private static string FormatAddress(string? line, string? city, string? prov, string? postal, string? country)
    {
        var parts = new List<string>(5);
        if (!string.IsNullOrWhiteSpace(line)) parts.Add(line);
        if (!string.IsNullOrWhiteSpace(city)) parts.Add(city);
        if (!string.IsNullOrWhiteSpace(prov)) parts.Add(prov);
        if (!string.IsNullOrWhiteSpace(postal)) parts.Add(postal);
        if (!string.IsNullOrWhiteSpace(country)) parts.Add(country);
        return parts.Count == 0 ? "—" : string.Join(", ", parts);
    }

    // Copy A3 Phase 3: navigate to /purchase-orders/new with ?copyFrom=.
    // PO copy works from any status (operator may want to re-issue a
    // closed/cancelled PO with corrections).
    private void CopyAsync()
    {
        if (_po is null) return;
        Navigation.NavigateTo($"purchase-orders/new?copyFrom={_po.Id:D}");
    }

}
