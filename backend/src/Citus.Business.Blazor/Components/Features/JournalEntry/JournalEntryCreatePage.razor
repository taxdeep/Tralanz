@page "/journal-entry/new"

@using Citus.Modules.UnitySearch.Blazor
@using Citus.Modules.UnitySearch.Domain.Shared

@inject BusinessShellState ShellState
@inject BusinessWriteFlowClient WriteFlow
@inject JournalEntryReviewClient JournalEntryReviewClient
@inject CompanyCurrencyClient CompanyCurrencyClient
@inject NavigationManager NavigationManager
@inject CitusToastService Message

<PageTitle>New Journal Entry | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <a class="citus-button citus-button--ghost" href="journal-entry">
            <CitusIcon Name="IconName.ArrowLeft" Size="IconSize.Inline" />
            <span>Back to journal entries</span>
        </a>
        <CitusBadge Color="@(_isBalanced ? "green" : "orange")">
            @(_isBalanced ? "Balanced" : "Out of balance")
        </CitusBadge>
    </Actions>
</CitusPageHeader>

@if (ShellState.AreWritesBlocked)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning"
                     ShowIcon="true"
                     Message="@ShellState.WriteBlockMessage"
                     Class="mb-4" />
}

@if (!string.IsNullOrWhiteSpace(_prefilledFromDisplayNumber))
{
    <CitusAlert Severity="CitusAlertSeverity.Info"
                ShowIcon="true"
                Class="mb-4">
        <MessageTemplate>
            <strong>Pre-filled from @_prefilledFromDisplayNumber.</strong>
            <div class="text-fg-muted text-sm mt-1">
                The original entry has been voided (a compensating entry was auto-posted).
                Adjust the lines below and submit to record the corrected version.
            </div>
        </MessageTemplate>
    </CitusAlert>
}

@if (!string.IsNullOrWhiteSpace(_validationMessage))
{
    <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_validationMessage" ShowIcon="true" Class="mb-4" />
}

@if (_lastResult is not null)
{
    <CitusAlert Severity="@(_lastResult.Succeeded ? CitusAlertSeverity.Success : CitusAlertSeverity.Info)"
                     ShowIcon="true"
                     Class="mb-4">
        <MessageTemplate>
            <strong>@_lastResult.Operation</strong>
            <div class="text-fg-muted text-sm mt-1">@_lastResult.Message</div>
        </MessageTemplate>
    </CitusAlert>
}

<div class="flex flex-col gap-6">
    <section class="citus-panel">
        <h2 class="citus-panel__title">Header</h2>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
                @* Journal No. — pre-filled with the next system-assigned
                   number on form load, but the operator can override inline.
                   Backend honors the override if it doesn't collide; if the
                   field is cleared, the post handler falls back to the
                   numbering engine's reserve path. *@
                <label class="citus-form-field">
                    <span class="citus-form-field__label">Journal No.</span>
                    <input type="text"
                           class="citus-form-field__input"
                           placeholder="@(_isLoadingJournalNumber ? "Loading…" : "Auto-assigned on save")"
                           value="@_journalNumber"
                           @oninput="@(e => _journalNumber = e.Value?.ToString() ?? string.Empty)"
                           maxlength="32" />
                </label>
                <label class="citus-form-field">
                    <span class="citus-form-field__label">Date</span>
                    <input type="date"
                           class="citus-form-field__input"
                           value="@(_date?.ToString("yyyy-MM-dd"))"
                           @onchange="OnDateChanged" />
                </label>
                @* Transaction currency picker — only currencies the company has
                   enabled (Settings → Multi-currency) appear, base currency
                   always included. Same pattern as CounterpartyForm. The FX
                   rate inline below auto-fetches on currency change; switching
                   currency clears the prior rate so FxRateInline re-fills
                   from the recommendation API. *@
                <label class="citus-form-field">
                    <span class="citus-form-field__label">Transaction currency</span>
                    <select class="citus-form-field__input"
                            value="@_currency"
                            @onchange="OnCurrencyChanged"
                            disabled="@(!ShellState.ActiveCompany.MultiCurrencyEnabled || _isLoadingCurrencies)">
                        @foreach (var entry in _enabledCurrencies)
                        {
                            <option value="@entry.CurrencyCode">
                                @entry.CurrencyCode — @entry.CurrencyName@(entry.IsBaseCurrency ? " (base)" : "")
                            </option>
                        }
                        @if (!string.IsNullOrWhiteSpace(_currency)
                             && _enabledCurrencies.All(c => !string.Equals(c.CurrencyCode, _currency, StringComparison.OrdinalIgnoreCase)))
                        {
                            <option value="@_currency">@_currency (no longer enabled)</option>
                        }
                    </select>
                    @if (!ShellState.ActiveCompany.MultiCurrencyEnabled)
                    {
                        <span class="text-fg-subtle text-xs mt-1">
                            Multi-currency is off — enable in Settings to choose another currency.
                        </span>
                    }
                </label>
                <div>
                    @if (!string.Equals(_currency.Trim(), ShellState.ActiveCompany.BaseCurrencyCode, StringComparison.OrdinalIgnoreCase) &&
                         !string.IsNullOrWhiteSpace(_currency.Trim()))
                    {
                        <label class="citus-form-field">
                            <span class="citus-form-field__label">Exchange rate</span>
                            <FxRateInline DocumentDate="@(DateOnly.FromDateTime((_date ?? DateTime.Today).Date))"
                                          BaseCurrencyCode="@ShellState.ActiveCompany.BaseCurrencyCode"
                                          QuoteCurrencyCode="@_currency"
                                          @bind-Rate="_exchangeRate" />
                        </label>
                    }
                </div>
                <label class="citus-form-field md:col-span-4">
                    <span class="citus-form-field__label">Description <span class="text-fg-subtle text-xs">(optional)</span></span>
                    <input type="text"
                           class="citus-form-field__input"
                           placeholder="What is this journal recording?"
                           value="@_description"
                           @oninput="@(e => _description = e.Value?.ToString() ?? string.Empty)" />
                </label>
            </div>
        </section>

        <section class="citus-panel">
            <header class="citus-panel__header">
                <h2 class="citus-panel__title">Lines</h2>
                <span class="text-fg-muted text-sm">Press Tab through cells; a new row appears as you fill the last one.</span>
            </header>

            <table class="citus-data-table citus-journal-lines">
                <thead>
                    <tr>
                        <th class="citus-journal-lines__num"></th>
                        <th class="citus-journal-lines__gutter"></th>
                        <th>ACCOUNT</th>
                        <th class="text-right citus-journal-lines__amount">DEBIT (@_currency.ToUpperInvariant())</th>
                        <th class="text-right citus-journal-lines__amount">CREDIT (@_currency.ToUpperInvariant())</th>
                        <th class="citus-journal-lines__desc">DESCRIPTION</th>
                        @* NAME (per-line counterparty) and SALES TAX columns
                           were removed: the values used to be captured in the
                           UI but the wire shape (ManualJournalLineDraft)
                           dropped them on post, so they never landed in
                           journal_entry_lines. They'll come back when the
                           line schema gains counterparty_id + tax_code_id
                           and the post payload carries them through. *@
                        <th class="citus-journal-lines__action"></th>
                    </tr>
                </thead>
                <tbody>
                    @for (var index = 0; index < _lines.Count; index++)
                    {
                        var i = index;
                        var line = _lines[i];
                        <tr class="citus-journal-lines__row">
                            <td class="citus-journal-lines__num">@(i + 1)</td>
                            <td class="citus-journal-lines__gutter">
                                <button type="button"
                                        class="citus-icon-button citus-journal-lines__insert"
                                        title="Insert a line below this one"
                                        @onclick="() => InsertLineAfter(i)">
                                    <CitusIcon Name="IconName.Plus" Size="IconSize.Inline" />
                                </button>
                            </td>
                            <td>
                                <AccountPicker CompanyId="@ShellState.ActiveCompany.Id"
                                               UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                               Context="journal_entry.account_picker"
                                               DefaultCurrencyCode="@ShellState.ActiveCompany.BaseCurrencyCode"
                                               SelectedId="@line.AccountId"
                                               SelectedDisplayText="@line.AccountDisplay"
                                               OnAccountSelected="@(account => OnAccountPicked(i, account))"
                                               OnCleared="@(() => ClearAccount(i))" />
                            </td>
                            @* type="text" + inputmode="decimal" instead of type="number":
                               type="number" pulls in Chromium's native numeric-input
                               renderer, which on these cells was painting the value with
                               a system-derived -webkit-text-fill-color that ended up
                               matching the cell background (invisible in both light and
                               dark mode). Plain text inputs paint via our own colour
                               tokens; mobile keyboards still get the decimal pad via
                               inputmode. ParseDecimal already tolerates whatever the
                               user types. *@
                            <td>
                                <input type="text"
                                       inputmode="decimal"
                                       class="citus-journal-lines__cell-input citus-journal-lines__amount-input"
                                       value="@FormatDecimalForInput(line.Debit)"
                                       @oninput="@(e => UpdateDebit(i, e.Value?.ToString()))" />
                            </td>
                            <td>
                                <input type="text"
                                       inputmode="decimal"
                                       class="citus-journal-lines__cell-input citus-journal-lines__amount-input"
                                       value="@FormatDecimalForInput(line.Credit)"
                                       @oninput="@(e => UpdateCredit(i, e.Value?.ToString()))" />
                            </td>
                            <td>
                                <input type="text"
                                       class="citus-journal-lines__cell-input"
                                       value="@line.Description"
                                       @oninput="@(e => UpdateLine(i, l => l with { Description = e.Value?.ToString() ?? string.Empty }))"
                                       placeholder="Memo" />
                            </td>
                            @* NAME and SALES TAX cells removed; see header note. *@
                            <td class="citus-journal-lines__action">
                                <button type="button"
                                        class="citus-icon-button"
                                        title="Remove line"
                                        @onclick="() => RemoveLine(i)">
                                    <CitusIcon Name="IconName.Trash" Size="IconSize.Inline" />
                                </button>
                            </td>
                        </tr>
                    }
                    <tr class="citus-journal-lines__total">
                        <td colspan="3" class="text-right font-medium">Totals</td>
                        <td class="text-right font-semibold">@FormatAmount(_totalDebit)</td>
                        <td class="text-right font-semibold">@FormatAmount(_totalCredit)</td>
                        <td colspan="4"></td>
                    </tr>
                </tbody>
            </table>

            <div class="flex items-center gap-3 mt-3">
            <CitusButton LeadingIcon="IconName.Plus" Size="CitusButtonSize.Small" OnClick="AddLine">Add line</CitusButton>
            <CitusButton Variant="CitusButtonVariant.Ghost" Size="CitusButtonSize.Small" OnClick="ClearAllLines">Clear all lines</CitusButton>
            @if (!_isBalanced)
            {
                <span class="text-warning text-sm ml-auto">
                    Difference: <span class="citus-inline-code">@FormatAmount(Math.Abs(_totalDebit - _totalCredit))</span>
                </span>
            }
        </div>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-stretch">
        <section class="citus-panel h-full">
            <h2 class="citus-panel__title">Posting summary</h2>
            <table class="citus-keyvalue">
                <tbody>
                    <tr><th>Company</th><td>@ShellState.ActiveCompany.CompanyName</td></tr>
                    <tr><th>Base currency</th><td>@ShellState.ActiveCompany.BaseCurrencyCode</td></tr>
                    <tr><th>Transaction currency</th><td>@(_currency.ToUpperInvariant())</td></tr>
                    <tr><th>Lines</th><td>@_lines.Count</td></tr>
                    <tr><th>Debit total</th><td>@FormatAmount(_totalDebit)</td></tr>
                    <tr><th>Credit total</th><td>@FormatAmount(_totalCredit)</td></tr>
                    <tr><th>Balance</th><td>@(_isBalanced ? "✓" : "△")</td></tr>
                </tbody>
            </table>
        </section>

        <section class="citus-panel h-full">
            <h2 class="citus-panel__title">Post</h2>
            <p class="text-fg-muted text-sm mb-3">
                Posting is irreversible from this surface. Backend reserves the journal entry number and the FX snapshot at the moment of the call.
            </p>

            <div class="flex items-center gap-3">
                <CitusButton Variant="CitusButtonVariant.Primary"
                             Disabled="@(!_isBalanced || _lines.Count == 0 || ShellState.AreWritesBlocked || _isSubmitting)"
                             OnClick="PostAsync">
                    @(_isSubmitting ? "Posting..." : "Post journal entry")
                </CitusButton>
                <CitusButton Variant="CitusButtonVariant.Ghost" Disabled="_isSubmitting" OnClick="ResetAsync">Reset draft</CitusButton>
            </div>
        </section>
    </div>
</div>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Core",
        Title = "New journal entry",
        Subtitle = "Create the manual journal posting that flows through the backend Posting Engine. Debit and credit totals must match before submit unlocks."
    };

    /// <summary>
    /// UI-side line model. Carries the columns the user enters today
    /// (account / name / description / debit / credit / tax). The wire
    /// shape (<see cref="ManualJournalLineDraft"/>) only forwards the
    /// fields the Posting Engine currently consumes; counterparty + tax
    /// values are captured for the upcoming backend integration.
    /// </summary>
    private sealed record JournalLineEditState(
        string AccountCode = "",
        string AccountDisplay = "",
        Guid? AccountId = null,
        string NameDisplay = "",
        Guid? NameEntityId = null,
        string NameEntityType = "",
        string Description = "",
        decimal Debit = 0m,
        decimal Credit = 0m,
        string TaxCode = "");

    @* Per-line tax codes were removed from the form; see header comment
       in the table. The fetch + drop-down state previously kept here go
       away too — they pull data nothing renders. Restore alongside the
       NAME / SALES TAX columns when the JE post payload starts carrying
       counterparty_id + tax_code_id per line. *@

    // Enabled currencies for the Transaction currency dropdown. Loaded
    // once at page init from /accounting/company/currencies. The base
    // currency is always present; foreign entries depend on what's been
    // enabled in Settings → Multi-currency.
    private IReadOnlyList<CompanyCurrencyEntry> _enabledCurrencies = Array.Empty<CompanyCurrencyEntry>();
    private bool _isLoadingCurrencies = true;

    /// <summary>
    /// Optional ?from={journalEntryId} query param. When the operator clicks
    /// "Edit" on the JE review page, that page voids the entry and routes
    /// here with this parameter set so we can pre-fill the form with the
    /// voided entry's lines instead of forcing a re-type.
    /// </summary>
    [SupplyParameterFromQuery(Name = "from")]
    public Guid? FromJournalEntryId { get; set; }

    private DateTime? _date = DateTime.Today;
    private string _description = string.Empty;
    private string _journalNumber = string.Empty;
    private bool _isLoadingJournalNumber;
    private string _currency = string.Empty;
    private decimal? _exchangeRate;
    private readonly List<JournalLineEditState> _lines = new();
    private bool _isSubmitting;
    private string? _validationMessage;
    private WriteFlowResult? _lastResult;
    /// <summary>Display number of the source JE when this form was opened
    /// via Edit ("from=..." in the URL). Drives the info banner at the top.</summary>
    private string? _prefilledFromDisplayNumber;

    private decimal _totalDebit => _lines.Sum(l => l.Debit);
    private decimal _totalCredit => _lines.Sum(l => l.Credit);
    private bool _isBalanced => _lines.Count > 0 && _totalDebit == _totalCredit && _totalDebit > 0;

    protected override async Task OnInitializedAsync()
    {
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;

        // When opened via the JE review page's "Edit" action the URL carries
        // ?from={journalEntryId}. Fetch that entry up-front and pre-fill the
        // form with its lines so the operator only edits the cells that
        // actually need correcting. Date stays today (we're recording a
        // correction now, not back-dating).
        if (FromJournalEntryId is { } fromId && fromId != Guid.Empty)
        {
            var source = await JournalEntryReviewClient.GetAsync(ShellState.ActiveCompany.Id, fromId);
            if (source is not null && source.Lines.Count > 0)
            {
                _prefilledFromDisplayNumber = source.DisplayNumber;
                _currency = source.TransactionCurrencyCode;
                if (!string.Equals(source.TransactionCurrencyCode, source.BaseCurrencyCode, StringComparison.OrdinalIgnoreCase))
                {
                    _exchangeRate = source.ExchangeRate;
                }
                foreach (var line in source.Lines.OrderBy(l => l.LineNumber))
                {
                    _lines.Add(new JournalLineEditState(
                        AccountCode: line.AccountCode,
                        AccountDisplay: $"{line.AccountCode} {line.AccountName}",
                        AccountId: line.AccountId,
                        Description: line.Description,
                        Debit: line.TxDebit,
                        Credit: line.TxCredit));
                }
            }
        }

        // Pad up to 4 visible rows so the grid feels the same regardless of
        // whether the form opened blank or pre-filled.
        while (_lines.Count < 4)
        {
            _lines.Add(new JournalLineEditState());
        }

        // Two independent loads — start both, await in parallel. Each is
        // best-effort: a transport failure leaves the corresponding field
        // empty / disabled, never blocks the form.
        _isLoadingJournalNumber = true;
        _isLoadingCurrencies = true;
        var numberTask = JournalEntryReviewClient.GetNextDisplayNumberAsync();
        var currenciesTask = CompanyCurrencyClient.GetAsync();

        try
        {
            var nextNumber = await numberTask;
            if (!string.IsNullOrWhiteSpace(nextNumber))
            {
                _journalNumber = nextNumber!;
            }
        }
        finally
        {
            _isLoadingJournalNumber = false;
        }

        try
        {
            var profile = await currenciesTask;
            if (profile is not null)
            {
                _enabledCurrencies = profile.Currencies
                    .Where(c => c.IsEnabled || c.IsBaseCurrency)
                    .OrderByDescending(c => c.IsBaseCurrency)
                    .ThenBy(c => c.CurrencyCode)
                    .ToList();
            }
        }
        finally
        {
            _isLoadingCurrencies = false;
        }
    }

    private void OnCurrencyChanged(ChangeEventArgs args)
    {
        var picked = args.Value?.ToString() ?? string.Empty;
        if (string.Equals(picked, _currency, StringComparison.OrdinalIgnoreCase)) return;
        _currency = picked;
        // Drop the previous rate so FxRateInline re-fetches the
        // recommendation for the new pair instead of reusing the
        // stale rate from the old currency.
        _exchangeRate = null;
    }

    private void OnDateChanged(ChangeEventArgs args)
    {
        var raw = args.Value?.ToString();
        _date = string.IsNullOrWhiteSpace(raw)
            ? null
            : DateTime.TryParse(raw, out var parsed) ? parsed : _date;
    }

    private void AddLine() => _lines.Add(new JournalLineEditState());

    private void InsertLineAfter(int index)
    {
        if (index < 0 || index >= _lines.Count) return;
        _lines.Insert(index + 1, new JournalLineEditState());
    }

    private void RemoveLine(int index)
    {
        if (index >= 0 && index < _lines.Count)
        {
            _lines.RemoveAt(index);
        }
        if (_lines.Count == 0)
        {
            _lines.Add(new JournalLineEditState());
        }
    }

    private void ClearAllLines()
    {
        _lines.Clear();
        _lines.Add(new JournalLineEditState());
    }

    private void UpdateLine(int index, Func<JournalLineEditState, JournalLineEditState> mutate)
    {
        if (index < 0 || index >= _lines.Count) return;
        _lines[index] = mutate(_lines[index]);
        EnsureTrailingEmptyLine(index);
    }

    private void UpdateDebit(int index, string? raw)
    {
        var parsed = ParseDecimal(raw);
        // A journal line is either a debit or a credit — never both. As soon
        // as the user types a positive amount in one column, zero out the
        // other so the row is unambiguous and the row-level check the
        // backend will run later can never fail on a UI-side input slip.
        UpdateLine(index, l => l with
        {
            Debit = parsed,
            Credit = parsed > 0 ? 0m : l.Credit,
        });
    }

    private void UpdateCredit(int index, string? raw)
    {
        var parsed = ParseDecimal(raw);
        UpdateLine(index, l => l with
        {
            Credit = parsed,
            Debit = parsed > 0 ? 0m : l.Debit,
        });
    }

    private void OnAccountPicked(int index, AccountSummary account)
    {
        UpdateLine(index, l => l with
        {
            AccountId = account.Id,
            AccountCode = account.Code,
            AccountDisplay = $"{account.Code} {account.Name}",
        });
    }

    private void ClearAccount(int index) => UpdateLine(index, l => l with
    {
        AccountId = null,
        AccountCode = string.Empty,
        AccountDisplay = string.Empty,
    });

    private void OnNameSelected(int index, UnitySearchPickerOption option)
    {
        UpdateLine(index, l => l with
        {
            NameEntityId = option.SourceId,
            NameEntityType = option.EntityType,
            NameDisplay = string.IsNullOrWhiteSpace(option.SecondaryText)
                ? option.PrimaryText
                : $"{option.PrimaryText} - {option.SecondaryText}",
        });
    }

    private void ClearName(int index) => UpdateLine(index, l => l with
    {
        NameEntityId = null,
        NameEntityType = string.Empty,
        NameDisplay = string.Empty,
    });

    /// <summary>
    /// When the user fills any field of the last row, append a fresh empty
    /// row so they can keep typing without reaching for "Add line". A row
    /// is considered "filled" if any of account / description / debit /
    /// credit carries content.
    /// </summary>
    private void EnsureTrailingEmptyLine(int touchedIndex)
    {
        if (touchedIndex != _lines.Count - 1) return;
        var last = _lines[^1];
        if (IsEmpty(last)) return;
        _lines.Add(new JournalLineEditState());
    }

    private static bool IsEmpty(JournalLineEditState line) =>
        string.IsNullOrWhiteSpace(line.AccountCode) &&
        string.IsNullOrWhiteSpace(line.Description) &&
        line.Debit == 0m &&
        line.Credit == 0m &&
        line.NameEntityId is null &&
        string.IsNullOrWhiteSpace(line.TaxCode);

    private async Task PostAsync()
    {
        _validationMessage = null;
        _lastResult = null;

        // Description is intentionally optional — a balanced entry is the
        // posting-engine's only hard requirement. Operators frequently file
        // routine adjustments where the line memos already say enough.

        var meaningful = _lines.Where(l => !IsEmpty(l)).ToArray();
        if (meaningful.Length == 0)
        {
            _validationMessage = "Add at least one journal line.";
            return;
        }
        if (meaningful.Any(l => string.IsNullOrWhiteSpace(l.AccountCode)))
        {
            _validationMessage = "Every line needs an account.";
            return;
        }
        if (meaningful.Any(l => l.Debit > 0 && l.Credit > 0))
        {
            _validationMessage = "Each line records either a debit or a credit, not both.";
            return;
        }
        if (!_isBalanced)
        {
            _validationMessage = "Debit and credit totals must match before posting.";
            return;
        }

        _isSubmitting = true;
        try
        {
            var draft = new ManualJournalDraft
            {
                Date = DateOnly.FromDateTime((_date ?? DateTime.Today).Date),
                DisplayNumber = _journalNumber.Trim(),
                Description = _description.Trim(),
                TransactionCurrencyCode = _currency.Trim().ToUpperInvariant(),
                ExchangeRate = _exchangeRate,
                Lines = meaningful.Select(l => new ManualJournalLineDraft
                {
                    AccountId = l.AccountId ?? Guid.Empty,
                    AccountCode = l.AccountCode.Trim(),
                    Description = l.Description,
                    Debit = l.Debit,
                    Credit = l.Credit,
                }).ToArray()
            };

            _lastResult = await WriteFlow.PostManualJournalAsync(draft);
            if (_lastResult.Succeeded)
            {
                await Message.SuccessAsync("Journal entry posted.");
                NavigationManager.NavigateTo("journal-entry");
            }
            else
            {
                await Message.InfoAsync(_lastResult.Message);
            }
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task ResetAsync()
    {
        _lines.Clear();
        for (var i = 0; i < 4; i++)
        {
            _lines.Add(new JournalLineEditState());
        }
        _description = string.Empty;
        _date = DateTime.Today;
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;
        _exchangeRate = null;
        _validationMessage = null;
        _lastResult = null;

        // Re-peek the next number so a follow-up entry on the same browser
        // session shows the correct preview (the previous one is now used /
        // burned and the sequence has likely advanced).
        _journalNumber = string.Empty;
        _isLoadingJournalNumber = true;
        try
        {
            var nextNumber = await JournalEntryReviewClient.GetNextDisplayNumberAsync();
            if (!string.IsNullOrWhiteSpace(nextNumber))
            {
                _journalNumber = nextNumber!;
            }
        }
        finally
        {
            _isLoadingJournalNumber = false;
        }
    }

    private static decimal ParseDecimal(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return 0m;
        return decimal.TryParse(raw, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : 0m;
    }

    private static string FormatDecimalForInput(decimal amount) =>
        amount == 0m ? string.Empty : amount.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private static string FormatAmount(decimal amount) => amount.ToString("N2");
}
