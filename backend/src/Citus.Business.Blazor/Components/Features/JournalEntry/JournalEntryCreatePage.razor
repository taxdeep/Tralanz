@page "/journal-entry/new"

@inject BusinessShellState ShellState
@inject BusinessWriteFlowClient WriteFlow
@inject NavigationManager NavigationManager
@inject AntDesign.IMessageService Message

<PageTitle>New Journal Entry | Citus Business</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <a class="citus-button citus-button--ghost" href="journal-entry">
            <CitusIcon Name="IconName.ArrowLeft" Size="IconSize.Inline" />
            <span>Back to journal entries</span>
        </a>
        <AntDesign.Tag Color="@(_isBalanced ? "green" : "orange")">
            @(_isBalanced ? "Balanced" : "Out of balance")
        </AntDesign.Tag>
    </Actions>
</CitusPageHeader>

@if (ShellState.AreWritesBlocked)
{
    <AntDesign.Alert Type="@AntDesign.AlertType.Warning"
                     ShowIcon="true"
                     Message="@ShellState.WriteBlockMessage"
                     Class="mb-4" />
}

@if (!string.IsNullOrWhiteSpace(_validationMessage))
{
    <AntDesign.Alert Type="@AntDesign.AlertType.Error" Message="@_validationMessage" ShowIcon="true" Class="mb-4" />
}

@if (_lastResult is not null)
{
    <AntDesign.Alert Type="@(_lastResult.Succeeded ? AntDesign.AlertType.Success : AntDesign.AlertType.Info)"
                     ShowIcon="true"
                     Class="mb-4">
        <MessageTemplate>
            <strong>@_lastResult.Operation</strong>
            <div class="text-fg-muted text-sm mt-1">@_lastResult.Message</div>
        </MessageTemplate>
    </AntDesign.Alert>
}

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <div class="lg:col-span-8 flex flex-col gap-6">
        <section class="citus-panel">
            <h2 class="citus-panel__title">Header</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="text-sm font-medium block mb-1">Date</label>
                    <AntDesign.DatePicker TValue="DateTime?" @bind-Value="_date" Style="width: 100%;" />
                </div>
                <div>
                    <label class="text-sm font-medium block mb-1">Transaction currency</label>
                    <CitusInput TValue="string" @bind-Value="_currency" Placeholder="USD" />
                </div>
                <div class="md:col-span-2">
                    <label class="text-sm font-medium block mb-1">Description</label>
                    <CitusInput TValue="string" @bind-Value="_description" Placeholder="What is this journal recording?" />
                </div>
                @if (!string.Equals(_currency.Trim(), ShellState.ActiveCompany.BaseCurrencyCode, StringComparison.OrdinalIgnoreCase) &&
                     !string.IsNullOrWhiteSpace(_currency.Trim()))
                {
                    <div>
                        <label class="text-sm font-medium block mb-1">FX rate (advisory)</label>
                        <AntDesign.InputNumber TValue="decimal?" @bind-Value="_exchangeRate" Min="0.000001m" Style="width: 100%;" />
                        <p class="text-fg-subtle text-xs mt-1">
                            Backend will reserve the official FX snapshot at post time. This is your editorial preview.
                        </p>
                    </div>
                }
            </div>
        </section>

        <section class="citus-panel">
            <header class="citus-panel__header">
                <h2 class="citus-panel__title">Lines</h2>
                <CitusButton LeadingIcon="IconName.Plus" Size="CitusButtonSize.Small" OnClick="AddLine">Add line</CitusButton>
            </header>

            <table class="citus-data-table">
                <thead>
                    <tr>
                        <th style="width: 8rem">Account</th>
                        <th>Description</th>
                        <th class="text-right" style="width: 10rem">Debit</th>
                        <th class="text-right" style="width: 10rem">Credit</th>
                        <th style="width: 3rem"></th>
                    </tr>
                </thead>
                <tbody>
                    @for (var index = 0; index < _lines.Count; index++)
                    {
                        var i = index;
                        var line = _lines[i];
                        <tr>
                            <td><CitusInput TValue="string" Value="@line.AccountCode" ValueChanged="@(v => UpdateLine(i, l => l with { AccountCode = v ?? string.Empty }))" Size="CitusButtonSize.Small" Placeholder="1100" /></td>
                            <td><CitusInput TValue="string" Value="@line.Description" ValueChanged="@(v => UpdateLine(i, l => l with { Description = v ?? string.Empty }))" Size="CitusButtonSize.Small" Placeholder="Line memo" /></td>
                            <td><AntDesign.InputNumber TValue="decimal" Value="@line.Debit" ValueChanged="@(v => UpdateLine(i, l => l with { Debit = v }))" Min="0" Style="width: 100%;" /></td>
                            <td><AntDesign.InputNumber TValue="decimal" Value="@line.Credit" ValueChanged="@(v => UpdateLine(i, l => l with { Credit = v }))" Min="0" Style="width: 100%;" /></td>
                            <td>
                                <button type="button" class="citus-icon-button" title="Remove line" @onclick="() => RemoveLine(i)">
                                    <CitusIcon Name="IconName.Trash" Size="IconSize.Inline" />
                                </button>
                            </td>
                        </tr>
                    }
                    <tr class="citus-data-table__total">
                        <td colspan="2" class="text-right font-medium">Totals</td>
                        <td class="text-right font-semibold">@FormatAmount(_totalDebit)</td>
                        <td class="text-right font-semibold">@FormatAmount(_totalCredit)</td>
                        <td></td>
                    </tr>
                </tbody>
            </table>

            @if (!_isBalanced)
            {
                <p class="text-warning text-sm mt-3">
                    Difference: <span class="citus-inline-code">@FormatAmount(Math.Abs(_totalDebit - _totalCredit))</span>. Posting requires debit and credit totals to match.
                </p>
            }
        </section>
    </div>

    <div class="lg:col-span-4 flex flex-col gap-6">
        <section class="citus-panel">
            <h2 class="citus-panel__title">Posting summary</h2>
            <table class="citus-keyvalue">
                <tbody>
                    <tr><th>Company</th><td>@ShellState.ActiveCompany.CompanyCode</td></tr>
                    <tr><th>Base currency</th><td>@ShellState.ActiveCompany.BaseCurrencyCode</td></tr>
                    <tr><th>Transaction currency</th><td>@(_currency.ToUpperInvariant())</td></tr>
                    <tr><th>Lines</th><td>@_lines.Count</td></tr>
                    <tr><th>Debit total</th><td>@FormatAmount(_totalDebit)</td></tr>
                    <tr><th>Credit total</th><td>@FormatAmount(_totalCredit)</td></tr>
                    <tr><th>Balance</th><td>@(_isBalanced ? "✓" : "△")</td></tr>
                </tbody>
            </table>
        </section>

        <section class="citus-panel">
            <h2 class="citus-panel__title">Post</h2>
            <p class="text-fg-muted text-sm mb-3">
                Posting is irreversible from this surface. Backend reserves the journal entry number and the FX snapshot at the moment of the call.
            </p>

            <div class="flex flex-col gap-2">
                <CitusButton Variant="CitusButtonVariant.Primary"
                             Block="true"
                             Disabled="@(!_isBalanced || _lines.Count == 0 || ShellState.AreWritesBlocked || _isSubmitting)"
                             OnClick="PostAsync">
                    @(_isSubmitting ? "Posting..." : "Post journal entry")
                </CitusButton>
                <CitusButton Block="true" Disabled="_isSubmitting" OnClick="ResetAsync">Reset draft</CitusButton>
            </div>
        </section>
    </div>
</div>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Core",
        Title = "New journal entry",
        Subtitle = "Create the manual journal posting that flows through the backend Posting Engine. Debit and credit totals must match before submit unlocks."
    };

    private DateTime? _date = DateTime.Today;
    private string _description = string.Empty;
    private string _currency = string.Empty;
    private decimal? _exchangeRate;
    private readonly List<ManualJournalLineDraft> _lines = new()
    {
        new ManualJournalLineDraft(),
        new ManualJournalLineDraft()
    };
    private bool _isSubmitting;
    private string? _validationMessage;
    private WriteFlowResult? _lastResult;

    private decimal _totalDebit => _lines.Sum(l => l.Debit);
    private decimal _totalCredit => _lines.Sum(l => l.Credit);
    private bool _isBalanced => _lines.Count > 0 && _totalDebit == _totalCredit && _totalDebit > 0;

    protected override void OnInitialized()
    {
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;
    }

    private void AddLine()
    {
        _lines.Add(new ManualJournalLineDraft());
    }

    private void RemoveLine(int index)
    {
        if (index >= 0 && index < _lines.Count)
        {
            _lines.RemoveAt(index);
        }
    }

    private void UpdateLine(int index, Func<ManualJournalLineDraft, ManualJournalLineDraft> mutate)
    {
        if (index < 0 || index >= _lines.Count) return;
        _lines[index] = mutate(_lines[index]);
    }

    private async Task PostAsync()
    {
        _validationMessage = null;
        _lastResult = null;

        if (string.IsNullOrWhiteSpace(_description))
        {
            _validationMessage = "Description is required.";
            return;
        }
        if (_lines.Count == 0)
        {
            _validationMessage = "Add at least one journal line.";
            return;
        }
        if (_lines.Any(l => string.IsNullOrWhiteSpace(l.AccountCode)))
        {
            _validationMessage = "Every line needs an account code.";
            return;
        }
        if (_lines.Any(l => l.Debit > 0 && l.Credit > 0))
        {
            _validationMessage = "Each line records either a debit or a credit, not both.";
            return;
        }
        if (!_isBalanced)
        {
            _validationMessage = "Debit and credit totals must match before posting.";
            return;
        }

        _isSubmitting = true;
        try
        {
            var draft = new ManualJournalDraft
            {
                Date = DateOnly.FromDateTime((_date ?? DateTime.Today).Date),
                Description = _description.Trim(),
                TransactionCurrencyCode = _currency.Trim().ToUpperInvariant(),
                ExchangeRate = _exchangeRate,
                Lines = _lines.Select(l => l with { AccountCode = l.AccountCode.Trim() }).ToArray()
            };

            _lastResult = await WriteFlow.PostManualJournalAsync(draft);
            if (_lastResult.Succeeded)
            {
                await Message.SuccessAsync("Journal entry posted.");
                NavigationManager.NavigateTo("journal-entry");
            }
            else
            {
                await Message.InfoAsync(_lastResult.Message);
            }
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private Task ResetAsync()
    {
        _lines.Clear();
        _lines.Add(new ManualJournalLineDraft());
        _lines.Add(new ManualJournalLineDraft());
        _description = string.Empty;
        _date = DateTime.Today;
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;
        _exchangeRate = null;
        _validationMessage = null;
        _lastResult = null;
        return Task.CompletedTask;
    }

    private static string FormatAmount(decimal amount) => amount.ToString("N2");
}
