@page "/journal-entry/review/{JournalEntryId:guid}"

@inject BusinessShellState ShellState
@inject JournalEntryReviewClient JournalEntryReviewClient
@inject NavigationManager NavigationManager
@inject CitusToastService Message

<PageTitle>@($"{_header.Title} | Tralanz Books")</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <a class="citus-button citus-button--ghost" href="journal-entry">
            <CitusIcon Name="IconName.ArrowLeft" Size="IconSize.Inline" />
            <span>Back to journal entries</span>
        </a>
        <CitusBadge Color="@("blue")">Read-only review</CitusBadge>
    </Actions>
</CitusPageHeader>

@if (_isLoading)
{
    <div class="mb-4"><CitusLoadingBar /></div>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_error" ShowIcon="true" Class="mb-4" />
}

@if (_review is not null)
{
    @if (_review.Status is "voided" or "reversed")
    {
        <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@GetLifecycleAlert(_review)" ShowIcon="true" Class="mb-4" />
    }

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <CitusStatCard
            Label="Journal entry"
            Value="@_review.DisplayNumber"
            Description="@($"{_review.SourceTypeLabel} | status {_review.Status}")"
            Icon="IconName.FileText"
            Tone="StatTone.Primary" />
        <CitusStatCard
            Label="Posted at"
            Value="@(_review.PostedAt?.ToString("yyyy-MM-dd") ?? "Pending")"
            Description="@(_review.PostedAt?.ToString("HH:mm 'UTC'") ?? "posted_at unavailable")"
            Icon="IconName.Clock"
            Tone="StatTone.Info" />
        @* Header total stays anchored on the *transaction-currency* truth (what the user
           typed). Base-currency total + FX rate hang off the description so reconciliation
           is one glance away without burying the user's mental model. Single-currency
           companies see only the transaction line; the base parenthetical is omitted. *@
        <CitusStatCard
            Label="Total"
            Value="@($"{FormatAmount(_review.TotalTxDebit)} {_review.TransactionCurrencyCode}")"
            Description="@BuildHeaderTotalDescription(_review)"
            Icon="IconName.BuildingBank"
            Tone="@(_review.TotalTxDebit == _review.TotalTxCredit ? StatTone.Success : StatTone.Danger)" />
        <CitusStatCard
            Label="FX snapshot"
            Value="@_review.ExchangeRate.ToString("0.######")"
            Description="@($"{_review.ExchangeRateSource} on {_review.ExchangeRateDate:yyyy-MM-dd}")"
            Icon="IconName.Coin"
            Tone="StatTone.Neutral" />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-7 flex flex-col gap-6">
            <section class="citus-panel">
                <h2 class="citus-panel__title">Journal facts</h2>
                <table class="citus-keyvalue">
                    <tbody>
                        @foreach (var fact in _factRows)
                        {
                            <tr><th>@fact.Label</th><td>@fact.Value</td></tr>
                        }
                    </tbody>
                </table>
            </section>

            <section class="citus-panel">
                <header class="citus-panel__header">
                    <h2 class="citus-panel__title">Journal lines</h2>
                    <CitusBadge Color="@("default")">@($"{_review.LineCount} lines")</CitusBadge>
                </header>

                <table class="citus-data-table">
                    <thead>
                        <tr>
                            <th>Line</th>
                            <th>Account</th>
                            <th>Description</th>
                            <th class="text-right">Tx debit</th>
                            <th class="text-right">Tx credit</th>
                            <th class="text-right">Debit</th>
                            <th class="text-right">Credit</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in _review.Lines)
                        {
                            <tr>
                                <td>@line.LineNumber</td>
                                <td>
                                    <div><span class="citus-inline-code">@line.AccountCode</span> @line.AccountName</div>
                                    <div class="text-fg-subtle text-xs">@line.RootType | @line.DetailType</div>
                                </td>
                                <td>
                                    <div>@DisplayDescription(line.Description)</div>
                                    @if (!string.IsNullOrWhiteSpace(line.ControlRole) || !string.IsNullOrWhiteSpace(line.TaxComponentType) || line.PartyId is not null)
                                    {
                                        <div class="text-fg-subtle text-xs">@DisplayLineMarkers(line)</div>
                                    }
                                </td>
                                <td class="text-right">@FormatAmount(line.TxDebit)</td>
                                <td class="text-right">@FormatAmount(line.TxCredit)</td>
                                <td class="text-right">@FormatAmount(line.Debit)</td>
                                <td class="text-right">@FormatAmount(line.Credit)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        </div>

        <div class="lg:col-span-5 flex flex-col gap-6">
            <section class="citus-panel">
                <h2 class="citus-panel__title">Source linkage</h2>
                <table class="citus-keyvalue">
                    <tbody>
                        @foreach (var fact in _sourceRows)
                        {
                            <tr><th>@fact.Label</th><td>@fact.Value</td></tr>
                        }
                    </tbody>
                </table>

                @if (_sourceDocumentHref is not null)
                {
                    <a class="citus-button citus-button--ghost mt-4" href="@_sourceDocumentHref">
                        <CitusIcon Name="IconName.Eye" Size="IconSize.Inline" />
                        <span>Open source document review</span>
                    </a>
                }
            </section>

            <section class="citus-panel">
                <h2 class="citus-panel__title">Why this page exists</h2>
                <ul class="citus-bullet-list">
                    <li>Edits happen via compensating entries, not by mutating posted journal rows — the audit trail stays whole.</li>
                    <li>FX snapshot data stays visible on the same page as line truth.</li>
                    <li>Source linkage stays explicit so business truth and accounting truth do not drift apart.</li>
                </ul>
            </section>
        </div>
    </div>

    @* Lifecycle actions. Posted entries can be voided (compensating entry
       is auto-generated, original marked as voided) or "edited" — which is
       just a void followed by re-entering on the create form. Buttons hide
       once the entry is already voided / reversed. *@
    @if (string.Equals(_review.Status, "posted", StringComparison.OrdinalIgnoreCase)
         && string.Equals(_review.SourceType, "manual_journal", StringComparison.OrdinalIgnoreCase))
    {
        <section class="citus-panel mt-6">
            <header class="citus-panel__header">
                <h2 class="citus-panel__title">Lifecycle actions</h2>
                <span class="text-fg-muted text-sm">
                    Both options preserve the posted row by inserting a compensating entry —
                    they never delete journal lines.
                </span>
            </header>

            @if (!string.IsNullOrWhiteSpace(_lifecycleError))
            {
                <CitusAlert Severity="CitusAlertSeverity.Error"
                            Message="@_lifecycleError"
                            ShowIcon="true"
                            Class="mb-3" />
            }

            @if (_pendingAction is "void")
            {
                <CitusAlert Severity="CitusAlertSeverity.Warning"
                            ShowIcon="true"
                            Class="mb-3">
                    <MessageTemplate>
                        <strong>Void this journal entry?</strong>
                        <div class="text-fg-muted text-sm mt-1">
                            A compensating reverse-side entry will be posted and
                            <span class="citus-inline-code">@_review.DisplayNumber</span>
                            will be marked as voided. This cannot be undone from the UI.
                        </div>
                    </MessageTemplate>
                </CitusAlert>
                <div class="flex items-center justify-end gap-3">
                    <CitusButton Variant="CitusButtonVariant.Primary"
                                 Danger="true"
                                 Disabled="@_isMutating"
                                 OnClick="ConfirmVoidAsync">
                        @(_isMutating ? "Voiding…" : "Confirm void")
                    </CitusButton>
                    <CitusButton Variant="CitusButtonVariant.Ghost"
                                 Disabled="@_isMutating"
                                 OnClick="CancelPending">
                        Cancel
                    </CitusButton>
                </div>
            }
            else if (_pendingAction is "edit")
            {
                <CitusAlert Severity="CitusAlertSeverity.Info"
                            ShowIcon="true"
                            Class="mb-3">
                    <MessageTemplate>
                        <strong>Edit by re-entering?</strong>
                        <div class="text-fg-muted text-sm mt-1">
                            Posted journal rows aren't modified in place. The current entry
                            will be voided (a compensating entry is auto-posted) and you'll
                            be sent to a fresh New Journal Entry form to re-enter the
                            corrected version. The original stays in the audit trail.
                        </div>
                    </MessageTemplate>
                </CitusAlert>
                <div class="flex items-center justify-end gap-3">
                    <CitusButton Variant="CitusButtonVariant.Primary"
                                 Disabled="@_isMutating"
                                 OnClick="ConfirmEditAsync">
                        @(_isMutating ? "Voiding…" : "Void and start a new entry")
                    </CitusButton>
                    <CitusButton Variant="CitusButtonVariant.Ghost"
                                 Disabled="@_isMutating"
                                 OnClick="CancelPending">
                        Cancel
                    </CitusButton>
                </div>
            }
            else
            {
                <div class="flex items-center justify-end gap-3">
                    @* Copy A3 Phase 2: secondary actions (just Copy
                       today, room for Print / Audit history later).
                       Void + Edit stay as primary buttons because
                       they have an inline confirm flow that's
                       awkward to surface from a menu item. *@
                    <CitusMoreMenu Items="@_moreItems" />
                    <CitusButton Variant="CitusButtonVariant.Primary"
                                 Danger="true"
                                 LeadingIcon="IconName.X"
                                 OnClick="@(() => RequestPending("void"))">
                        Void
                    </CitusButton>
                    <CitusButton Variant="CitusButtonVariant.Ghost"
                                 LeadingIcon="IconName.Pencil"
                                 OnClick="@(() => RequestPending("edit"))">
                        Edit
                    </CitusButton>
                </div>
            }
        </section>
    }
    else if (string.Equals(_review.Status, "posted", StringComparison.OrdinalIgnoreCase))
    {
        @* Source-document JE (bill, invoice, …): no Void/Edit here. Voiding
           the JE alone would leave the source document behind, so the
           lifecycle is driven from the source instead. *@
        <section class="citus-panel mt-6">
            <header class="citus-panel__header">
                <h2 class="citus-panel__title">Lifecycle actions</h2>
            </header>
            <p class="text-fg-muted text-sm m-0">
                Posted from a @_review.SourceTypeLabel. To void or reverse it, use the source
                document — that keeps the @_review.SourceTypeLabel and its journal entry in sync;
                voiding the journal entry on its own would leave the @_review.SourceTypeLabel behind.
                @if (_sourceDocumentHref is not null)
                {
                    <a class="citus-link" href="@_sourceDocumentHref"> Open the source document.</a>
                }
            </p>
        </section>
    }
}

@code {
    [Parameter]
    public Guid JournalEntryId { get; set; }

    private PageHeaderModel _header = new()
    {
        Eyebrow = "Accounting",
        Title = "Journal Entry review",
        Subtitle = "Journal detail stays read-only, source-linked, and explicit about FX and line truth."
    };

    private JournalEntryReviewSummary? _review;
    private bool _isLoading;
    private string? _error;
    private string? _sourceDocumentHref;
    private IReadOnlyList<FactRow> _factRows = Array.Empty<FactRow>();
    private IReadOnlyList<FactRow> _sourceRows = Array.Empty<FactRow>();

    /// <summary>
    /// "void" or "edit" while the user is staring at the inline confirm
    /// banner; null when no lifecycle action is in flight. Drives which
    /// affordance the page renders below the line table.
    /// </summary>
    private string? _pendingAction;
    private bool _isMutating;
    private string? _lifecycleError;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _error = null;
        _review = null;
        _sourceDocumentHref = null;
        _factRows = Array.Empty<FactRow>();
        _sourceRows = Array.Empty<FactRow>();

        var review = await JournalEntryReviewClient.GetAsync(ShellState.ActiveCompany.Id, JournalEntryId);

        if (review is null)
        {
            _header = new PageHeaderModel
            {
                Eyebrow = "Accounting",
                Title = "Journal Entry review",
                Subtitle = "The requested journal entry was not found in the active company context."
            };
            _error = $"Journal entry {JournalEntryId:D} could not be found for company {ShellState.ActiveCompany.CompanyName}.";
            _isLoading = false;
            return;
        }

        _review = review;
        _header = new PageHeaderModel
        {
            Eyebrow = "Accounting",
            Title = review.DisplayNumber,
            Subtitle = $"{review.SourceTypeLabel} posting review stays read-only and preserves backend-owned journal truth."
        };
        _factRows =
        [
            new("Entity number", review.EntityNumber),
            new("Status", review.Status),
            new("Transaction currency", review.TransactionCurrencyCode),
            new("Base currency", review.BaseCurrencyCode),
            new("FX rate snapshot", review.FxRateSnapshotId?.ToString("D") ?? "No snapshot id"),
            new("Voided at", review.VoidedAt?.ToString("yyyy-MM-dd HH:mm 'UTC'") ?? "Not voided"),
            new("Reversed at", review.ReversedAt?.ToString("yyyy-MM-dd HH:mm 'UTC'") ?? "Not reversed"),
            new("Created by", review.CreatedByUserId.ToString())
        ];
        _sourceRows =
        [
            new("Source type", review.SourceTypeLabel),
            new("Source id", review.SourceId.ToString("D")),
            new("Posted at", review.PostedAt?.ToString("yyyy-MM-dd HH:mm 'UTC'") ?? "Unavailable"),
            new("Company", $"{ShellState.ActiveCompany.CompanyName} ({ShellState.ActiveCompany.CompanyCode})")
        ];

        if (AccountingDocumentReviewRouteCatalog.TryBuildReviewHref(review.SourceType, review.SourceId, out var href))
        {
            _sourceDocumentHref = href;
        }

        _isLoading = false;
    }

    private static string FormatAmount(decimal amount) => amount.ToString("N2");

    private static string BuildHeaderTotalDescription(JournalEntryReviewSummary review)
    {
        var creditPart = $"Credit {FormatAmount(review.TotalTxCredit)} {review.TransactionCurrencyCode}";
        var multiCurrency = !string.Equals(
            review.TransactionCurrencyCode,
            review.BaseCurrencyCode,
            StringComparison.OrdinalIgnoreCase);
        if (!multiCurrency)
        {
            return creditPart;
        }
        var basePart = $"= {FormatAmount(review.TotalDebit)} {review.BaseCurrencyCode} @ {review.ExchangeRate.ToString("0.######")}";
        return $"{creditPart} · {basePart}";
    }

    private static string DisplayDescription(string description) =>
        string.IsNullOrWhiteSpace(description) ? "No description" : description;

    private void RequestPending(string action)
    {
        _pendingAction = action;
        _lifecycleError = null;
    }

    private void CancelPending()
    {
        _pendingAction = null;
        _lifecycleError = null;
    }

    private async Task ConfirmVoidAsync()
    {
        if (_review is null) return;
        await ExecuteVoidAsync(navigateToCreate: false);
    }

    private async Task ConfirmEditAsync()
    {
        if (_review is null) return;
        await ExecuteVoidAsync(navigateToCreate: true);
    }

    private async Task ExecuteVoidAsync(bool navigateToCreate)
    {
        if (_review is null || _isMutating)
        {
            return;
        }

        _isMutating = true;
        _lifecycleError = null;

        try
        {
            var outcome = await JournalEntryReviewClient.VoidAsync(JournalEntryId);
            if (!outcome.Succeeded)
            {
                _lifecycleError = outcome.Message;
                return;
            }

            await Message.SuccessAsync(outcome.Message);

            if (navigateToCreate)
            {
                // Pass the just-voided JE id along so the create form can
                // fetch its lines and pre-fill — saves the operator from
                // retyping a multi-row entry just to fix a single amount.
                NavigationManager.NavigateTo($"journal-entry/new?from={JournalEntryId:D}");
            }
            else
            {
                NavigationManager.NavigateTo("journal-entry");
            }
        }
        finally
        {
            _isMutating = false;
        }
    }

    private static string GetLifecycleAlert(JournalEntryReviewSummary review) =>
        review.Status switch
        {
            "voided" => $"This journal entry is voided. Voided at {review.VoidedAt?.ToString("yyyy-MM-dd HH:mm 'UTC'") ?? "an unavailable time"}.",
            "reversed" => $"This journal entry is reversed. Reversed at {review.ReversedAt?.ToString("yyyy-MM-dd HH:mm 'UTC'") ?? "an unavailable time"}.",
            _ => string.Empty
        };

    // Copy A3 Phase 2: navigate to /journal-entry/new with ?copyFrom=
    // (distinct from the existing ?from= which is reserved for the
    // edit-after-void flow). The new JE is fully independent of the
    // source — no lineage, no reverse-link.
    private void CopyAsync()
    {
        if (_review is null) return;
        NavigationManager.NavigateTo($"journal-entry/new?copyFrom={_review.Id:D}");
    }

    private IReadOnlyList<CitusMoreMenuItem> _moreItems => _review is null
        ? Array.Empty<CitusMoreMenuItem>()
        : new[]
        {
            new CitusMoreMenuItem
            {
                Label = "Copy",
                OnClick = EventCallback.Factory.Create(this, CopyAsync)
            }
        };

    private static string DisplayLineMarkers(JournalEntryReviewLineSummary line)
    {
        var parts = new List<string>();

        if (!string.IsNullOrWhiteSpace(line.ControlRole))
        {
            parts.Add($"control: {line.ControlRole}");
        }

        if (!string.IsNullOrWhiteSpace(line.TaxComponentType))
        {
            parts.Add($"tax: {line.TaxComponentType}");
        }

        if (line.PartyId is not null)
        {
            parts.Add($"party: {line.PartyId.Value:D}");
        }

        return string.Join(" | ", parts);
    }

    private sealed record class FactRow(string Label, string Value);
}
