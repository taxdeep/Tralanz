@page "/journal-entry"

@inject BusinessShellState ShellState
@inject AccountingHealthClient AccountingHealthClient
@inject JournalEntryReviewClient JournalEntryReviewClient

<PageTitle>Journal Entry | Citus Business</PageTitle>

<CitusPageHeader Model="_header" />

<MudGrid Class="mb-6">
    <MudItem xs="12" md="6" lg="3">
        <CitusStatCard
            Label="Company"
            Value="@ShellState.ActiveCompany.CompanyCode"
            Description="The journal workspace is always scoped to the active company."
            Icon="IconName.BuildingSkyscraper"
            Tone="StatTone.Primary" />
    </MudItem>
    <MudItem xs="12" md="6" lg="3">
        <CitusStatCard
            Label="Recent entries"
            Value="@_recentEntries.Count.ToString()"
            Description="Read-only journal review now opens from live PostgreSQL journal entry truth."
            Icon="IconName.FileText"
            Tone="StatTone.Info" />
    </MudItem>
    <MudItem xs="12" md="6" lg="3">
        <CitusStatCard
            Label="Latest posted"
            Value="@(_recentEntries.FirstOrDefault()?.DisplayNumber ?? "Unavailable")"
            Description="@(_recentEntries.FirstOrDefault()?.PostedAt?.ToString("yyyy-MM-dd HH:mm 'UTC'") ?? "No posted journal entries found yet.")"
            Icon="IconName.Clock"
            Tone="StatTone.Success" />
    </MudItem>
    <MudItem xs="12" md="6" lg="3">
        <CitusStatCard
            Label="Accounting API"
            Value="@(_health?.Status ?? "Unavailable")"
            Description="Recent list and detail pages are now backed by journal_entries and journal_entry_lines."
            Icon="IconName.Activity"
            Tone="StatTone.Neutral" />
    </MudItem>
</MudGrid>

<MudGrid>
    <MudItem xs="12" lg="7">
        <MudPaper Class="pa-4 mb-6">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                <MudText Typo="Typo.h6">Recent journal reviews</MudText>
                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">Read-only</MudChip>
            </MudStack>

            @if (_isLoading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mb-4" />
            }

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
                    @_error
                </MudAlert>
            }

            @if (_recentEntries.Count == 0 && string.IsNullOrWhiteSpace(_error) && !_isLoading)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    No journal entries were found yet for the active company.
                </MudAlert>
            }
            else if (_recentEntries.Count > 0)
            {
                <MudTable Items="_recentEntries" Dense="true" Hover="true" Striped="true">
                    <HeaderContent>
                        <MudTh>Journal entry</MudTh>
                        <MudTh>Source</MudTh>
                        <MudTh>Posted at</MudTh>
                        <MudTh>Debit</MudTh>
                        <MudTh>Credit</MudTh>
                        <MudTh>Lines</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Journal entry">
                            <MudStack Spacing="0">
                                <MudLink Href="@($"journal-entry/review/{context.Id:D}")" Typo="Typo.body2" Underline="Underline.Always">
                                    @context.DisplayNumber
                                </MudLink>
                                <MudText Typo="Typo.caption" Class="text-secondary">
                                    <span class="citus-inline-code">@context.EntityNumber</span> | @GetLifecycleSummary(context)
                                </MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Source">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2">@context.SourceTypeLabel</MudText>
                                <MudText Typo="Typo.caption" Class="text-secondary"><span class="citus-inline-code">@context.SourceId</span></MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Posted at">@(context.PostedAt?.ToString("yyyy-MM-dd HH:mm 'UTC'") ?? "Pending")</MudTd>
                        <MudTd DataLabel="Debit">@FormatAmount(context.TotalDebit)</MudTd>
                        <MudTd DataLabel="Credit">@FormatAmount(context.TotalCredit)</MudTd>
                        <MudTd DataLabel="Lines">@context.LineCount</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>

        <MudPaper Class="pa-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                <MudText Typo="Typo.h6">Current backend shape</MudText>
                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">Review + source linkage</MudChip>
            </MudStack>

            <MudTable Items="_endpointRows" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Endpoint</MudTh>
                    <MudTh>Purpose</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Endpoint"><span class="citus-inline-code">@context.Path</span></MudTd>
                    <MudTd DataLabel="Purpose">@context.Purpose</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" lg="5">
        <MudPaper Class="pa-4 mb-6">
            <MudText Typo="Typo.h6" Class="mb-4">Why this surface matters</MudText>
            <MudList T="string" Dense="true">
                <MudListItem>Formal JE stays backend-owned and read-only.</MudListItem>
                <MudListItem>Source linkage remains visible before anyone reviews lines.</MudListItem>
                <MudListItem>Future compose flows should arrive after review feels trustworthy.</MudListItem>
            </MudList>
        </MudPaper>

        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">Session guardrails</MudText>
            <MudTable Items="_guardrailRows" Dense="true">
                <RowTemplate>
                    <MudTd DataLabel="Rule">@context.Rule</MudTd>
                    <MudTd DataLabel="Reason">@context.Reason</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code
{
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Core",
        Title = "Journal Entry workspace",
        Subtitle = "Recent journal entries now open through a controlled, read-only review flow grounded in posted backend truth."
    };

    private readonly IReadOnlyList<EndpointRow> _endpointRows =
    [
        new("/accounting/journal-entries", "List recent company-scoped journal entries for review."),
        new("/accounting/journal-entries/{journalEntryId}", "Read a full journal entry header, FX snapshot, and line set."),
        new("/accounting/journal-entries/by-source/{sourceType}/{sourceId}", "Resolve the posted journal entry linked to a source document.")
    ];

    private readonly IReadOnlyList<GuardrailRow> _guardrailRows =
    [
        new("Active company required", "Every journal review request resolves inside the current company context."),
        new("Read-only first", "Review pages do not mutate journal truth or bypass posting rules."),
        new("Source linkage visible", "Journal entry review keeps the originating source document explicit.")
    ];

    private ServiceHealthStatus? _health;
    private IReadOnlyList<JournalEntryReviewListItemSummary> _recentEntries = Array.Empty<JournalEntryReviewListItemSummary>();
    private bool _isLoading;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        _health = await AccountingHealthClient.GetHealthAsync();
        _recentEntries = await JournalEntryReviewClient.GetRecentAsync(ShellState.ActiveCompany.Id, 12);

        if (_recentEntries.Count == 0)
        {
            _error = _health?.Status == "ok"
                ? null
                : "Journal review is unavailable until Accounting API responds and journal entry truth is available.";
        }

        _isLoading = false;
    }

    private static string FormatAmount(decimal amount) => amount.ToString("N2");

    private static string GetLifecycleSummary(JournalEntryReviewListItemSummary item) =>
        item.Status switch
        {
            "voided" => $"voided at {item.VoidedAt?.ToString("yyyy-MM-dd") ?? "unknown"}",
            "reversed" => $"reversed at {item.ReversedAt?.ToString("yyyy-MM-dd") ?? "unknown"}",
            _ => $"status {item.Status}"
        };

    private sealed record class EndpointRow(string Path, string Purpose);

    private sealed record class GuardrailRow(string Rule, string Reason);
}
