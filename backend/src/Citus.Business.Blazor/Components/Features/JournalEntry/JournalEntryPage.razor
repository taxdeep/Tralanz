@page "/journal-entry"

@using Citus.Ui.Shared.Journal
@using Radzen
@using Radzen.Blazor

@inject BusinessShellState ShellState
@inject AccountingHealthClient AccountingHealthClient
@inject JournalEntryReviewClient JournalEntryReviewClient

<PageTitle>Journal Entry | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusLinkButton Href="journal-entry/new" LeadingIcon="IconName.Plus">New journal entry</CitusLinkButton>
    </Actions>
</CitusPageHeader>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <CitusStatCard
        Label="Company"
        Value="@ShellState.ActiveCompany.CompanyName"
        Description="The journal workspace is always scoped to the active company."
        Icon="IconName.BuildingSkyscraper"
        Tone="StatTone.Primary" />
    <CitusStatCard
        Label="Recent entries"
        Value="@_recentEntries.Count.ToString()"
        Description="Read-only journal review now opens from live PostgreSQL journal entry truth."
        Icon="IconName.FileText"
        Tone="StatTone.Info" />
    <CitusStatCard
        Label="Latest posted"
        Value="@(_recentEntries.FirstOrDefault()?.DisplayNumber ?? "Unavailable")"
        Description="@(_recentEntries.FirstOrDefault()?.PostedAt?.ToString("yyyy-MM-dd HH:mm 'UTC'") ?? "No posted journal entries found yet.")"
        Icon="IconName.Clock"
        Tone="StatTone.Success" />
    <CitusStatCard
        Label="Accounting API"
        Value="@(_health?.Status ?? "Unavailable")"
        Description="Recent list and detail pages are now backed by journal_entries and journal_entry_lines."
        Icon="IconName.Activity"
        Tone="StatTone.Neutral" />
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <div class="lg:col-span-7 flex flex-col gap-6">
        <CitusFormSection Title="Recent journal reviews">
            <HeaderActions>
                <CitusBadge Color="@("blue")">Read-only</CitusBadge>
            </HeaderActions>
            <ChildContent>
            @if (_isLoading)
            {
                <div class="mb-3"><CitusLoadingBar /></div>
            }

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_error" ShowIcon="true" Class="mb-3" />
            }

            @if (_recentEntries.Count == 0 && string.IsNullOrWhiteSpace(_error) && !_isLoading)
            {
                <CitusAlert Severity="CitusAlertSeverity.Info" Message="No journal entries were found yet for the active company." ShowIcon="true" />
            }
            else if (_recentEntries.Count > 0)
            {
                <CitusDataGrid TItem="JournalEntryReviewListItemSummary" Data="@_recentEntries" AllowFiltering="false" PageSize="25">
                    <Columns>
                        <RadzenDataGridColumn TItem="JournalEntryReviewListItemSummary"
                                              Property="@nameof(JournalEntryReviewListItemSummary.DisplayNumber)"
                                              Title="Journal entry"
                                              Width="200px">
                            <Template Context="item">
                                <a class="citus-link" href="@ResolveSourceHref(item)">@item.DisplayNumber</a>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="JournalEntryReviewListItemSummary"
                                              Property="@nameof(JournalEntryReviewListItemSummary.SourceTypeLabel)"
                                              Title="Source">
                            <Template Context="item">
                                <div>@item.SourceTypeLabel</div>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="JournalEntryReviewListItemSummary"
                                              Property="@nameof(JournalEntryReviewListItemSummary.EntryDate)"
                                              Title="Date"
                                              Width="180px">
                            <Template Context="item">@(item.EntryDate?.ToString("yyyy-MM-dd") ?? "—")</Template>
                        </RadzenDataGridColumn>
                        @* Debit / Credit columns lead with the *transaction-currency* total
                           (what the user typed) labelled with its ISO code; the base-currency
                           equivalent only renders in a muted sub-line when the entry isn't
                           single-currency, so the grid stays compact for the common case. *@
                        <RadzenDataGridColumn TItem="JournalEntryReviewListItemSummary"
                                              Property="@nameof(JournalEntryReviewListItemSummary.TotalTxDebit)"
                                              Title="Debit" TextAlign="TextAlign.Right" Width="160px">
                            <Template Context="item">
                                <div>@FormatAmount(item.TotalTxDebit) <span class="text-fg-subtle">@item.TransactionCurrencyCode</span></div>
                                @if (IsMultiCurrency(item))
                                {
                                    <div class="text-fg-subtle text-xs">@FormatAmount(item.TotalDebit) @item.BaseCurrencyCode</div>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="JournalEntryReviewListItemSummary"
                                              Property="@nameof(JournalEntryReviewListItemSummary.TotalTxCredit)"
                                              Title="Credit" TextAlign="TextAlign.Right" Width="160px">
                            <Template Context="item">
                                <div>@FormatAmount(item.TotalTxCredit) <span class="text-fg-subtle">@item.TransactionCurrencyCode</span></div>
                                @if (IsMultiCurrency(item))
                                {
                                    <div class="text-fg-subtle text-xs">@FormatAmount(item.TotalCredit) @item.BaseCurrencyCode</div>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="JournalEntryReviewListItemSummary"
                                              Property="@nameof(JournalEntryReviewListItemSummary.Status)"
                                              Title="Status" Width="120px">
                            <Template Context="item">
                                <CitusBadge Color="@StatusColor(item.Status)">@StatusLabel(item.Status)</CitusBadge>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </CitusDataGrid>
            }
            </ChildContent>
        </CitusFormSection>

        <CitusFormSection Title="Current backend shape">
            <HeaderActions>
                <CitusBadge Color="@("blue")">Review + source linkage</CitusBadge>
            </HeaderActions>
            <ChildContent>
            <table class="citus-data-table">
                <thead>
                    <tr>
                        <th>Endpoint</th>
                        <th>Purpose</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _endpointRows)
                    {
                        <tr>
                            <td><span class="citus-inline-code">@row.Path</span></td>
                            <td>@row.Purpose</td>
                        </tr>
                    }
                </tbody>
            </table>
            </ChildContent>
        </CitusFormSection>
    </div>

    <div class="lg:col-span-5 flex flex-col gap-6">
        <CitusFormSection Title="Why this surface matters">
            <ul class="citus-bullet-list">
                <li>Formal JE stays backend-owned and read-only.</li>
                <li>Source linkage remains visible before anyone reviews lines.</li>
                <li>Future compose flows should arrive after review feels trustworthy.</li>
            </ul>
        </CitusFormSection>

        <CitusFormSection Title="Session guardrails">
            <table class="citus-keyvalue">
                <tbody>
                    @foreach (var rule in _guardrailRows)
                    {
                        <tr>
                            <th>@rule.Rule</th>
                            <td>@rule.Reason</td>
                        </tr>
                    }
                </tbody>
            </table>
        </CitusFormSection>
    </div>
</div>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Core",
        Title = "Journal Entry workspace",
        Subtitle = "Recent journal entries now open through a controlled, read-only review flow grounded in posted backend truth."
    };

    private readonly IReadOnlyList<EndpointRow> _endpointRows =
    [
        new("/accounting/journal-entries", "List recent company-scoped journal entries for review."),
        new("/accounting/journal-entries/{journalEntryId}", "Read a full journal entry header, FX snapshot, and line set."),
        new("/accounting/journal-entries/by-source/{sourceType}/{sourceId}", "Resolve the posted journal entry linked to a source document.")
    ];

    private readonly IReadOnlyList<GuardrailRow> _guardrailRows =
    [
        new("Active company required", "Every journal review request resolves inside the current company context."),
        new("Read-only first", "Review pages do not mutate journal truth or bypass posting rules."),
        new("Source linkage visible", "Journal entry review keeps the originating source document explicit.")
    ];

    private ServiceHealthStatus? _health;
    private IReadOnlyList<JournalEntryReviewListItemSummary> _recentEntries = Array.Empty<JournalEntryReviewListItemSummary>();
    private bool _isLoading;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        _health = await AccountingHealthClient.GetHealthAsync();
        _recentEntries = await JournalEntryReviewClient.GetRecentAsync(ShellState.ActiveCompany.Id, 12);

        if (_recentEntries.Count == 0)
        {
            _error = _health?.Status == "ok"
                ? null
                : "Journal review is unavailable until Accounting API responds and journal entry truth is available.";
        }

        _isLoading = false;
    }

    private static string FormatAmount(decimal amount) => amount.ToString("N2");

    // A journal-review row opens the SOURCE document, not the raw JE — bill →
    // the bill, invoice → the invoice — so users manage the lifecycle from the
    // business document (and never void a JE while its source lives on). Only a
    // manual journal (where the JE *is* the document) opens the JE review;
    // other source docs use the generic document review, and types without a
    // document surface (e.g. reversals) fall back to the JE review.
    private static string ResolveSourceHref(JournalEntryReviewListItemSummary item)
    {
        var normalized = item.SourceType?.Trim().ToLowerInvariant();
        return normalized switch
        {
            "manual_journal" => $"journal-entry/review/{item.Id:D}",
            "bill" => $"bills/{item.SourceId:D}",
            "invoice" => $"invoices/{item.SourceId:D}",
            _ => AccountingDocumentReviewRouteCatalog.TryBuildReviewHref(normalized, item.SourceId, out var href)
                ? href
                : $"journal-entry/review/{item.Id:D}",
        };
    }

    private static bool IsMultiCurrency(JournalEntryReviewListItemSummary item) =>
        !string.IsNullOrWhiteSpace(item.TransactionCurrencyCode)
        && !string.IsNullOrWhiteSpace(item.BaseCurrencyCode)
        && !string.Equals(item.TransactionCurrencyCode, item.BaseCurrencyCode, StringComparison.OrdinalIgnoreCase);

    private static string StatusColor(string status) =>
        status switch
        {
            "posted" => "green",
            "voided" => "red",
            "reversed" => "orange",
            _ => "default"
        };

    private static string StatusLabel(string status) =>
        string.IsNullOrEmpty(status)
            ? "—"
            : char.ToUpperInvariant(status[0]) + status[1..];

    private sealed record class EndpointRow(string Path, string Purpose);

    private sealed record class GuardrailRow(string Rule, string Reason);
}
