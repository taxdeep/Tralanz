@page "/invoices/new"
@page "/invoices/{InvoiceId:guid}/edit"

@*
    Thin route wrapper. Resolves the route/query params and forwards them to
    InvoiceEditor, which owns all state + business logic. Keeping routing here
    (and state in InvoiceEditor) is the 8-component split's container boundary.
*@

<PageTitle>New Invoice | Tralanz Books</PageTitle>

<InvoiceEditor InvoiceId="@InvoiceId"
               FromSalesOrderId="@FromSalesOrderId"
               FromTaskId="@FromTaskId"
               FromTaskIds="@FromTaskIds"
               CopyFromInvoiceId="@CopyFromInvoiceId"
               ReviseFromInvoiceId="@ReviseFromInvoiceId" />

@code {
    /// <summary>Source-SO id ("Invoice this SO" flow). Forwarded to the editor.</summary>
    [SupplyParameterFromQuery] public Guid? FromSalesOrderId { get; set; }

    /// <summary>Source-task id ("Bill this task" flow). Forwarded to the editor.</summary>
    [SupplyParameterFromQuery] public Guid? FromTaskId { get; set; }

    /// <summary>Comma-separated source-task ids (Tasks "Invoice selected"). Forwarded.</summary>
    [SupplyParameterFromQuery] public string? FromTaskIds { get; set; }

    /// <summary>Copy source invoice id (?copyFrom=). Forwarded to the editor.</summary>
    [SupplyParameterFromQuery(Name = "copyFrom")] public Guid? CopyFromInvoiceId { get; set; }

    /// <summary>Revise source invoice id (?reviseFrom=). Forwarded to the editor.</summary>
    [SupplyParameterFromQuery(Name = "reviseFrom")] public Guid? ReviseFromInvoiceId { get; set; }

    /// <summary>Edit-flow invoice id (/invoices/{id}/edit). Forwarded to the editor.</summary>
    [Parameter] public Guid? InvoiceId { get; set; }
}
