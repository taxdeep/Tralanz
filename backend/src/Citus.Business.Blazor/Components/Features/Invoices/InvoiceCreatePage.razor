@page "/invoices/new"
@page "/invoices/{InvoiceId:guid}/edit"

@using Citus.Modules.UnitySearch.Blazor
@using Citus.Modules.Tasks.Domain.Shared

@inject BusinessShellState ShellState
@inject BusinessWriteFlowClient WriteFlow
@inject InvoiceClient InvoiceClient
@inject CustomerClient CustomerClient
@inject ItemClient ItemClient
@inject AccountClient AccountClient
@inject TaxCodeClient TaxCodeClient
@inject SalesTaxClient SalesTaxClient
@inject SalesOrderClient SalesOrderClient
@inject TaskClient TaskClient
@inject NavigationManager NavigationManager
@inject CitusToastService Message

<PageTitle>@($"{InvoiceTitle} | Tralanz Books")</PageTitle>

<div class="aise-invoice-page">
    <header class="aise-invoice-topbar">
        <div class="aise-invoice-title">
            <a class="aise-invoice-back" href="invoices" title="Back to invoices">
                <CitusIcon Name="IconName.ArrowLeft" Size="IconSize.Inline" />
            </a>
            <div>
                <h1>@InvoiceTitle</h1>
                <span>@ShellState.ActiveCompany.CompanyName</span>
            </div>
        </div>
        <div class="aise-invoice-topbar__actions">
            <a class="citus-button citus-button--ghost" href="receive-payment">
                <CitusIcon Name="IconName.Cash" Size="IconSize.Inline" />
                <span>Receive payment</span>
            </a>
        </div>
    </header>

    @if (ShellState.AreWritesBlocked)
    {
        <CitusAlert Severity="CitusAlertSeverity.Warning" ShowIcon="true" Message="@ShellState.WriteBlockMessage" Class="mb-3" />
    }

    @if (NeedsFxRate)
    {
        <CitusAlert Severity="CitusAlertSeverity.Warning" ShowIcon="true" Class="mb-3">
            <MessageTemplate>
                <strong>Something's not quite right.</strong>
                <div class="text-fg-muted text-sm mt-1">
                    No exchange rate is available for the chosen date. Please enter the exchange rate.
                    <button type="button" class="citus-link-button" @onclick="OpenFxDrawer">Enter</button>
                </div>
            </MessageTemplate>
        </CitusAlert>
    }

    @if (!string.IsNullOrWhiteSpace(_validation))
    {
        <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_validation" ShowIcon="true" Class="mb-3" />
    }

    @if (_lastResult is not null)
    {
        <CitusAlert Severity="CitusAlertSeverity.Info" ShowIcon="true" Class="mb-3">
            <MessageTemplate>
                <strong>@_lastResult.Operation</strong>
                <div class="text-fg-muted text-sm mt-1">@_lastResult.Message</div>
            </MessageTemplate>
        </CitusAlert>
    }

    <div class="aise-invoice-workspace">
        <main class="aise-invoice-sheet">
            <section class="aise-invoice-sheet__header">
                <h2>Invoice</h2>
                <div class="aise-invoice-balance">
                    <span>Balance due</span>
                    <strong>@_currency.ToUpperInvariant() @FormatAmount(_total)</strong>
                </div>
            </section>

            <section class="aise-invoice-band">
                <div class="aise-invoice-customer">
                    <label class="aise-invoice-label">Customer</label>
                    <CustomerPicker CompanyId="@ShellState.ActiveCompany.Id"
                                    UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                    Placeholder="Choose a customer..."
                                    Take="8"
                                    SourceRoute="/invoices/new"
                                    SelectedId="@(_customerId == Guid.Empty ? null : _customerId)"
                                    SelectedDisplayText="@_customerDisplay"
                                    OnCustomerSelected="OnCustomerSelected"
                                    OnCleared="OnCustomerCleared" />
                    <CitusInput TValue="string" Placeholder="Enter customer email" Size="CitusButtonSize.Small" />
                    <button type="button" class="citus-link-button">Cc/Bcc</button>
                </div>

                <div class="aise-invoice-address">
                    <label class="aise-invoice-label">Bill to</label>
                    <textarea class="citus-form-field__input aise-invoice-textarea">@CustomerAddressText</textarea>
                    <button type="button" class="citus-link-button">Edit Customer</button>
                </div>

                <div class="aise-invoice-address">
                    <label class="aise-invoice-label">Ship to</label>
                    <textarea class="citus-form-field__input aise-invoice-textarea">@CustomerAddressText</textarea>
                </div>

                <div class="aise-invoice-shipping">
                    <label>Ship via</label>
                    <CitusInput TValue="string" Size="CitusButtonSize.Small" />
                    <label>Shipping date</label>
                    <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" Class="citus-control-full" />
                    <label>Tracking no.</label>
                    <CitusInput TValue="string" Size="CitusButtonSize.Small" />
                </div>

                <div class="aise-invoice-meta">
                    <label>Invoice no.</label>
                    <div class="citus-form-field__input citus-form-field__input--readonly">Reserved at posting</div>
                    <label>Terms</label>
                    <select class="citus-form-field__input">
                        <option>Due on receipt</option>
                        <option>Net 15</option>
                        <option>Net 30</option>
                    </select>
                    <label>Invoice date</label>
                    <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_documentDate" Class="citus-control-full" />
                    <label>Due date</label>
                    <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_dueDate" Class="citus-control-full" />
                </div>
            </section>

            <section class="aise-invoice-options">
                <label class="aise-invoice-label">Tags (hidden)</label>
                <CitusInput TValue="string" Placeholder="Start typing to add a tag" Size="CitusButtonSize.Small" />
                <label class="aise-invoice-label">Invoice amounts are (hidden)</label>
                <select class="citus-form-field__input aise-invoice-tax-mode">
                    <option>Exclusive of Tax</option>
                </select>
            </section>

            <section class="aise-invoice-lines">
                <header>
                    <h3>Product or service</h3>
                    <CitusButton LeadingIcon="IconName.Plus" Size="CitusButtonSize.Small" OnClick="AddLine">Add line</CitusButton>
                </header>

                <div class="aise-invoice-table-wrap">
                    <table class="citus-data-table aise-invoice-table">
                        <thead>
                            <tr>
                                <th style="width: 2.25rem">#</th>
                                <th style="width: 16rem">Product/service</th>
                                <th>Description</th>
                                <th class="text-right" style="width: 6rem">Qty</th>
                                <th class="text-right" style="width: 9rem">Rate</th>
                                <th class="text-right" style="width: 9rem">Amount</th>
                                <th style="width: 7rem">Sales tax</th>
                                <th style="width: 3rem"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var index = 0; index < _lines.Count; index++)
                            {
                                var i = index;
                                var line = _lines[i];
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td>
                                        <ItemServicePicker CompanyId="@ShellState.ActiveCompany.Id"
                                                           UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                                           Placeholder="Search items..."
                                                           Take="6"
                                                           SourceRoute="/invoices/new"
                                                           SelectedId="@(line.ItemId == Guid.Empty ? null : line.ItemId)"
                                                           SelectedDisplayText="@line.ItemDisplay"
                                                           OnItemSelected="@(option => OnItemPicked(i, option))"
                                                           OnCleared="@(() => OnItemCleared(i))" />
                                        @if (line.ItemId != Guid.Empty && string.IsNullOrWhiteSpace(line.AccountDisplay))
                                        {
                                            <div class="text-error text-xs mt-1">Item has no sales/revenue account.</div>
                                        }
                                    </td>
                                    <td><CitusInput TValue="string" Value="@line.Description" ValueChanged="@(v => Update(i, l => l with { Description = v ?? string.Empty }))" Size="CitusButtonSize.Small" Placeholder="Free-form description" /></td>
                                    <td><RadzenNumeric TValue="decimal" Value="@line.Quantity" ValueChanged="@(async v => await UpdateAndRefreshTaxAsync(i, l => l with { Quantity = v }))" Min="0" Class="citus-control-full" /></td>
                                    <td><RadzenNumeric TValue="decimal" Value="@line.UnitPrice" ValueChanged="@(async v => await UpdateAndRefreshTaxAsync(i, l => l with { UnitPrice = v }))" Min="0" Class="citus-control-full" /></td>
                                    <td class="text-right">@FormatAmount(line.Quantity * line.UnitPrice)</td>
                                    <td>
                                        <TaxCodePicker SelectedId="@line.TaxCodeId"
                                                       SelectedDisplayText="@line.TaxCode"
                                                       AppliesTo="sales"
                                                       Placeholder="Tax"
                                                       OnTaxCodeSelected="@(tax => OnTaxCodeSelected(i, tax))"
                                                       OnCleared="@(() => OnTaxCodeCleared(i))" />
                                    </td>
                                    <td>
                                        <button type="button" class="citus-icon-button" title="Remove line" @onclick="() => RemoveLine(i)">
                                            <CitusIcon Name="IconName.Trash" Size="IconSize.Inline" />
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="aise-invoice-line-actions">
                    <CitusButton Variant="CitusButtonVariant.Ghost" Size="CitusButtonSize.Small" OnClick="AddLine">Add product or service</CitusButton>
                    <CitusButton Variant="CitusButtonVariant.Ghost" Size="CitusButtonSize.Small" OnClick="ClearLines">Clear all lines</CitusButton>
                </div>
            </section>

            <section class="aise-invoice-lower">
                <div class="aise-invoice-notes">
                    <label class="aise-invoice-label">Message on invoice</label>
                    <textarea class="citus-form-field__input aise-invoice-textarea" placeholder="Thank you for your business."></textarea>
                    <label class="aise-invoice-label">Memo on statement</label>
                    <CitusInput TValue="string" @bind-Value="_memo" Placeholder="This memo will not show up on your invoice." Size="CitusButtonSize.Small" />
                    <label class="aise-invoice-label">Attachments</label>
                    <div class="aise-invoice-attachment">Add attachment<br /><span>Max file size 20 MB</span></div>
                </div>
                <div class="aise-invoice-totals">
                    <div><span>Subtotal</span><strong>@_currency.ToUpperInvariant() @FormatAmount(_subtotal)</strong></div>
                    <div><span>Discount</span><strong>@_currency.ToUpperInvariant() 0.00</strong></div>
                    <div><span>Shipping</span><strong>@_currency.ToUpperInvariant() 0.00</strong></div>
                    <div><span>Tax</span><strong>@_currency.ToUpperInvariant() @FormatAmount(_taxTotal)</strong></div>
                    <div class="aise-invoice-totals__grand"><span>Invoice total</span><strong>@_currency.ToUpperInvariant() @FormatAmount(_total)</strong></div>
                    @if (!string.Equals(_currency, ShellState.ActiveCompany.BaseCurrencyCode, StringComparison.OrdinalIgnoreCase))
                    {
                        <button type="button" class="citus-link-button" @onclick="OpenFxDrawer">
                            Edit exchange rate
                        </button>
                    }
                </div>
            </section>
        </main>

        <aside class="aise-invoice-rail">
            <header>
                <strong>Invoice</strong>
                <span>@InvoiceSourceLabel</span>
            </header>
            <section>
                <label>Status</label>
                <select class="citus-form-field__input">
                    <option>Open</option>
                </select>
            </section>
            <section>
                <label>Payment options</label>
                <div class="aise-invoice-payment-icons">
                    <span>Visa</span><span>MC</span><span>ACH</span>
                </div>
            </section>
            <section>
                <label>Exchange rate</label>
                <button type="button" class="citus-link-button" @onclick="OpenFxDrawer">
                    @FxSummary
                </button>
            </section>
            <section>
                <label>Design</label>
                <div class="text-fg-muted text-sm">Default invoice template</div>
            </section>
        </aside>
    </div>

    <AisePageActionBar>
        <LeftContent>
            <CitusButton Variant="CitusButtonVariant.Ghost" OnClick="@(() => NavigationManager.NavigateTo("invoices"))">Cancel</CitusButton>
            <CitusButton Variant="CitusButtonVariant.Ghost" OnClick="ClearLines">Clear lines</CitusButton>
        </LeftContent>
        <CenterContent>
            <span class="text-fg-muted text-sm">Print or download</span>
            <span class="text-fg-muted text-sm">Make recurring</span>
        </CenterContent>
        <RightContent>
            <CitusButton Variant="CitusButtonVariant.Ghost"
                         Disabled="@(_isSavingDraft || _isSubmitting || ShellState.AreWritesBlocked)"
                         Loading="@_isSavingDraft"
                         OnClick="SaveDraftAsync">
                @(_isSavingDraft ? "Saving..." : "Save draft")
            </CitusButton>
            <CitusButton Variant="CitusButtonVariant.Primary"
                         Disabled="@(_lines.Count == 0 || _subtotal <= 0 || ShellState.AreWritesBlocked || _isSubmitting || _isSavingDraft)"
                         OnClick="PostCurrentAsync">
                @(_isSubmitting ? "Posting..." : PrimaryPostLabel)
            </CitusButton>
        </RightContent>
    </AisePageActionBar>
</div>

<CitusDrawer @bind-IsOpen="_isFxDrawerOpen"
             Title="Edit exchange rate"
             Width="CitusDrawerWidth.Medium"
             SaveDisabled="@(!_fxRateDraft.HasValue || _fxRateDraft.Value <= 0)"
             OnSave="SaveFxDrawer"
             OnCancel="CancelFxDrawer">
    <div class="aise-fx-drawer">
        <div class="aise-fx-drawer__note">
            We use the recommended exchange rate for the invoice date when one is available.
        </div>
        <h3>Custom rate</h3>
        <label>@_currency.ToUpperInvariant()</label>
        <div class="citus-form-field__input citus-form-field__input--readonly">$1</div>
        <label>@ShellState.ActiveCompany.BaseCurrencyCode.ToUpperInvariant()</label>
        <RadzenNumeric TValue="decimal?"
                       @bind-Value="_fxRateDraft"
                       Min="0"
                       Format="0.000000"
                       Class="citus-control-full" />
        <hr />
        <h3>Apply rate to</h3>
        <label class="aise-fx-drawer__radio">
            <input type="radio" checked />
            <span>Transaction only</span>
        </label>
    </div>
</CitusDrawer>

@code {
    [Parameter] public Guid InvoiceId { get; set; }

    /// <summary>
    /// Optional source-SO id passed via query string. When present (the
    /// "Invoice this SO" flow from the SO detail page) the create page
    /// pre-fills customer + currency + Customer PO# + lines from the SO,
    /// and stores the SO id back-link on the new invoice so the M3 iter 3
    /// auto-COGS bridge can resolve the linked SalesIssue.
    /// </summary>
    [SupplyParameterFromQuery] public Guid? FromSalesOrderId { get; set; }

    [SupplyParameterFromQuery(Name = "FromTaskId")]
    public Guid? FromTaskId { get; set; }

    private DateTime? _documentDate = DateTime.Today;
    private DateTime? _dueDate = DateTime.Today.AddDays(30);
    private Guid _customerId;
    private string _customerDisplay = string.Empty;
    /// <summary>
    /// Always tracks the picked customer's default currency, falling back
    /// to the company base when no customer is picked yet. The form has
    /// no input for it — Currency is a read-only display now.
    /// </summary>
    private string _currency = string.Empty;
    private decimal? _fxRate;
    private string _memo = string.Empty;
    private string _customerPoNumber = string.Empty;
    /// <summary>
    /// Back-link to the source Sales Order, populated when the page is
    /// opened via "Invoice this SO" (FromSalesOrderId query param). Sent
    /// to the backend on save so M3 iter 3's auto-COGS bridge can find
    /// the SalesIssue tied to this SO.
    /// </summary>
    private Guid? _salesOrderId;
    private string? _salesOrderNumber;
    private Guid? _sourceTaskId;
    private string? _sourceTaskNumber;
    private string? _editingInvoiceNumber;
    /// <summary>
    /// UI-side per-line state. Carries the wire-shape fields plus the
    /// item-picker's <see cref="ItemId"/> / <see cref="ItemDisplay"/> so
    /// the picker on each row can render a stable "selected" state across
    /// re-renders. Submit projects this list back into <see cref="DocumentLineDraft"/>
    /// (the wire shape) — ItemId is informational for now; pre-fill of
    /// unit price / account from the item master is a future iteration.
    /// </summary>
    private sealed record InvoiceLineEditState(
        Guid ItemId = default,
        string ItemDisplay = "",
        string Description = "",
        decimal Quantity = 1m,
        decimal UnitPrice = 0m,
        Guid? AccountId = null,
        string AccountDisplay = "",
        string AccountCode = "",
        Guid? TaxCodeId = null,
        string TaxCode = "",
        decimal TaxAmount = 0m,
        Guid? TaskId = null,
        Guid? TaskLineId = null)
    {
        public bool HasContent =>
            ItemId != Guid.Empty
            || !string.IsNullOrWhiteSpace(Description)
            || !string.IsNullOrWhiteSpace(AccountCode)
            || !string.IsNullOrWhiteSpace(TaxCode)
            || TaskId.HasValue
            || TaskLineId.HasValue
            || UnitPrice > 0m;
    }

    private readonly List<InvoiceLineEditState> _lines = new() { new InvoiceLineEditState() };
    private bool _isSubmitting;
    private bool _isSavingDraft;
    private bool _isFxDrawerOpen;
    private decimal? _fxRateDraft;
    private string? _validation;
    private WriteFlowResult? _lastResult;

    // Item + account caches let the Item picker auto-fill each line's revenue
    // account without a per-pick round-trip. Loaded once on page init; stale
    // entries fall back to "missing account" and surface the validation error.
    private Dictionary<Guid, ItemSummary> _itemsById = new();
    private Dictionary<Guid, AccountSummary> _accountsById = new();
    private Dictionary<Guid, TaxCodeSummary> _salesTaxCodesById = new();

    private decimal _subtotal => Math.Round(_lines.Sum(l => l.Quantity * l.UnitPrice), 4);
    private decimal _taxTotal => Math.Round(_lines.Sum(l => l.TaxAmount), 4);
    private decimal _total => Math.Round(_subtotal + _taxTotal, 4);

    private bool IsForeignCurrency =>
        !string.IsNullOrWhiteSpace(_currency)
        && !string.Equals(_currency, ShellState.ActiveCompany.BaseCurrencyCode, StringComparison.OrdinalIgnoreCase);

    private bool NeedsFxRate => _customerId != Guid.Empty && IsForeignCurrency && (!_fxRate.HasValue || _fxRate.Value <= 0m);

    private bool IsEditMode => InvoiceId != Guid.Empty;

    private string CustomerAddressText =>
        string.IsNullOrWhiteSpace(_customerDisplay)
            ? string.Empty
            : _customerDisplay;

    private string FxSummary =>
        !IsForeignCurrency
            ? "Base currency"
            : _fxRate.HasValue && _fxRate.Value > 0m
                ? $"1 {_currency.ToUpperInvariant()} = {_fxRate.Value:0.000000} {ShellState.ActiveCompany.BaseCurrencyCode.ToUpperInvariant()}"
                : "Enter exchange rate";

    private string InvoiceTitle =>
        IsEditMode
            ? $"Edit invoice {_editingInvoiceNumber ?? string.Empty}".TrimEnd()
            : _salesOrderId is not null
            ? $"New invoice from {_salesOrderNumber}"
            : _sourceTaskId is not null
                ? $"New invoice from {_sourceTaskNumber}"
                : "New invoice";

    private string PrimaryPostLabel => IsEditMode ? "Save and post" : "Review and post";

    private string InvoiceSourceLabel =>
        _salesOrderId is not null
            ? _salesOrderNumber ?? "Sales order"
            : _sourceTaskId is not null
                ? _sourceTaskNumber ?? "Task"
                : "New invoice";

    protected override async Task OnInitializedAsync()
    {
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;
        var items = await ItemClient.ListAsync(includeInactive: false);
        _itemsById = items.ToDictionary(i => i.Id);
        var accounts = await AccountClient.ListAsync();
        _accountsById = accounts.ToDictionary(a => a.Id);
        var taxCodes = await TaxCodeClient.ListAsync(appliesTo: "sales");
        _salesTaxCodesById = taxCodes.ToDictionary(t => t.Id);

        if (IsEditMode)
        {
            await LoadExistingDraftAsync(InvoiceId);
        }
        else if (FromSalesOrderId is { } soId && soId != Guid.Empty)
        {
            await PrefillFromSalesOrderAsync(soId);
        }
        else if (FromTaskId is { } taskId && taskId != Guid.Empty)
        {
            await PrefillFromTaskAsync(taskId);
        }
    }

    private async Task LoadExistingDraftAsync(Guid invoiceId)
    {
        var invoice = await InvoiceClient.GetByIdAsync(invoiceId, ShellState.ActiveCompany.Id);
        if (invoice is null)
        {
            _validation = "Invoice draft was not found in this company.";
            return;
        }

        if (!string.Equals(invoice.Status, "draft", StringComparison.OrdinalIgnoreCase))
        {
            _validation = "Only draft invoices can be edited.";
            await Message.WarningAsync(_validation);
            return;
        }

        _editingInvoiceNumber = invoice.DisplayNumber;
        _customerId = invoice.CustomerId;
        _documentDate = invoice.DocumentDate.ToDateTime(TimeOnly.MinValue);
        _dueDate = invoice.DueDate?.ToDateTime(TimeOnly.MinValue);
        _currency = string.IsNullOrWhiteSpace(invoice.TransactionCurrencyCode)
            ? ShellState.ActiveCompany.BaseCurrencyCode
            : invoice.TransactionCurrencyCode.Trim().ToUpperInvariant();
        _fxRate = null;
        _memo = invoice.Memo ?? string.Empty;
        _customerPoNumber = invoice.CustomerPoNumber ?? string.Empty;
        _salesOrderId = invoice.SalesOrderId;
        _sourceTaskId = invoice.Lines.FirstOrDefault(line => line.TaskId.HasValue)?.TaskId;
        _sourceTaskNumber = _sourceTaskId.HasValue ? "task" : null;

        var customer = await CustomerClient.GetByIdAsync(_customerId);
        _customerDisplay = customer?.DisplayName ?? string.Empty;

        _lines.Clear();
        foreach (var invoiceLine in invoice.Lines.OrderBy(static line => line.LineNumber))
        {
            var itemId = invoiceLine.ItemId ?? Guid.Empty;
            var itemDisplay = itemId != Guid.Empty && _itemsById.TryGetValue(itemId, out var item)
                ? item.Name
                : string.Empty;
            var accountId = invoiceLine.RevenueAccountId;
            string accountCode = string.Empty;
            string accountDisplay = string.Empty;
            if (accountId is { } resolvedAccountId && _accountsById.TryGetValue(resolvedAccountId, out var account))
            {
                accountCode = account.Code;
                accountDisplay = $"{account.Code} {account.Name}";
            }

            var taxDisplay = invoiceLine.TaxCodeId is { } taxCodeId &&
                             _salesTaxCodesById.TryGetValue(taxCodeId, out var tax)
                ? tax.Code
                : string.Empty;

            _lines.Add(new InvoiceLineEditState(
                ItemId: itemId,
                ItemDisplay: itemDisplay,
                Description: invoiceLine.Description ?? string.Empty,
                Quantity: invoiceLine.Quantity,
                UnitPrice: invoiceLine.UnitPrice,
                AccountId: accountId,
                AccountDisplay: accountDisplay,
                AccountCode: accountCode,
                TaxCodeId: invoiceLine.TaxCodeId,
                TaxCode: taxDisplay,
                TaxAmount: invoiceLine.TaxAmount,
                TaskId: invoiceLine.TaskId,
                TaskLineId: invoiceLine.TaskLineId));
        }

        if (_lines.Count == 0 || _lines[^1].HasContent)
        {
            _lines.Add(new InvoiceLineEditState());
        }

        await RefreshAllTaxPreviewsAsync();
    }

    /// <summary>
    /// Pre-fills the form from an existing Sales Order. Best-effort:
    /// missing items / accounts / tax codes leave their respective
    /// per-line cells blank rather than blocking the whole prefill, and
    /// the operator sees the inline validation when they go to post.
    /// </summary>
    private async Task PrefillFromSalesOrderAsync(Guid salesOrderId)
    {
        var so = await SalesOrderClient.GetByIdAsync(salesOrderId);
        if (so is null)
        {
            await Message.WarningAsync("Source sales order not found in this company; starting a blank invoice.");
            return;
        }

        // Header pre-fill
        _customerId = so.CustomerId;
        _customerDisplay = so.CustomerName;
        _currency = so.TransactionCurrencyCode;
        _fxRate = so.FxRate;
        _customerPoNumber = so.CustomerPoNumber ?? string.Empty;
        _salesOrderId = so.Id;
        _salesOrderNumber = so.SalesOrderNumber;
        _memo = so.MemoToCustomer ?? string.Empty;

        // Tax codes are loaded only on this path so the display labels in
        // the per-line tax picker render correctly. Normal "blank invoice"
        // start skips this round-trip.
        Dictionary<Guid, TaxCodeSummary> taxById;
        try
        {
            var taxCodes = await TaxCodeClient.ListAsync(appliesTo: "sales");
            taxById = taxCodes.ToDictionary(t => t.Id);
        }
        catch
        {
            taxById = new Dictionary<Guid, TaxCodeSummary>();
        }

        // Lines pre-fill — replace the seeded blank line with the SO lines.
        _lines.Clear();
        foreach (var soLine in so.Lines.OrderBy(l => l.Sequence))
        {
            var itemId = soLine.ItemId ?? Guid.Empty;
            string itemDisplay = string.Empty;
            Guid? accountId = null;
            string accountCode = string.Empty;
            string accountDisplay = string.Empty;

            if (itemId != Guid.Empty && _itemsById.TryGetValue(itemId, out var item))
            {
                itemDisplay = item.Name;
                if (item.DefaultSalesRevenueAccountId is { } itemAccountId
                    && _accountsById.TryGetValue(itemAccountId, out var account))
                {
                    accountId = account.Id;
                    accountCode = account.Code;
                    accountDisplay = $"{account.Code} {account.Name}";
                }
            }

            string taxDisplay = string.Empty;
            if (soLine.TaxCodeId is { } taxId && taxById.TryGetValue(taxId, out var tax))
            {
                taxDisplay = tax.Code;
            }

            _lines.Add(new InvoiceLineEditState(
                ItemId: itemId,
                ItemDisplay: itemDisplay,
                Description: soLine.Description ?? string.Empty,
                Quantity: soLine.Quantity,
                UnitPrice: soLine.UnitPrice,
                AccountId: accountId,
                AccountDisplay: accountDisplay,
                AccountCode: accountCode,
                TaxCodeId: soLine.TaxCodeId,
                TaxCode: taxDisplay));
        }

        // Always keep one trailing blank line so the operator can append
        // an extra line (shipping, surcharge, etc.) without re-clicking
        // "Add line".
        if (_lines.Count == 0 || _lines[^1].HasContent)
        {
            _lines.Add(new InvoiceLineEditState());
        }

        await RefreshAllTaxPreviewsAsync();
    }

    private async Task PrefillFromTaskAsync(Guid taskId)
    {
        var task = await TaskClient.GetAsync(taskId);
        if (task is null)
        {
            await Message.WarningAsync("Source task not found in this company; starting a blank invoice.");
            return;
        }

        if (!task.CustomerId.HasValue || task.CustomerId.Value == Guid.Empty)
        {
            _validation = "The source task has no customer, so it cannot pre-fill an invoice.";
            return;
        }

        var taskDisplay = FormatTaskDisplay(task);
        _sourceTaskId = task.Id;
        _sourceTaskNumber = task.TaskNo;
        _customerId = task.CustomerId.Value;
        _currency = string.IsNullOrWhiteSpace(task.CurrencyCode)
            ? ShellState.ActiveCompany.BaseCurrencyCode
            : task.CurrencyCode.Trim().ToUpperInvariant();

        if (task.ServiceDate is { } serviceDate)
        {
            _documentDate = serviceDate.ToDateTime(TimeOnly.MinValue);
            _dueDate = _documentDate.Value.AddDays(30);
        }

        var customer = await CustomerClient.GetByIdAsync(_customerId);
        if (customer is not null)
        {
            _customerDisplay = customer.DisplayName;
            if (string.IsNullOrWhiteSpace(task.CurrencyCode) && !string.IsNullOrWhiteSpace(customer.DefaultCurrencyCode))
            {
                _currency = customer.DefaultCurrencyCode.Trim().ToUpperInvariant();
            }
        }

        _memo = $"Invoice for {taskDisplay}";

        Dictionary<Guid, TaxCodeSummary> taxById;
        try
        {
            var taxCodes = await TaxCodeClient.ListAsync(appliesTo: "sales");
            taxById = taxCodes.ToDictionary(t => t.Id);
        }
        catch
        {
            taxById = new Dictionary<Guid, TaxCodeSummary>();
        }

        _lines.Clear();
        foreach (var taskLine in task.Lines.OrderBy(l => l.LineNo))
        {
            var itemId = taskLine.ItemId;
            string itemDisplay = string.Empty;
            Guid? accountId = null;
            string accountCode = string.Empty;
            string accountDisplay = string.Empty;

            if (itemId != Guid.Empty && _itemsById.TryGetValue(itemId, out var item))
            {
                itemDisplay = item.Name;
                if (item.DefaultSalesRevenueAccountId is { } itemAccountId
                    && _accountsById.TryGetValue(itemAccountId, out var account))
                {
                    accountId = account.Id;
                    accountCode = account.Code;
                    accountDisplay = $"{account.Code} {account.Name}";
                }
            }

            string taxDisplay = string.Empty;
            if (taskLine.TaxCodeId is { } taxId && taxById.TryGetValue(taxId, out var tax))
            {
                taxDisplay = tax.Code;
            }

            _lines.Add(new InvoiceLineEditState(
                ItemId: itemId,
                ItemDisplay: itemDisplay,
                Description: string.IsNullOrWhiteSpace(taskLine.Description) ? task.Title : taskLine.Description,
                Quantity: taskLine.Quantity,
                UnitPrice: taskLine.UnitPrice,
                AccountId: accountId,
                AccountDisplay: accountDisplay,
                AccountCode: accountCode,
                TaxCodeId: taskLine.TaxCodeId,
                TaxCode: taxDisplay,
                TaskId: task.Id,
                TaskLineId: taskLine.Id));
        }

        if (_lines.Count == 0)
        {
            _validation = $"Task {taskDisplay} has no billable lines.";
            _lines.Add(new InvoiceLineEditState());
            return;
        }

        if (_lines[^1].HasContent)
        {
            _lines.Add(new InvoiceLineEditState());
        }

        await RefreshAllTaxPreviewsAsync();
    }

    private async Task OnCustomerSelected(UnitySearchPickerOption option)
    {
        _customerId = option.SourceId;
        _customerDisplay = option.DisplayText;

        // Best-effort lookup. Transient failure leaves _currency on its
        // previous value (base or the previous customer's default) — the
        // operator can re-pick to retry. The invoice can't post without
        // a valid customer id either way.
        var customer = await CustomerClient.GetByIdAsync(_customerId);
        if (customer is not null && !string.IsNullOrWhiteSpace(customer.DefaultCurrencyCode))
        {
            _currency = customer.DefaultCurrencyCode;
        }
    }

    private void OnCustomerCleared()
    {
        _customerId = Guid.Empty;
        _customerDisplay = string.Empty;
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;
    }

    private void AddLine() => _lines.Add(new InvoiceLineEditState());

    private void ClearLines()
    {
        _lines.Clear();
        _lines.Add(new InvoiceLineEditState());
    }

    private void RemoveLine(int i)
    {
        if (i < 0 || i >= _lines.Count) return;
        _lines.RemoveAt(i);
        // Always keep at least one row so the operator has somewhere to
        // type. The auto-grow rule below relies on the LAST row being
        // the "blank trailer" — removing it would strand the table.
        if (_lines.Count == 0) _lines.Add(new InvoiceLineEditState());
    }

    private void InsertLineAfter(int i)
    {
        if (i < 0 || i >= _lines.Count) return;
        _lines.Insert(i + 1, new InvoiceLineEditState());
    }

    private void Update(int i, Func<InvoiceLineEditState, InvoiceLineEditState> mutate)
    {
        if (i < 0 || i >= _lines.Count) return;
        _lines[i] = mutate(_lines[i]);
        EnsureTrailingBlankLine();
    }

    private async Task UpdateAndRefreshTaxAsync(int i, Func<InvoiceLineEditState, InvoiceLineEditState> mutate)
    {
        Update(i, mutate);
        await RefreshLineTaxPreviewAsync(i);
    }

    /// <summary>
    /// Appends a fresh blank line whenever the user has filled content
    /// into the previously-trailing row. Mirrors the JE create page's
    /// auto-grow UX: operator types into the last row → another blank
    /// row appears at the bottom → keep going. Removes the need to hunt
    /// for "Add line" mid-flow.
    /// </summary>
    private void EnsureTrailingBlankLine()
    {
        if (_lines.Count == 0)
        {
            _lines.Add(new InvoiceLineEditState());
            return;
        }
        if (_lines[^1].HasContent)
        {
            _lines.Add(new InvoiceLineEditState());
        }
    }

    private void OnItemPicked(int i, UnitySearchPickerOption option)
    {
        // Auto-fill the line's revenue account from the picked item's
        // DefaultSalesRevenueAccountId. Sales lines have no manual Account
        // column — the item is the single source of truth. If the item
        // (or its account) is missing locally, we leave Account fields
        // blank and the inline error / submit-time validation guides the
        // operator to fix the item master.
        var (accountId, accountCode, accountDisplay) = ResolveItemAccount(option.SourceId);
        Update(i, l => l with
        {
            ItemId = option.SourceId,
            ItemDisplay = option.DisplayText,
            Description = string.IsNullOrWhiteSpace(l.Description) ? option.PrimaryText : l.Description,
            AccountId = accountId,
            AccountCode = accountCode,
            AccountDisplay = accountDisplay,
        });
    }

    private void OnItemCleared(int i)
    {
        Update(i, l => l with
        {
            ItemId = Guid.Empty,
            ItemDisplay = string.Empty,
            AccountId = null,
            AccountCode = string.Empty,
            AccountDisplay = string.Empty,
        });
    }

    private (Guid? AccountId, string AccountCode, string AccountDisplay) ResolveItemAccount(Guid itemId)
    {
        if (!_itemsById.TryGetValue(itemId, out var item) || !item.DefaultSalesRevenueAccountId.HasValue)
        {
            return (null, string.Empty, string.Empty);
        }
        var accountId = item.DefaultSalesRevenueAccountId.Value;
        if (!_accountsById.TryGetValue(accountId, out var account))
        {
            return (accountId, string.Empty, string.Empty);
        }
        return (accountId, account.Code, $"{account.Code} {account.Name}");
    }

    private async Task OnTaxCodeSelected(int i, TaxCodeSummary tax)
    {
        _salesTaxCodesById[tax.Id] = tax;
        Update(i, l => l with
        {
            TaxCodeId = tax.Id,
            TaxCode = tax.Code
        });
        await RefreshLineTaxPreviewAsync(i);
    }

    private void OnTaxCodeCleared(int i)
    {
        Update(i, l => l with { TaxCodeId = null, TaxCode = string.Empty, TaxAmount = 0m });
    }

    private async Task RefreshAllTaxPreviewsAsync()
    {
        for (var i = 0; i < _lines.Count; i++)
        {
            await RefreshLineTaxPreviewAsync(i);
        }
    }

    private async Task RefreshLineTaxPreviewAsync(int i)
    {
        if (i < 0 || i >= _lines.Count)
        {
            return;
        }

        var line = _lines[i];
        var lineAmount = Math.Round(line.Quantity * line.UnitPrice, 4);
        if (lineAmount <= 0m || line.TaxCodeId is not { } taxCodeId)
        {
            _lines[i] = line with { TaxAmount = 0m };
            return;
        }

        var preview = await SalesTaxClient.CalculatePreviewAsync(new SalesTaxPreviewRequest(
            DocumentSide: "sales",
            DocumentDate: DateOnly.FromDateTime((_documentDate ?? DateTime.Today).Date),
            TaxMode: "exclusive",
            Amount: lineAmount,
            TaxCodeId: taxCodeId,
            CurrencyCode: string.IsNullOrWhiteSpace(_currency) ? ShellState.ActiveCompany.BaseCurrencyCode : _currency.Trim().ToUpperInvariant()));

        if (i < 0 || i >= _lines.Count)
        {
            return;
        }

        var current = _lines[i];
        if (current.TaxCodeId != taxCodeId || Math.Round(current.Quantity * current.UnitPrice, 4) != lineAmount)
        {
            return;
        }

        _lines[i] = current with { TaxAmount = Math.Round(preview?.TaxAmount ?? 0m, 4) };
    }

    private void OpenFxDrawer()
    {
        _fxRateDraft = _fxRate is > 0m ? _fxRate : null;
        _isFxDrawerOpen = true;
    }

    private Task SaveFxDrawer()
    {
        _fxRate = _fxRateDraft;
        _isFxDrawerOpen = false;
        return Task.CompletedTask;
    }

    private void CancelFxDrawer()
    {
        _isFxDrawerOpen = false;
    }

    private async Task PostAsync()
    {
        _validation = null;
        _lastResult = null;

        if (_customerId == Guid.Empty) { _validation = "Pick a customer first."; return; }

        // Drop any trailing blank lines the auto-grow heuristic left behind
        // before validating — they're scaffolding, not user intent.
        var meaningful = _lines.Where(l => l.HasContent).ToArray();
        if (meaningful.Length == 0) { _validation = "Add at least one invoice line."; return; }
        if (meaningful.Any(l => l.ItemId == Guid.Empty)) { _validation = "Every line needs an item / service picked."; return; }
        if (meaningful.Any(l => string.IsNullOrWhiteSpace(l.Description))) { _validation = "Every line needs a description."; return; }
        if (meaningful.Any(l => string.IsNullOrWhiteSpace(l.AccountCode))) { _validation = "One or more items have no sales / revenue account configured. Set it in Products & Services and re-pick."; return; }
        var lineSubtotal = meaningful.Sum(l => l.Quantity * l.UnitPrice);
        if (lineSubtotal <= 0) { _validation = "Invoice total must be greater than zero."; return; }

        _isSubmitting = true;
        try
        {
            var draft = new InvoiceDraft
            {
                CompanyId = ShellState.ActiveCompany.Id,
                UserId = ShellState.User.Id,
                DocumentDate = DateOnly.FromDateTime((_documentDate ?? DateTime.Today).Date),
                DueDate = _dueDate.HasValue ? DateOnly.FromDateTime(_dueDate.Value.Date) : null,
                CustomerId = _customerId,
                TransactionCurrencyCode = _currency.Trim().ToUpperInvariant(),
                BaseCurrencyCode = ShellState.ActiveCompany.BaseCurrencyCode.Trim().ToUpperInvariant(),
                FxRate = _fxRate,
                Memo = _memo.Trim(),
                CustomerPoNumber = _customerPoNumber.Trim(),
                SalesOrderId = _salesOrderId,
                Lines = meaningful.Select((l, idx) => new InvoiceLineDraft
                {
                    LineNumber = idx + 1,
                    RevenueAccountId = l.AccountId!.Value,
                    ItemId = l.ItemId == Guid.Empty ? null : l.ItemId,
                    Description = l.Description,
                    Quantity = l.Quantity,
                    UnitPrice = l.UnitPrice,
                    TaxCodeId = l.TaxCodeId,
                    TaxAmount = l.TaxAmount, // Server recomputes from TaxCodeId when saving; this keeps the draft echo consistent.
                    TaskId = l.TaskId,
                    TaskLineId = l.TaskLineId,
                }).ToArray()
            };
            _lastResult = await WriteFlow.PostInvoiceAsync(draft);
            if (_lastResult.Succeeded)
            {
                // Use the composed message — includes "Invoice INV-XXXX posted"
                // plus auto-COGS JE numbers (M3 iter 3) so the operator sees
                // the full set of journal entries that just landed.
                await Message.SuccessAsync(_lastResult.Message);
                NavigationManager.NavigateTo(_lastResult.DocumentId is { } id
                    ? $"invoices/{id:D}"
                    : "invoices");
            }
            else
            {
                await Message.InfoAsync(_lastResult.Message);
            }
        }
        finally { _isSubmitting = false; }
    }

    private async Task PostCurrentAsync()
    {
        _lastResult = null;
        var draft = BuildValidatedDraft();
        if (draft is null)
        {
            return;
        }

        _isSubmitting = true;
        try
        {
            if (IsEditMode)
            {
                var saveResult = await WriteFlow.SaveInvoiceDraftAsync(draft, InvoiceId);
                if (!saveResult.Succeeded)
                {
                    _lastResult = saveResult;
                    await Message.WarningAsync(saveResult.Message);
                    return;
                }

                var refreshed = await InvoiceClient.GetByIdAsync(InvoiceId, ShellState.ActiveCompany.Id);
                _lastResult = await WriteFlow.PostExistingInvoiceAsync(
                    InvoiceId,
                    ShellState.ActiveCompany.Id,
                    ShellState.User.Id,
                    refreshed?.DisplayNumber ?? _editingInvoiceNumber ?? InvoiceId.ToString("D"),
                    refreshed?.CustomerId ?? _customerId,
                    refreshed is null ? Array.Empty<InvoiceTaskBillingLink>() : BuildTaskBillingLinks(refreshed));
            }
            else
            {
                _lastResult = await WriteFlow.PostInvoiceAsync(draft);
            }

            if (_lastResult.Succeeded)
            {
                await Message.SuccessAsync(_lastResult.Message);
                NavigationManager.NavigateTo(_lastResult.DocumentId is { } id
                    ? $"invoices/{id:D}"
                    : "invoices");
            }
            else
            {
                await Message.InfoAsync(_lastResult.Message);
            }
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task SaveDraftAsync()
    {
        _lastResult = null;
        var draft = BuildValidatedDraft();
        if (draft is null)
        {
            return;
        }

        _isSavingDraft = true;
        try
        {
            _lastResult = await WriteFlow.SaveInvoiceDraftAsync(
                draft,
                IsEditMode ? InvoiceId : null);
            if (!_lastResult.Succeeded)
            {
                await Message.WarningAsync(_lastResult.Message);
                return;
            }

            await Message.SuccessAsync(_lastResult.Message);
            NavigationManager.NavigateTo(_lastResult.DocumentId is { } id
                ? $"invoices/{id:D}"
                : "invoices");
        }
        finally
        {
            _isSavingDraft = false;
        }
    }

    private InvoiceDraft? BuildValidatedDraft()
    {
        _validation = null;

        if (_customerId == Guid.Empty) { _validation = "Pick a customer first."; return null; }

        // Drop any trailing blank lines the auto-grow heuristic left behind
        // before validating; they're scaffolding, not user intent.
        var meaningful = _lines.Where(l => l.HasContent).ToArray();
        if (meaningful.Length == 0) { _validation = "Add at least one invoice line."; return null; }
        if (meaningful.Any(l => l.ItemId == Guid.Empty)) { _validation = "Every line needs an item / service picked."; return null; }
        if (meaningful.Any(l => string.IsNullOrWhiteSpace(l.Description))) { _validation = "Every line needs a description."; return null; }
        if (meaningful.Any(l => string.IsNullOrWhiteSpace(l.AccountCode))) { _validation = "One or more items have no sales / revenue account configured. Set it in Products & Services and re-pick."; return null; }
        var lineSubtotal = meaningful.Sum(l => l.Quantity * l.UnitPrice);
        if (lineSubtotal <= 0) { _validation = "Invoice total must be greater than zero."; return null; }

        return new InvoiceDraft
        {
            CompanyId = ShellState.ActiveCompany.Id,
            UserId = ShellState.User.Id,
            DocumentDate = DateOnly.FromDateTime((_documentDate ?? DateTime.Today).Date),
            DueDate = _dueDate.HasValue ? DateOnly.FromDateTime(_dueDate.Value.Date) : null,
            CustomerId = _customerId,
            TransactionCurrencyCode = _currency.Trim().ToUpperInvariant(),
            BaseCurrencyCode = ShellState.ActiveCompany.BaseCurrencyCode.Trim().ToUpperInvariant(),
            FxRate = _fxRate,
            Memo = _memo.Trim(),
            CustomerPoNumber = _customerPoNumber.Trim(),
            SalesOrderId = _salesOrderId,
            Lines = meaningful.Select((l, idx) => new InvoiceLineDraft
            {
                LineNumber = idx + 1,
                RevenueAccountId = l.AccountId!.Value,
                ItemId = l.ItemId == Guid.Empty ? null : l.ItemId,
                Description = l.Description,
                Quantity = l.Quantity,
                UnitPrice = l.UnitPrice,
                TaxCodeId = l.TaxCodeId,
                TaxAmount = l.TaxAmount,
                TaskId = l.TaskId,
                TaskLineId = l.TaskLineId,
            }).ToArray()
        };
    }

    private static IReadOnlyList<InvoiceTaskBillingLink> BuildTaskBillingLinks(InvoiceRecordDto invoice) =>
        invoice.Lines
            .Where(static line => line.TaskId.HasValue && line.TaskLineId.HasValue)
            .Select(static line => new InvoiceTaskBillingLink(
                line.TaskId!.Value,
                line.TaskLineId!.Value,
                line.Id))
            .Distinct()
            .ToArray();

    private static string FormatTaskDisplay(TaskRecord task) =>
        string.IsNullOrWhiteSpace(task.Title)
            ? task.TaskNo
            : $"{task.TaskNo} - {task.Title}";

    private static string FormatAmount(decimal amount) => amount.ToString("N2");
