@page "/invoices/new"
@page "/invoices/{InvoiceId:guid}/edit"

@using Citus.Modules.UnitySearch.Blazor
@using Citus.Modules.Tasks.Domain.Shared
@using TaskStatus = Citus.Modules.Tasks.Domain.Shared.TaskStatus

@inject BusinessShellState ShellState
@inject BusinessWriteFlowClient WriteFlow
@inject CustomerClient CustomerClient
@inject ItemClient ItemClient
@inject AccountClient AccountClient
@inject TaxCodeClient TaxCodeClient
@inject TaxCodeSetClient TaxCodeSetClient
@inject UomClient UomClient
@inject SalesOrderClient SalesOrderClient
@inject TaskClient TaskClient
@inject InvoiceClient InvoiceClient
@inject NavigationManager NavigationManager
@inject CitusToastService Message

<PageTitle>New Invoice | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusLinkButton Href="invoices"
                         Variant="CitusButtonVariant.Ghost"
                         LeadingIcon="IconName.ArrowLeft">
            Back to invoices
        </CitusLinkButton>
    </Actions>
</CitusPageHeader>

@if (ShellState.AreWritesBlocked)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" ShowIcon="true" Message="@ShellState.WriteBlockMessage" Class="mb-4" />
}

@if (_isFromCopy)
{
    @* Copy A3 Phase 2: prefilled from another invoice. The source is
       untouched; this is a fresh draft the operator can revise. *@
    <CitusAlert Severity="CitusAlertSeverity.Info" ShowIcon="true" Class="mb-4"
                Message="This is a copy. Review the lines and revise as needed; the original invoice is unchanged." />
}

@if (!string.IsNullOrWhiteSpace(_validation))
{
    <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_validation" ShowIcon="true" Class="mb-4" />
}

<WriteFlowResultAlert Result="@_lastResult" />

<div class="flex flex-col gap-6">
        <CitusFormSection Title="Header">
            @* Two-column header: identity / customer on the left, dates /
               currency on the right; billing + shipping addresses below. *@
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-6 gap-y-4">
                @* LEFT column *@
                <div class="flex flex-col gap-4">
                    <CitusFormField Label="Invoice #">
                        @* Defaults to the system's next auto number; editable on a
                           new invoice, read-only once the number is assigned. *@
                        @if (_editInvoiceId is null)
                        {
                            <CitusInput TValue="string" @bind-Value="_invoiceNumber" Placeholder="Auto-assigned on save; editable" MaxLength="64" />
                        }
                        else
                        {
                            <div class="citus-form-field__input citus-form-field__input--readonly flex items-center">
                                <span class="citus-inline-code">@_invoiceNumber</span>
                            </div>
                        }
                    </CitusFormField>
                    <CitusFormField Label="Customer">
                        <CustomerPicker CompanyId="@ShellState.ActiveCompany.Id"
                                           UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                           Placeholder="Search customers…"
                                           Take="8"
                                           SourceRoute="/invoices/new"
                                           SelectedId="@(_customerId == Guid.Empty ? null : _customerId)"
                                           SelectedDisplayText="@_customerDisplay"
                                           OnCustomerSelected="OnCustomerSelected"
                                           OnCleared="OnCustomerCleared" />
                    </CitusFormField>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <CitusFormField Label="Sales order">
                            <div class="citus-form-field__input citus-form-field__input--readonly flex items-center">
                                <span class="text-fg-muted text-sm">@(_salesOrderId is null ? "Direct invoice (no source SO)" : $"From SO {_salesOrderNumber}")</span>
                            </div>
                        </CitusFormField>
                        <CitusFormField Label="Customer PO #">
                            <CitusInput TValue="string" @bind-Value="_customerPoNumber" Placeholder="Customer's PO reference (optional)" MaxLength="64" />
                        </CitusFormField>
                    </div>
                </div>
                @* RIGHT column *@
                <div class="flex flex-col gap-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <CitusFormField Label="Document date">
                            <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_documentDate" Class="citus-control-full" />
                        </CitusFormField>
                        <CitusFormField Label="Due date">
                            <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_dueDate" Class="citus-control-full" />
                        </CitusFormField>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <CitusFormField Label="Currency">
                            <div class="citus-form-field__input citus-form-field__input--readonly flex items-center">
                                <span>@_currency.ToUpperInvariant()</span>
                            </div>
                        </CitusFormField>
                        <CitusFormField Label="Exchange rate">
                            @if (_customerId == Guid.Empty)
                            {
                                <div class="citus-form-field__input citus-form-field__input--readonly flex items-center">
                                    <span class="text-fg-subtle">Pick a customer first</span>
                                </div>
                            }
                            else
                            {
                                <FxRateInline DocumentDate="@(DateOnly.FromDateTime((_documentDate ?? DateTime.Today).Date))"
                                              BaseCurrencyCode="@ShellState.ActiveCompany.BaseCurrencyCode"
                                              QuoteCurrencyCode="@_currency"
                                              @bind-Rate="_fxRate" />
                            }
                        </CitusFormField>
                    </div>
                </div>
            </div>
            @* Billing (left) + Shipping (right) addresses — free-text, pre-filled
               from the selected customer and editable per invoice. *@
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-4">
                <CitusFormField Label="Billing address">
                    <RadzenTextArea @bind-Value="_billingAddress" Rows="3" Placeholder="Pre-filled from the customer; editable" Class="citus-control-full" />
                </CitusFormField>
                <CitusFormField Label="Shipping address">
                    <RadzenTextArea @bind-Value="_shippingAddress" Rows="3" Placeholder="Pre-filled from the customer; editable" Class="citus-control-full" />
                </CitusFormField>
            </div>
        </CitusFormSection>

        <CitusFormSection Title="Lines">
            <HeaderActions>
                <CitusButton LeadingIcon="IconName.Plus" Size="CitusButtonSize.Small" OnClick="AddLine">Add line</CitusButton>
            </HeaderActions>
            <ChildContent>
            <table class="citus-data-table citus-data-table--compact">
                <thead>
                    <tr>
                        <th style="width: 2.25rem"></th>
                        <th style="width: 15rem">Item / Service</th>
                        <th style="width: 14rem">Category</th>
                        <th>Description</th>
                        <th class="text-right" style="width: 6rem">Qty</th>
                        <th class="text-right" style="width: 9rem">Unit price</th>
                        <th style="width: 6rem">Tax</th>
                        <th class="text-right" style="width: 9rem">Line total</th>
                        <th style="width: 3rem"></th>
                    </tr>
                </thead>
                <tbody>
                    @for (var index = 0; index < _lines.Count; index++)
                    {
                        var i = index;
                        var line = _lines[i];
                        <tr>
                            <td>
                                @* Insert-below button. Always visible (no hover-show) — keeps
                                   the affordance discoverable for new operators. Plus auto-grow
                                   below means most operators won't actually need this; it's
                                   for re-ordering / inserting between two filled lines. *@
                                <button type="button"
                                        class="citus-icon-button"
                                        title="Insert line below"
                                        @onclick="() => InsertLineAfter(i)">
                                    <CitusIcon Name="IconName.Plus" Size="IconSize.Inline" />
                                </button>
                            </td>
                            <td>
                                @* Item / Service picker (optional). On select, the
                                   line's Category auto-fills from the item's revenue
                                   account; the Category stays editable. *@
                                <ItemServicePicker CompanyId="@ShellState.ActiveCompany.Id"
                                                   UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                                   Placeholder="Search items… (optional)"
                                                   Take="6"
                                                   SourceRoute="/invoices/new"
                                                   SelectedId="@(line.ItemId == Guid.Empty ? null : line.ItemId)"
                                                   SelectedDisplayText="@line.ItemDisplay"
                                                   OnItemSelected="@(option => OnItemPicked(i, option))"
                                                   OnCleared="@(() => OnItemCleared(i))" />
                            </td>
                            <td>
                                @* Category = the line's income account. Required;
                                   auto-filled from the Item when one is picked, and
                                   editable for item-less lines (added flexibility). *@
                                <AccountPicker CompanyId="@ShellState.ActiveCompany.Id"
                                               UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                               Context="invoice.line.category"
                                               SelectedId="@line.AccountId"
                                               SelectedDisplayText="@GetAccountLabel(line.AccountId)"
                                               Placeholder="Pick a category…"
                                               OnAccountSelected="@(acct => Update(i, l => l with { AccountId = acct.Id, AccountCode = acct.Code, AccountDisplay = $"{acct.Code}  {acct.Name}" }))"
                                               OnCleared="@(() => Update(i, l => l with { AccountId = null, AccountCode = string.Empty, AccountDisplay = string.Empty }))" />
                            </td>
                            <td><CitusInput TValue="string" Value="@line.Description" ValueChanged="@(v => Update(i, l => l with { Description = v ?? string.Empty }))" Size="CitusButtonSize.Small" Placeholder="Free-form description" /></td>
                            <td><RadzenNumeric TValue="decimal" Value="@line.Quantity" ValueChanged="@(v => Update(i, l => l with { Quantity = v }))" Min="0" Class="citus-control-full" /></td>
                            <td><RadzenNumeric TValue="decimal" Value="@line.UnitPrice" ValueChanged="@(v => Update(i, l => l with { UnitPrice = v }))" Min="0" Class="citus-control-full" /></td>
                            <td>
                                <RadzenDropDown TValue="Guid?"
                                                Data="@_taxCodeSets"
                                                Value="@line.TaxCodeSetId"
                                                Change="@(v => Update(i, l => l with { TaxCodeSetId = v as Guid? }))"
                                                TextProperty="Code"
                                                ValueProperty="Id"
                                                AllowClear="true"
                                                Placeholder="Tax"
                                                Class="citus-control-full" />
                            </td>
                            <td class="text-right">@FormatAmount(line.Quantity * line.UnitPrice)</td>
                            <td>
                                <button type="button" class="citus-icon-button" title="Remove line" @onclick="() => RemoveLine(i)">
                                    <CitusIcon Name="IconName.Trash" Size="IconSize.Inline" />
                                </button>
                            </td>
                        </tr>
                    }
                    <tr class="citus-data-table__total">
                        <td colspan="6" class="text-right font-medium">Total</td>
                        <td class="text-right font-semibold">@FormatAmount(_total)</td>
                        <td></td>
                    </tr>
                </tbody>
            </table>
            </ChildContent>
        </CitusFormSection>

        @* Memo (left) + Summary (right) share a row below the Lines.
           The engine recomputes the authoritative tax split on save. *@
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <CitusFormSection Title="Memo">
                <CitusInput TValue="string" @bind-Value="_memo" Placeholder="Visible to customer; optional." />
            </CitusFormSection>
            <CitusFormSection Title="Summary">
                <CitusKeyValueTable>
                    <CitusKeyValueRow Label="Lines">@_lines.Count</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Subtotal">@FormatAmount(_total)</CitusKeyValueRow>
                    @* Live tax preview, broken out per Tax Rule (the components
                       of each selected Tax Code — e.g. GST / PST inside a BC/GP
                       code). Computed client-side from the loaded code rates;
                       the engine recomputes the authoritative split on save. *@
                    @foreach (var t in _taxByRule)
                    {
                        <CitusKeyValueRow Label="@t.RuleCode">@FormatAmount(t.Amount)</CitusKeyValueRow>
                    }
                    <CitusKeyValueRow Label="Currency">@_currency.ToUpperInvariant()</CitusKeyValueRow>
                    @if (!string.Equals(_currency, ShellState.ActiveCompany.BaseCurrencyCode, StringComparison.OrdinalIgnoreCase))
                    {
                        <CitusKeyValueRow Label="FX rate">@(_fxRate.HasValue ? _fxRate.Value.ToString("0.000000") : "—")</CitusKeyValueRow>
                    }
                    @if (_taxTotal > 0m)
                    {
                        <CitusKeyValueRow Label="Total"><strong>@FormatAmount(_total + _taxTotal) @_currency.ToUpperInvariant()</strong></CitusKeyValueRow>
                    }
                </CitusKeyValueTable>
            </CitusFormSection>
        </div>
</div>

@* Sticky Post action — single primary button (no Cancel; invoices
   have no Save Draft pathway, Back navigates away). ErrorHint nudges
   the operator back up to the top-of-page validation alert. *@
<CitusFormActions Sticky="true"
                  PrimaryLabel="@(_editInvoiceId is null ? "Post invoice" : "Save draft")"
                  SavingLabel="@(_editInvoiceId is null ? "Posting..." : "Saving...")"
                  CancelVisible="false"
                  IsSaving="@_isSubmitting"
                  Disabled="@(_lines.Count == 0 || _total <= 0 || ShellState.AreWritesBlocked)"
                  ErrorHint="@(string.IsNullOrWhiteSpace(_validation) ? null : "Fix errors above")"
                  OnSave="PostAsync" />

@code {
    /// <summary>
    /// Optional source-SO id passed via query string. When present (the
    /// "Invoice this SO" flow from the SO detail page) the create page
    /// pre-fills customer + currency + Customer PO# + lines from the SO,
    /// and stores the SO id back-link on the new invoice so the M3 iter 3
    /// auto-COGS bridge can resolve the linked SalesIssue.
    /// </summary>
    [SupplyParameterFromQuery] public Guid? FromSalesOrderId { get; set; }

    /// <summary>
    /// Optional source-task id passed via query string. When present
    /// ("Bill this task" flow from TaskDetailPage) the create page
    /// pre-fills customer + currency + lines from the task, and every
    /// line is stamped with TaskId so the post handler can flip the
    /// task Completed -> Billed once the invoice posts.
    /// </summary>
    [SupplyParameterFromQuery] public Guid? FromTaskId { get; set; }

    /// <summary>
    /// Copy A3 Phase 2: source invoice id passed via query string. Set
    /// by InvoiceDetailPage's More → Copy. The create page hydrates
    /// the form with the source's customer / currency / lines / memo,
    /// resets the dates to today (+30), and shows a "This is a copy"
    /// banner. The new invoice is fully independent of the source —
    /// no FK back, no JE link.
    /// </summary>
    [SupplyParameterFromQuery(Name = "copyFrom")] public Guid? CopyFromInvoiceId { get; set; }

    /// <summary>
    /// Route param for the edit flow (/invoices/{id}/edit). When set, the
    /// page loads that draft and saves via PUT (stays a draft) instead of
    /// the create-and-post path.
    /// </summary>
    [Parameter] public Guid? InvoiceId { get; set; }

    // Non-null while editing an existing draft (set by PrefillFromEditSource).
    private Guid? _editInvoiceId;

    private PageHeaderModel _header = new()
    {
        Eyebrow = "Sales & Get Paid",
        Title = "New invoice",
        Subtitle = "Customer-facing receivable. Posting opens the AR open item; settlement happens in Receive Payment."
    };

    private DateTime? _documentDate = DateTime.Today;
    private DateTime? _dueDate = DateTime.Today.AddDays(30);
    private Guid _customerId;
    private string _customerDisplay = string.Empty;
    /// <summary>
    /// Always tracks the picked customer's default currency, falling back
    /// to the company base when no customer is picked yet. The form has
    /// no input for it — Currency is a read-only display now.
    /// </summary>
    private string _currency = string.Empty;
    private decimal? _fxRate;
    private string _memo = string.Empty;
    // Editable invoice number. Pre-filled with the peeked next auto number
    // on a new invoice; on edit it shows the assigned number (read-only).
    private string _invoiceNumber = string.Empty;
    // Free-text billing / shipping address. Pre-filled from the selected
    // customer (OnCustomerSelected) or the source on edit/copy; editable.
    private string _billingAddress = string.Empty;
    private string _shippingAddress = string.Empty;
    private string _customerPoNumber = string.Empty;
    /// <summary>
    /// Back-link to the source Sales Order, populated when the page is
    /// opened via "Invoice this SO" (FromSalesOrderId query param). Sent
    /// to the backend on save so M3 iter 3's auto-COGS bridge can find
    /// the SalesIssue tied to this SO.
    /// </summary>
    private Guid? _salesOrderId;
    private string? _salesOrderNumber;
    /// <summary>
    /// UI-side per-line state. Carries the wire-shape fields plus the
    /// item-picker's <see cref="ItemId"/> / <see cref="ItemDisplay"/> so
    /// the picker on each row can render a stable "selected" state across
    /// re-renders. Submit projects this list back into <see cref="DocumentLineDraft"/>
    /// (the wire shape) — ItemId is informational for now; pre-fill of
    /// unit price / account from the item master is a future iteration.
    /// </summary>
    private sealed record InvoiceLineEditState(
        Guid ItemId = default,
        string ItemDisplay = "",
        string Description = "",
        decimal Quantity = 1m,
        decimal UnitPrice = 0m,
        Guid? AccountId = null,
        string AccountDisplay = "",
        string AccountCode = "",
        Guid? TaxCodeId = null,
        string TaxCode = "",
        Guid? TaxCodeSetId = null,
        // Back-link to the Task this line bills. Set on every line when
        // the page is opened via "Bill this task" (FromTaskId path). The
        // submit projection passes it to the wire shape so the post
        // handler can flip the source tasks Completed -> Billed.
        Guid? TaskId = null)
    {
        public bool HasContent =>
            ItemId != Guid.Empty
            || AccountId is not null
            || !string.IsNullOrWhiteSpace(Description)
            || !string.IsNullOrWhiteSpace(AccountCode)
            || !string.IsNullOrWhiteSpace(TaxCode)
            || UnitPrice > 0m;
    }

    private readonly List<InvoiceLineEditState> _lines = new() { new InvoiceLineEditState() };
    private bool _isSubmitting;
    private string? _validation;
    private WriteFlowResult? _lastResult;
    // Copy A3 Phase 2: drives the "This is a copy" banner. Set true
    // by TryHydrateFromCopySourceAsync when ?copyFrom={id} succeeds.
    private bool _isFromCopy;

    // Item + account caches let the Item picker auto-fill each line's revenue
    // account without a per-pick round-trip. Loaded once on page init; stale
    // entries fall back to "missing account" and surface the validation error.
    private Dictionary<Guid, ItemSummary> _itemsById = new();
    private Dictionary<Guid, AccountSummary> _accountsById = new();
    // UOM lookup: drives the Task-prefill rounding (qty precision follows
    // the picked item's UOM). Default 2 when the item has no UOM or the
    // master couldn't be loaded — lets fractional hour-based services
    // through instead of force-flooring to integer.
    private Dictionary<string, UomSummary> _uomsByCode = new(StringComparer.OrdinalIgnoreCase);
    private const int DefaultUomPrecision = 2;

    private decimal _total => _lines.Sum(l => l.Quantity * l.UnitPrice);

    // R2: Tax Codes (bundles) for the per-line tax dropdown (Code-only).
    private IReadOnlyList<TaxCodeSetSummary> _taxCodeSets = Array.Empty<TaxCodeSetSummary>();

    // Live tax preview for the Summary: each selected Tax Code is split
    // into its Tax Rules (GST, PST, …) and summed across lines. Mirrors
    // the engine's per-rule split (rate × line amount; a compound rule
    // builds on the running base) so the operator sees the breakdown
    // before posting. The engine recomputes the authoritative amounts.
    private IReadOnlyList<(string RuleCode, decimal Amount)> _taxByRule
    {
        get
        {
            var totals = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);
            var order = new List<string>();
            foreach (var line in _lines)
            {
                if (line.TaxCodeSetId is not { } setId) continue;
                var set = _taxCodeSets.FirstOrDefault(s => s.Id == setId);
                if (set is null || set.Members.Count == 0) continue;
                var lineAmount = line.Quantity * line.UnitPrice;
                if (lineAmount <= 0m) continue;
                var compoundBase = lineAmount;
                foreach (var rule in set.Members.OrderBy(m => m.Sequence))
                {
                    var taxable = rule.IsCompound ? compoundBase : lineAmount;
                    var amount = Math.Round(taxable * rule.RatePercent / 100m, 2, MidpointRounding.AwayFromZero);
                    if (!totals.ContainsKey(rule.RuleCode))
                    {
                        totals[rule.RuleCode] = 0m;
                        order.Add(rule.RuleCode);
                    }
                    totals[rule.RuleCode] += amount;
                    if (rule.IsCompound) compoundBase += amount;
                }
            }
            return order.Select(c => (c, totals[c])).ToList();
        }
    }

    private decimal _taxTotal => _taxByRule.Sum(t => t.Amount);

    protected override async Task OnInitializedAsync()
    {
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;
        var items = await ItemClient.ListAsync(includeInactive: false);
        _itemsById = items.ToDictionary(i => i.Id);
        var accounts = await AccountClient.ListAsync();
        _accountsById = accounts.ToDictionary(a => a.Id);
        var uoms = await UomClient.ListAsync(includeInactive: false);
        _uomsByCode = uoms.ToDictionary(u => u.Code, StringComparer.OrdinalIgnoreCase);
        _taxCodeSets = await TaxCodeSetClient.ListAsync(appliesTo: "sales");

        if (FromSalesOrderId is { } soId && soId != Guid.Empty)
        {
            await PrefillFromSalesOrderAsync(soId);
        }
        else if (FromTaskId is { } taskId && taskId != Guid.Empty)
        {
            await PrefillFromTaskAsync(taskId);
        }
        else if (CopyFromInvoiceId is { } copyId && copyId != Guid.Empty)
        {
            await PrefillFromCopySourceAsync(copyId);
        }
        else if (InvoiceId is { } editId && editId != Guid.Empty)
        {
            await PrefillFromEditSourceAsync(editId);
        }

        // New invoice (incl. copy / from-SO / from-task): pre-fill the
        // editable Invoice # with the system's next auto number. Edit keeps
        // the already-assigned number (set in PrefillFromEditSourceAsync).
        if (_editInvoiceId is null)
        {
            _invoiceNumber = await InvoiceClient.PeekNextNumberAsync(ShellState.ActiveCompany.Id) ?? string.Empty;
        }
    }

    /// <summary>
    /// Copy A3 Phase 2: pre-fills the form from an existing invoice
    /// (called via the More → Copy flow on InvoiceDetailPage). The
    /// new invoice is fully independent of the source — there's no
    /// FK link and no JE provenance. Defaults that intentionally
    /// differ from a verbatim copy:
    ///   - Document date  → today
    ///   - Due date       → today + 30 days (reset; carrying the
    ///                      source's due date would yield a date
    ///                      already in the past for stale invoices)
    ///   - FX rate        → null (re-resolved for today)
    ///   - Customer PO #  → blank (PO #s are per-occurrence)
    ///   - Sales Order    → not carried (we're not refulfilling an SO)
    ///   - Memo           → copied (describes the deliverable)
    ///   - Lines          → copied (item/account/qty/unit price/tax)
    ///   - Task back-link → NOT copied (source task may already be
    ///                      Billed/Closed; a new bill needs an
    ///                      explicit operator decision on attribution)
    /// </summary>
    private async Task PrefillFromCopySourceAsync(Guid sourceInvoiceId)
    {
        InvoiceRecordDto? source;
        try
        {
            source = await InvoiceClient.GetByIdAsync(sourceInvoiceId, ShellState.ActiveCompany.Id);
        }
        catch
        {
            return;
        }
        if (source is null)
        {
            _validation = "The invoice you copied from is not visible in this company. The form is blank.";
            return;
        }

        var customer = await CustomerClient.GetByIdAsync(source.CustomerId);
        _isFromCopy = true;
        _customerId = source.CustomerId;
        _customerDisplay = customer?.DisplayName ?? string.Empty;
        _currency = source.TransactionCurrencyCode;
        _documentDate = DateTime.Today;
        _dueDate = DateTime.Today.AddDays(30);
        _fxRate = null;
        _memo = source.Memo ?? string.Empty;
        _billingAddress = source.BillingAddress ?? string.Empty;
        _shippingAddress = source.ShippingAddress ?? string.Empty;
        _customerPoNumber = string.Empty;
        _salesOrderId = null;
        _salesOrderNumber = null;

        // Note: InvoiceLineDto exposes only the resolved TaxAmount, not
        // the source tax-code id, so we can't carry per-line tax codes
        // across a copy without widening the read DTO. For Phase 2 we
        // accept that tradeoff — operator re-picks tax on the new
        // invoice (which is anyway sensible: rates may have changed
        // since the original).
        _lines.Clear();
        foreach (var line in source.Lines.OrderBy(l => l.LineNumber))
        {
            var accountDisplay = line.RevenueAccountId is { } rid && _accountsById.TryGetValue(rid, out var acct)
                ? $"{acct.Code}  {acct.Name}"
                : string.Empty;
            var accountCode = line.RevenueAccountId is { } rid2 && _accountsById.TryGetValue(rid2, out var acct2)
                ? acct2.Code
                : string.Empty;
            _lines.Add(new InvoiceLineEditState(
                ItemId: Guid.Empty,
                ItemDisplay: string.Empty,
                Description: line.Description ?? string.Empty,
                Quantity: line.Quantity,
                UnitPrice: line.UnitPrice,
                AccountId: line.RevenueAccountId,
                AccountDisplay: accountDisplay,
                AccountCode: accountCode,
                TaxCodeId: null,   // see comment above
                TaxCode: string.Empty,
                TaskId: null));    // Task back-link NOT copied — see doc
        }
        if (_lines.Count == 0) _lines.Add(new InvoiceLineEditState());

        _header = _header with
        {
            Title = "New invoice (copy)",
            Subtitle = $"Pre-filled from {source.DisplayNumber}. The original invoice is unchanged."
        };
    }

    /// <summary>
    /// Edit mode (/invoices/{id}/edit): load an existing DRAFT into the
    /// form, keeping its id / number / dates / PO / SO so a save updates
    /// the same draft in place (PUT) instead of creating a new one.
    /// v1 limitation: the invoice read DTO doesn't surface per-line tax
    /// codes, so the tax dropdown loads empty and the operator re-picks.
    /// </summary>
    private async Task PrefillFromEditSourceAsync(Guid invoiceId)
    {
        InvoiceRecordDto? source;
        try
        {
            source = await InvoiceClient.GetByIdAsync(invoiceId, ShellState.ActiveCompany.Id);
        }
        catch
        {
            _validation = "Could not load this invoice for editing.";
            return;
        }
        if (source is null)
        {
            _validation = "This invoice is not visible in the active company.";
            return;
        }
        if (source.Status != "draft")
        {
            _validation = $"Only draft invoices can be edited (this one is '{source.Status}').";
            return;
        }

        _editInvoiceId = source.Id;
        _invoiceNumber = source.DisplayNumber;
        _billingAddress = source.BillingAddress ?? string.Empty;
        _shippingAddress = source.ShippingAddress ?? string.Empty;

        var customer = await CustomerClient.GetByIdAsync(source.CustomerId);
        _customerId = source.CustomerId;
        _customerDisplay = customer?.DisplayName ?? string.Empty;
        _currency = source.TransactionCurrencyCode;
        _documentDate = source.DocumentDate.ToDateTime(TimeOnly.MinValue);
        _dueDate = source.DueDate?.ToDateTime(TimeOnly.MinValue);
        _fxRate = null;
        _memo = source.Memo ?? string.Empty;
        _customerPoNumber = source.CustomerPoNumber ?? string.Empty;
        _salesOrderId = source.SalesOrderId;
        _salesOrderNumber = null;

        _lines.Clear();
        foreach (var line in source.Lines.OrderBy(l => l.LineNumber))
        {
            var accountDisplay = line.RevenueAccountId is { } rid && _accountsById.TryGetValue(rid, out var acct)
                ? $"{acct.Code}  {acct.Name}"
                : string.Empty;
            var accountCode = line.RevenueAccountId is { } rid2 && _accountsById.TryGetValue(rid2, out var acct2)
                ? acct2.Code
                : string.Empty;
            _lines.Add(new InvoiceLineEditState(
                ItemId: Guid.Empty,
                ItemDisplay: string.Empty,
                Description: line.Description ?? string.Empty,
                Quantity: line.Quantity,
                UnitPrice: line.UnitPrice,
                AccountId: line.RevenueAccountId,
                AccountDisplay: accountDisplay,
                AccountCode: accountCode,
                TaxCodeId: null,            // read DTO doesn't surface tax codes yet — operator re-picks (v1)
                TaxCode: string.Empty,
                TaskId: line.TaskId));
        }
        if (_lines.Count == 0) _lines.Add(new InvoiceLineEditState());

        _header = _header with
        {
            Title = $"Edit invoice {source.DisplayNumber}",
            Subtitle = "Update this draft. Saving keeps it a draft — post it from the detail page."
        };
    }

    /// <summary>
    /// Pre-fills the form from a Completed task. Mirrors the SO prefill
    /// pattern: header carries customer + currency + memo, lines mirror
    /// the task's lines (best-effort revenue-account resolve from item
    /// master), and every line is stamped with TaskId so the post
    /// handler can flip the task Completed -> Billed.
    /// </summary>
    private async Task PrefillFromTaskAsync(Guid taskId)
    {
        var task = await TaskClient.GetAsync(taskId);
        if (task is null)
        {
            await Message.WarningAsync("Source task not found in this company; starting a blank invoice.");
            return;
        }

        if (task.Status != TaskStatus.Completed)
        {
            await Message.WarningAsync(
                $"Task {task.TaskNo} is in status '{task.Status}' and cannot be billed. Only completed tasks can build an invoice.");
            return;
        }

        if (task.CustomerId is null)
        {
            await Message.WarningAsync(
                $"Task {task.TaskNo} has no customer assigned; set one on the task before billing.");
            return;
        }

        // Header pre-fill — fetch the customer summary to populate the
        // display name + currency. Falls back to task currency if the
        // customer fetch fails (best-effort).
        var customer = await CustomerClient.GetByIdAsync(task.CustomerId.Value);
        _customerId = task.CustomerId.Value;
        _customerDisplay = customer?.DisplayName ?? string.Empty;
        _currency = customer?.DefaultCurrencyCode ?? task.CurrencyCode;
        _memo = task.Description?.Trim() ?? string.Empty;

        _header = _header with
        {
            Title = $"New invoice from task {task.TaskNo}",
            Subtitle = $"Pre-filled from task {task.TaskNo}. Review and post — posting flips the task to Billed."
        };

        // Tax codes loaded only on this path so the display labels in
        // the per-line tax picker render correctly. Same pattern as
        // PrefillFromSalesOrderAsync.
        Dictionary<Guid, TaxCodeSummary> taxById;
        try
        {
            var taxCodes = await TaxCodeClient.ListAsync(appliesTo: "sales");
            taxById = taxCodes.ToDictionary(t => t.Id);
        }
        catch
        {
            taxById = new Dictionary<Guid, TaxCodeSummary>();
        }

        _lines.Clear();
        foreach (var line in task.Lines.OrderBy(l => l.LineNo))
        {
            string itemDisplay = string.Empty;
            Guid? accountId = null;
            string accountCode = string.Empty;
            string accountDisplay = string.Empty;

            if (_itemsById.TryGetValue(line.ItemId, out var item))
            {
                itemDisplay = item.Name;
                if (item.DefaultSalesRevenueAccountId is { } itemAccountId
                    && _accountsById.TryGetValue(itemAccountId, out var account))
                {
                    accountId = account.Id;
                    accountCode = account.Code;
                    accountDisplay = $"{account.Code} {account.Name}";
                }
            }

            string taxDisplay = string.Empty;
            if (line.TaxCodeId is { } taxId && taxById.TryGetValue(taxId, out var tax))
            {
                taxDisplay = tax.Code;
            }

            // task_lines columns are numeric(20,4) so DB always returns scale 4
            // even when the operator entered an integer ("2.0000") or 2-dp value
            // ("60.0000"). RadzenNumeric falls back to the decimal's native scale
            // for display, so without rounding the grid surfaces "2.0000" /
            // "60.0000". Use the item's UOM precision to round qty (hours stay
            // fractional, "each" floors to integer); price always rounds to 2
            // decimals (CAD/USD billing convention).
            var qtyPrecision = DefaultUomPrecision;
            if (_itemsById.TryGetValue(line.ItemId, out var pickedItem)
                && !string.IsNullOrWhiteSpace(pickedItem.StockUomCode)
                && _uomsByCode.TryGetValue(pickedItem.StockUomCode!, out var uom))
            {
                qtyPrecision = uom.DecimalPrecision;
            }
            _lines.Add(new InvoiceLineEditState(
                ItemId: line.ItemId,
                ItemDisplay: itemDisplay,
                Description: line.Description ?? string.Empty,
                Quantity: Math.Round(line.Quantity, qtyPrecision, MidpointRounding.AwayFromZero),
                UnitPrice: Math.Round(line.UnitPrice, 2, MidpointRounding.AwayFromZero),
                AccountId: accountId,
                AccountDisplay: accountDisplay,
                AccountCode: accountCode,
                TaxCodeId: line.TaxCodeId,
                TaxCode: taxDisplay,
                TaskId: task.Id));
        }

        if (_lines.Count == 0 || _lines[^1].HasContent)
        {
            _lines.Add(new InvoiceLineEditState(TaskId: task.Id));
        }
    }

    /// <summary>
    /// Pre-fills the form from an existing Sales Order. Best-effort:
    /// missing items / accounts / tax codes leave their respective
    /// per-line cells blank rather than blocking the whole prefill, and
    /// the operator sees the inline validation when they go to post.
    /// </summary>
    private async Task PrefillFromSalesOrderAsync(Guid salesOrderId)
    {
        var so = await SalesOrderClient.GetByIdAsync(salesOrderId);
        if (so is null)
        {
            await Message.WarningAsync("Source sales order not found in this company; starting a blank invoice.");
            return;
        }

        // Header pre-fill
        _customerId = so.CustomerId;
        _customerDisplay = so.CustomerName;
        _currency = so.TransactionCurrencyCode;
        _fxRate = so.FxRate;
        _customerPoNumber = so.CustomerPoNumber ?? string.Empty;
        _salesOrderId = so.Id;
        _salesOrderNumber = so.SalesOrderNumber;
        _memo = so.MemoToCustomer ?? string.Empty;

        _header = _header with
        {
            Title = $"New invoice from {so.SalesOrderNumber}",
            Subtitle = $"Pre-filled from {so.SalesOrderNumber} for {so.CustomerName}. Review and post."
        };

        // Tax codes are loaded only on this path so the display labels in
        // the per-line tax picker render correctly. Normal "blank invoice"
        // start skips this round-trip.
        Dictionary<Guid, TaxCodeSummary> taxById;
        try
        {
            var taxCodes = await TaxCodeClient.ListAsync(appliesTo: "sales");
            taxById = taxCodes.ToDictionary(t => t.Id);
        }
        catch
        {
            taxById = new Dictionary<Guid, TaxCodeSummary>();
        }

        // Lines pre-fill — replace the seeded blank line with the SO lines.
        _lines.Clear();
        foreach (var soLine in so.Lines.OrderBy(l => l.Sequence))
        {
            var itemId = soLine.ItemId ?? Guid.Empty;
            string itemDisplay = string.Empty;
            Guid? accountId = null;
            string accountCode = string.Empty;
            string accountDisplay = string.Empty;

            if (itemId != Guid.Empty && _itemsById.TryGetValue(itemId, out var item))
            {
                itemDisplay = item.Name;
                if (item.DefaultSalesRevenueAccountId is { } itemAccountId
                    && _accountsById.TryGetValue(itemAccountId, out var account))
                {
                    accountId = account.Id;
                    accountCode = account.Code;
                    accountDisplay = $"{account.Code} {account.Name}";
                }
            }

            string taxDisplay = string.Empty;
            if (soLine.TaxCodeId is { } taxId && taxById.TryGetValue(taxId, out var tax))
            {
                taxDisplay = tax.Code;
            }

            _lines.Add(new InvoiceLineEditState(
                ItemId: itemId,
                ItemDisplay: itemDisplay,
                Description: soLine.Description ?? string.Empty,
                Quantity: soLine.Quantity,
                UnitPrice: soLine.UnitPrice,
                AccountId: accountId,
                AccountDisplay: accountDisplay,
                AccountCode: accountCode,
                TaxCodeId: soLine.TaxCodeId,
                TaxCode: taxDisplay));
        }

        // Always keep one trailing blank line so the operator can append
        // an extra line (shipping, surcharge, etc.) without re-clicking
        // "Add line".
        if (_lines.Count == 0 || _lines[^1].HasContent)
        {
            _lines.Add(new InvoiceLineEditState());
        }
    }

    private async Task OnCustomerSelected(UnitySearchPickerOption option)
    {
        _customerId = option.SourceId;
        _customerDisplay = option.DisplayText;

        // Best-effort lookup. Transient failure leaves _currency on its
        // previous value (base or the previous customer's default) — the
        // operator can re-pick to retry. The invoice can't post without
        // a valid customer id either way.
        var customer = await CustomerClient.GetByIdAsync(_customerId);
        if (customer is not null)
        {
            if (!string.IsNullOrWhiteSpace(customer.DefaultCurrencyCode))
            {
                _currency = customer.DefaultCurrencyCode;
            }
            // Pre-fill both addresses from the customer; the operator can edit
            // (e.g. a different ship-to) per invoice.
            var formatted = FormatCustomerAddress(customer);
            if (!string.IsNullOrWhiteSpace(formatted))
            {
                _billingAddress = formatted;
                _shippingAddress = formatted;
            }
        }
    }

    private static string FormatCustomerAddress(CustomerSummary c)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(c.AddressLine)) parts.Add(c.AddressLine!.Trim());
        var locality = string.Join(" ", new[] { c.City, c.ProvinceState, c.PostalCode }
            .Where(static s => !string.IsNullOrWhiteSpace(s)).Select(static s => s!.Trim()));
        if (!string.IsNullOrWhiteSpace(locality)) parts.Add(locality);
        if (!string.IsNullOrWhiteSpace(c.Country)) parts.Add(c.Country!.Trim());
        return string.Join("\n", parts);
    }

    private void OnCustomerCleared()
    {
        _customerId = Guid.Empty;
        _customerDisplay = string.Empty;
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;
    }

    private void AddLine() => _lines.Add(new InvoiceLineEditState());

    private void RemoveLine(int i)
    {
        if (i < 0 || i >= _lines.Count) return;
        _lines.RemoveAt(i);
        // Always keep at least one row so the operator has somewhere to
        // type. The auto-grow rule below relies on the LAST row being
        // the "blank trailer" — removing it would strand the table.
        if (_lines.Count == 0) _lines.Add(new InvoiceLineEditState());
    }

    private void InsertLineAfter(int i)
    {
        if (i < 0 || i >= _lines.Count) return;
        _lines.Insert(i + 1, new InvoiceLineEditState());
    }

    private void Update(int i, Func<InvoiceLineEditState, InvoiceLineEditState> mutate)
    {
        if (i < 0 || i >= _lines.Count) return;
        _lines[i] = mutate(_lines[i]);
        EnsureTrailingBlankLine();
    }

    /// <summary>
    /// Appends a fresh blank line whenever the user has filled content
    /// into the previously-trailing row. Mirrors the JE create page's
    /// auto-grow UX: operator types into the last row → another blank
    /// row appears at the bottom → keep going. Removes the need to hunt
    /// for "Add line" mid-flow.
    /// </summary>
    private void EnsureTrailingBlankLine()
    {
        if (_lines.Count == 0)
        {
            _lines.Add(new InvoiceLineEditState());
            return;
        }
        if (_lines[^1].HasContent)
        {
            _lines.Add(new InvoiceLineEditState());
        }
    }

    private void OnItemPicked(int i, UnitySearchPickerOption option)
    {
        // Auto-fill the line's revenue account from the picked item's
        // DefaultSalesRevenueAccountId. Sales lines have no manual Account
        // column — the item is the single source of truth. If the item
        // (or its account) is missing locally, we leave Account fields
        // blank and the inline error / submit-time validation guides the
        // operator to fix the item master.
        var (accountId, accountCode, accountDisplay) = ResolveItemAccount(option.SourceId);
        Update(i, l => l with
        {
            ItemId = option.SourceId,
            ItemDisplay = option.DisplayText,
            Description = string.IsNullOrWhiteSpace(l.Description) ? option.PrimaryText : l.Description,
            AccountId = accountId,
            AccountCode = accountCode,
            AccountDisplay = accountDisplay,
        });
    }

    private void OnItemCleared(int i)
    {
        // Clear only the item; keep the Category (account) + description so an
        // item-less line stands on its own (Item is optional now).
        Update(i, l => l with
        {
            ItemId = Guid.Empty,
            ItemDisplay = string.Empty,
        });
    }

    // Resting-state label for the Category AccountPicker so a pre-filled /
    // loaded line shows the account before the picker fetches its own chart.
    private string? GetAccountLabel(Guid? id) =>
        id is { } accountId && _accountsById.TryGetValue(accountId, out var a)
            ? $"{a.Code}  {a.Name}"
            : null;

    private (Guid? AccountId, string AccountCode, string AccountDisplay) ResolveItemAccount(Guid itemId)
    {
        if (!_itemsById.TryGetValue(itemId, out var item) || !item.DefaultSalesRevenueAccountId.HasValue)
        {
            return (null, string.Empty, string.Empty);
        }
        var accountId = item.DefaultSalesRevenueAccountId.Value;
        if (!_accountsById.TryGetValue(accountId, out var account))
        {
            return (accountId, string.Empty, string.Empty);
        }
        return (accountId, account.Code, $"{account.Code} {account.Name}");
    }


    private async Task PostAsync()
    {
        _validation = null;
        _lastResult = null;

        if (_customerId == Guid.Empty) { _validation = "Pick a customer first."; return; }

        // Drop any trailing blank lines the auto-grow heuristic left behind
        // before validating — they're scaffolding, not user intent.
        var meaningful = _lines.Where(l => l.HasContent).ToArray();
        if (meaningful.Length == 0) { _validation = "Add at least one invoice line."; return; }
        if (meaningful.Any(l => string.IsNullOrWhiteSpace(l.Description))) { _validation = "Every line needs a description."; return; }
        if (meaningful.Any(l => l.AccountId is null)) { _validation = "Every line needs a Category (income account). Pick a Category, or an Item / Service to fill it."; return; }
        var total = meaningful.Sum(l => l.Quantity * l.UnitPrice);
        if (total <= 0) { _validation = "Invoice total must be greater than zero."; return; }

        _isSubmitting = true;
        try
        {
            var draft = new InvoiceDraft
            {
                CompanyId = ShellState.ActiveCompany.Id,
                UserId = ShellState.User.Id,
                DocumentDate = DateOnly.FromDateTime((_documentDate ?? DateTime.Today).Date),
                DueDate = _dueDate.HasValue ? DateOnly.FromDateTime(_dueDate.Value.Date) : null,
                CustomerId = _customerId,
                TransactionCurrencyCode = _currency.Trim().ToUpperInvariant(),
                BaseCurrencyCode = ShellState.ActiveCompany.BaseCurrencyCode.Trim().ToUpperInvariant(),
                FxRate = _fxRate,
                Memo = _memo.Trim(),
                InvoiceNumber = string.IsNullOrWhiteSpace(_invoiceNumber) ? null : _invoiceNumber.Trim(),
                BillingAddress = string.IsNullOrWhiteSpace(_billingAddress) ? null : _billingAddress.Trim(),
                ShippingAddress = string.IsNullOrWhiteSpace(_shippingAddress) ? null : _shippingAddress.Trim(),
                CustomerPoNumber = _customerPoNumber.Trim(),
                SalesOrderId = _salesOrderId,
                Lines = meaningful.Select((l, idx) => new InvoiceLineDraft
                {
                    LineNumber = idx + 1,
                    RevenueAccountId = l.AccountId!.Value,
                    Description = l.Description,
                    Quantity = l.Quantity,
                    UnitPrice = l.UnitPrice,
                    TaxCodeId = l.TaxCodeId,
                    TaxCodeSetId = l.TaxCodeSetId,
                    TaxAmount = 0m, // Tax computed server-side from tax_code rate; client doesn't push a computed amount.
                    TaskId = l.TaskId,
                }).ToArray()
            };
            _lastResult = _editInvoiceId is { } editId
                ? await WriteFlow.UpdateInvoiceDraftAsync(editId, draft)
                : await WriteFlow.PostInvoiceAsync(draft);
            if (_lastResult.Succeeded)
            {
                // Use the composed message — includes "Invoice INV-XXXX posted"
                // plus auto-COGS JE numbers (M3 iter 3) so the operator sees
                // the full set of journal entries that just landed.
                await Message.SuccessAsync(_lastResult.Message);
                NavigationManager.NavigateTo(_lastResult.DocumentId is { } id
                    ? $"invoices/{id:D}"
                    : "invoices");
            }
            else
            {
                await Message.InfoAsync(_lastResult.Message);
            }
        }
        finally { _isSubmitting = false; }
    }

    private static string FormatAmount(decimal amount) => amount.ToString("N2");
}
