@*
    InvoiceActionBar — flat sticky bottom bar (NO card / no radius / no shadow).
    Left: Print-or-download / Make-recurring (TODO). Right: Review-and-send
    (TODO) + the REAL primary Save, which forwards to the parent's PostAsync
    with the same label / disabled / saving semantics as before.
*@

<div class="invoice-action-bar">
    <div class="invoice-action-bar__group">
        @* TODO: not in invoice model — no PDF/print or recurring flow yet. *@
        <CitusButton Variant="CitusButtonVariant.Ghost" Size="CitusButtonSize.Small" Disabled="true" LeadingIcon="IconName.Download" Class="invoice-todo">Print or download</CitusButton>
        <CitusButton Variant="CitusButtonVariant.Ghost" Size="CitusButtonSize.Small" Disabled="true" Class="invoice-todo">Make recurring</CitusButton>
    </div>
    <div class="invoice-action-bar__group">
        @if (!string.IsNullOrWhiteSpace(ErrorHint))
        {
            <span class="invoice-action-bar__hint">@ErrorHint</span>
        }
        @* TODO: not in invoice model — no send flow yet. *@
        <CitusButton Variant="CitusButtonVariant.Ghost" Size="CitusButtonSize.Small" Disabled="true" Class="invoice-todo">Review and send</CitusButton>
        <CitusButton Variant="CitusButtonVariant.Primary" Disabled="@Disabled" Loading="@IsSaving" OnClick="OnSave">
            @(EditInvoiceId is null ? "Post invoice" : "Save draft")
        </CitusButton>
    </div>
</div>

@code {
    [Parameter] public Guid? EditInvoiceId { get; set; }
    [Parameter] public bool IsSaving { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? ErrorHint { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
}
