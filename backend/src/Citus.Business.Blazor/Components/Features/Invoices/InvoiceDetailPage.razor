@page "/invoices/{InvoiceId:guid}"

@inject BusinessShellState ShellState
@inject InvoiceClient InvoiceClient
@inject BusinessWriteFlowClient WriteFlow
@inject AccountClient AccountClient
@inject CustomerClient CustomerClient
@inject CitusToastService Message
@inject NavigationManager Navigation

@*
    InvoiceDetailPage — read-only detail surface for a posted invoice.
    Mirrors BillDetailPage's structure on purpose (stat-card row,
    actions bar, line table, sidebar with Document + Totals) so the
    sales / expense detail surfaces feel like one design language.

    Differences from the bill twin:
      • Sales-side terminology (Customer / receivable / invoice number)
      • Lifecycle hint copy reflects AR semantics ("Awaiting payment"
        vs "Awaiting payment", "partially_paid" → "Some receipts
        received", etc.)
      • Lines render Quantity × Unit price (the wire shape) since the
        invoice line model exposes those, where bill lines collapsed
        to a single LineAmount.
*@

<PageTitle>@($"{_pageTitle} | Tralanz Books")</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <a class="citus-button citus-button--ghost" href="invoices">
            <CitusIcon Name="IconName.ArrowLeft" Size="IconSize.Inline" />
            <span>Back to invoices</span>
        </a>
    </Actions>
</CitusPageHeader>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_error" ShowIcon="true" Class="mb-4" />
}

@if (_isLoading)
{
    <CitusSkeleton Variant="SkeletonVariant.Detail" />
}
else if (_invoice is null)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="Invoice not found in this company." ShowIcon="true" />
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <CitusStatCard Label="Invoice #" Value="@_invoice.DisplayNumber" Description="@_customerName"
                       Icon="IconName.FileInvoice" Tone="StatTone.Primary" />
        <CitusStatCard Label="Status" Value="@HumanizeStatus(_invoice.Status)" Description="@StatusHint(_invoice.Status)"
                       Icon="IconName.Eye" Tone="@StatusTone(_invoice.Status)" />
        <CitusStatCard Label="Total" Value="@($"{_invoice.TotalAmount:N2} {_invoice.TransactionCurrencyCode}")"
                       Description="@($"Subtotal {_invoice.SubtotalAmount:N2} + tax {_invoice.TaxAmount:N2}")"
                       Icon="IconName.Coin" Tone="StatTone.Success" />
        <CitusStatCard Label="@(_invoice.DueDate.HasValue ? "Due" : "Receipt")"
                       Value="@(_invoice.DueDate?.ToString("yyyy-MM-dd") ?? "On receipt")"
                       Description="@($"Issued {_invoice.DocumentDate:yyyy-MM-dd}")"
                       Icon="IconName.Calendar" Tone="StatTone.Neutral" />
    </div>

    <AiseFormSection Title="Actions" Class="mb-6">
        <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <span class="text-fg-muted text-sm">@ActionHint(_invoice.Status)</span>
            <AiseButtonGroup Align="end">
                @if (_invoice.Status == "draft")
                {
                    <a class="citus-button citus-button--ghost" href="@($"invoices/{_invoice.Id:D}/edit")">
                        <CitusIcon Name="IconName.Pencil" Size="IconSize.Inline" />
                        <span>Edit</span>
                    </a>
                    <CitusButton Variant="CitusButtonVariant.Primary"
                                 LeadingIcon="IconName.Check"
                                 Disabled="@(_isMutating || ShellState.AreWritesBlocked)"
                                 Loading="@_isMutating"
                                 OnClick="PostAsync">
                        @(_isMutating ? "Posting..." : "Post")
                    </CitusButton>
                }
                else if (_invoice.Status == "posted" || _invoice.Status == "partially_paid")
                {
                    <a class="citus-button citus-button--primary" href="receive-payment">
                        <CitusIcon Name="IconName.Cash" Size="IconSize.Inline" />
                        <span>Receive payment</span>
                    </a>
                    <a class="citus-button citus-button--ghost" href="@($"sales-receipts/new")">Issue credit memo</a>
                }
                @if (CanVoid(_invoice.Status))
                {
                    <AiseConfirmDangerAction Label="Void"
                                             Disabled="@_isMutating"
                                             ConfirmMessage="@VoidConfirmMessage(_invoice.Status)"
                                             OnConfirmed="VoidAsync" />
                }
            </AiseButtonGroup>
        </div>
    </AiseFormSection>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-8">
            <AiseFormSection Title="Lines">
                <table class="citus-data-table">
                    <thead>
                        <tr>
                            <th style="width: 3rem">#</th>
                            <th>Account</th>
                            <th>Description</th>
                            <th class="text-right" style="width: 5rem">Qty</th>
                            <th class="text-right" style="width: 8rem">Unit price</th>
                            <th class="text-right" style="width: 8rem">Tax</th>
                            <th class="text-right" style="width: 9rem">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in _invoice.Lines)
                        {
                            <tr>
                                <td>@line.LineNumber</td>
                                <td>@ResolveAccountLabel(line.RevenueAccountId)</td>
                                <td>@(string.IsNullOrEmpty(line.Description) ? "—" : line.Description)</td>
                                <td class="text-right">@line.Quantity.ToString("0.##")</td>
                                <td class="text-right">@line.UnitPrice.ToString("N2")</td>
                                <td class="text-right">@line.TaxAmount.ToString("N2")</td>
                                <td class="text-right">@line.LineAmount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </AiseFormSection>

            @if (!string.IsNullOrWhiteSpace(_invoice.Memo))
            {
                <AiseFormSection Title="Memo" Class="mt-6">
                    <p class="text-fg-muted text-sm">@_invoice.Memo</p>
                </AiseFormSection>
            }
        </div>

        <aside class="lg:col-span-4 flex flex-col gap-6">
            <AiseFormSection Title="Document">
                <table class="citus-keyvalue">
                    <tbody>
                        <tr><th>Invoice no.</th><td><span class="citus-inline-code">@_invoice.DisplayNumber</span></td></tr>
                        <tr><th>Internal #</th><td><span class="citus-inline-code">@_invoice.EntityNumber</span></td></tr>
                        <tr><th>Document date</th><td>@_invoice.DocumentDate.ToString("yyyy-MM-dd")</td></tr>
                        @if (_invoice.DueDate is { } due)
                        {
                            <tr><th>Due date</th><td>@due.ToString("yyyy-MM-dd")</td></tr>
                        }
                        <tr><th>Currency</th><td>@_invoice.TransactionCurrencyCode</td></tr>
                        @if (!string.Equals(_invoice.TransactionCurrencyCode, _invoice.BaseCurrencyCode, StringComparison.OrdinalIgnoreCase))
                        {
                            <tr><th>Base currency</th><td>@_invoice.BaseCurrencyCode</td></tr>
                        }
                        <tr><th>Customer</th><td>@_customerName</td></tr>
                        @if (!string.IsNullOrWhiteSpace(_invoice.CustomerPoNumber))
                        {
                            <tr><th>Customer PO #</th><td><span class="citus-inline-code">@_invoice.CustomerPoNumber</span></td></tr>
                        }
                        @if (_invoice.SalesOrderId is { } soId)
                        {
                            <tr><th>From SO</th><td><a class="citus-link" href="@($"sales-orders/{soId:D}")">View source SO</a></td></tr>
                        }
                    </tbody>
                </table>
            </AiseFormSection>

            <AiseFormSection Title="Totals">
                <table class="citus-keyvalue">
                    <tbody>
                        <tr><th>Subtotal</th><td class="text-right">@_invoice.SubtotalAmount.ToString("N2")</td></tr>
                        <tr><th>Tax</th><td class="text-right">@_invoice.TaxAmount.ToString("N2")</td></tr>
                        <tr><th>Total</th><td class="text-right"><strong>@_invoice.TotalAmount.ToString("N2") @_invoice.TransactionCurrencyCode</strong></td></tr>
                    </tbody>
                </table>
            </AiseFormSection>
        </aside>
    </div>
}

@code {
    [Parameter] public Guid InvoiceId { get; set; }

    private InvoiceRecordDto? _invoice;
    private string _customerName = "—";
    private IReadOnlyList<AccountSummary> _accounts = Array.Empty<AccountSummary>();
    private bool _isLoading = true;
    private bool _isMutating;
    private string? _error;

    private PageHeaderModel _header = new() { Eyebrow = "Sales & Get Paid", Title = "Invoice", Subtitle = "Invoice detail" };
    private string _pageTitle = "Invoice";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override async Task OnParametersSetAsync()
    {
        if (_invoice is not null && _invoice.Id != InvoiceId)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            var invoiceTask = InvoiceClient.GetByIdAsync(InvoiceId, ShellState.ActiveCompany.Id);
            var accountsTask = AccountClient.ListAsync();
            await Task.WhenAll(invoiceTask, accountsTask);
            _invoice = invoiceTask.Result;
            _accounts = accountsTask.Result;
            if (_invoice is not null)
            {
                var customer = await CustomerClient.GetByIdAsync(_invoice.CustomerId);
                _customerName = customer?.DisplayName ?? "—";
            }
            ApplyHeader();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally { _isLoading = false; }
    }

    private void ApplyHeader()
    {
        if (_invoice is null)
        {
            _pageTitle = "Invoice";
            _header = new PageHeaderModel { Eyebrow = "Sales & Get Paid", Title = "Invoice", Subtitle = "Invoice detail" };
            return;
        }
        _pageTitle = _invoice.DisplayNumber;
        _header = new PageHeaderModel
        {
            Eyebrow = "Sales & Get Paid",
            Title = _invoice.DisplayNumber,
            Subtitle = $"{_customerName} · {HumanizeStatus(_invoice.Status)}"
        };
    }

    private string ResolveAccountLabel(Guid? accountId)
    {
        if (accountId is null) return "—";
        var account = _accounts.FirstOrDefault(a => a.Id == accountId.Value);
        return account is null ? accountId.Value.ToString("D") : $"{account.Code}  {account.Name}";
    }

    private async Task PostAsync()
    {
        if (_invoice is null || _isMutating) return;
        if (_invoice.Status != "draft")
        {
            _error = "Only draft invoices can be posted from this action.";
            await Message.WarningAsync(_error);
            return;
        }

        _isMutating = true;
        _error = null;
        try
        {
            var outcome = await WriteFlow.PostExistingInvoiceAsync(
                _invoice.Id,
                ShellState.ActiveCompany.Id,
                ShellState.User.Id,
                _invoice.DisplayNumber,
                _invoice.CustomerId,
                BuildTaskBillingLinks(_invoice));

            if (!outcome.Succeeded)
            {
                _error = outcome.Message;
                await Message.WarningAsync(_error);
                return;
            }

            if (outcome.Message.Contains("failed", StringComparison.OrdinalIgnoreCase) ||
                outcome.Message.Contains("could not", StringComparison.OrdinalIgnoreCase))
            {
                await Message.WarningAsync(outcome.Message);
            }
            else
            {
                await Message.SuccessAsync(outcome.Message);
            }

            await LoadAsync();
        }
        finally
        {
            _isMutating = false;
        }
    }

    private async Task VoidAsync()
    {
        if (_invoice is null || _isMutating) return;
        _isMutating = true;
        _error = null;
        try
        {
            var outcome = await InvoiceClient.VoidAsync(_invoice.Id, ShellState.ActiveCompany.Id);
            if (!outcome.Succeeded)
            {
                _error = outcome.ErrorMessage ?? "Void failed.";
                await Message.WarningAsync(_error);
                return;
            }

            _invoice = outcome.Saved;
            ApplyHeader();
            await Message.SuccessAsync("Invoice voided.");
        }
        finally
        {
            _isMutating = false;
        }
    }

    private static bool CanVoid(string status) => status is "draft" or "posted";

    private static IReadOnlyList<InvoiceTaskBillingLink> BuildTaskBillingLinks(InvoiceRecordDto invoice) =>
        invoice.Lines
            .Where(static line => line.TaskId.HasValue && line.TaskLineId.HasValue)
            .Select(static line => new InvoiceTaskBillingLink(
                line.TaskId!.Value,
                line.TaskLineId!.Value,
                line.Id))
            .Distinct()
            .ToArray();

    private static string ActionHint(string status) => status switch
    {
        "draft" => "Review the draft, edit if needed, then post it.",
        "posted" => "Settlement happens in Receive Payment.",
        "partially_paid" => "Settlement happens in Receive Payment.",
        "voided" => "This invoice has no outstanding balance.",
        "reversed" => "This invoice has no outstanding balance.",
        _ => string.Empty
    };

    private static string VoidConfirmMessage(string status) =>
        status == "posted"
            ? "Void this posted invoice? This inserts a reversing journal entry, voids the AR open item, and cannot be undone from this screen."
            : "Void this invoice? This keeps the audit trail and cannot be undone from this screen.";

    private static string HumanizeStatus(string status) => status switch
    {
        "draft" => "Draft",
        "submitted" => "Submitted",
        "posted" => "Posted",
        "partially_paid" => "Partially paid",
        "paid" => "Paid",
        "voided" => "Voided",
        "reversed" => "Reversed",
        _ => status
    };

    private static string StatusHint(string status) => status switch
    {
        "draft" => "Not posted yet.",
        "submitted" => "Awaiting approval / posting.",
        "posted" => "Awaiting payment.",
        "partially_paid" => "Some receipts received.",
        "paid" => "Fully settled.",
        "voided" => "Voided.",
        "reversed" => "Reversed.",
        _ => string.Empty
    };

    private static StatTone StatusTone(string status) => status switch
    {
        "draft" => StatTone.Neutral,
        "submitted" => StatTone.Info,
        "posted" => StatTone.Info,
        "partially_paid" => StatTone.Info,
        "paid" => StatTone.Success,
        "voided" => StatTone.Neutral,
        "reversed" => StatTone.Warning,
        _ => StatTone.Neutral
    };
}
