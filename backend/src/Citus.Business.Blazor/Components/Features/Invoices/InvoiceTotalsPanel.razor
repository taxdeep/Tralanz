@*
    InvoiceTotalsPanel — flat right-aligned totals summary (NO card). Renders
    the parent's already-computed subtotal / per-rule tax / grand total
    (verbatim conditions). Discount / Shipping / Deposit are mockup-only (TODO).
*@

<div class="invoice-totals-panel">
    <div class="invoice-totals-row"><span>Subtotal</span><span>@FormatAmount(Total)</span></div>

    @* TODO: not in invoice model. *@
    <div class="invoice-totals-row invoice-todo"><span>Discount</span><span>—</span></div>
    <div class="invoice-totals-row invoice-todo"><span>Shipping</span><span>—</span></div>

    @* Live per-rule tax preview (GST / PST / …). Engine recomputes on save. *@
    @foreach (var t in TaxByRule)
    {
        <div class="invoice-totals-row"><span>@t.RuleCode</span><span>@FormatAmount(t.Amount)</span></div>
    }

    @if (TaxTotal > 0m)
    {
        <div class="invoice-totals-row invoice-totals-row--grand"><span>Invoice total</span><span>@FormatAmount(Total + TaxTotal) @Currency.ToUpperInvariant()</span></div>
    }

    @* TODO: not in invoice model. *@
    <div class="invoice-totals-row invoice-todo"><span>Deposit</span><span>—</span></div>

    <div class="invoice-totals-row"><span>Currency</span><span>@Currency.ToUpperInvariant()</span></div>
    @if (!string.Equals(Currency, BaseCurrencyCode, StringComparison.OrdinalIgnoreCase))
    {
        <div class="invoice-totals-row"><span>Exchange rate</span><span>@(FxRate.HasValue ? FxRate.Value.ToString("0.000000") : "—")</span></div>
    }
</div>

@code {
    [Parameter] public decimal Total { get; set; }
    [Parameter] public IReadOnlyList<(string RuleCode, decimal Amount)> TaxByRule { get; set; } = Array.Empty<(string, decimal)>();
    [Parameter] public decimal TaxTotal { get; set; }
    [Parameter] public string Currency { get; set; } = string.Empty;
    [Parameter] public decimal? FxRate { get; set; }
    [Parameter] public string BaseCurrencyCode { get; set; } = string.Empty;
    [Parameter, EditorRequired] public Func<decimal, string> FormatAmount { get; set; } = a => a.ToString("N2");
}
