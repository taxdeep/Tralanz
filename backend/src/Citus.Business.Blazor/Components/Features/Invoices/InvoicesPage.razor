@page "/invoices"

@using Radzen
@using Radzen.Blazor

@inject BusinessShellState ShellState

<PageTitle>Invoices | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <a class="citus-button" href="invoices/new">
            <CitusIcon Name="IconName.Plus" Size="IconSize.Inline" />
            <span>New invoice</span>
        </a>
    </Actions>
</CitusPageHeader>

<CitusAlert Severity="CitusAlertSeverity.Info"
                 ShowIcon="true"
                 Message="Invoice list pulls from the existing A/R Aging + Document Review HTTP surface. Posted invoices stay read-only — review opens via the Document drill-down."
                 Class="mb-4" />

<section class="citus-panel">
    <header class="citus-panel__header">
        <h2 class="citus-panel__title">Recent invoices</h2>
        <CitusBadge Color="@("blue")">Read-only review</CitusBadge>
    </header>

    <CitusAsyncBoundary IsLoading="false"
                        IsEmpty="@(_invoices.Count == 0)"
                        EmptyIcon="IconName.FileInvoice"
                        EmptyTitle="No invoices for this company yet"
                        EmptyMessage="Use 'New invoice' to compose one. Posted invoices appear here ordered by document date.">
        <RadzenDataGrid TItem="InvoiceListRow"
                        Data="@_invoices"
                        AllowSorting="true"
                        AllowFiltering="true"
                        AllowColumnResize="true"
                        AllowPaging="true"
                        PageSize="50"
                        FilterMode="FilterMode.Simple"
                        class="citus-radzen-grid">
            <Columns>
                <RadzenDataGridColumn TItem="InvoiceListRow" Property="@nameof(InvoiceListRow.DisplayNumber)" Title="Invoice" Width="180px">
                    <Template Context="invoice">
                        <a class="citus-link" href="@($"documents/invoice/{invoice.Id:D}")">@invoice.DisplayNumber</a>
                        <div class="text-fg-subtle text-xs">@invoice.Memo</div>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="InvoiceListRow" Property="@nameof(InvoiceListRow.CustomerName)" Title="Customer" />
                <RadzenDataGridColumn TItem="InvoiceListRow" Property="@nameof(InvoiceListRow.DocumentDate)" Title="Document date" Width="140px">
                    <Template Context="invoice">@invoice.DocumentDate.ToString("yyyy-MM-dd")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="InvoiceListRow" Property="@nameof(InvoiceListRow.DueDate)" Title="Due date" Width="120px">
                    <Template Context="invoice">@(invoice.DueDate?.ToString("yyyy-MM-dd") ?? "-")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="InvoiceListRow" Property="@nameof(InvoiceListRow.Status)" Title="Status" Width="110px">
                    <Template Context="invoice">
                        <CitusBadge Color="@StatusColor(invoice.Status)">@invoice.Status</CitusBadge>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="InvoiceListRow" Property="@nameof(InvoiceListRow.CustomerPoNumber)" Title="Customer PO" Width="160px">
                    <Template Context="invoice">
                        @if (string.IsNullOrWhiteSpace(invoice.CustomerPoNumber))
                        {
                            <span class="text-fg-subtle">—</span>
                        }
                        else
                        {
                            <span class="citus-inline-code">@invoice.CustomerPoNumber</span>
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="InvoiceListRow" Property="@nameof(InvoiceListRow.TotalAmount)" Title="Total" TextAlign="TextAlign.Right" Width="140px">
                    <Template Context="invoice">@invoice.TotalAmount.ToString("N2") @invoice.Currency</Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </CitusAsyncBoundary>
</section>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Sales & Get Paid",
        Title = "Invoices",
        Subtitle = "Customer-facing receivable anchors. Posted invoices flow into A/R Aging and Receive Payment settlement."
    };

    // Empty until /accounting/invoices HTTP endpoint exists; the list shape
    // matches what the eventual InvoiceListClient will return.
    private readonly IReadOnlyList<InvoiceListRow> _invoices = Array.Empty<InvoiceListRow>();

    private static string StatusColor(string status) => status.ToLowerInvariant() switch
    {
        "posted" => "green",
        "draft" => "blue",
        "voided" => "red",
        "overdue" => "orange",
        _ => "default"
    };

    private sealed record class InvoiceListRow(
        Guid Id,
        string DisplayNumber,
        string CustomerName,
        DateOnly DocumentDate,
        DateOnly? DueDate,
        string Status,
        decimal TotalAmount,
        string Currency,
        string Memo,
        string? CustomerPoNumber = null);
}
