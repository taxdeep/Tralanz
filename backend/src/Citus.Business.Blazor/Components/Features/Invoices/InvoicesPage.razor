@page "/invoices"

@inject BusinessShellState ShellState

<PageTitle>Invoices | Citus Business</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <a class="citus-button" href="invoices/new">
            <CitusIcon Name="IconName.Plus" Size="IconSize.Inline" />
            <span>New invoice</span>
        </a>
    </Actions>
</CitusPageHeader>

<AntDesign.Alert Type="@AntDesign.AlertType.Info"
                 ShowIcon="true"
                 Message="Invoice list pulls from the existing A/R Aging + Document Review HTTP surface. Posted invoices stay read-only — review opens via the Document drill-down."
                 Class="mb-4" />

<section class="citus-panel">
    <header class="citus-panel__header">
        <h2 class="citus-panel__title">Recent invoices</h2>
        <AntDesign.Tag Color="@("blue")">Read-only review</AntDesign.Tag>
    </header>

    <CitusAsyncBoundary IsLoading="false"
                        IsEmpty="@(_invoices.Count == 0)"
                        EmptyIcon="IconName.FileInvoice"
                        EmptyTitle="No invoices for this company yet"
                        EmptyMessage="Use 'New invoice' to compose one. Posted invoices appear here ordered by document date.">
        <table class="citus-data-table">
            <thead>
                <tr>
                    <th>Invoice</th>
                    <th>Customer</th>
                    <th>Document date</th>
                    <th>Due date</th>
                    <th>Status</th>
                    <th class="text-right">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var invoice in _invoices)
                {
                    <tr>
                        <td>
                            <a class="citus-link" href="@($"documents/invoice/{invoice.Id:D}")">@invoice.DisplayNumber</a>
                            <div class="text-fg-subtle text-xs">@invoice.Memo</div>
                        </td>
                        <td>@invoice.CustomerName</td>
                        <td>@invoice.DocumentDate.ToString("yyyy-MM-dd")</td>
                        <td>@(invoice.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td><AntDesign.Tag Color="@StatusColor(invoice.Status)">@invoice.Status</AntDesign.Tag></td>
                        <td class="text-right">@invoice.TotalAmount.ToString("N2") @invoice.Currency</td>
                    </tr>
                }
            </tbody>
        </table>
    </CitusAsyncBoundary>
</section>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Sales & Get Paid",
        Title = "Invoices",
        Subtitle = "Customer-facing receivable anchors. Posted invoices flow into A/R Aging and Receive Payment settlement."
    };

    // Empty until /accounting/invoices HTTP endpoint exists; the list shape
    // matches what the eventual InvoiceListClient will return.
    private readonly IReadOnlyList<InvoiceListRow> _invoices = Array.Empty<InvoiceListRow>();

    private static string StatusColor(string status) => status.ToLowerInvariant() switch
    {
        "posted" => "green",
        "draft" => "blue",
        "voided" => "red",
        "overdue" => "orange",
        _ => "default"
    };

    private sealed record class InvoiceListRow(
        Guid Id,
        string DisplayNumber,
        string CustomerName,
        DateOnly DocumentDate,
        DateOnly? DueDate,
        string Status,
        decimal TotalAmount,
        string Currency,
        string Memo);
}
