@*
    InvoiceAddressSection — Bill-to / Ship-to as flat textarea-style address
    boxes (NO card). Rendered inside the header's left zone. Edit fires
    OnEditAddress; the drawer + working-copy state live in the parent.
*@

<div class="flex flex-col gap-2">
    <div class="invoice-address-head">
        <span class="invoice-field__label">Bill to / Ship to</span>
        <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small"
                     LeadingIcon="IconName.Pencil" OnClick="OnEditAddress">Edit</CitusButton>
    </div>
    <div class="invoice-field">
        <label class="invoice-field__label">Bill to</label>
        <div class="invoice-address-box @(Billing.IsEmpty ? "invoice-address-box--empty" : null)">
            <AddressDisplay Address="Billing" EmptyHint="No billing address set." />
        </div>
    </div>
    <div class="invoice-field">
        <label class="invoice-field__label">Ship to</label>
        @if (ShippingMode == ShippingMode.SameAsBilling)
        {
            <div class="invoice-address-box invoice-address-box--empty">Same as billing</div>
        }
        else
        {
            <div class="invoice-address-box @(Shipping.IsEmpty ? "invoice-address-box--empty" : null)">
                <AddressDisplay Address="Shipping" EmptyHint="No shipping address set." />
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public AddressDraft Billing { get; set; } = AddressDraft.Empty;
    [Parameter] public AddressDraft Shipping { get; set; } = AddressDraft.Empty;
    [Parameter] public ShippingMode ShippingMode { get; set; } = ShippingMode.SameAsBilling;
    [Parameter] public EventCallback OnEditAddress { get; set; }
}
