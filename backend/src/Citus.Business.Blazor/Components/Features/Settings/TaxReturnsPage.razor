@page "/tax-returns"

@inject BusinessShellState ShellState
@inject TaxReturnClient TaxReturnClient

<PageTitle>Tax Returns | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header" />

<CitusFormSection Title="Tax returns">
    <HeaderActions>
        <label class="inline-flex items-center gap-2 text-sm">
            <input type="checkbox" checked="@_includeDrafts" @onchange="OnIncludeDraftsChanged" />
            <span>Include drafts</span>
        </label>
    </HeaderActions>
    <ChildContent>
        @if (_isLoading)
        {
            <CitusSkeleton Variant="SkeletonVariant.List" />
        }
        else if (_rows.Count == 0)
        {
            <CitusEmpty Title="No tax returns yet"
                        Description="Period filings will appear here once posted."
                        Icon="IconName.FileText" />
        }
        else
        {
            <table class="citus-data-table">
                <thead>
                    <tr>
                        <th>Filing #</th>
                        <th>Regime</th>
                        <th>Period</th>
                        <th>Frequency</th>
                        <th>Status</th>
                        <th class="text-right">Net</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _rows)
                    {
                        <tr>
                            <td><a class="citus-link" href="@($"tax-returns/{row.Id:D}")">@row.DisplayNumber</a></td>
                            <td>@row.TaxRegime</td>
                            <td>@row.PeriodStart.ToString("yyyy-MM-dd") → @row.PeriodEnd.ToString("yyyy-MM-dd")</td>
                            <td>@HumanizeFrequency(row.FilingFrequency)</td>
                            <td>@HumanizeStatus(row.Status)</td>
                            <td class="text-right">
                                @(row.NetAmount >= 0 ? "+" : "")@row.NetAmount.ToString("N2") @row.BaseCurrencyCode
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </ChildContent>
</CitusFormSection>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Settings & Setup",
        Title = "Tax returns",
        Subtitle = "Period filings — collected − ITCs + adjustments → net payable / refund."
    };

    private IReadOnlyList<TaxReturnSummaryDto> _rows = Array.Empty<TaxReturnSummaryDto>();
    private bool _isLoading = true;
    private bool _includeDrafts = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task OnIncludeDraftsChanged(ChangeEventArgs e)
    {
        _includeDrafts = (bool)(e.Value ?? false);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            _rows = await TaxReturnClient.ListAsync(ShellState.ActiveCompany.Id, _includeDrafts);
        }
        finally { _isLoading = false; }
    }

    private static string HumanizeStatus(string status) => status switch
    {
        "draft" => "Draft", "posted" => "Filed", "voided" => "Voided", "amended" => "Amended", _ => status
    };

    private static string HumanizeFrequency(string freq) => freq switch
    {
        "monthly" => "Monthly", "quarterly" => "Quarterly", "annual" => "Annual", _ => freq
    };
}
