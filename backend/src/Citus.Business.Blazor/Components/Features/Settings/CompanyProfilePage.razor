@page "/settings/profile"

@inject BusinessShellState ShellState

<PageTitle>Company Profile | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusBadge Color="@("default")">Read-only</CitusBadge>
    </Actions>
</CitusPageHeader>

<CitusAlert Severity="CitusAlertSeverity.Info"
                 ShowIcon="true"
                 Message="Company identity is captured during first-time setup and is currently shown read-only here. Direct editing will be added once the underlying API endpoint is in place."
                 Class="mb-6" />

<CitusFormSection Title="Identity">
    <CitusKeyValueTable>
        <CitusKeyValueRow Label="Company name">@ShellState.ActiveCompany.CompanyName</CitusKeyValueRow>
        <CitusKeyValueRow Label="Company code"><span class="citus-inline-code">@ShellState.ActiveCompany.CompanyCode</span></CitusKeyValueRow>
        <CitusKeyValueRow Label="Status">@FormatStatus(ShellState.ActiveCompany.Status)</CitusKeyValueRow>
        <CitusKeyValueRow Label="Read-only">@(ShellState.ActiveCompany.IsReadOnly ? "Yes" : "No")</CitusKeyValueRow>
    </CitusKeyValueTable>
</CitusFormSection>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Settings",
        Title = "Company profile",
        Subtitle = "Read-only view of the active company's identity captured at first-company setup."
    };

    private static string FormatStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return "Active";
        }

        return string.Join(' ',
            status.Trim()
                .Split('-', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(static part => char.ToUpperInvariant(part[0]) + part[1..].ToLowerInvariant()));
    }
}
