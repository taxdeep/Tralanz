@page "/settings/invoice-templates/new"
@page "/settings/invoice-templates/{TemplateId:guid}"

@implements IAsyncDisposable

@inject BusinessShellState ShellState
@inject InvoiceTemplateClient TemplateClient
@inject CitusToastService Message
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@_pageTitle | Tralanz Books</PageTitle>

<div class="citus-page-narrow">
<CitusPageHeader Model="_header">
    <Actions>
        <a class="citus-button citus-button--ghost" href="settings/invoice-templates">
            <CitusIcon Name="IconName.ArrowLeft" Size="IconSize.Inline" />
            <span>Back to templates</span>
        </a>
        @if (_isExisting && !_template.IsDefault)
        {
            <CitusButton Variant="CitusButtonVariant.Ghost"
                         Disabled="_isBusy"
                         OnClick="MarkAsDefaultAsync">
                Set as default
            </CitusButton>
        }
        @if (_isExisting && _template.IsDefault)
        {
            <CitusBadge Color="@("green")">Default template</CitusBadge>
        }
    </Actions>
</CitusPageHeader>

@if (_isLoading)
{
    <CitusSkeleton Variant="SkeletonVariant.Form" />
}
else
{
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_error" ShowIcon="true" Class="mb-4" />
    }

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <section class="citus-panel">
            <h2 class="citus-panel__title">Brand</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <label class="citus-form-field md:col-span-2">
                    <span class="citus-form-field__label">Template name</span>
                    <input type="text"
                           class="citus-form-field__input"
                           value="@_template.Name"
                           @oninput="@(e => UpdateDraft(_template with { Name = e.Value?.ToString() ?? string.Empty }))" />
                </label>

                <label class="citus-form-field">
                    <span class="citus-form-field__label">Primary color</span>
                    <div class="flex items-center gap-2">
                        <input type="color"
                               class="citus-form-field__input citus-color-input"
                               value="@_template.PrimaryColorHex"
                               @oninput="@(e => UpdateDraft(_template with { PrimaryColorHex = e.Value?.ToString() ?? "#000000" }))" />
                        <input type="text"
                               class="citus-form-field__input"
                               value="@_template.PrimaryColorHex"
                               @oninput="@(e => UpdateDraft(_template with { PrimaryColorHex = e.Value?.ToString() ?? string.Empty }))" />
                    </div>
                </label>

                <label class="citus-form-field">
                    <span class="citus-form-field__label">Accent color</span>
                    <div class="flex items-center gap-2">
                        <input type="color"
                               class="citus-form-field__input citus-color-input"
                               value="@_template.AccentColorHex"
                               @oninput="@(e => UpdateDraft(_template with { AccentColorHex = e.Value?.ToString() ?? "#666666" }))" />
                        <input type="text"
                               class="citus-form-field__input"
                               value="@_template.AccentColorHex"
                               @oninput="@(e => UpdateDraft(_template with { AccentColorHex = e.Value?.ToString() ?? string.Empty }))" />
                    </div>
                </label>

                <label class="citus-form-field md:col-span-2">
                    <span class="citus-form-field__label">Logo URL (optional, public link)</span>
                    <input type="url"
                           class="citus-form-field__input"
                           placeholder="https://cdn.example.com/logo.png"
                           value="@(_template.LogoUrl ?? string.Empty)"
                           @oninput="@(e => UpdateDraft(_template with { LogoUrl = NullIfBlank(e.Value?.ToString()) }))" />
                </label>

                <label class="citus-form-field md:col-span-2">
                    <span class="citus-form-field__label">Tagline (optional)</span>
                    <input type="text"
                           class="citus-form-field__input"
                           placeholder="e.g. Independent advisory and integration"
                           value="@(_template.Tagline ?? string.Empty)"
                           @oninput="@(e => UpdateDraft(_template with { Tagline = NullIfBlank(e.Value?.ToString()) }))" />
                </label>
            </div>

            <h2 class="citus-panel__title mt-6">Body text</h2>
            <div class="grid grid-cols-1 gap-3">
                <label class="citus-form-field">
                    <span class="citus-form-field__label">Greeting (printed above the lines table)</span>
                    <input type="text"
                           class="citus-form-field__input"
                           value="@_template.Greeting"
                           @oninput="@(e => UpdateDraft(_template with { Greeting = e.Value?.ToString() ?? string.Empty }))" />
                </label>

                <label class="citus-form-field">
                    <span class="citus-form-field__label">Payment instructions</span>
                    <textarea class="citus-form-field__input"
                              rows="3"
                              placeholder="Wire / e-Transfer / cheque mailing address — anything you want above the customer's eyes."
                              @oninput="@(e => UpdateDraft(_template with { PaymentInstructions = e.Value?.ToString() ?? string.Empty }))">@_template.PaymentInstructions</textarea>
                </label>

                <label class="citus-form-field">
                    <span class="citus-form-field__label">Footer note</span>
                    <input type="text"
                           class="citus-form-field__input"
                           value="@_template.FooterNote"
                           @oninput="@(e => UpdateDraft(_template with { FooterNote = e.Value?.ToString() ?? string.Empty }))" />
                </label>

                <label class="citus-form-field">
                    <input type="checkbox"
                           class="mr-2"
                           checked="@_template.ShowTaxColumn"
                           @onchange="@(e => UpdateDraft(_template with { ShowTaxColumn = (bool)(e.Value ?? false) }))" />
                    <span>Show tax row in invoice totals</span>
                </label>
            </div>
        </section>

        <section class="citus-panel">
            <h2 class="citus-panel__title">Email</h2>
            <p class="text-fg-muted text-sm mb-3">
                Used by Send invoice. Use <span class="citus-inline-code">{invoiceNumber}</span>
                and <span class="citus-inline-code">{companyName}</span> as placeholders.
            </p>

            <div class="grid grid-cols-1 gap-3">
                <label class="citus-form-field">
                    <span class="citus-form-field__label">Subject</span>
                    <input type="text"
                           class="citus-form-field__input"
                           value="@_template.EmailSubjectTemplate"
                           @oninput="@(e => UpdateDraft(_template with { EmailSubjectTemplate = e.Value?.ToString() ?? string.Empty }))" />
                </label>

                <label class="citus-form-field">
                    <span class="citus-form-field__label">Body intro (optional, shown above invoice details)</span>
                    <textarea class="citus-form-field__input"
                              rows="4"
                              placeholder="Hello {customerName} — etc."
                              @oninput="@(e => UpdateDraft(_template with { EmailBodyTemplate = e.Value?.ToString() ?? string.Empty }))">@_template.EmailBodyTemplate</textarea>
                </label>
            </div>

            <header class="citus-panel__header mt-6">
                <h2 class="citus-panel__title">Live PDF preview</h2>
                <span class="citus-template-preview__status @_previewStatusModifier">
                    @_previewStatusLabel
                </span>
            </header>
            <p class="text-fg-subtle text-xs mb-3">
                Byte-accurate render of what your customer will receive. Auto-refreshes
                ~800ms after typing pauses; shows a synthetic Acme Co. invoice so the
                preview works before you have any real invoice data.
            </p>
            <iframe id="@_previewIframeId"
                    class="citus-template-preview__iframe"
                    title="Invoice template PDF preview"
                    src="about:blank"></iframe>
        </section>
    </div>

    <div class="flex items-center gap-3 mt-6">
        <CitusButton Variant="CitusButtonVariant.Primary"
                     Disabled="_isBusy || string.IsNullOrWhiteSpace(_template.Name)"
                     OnClick="SaveAsync">
            @(_isBusy ? "Saving…" : (_isExisting ? "Save changes" : "Create template"))
        </CitusButton>
        <a class="citus-button citus-button--ghost" href="settings/invoice-templates">Cancel</a>
    </div>
}
</div>

@code {
    [Parameter]
    public Guid? TemplateId { get; set; }

    private InvoiceTemplateDraft _template = InvoiceTemplateDraft.Empty();
    private InvoiceTemplateDraft? _lastPreviewedTemplate;
    private bool _isLoading;
    private bool _isBusy;
    private bool _isExisting;
    private string? _error;
    private string _pageTitle = "Invoice template";

    private const int PreviewDebounceMilliseconds = 800;
    private readonly string _previewIframeId = $"invoice-template-preview-{Guid.NewGuid():N}";
    private CancellationTokenSource? _previewCts;
    private PreviewStatus _previewStatus = PreviewStatus.Idle;
    private DateTimeOffset? _previewUpdatedAt;
    private string _previewStatusLabel => _previewStatus switch
    {
        PreviewStatus.Refreshing => "Refreshing…",
        PreviewStatus.Failed => "Could not render preview",
        PreviewStatus.Updated when _previewUpdatedAt is { } at => $"Updated {at.ToLocalTime():HH:mm:ss}",
        _ => "Pending first render",
    };
    private string _previewStatusModifier => _previewStatus switch
    {
        PreviewStatus.Refreshing => "citus-template-preview__status--busy",
        PreviewStatus.Failed => "citus-template-preview__status--error",
        PreviewStatus.Updated => "citus-template-preview__status--ok",
        _ => "citus-template-preview__status--idle",
    };

    private enum PreviewStatus { Idle, Refreshing, Updated, Failed }

    private PageHeaderModel _header = new()
    {
        Eyebrow = "Settings",
        Title = "Invoice template",
        Subtitle = "Brand colors, payment instructions, and email subject for the company's invoices."
    };

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            if (TemplateId is { } id)
            {
                var dto = await TemplateClient.GetAsync(ShellState.ActiveCompany.Id, id);
                if (dto is null)
                {
                    _error = "Template not found in this company.";
                    _template = InvoiceTemplateDraft.Empty();
                    _isExisting = false;
                }
                else
                {
                    _template = InvoiceTemplateDraft.From(dto);
                    _isExisting = true;
                    _pageTitle = $"Edit {_template.Name}";
                    _header = _header with { Title = $"Edit {_template.Name}" };
                }
            }
            else
            {
                _template = InvoiceTemplateDraft.Empty();
                _isExisting = false;
                _pageTitle = "New invoice template";
                _header = _header with { Title = "New invoice template" };
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // First render gives us a real DOM-mounted iframe to embed into.
        // Kick off the initial PDF preview render so the operator sees
        // something immediately on page load instead of an empty frame.
        if (firstRender && !_isLoading)
        {
            await RefreshPreviewAsync(immediate: true);
        }
    }

    /// <summary>
    /// Single mutation entry point used by every form field handler.
    /// Replaces the draft and schedules a debounced preview re-render so
    /// rapid edits don't cause a network call per keystroke.
    /// </summary>
    private void UpdateDraft(InvoiceTemplateDraft next)
    {
        _template = next;
        ScheduleDebouncedPreview();
    }

    /// <summary>
    /// Called on every form field input. Cancels any pending preview
    /// render and schedules a new one PreviewDebounceMilliseconds in the
    /// future. The actual fetch happens once typing stops; rapid edits
    /// only trigger one final render instead of a network roundtrip per
    /// keystroke.
    /// </summary>
    private void ScheduleDebouncedPreview()
    {
        _previewCts?.Cancel();
        _previewCts = new CancellationTokenSource();
        var token = _previewCts.Token;

        // Fire-and-forget. The token tied to this scheduling call gets
        // cancelled when the next keystroke lands; that drops the awaiter
        // and the previous in-flight render exits without committing.
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(PreviewDebounceMilliseconds, token);
                await RefreshPreviewAsync(immediate: false);
            }
            catch (OperationCanceledException)
            {
                // Expected — another keystroke landed.
            }
        });
    }

    private async Task RefreshPreviewAsync(bool immediate)
    {
        if (_isLoading) return;

        // Skip the network call if the form hasn't actually changed since
        // the last successful preview. Same hash, same PDF, no point.
        if (_lastPreviewedTemplate == _template && !immediate) return;

        var snapshot = _template;
        _previewStatus = PreviewStatus.Refreshing;
        await InvokeAsync(StateHasChanged);

        var request = new InvoiceTemplateUpsertDto(
            Name: snapshot.Name,
            LogoUrl: snapshot.LogoUrl,
            PrimaryColorHex: snapshot.PrimaryColorHex,
            AccentColorHex: snapshot.AccentColorHex,
            Tagline: snapshot.Tagline,
            Greeting: snapshot.Greeting,
            PaymentInstructions: snapshot.PaymentInstructions,
            FooterNote: snapshot.FooterNote,
            ShowTaxColumn: snapshot.ShowTaxColumn,
            EmailSubjectTemplate: snapshot.EmailSubjectTemplate,
            EmailBodyTemplate: snapshot.EmailBodyTemplate);

        var pdfBytes = await TemplateClient.GeneratePreviewAsync(ShellState.ActiveCompany.Id, request);

        if (pdfBytes is null)
        {
            _previewStatus = PreviewStatus.Failed;
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("citusDownloads.embedPdfPreview", _previewIframeId, base64);
            _lastPreviewedTemplate = snapshot;
            _previewStatus = PreviewStatus.Updated;
            _previewUpdatedAt = DateTimeOffset.UtcNow;
        }
        catch
        {
            _previewStatus = PreviewStatus.Failed;
        }

        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        _previewCts?.Cancel();
        _previewCts?.Dispose();
        try
        {
            await JS.InvokeVoidAsync("citusDownloads.clearPdfPreview", _previewIframeId);
        }
        catch
        {
            // Page is being torn down — JS handle may already be gone.
        }
    }

    private async Task SaveAsync()
    {
        if (_isBusy) return;
        _isBusy = true;
        _error = null;
        try
        {
            var request = new InvoiceTemplateUpsertDto(
                Name: _template.Name.Trim(),
                LogoUrl: _template.LogoUrl,
                PrimaryColorHex: _template.PrimaryColorHex,
                AccentColorHex: _template.AccentColorHex,
                Tagline: _template.Tagline,
                Greeting: _template.Greeting,
                PaymentInstructions: _template.PaymentInstructions,
                FooterNote: _template.FooterNote,
                ShowTaxColumn: _template.ShowTaxColumn,
                EmailSubjectTemplate: _template.EmailSubjectTemplate,
                EmailBodyTemplate: _template.EmailBodyTemplate);

            var outcome = _isExisting
                ? await TemplateClient.UpdateAsync(ShellState.ActiveCompany.Id, _template.Id, request)
                : await TemplateClient.CreateAsync(ShellState.ActiveCompany.Id, request);

            if (!outcome.Succeeded)
            {
                _error = outcome.ErrorMessage ?? "Save failed.";
                return;
            }

            await Message.SuccessAsync(_isExisting ? "Template updated." : "Template created.");
            Navigation.NavigateTo("settings/invoice-templates");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task MarkAsDefaultAsync()
    {
        if (!_isExisting || _isBusy) return;
        _isBusy = true;
        try
        {
            var outcome = await TemplateClient.SetDefaultAsync(ShellState.ActiveCompany.Id, _template.Id);
            if (!outcome.Succeeded)
            {
                _error = outcome.ErrorMessage ?? "Could not set as default.";
                return;
            }
            await Message.SuccessAsync("Set as default.");
            _template = _template with { IsDefault = true };
        }
        finally
        {
            _isBusy = false;
        }
    }

    private static string? NullIfBlank(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed record InvoiceTemplateDraft(
        Guid Id,
        string Name,
        bool IsDefault,
        string? LogoUrl,
        string PrimaryColorHex,
        string AccentColorHex,
        string? Tagline,
        string Greeting,
        string PaymentInstructions,
        string FooterNote,
        bool ShowTaxColumn,
        string EmailSubjectTemplate,
        string EmailBodyTemplate)
    {
        public static InvoiceTemplateDraft Empty() => new(
            Id: Guid.Empty,
            Name: "Custom template",
            IsDefault: false,
            LogoUrl: null,
            PrimaryColorHex: "#1f2937",
            AccentColorHex: "#6b7280",
            Tagline: null,
            Greeting: "Thank you for your business.",
            PaymentInstructions: string.Empty,
            FooterNote: "Thank you for your business.",
            ShowTaxColumn: true,
            EmailSubjectTemplate: "Invoice {invoiceNumber} from {companyName}",
            EmailBodyTemplate: string.Empty);

        public static InvoiceTemplateDraft From(InvoiceTemplateDto dto) => new(
            Id: dto.Id,
            Name: dto.Name,
            IsDefault: dto.IsDefault,
            LogoUrl: dto.LogoUrl,
            PrimaryColorHex: dto.PrimaryColorHex,
            AccentColorHex: dto.AccentColorHex,
            Tagline: dto.Tagline,
            Greeting: dto.Greeting,
            PaymentInstructions: dto.PaymentInstructions,
            FooterNote: dto.FooterNote,
            ShowTaxColumn: dto.ShowTaxColumn,
            EmailSubjectTemplate: dto.EmailSubjectTemplate,
            EmailBodyTemplate: dto.EmailBodyTemplate);
    }
}
