@page "/settings"

@inject BusinessShellState ShellState
@inject NavigationManager Navigation

<PageTitle>Settings | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header" />

<CitusStatCardGrid Columns="3">
    <CitusStatCard
        Label="Company"
        Value="@ShellState.ActiveCompany.CompanyName"
        Description="@ShellState.ActiveCompany.CompanyCode"
        Icon="IconName.BuildingSkyscraper"
        Tone="StatTone.Primary" />
    <CitusStatCard
        Label="Base currency"
        Value="@ShellState.ActiveCompany.BaseCurrencyCode"
        Description="Company-level accounting default."
        Icon="IconName.Coin"
        Tone="StatTone.Info" />
    <CitusStatCard
        Label="Multi-currency"
        Value="@(ShellState.ActiveCompany.MultiCurrencyEnabled ? "Enabled" : "Disabled")"
        Description="Add currencies to seed AR/AP per currency."
        Icon="IconName.Coin"
        Tone="StatTone.Success" />
    <CitusStatCard
        Label="Company status"
        Value="@FormatCompanyStatus(ShellState.ActiveCompany.Status)"
        Description="Active company lifecycle gates whether business writes remain available."
        Icon="IconName.ShieldLock"
        Tone="@(ShellState.ActiveCompany.IsReadOnly ? StatTone.Warning : StatTone.Success)" />
    <CitusStatCard
        Label="Maintenance"
        Value="@(ShellState.MaintenanceState.Enabled ? "Active" : "Normal")"
        Description="Business write behavior must reflect platform maintenance state."
        Icon="IconName.Tool"
        Tone="StatTone.Neutral" />
    <CitusStatCard
        Label="Write mode"
        Value="@(ShellState.AreWritesBlocked ? "Blocked" : "Writable")"
        Description="@ShellState.WriteBlockMessage"
        Icon="IconName.Eye"
        Tone="@(ShellState.AreWritesBlocked ? StatTone.Warning : StatTone.Info)" />
</CitusStatCardGrid>

<CitusFormSection Title="Company settings domains">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
        @foreach (var domain in _domains)
        {
            <CitusNavCard Title="@domain.Title"
                          Description="@domain.Description"
                          Href="@domain.Href"
                          Stage="@domain.Stage"
                          Tone="@domain.Tone" />
        }
    </div>
</CitusFormSection>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <CitusFormSection Title="Current company snapshot">
        <CitusKeyValueTable>
            @foreach (var row in _snapshotRows)
            {
                <CitusKeyValueRow Label="@row.Field">@row.Value</CitusKeyValueRow>
            }
        </CitusKeyValueTable>
    </CitusFormSection>

    <CitusFormSection Title="Guardrails for settings">
        <ul class="citus-bullet-list">
            <li>Settings remain structured domains, not a miscellaneous dumping ground.</li>
            <li>Currency and numbering behavior stay company-scoped.</li>
            <li>Sensitive changes should remain audit-visible and backend-authoritative.</li>
            <li>Security and notification readiness should not be inferred only from the UI.</li>
        </ul>
    </CitusFormSection>
</div>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Settings",
        Title = "Company settings shell",
        Subtitle = "This page establishes the controlled settings domains before deeper forms are migrated."
    };

    // Domain cards: Live = page exists and is wired, Later = stub waiting
    // for infrastructure work. Live cards render as anchor tags so the
    // whole card is clickable; Later cards stay as plain articles so an
    // operator never lands on a 404.
    private readonly IReadOnlyList<DomainRow> _domains =
    [
        new("Profile", "Live", "Company identity, address, and fiscal profile.", StatTone.Success, "/settings/profile"),
        new("Currencies", "Live", "Base currency and multi-currency state.", StatTone.Success, "/settings/currencies"),
        new("Fiscal Year", "Live", "Year-end month / day used by reporting periods.", StatTone.Success, "/settings/fiscal-year"),
        new("Payment Terms", "Live", "Per-company payment terms feeding vendor master data and bill due dates.", StatTone.Success, "/settings/payment-terms"),
        new("Sales Tax", "Live", "Tax Rules and Tax Codes wired into the backend posting engine.", StatTone.Success, "/settings/tax-rates"),
        new("Numbering", "Live", "Entity-number rules are company-scoped and backend-generated.", StatTone.Success, "/settings/numbering"),
        new("Invoice Templates", "Live", "Branding presets and email templates for invoices, with a live PDF preview.", StatTone.Success, "/settings/invoice-templates"),
        new("Notifications", "Later", "Readiness and verification state need infrastructure support.", StatTone.Warning, null),
        new("Security", "Later", "Verification-driven security settings will follow auth / session foundations.", StatTone.Warning, null)
    ];

    private IReadOnlyList<SnapshotRow> _snapshotRows =>
    [
        new("Company", $"{ShellState.ActiveCompany.CompanyName} ({ShellState.ActiveCompany.CompanyCode})"),
        new("Base currency", ShellState.ActiveCompany.BaseCurrencyCode),
        new("Multi-currency", ShellState.ActiveCompany.MultiCurrencyEnabled ? "Enabled" : "Disabled"),
        new("Company status", FormatCompanyStatus(ShellState.ActiveCompany.Status)),
        new("Company write mode", ShellState.ActiveCompany.IsReadOnly ? "Read-only" : "Writable"),
        new("Available companies", ShellState.AvailableCompanies.Count.ToString()),
        new("Maintenance mode", ShellState.MaintenanceState.Enabled ? ShellState.MaintenanceState.Message : "Disabled"),
        new("Effective write gate", ShellState.WriteBlockMessage)
    ];

    private sealed record class DomainRow(string Title, string Stage, string Description, StatTone Tone, string? Href);

    private sealed record class SnapshotRow(string Field, string Value);

    private static string TagColor(StatTone tone) => tone switch
    {
        StatTone.Success => "green",
        StatTone.Warning => "orange",
        StatTone.Danger => "red",
        StatTone.Info => "blue",
        StatTone.Primary => "geekblue",
        _ => "default"
    };

    private static string FormatCompanyStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return "Active";
        }

        return string.Join(' ',
            status.Trim()
                .Split('-', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(static part => char.ToUpperInvariant(part[0]) + part[1..].ToLowerInvariant()));
    }
}
