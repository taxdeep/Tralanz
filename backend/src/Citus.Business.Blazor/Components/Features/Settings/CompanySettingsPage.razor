@page "/settings"

@inject BusinessShellState ShellState
@inject NavigationManager Navigation

<PageTitle>Settings | Citus Business</PageTitle>

<CitusPageHeader Model="_header" />

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
    <CitusStatCard
        Label="Company"
        Value="@ShellState.ActiveCompany.CompanyCode"
        Description="@ShellState.ActiveCompany.CompanyName"
        Icon="IconName.BuildingSkyscraper"
        Tone="StatTone.Primary" />
    <CitusStatCard
        Label="Base currency"
        Value="@ShellState.ActiveCompany.BaseCurrencyCode"
        Description="Company-level accounting default."
        Icon="IconName.Coin"
        Tone="StatTone.Info" />
    <CitusStatCard
        Label="Multi-currency"
        Value="@(ShellState.ActiveCompany.MultiCurrencyEnabled ? "Enabled" : "Disabled")"
        Description="Add currencies to seed AR/AP per currency."
        Icon="IconName.Coin"
        Tone="StatTone.Success" />
    <CitusStatCard
        Label="Company status"
        Value="@FormatCompanyStatus(ShellState.ActiveCompany.Status)"
        Description="Active company lifecycle gates whether business writes remain available."
        Icon="IconName.ShieldLock"
        Tone="@(ShellState.ActiveCompany.IsReadOnly ? StatTone.Warning : StatTone.Success)" />
    <CitusStatCard
        Label="Maintenance"
        Value="@(ShellState.MaintenanceState.Enabled ? "Active" : "Normal")"
        Description="Business write behavior must reflect platform maintenance state."
        Icon="IconName.Tool"
        Tone="StatTone.Neutral" />
    <CitusStatCard
        Label="Write mode"
        Value="@(ShellState.AreWritesBlocked ? "Blocked" : "Writable")"
        Description="@ShellState.WriteBlockMessage"
        Icon="IconName.Eye"
        Tone="@(ShellState.AreWritesBlocked ? StatTone.Warning : StatTone.Info)" />
</div>

<div class="flex flex-wrap gap-2 mb-6">
    <RadzenButton Text="Manage currencies"
                  ButtonStyle="ButtonStyle.Primary"
                  Icon="payments"
                  Click="OpenMultiCurrencyDrawer" />
    <RadzenButton Text="View all currencies"
                  ButtonStyle="ButtonStyle.Secondary"
                  Icon="open_in_new"
                  Click="@(() => Navigation.NavigateTo("/settings/currencies"))" />
</div>

<MultiCurrencyDrawer @ref="_currencyDrawer" />

<section class="citus-panel mb-6">
    <h2 class="citus-panel__title">Company settings domains</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 mt-3">
        @foreach (var domain in _domains)
        {
            <article class="citus-domain-card">
                <header class="citus-domain-card__header">
                    <h3 class="citus-domain-card__title">@domain.Title</h3>
                    <CitusBadge Color="@TagColor(domain.Tone)">@domain.Stage</CitusBadge>
                </header>
                <p class="citus-domain-card__description">@domain.Description</p>
            </article>
        }
    </div>
</section>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <section class="citus-panel">
        <h2 class="citus-panel__title">Current company snapshot</h2>
        <table class="citus-keyvalue">
            <tbody>
                @foreach (var row in _snapshotRows)
                {
                    <tr>
                        <th>@row.Field</th>
                        <td>@row.Value</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    <section class="citus-panel">
        <h2 class="citus-panel__title">Guardrails for settings</h2>
        <ul class="citus-bullet-list">
            <li>Settings remain structured domains, not a miscellaneous dumping ground.</li>
            <li>Currency and numbering behavior stay company-scoped.</li>
            <li>Sensitive changes should remain audit-visible and backend-authoritative.</li>
            <li>Security and notification readiness should not be inferred only from the UI.</li>
        </ul>
    </section>
</div>

@code {
    private MultiCurrencyDrawer? _currencyDrawer;

    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Settings",
        Title = "Company settings shell",
        Subtitle = "This page establishes the controlled settings domains before deeper forms are migrated."
    };

    private async Task OpenMultiCurrencyDrawer()
    {
        if (_currencyDrawer is not null)
        {
            await _currencyDrawer.OpenAsync();
        }
    }

    private readonly IReadOnlyList<DomainRow> _domains =
    [
        new("Profile", "Next", "Company identity, address, and fiscal profile should live together.", StatTone.Success),
        new("Templates", "Planned", "Document template controls belong under company-owned settings.", StatTone.Info),
        new("Sales Tax", "Planned", "Tax controls should connect back to the backend tax engine, not ad hoc form logic.", StatTone.Info),
        new("Numbering", "Planned", "Entity numbering rules are company-scoped and backend-generated.", StatTone.Info),
        new("Notifications", "Later", "Readiness and verification state need infrastructure support.", StatTone.Warning),
        new("Security", "Later", "Verification-driven security settings should follow auth/session foundations.", StatTone.Warning),
        new("Currencies", "Core", "Base currency and multi-currency state must remain visible and governed.", StatTone.Neutral)
    ];

    private IReadOnlyList<SnapshotRow> _snapshotRows =>
    [
        new("Company", $"{ShellState.ActiveCompany.CompanyName} ({ShellState.ActiveCompany.CompanyCode})"),
        new("Base currency", ShellState.ActiveCompany.BaseCurrencyCode),
        new("Multi-currency", ShellState.ActiveCompany.MultiCurrencyEnabled ? "Enabled" : "Disabled"),
        new("Company status", FormatCompanyStatus(ShellState.ActiveCompany.Status)),
        new("Company write mode", ShellState.ActiveCompany.IsReadOnly ? "Read-only" : "Writable"),
        new("Available companies", ShellState.AvailableCompanies.Count.ToString()),
        new("Maintenance mode", ShellState.MaintenanceState.Enabled ? ShellState.MaintenanceState.Message : "Disabled"),
        new("Effective write gate", ShellState.WriteBlockMessage)
    ];

    private sealed record class DomainRow(string Title, string Stage, string Description, StatTone Tone);

    private sealed record class SnapshotRow(string Field, string Value);

    private static string TagColor(StatTone tone) => tone switch
    {
        StatTone.Success => "green",
        StatTone.Warning => "orange",
        StatTone.Danger => "red",
        StatTone.Info => "blue",
        StatTone.Primary => "geekblue",
        _ => "default"
    };

    private static string FormatCompanyStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return "Active";
        }

        return string.Join(' ',
            status.Trim()
                .Split('-', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(static part => char.ToUpperInvariant(part[0]) + part[1..].ToLowerInvariant()));
    }
}
