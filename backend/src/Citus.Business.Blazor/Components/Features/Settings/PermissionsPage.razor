@page "/settings/permissions"

@inject BusinessShellState ShellState
@inject PermissionManagementClient PermissionClient
@inject NavigationManager NavigationManager

<PageTitle>Member Permissions | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header" />

@if (_loadFailed)
{
    @* Most likely cause: caller is not the company Owner. Show the
       same friendly message either way — we don't differentiate
       between "you're not Owner" and "transport blew up" because the
       remediation is the same: ask the Owner. *@
    <CitusAlert Severity="CitusAlertSeverity.Warning"
                Message="Only the company owner can manage permissions. Ask the owner to grant or revoke access on your behalf."
                ShowIcon="true"
                Class="mb-4" />
}
else if (_isLoading)
{
    <CitusSkeleton Variant="SkeletonVariant.List" />
}
else
{
    <section class="citus-panel mb-4">
        <header class="citus-panel__header">
            <h2 class="citus-panel__title">Members</h2>
            <span class="text-fg-subtle text-sm">@_members.Count member(s)</span>
        </header>

        @if (_members.Count == 0)
        {
            <CitusEmpty Title="No members yet"
                        Description="Once you invite teammates they'll appear here."
                        Icon="IconName.Users" />
        }
        else
        {
            <table class="citus-data-table">
                <thead>
                    <tr>
                        <th>Member</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th class="text-right">Active grants</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in _members)
                    {
                        var isSelected = _selectedMember?.UserId == member.UserId;
                        <tr class="@(isSelected ? "citus-data-table__row--selected" : null) cursor-pointer"
                            @onclick="@(() => SelectMemberAsync(member))">
                            <td>
                                <div style="display: flex; flex-direction: column;">
                                    <span>@(string.IsNullOrWhiteSpace(member.DisplayName) ? member.Username : member.DisplayName)</span>
                                    <span class="text-fg-subtle text-xs"><span class="citus-inline-code">@member.UserId</span></span>
                                </div>
                            </td>
                            <td>@member.Email</td>
                            <td>
                                @if (member.IsOwner)
                                {
                                    <CitusBadge Color="gold">Owner</CitusBadge>
                                }
                                else if (!member.IsActive)
                                {
                                    <CitusBadge Color="default">Inactive</CitusBadge>
                                }
                                else
                                {
                                    <CitusBadge Color="blue">Member</CitusBadge>
                                }
                            </td>
                            <td class="text-right">
                                @if (_grantCounts.TryGetValue(member.UserId, out var count))
                                {
                                    @count
                                }
                                else
                                {
                                    <span class="text-fg-subtle">—</span>
                                }
                            </td>
                            <td class="text-right">
                                <CitusButton Size="CitusButtonSize.Small"
                                             Variant="@(isSelected ? CitusButtonVariant.Primary : CitusButtonVariant.Ghost)"
                                             OnClick="@(() => SelectMemberAsync(member))">
                                    @(isSelected ? "Selected" : "Manage")
                                </CitusButton>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    @if (_selectedMember is not null)
    {
        <section class="citus-panel">
            <header class="citus-panel__header">
                <h2 class="citus-panel__title">
                    Permissions for @(string.IsNullOrWhiteSpace(_selectedMember.DisplayName) ? _selectedMember.Email : _selectedMember.DisplayName)
                </h2>
                <span class="citus-inline-code">@_selectedMember.UserId</span>
            </header>

            @if (_selectedMember.IsOwner)
            {
                <CitusAlert Severity="CitusAlertSeverity.Info"
                            Message="Owner has all permissions (implied-all). To change this, transfer ownership to another active member."
                            ShowIcon="true" />
            }
            else if (_selectedSnapshot is null && _selectedMember is not null)
            {
                <div class="text-fg-subtle">Loading permissions…</div>
            }
            else if (_registry.Count == 0)
            {
                <div class="text-fg-subtle">Permission registry is empty. Check the deploy migration.</div>
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace(_mutationMessage))
                {
                    <CitusAlert Severity="@(_mutationSucceeded ? CitusAlertSeverity.Success : CitusAlertSeverity.Warning)"
                                Message="@_mutationMessage"
                                ShowIcon="true"
                                Class="mb-3" />
                }

                @foreach (var moduleGroup in _registry
                    .GroupBy(t => t.ModuleKey)
                    .OrderBy(g => g.Key, StringComparer.Ordinal))
                {
                    <div class="mb-4">
                        <h3 class="text-sm font-semibold mb-2" style="text-transform: uppercase; letter-spacing: 0.05em; color: var(--citus-color-fg-subtle);">
                            @FormatModuleLabel(moduleGroup.Key)
                        </h3>
                        <table class="citus-data-table">
                            <thead>
                                <tr>
                                    <th>Token</th>
                                    <th>Description</th>
                                    <th class="text-center">Granted</th>
                                    <th class="text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in moduleGroup.OrderBy(e => e.PermissionToken, StringComparer.Ordinal))
                                {
                                    var isActive = _activeGrants.Contains(entry.PermissionToken);
                                    var busy = _busyToken == entry.PermissionToken;
                                    <tr>
                                        <td>
                                            <span class="citus-inline-code">@entry.PermissionToken</span>
                                            @if (entry.IsHighRisk)
                                            {
                                                <span class="ml-2"><CitusBadge Color="orange">high-risk</CitusBadge></span>
                                            }
                                        </td>
                                        <td>@(string.IsNullOrWhiteSpace(entry.Description) ? "—" : entry.Description)</td>
                                        <td class="text-center">
                                            @if (isActive)
                                            {
                                                <CitusBadge Color="green">Granted</CitusBadge>
                                            }
                                            else
                                            {
                                                <span class="text-fg-subtle">—</span>
                                            }
                                        </td>
                                        <td class="text-right">
                                            @if (isActive)
                                            {
                                                <CitusButton Size="CitusButtonSize.Small"
                                                             Variant="CitusButtonVariant.Ghost"
                                                             Disabled="@busy"
                                                             OnClick="@(() => RevokeAsync(entry.PermissionToken))">
                                                    Revoke
                                                </CitusButton>
                                            }
                                            else
                                            {
                                                <CitusButton Size="CitusButtonSize.Small"
                                                             Variant="CitusButtonVariant.Primary"
                                                             Disabled="@busy"
                                                             OnClick="@(() => GrantAsync(entry.PermissionToken))">
                                                    Grant
                                                </CitusButton>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </section>
    }
}

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Settings & Setup",
        Title = "Member Permissions",
        Subtitle = "Grant or revoke fine-grained permissions per member. Owner has all permissions implicitly — non-Owners need explicit grants for post / void / reverse / export operations."
    };

    private bool _isLoading = true;
    private bool _loadFailed;
    private IReadOnlyList<CompanyMemberDto> _members = Array.Empty<CompanyMemberDto>();
    private IReadOnlyList<PermissionRegistryEntryDto> _registry = Array.Empty<PermissionRegistryEntryDto>();
    private readonly Dictionary<string, int> _grantCounts = new(StringComparer.Ordinal);
    private CompanyMemberDto? _selectedMember;
    private UserPermissionSnapshotDto? _selectedSnapshot;
    private HashSet<string> _activeGrants = new(StringComparer.Ordinal);
    private string? _busyToken;
    private string? _mutationMessage;
    private bool _mutationSucceeded;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _loadFailed = false;
        try
        {
            // Both endpoints are Owner-only on the backend. If the
            // caller is not Owner, the list call returns 403 → empty
            // list here → we surface the "owner only" alert. The
            // registry call is open to any active member but only the
            // matrix needs it, so loading it speculatively is cheap.
            var membersTask = PermissionClient.ListMembersAsync(ShellState.ActiveCompany.Id);
            var registryTask = PermissionClient.ListAssignableTokensAsync();

            _members = await membersTask;
            _registry = await registryTask;

            if (_members.Count == 0)
            {
                // Either zero members (impossible for a real company)
                // or the caller is not Owner. Treat as "no access".
                _loadFailed = true;
                return;
            }

            // Pre-populate grant counts for the member table.
            foreach (var member in _members)
            {
                if (member.IsOwner)
                {
                    _grantCounts[member.UserId] = -1; // sentinel: shown as —
                    continue;
                }
                var snapshot = await PermissionClient.GetUserPermissionsAsync(
                    ShellState.ActiveCompany.Id, member.UserId);
                _grantCounts[member.UserId] = snapshot?.ActiveGrants.Count ?? 0;
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SelectMemberAsync(CompanyMemberDto member)
    {
        _selectedMember = member;
        _mutationMessage = null;
        _selectedSnapshot = null;
        _activeGrants = new HashSet<string>(StringComparer.Ordinal);

        if (member.IsOwner)
        {
            return; // Implied-all; no matrix to render.
        }

        _selectedSnapshot = await PermissionClient.GetUserPermissionsAsync(
            ShellState.ActiveCompany.Id, member.UserId);
        _activeGrants = new HashSet<string>(
            _selectedSnapshot?.ActiveGrants.Select(g => g.PermissionToken) ?? Array.Empty<string>(),
            StringComparer.Ordinal);
        _grantCounts[member.UserId] = _activeGrants.Count;
    }

    private async Task GrantAsync(string token)
    {
        if (_selectedMember is null) return;
        _busyToken = token;
        var outcome = await PermissionClient.GrantAsync(
            ShellState.ActiveCompany.Id, _selectedMember.UserId, token);
        ApplyOutcome(outcome, token, added: outcome.Succeeded && outcome.Applied);
    }

    private async Task RevokeAsync(string token)
    {
        if (_selectedMember is null) return;
        _busyToken = token;
        var outcome = await PermissionClient.RevokeAsync(
            ShellState.ActiveCompany.Id, _selectedMember.UserId, token);
        ApplyOutcome(outcome, token, added: !(outcome.Succeeded && outcome.Applied));
    }

    private void ApplyOutcome(PermissionMutationOutcome outcome, string token, bool added)
    {
        _busyToken = null;
        _mutationSucceeded = outcome.Succeeded;

        if (outcome.Succeeded)
        {
            if (added)
            {
                _activeGrants.Add(token);
            }
            else
            {
                _activeGrants.Remove(token);
            }
            if (_selectedMember is not null)
            {
                _grantCounts[_selectedMember.UserId] = _activeGrants.Count;
            }
            _mutationMessage = outcome.Applied
                ? outcome.Message
                : $"Already in target state — no change. ({outcome.Message})";
        }
        else
        {
            _mutationMessage = string.IsNullOrWhiteSpace(outcome.Message)
                ? $"Permission change rejected ({outcome.ResultCode})."
                : outcome.Message;
        }

        StateHasChanged();
    }

    private static string FormatModuleLabel(string moduleKey) => moduleKey switch
    {
        "ar" => "Accounts Receivable",
        "ap" => "Accounts Payable",
        "gl" => "General Ledger",
        "inventory" => "Inventory & Products",
        "task" => "Tasks",
        "reports" => "Reports",
        "settings" => "Settings",
        "company" => "Company",
        _ => moduleKey,
    };
}
