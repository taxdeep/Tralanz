@page "/settings/tax-rates"

@inject BusinessShellState ShellState
@inject TaxCodeClient TaxCodeClient
@inject TaxCodeSetClient TaxCodeSetClient
@inject CitusToastService Message

@*
    Tax Rates — per-company tax-code catalog. Lists, creates, edits and
    activate-toggles entries in the tax_codes table. The Settings → Tax
    Rates link in the nav menu points here.

    V1 surfaces the fields the journal-entry / invoice / bill UIs need
    today: code, name, rate, applies-to scope, active flag. The full
    migration-draft schema (recoverability_mode, account refs) stays
    server-side with safe defaults; advanced editing lands in a later
    batch when the Posting Engine wiring needs it.
*@

<PageTitle>Sales Tax | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusButton LeadingIcon="IconName.Plus"
                     Variant="CitusButtonVariant.Ghost"
                     Size="CitusButtonSize.Small"
                     Disabled="@_isLoading"
                     OnClick="StartCreating">
            New Tax Rule
        </CitusButton>
        <CitusButton LeadingIcon="IconName.Plus"
                     Variant="CitusButtonVariant.Primary"
                     Size="CitusButtonSize.Small"
                     Disabled="@_isLoading"
                     OnClick="StartCreatingCode">
            New Tax Code
        </CitusButton>
    </Actions>
</CitusPageHeader>

<CitusFormSection Title="Tax Rules">
    <HeaderActions>
        <label class="inline-flex items-center gap-2 text-sm">
            <input type="checkbox"
                   checked="@_includeInactive"
                   @onchange="@OnToggleInactive" />
            Show inactive
        </label>
        <CitusBadge Color="@(ShellState.IsCompanyReadOnly ? "orange" : "blue")">
            @ShellState.ActiveCompany.CompanyName
        </CitusBadge>
    </HeaderActions>
    <ChildContent>
        @if (_isLoading)
        {
            <CitusLoadingBar />
        }
        else if (_rows.Count == 0)
        {
            <CitusInlineEmpty Message="No Tax Rules yet. A Tax Rule is one tax (e.g. GST 5%). Click New Tax Rule to create your first one." />
        }
        else
        {
            <table class="citus-data-table">
                <thead>
                    <tr>
                        <th style="width: 8rem">Code</th>
                        <th>Name</th>
                        <th class="text-right" style="width: 6rem">Rate</th>
                        <th style="width: 8rem">Applies to</th>
                        <th style="width: 12rem">Registration #</th>
                        <th style="width: 6rem">Status</th>
                        <th style="width: 9rem"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _rows)
                    {
                        <tr class="@(row.IsActive ? null : "citus-data-table__row--muted")">
                            <td><span class="citus-inline-code">@row.Code</span></td>
                            <td>@row.Name</td>
                            <td class="text-right">@FormatRate(row.RatePercent)</td>
                            <td>@HumanizeAppliesTo(row.AppliesTo)</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(row.RegistrationNumber))
                                {
                                    <span class="citus-inline-code">@row.RegistrationNumber</span>
                                }
                                else
                                {
                                    <span class="text-fg-subtle text-xs">—</span>
                                }
                            </td>
                            <td>
                                <CitusBadge Color="@(row.IsActive ? "green" : "default")">
                                    @(row.IsActive ? "Active" : "Inactive")
                                </CitusBadge>
                            </td>
                            <td>
                                <div class="flex items-center gap-2">
                                    <CitusButton Variant="CitusButtonVariant.Ghost"
                                                 Size="CitusButtonSize.Small"
                                                 Disabled="@_isMutating"
                                                 OnClick="@(() => StartEditing(row))">
                                        Edit
                                    </CitusButton>
                                    <CitusButton Variant="CitusButtonVariant.Ghost"
                                                 Size="CitusButtonSize.Small"
                                                 Disabled="@_isMutating"
                                                 OnClick="@(() => ToggleActiveAsync(row))">
                                        @(row.IsActive ? "Deactivate" : "Activate")
                                    </CitusButton>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </ChildContent>
</CitusFormSection>

<CitusFormSection Title="Tax Codes">
    <HeaderActions>
        <span class="text-fg-subtle text-xs">A Tax Code bundles several Tax Rules (e.g. BC = GST + PST).</span>
    </HeaderActions>
    <ChildContent>
        @if (_isLoading)
        {
            <CitusLoadingBar />
        }
        else if (_codeRows.Count == 0)
        {
            <CitusInlineEmpty Message="No Tax Codes yet. Click New Tax Code to bundle a few Tax Rules into one selectable code." />
        }
        else
        {
            <table class="citus-data-table">
                <thead>
                    <tr>
                        <th style="width: 8rem">Code</th>
                        <th>Name</th>
                        <th>Rules</th>
                        <th style="width: 8rem">Applies to</th>
                        <th style="width: 6rem">Status</th>
                        <th style="width: 9rem"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _codeRows)
                    {
                        <tr class="@(row.IsActive ? null : "citus-data-table__row--muted")">
                            <td><span class="citus-inline-code">@row.Code</span></td>
                            <td>@row.Name</td>
                            <td>@DescribeMembers(row)</td>
                            <td>@HumanizeAppliesTo(row.AppliesTo)</td>
                            <td>
                                <CitusBadge Color="@(row.IsActive ? "green" : "default")">
                                    @(row.IsActive ? "Active" : "Inactive")
                                </CitusBadge>
                            </td>
                            <td>
                                <div class="flex items-center gap-2">
                                    <CitusButton Variant="CitusButtonVariant.Ghost"
                                                 Size="CitusButtonSize.Small"
                                                 Disabled="@_isMutating"
                                                 OnClick="@(() => StartEditingCode(row))">
                                        Edit
                                    </CitusButton>
                                    <CitusButton Variant="CitusButtonVariant.Ghost"
                                                 Size="CitusButtonSize.Small"
                                                 Disabled="@_isMutating"
                                                 OnClick="@(() => ToggleCodeActiveAsync(row))">
                                        @(row.IsActive ? "Deactivate" : "Activate")
                                    </CitusButton>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </ChildContent>
</CitusFormSection>

@if (_isFormOpen)
{
    <CitusFormSection Title="@(_editingId is null ? "New Tax Rule" : "Edit Tax Rule")">
        <form @onsubmit="OnSaveAsync" @onsubmit:preventDefault>
            <CitusFormGrid Columns="2">
                <CitusFormField Label="Code">
                    <input type="text"
                           class="citus-form-field__input"
                           value="@_formCode"
                           @oninput="@(e => _formCode = e.Value?.ToString() ?? string.Empty)"
                           maxlength="32"
                           placeholder="HST_ON, GST, PST_BC, …"
                           disabled="@_isMutating" />
                </CitusFormField>

                <CitusFormField Label="Name">
                    <input type="text"
                           class="citus-form-field__input"
                           value="@_formName"
                           @oninput="@(e => _formName = e.Value?.ToString() ?? string.Empty)"
                           maxlength="120"
                           placeholder="Ontario HST 13%"
                           disabled="@_isMutating" />
                </CitusFormField>

                <CitusFormField Label="Rate (%)">
                    @* RadzenNumeric with two-way @bind-Value works reliably across
                       browsers; the previous raw <input type="number"> with a manual
                       oninput handler intermittently rejected keystrokes when the
                       initial value attribute was set. *@
                    <RadzenNumeric TValue="decimal?"
                                   @bind-Value="_formRate"
                                   Min="0"
                                   Max="100"
                                   Step="0.01m"
                                   Format="0.######"
                                   ShowUpDown="false"
                                   Class="citus-control-full"
                                   Disabled="@_isMutating" />
                </CitusFormField>

                <CitusFormField Label="Applies to">
                    <select class="citus-form-field__input"
                            value="@_formAppliesTo"
                            @onchange="@(e => _formAppliesTo = e.Value?.ToString() ?? "both")"
                            disabled="@_isMutating">
                        <option value="sales">Sales only</option>
                        <option value="purchase">Purchases only</option>
                        <option value="both">Sales and purchases</option>
                    </select>
                </CitusFormField>
            </CitusFormGrid>

            <label class="citus-form-field mt-4">
                <span class="citus-form-field__label">
                    Tax registration number <span class="text-error">*</span>
                </span>
                <input type="text"
                       class="citus-form-field__input"
                       value="@_formRegistrationNumber"
                       @oninput="@(e => _formRegistrationNumber = e.Value?.ToString() ?? string.Empty)"
                       maxlength="64"
                       placeholder="e.g. GST/HST # 123456789RT0001"
                       disabled="@_isMutating" />
                <span class="text-fg-subtle text-xs mt-1">
                    Issued by the taxing authority (GST/HST #, VAT #, EIN, etc.).
                    Invoices and tax returns surface this number on documents that use this code.
                </span>
            </label>

            <label class="inline-flex items-center gap-2 text-sm mt-4">
                <input type="checkbox"
                       checked="@_formIsActive"
                       @onchange="@(e => _formIsActive = (bool)(e.Value ?? false))"
                       disabled="@_isMutating" />
                Active (available for selection on new documents)
            </label>

            <CitusFormActions PrimaryLabel="Save"
                              CancelLabel="Cancel"
                              IsSaving="@_isMutating"
                              OnSave="OnSaveAsync"
                              OnCancel="CancelForm" />
        </form>
    </CitusFormSection>
}

@if (_isCodeFormOpen)
{
    <CitusFormSection Title="@(_editingCodeId is null ? "New Tax Code" : "Edit Tax Code")">
        <form @onsubmit="OnSaveCodeAsync" @onsubmit:preventDefault>
            <CitusFormGrid Columns="2">
                <CitusFormField Label="Code">
                    <input type="text"
                           class="citus-form-field__input"
                           value="@_codeFormCode"
                           @oninput="@(e => _codeFormCode = e.Value?.ToString() ?? string.Empty)"
                           maxlength="32"
                           placeholder="BC, ON, …"
                           disabled="@_isMutating" />
                </CitusFormField>

                <CitusFormField Label="Name">
                    <input type="text"
                           class="citus-form-field__input"
                           value="@_codeFormName"
                           @oninput="@(e => _codeFormName = e.Value?.ToString() ?? string.Empty)"
                           maxlength="120"
                           placeholder="BC (GST + PST)"
                           disabled="@_isMutating" />
                </CitusFormField>

                <CitusFormField Label="Applies to">
                    <select class="citus-form-field__input"
                            value="@_codeFormAppliesTo"
                            @onchange="@(e => _codeFormAppliesTo = e.Value?.ToString() ?? "both")"
                            disabled="@_isMutating">
                        <option value="sales">Sales only</option>
                        <option value="purchase">Purchases only</option>
                        <option value="both">Sales and purchases</option>
                    </select>
                </CitusFormField>
            </CitusFormGrid>

            <div class="citus-form-field mt-4">
                <span class="citus-form-field__label">Tax Rules in this code</span>
                @if (_codeMembers.Count == 0)
                {
                    <span class="text-fg-subtle text-xs">
                        Add at least one Tax Rule. Each becomes its own tax leg on the journal entry, in the order listed.
                    </span>
                }
                else
                {
                    <table class="citus-data-table">
                        <tbody>
                            @for (var i = 0; i < _codeMembers.Count; i++)
                            {
                                var idx = i;
                                var member = _codeMembers[idx];
                                var rule = _rows.FirstOrDefault(r => r.Id == member.RuleId);
                                <tr>
                                    <td style="width: 2rem">@(idx + 1)</td>
                                    <td>
                                        <span class="citus-inline-code">@(rule?.Code ?? "?")</span>
                                        @(rule?.Name)
                                    </td>
                                    <td class="text-right" style="width: 5rem">@(rule is null ? "" : FormatRate(rule.RatePercent))</td>
                                    <td style="width: 9rem">
                                        <label class="inline-flex items-center gap-1 text-xs">
                                            <input type="checkbox"
                                                   checked="@member.IsCompound"
                                                   @onchange="@(e => SetMemberCompound(idx, (bool)(e.Value ?? false)))"
                                                   disabled="@_isMutating" />
                                            Compound
                                        </label>
                                    </td>
                                    <td style="width: 5rem">
                                        <CitusButton Variant="CitusButtonVariant.Ghost"
                                                     Size="CitusButtonSize.Small"
                                                     Disabled="@_isMutating"
                                                     OnClick="@(() => RemoveMember(idx))">
                                            Remove
                                        </CitusButton>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                <div class="mt-2">
                    <select class="citus-form-field__input"
                            value=""
                            @onchange="OnAddMember"
                            disabled="@_isMutating">
                        <option value="">+ Add a Tax Rule…</option>
                        @foreach (var r in AvailableRules())
                        {
                            <option value="@r.Id">@r.Code — @r.Name (@FormatRate(r.RatePercent))</option>
                        }
                    </select>
                </div>
            </div>

            <label class="inline-flex items-center gap-2 text-sm mt-4">
                <input type="checkbox"
                       checked="@_codeFormIsActive"
                       @onchange="@(e => _codeFormIsActive = (bool)(e.Value ?? false))"
                       disabled="@_isMutating" />
                Active (available for selection on new documents)
            </label>

            <CitusFormActions PrimaryLabel="Save"
                              CancelLabel="Cancel"
                              IsSaving="@_isMutating"
                              OnSave="OnSaveCodeAsync"
                              OnCancel="CancelCodeForm" />
        </form>
    </CitusFormSection>
}

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Settings",
        Title = "Sales Tax",
        Subtitle = "Tax Rules (single taxes) and Tax Codes (bundles of Rules). Used by the per-line tax pickers on documents."
    };

    private bool _isLoading = true;
    private bool _isMutating;
    private bool _isFormOpen;
    private bool _includeInactive;
    private Guid? _editingId;
    private string _formCode = string.Empty;
    private string _formName = string.Empty;
    private decimal? _formRate = 0m;
    private string _formAppliesTo = "both";
    private string _formRegistrationNumber = string.Empty;
    private bool _formIsActive = true;

    private List<TaxCodeSummary> _rows = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            var rulesTask = TaxCodeClient.ListAsync(includeInactive: _includeInactive);
            var codesTask = TaxCodeSetClient.ListAsync(includeInactive: _includeInactive);
            await Task.WhenAll(rulesTask, codesTask);
            _rows = rulesTask.Result.OrderByDescending(r => r.IsActive).ThenBy(r => r.Code).ToList();
            _codeRows = codesTask.Result.OrderByDescending(r => r.IsActive).ThenBy(r => r.Code).ToList();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnToggleInactive(ChangeEventArgs args)
    {
        _includeInactive = (bool)(args.Value ?? false);
        await LoadAsync();
    }

    private void StartCreating()
    {
        _editingId = null;
        _formCode = string.Empty;
        _formName = string.Empty;
        _formRate = 0m;
        _formAppliesTo = "both";
        _formRegistrationNumber = string.Empty;
        _formIsActive = true;
        _isFormOpen = true;
    }

    private void StartEditing(TaxCodeSummary row)
    {
        _editingId = row.Id;
        _formCode = row.Code;
        _formName = row.Name;
        _formRate = row.RatePercent;
        _formAppliesTo = row.AppliesTo;
        _formRegistrationNumber = row.RegistrationNumber ?? string.Empty;
        _formIsActive = row.IsActive;
        _isFormOpen = true;
    }

    private void CancelForm()
    {
        _isFormOpen = false;
        _editingId = null;
    }

    private async Task OnSaveAsync()
    {
        if (_isMutating) return;

        if (string.IsNullOrWhiteSpace(_formCode))
        {
            await Message.WarningAsync("Code is required.");
            return;
        }
        if (string.IsNullOrWhiteSpace(_formName))
        {
            await Message.WarningAsync("Name is required.");
            return;
        }
        var rate = _formRate ?? 0m;
        if (rate < 0m || rate > 100m)
        {
            await Message.WarningAsync("Rate must be between 0 and 100.");
            return;
        }
        if (string.IsNullOrWhiteSpace(_formRegistrationNumber))
        {
            await Message.WarningAsync("Tax registration number is required.");
            return;
        }

        _isMutating = true;
        try
        {
            var registration = _formRegistrationNumber.Trim();
            var payload = new TaxCodeUpsertPayload(
                Code: _formCode.Trim(),
                Name: _formName.Trim(),
                RatePercent: rate,
                AppliesTo: _formAppliesTo,
                RegistrationNumber: registration,
                IsActive: _formIsActive);

            TaxCodeMutationOutcome outcome = _editingId is null
                ? await TaxCodeClient.CreateAsync(payload)
                : await TaxCodeClient.UpdateAsync(_editingId.Value, payload);

            if (!outcome.Succeeded)
            {
                await Message.WarningAsync(string.IsNullOrWhiteSpace(outcome.ErrorMessage)
                    ? "Unable to save tax code."
                    : outcome.ErrorMessage);
                return;
            }

            _isFormOpen = false;
            _editingId = null;
            await LoadAsync();
            await Message.SuccessAsync(_editingId is null ? "Tax code created." : "Tax code updated.");
        }
        finally
        {
            _isMutating = false;
        }
    }

    private async Task ToggleActiveAsync(TaxCodeSummary row)
    {
        if (_isMutating) return;
        _isMutating = true;
        try
        {
            var outcome = await TaxCodeClient.SetActiveAsync(row.Id, !row.IsActive);
            if (!outcome.Succeeded)
            {
                await Message.WarningAsync(outcome.ErrorMessage ?? "Unable to update tax code status.");
                return;
            }
            await LoadAsync();
            await Message.SuccessAsync(row.IsActive ? "Tax code deactivated." : "Tax code activated.");
        }
        finally
        {
            _isMutating = false;
        }
    }

    private static string FormatRate(decimal ratePercent) =>
        ratePercent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) + "%";

    private static string HumanizeAppliesTo(string appliesTo) => appliesTo switch
    {
        "sales" => "Sales only",
        "purchase" => "Purchases only",
        "both" => "Sales + purchases",
        _ => appliesTo,
    };

    // ---------------------------------------------------------------------
    // R2: Tax Codes (bundles of Tax Rules) — tax_code_sets.
    // ---------------------------------------------------------------------
    private List<TaxCodeSetSummary> _codeRows = new();
    private bool _isCodeFormOpen;
    private Guid? _editingCodeId;
    private string _codeFormCode = string.Empty;
    private string _codeFormName = string.Empty;
    private string _codeFormAppliesTo = "both";
    private bool _codeFormIsActive = true;
    private readonly List<CodeMemberDraft> _codeMembers = new();

    private void StartCreatingCode()
    {
        _editingCodeId = null;
        _codeFormCode = string.Empty;
        _codeFormName = string.Empty;
        _codeFormAppliesTo = "both";
        _codeFormIsActive = true;
        _codeMembers.Clear();
        _isCodeFormOpen = true;
    }

    private void StartEditingCode(TaxCodeSetSummary row)
    {
        _editingCodeId = row.Id;
        _codeFormCode = row.Code;
        _codeFormName = row.Name;
        _codeFormAppliesTo = row.AppliesTo;
        _codeFormIsActive = row.IsActive;
        _codeMembers.Clear();
        foreach (var m in row.Members.OrderBy(m => m.Sequence))
        {
            _codeMembers.Add(new CodeMemberDraft { RuleId = m.RuleId, IsCompound = m.IsCompound });
        }
        _isCodeFormOpen = true;
    }

    private void CancelCodeForm()
    {
        _isCodeFormOpen = false;
        _editingCodeId = null;
    }

    private IEnumerable<TaxCodeSummary> AvailableRules()
        => _rows.Where(r => r.IsActive && _codeMembers.All(m => m.RuleId != r.Id));

    private void OnAddMember(ChangeEventArgs args)
    {
        if (Guid.TryParse(args.Value?.ToString(), out var ruleId)
            && _codeMembers.All(m => m.RuleId != ruleId))
        {
            _codeMembers.Add(new CodeMemberDraft { RuleId = ruleId, IsCompound = false });
        }
    }

    private void RemoveMember(int index)
    {
        if (index >= 0 && index < _codeMembers.Count)
        {
            _codeMembers.RemoveAt(index);
        }
    }

    private void SetMemberCompound(int index, bool value)
    {
        if (index >= 0 && index < _codeMembers.Count)
        {
            _codeMembers[index].IsCompound = value;
        }
    }

    private async Task OnSaveCodeAsync()
    {
        if (_isMutating) return;
        if (string.IsNullOrWhiteSpace(_codeFormCode)) { await Message.WarningAsync("Code is required."); return; }
        if (string.IsNullOrWhiteSpace(_codeFormName)) { await Message.WarningAsync("Name is required."); return; }
        if (_codeMembers.Count == 0) { await Message.WarningAsync("Add at least one Tax Rule."); return; }

        _isMutating = true;
        try
        {
            var payload = new TaxCodeSetUpsertPayload(
                Code: _codeFormCode.Trim(),
                Name: _codeFormName.Trim(),
                AppliesTo: _codeFormAppliesTo,
                IsActive: _codeFormIsActive,
                Members: _codeMembers.Select((m, i) => new TaxCodeSetMemberPayload(m.RuleId, i + 1, m.IsCompound)).ToList());

            var wasCreate = _editingCodeId is null;
            var outcome = wasCreate
                ? await TaxCodeSetClient.CreateAsync(payload)
                : await TaxCodeSetClient.UpdateAsync(_editingCodeId!.Value, payload);

            if (!outcome.Succeeded)
            {
                await Message.WarningAsync(string.IsNullOrWhiteSpace(outcome.ErrorMessage) ? "Unable to save Tax Code." : outcome.ErrorMessage);
                return;
            }

            _isCodeFormOpen = false;
            _editingCodeId = null;
            await LoadAsync();
            await Message.SuccessAsync(wasCreate ? "Tax Code created." : "Tax Code updated.");
        }
        finally
        {
            _isMutating = false;
        }
    }

    private async Task ToggleCodeActiveAsync(TaxCodeSetSummary row)
    {
        if (_isMutating) return;
        _isMutating = true;
        try
        {
            var outcome = await TaxCodeSetClient.SetActiveAsync(row.Id, !row.IsActive);
            if (!outcome.Succeeded)
            {
                await Message.WarningAsync(outcome.ErrorMessage ?? "Unable to update Tax Code status.");
                return;
            }
            await LoadAsync();
            await Message.SuccessAsync(row.IsActive ? "Tax Code deactivated." : "Tax Code activated.");
        }
        finally
        {
            _isMutating = false;
        }
    }

    private static string DescribeMembers(TaxCodeSetSummary row)
        => row.Members.Count == 0
            ? "—"
            : string.Join(" + ", row.Members.OrderBy(m => m.Sequence).Select(m => $"{m.RuleCode} {FormatRate(m.RatePercent)}"));

    private sealed class CodeMemberDraft
    {
        public Guid RuleId { get; set; }
        public bool IsCompound { get; set; }
    }
}
