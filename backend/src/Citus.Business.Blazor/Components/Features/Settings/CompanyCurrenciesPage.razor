@page "/settings/currencies"

@inject BusinessShellState ShellState

<PageTitle>Currencies | Citus Business</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <AntDesign.Tag Color="@("default")">Read-only</AntDesign.Tag>
    </Actions>
</CitusPageHeader>

<AntDesign.Alert Type="@AntDesign.AlertType.Info"
                 ShowIcon="true"
                 Class="mb-6">
    <MessageTemplate>
        Base currency and multi-currency state are company-scoped truth. Switching the base currency requires a governed migration and is not editable from this surface.
    </MessageTemplate>
</AntDesign.Alert>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <CitusStatCard
        Label="Base currency"
        Value="@ShellState.ActiveCompany.BaseCurrencyCode"
        Description="The accounting truth currency for this company."
        Icon="IconName.Coin"
        Tone="StatTone.Primary" />
    <CitusStatCard
        Label="Multi-currency"
        Value="@(ShellState.ActiveCompany.MultiCurrencyEnabled ? "Enabled" : "Disabled")"
        Description="Toggles whether transactional currency may differ from base."
        Icon="IconName.Coin"
        Tone="@(ShellState.ActiveCompany.MultiCurrencyEnabled ? StatTone.Success : StatTone.Neutral)" />
    <CitusStatCard
        Label="Open accessible companies"
        Value="@ShellState.AvailableCompanies.Count.ToString()"
        Description="Switch from the top bar to view another company's settings."
        Icon="IconName.BuildingSkyscraper"
        Tone="StatTone.Info" />
</div>

<section class="citus-panel">
    <h2 class="citus-panel__title">FX governance</h2>
    <ul class="citus-bullet-list">
        <li>Base currency is locked at company creation. Migrations require backend governance.</li>
        <li>FX rate snapshots remain immutable at posting time and live with each journal entry.</li>
        <li>Multi-currency enablement gates whether transaction currency may differ from base on posted documents.</li>
        <li>FX revaluation is a backend engine flow, not a UI-driven setting.</li>
    </ul>
</section>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Settings",
        Title = "Currencies",
        Subtitle = "Base currency, multi-currency state, and the FX governance rules that surround them."
    };
}
