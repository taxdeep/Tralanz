@page "/settings/tax-return"
@page "/tax-return"

@inject BusinessShellState ShellState
@inject BusinessWriteFlowClient WriteFlow
@inject NavigationManager NavigationManager
@inject CitusToastService Message

@*
    TaxReturnPage — period close for sales-tax filings (GST/HST in
    Canada, QST, PST, VAT — the regime is a parameter so the same
    page handles each).

    The flow is intentionally narrow for V1:
      1. Pick the regime + filing frequency. Period bounds default
         from the frequency (monthly = current month, quarterly =
         current quarter, annual = current fiscal year).
      2. Hit "Recalculate" to pull the auto-totals from the GL
         (collected / ITCs). V1 these come back as zeros from the
         stub Post; once the backend lands they query
         /accounting/tax-returns/preview.
      3. Type any prior-period adjustments + a justification note.
      4. Type the regulator confirmation number after filing on the
         portal — operators usually file on CRA / Revenu Quebec
         first, then come here to record the snapshot.
      5. Post → emits the JE that moves the tax-payable balance off
         the accrual account and onto a single net row that becomes
         a Pay Bills (owe) or Receive Payment (refund) target.

    Out of scope for V1: full line-by-line CRA Form 5000-S box mapping,
    Quebec QST split-bracketing, recapture / quick-method elections.
    Those land when the backend Tax Engine ships.
*@

<PageTitle>Tax Return | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <a class="citus-button citus-button--ghost" href="settings/tax-rates">
            <CitusIcon Name="IconName.ArrowLeft" Size="IconSize.Inline" />
            <span>Back to tax rates</span>
        </a>
    </Actions>
</CitusPageHeader>

@if (ShellState.AreWritesBlocked)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" ShowIcon="true" Message="@ShellState.WriteBlockMessage" Class="mb-4" />
}

@if (!string.IsNullOrWhiteSpace(_validation))
{
    <CitusAlert Severity="CitusAlertSeverity.Error" Message="@_validation" ShowIcon="true" Class="mb-4" />
}

<WriteFlowResultAlert Result="@_lastResult" />

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <div class="lg:col-span-8 flex flex-col gap-6">
        <section class="citus-panel">
            <h2 class="citus-panel__title">Period</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="text-sm font-medium block mb-1">Regime</label>
                    <select class="citus-form-field__input" value="@_taxRegime" @onchange="OnRegimeChanged">
                        <option value="GST_HST">GST / HST (Canada)</option>
                        <option value="QST">QST (Quebec)</option>
                        <option value="PST_BC">PST (British Columbia)</option>
                        <option value="PST_SK">PST (Saskatchewan)</option>
                        <option value="PST_MB">RST (Manitoba)</option>
                        <option value="VAT_UK">VAT (United Kingdom)</option>
                        <option value="VAT_EU">VAT (European Union)</option>
                        <option value="OTHER">Other</option>
                    </select>
                </div>
                <div>
                    <label class="text-sm font-medium block mb-1">Filing frequency</label>
                    <select class="citus-form-field__input" value="@_filingFrequency" @onchange="OnFrequencyChanged">
                        <option value="monthly">Monthly</option>
                        <option value="quarterly">Quarterly</option>
                        <option value="annual">Annual</option>
                    </select>
                </div>
                <div>
                    <label class="text-sm font-medium block mb-1">Period start</label>
                    <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_periodStart" Class="citus-control-full" />
                </div>
                <div>
                    <label class="text-sm font-medium block mb-1">Period end</label>
                    <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_periodEnd" Class="citus-control-full" />
                </div>
            </div>
            <div class="mt-3">
                <CitusButton Variant="CitusButtonVariant.Ghost" LeadingIcon="IconName.Refresh"
                             Disabled="@(_isLoading || _isSubmitting)"
                             OnClick="RecalculateAsync">
                    @(_isLoading ? "Recalculating..." : "Recalculate from GL")
                </CitusButton>
                <span class="text-fg-muted text-sm ml-3">
                    Pulls collected-tax + ITC totals for the picked period from posted journal entries.
                </span>
            </div>
        </section>

        <section class="citus-panel">
            <h2 class="citus-panel__title">Calculation</h2>
            <table class="citus-keyvalue">
                <tbody>
                    <tr>
                        <th>Sales tax collected (output)</th>
                        <td class="text-right">@FormatAmount(_collectedAmount) @ShellState.ActiveCompany.BaseCurrencyCode</td>
                    </tr>
                    <tr>
                        <th>Input tax credits (ITC, paid on purchases)</th>
                        <td class="text-right">@FormatAmount(_inputCreditsAmount) @ShellState.ActiveCompany.BaseCurrencyCode</td>
                    </tr>
                    <tr>
                        <th>Adjustments</th>
                        <td class="text-right">
                            <input type="text"
                                   inputmode="decimal"
                                   class="citus-form-field__input text-right"
                                   style="width: 12rem; display: inline-block;"
                                   value="@FormatDecimal(_adjustmentsAmount)"
                                   @oninput="OnAdjustmentsInput" />
                        </td>
                    </tr>
                    <tr class="citus-data-table__total">
                        <th>
                            @(NetIsPayable ? "Net payable to regulator" : "Net refund expected")
                            <div class="text-fg-subtle text-xs font-normal mt-1">
                                Net = Collected − ITCs + Adjustments
                            </div>
                        </th>
                        <td class="text-right">
                            <strong>@FormatAmount(Math.Abs(NetAmount)) @ShellState.ActiveCompany.BaseCurrencyCode</strong>
                        </td>
                    </tr>
                </tbody>
            </table>
            <div class="mt-3">
                <label class="text-sm font-medium block mb-1">Adjustment note</label>
                <CitusInput TValue="string" @bind-Value="_adjustmentsNote"
                            Placeholder="Why is the adjustment non-zero? Prior-period correction, recapture, etc." />
            </div>
        </section>

        <section class="citus-panel">
            <h2 class="citus-panel__title">Filing record</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="text-sm font-medium block mb-1">Regulator confirmation #</label>
                    <CitusInput TValue="string" @bind-Value="_regulatorReferenceNo"
                                Placeholder="CRA confirmation, Revenu Québec ref, HMRC receipt..." />
                </div>
                <div>
                    <label class="text-sm font-medium block mb-1">Memo</label>
                    <CitusInput TValue="string" @bind-Value="_memo" Placeholder="Internal note; optional." />
                </div>
            </div>
        </section>
    </div>

    <div class="lg:col-span-4 flex flex-col gap-6">
        <section class="citus-panel">
            <h2 class="citus-panel__title">Summary</h2>
            <table class="citus-keyvalue">
                <tbody>
                    <tr><th>Company</th><td>@ShellState.ActiveCompany.CompanyCode</td></tr>
                    <tr><th>Regime</th><td>@HumanizeRegime(_taxRegime)</td></tr>
                    <tr><th>Frequency</th><td>@HumanizeFrequency(_filingFrequency)</td></tr>
                    <tr>
                        <th>Period</th>
                        <td>
                            @(_periodStart?.ToString("yyyy-MM-dd") ?? "?") →
                            @(_periodEnd?.ToString("yyyy-MM-dd") ?? "?")
                        </td>
                    </tr>
                    <tr><th>Collected</th><td class="text-right">@FormatAmount(_collectedAmount)</td></tr>
                    <tr><th>ITCs</th><td class="text-right">@FormatAmount(_inputCreditsAmount)</td></tr>
                    <tr><th>Adjustments</th><td class="text-right">@FormatAmount(_adjustmentsAmount)</td></tr>
                    <tr><th>Net</th><td class="text-right"><strong>@FormatAmount(Math.Abs(NetAmount))</strong> @(NetIsPayable ? "owe" : "refund")</td></tr>
                </tbody>
            </table>
        </section>

        <section class="citus-panel">
            <h2 class="citus-panel__title">File &amp; post</h2>
            <p class="text-fg-muted text-sm mb-3">
                Posting locks the period and emits the net JE
                — moves @(NetIsPayable ? "the payable" : "the refund")
                onto a row you can settle with @(NetIsPayable ? "Pay Bills" : "Receive Payment").
            </p>
            <CitusButton Variant="CitusButtonVariant.Primary" Block="true"
                         Disabled="@(_periodStart is null || _periodEnd is null || ShellState.AreWritesBlocked || _isSubmitting)"
                         OnClick="PostAsync">
                @(_isSubmitting ? "Posting..." : "File and post")
            </CitusButton>
        </section>
    </div>
</div>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Settings",
        Title = "Tax return",
        Subtitle = "Period close for sales-tax filings. Auto-totals + manual adjustments → one net JE."
    };

    private string _taxRegime = "GST_HST";
    private string _filingFrequency = "quarterly";
    private DateTime? _periodStart;
    private DateTime? _periodEnd;
    private decimal _collectedAmount;
    private decimal _inputCreditsAmount;
    private decimal _adjustmentsAmount;
    private string _adjustmentsNote = string.Empty;
    private string _regulatorReferenceNo = string.Empty;
    private string _memo = string.Empty;

    private bool _isLoading;
    private bool _isSubmitting;
    private string? _validation;
    private WriteFlowResult? _lastResult;

    private decimal NetAmount => _collectedAmount - _inputCreditsAmount + _adjustmentsAmount;
    private bool NetIsPayable => NetAmount >= 0;

    protected override void OnInitialized() => DefaultPeriodFromFrequency();

    private void OnRegimeChanged(ChangeEventArgs e)
    {
        _taxRegime = e.Value?.ToString() ?? "GST_HST";
    }

    private void OnFrequencyChanged(ChangeEventArgs e)
    {
        _filingFrequency = e.Value?.ToString() ?? "quarterly";
        DefaultPeriodFromFrequency();
    }

    /// <summary>
    /// Pre-fill period bounds from the picked frequency. Operators
    /// almost always file the most-recently-closed period, so default
    /// to "previous full period" rather than "current period".
    /// </summary>
    private void DefaultPeriodFromFrequency()
    {
        var today = DateTime.Today;
        switch (_filingFrequency)
        {
            case "monthly":
                var firstOfThisMonth = new DateTime(today.Year, today.Month, 1);
                _periodEnd = firstOfThisMonth.AddDays(-1);
                _periodStart = new DateTime(_periodEnd.Value.Year, _periodEnd.Value.Month, 1);
                break;
            case "annual":
                _periodStart = new DateTime(today.Year - 1, 1, 1);
                _periodEnd = new DateTime(today.Year - 1, 12, 31);
                break;
            case "quarterly":
            default:
                var quarter = (today.Month - 1) / 3;
                var prevQuarter = quarter - 1;
                var year = today.Year;
                if (prevQuarter < 0) { prevQuarter = 3; year -= 1; }
                _periodStart = new DateTime(year, prevQuarter * 3 + 1, 1);
                _periodEnd = _periodStart.Value.AddMonths(3).AddDays(-1);
                break;
        }
    }

    private void OnAdjustmentsInput(ChangeEventArgs e)
    {
        _adjustmentsAmount = ParseDecimal(e.Value?.ToString());
    }

    private async Task RecalculateAsync()
    {
        if (_periodStart is null || _periodEnd is null) { _validation = "Pick a valid period first."; return; }
        _validation = null;
        _isLoading = true;
        try
        {
            // Backend preview endpoint not wired yet — when it lands,
            // this calls /accounting/tax-returns/preview?regime=...&from=...&to=...
            // and populates _collectedAmount / _inputCreditsAmount.
            // Until then we leave the totals at zero so the operator sees the
            // page wiring is real but the numbers are pending.
            await Task.Delay(150);
            _collectedAmount = 0m;
            _inputCreditsAmount = 0m;
        }
        finally { _isLoading = false; }
    }

    private async Task PostAsync()
    {
        _validation = null;
        _lastResult = null;

        if (_periodStart is null || _periodEnd is null) { _validation = "Pick a period."; return; }
        if (_periodEnd < _periodStart) { _validation = "Period end must be on or after the start."; return; }

        _isSubmitting = true;
        try
        {
            var draft = new TaxReturnDraft
            {
                CompanyId = ShellState.ActiveCompany.Id,
                UserId = ShellState.User.Id,
                PeriodStart = DateOnly.FromDateTime(_periodStart.Value.Date),
                PeriodEnd = DateOnly.FromDateTime(_periodEnd.Value.Date),
                TaxRegime = _taxRegime,
                FilingFrequency = _filingFrequency,
                BaseCurrencyCode = ShellState.ActiveCompany.BaseCurrencyCode.Trim().ToUpperInvariant(),
                CollectedAmount = _collectedAmount,
                InputCreditsAmount = _inputCreditsAmount,
                AdjustmentsAmount = _adjustmentsAmount,
                AdjustmentsNote = _adjustmentsNote.Trim(),
                RegulatorReferenceNo = _regulatorReferenceNo.Trim(),
                Memo = _memo.Trim(),
            };
            _lastResult = await WriteFlow.PostTaxReturnAsync(draft);
            if (_lastResult.Succeeded)
            {
                await Message.SuccessAsync("Tax return posted.");
                NavigationManager.NavigateTo(_lastResult.DocumentId is { } id ? $"tax-returns/{id:D}" : "tax-returns");
            }
            else { await Message.InfoAsync(_lastResult.Message); }
        }
        finally { _isSubmitting = false; }
    }

    private static string HumanizeRegime(string regime) => regime switch
    {
        "GST_HST" => "GST / HST",
        "QST" => "QST",
        "PST_BC" => "PST (BC)",
        "PST_SK" => "PST (SK)",
        "PST_MB" => "RST (MB)",
        "VAT_UK" => "VAT (UK)",
        "VAT_EU" => "VAT (EU)",
        _ => regime
    };

    private static string HumanizeFrequency(string frequency) => frequency switch
    {
        "monthly" => "Monthly",
        "quarterly" => "Quarterly",
        "annual" => "Annual",
        _ => frequency
    };

    private static decimal ParseDecimal(string? raw) =>
        decimal.TryParse(raw, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : 0m;

    private static string FormatAmount(decimal amount) => amount.ToString("N2");
    private static string FormatDecimal(decimal value) => value == 0m ? string.Empty : value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
}
