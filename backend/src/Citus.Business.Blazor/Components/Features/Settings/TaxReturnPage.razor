@page "/settings/tax-return"
@page "/tax-return"

@inject BusinessShellState ShellState

@*
    TaxReturnPage — period close for sales-tax filings (GST/HST in
    Canada, QST, PST, VAT, etc.).

    NOTE: The backend Tax Engine (auto-total from GL, JE emission,
    period-lock writeback) is not wired yet. The full preview-form
    UI used to live here; it called a stub /accounting/tax-returns
    endpoint that returned zeros and never posted. To prevent
    accountants from filing zero numbers and thinking the system
    captured them, the form has been replaced with a clear "coming
    soon" notice. The earlier form scaffolding is preserved in git
    history at commit ffdffc6~ — restore it when /accounting/tax-
    returns/preview and /accounting/tax-returns POST land.
*@

<PageTitle>Tax Return | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusLinkButton Href="settings/tax-rates"
                         Variant="CitusButtonVariant.Ghost"
                         LeadingIcon="IconName.ArrowLeft">
            Back to tax rates
        </CitusLinkButton>
    </Actions>
</CitusPageHeader>

<CitusFormSection>
    <div class="text-center py-8">
        <CitusIcon Name="IconName.Report" Size="IconSize.Display" />
        <h2 class="text-lg font-semibold mt-3">Tax return filing is in development.</h2>
        <p class="text-fg-muted text-sm mt-2 mb-4 max-w-2xl mx-auto">
            The auto-total from posted journal entries (collected output tax + ITCs from purchases),
            the period-lock JE that moves the net balance to a payable / refundable row, and the
            regulator-confirmation snapshot all land together with the V2 Tax Engine. Until then,
            this page would show zeros and accept inputs that aren't actually posted to the GL —
            so it's been replaced with this notice.
        </p>
        <p class="text-fg-muted text-sm max-w-2xl mx-auto mb-4">
            <strong>For now</strong>: file with your regulator (CRA, Revenu Québec, HMRC, etc.)
            on their portal. Record the net result as a manual journal entry against your tax-
            payable / tax-receivable accounts.
        </p>
        <CitusLinkButton Href="journal-entry/new"
                         Variant="CitusButtonVariant.Primary">
            Open Journal Entry →
        </CitusLinkButton>
    </div>
</CitusFormSection>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Settings",
        Title = "Tax return",
        Subtitle = "Period close for sales-tax filings — coming with the V2 Tax Engine."
    };
}
