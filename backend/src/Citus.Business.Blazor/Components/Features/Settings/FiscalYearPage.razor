@page "/settings/fiscal-year"

@inject BusinessShellState ShellState

<PageTitle>Fiscal Year | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusBadge Color="@("default")">Read-only</CitusBadge>
    </Actions>
</CitusPageHeader>

<CitusAlert Severity="CitusAlertSeverity.Info"
                 ShowIcon="true"
                 Message="Fiscal year configuration is captured during first-company setup. Changing it requires a governed migration so this surface stays read-only for now."
                 Class="mb-6" />

<CitusFormSection Title="Fiscal year">
    <CitusKeyValueTable>
        <CitusKeyValueRow Label="Company">@ShellState.ActiveCompany.CompanyName (<span class="citus-inline-code">@ShellState.ActiveCompany.CompanyCode</span>)</CitusKeyValueRow>
        <CitusKeyValueRow Label="Fiscal year end">Captured at first-company setup (see SysAdmin Setup Wizard)</CitusKeyValueRow>
        <CitusKeyValueRow Label="Period frequency">Monthly (governed by Posting Engine)</CitusKeyValueRow>
        <CitusKeyValueRow Label="Year-end policies">Backend-owned. Closing entries flow through the FX revaluation and posting engines.</CitusKeyValueRow>
    </CitusKeyValueTable>
</CitusFormSection>

<CitusFormSection Title="Why fiscal year stays read-only">
    <ul class="citus-bullet-list">
        <li>Period boundaries are referenced by every posted journal entry and aging report; UI-driven changes risk silently invalidating prior reports.</li>
        <li>Fiscal year migrations require a backend script, not a settings toggle, and must be audited.</li>
        <li>The first-company wizard is the canonical place where this value is set.</li>
    </ul>
</CitusFormSection>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Settings",
        Title = "Fiscal year",
        Subtitle = "Read-only view of the active company's fiscal year configuration."
    };
}
