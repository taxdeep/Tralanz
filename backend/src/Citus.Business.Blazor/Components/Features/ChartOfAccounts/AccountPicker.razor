@*
    AccountPicker — typed-input + popup for selecting a chart-of-accounts
    row inline on document forms (journal entry lines, invoice line account
    column, etc.). Reuses UnitySearchPickerService for ranking — the
    learned "you pick this account often" signal still applies — but
    enriches each result with currency / detail-type metadata from
    AccountClient so the popup can render the QuickBooks-style triple
    column (code | name - CCY | detail/parent hint).

    Includes an inline "+ Add new {query}" affordance that opens a
    minimal expansion panel: code / name / root type / currency, posts
    via AccountClient.CreateAsync, then auto-selects the new account.
    The newly-created row also lands in the local cache so subsequent
    keystrokes show it without waiting for the UnitySearch projection
    refresh.
*@

@namespace Citus.Business.Blazor.Components.Features.ChartOfAccounts
@inject AccountClient AccountClient
@inject Citus.Modules.UnitySearch.Blazor.UnitySearchPickerService PickerService
@inject CitusToastService Toast

<div class="citus-account-picker @(Disabled ? "citus-account-picker--disabled" : null)">
    <div class="citus-account-picker__control" @onclick="HandleControlClick">
        <input class="citus-account-picker__input"
               type="text"
               value="@_searchText"
               placeholder="@Placeholder"
               disabled="@Disabled"
               @ref="_inputRef"
               @oninput="HandleInputAsync"
               @onfocus="HandleFocus"
               @onblur="HandleBlurAsync"
               @onkeydown="HandleKeyDownAsync" />
        <i class="citus-account-picker__chevron ti ti-chevron-down" aria-hidden="true"></i>
        @if (!Disabled && (!string.IsNullOrWhiteSpace(_searchText) || SelectedId.HasValue))
        {
            <button type="button"
                    class="citus-account-picker__clear"
                    @onmousedown:preventDefault
                    @onclick="ClearAsync"
                    aria-label="Clear">×</button>
        }
    </div>

    @if (_showResults)
    {
        <div class="citus-account-picker__panel" role="listbox">
            @if (CanCreate)
            {
                <button type="button"
                        class="citus-account-picker__create"
                        @onmousedown:preventDefault
                        @onclick="OpenCreatePanelAsync">
                    <span class="citus-account-picker__create-plus">+</span>
                    <span>Add new @(_searchText.Trim().Length > 0 ? $"\"{_searchText.Trim()}\"" : "account")</span>
                </button>
            }
            @if (_loading)
            {
                <div class="citus-account-picker__empty">Loading…</div>
            }
            else if (_visibleRows.Count == 0)
            {
                <div class="citus-account-picker__empty">No matching accounts.</div>
            }
            else
            {
                @for (var idx = 0; idx < _visibleRows.Count; idx++)
                {
                    var i = idx;
                    var row = _visibleRows[i];
                    <button type="button"
                            class="citus-account-picker__option @(i == _highlightedIndex ? "is-active" : null)"
                            @onmousedown:preventDefault
                            @onclick="@(() => SelectAsync(row))"
                            @onmouseover="() => _highlightedIndex = i">
                        <span class="citus-account-picker__option-code">@RenderHighlight(row.Code)</span>
                        <span class="citus-account-picker__option-name">
                            @RenderHighlight(row.Name)
                            @if (!string.IsNullOrEmpty(row.CurrencyCode))
                            {
                                <span class="citus-account-picker__option-ccy"> - @row.CurrencyCode</span>
                            }
                        </span>
                        <span class="citus-account-picker__option-meta">@FormatMeta(row)</span>
                    </button>
                }
            }
        </div>
    }

    @if (_creating)
    {
        <div class="citus-account-picker__create-panel">
            <div class="citus-account-picker__create-row">
                <label class="text-xs font-medium block mb-1">Code</label>
                <input class="citus-account-picker__create-input"
                       value="@_newCode"
                       @oninput="@(e => _newCode = e.Value?.ToString() ?? string.Empty)" />
            </div>
            <div class="citus-account-picker__create-row">
                <label class="text-xs font-medium block mb-1">Name</label>
                <input class="citus-account-picker__create-input"
                       value="@_newName"
                       @oninput="@(e => _newName = e.Value?.ToString() ?? string.Empty)" />
            </div>
            <div class="citus-account-picker__create-row">
                <label class="text-xs font-medium block mb-1">Type</label>
                <select class="citus-account-picker__create-input"
                        value="@_newRootType"
                        @onchange="OnNewRootTypeChanged">
                    <option value="asset">Asset</option>
                    <option value="liability">Liability</option>
                    <option value="equity">Equity</option>
                    <option value="revenue">Revenue</option>
                    <option value="cost_of_sales">Cost of Sales</option>
                    <option value="expense">Expense</option>
                </select>
            </div>
            @* Batch B: Detail type — same catalog as ChartOfAccountsPage's
               full form (AccountDetailTypeCatalog). Filtered by the
               selected Root type; resets when Root type changes so a
               stale child-of-different-root doesn't leak through. *@
            <div class="citus-account-picker__create-row">
                <label class="text-xs font-medium block mb-1">Detail type (optional)</label>
                <select class="citus-account-picker__create-input"
                        value="@_newDetailType"
                        @onchange="@(e => _newDetailType = e.Value?.ToString() ?? string.Empty)">
                    <option value="">—</option>
                    @foreach (var detail in AccountDetailTypeCatalog.OptionsFor(_newRootType))
                    {
                        <option value="@detail.Value">@detail.Label</option>
                    }
                </select>
            </div>
            <div class="citus-account-picker__create-actions">
                <button type="button" class="citus-account-picker__create-cancel" @onclick="CancelCreate">Cancel</button>
                <button type="button"
                        class="citus-account-picker__create-save"
                        disabled="@(_creatingBusy || string.IsNullOrWhiteSpace(_newCode) || string.IsNullOrWhiteSpace(_newName))"
                        @onclick="SaveCreateAsync">
                    @(_creatingBusy ? "Saving…" : "Save")
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_createError))
            {
                <p class="citus-account-picker__create-error">@_createError</p>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public CompanyId CompanyId { get; set; }
    [Parameter] public UserId? UserId { get; set; }
    [Parameter] public Guid? SelectedId { get; set; }
    [Parameter] public string? SelectedDisplayText { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Account";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? DefaultCurrencyCode { get; set; }
    [Parameter] public EventCallback<AccountSummary> OnAccountSelected { get; set; }
    [Parameter] public EventCallback OnCleared { get; set; }
    [Parameter] public string Context { get; set; } = "journal_entry.account_picker";

    /// <summary>
    /// Optional CSV of root_type values that may appear in search
    /// results, e.g. <c>"expense,asset,cost_of_sales"</c> on the
    /// expense lines. Empty / null = no filter (full chart). Used to
    /// keep the picker's result set semantically appropriate for the
    /// page (e.g. don't surface revenue accounts when the operator is
    /// recording an expense).
    /// </summary>
    [Parameter] public string? AllowedRootTypes { get; set; }

    private ElementReference _inputRef;
    private string _searchText = string.Empty;
    private bool _showResults;
    private bool _isFocused;
    private bool _loading;
    private bool _hasLoadedOnce;
    private int _highlightedIndex = -1;

    // Full company chart, loaded once per session and refreshed when we
    // create a row inline. Search filters this list client-side; ranking
    // is layered on top via UnitySearchPickerService.SearchAsync results.
    private List<AccountSummary> _allAccounts = new();
    private IReadOnlyList<AccountSummary> _visibleRows = Array.Empty<AccountSummary>();
    private CancellationTokenSource? _searchCts;
    private CancellationTokenSource? _blurCts;

    // Inline create-account panel state.
    private bool _creating;
    private bool _creatingBusy;
    private string _newCode = string.Empty;
    private string _newName = string.Empty;
    private string _newRootType = "expense";
    // Batch B: detail type captured from the new field (default empty).
    private string _newDetailType = string.Empty;
    private string? _createError;

    private void OnNewRootTypeChanged(ChangeEventArgs args)
    {
        _newRootType = args.Value?.ToString() ?? "expense";
        // A stored detail type from a previous root selection no longer
        // applies (e.g. "asset/cash" doesn't make sense once the user
        // flips to expense). Same reset logic as ChartOfAccountsPage.
        _newDetailType = string.Empty;
    }

    private bool CanCreate => !Disabled && !_creating;

    protected override void OnParametersSet()
    {
        // SelectedDisplayText is a hint shown until the picker fetches its
        // own chart. Don't overwrite a real resolved selection (set below
        // in EnsureLoadedAsync) with the hint on subsequent renders.
        if (!_isFocused && !string.IsNullOrEmpty(SelectedDisplayText) && string.IsNullOrEmpty(_searchText))
        {
            _searchText = SelectedDisplayText;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // Edit pages render the picker with SelectedId already set. Pre-
        // load the chart so we can replace the SelectedDisplayText hint
        // (e.g. literal "(account)") with the actual code + name before
        // the user ever clicks. Without this the input shows the hint as
        // its value AND the dropdown uses it as a filter query, hiding
        // the full chart behind a phantom "no matching accounts".
        if (SelectedId.HasValue)
        {
            await EnsureLoadedAsync();
        }
    }

    private async Task EnsureLoadedAsync()
    {
        if (_hasLoadedOnce || Disabled || string.IsNullOrEmpty(CompanyId.Value))
        {
            return;
        }
        _hasLoadedOnce = true;
        _loading = true;
        try
        {
            var rows = await AccountClient.ListAsync();
            var allowed = ParseAllowedRootTypes(AllowedRootTypes);
            _allAccounts = rows
                .Where(r => r.IsActive)
                .Where(r => allowed is null || allowed.Contains(r.RootType ?? string.Empty))
                .ToList();

            // Now that the chart is in memory, resolve any pre-selected ID
            // to its real code + name and overwrite the SelectedDisplayText
            // hint. Skipped while the user is actively typing (focused) so
            // a load that happens to land mid-keystroke doesn't clobber
            // their query.
            if (!_isFocused && SelectedId.HasValue)
            {
                var selected = _allAccounts.FirstOrDefault(a => a.Id == SelectedId.Value);
                if (selected is not null)
                {
                    _searchText = $"{selected.Code} {selected.Name}";
                }
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private static HashSet<string>? ParseAllowedRootTypes(string? csv)
    {
        if (string.IsNullOrWhiteSpace(csv)) return null;
        return csv.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(s => s.ToLowerInvariant())
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private async Task HandleFocus(FocusEventArgs _)
    {
        _isFocused = true;
        _blurCts?.Cancel();
        _blurCts?.Dispose();
        _blurCts = null;

        await EnsureLoadedAsync();

        // Standard combobox behaviour: if the input currently displays
        // the selected account (or the SelectedDisplayText hint), clear
        // it on focus so the dropdown shows the full chart, not just
        // the row matching the existing selection. Restored on blur if
        // the user didn't pick something else.
        if (SelectedId.HasValue)
        {
            var selected = _allAccounts.FirstOrDefault(a => a.Id == SelectedId.Value);
            var resolvedDisplay = selected is not null ? $"{selected.Code} {selected.Name}" : null;
            if (string.Equals(_searchText, resolvedDisplay, StringComparison.Ordinal) ||
                string.Equals(_searchText, SelectedDisplayText, StringComparison.Ordinal))
            {
                _searchText = string.Empty;
            }
        }

        await ApplyFilterAsync(_searchText);
        _showResults = true;
        StateHasChanged();
    }

    private async Task HandleControlClick()
    {
        if (Disabled) return;
        if (!_showResults)
        {
            await HandleFocus(default!);
        }
    }

    private async Task HandleInputAsync(ChangeEventArgs args)
    {
        _searchText = args.Value?.ToString() ?? string.Empty;
        _highlightedIndex = -1;
        _showResults = true;
        await EnsureLoadedAsync();
        await ApplyFilterAsync(_searchText);
        StateHasChanged();
    }

    private async Task ApplyFilterAsync(string query)
    {
        _searchCts?.Cancel();
        _searchCts?.Dispose();
        var cts = new CancellationTokenSource();
        _searchCts = cts;

        var trimmed = query.Trim();
        if (string.IsNullOrEmpty(trimmed))
        {
            // No query → top-N by code, gives the user something useful
            // immediately on focus.
            _visibleRows = _allAccounts
                .OrderBy(a => a.Code, StringComparer.OrdinalIgnoreCase)
                .Take(15)
                .ToArray();
            return;
        }

        // Local match: starts-with code wins, then contains-in-code, then
        // contains-in-name. This is the immediate result so the popup
        // never feels like it's waiting on the network.
        var localMatches = _allAccounts
            .Where(a =>
                a.Code.StartsWith(trimmed, StringComparison.OrdinalIgnoreCase) ||
                a.Code.Contains(trimmed, StringComparison.OrdinalIgnoreCase) ||
                a.Name.Contains(trimmed, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(a => a.Code.StartsWith(trimmed, StringComparison.OrdinalIgnoreCase))
            .ThenBy(a => a.Code, StringComparer.OrdinalIgnoreCase)
            .Take(15)
            .ToArray();
        _visibleRows = localMatches;

        if (trimmed.Length < 2 || string.IsNullOrEmpty(CompanyId.Value))
        {
            return;
        }

        // Ranked overlay — UnitySearch returns SourceIds in learned-rank
        // order. Re-order the local matches to follow that order, falling
        // back to local order for anything UnitySearch didn't rank.
        try
        {
            await Task.Delay(150, cts.Token);
            var ranked = await PickerService.SearchAsync(
                CompanyId,
                UserId,
                Context,
                trimmed,
                take: 15,
                cts.Token);

            if (cts.IsCancellationRequested || ranked.Count == 0)
            {
                return;
            }

            var indexById = _allAccounts.ToDictionary(a => a.Id);
            var rankOrdered = ranked
                .Where(opt => indexById.ContainsKey(opt.SourceId))
                .Select(opt => indexById[opt.SourceId])
                .ToList();
            // Append local matches that weren't in the ranked set so we
            // never lose data the user expected to see.
            foreach (var local in localMatches)
            {
                if (!rankOrdered.Any(r => r.Id == local.Id))
                {
                    rankOrdered.Add(local);
                }
            }
            _visibleRows = rankOrdered;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { }
    }

    private async Task HandleBlurAsync(FocusEventArgs _)
    {
        _isFocused = false;
        _blurCts?.Cancel();
        _blurCts?.Dispose();
        var cts = new CancellationTokenSource();
        _blurCts = cts;

        try
        {
            await Task.Delay(150, cts.Token);
            if (!cts.IsCancellationRequested && !_creating)
            {
                _showResults = false;
                // Restore display from the loaded chart when possible —
                // SelectedDisplayText is just the pre-load hint and may
                // be the literal "(account)" placeholder some pages
                // emit. Falling back to whatever the user last typed
                // matches the prior behaviour.
                if (SelectedId.HasValue)
                {
                    var selected = _allAccounts.FirstOrDefault(a => a.Id == SelectedId.Value);
                    if (selected is not null)
                    {
                        _searchText = $"{selected.Code} {selected.Name}";
                    }
                    else
                    {
                        _searchText = SelectedDisplayText ?? _searchText;
                    }
                }
                else
                {
                    _searchText = string.Empty;
                }
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        if (!_showResults || _visibleRows.Count == 0) return;
        if (e.Key == "ArrowDown")
        {
            _highlightedIndex = Math.Min(_highlightedIndex + 1, _visibleRows.Count - 1);
        }
        else if (e.Key == "ArrowUp")
        {
            _highlightedIndex = Math.Max(_highlightedIndex - 1, 0);
        }
        else if (e.Key == "Enter" && _highlightedIndex >= 0 && _highlightedIndex < _visibleRows.Count)
        {
            await SelectAsync(_visibleRows[_highlightedIndex]);
        }
        else if (e.Key == "Escape")
        {
            _showResults = false;
        }
    }

    private async Task SelectAsync(AccountSummary row)
    {
        _showResults = false;
        _searchText = $"{row.Code} {row.Name}";
        await OnAccountSelected.InvokeAsync(row);
        StateHasChanged();
    }

    private async Task ClearAsync()
    {
        _searchText = string.Empty;
        _showResults = false;
        await OnCleared.InvokeAsync();
        StateHasChanged();
    }

    private Task OpenCreatePanelAsync()
    {
        // Pre-populate from what the user has typed: numeric → Code, else → Name.
        var typed = _searchText.Trim();
        if (typed.Length > 0 && typed.All(char.IsDigit))
        {
            _newCode = typed;
            _newName = string.Empty;
        }
        else
        {
            _newCode = string.Empty;
            _newName = typed;
        }
        _newRootType = "expense";
        _newDetailType = string.Empty;
        _createError = null;
        _creating = true;
        _showResults = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void CancelCreate()
    {
        _creating = false;
        _createError = null;
    }

    private async Task SaveCreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_newCode) || string.IsNullOrWhiteSpace(_newName))
        {
            return;
        }
        _creatingBusy = true;
        _createError = null;
        try
        {
            var payload = new AccountUpsertPayload(
                Code: _newCode.Trim(),
                Name: _newName.Trim(),
                RootType: _newRootType,
                // Batch B: send the picked Detail type when set;
                // null still means "operator left it blank".
                DetailType: string.IsNullOrWhiteSpace(_newDetailType) ? null : _newDetailType,
                CurrencyCode: DefaultCurrencyCode,
                AllowManualPosting: true,
                IsActive: true);

            var outcome = await AccountClient.CreateAsync(payload);
            if (!outcome.Succeeded || outcome.Saved is null)
            {
                _createError = outcome.ErrorMessage ?? "Could not save the account.";
                return;
            }

            _allAccounts.Add(outcome.Saved);
            _creating = false;
            await Toast.SuccessAsync($"Account {outcome.Saved.Code} created.");
            await SelectAsync(outcome.Saved);
        }
        finally
        {
            _creatingBusy = false;
            StateHasChanged();
        }
    }

    private string FormatMeta(AccountSummary row)
    {
        var rootLabel = char.ToUpperInvariant(row.RootType[0]) + row.RootType.Substring(1).Replace('_', ' ');
        if (!string.IsNullOrEmpty(row.DetailType) && !string.Equals(row.DetailType, row.RootType, StringComparison.OrdinalIgnoreCase))
        {
            return rootLabel;
        }
        return rootLabel;
    }

    private RenderFragment RenderHighlight(string text) => builder =>
    {
        if (string.IsNullOrEmpty(text)) return;
        var query = _searchText?.Trim();
        if (string.IsNullOrEmpty(query))
        {
            builder.AddContent(0, text);
            return;
        }
        var idx = text.IndexOf(query, StringComparison.OrdinalIgnoreCase);
        if (idx < 0)
        {
            builder.AddContent(0, text);
            return;
        }
        if (idx > 0) builder.AddContent(1, text.Substring(0, idx));
        builder.OpenElement(2, "strong");
        builder.AddAttribute(3, "class", "citus-account-picker__match");
        builder.AddContent(4, text.Substring(idx, query.Length));
        builder.CloseElement();
        var tail = idx + query.Length;
        if (tail < text.Length) builder.AddContent(5, text.Substring(tail));
    };
}
