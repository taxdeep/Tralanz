@page "/chart-of-accounts"

@inject BusinessShellState ShellState
@inject AccountClient AccountClient
@inject CitusToastService Message

@*
    Chart of Accounts maintenance — per-company catalog. Replaces the
    earlier read-only view that inferred accounts from Trial Balance
    rows. Reads the accounts table directly via /accounting/accounts;
    creating / editing / activate-toggling rows here is what later
    surfaces them in the journal-entry account picker (UnitySearch
    SeedAccountDocumentsAsync runs against the same table on its
    periodic refresh).

    System accounts (is_system = true) are read-only in this UI; the
    Posting Engine's AR / AP / FX control rows are protected so they
    can't be quietly mutated through the maintenance surface.
*@

<PageTitle>Chart of Accounts | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusButton LeadingIcon="IconName.Plus"
                     Variant="CitusButtonVariant.Primary"
                     Size="CitusButtonSize.Small"
                     Disabled="@_isLoading"
                     OnClick="StartCreating">
            New account
        </CitusButton>
        @* Seed-from-template only renders for an empty chart. Once any
           account exists in the company (active or inactive), the chart
           is owned by the user and re-seeding is forbidden; the backend
           also rejects the call with 409 Conflict. *@
        @if (!_isLoading && _rows.Count == 0)
        {
            <CitusButton Variant="CitusButtonVariant.Ghost"
                         Size="CitusButtonSize.Small"
                         Disabled="@_isMutating"
                         OnClick="OpenSeedPanelAsync">
                Seed from template
            </CitusButton>
        }
    </Actions>
</CitusPageHeader>

@if (_isSeedPanelOpen)
{
    <section class="citus-panel mb-6">
        <header class="citus-panel__header">
            <h2 class="citus-panel__title">Apply a starter template</h2>
            <CitusButton Variant="CitusButtonVariant.Ghost"
                         Size="CitusButtonSize.Small"
                         Disabled="@_isMutating"
                         OnClick="CloseSeedPanel">
                Close
            </CitusButton>
        </header>

        <p class="text-fg-muted text-sm mb-4">
            Templates are applied <strong>additively</strong> — accounts whose code already exists in this
            company are skipped, never overwritten. Re-applying the same template is safe.
        </p>

        @if (_seedSummary is not null)
        {
            <CitusAlert Severity="@(_seedSummary.FailedCount > 0 ? CitusAlertSeverity.Warning : CitusAlertSeverity.Success)"
                             ShowIcon="true"
                             Class="mb-4">
                <MessageTemplate>
                    <strong>@_seedSummary.TemplateKey @_seedSummary.TemplateVersion applied.</strong>
                    Created @_seedSummary.CreatedCount, skipped @_seedSummary.SkippedCount existing,
                    failed @_seedSummary.FailedCount.
                </MessageTemplate>
            </CitusAlert>
        }

        @if (_templates.Count == 0)
        {
            <p class="text-fg-muted text-sm">No templates available.</p>
        }
        else
        {
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                @foreach (var template in _templates)
                {
                    <article class="citus-subpanel">
                        <header class="citus-subpanel__header">
                            <div>
                                <h3 class="citus-subpanel__title">@template.Name</h3>
                                <p class="text-fg-subtle text-xs mt-1">
                                    @template.Country · @template.AccountCodeLength-digit codes · @template.AccountCount accounts ·
                                    <span class="citus-inline-code">@template.Key</span>
                                </p>
                            </div>
                            <CitusButton Variant="CitusButtonVariant.Primary"
                                         Size="CitusButtonSize.Small"
                                         Disabled="@_isMutating"
                                         OnClick="@(() => ApplyTemplateAsync(template.Key))">
                                @(_isMutating && _applyingTemplateKey == template.Key ? "Applying…" : "Apply")
                            </CitusButton>
                        </header>
                        <p class="text-fg-muted text-sm mb-3">@template.Description</p>
                        <details>
                            <summary class="text-fg-muted text-xs cursor-pointer">Preview accounts (@template.AccountCount)</summary>
                            <table class="citus-data-table mt-2">
                                <thead>
                                    <tr>
                                        <th style="width: 5rem">Code</th>
                                        <th>Name</th>
                                        <th style="width: 7rem">Root type</th>
                                        <th style="width: 6rem">System</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var account in template.Accounts)
                                    {
                                        <tr>
                                            <td><span class="citus-inline-code">@account.Code</span></td>
                                            <td>@account.Name</td>
                                            <td>@HumanizeRootType(account.RootType)</td>
                                            <td class="text-fg-subtle text-xs">
                                                @(string.IsNullOrEmpty(account.SystemRole) ? "—" : account.SystemRole)
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </details>
                    </article>
                }
            </div>
        }
    </section>
}

<section class="citus-panel">
    <header class="citus-panel__header">
        <h2 class="citus-panel__title">Accounts</h2>
        <div class="flex items-center gap-3">
            <select class="citus-form-field__input"
                    style="width: 12rem"
                    value="@_filterRootType"
                    @onchange="@OnFilterRootTypeChanged">
                <option value="">All root types</option>
                @foreach (var type in RootTypeOptions)
                {
                    <option value="@type.Value">@type.Label</option>
                }
            </select>
            <label class="inline-flex items-center gap-2 text-sm">
                <input type="checkbox"
                       checked="@_includeInactive"
                       @onchange="@OnToggleInactive" />
                Show inactive
            </label>
            <CitusBadge Color="@(ShellState.IsCompanyReadOnly ? "orange" : "blue")">
                @ShellState.ActiveCompany.CompanyCode
            </CitusBadge>
        </div>
    </header>

    @if (_isLoading)
    {
        <CitusLoadingBar />
    }
    else if (FilteredRows.Count == 0)
    {
        <div class="citus-empty">
            <p class="text-fg-muted text-sm">
                @(_rows.Count == 0
                    ? "No accounts yet. Click \"New account\" to start your chart of accounts."
                    : "No accounts match the current filters.")
            </p>
        </div>
    }
    else
    {
        <table class="citus-data-table">
            <thead>
                <tr>
                    <th style="width: 7rem">Code</th>
                    <th>Name</th>
                    <th style="width: 9rem">Root type</th>
                    <th style="width: 9rem">Detail</th>
                    <th style="width: 5rem">Currency</th>
                    <th style="width: 7rem">Status</th>
                    <th style="width: 11rem"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in FilteredRows)
                {
                    <tr class="@(row.IsActive ? null : "citus-data-table__row--muted")">
                        <td>
                            <span class="citus-inline-code">@row.Code</span>
                            @if (row.IsSystem)
                            {
                                <span class="text-fg-subtle text-xs ml-2">system</span>
                            }
                        </td>
                        <td>@row.Name</td>
                        <td>@HumanizeRootType(row.RootType)</td>
                        <td class="text-fg-muted">@(string.IsNullOrEmpty(row.DetailType) ? "—" : row.DetailType)</td>
                        <td class="text-fg-muted">@(string.IsNullOrWhiteSpace(row.CurrencyCode) ? "—" : row.CurrencyCode)</td>
                        <td>
                            <CitusBadge Color="@(row.IsActive ? "green" : "default")">
                                @(row.IsActive ? "Active" : "Inactive")
                            </CitusBadge>
                        </td>
                        <td>
                            <div class="flex items-center gap-2">
                                @if (!row.IsSystem)
                                {
                                    <CitusButton Variant="CitusButtonVariant.Ghost"
                                                 Size="CitusButtonSize.Small"
                                                 Disabled="@_isMutating"
                                                 OnClick="@(() => StartEditing(row))">
                                        Edit
                                    </CitusButton>
                                    <CitusButton Variant="CitusButtonVariant.Ghost"
                                                 Size="CitusButtonSize.Small"
                                                 Disabled="@_isMutating"
                                                 OnClick="@(() => ToggleActiveAsync(row))">
                                        @(row.IsActive ? "Deactivate" : "Activate")
                                    </CitusButton>
                                }
                                else
                                {
                                    <span class="text-fg-subtle text-xs">Read-only</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

<CitusDrawer @bind-IsOpen="_isFormOpen"
             Title="@(_editingId is null ? "New account" : "Edit account")"
             SaveLabel="@(_isMutating ? "Saving…" : "Save")"
             SaveDisabled="_isMutating"
             Width="CitusDrawerWidth.Medium"
             OnSave="OnSaveAsync"
             OnCancel="CancelForm">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="citus-form-field">
            <span class="citus-form-field__label">Code</span>
            <input type="text"
                   class="citus-form-field__input"
                   value="@_formCode"
                   @oninput="@(e => _formCode = e.Value?.ToString() ?? string.Empty)"
                   maxlength="32"
                   placeholder="1000, 4100, 6300, …"
                   disabled="@_isMutating" />
        </label>

        <label class="citus-form-field">
            <span class="citus-form-field__label">Name</span>
            <input type="text"
                   class="citus-form-field__input"
                   value="@_formName"
                   @oninput="@(e => _formName = e.Value?.ToString() ?? string.Empty)"
                   maxlength="200"
                   placeholder="Cash, Accounts Receivable, Office Expense, …"
                   disabled="@_isMutating" />
        </label>

        <label class="citus-form-field">
            <span class="citus-form-field__label">Root type</span>
            <select class="citus-form-field__input"
                    value="@_formRootType"
                    @onchange="@(e => _formRootType = e.Value?.ToString() ?? "asset")"
                    disabled="@_isMutating">
                @foreach (var type in RootTypeOptions)
                {
                    <option value="@type.Value">@type.Label</option>
                }
            </select>
        </label>

        <label class="citus-form-field">
            <span class="citus-form-field__label">Detail type (optional)</span>
            <input type="text"
                   class="citus-form-field__input"
                   value="@_formDetailType"
                   @oninput="@(e => _formDetailType = e.Value?.ToString() ?? string.Empty)"
                   maxlength="80"
                   placeholder="bank, receivable, equipment, …"
                   disabled="@_isMutating" />
        </label>

        <label class="citus-form-field">
            <span class="citus-form-field__label">Currency (optional, ISO 4217)</span>
            <input type="text"
                   class="citus-form-field__input"
                   value="@_formCurrencyCode"
                   @oninput="@(e => _formCurrencyCode = e.Value?.ToString() ?? string.Empty)"
                   maxlength="3"
                   placeholder="@($"Defaults to {ShellState.ActiveCompany.BaseCurrencyCode}")"
                   disabled="@_isMutating" />
        </label>

        <label class="citus-form-field">
            <span class="inline-flex items-center gap-2 text-sm">
                <input type="checkbox"
                       checked="@_formAllowManualPosting"
                       @onchange="@(e => _formAllowManualPosting = (bool)(e.Value ?? false))"
                       disabled="@_isMutating" />
                Allow manual posting (uncheck to make this a rollup-only account)
            </span>
        </label>

        <label class="citus-form-field md:col-span-2">
            <span class="inline-flex items-center gap-2 text-sm">
                <input type="checkbox"
                       checked="@_formIsActive"
                       @onchange="@(e => _formIsActive = (bool)(e.Value ?? false))"
                       disabled="@_isMutating" />
                Active (available for selection on new transactions)
            </span>
        </label>
    </div>
</CitusDrawer>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Accounting",
        Title = "Chart of accounts",
        Subtitle = "Per-company account catalog. Used by journal entry, invoice, bill, and report surfaces."
    };

    private static readonly (string Value, string Label)[] RootTypeOptions =
    {
        ("asset", "Asset"),
        ("liability", "Liability"),
        ("equity", "Equity"),
        ("revenue", "Revenue"),
        ("cost_of_sales", "Cost of sales"),
        ("expense", "Expense"),
    };

    private bool _isLoading = true;
    private bool _isMutating;
    private bool _isFormOpen;
    private bool _includeInactive;
    private string _filterRootType = string.Empty;

    private Guid? _editingId;
    private string _formCode = string.Empty;
    private string _formName = string.Empty;
    private string _formRootType = "asset";
    private string _formDetailType = string.Empty;
    private string _formCurrencyCode = string.Empty;
    private bool _formAllowManualPosting = true;
    private bool _formIsActive = true;

    private List<AccountSummary> _rows = new();

    // Seed-from-template state.
    private bool _isSeedPanelOpen;
    private List<CoaTemplateSummary> _templates = new();
    private CoaSeedSummaryDto? _seedSummary;
    private string? _applyingTemplateKey;

    private IReadOnlyList<AccountSummary> FilteredRows
    {
        get
        {
            IEnumerable<AccountSummary> rows = _rows;
            if (!_includeInactive)
            {
                rows = rows.Where(r => r.IsActive);
            }
            if (!string.IsNullOrEmpty(_filterRootType))
            {
                rows = rows.Where(r => string.Equals(r.RootType, _filterRootType, StringComparison.OrdinalIgnoreCase));
            }
            return rows as IReadOnlyList<AccountSummary> ?? rows.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            // Always pull the full set (incl. inactive) so the seed-button
            // gate and the empty-state copy reflect the company's true state
            // regardless of the "Show inactive" toggle. The toggle filters
            // client-side via FilteredRows.
            var rows = await AccountClient.ListAsync(includeInactive: true);
            _rows = rows
                .OrderBy(r => RootTypeRank(r.RootType))
                .ThenBy(r => r.Code, StringComparer.Ordinal)
                .ToList();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OnToggleInactive(ChangeEventArgs args)
    {
        _includeInactive = (bool)(args.Value ?? false);
    }

    private void OnFilterRootTypeChanged(ChangeEventArgs args)
    {
        _filterRootType = args.Value?.ToString() ?? string.Empty;
    }

    private void StartCreating()
    {
        _editingId = null;
        _formCode = string.Empty;
        _formName = string.Empty;
        _formRootType = string.IsNullOrEmpty(_filterRootType) ? "asset" : _filterRootType;
        _formDetailType = string.Empty;
        _formCurrencyCode = string.Empty;
        _formAllowManualPosting = true;
        _formIsActive = true;
        _isFormOpen = true;
    }

    private void StartEditing(AccountSummary row)
    {
        _editingId = row.Id;
        _formCode = row.Code;
        _formName = row.Name;
        _formRootType = row.RootType;
        _formDetailType = row.DetailType ?? string.Empty;
        _formCurrencyCode = row.CurrencyCode ?? string.Empty;
        _formAllowManualPosting = row.AllowManualPosting;
        _formIsActive = row.IsActive;
        _isFormOpen = true;
    }

    private void CancelForm()
    {
        _isFormOpen = false;
        _editingId = null;
    }

    private async Task OnSaveAsync()
    {
        if (_isMutating) return;

        if (string.IsNullOrWhiteSpace(_formCode))
        {
            await Message.WarningAsync("Code is required.");
            return;
        }
        if (string.IsNullOrWhiteSpace(_formName))
        {
            await Message.WarningAsync("Name is required.");
            return;
        }
        if (!IsValidRootType(_formRootType))
        {
            await Message.WarningAsync("Pick a root type.");
            return;
        }
        var currency = _formCurrencyCode?.Trim();
        if (!string.IsNullOrEmpty(currency) && currency.Length != 3)
        {
            await Message.WarningAsync("Currency code must be exactly 3 letters (ISO 4217).");
            return;
        }

        _isMutating = true;
        try
        {
            var payload = new AccountUpsertPayload(
                Code: _formCode.Trim(),
                Name: _formName.Trim(),
                RootType: _formRootType,
                DetailType: string.IsNullOrWhiteSpace(_formDetailType) ? null : _formDetailType.Trim(),
                CurrencyCode: string.IsNullOrEmpty(currency) ? null : currency,
                AllowManualPosting: _formAllowManualPosting,
                IsActive: _formIsActive);

            var outcome = _editingId is null
                ? await AccountClient.CreateAsync(payload)
                : await AccountClient.UpdateAsync(_editingId.Value, payload);

            if (!outcome.Succeeded)
            {
                await Message.WarningAsync(string.IsNullOrWhiteSpace(outcome.ErrorMessage)
                    ? "Unable to save account."
                    : outcome.ErrorMessage);
                return;
            }

            var wasEditing = _editingId is not null;
            _isFormOpen = false;
            _editingId = null;
            await LoadAsync();
            await Message.SuccessAsync(wasEditing ? "Account updated." : "Account created.");
        }
        finally
        {
            _isMutating = false;
        }
    }

    private async Task OpenSeedPanelAsync()
    {
        _isSeedPanelOpen = true;
        _seedSummary = null;
        if (_templates.Count == 0)
        {
            var rows = await AccountClient.ListTemplatesAsync();
            _templates = rows.ToList();
        }
    }

    private void CloseSeedPanel()
    {
        _isSeedPanelOpen = false;
        _seedSummary = null;
        _applyingTemplateKey = null;
    }

    private async Task ApplyTemplateAsync(string templateKey)
    {
        if (_isMutating) return;
        _isMutating = true;
        _applyingTemplateKey = templateKey;
        try
        {
            var outcome = await AccountClient.ApplyTemplateAsync(templateKey);
            if (!outcome.Succeeded || outcome.Summary is null)
            {
                await Message.WarningAsync(outcome.ErrorMessage ?? "Unable to apply template.");
                return;
            }
            _seedSummary = outcome.Summary;
            await LoadAsync();
            if (outcome.Summary.CreatedCount > 0)
            {
                await Message.SuccessAsync($"Created {outcome.Summary.CreatedCount} accounts from {outcome.Summary.TemplateKey}.");
            }
            else if (outcome.Summary.SkippedCount > 0)
            {
                await Message.InfoAsync($"Template {outcome.Summary.TemplateKey} fully matched existing accounts; nothing to add.");
            }
        }
        finally
        {
            _isMutating = false;
            _applyingTemplateKey = null;
        }
    }

    private async Task ToggleActiveAsync(AccountSummary row)
    {
        if (_isMutating) return;
        _isMutating = true;
        try
        {
            var outcome = await AccountClient.SetActiveAsync(row.Id, !row.IsActive);
            if (!outcome.Succeeded)
            {
                await Message.WarningAsync(outcome.ErrorMessage ?? "Unable to update account status.");
                return;
            }
            await LoadAsync();
            await Message.SuccessAsync(row.IsActive ? "Account deactivated." : "Account activated.");
        }
        finally
        {
            _isMutating = false;
        }
    }

    private static bool IsValidRootType(string? value) =>
        value is "asset" or "liability" or "equity" or "revenue" or "cost_of_sales" or "expense";

    private static int RootTypeRank(string rootType) => rootType switch
    {
        "asset" => 1,
        "liability" => 2,
        "equity" => 3,
        "revenue" => 4,
        "cost_of_sales" => 5,
        "expense" => 6,
        _ => 9,
    };

    private static string HumanizeRootType(string rootType) => rootType switch
    {
        "asset" => "Asset",
        "liability" => "Liability",
        "equity" => "Equity",
        "revenue" => "Revenue",
        "cost_of_sales" => "Cost of sales",
        "expense" => "Expense",
        _ => rootType,
    };
}
