@page "/bills/new"
@page "/bills/{BillId:guid}/edit"

@using Radzen
@using Radzen.Blazor
@using Microsoft.AspNetCore.WebUtilities
@using Citus.Modules.UnitySearch.Blazor
@using Citus.Modules.UnitySearch.Domain.Shared

@inject BusinessShellState ShellState
@inject VendorClient VendorClient
@inject AccountClient AccountClient
@inject TaxCodeClient TaxCodeClient
@inject TaxCodeSetClient TaxCodeSetClient
@inject PaymentTermClient PaymentTermClient
@inject BillClient BillClient
@inject BusinessWriteFlowClient WriteFlow
@inject TaskClient TaskClient
@inject ItemClient ItemClient
@inject CitusToastService Message
@inject NavigationManager Navigation

@*
    Bill create / edit. Same component handles both routes:
      • /bills/new            → fresh draft
      • /bills/{id}/edit      → loads an existing Draft (only Draft is editable)

    Layout (Batch 2d — clean rewrite):
        [CitusPageHeader] Back-to-bills only.
        [Top alerts] write-block / copy-banner / validation
        [Skeleton OR main body]
            <Bill>      — single card, 12-col internal split:
                          col-8 metadata (Supplier + bill # + dates + currency)
                          col-4 running Totals key-value
            <Lines>     — full-width table; Item (stock) / Category / Task /
                          Tax / Amount columns. Add / clear at the bottom.
            <Memo>      — full-width single input.
        [Sticky CitusFormActions]  Cancel left, Save right; "Fix errors above"
                                    hint appears when _validation is set.

    Save semantics live in @code (SaveAsync). Posting is blocked here until
    the canonical workflow can create the JE + AP open item atomically.
*@

<PageTitle>@(_billId is null ? "New bill" : $"Edit {_billNumberDisplay}") | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusLinkButton Href="bills"
                         Variant="CitusButtonVariant.Ghost"
                         LeadingIcon="IconName.ArrowLeft">
            Back to bills
        </CitusLinkButton>
    </Actions>
</CitusPageHeader>

@if (ShellState.AreWritesBlocked)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning"
                ShowIcon="true"
                Message="@ShellState.WriteBlockMessage"
                Class="mb-4" />
}

@if (_copiedFromBillId is not null)
{
    @* Copy A3 Phase 2: form prefilled from another bill via ?copyFrom=
       The source bill is untouched; this is a fresh draft. *@
    <CitusAlert Severity="CitusAlertSeverity.Info"
                ShowIcon="true"
                Class="mb-4"
                Message="This is a copy. Enter the new supplier invoice number and revise as needed; the original bill is unchanged." />
}

@if (!string.IsNullOrWhiteSpace(_validation))
{
    <CitusAlert Severity="CitusAlertSeverity.Error"
                Message="@_validation"
                ShowIcon="true"
                Class="mb-4" />
}

@if (_isLoading)
{
    <CitusSkeleton Variant="SkeletonVariant.Form" />
}
else
{
    @* === Bill — single card containing supplier + bill metadata on the
         left (col-8) and the running Totals summary on the right (col-4).
         Operator never has to look elsewhere for the live subtotal. ===*@
    <CitusFormSection Title="Bill">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <div class="lg:col-span-8">
                <CitusFormGrid Columns="2">
                    <CitusFormField Label="Supplier" Required="true">
                        <RadzenDropDown TValue="Guid?"
                                        Data="@_vendors"
                                        @bind-Value="_vendorId"
                                        TextProperty="DisplayName"
                                        ValueProperty="Id"
                                        Placeholder="Choose a supplier…"
                                        AllowFiltering="true"
                                        Class="citus-control-full"
                                        Change="@(_ => OnVendorChanged())" />
                    </CitusFormField>

                    <CitusFormField Label="Source PO">
                        @if (!string.IsNullOrWhiteSpace(_sourcePurchaseOrderNumber))
                        {
                            @if (_sourcePurchaseOrderId is { } poId)
                            {
                                <a class="citus-link" href="@($"purchase-orders/{poId:D}")">
                                    <span class="citus-inline-code">@_sourcePurchaseOrderNumber</span>
                                </a>
                            }
                            else
                            {
                                <span class="citus-inline-code">@_sourcePurchaseOrderNumber</span>
                            }
                        }
                        else
                        {
                            <div class="text-fg-muted text-sm">Created directly (no source PO)</div>
                        }
                    </CitusFormField>

                    <CitusFormField Label="Bill no. (supplier's invoice #)" Required="true">
                        <CitusInput TValue="string"
                                    @bind-Value="_billNumber"
                                    Placeholder="e.g. INV-12345" />
                    </CitusFormField>

                    <CitusFormField Label="Internal entity number"
                                    Hint="@(string.IsNullOrWhiteSpace(_billNumberDisplay) ? "Auto-assigned on save" : null)">
                        @if (!string.IsNullOrWhiteSpace(_billNumberDisplay))
                        {
                            <div class="citus-inline-code">@_billNumberDisplay</div>
                        }
                        else
                        {
                            <div class="text-fg-subtle text-sm">—</div>
                        }
                    </CitusFormField>

                    <CitusFormField Label="Bill date" Required="true">
                        <RadzenDatePicker TValue="DateTime?"
                                          DateFormat="yyyy-MM-dd"
                                          ShowTime="false"
                                          @bind-Value="_billDate"
                                          Change="@(_ => RecomputeDueDate())"
                                          Class="citus-control-full" />
                    </CitusFormField>

                    <CitusFormField Label="Due date" Required="true">
                        <RadzenDatePicker TValue="DateTime?"
                                          DateFormat="yyyy-MM-dd"
                                          ShowTime="false"
                                          @bind-Value="_dueDate"
                                          Class="citus-control-full" />
                        @if (_paymentTermId is { } termId)
                        {
                            var term = _paymentTerms.FirstOrDefault(t => t.Id == termId);
                            if (term is not null)
                            {
                                <p class="text-fg-subtle text-xs mt-1">
                                    Defaulted from payment term <strong>@term.Name</strong> (Net @term.NetDays).
                                </p>
                            }
                        }
                    </CitusFormField>

                    <CitusFormField Label="Transaction currency">
                        <CitusInput TValue="string"
                                    @bind-Value="_currency"
                                    Disabled="@(!ShellState.ActiveCompany.MultiCurrencyEnabled)" />
                    </CitusFormField>

                    <CitusFormField Label="Exchange rate">
                        <FxRateInline DocumentDate="@(DateOnly.FromDateTime((_billDate ?? DateTime.Today).Date))"
                                      BaseCurrencyCode="@ShellState.ActiveCompany.BaseCurrencyCode"
                                      QuoteCurrencyCode="@_currency"
                                      @bind-Rate="_fxRate" />
                    </CitusFormField>
                </CitusFormGrid>
            </div>

            <div class="lg:col-span-4">
                <div class="citus-totals-card">
                    <CitusKeyValueTable>
                        <CitusKeyValueRow Label="Subtotal" ValueAlignRight="true">@FormatAmount(Subtotal)</CitusKeyValueRow>
                        <CitusKeyValueRow Label="Tax" ValueAlignRight="true">@FormatAmount(TaxTotal)</CitusKeyValueRow>
                        <CitusKeyValueRow Label="Total" ValueAlignRight="true"><strong>@FormatAmount(Total) @_currency</strong></CitusKeyValueRow>
                    </CitusKeyValueTable>
                </div>
            </div>
        </div>
    </CitusFormSection>

    @* === Lines — purchase line editor. Item column is gated to stock
         items only (see BillItemPicker policy); service-kind purchases
         leave Item blank and pick Category directly. Task column is
         only rendered when the company has the Task module enabled.
         The table sums to ~74rem of fixed-width columns; min-width
         pins the column rhythm on narrow viewports (the page itself
         scrolls horizontally below ~74rem available width). No
         overflow wrapper here — picker dropdowns need to escape the
         table bounds when they open. ===*@
    <CitusFormSection Title="Lines">
        <table class="citus-data-table citus-line-table">
            <thead>
                <tr>
                    <th style="width: 3rem">#</th>
                    <th style="width: 14rem">Item (stock)</th>
                    <th style="width: 14rem">Category</th>
                    <th>Description</th>
                    @if (ShellState.IsModuleEnabled("task"))
                    {
                        <th style="width: 14rem">Task</th>
                    }
                    <th style="width: 8rem">Tax</th>
                    <th class="text-right" style="width: 8rem">Tax amt</th>
                    <th class="text-right" style="width: 10rem">Amount</th>
                    <th style="width: 3rem"></th>
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < _lines.Count; i++)
                {
                    var index = i;
                    var line = _lines[index];
                    var hasItem = line.ItemId != Guid.Empty;
                    <tr>
                        <td>@(index + 1)</td>
                        <td>
                            <ItemServicePicker CompanyId="@ShellState.ActiveCompany.Id"
                                               UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                               Context="@SearchScopeContext.BillItemPicker"
                                               Placeholder="Stock items only"
                                               Take="6"
                                               SourceRoute="/bills/new"
                                               SelectedId="@(line.ItemId == Guid.Empty ? null : line.ItemId)"
                                               SelectedDisplayText="@line.ItemDisplay"
                                               OnItemSelected="@(option => OnItemPicked(index, option))"
                                               OnCleared="@(() => OnItemCleared(index))" />
                        </td>
                        <td>
                            <AccountPicker CompanyId="@ShellState.ActiveCompany.Id"
                                           UserId="@(string.IsNullOrEmpty(ShellState.User.Id.Value) ? null : ShellState.User.Id)"
                                           Context="bill.line.category"
                                           Disabled="@hasItem"
                                           SelectedId="@line.ExpenseAccountId"
                                           SelectedDisplayText="@GetAccountLabel(line.ExpenseAccountId)"
                                           Placeholder="@(hasItem ? "From item" : "Pick a category…")"
                                           OnAccountSelected="@(acct => UpdateLine(index, l => l with { ExpenseAccountId = acct.Id }))"
                                           OnCleared="@(() => UpdateLine(index, l => l with { ExpenseAccountId = null }))" />
                        </td>
                        <td>
                            <CitusInput TValue="string"
                                        Value="@line.Description"
                                        ValueChanged="@(v => UpdateLine(index, l => l with { Description = v ?? string.Empty }))" />
                        </td>
                        @if (ShellState.IsModuleEnabled("task"))
                        {
                            <td>
                                <TaskPicker SelectedId="@line.TaskId"
                                            SelectedDisplayText="@line.TaskDisplay"
                                            Placeholder="Optional…"
                                            OnTaskSelected="@(option => UpdateLine(index, l => l with { TaskId = option.SourceId, TaskDisplay = option.DisplayText }))"
                                            OnCleared="@(() => UpdateLine(index, l => l with { TaskId = null, TaskDisplay = string.Empty }))" />
                            </td>
                        }
                        <td>
                            <RadzenDropDown TValue="Guid?"
                                            Data="@_taxCodeSets"
                                            Value="@line.TaxCodeSetId"
                                            Change="@(v => UpdateLine(index, l => l with { TaxCodeSetId = v as Guid? }))"
                                            TextProperty="Code"
                                            ValueProperty="Id"
                                            AllowClear="true"
                                            Class="citus-control-full" />
                        </td>
                        <td>
                            <RadzenNumeric TValue="decimal"
                                           Value="@line.TaxAmount"
                                           Change="@(v => UpdateLine(index, l => l with { TaxAmount = v }))"
                                           Format="0.00"
                                           Class="citus-control-full" />
                        </td>
                        <td>
                            <RadzenNumeric TValue="decimal"
                                           Value="@line.LineAmount"
                                           Change="@(v => UpdateLine(index, l => l with { LineAmount = v }))"
                                           Format="0.00"
                                           Class="citus-control-full" />
                        </td>
                        <td>
                            <CitusButton Variant="CitusButtonVariant.Ghost"
                                         Size="CitusButtonSize.Small"
                                         OnClick="@(() => RemoveLine(index))">×</CitusButton>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="flex gap-2 mt-3">
            <CitusButton Variant="CitusButtonVariant.Ghost"
                         Size="CitusButtonSize.Small"
                         OnClick="AddLine">+ Add line</CitusButton>
            <CitusButton Variant="CitusButtonVariant.Ghost"
                         Size="CitusButtonSize.Small"
                         OnClick="ClearLines">Clear all lines</CitusButton>
        </div>
    </CitusFormSection>

    <CitusFormSection Title="Memo">
        <CitusInput TValue="string"
                    @bind-Value="_memo"
                    Placeholder="Internal note about this bill" />
    </CitusFormSection>

    <CitusFormActions Sticky="true"
                      IsSaving="@_isSaving"
                      ErrorHint="@(string.IsNullOrWhiteSpace(_validation) ? null : "Fix errors above")"
                      OnSave="SaveAsync"
                      OnCancel="Cancel" />
}

@code {
    [Parameter] public Guid? BillId { get; set; }

    private Guid? _billId;
    private string? _billNumberDisplay;
    private string _status = "draft";

    private IReadOnlyList<VendorSummary> _vendors = Array.Empty<VendorSummary>();
    private IReadOnlyList<AccountSummary> _accountsRaw = Array.Empty<AccountSummary>();
    private IReadOnlyList<AccountOption> _accounts = Array.Empty<AccountOption>();
    private IReadOnlyList<TaxCodeSummary> _taxCodes = Array.Empty<TaxCodeSummary>();
    private IReadOnlyList<TaxCodeSetSummary> _taxCodeSets = Array.Empty<TaxCodeSetSummary>();
    private IReadOnlyList<PaymentTermSummary> _paymentTerms = Array.Empty<PaymentTermSummary>();
    // Item lookup powers the Item-pick → Category auto-fill on bill lines.
    // Loaded once on page init alongside accounts; the picker still searches
    // server-side, this dict only resolves SourceId → ItemSummary on pick.
    private Dictionary<Guid, ItemSummary> _itemsById = new();

    private Guid? _vendorId;
    private Guid? _paymentTermId;
    private Guid? _sourcePurchaseOrderId;
    private string? _sourcePurchaseOrderNumber;
    private string _billNumber = string.Empty;
    private DateTime? _billDate = DateTime.Today;
    private DateTime? _dueDate;
    private string _currency = string.Empty;
    private decimal? _fxRate;
    private string _memo = string.Empty;

    private List<LineDraft> _lines = new() { new LineDraft() };

    private bool _isLoading = true;
    private bool _isSaving;
    private string? _validation;
    // Optimistic-concurrency token. Captured from the bill's
    // updated_at on load and on every successful save; round-trips
    // back to the server on the next save so the API can reject
    // stale writes with HTTP 409.
    private DateTimeOffset? _expectedUpdatedAt;
    // Copy A3 Phase 2: source bill id when this page was reached
    // via the More → Copy flow from a detail page. Drives the
    // "This is a copy" banner + is sent to the server on Save so the
    // bill_copied audit_log row records the provenance. Only set in
    // the /bills/new route — the /bills/{id}/edit route ignores it.
    private Guid? _copiedFromBillId;
    private PageHeaderModel _header = new() { Eyebrow = "Expense & Bills", Title = "New bill", Subtitle = "Record a vendor invoice." };

    private decimal Subtotal => _lines.Sum(l => Math.Round(l.LineAmount, 6));
    private decimal TaxTotal => _lines.Sum(l => Math.Round(l.TaxAmount, 6));
    private decimal Total => Math.Round(Subtotal + TaxTotal, 6);

    /// <summary>
    /// Resting-state label shown inside the AccountPicker control so a
    /// loaded draft (or a freshly-picked row before re-render) shows the
    /// account name instead of an empty input. AccountPicker fetches its
    /// own search results — this helper only sources the *displayed*
    /// text from the page's pre-loaded account list.
    /// </summary>
    private string? GetAccountLabel(Guid? id) =>
        id is { } accountId ? _accounts.FirstOrDefault(a => a.Id == accountId)?.Label : null;

    protected override async Task OnInitializedAsync()
    {
        _currency = ShellState.ActiveCompany.BaseCurrencyCode;
        await LoadAsync();
        // Copy A3 Phase 2: handle ?copyFrom={id} after dropdowns/lookups
        // are loaded so the hydrated vendor / account ids resolve to
        // valid options. Only fires when BillId is null (the
        // /bills/new route); the /bills/{id}/edit route ignores
        // copyFrom because the edit ID takes precedence.
        if (BillId is null)
        {
            await TryHydrateFromCopySourceAsync();
        }
    }

    /// <summary>
    /// When the URL has ?copyFrom={guid}, fetch that bill and populate
    /// the form. Sensible defaults that differ from a straight copy:
    ///   - BillNumber    →  blanked (each supplier bill has a unique
    ///                      vendor-issued #; reusing it would create
    ///                      duplicate-bill ambiguity for the AP team)
    ///   - BillDate      →  today (a copy is a new bill received today)
    ///   - DueDate       →  recomputed from today + payment term
    ///                      (carrying forward the source's due date
    ///                      yields a date already in the past)
    ///   - FxRate        →  null (FxRateInline re-resolves for today)
    ///   - SourcePO link →  blanked (the new copy doesn't inherit
    ///                      provenance — that would corrupt the source
    ///                      PO's "fulfilled by" trail)
    ///   - Memo          →  copied (describes the bill itself)
    ///   - Lines         →  copied (account, description, amount,
    ///                      tax). Task back-links are NOT copied since
    ///                      the source task may be closed.
    /// </summary>
    private async Task TryHydrateFromCopySourceAsync()
    {
        var uri = new Uri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (!query.TryGetValue("copyFrom", out var raw) ||
            !Guid.TryParse(raw.ToString(), out var sourceId))
        {
            return;
        }

        BillRecordDto? source;
        try
        {
            source = await BillClient.GetByIdAsync(sourceId);
        }
        catch
        {
            return;
        }
        if (source is null)
        {
            _validation = "The bill you copied from is not visible in this company. The form is blank.";
            return;
        }

        _copiedFromBillId = source.Id;
        _vendorId = source.VendorId;
        _paymentTermId = source.PaymentTermId;
        _sourcePurchaseOrderId = null;       // see XML doc above
        _sourcePurchaseOrderNumber = null;
        _billNumber = string.Empty;           // see XML doc above
        _billDate = DateTime.Today;
        _dueDate = null;                      // RecomputeDueDate below
        _currency = source.DocumentCurrencyCode;
        _fxRate = null;                       // FxRateInline re-resolves
        _memo = source.Memo ?? string.Empty;
        _lines = source.Lines.Select(l => new LineDraft
        {
            ExpenseAccountId = l.ExpenseAccountId,
            Description = l.Description,
            LineAmount = l.LineAmount,
            TaxCodeId = l.TaxCodeId,
            TaxAmount = l.TaxAmount,
            // Task back-link NOT copied — source task may be closed.
            TaskId = null,
            TaskDisplay = string.Empty
        }).ToList();
        if (_lines.Count == 0) _lines.Add(new LineDraft());
        RecomputeDueDate();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (BillId.HasValue && _billId != BillId)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            var vendorsTask = VendorClient.ListAsync();
            var accountsTask = AccountClient.ListAsync();
            var taxTask = TaxCodeClient.ListAsync(appliesTo: "purchase");
            var taxSetTask = TaxCodeSetClient.ListAsync(appliesTo: "purchase");
            var termsTask = PaymentTermClient.ListAsync(includeInactive: false);
            var itemsTask = ItemClient.ListAsync(includeInactive: false);
            await Task.WhenAll(vendorsTask, accountsTask, taxTask, taxSetTask, termsTask, itemsTask);

            _vendors = vendorsTask.Result;
            _accountsRaw = accountsTask.Result;
            _accounts = _accountsRaw
                .Where(a => a.IsActive && a.AllowManualPosting)
                .Select(a => new AccountOption(a.Id, $"{a.Code}  {a.Name}"))
                .ToList();
            _taxCodes = taxTask.Result;
            _taxCodeSets = taxSetTask.Result;
            _paymentTerms = termsTask.Result;
            _itemsById = itemsTask.Result.ToDictionary(i => i.Id);

            _billId = BillId;
            if (BillId is { } id)
            {
                var bill = await BillClient.GetByIdAsync(id);
                if (bill is null)
                {
                    _validation = "Bill not found.";
                    return;
                }
                await ApplyExisting(bill);
            }
        }
        finally { _isLoading = false; }
    }

    private async Task ApplyExisting(BillRecordDto bill)
    {
        _billNumberDisplay = bill.EntityNumber;
        _status = bill.Status;
        _expectedUpdatedAt = bill.UpdatedAt;
        _header = new PageHeaderModel
        {
            Eyebrow = "Expense & Bills",
            Title = $"Edit {bill.BillNumber}",
            Subtitle = $"Status: {bill.Status}"
        };
        _vendorId = bill.VendorId;
        _paymentTermId = bill.PaymentTermId;
        _sourcePurchaseOrderId = bill.SourcePurchaseOrderId;
        _sourcePurchaseOrderNumber = bill.SourcePurchaseOrderNumber;
        _billNumber = bill.BillNumber;
        _billDate = bill.BillDate.ToDateTime(TimeOnly.MinValue);
        _dueDate = bill.DueDate.ToDateTime(TimeOnly.MinValue);
        _currency = bill.DocumentCurrencyCode;
        _fxRate = bill.FxRate;
        _memo = bill.Memo ?? string.Empty;
        _lines = bill.Lines.Select(l => new LineDraft
        {
            ExpenseAccountId = l.ExpenseAccountId,
            Description = l.Description,
            LineAmount = l.LineAmount,
            TaxCodeId = l.TaxCodeId,
            TaxAmount = l.TaxAmount,
            TaskId = l.TaskId,
            // TaskDisplay is filled in below by a single batch call to
            // /accounting/tasks/lookup. Start empty and let the lookup
            // populate "TSK-000123 - Title" labels in one round trip.
            TaskDisplay = string.Empty,
        }).ToList();

        // Resolve real task display labels for any persisted task_ids
        // on this bill's lines. Single HTTP call, regardless of line
        // count. Missing ids (deleted tasks etc.) silently fall back
        // to an empty label.
        var distinctTaskIds = _lines
            .Where(l => l.TaskId.HasValue)
            .Select(l => l.TaskId!.Value)
            .Distinct()
            .ToArray();
        if (distinctTaskIds.Length > 0)
        {
            var labels = await TaskClient.LookupDisplayAsync(distinctTaskIds);
            foreach (var line in _lines)
            {
                if (line.TaskId is { } tid && labels.TryGetValue(tid, out var label))
                {
                    line.TaskDisplay = label;
                }
            }
        }
        if (_lines.Count == 0) _lines.Add(new LineDraft());
    }

    private void OnVendorChanged()
    {
        if (_vendorId is null) return;
        var vendor = _vendors.FirstOrDefault(v => v.Id == _vendorId.Value);
        if (vendor is null) return;
        _currency = vendor.DefaultCurrencyCode;
        _paymentTermId = vendor.PaymentTermId;
        RecomputeDueDate();
    }

    private void RecomputeDueDate()
    {
        if (_paymentTermId is { } termId && _billDate is { } billDate)
        {
            var term = _paymentTerms.FirstOrDefault(t => t.Id == termId);
            if (term is not null)
            {
                _dueDate = billDate.AddDays(term.NetDays);
            }
        }
        else if (_dueDate is null && _billDate is { } d)
        {
            _dueDate = d;
        }
    }

    private void UpdateLine(int index, Func<LineDraft, LineDraft> mutate)
    {
        if (index < 0 || index >= _lines.Count) return;
        var current = _lines[index];
        var updated = mutate(current);
        current.ItemId = updated.ItemId;
        current.ItemDisplay = updated.ItemDisplay;
        current.ExpenseAccountId = updated.ExpenseAccountId;
        current.Description = updated.Description;
        current.LineAmount = updated.LineAmount;
        current.TaxCodeId = updated.TaxCodeId;
        current.TaxCodeSetId = updated.TaxCodeSetId;
        current.TaxAmount = updated.TaxAmount;
        current.TaskId = updated.TaskId;
        current.TaskDisplay = updated.TaskDisplay;
    }

    private void OnItemPicked(int index, UnitySearchPickerOption option)
    {
        // Bill picker (BillItemPicker policy → 'inventory_stock_item'
        // projection) surfaces stock + drop-ship items. Auto-fill the
        // line's account by item kind:
        //   stock     → DefaultInventoryAssetAccountId (Dr Inventory)
        //   drop_ship → DefaultDropShipClearingAccountId (Dr Drop-ship Clearing)
        // Either way the server-side override in PostgresBillDocumentRepository
        // re-resolves at post time, so a missing per-item default still
        // posts correctly via the company-level system_role lookup. The
        // form-fill is a UX nicety, not a correctness requirement.
        Guid? expenseAccountId = null;
        if (_itemsById.TryGetValue(option.SourceId, out var item))
        {
            expenseAccountId = string.Equals(item.ItemKind, "drop_ship", StringComparison.Ordinal)
                ? item.DefaultDropShipClearingAccountId
                : item.DefaultInventoryAssetAccountId;
        }
        UpdateLine(index, l => l with
        {
            ItemId = option.SourceId,
            ItemDisplay = option.DisplayText,
            ExpenseAccountId = expenseAccountId,
            Description = string.IsNullOrWhiteSpace(l.Description) ? option.PrimaryText : l.Description,
        });
    }

    private void OnItemCleared(int index)
    {
        UpdateLine(index, l => l with
        {
            ItemId = Guid.Empty,
            ItemDisplay = string.Empty,
            ExpenseAccountId = null,
        });
    }

    private void AddLine() => _lines.Add(new LineDraft());

    private void RemoveLine(int index)
    {
        if (index < 0 || index >= _lines.Count) return;
        _lines.RemoveAt(index);
        if (_lines.Count == 0) _lines.Add(new LineDraft());
    }

    private void ClearLines() { _lines.Clear(); _lines.Add(new LineDraft()); }

    private async Task SaveAsync()
    {
        _validation = null;
        if (_vendorId is null) { _validation = "Pick a supplier."; return; }
        if (string.IsNullOrWhiteSpace(_billNumber)) { _validation = "Bill no. is required (use the supplier's invoice number)."; return; }
        if (_lines.All(l => l.LineAmount == 0 && string.IsNullOrWhiteSpace(l.Description) && l.ExpenseAccountId is null))
        {
            _validation = "Add at least one line with a category and amount.";
            return;
        }
        var lineWithoutCategory = _lines.FirstOrDefault(l => (l.LineAmount > 0 || !string.IsNullOrWhiteSpace(l.Description)) && l.ExpenseAccountId is null);
        if (lineWithoutCategory is not null)
        {
            _validation = "Every line with an amount or description needs a category.";
            return;
        }

        _isSaving = true;
        try
        {
            var billDate = DateOnly.FromDateTime((_billDate ?? DateTime.Today).Date);
            var dueDate = DateOnly.FromDateTime((_dueDate ?? _billDate ?? DateTime.Today).Date);
            var draft = new BillDraft
            {
                CompanyId = ShellState.ActiveCompany.Id,
                UserId = ShellState.User.Id,
                DocumentDate = billDate,
                DueDate = dueDate,
                VendorId = _vendorId,
                TransactionCurrencyCode = string.IsNullOrWhiteSpace(_currency) ? ShellState.ActiveCompany.BaseCurrencyCode : _currency,
                BaseCurrencyCode = ShellState.ActiveCompany.BaseCurrencyCode,
                FxRate = _fxRate,
                Memo = _memo?.Trim() ?? string.Empty,
                BillNumber = _billNumber?.Trim() ?? string.Empty,
                PaymentTermId = _paymentTermId,
                SourcePurchaseOrderId = _sourcePurchaseOrderId,
                SourcePurchaseOrderNumber = _sourcePurchaseOrderNumber ?? string.Empty,
                Lines = _lines
                    .Where(l => l.ExpenseAccountId is not null && (l.LineAmount > 0 || !string.IsNullOrWhiteSpace(l.Description)))
                    .Select((l, i) => new BillLineDraft
                    {
                        LineNumber = i + 1,
                        ExpenseAccountId = l.ExpenseAccountId!.Value,
                        Description = l.Description ?? string.Empty,
                        LineAmount = l.LineAmount,
                        TaxCodeId = l.TaxCodeId,
                        TaxCodeSetId = l.TaxCodeSetId,
                        TaxAmount = 0m,
                        IsTaxRecoverable = true,
                        TaskId = l.TaskId,
                    })
                    .ToArray(),
            };
            var result = _billId is null
                ? await WriteFlow.PostBillDraftAsync(draft)
                : await WriteFlow.UpdateBillDraftAsync(_billId.Value, draft);
            if (!result.Succeeded)
            {
                _validation = result.Message ?? "Could not save the bill.";
                return;
            }
            await Message.SuccessAsync(result.Message);
            Navigation.NavigateTo(result.DocumentId is { } newId ? $"bills/{newId:D}" : (_billId is { } existing ? $"bills/{existing:D}" : "bills"));
        }
        finally { _isSaving = false; }
    }

    private void Cancel() => Navigation.NavigateTo(_billId is null ? "bills" : $"bills/{_billId:D}");

    private static string FormatAmount(decimal value) =>
        value.ToString("N2", System.Globalization.CultureInfo.InvariantCulture);

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed record LineDraft
    {
        // ItemId / ItemDisplay are UI-only — the wire shape (BillLinePayload)
        // posts only the resolved ExpenseAccountId. We don't persist which
        // item drove the line yet; matches the precedent on the sales side.
        public Guid ItemId { get; set; }
        public string ItemDisplay { get; set; } = string.Empty;
        public Guid? ExpenseAccountId { get; set; }
        public string Description { get; set; } = string.Empty;
        public decimal LineAmount { get; set; }
        public Guid? TaxCodeId { get; set; }
        public Guid? TaxCodeSetId { get; set; }
        public decimal TaxAmount { get; set; }
        // Optional Task back-link. Edit-page loads it from
        // BillLineDto.TaskId; new lines start blank. Display text falls
        // back to a short GUID on load since we don't fetch task
        // summaries up-front — re-pick to see the full label.
        public Guid? TaskId { get; set; }
        public string TaskDisplay { get; set; } = string.Empty;
    }

    private sealed record AccountOption(Guid Id, string Label);
}
