@page "/bills/{BillId:guid}"

@inject BusinessShellState ShellState
@inject BillClient BillClient
@inject AccountClient AccountClient
@inject CitusToastService Message
@inject NavigationManager Navigation

<PageTitle>@($"{_pageTitle} | Tralanz Books")</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusLinkButton Href="bills"
                         Variant="CitusButtonVariant.Ghost"
                         LeadingIcon="IconName.ArrowLeft">
            Back to bills
        </CitusLinkButton>
        @if (_bill is not null && IsEditable(_bill.Status))
        {
            <CitusLinkButton Href="@($"bills/{_bill.Id:D}/edit")"
                             Variant="CitusButtonVariant.Primary"
                             LeadingIcon="IconName.Pencil">
                Edit
            </CitusLinkButton>
        }
    </Actions>
</CitusPageHeader>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_error" ShowIcon="true" Class="mb-4" />
}

@if (_isLoading)
{
    <CitusSkeleton Variant="SkeletonVariant.Detail" />
}
else if (_bill is null)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning" Message="Bill not found in this company." ShowIcon="true" />
}
else
{
    <CitusStatCardGrid Columns="4">
        <CitusStatCard Label="Bill #" Value="@_bill.BillNumber" Description="@_bill.VendorName"
                       Icon="IconName.Receipt" Tone="StatTone.Primary" />
        <CitusStatCard Label="Status" Value="@HumanizeStatus(_bill.Status)" Description="@StatusHint(_bill.Status)"
                       Icon="IconName.Eye" Tone="@StatusTone(_bill.Status)" />
        <CitusStatCard Label="Total" Value="@($"{_bill.TotalAmount:N2} {_bill.DocumentCurrencyCode}")"
                       Description="@($"Subtotal {_bill.SubtotalAmount:N2} + tax {_bill.TaxAmount:N2}")"
                       Icon="IconName.Coin" Tone="StatTone.Success" />
        <CitusStatCard Label="Due"
                       Value="@_bill.DueDate.ToString("yyyy-MM-dd")"
                       Description="@($"Issued {_bill.BillDate:yyyy-MM-dd}")"
                       Icon="IconName.Calendar" Tone="StatTone.Neutral" />
    </CitusStatCardGrid>

    @* Copy A3 Phase 2: secondary actions collapse into the More
       menu. Void only applies to drafts (server still re-checks);
       Copy is always available — copying a paid bill into a fresh
       draft is a valid recurring-bill workflow. *@
    <CitusActionsPanel MoreMenuItems="@_moreItems"
                       Hint="@(_bill.Status == "posted" ? "Use the Pay Bills page to settle this bill." : null)">
        @if (_bill.SourcePurchaseOrderId is { } poId)
        {
            <CitusLinkButton Href="@($"purchase-orders/{poId:D}")"
                             Variant="CitusButtonVariant.Ghost">
                View source PO
            </CitusLinkButton>
        }
    </CitusActionsPanel>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-8">
            <CitusFormSection Title="Lines">
                <table class="citus-data-table">
                    <thead>
                        <tr>
                            <th style="width: 3rem">#</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th class="text-right" style="width: 8rem">Tax</th>
                            <th class="text-right" style="width: 9rem">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in _bill.Lines)
                        {
                            <tr>
                                <td>@line.LineNumber</td>
                                <td>@ResolveAccountLabel(line.ExpenseAccountId)</td>
                                <td>@(string.IsNullOrEmpty(line.Description) ? "—" : line.Description)</td>
                                <td class="text-right">@line.TaxAmount.ToString("N2")</td>
                                <td class="text-right">@line.LineAmount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </CitusFormSection>

            @if (!string.IsNullOrWhiteSpace(_bill.Memo))
            {
                <CitusFormSection Title="Memo">
                    <p class="text-fg-muted text-sm">@_bill.Memo</p>
                </CitusFormSection>
            }
        </div>

        <aside class="lg:col-span-4 flex flex-col gap-6">
            <CitusFormSection Title="Document">
                <CitusKeyValueTable>
                    <CitusKeyValueRow Label="Bill no."><span class="citus-inline-code">@_bill.BillNumber</span></CitusKeyValueRow>
                    <CitusKeyValueRow Label="Internal #"><span class="citus-inline-code">@_bill.EntityNumber</span></CitusKeyValueRow>
                    <CitusKeyValueRow Label="Bill date">@_bill.BillDate.ToString("yyyy-MM-dd")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Due date">@_bill.DueDate.ToString("yyyy-MM-dd")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Currency">@_bill.DocumentCurrencyCode @(_bill.DocumentCurrencyCode == _bill.BaseCurrencyCode ? "" : $"@ {_bill.FxRate}")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Source PO">@(string.IsNullOrEmpty(_bill.SourcePurchaseOrderNumber) ? "—" : _bill.SourcePurchaseOrderNumber)</CitusKeyValueRow>
                    @if (_bill.PostedAt is { } postedAt)
                    {
                        <CitusKeyValueRow Label="Posted">@postedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</CitusKeyValueRow>
                    }
                </CitusKeyValueTable>
            </CitusFormSection>

            <CitusFormSection Title="Totals">
                <CitusKeyValueTable>
                    <CitusKeyValueRow Label="Subtotal" ValueAlignRight="true">@_bill.SubtotalAmount.ToString("N2")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Tax" ValueAlignRight="true">@_bill.TaxAmount.ToString("N2")</CitusKeyValueRow>
                    <CitusKeyValueRow Label="Total" ValueAlignRight="true"><strong>@_bill.TotalAmount.ToString("N2") @_bill.DocumentCurrencyCode</strong></CitusKeyValueRow>
                </CitusKeyValueTable>
            </CitusFormSection>
        </aside>
    </div>
}

@code {
    [Parameter] public Guid BillId { get; set; }

    private BillRecordDto? _bill;
    private IReadOnlyList<AccountSummary> _accounts = Array.Empty<AccountSummary>();
    private bool _isLoading = true;
    private bool _isMutating;
    private string? _error;

    private PageHeaderModel _header = new() { Eyebrow = "Expense & Bills", Title = "Bill", Subtitle = "Bill detail" };
    private string _pageTitle = "Bill";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override async Task OnParametersSetAsync()
    {
        if (_bill is not null && _bill.Id != BillId)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            var billTask = BillClient.GetByIdAsync(BillId);
            var accountsTask = AccountClient.ListAsync();
            await Task.WhenAll(billTask, accountsTask);
            _bill = billTask.Result;
            _accounts = accountsTask.Result;
            ApplyHeader();
        }
        finally { _isLoading = false; }
    }

    private void ApplyHeader()
    {
        if (_bill is null)
        {
            _pageTitle = "Bill";
            _header = new PageHeaderModel { Eyebrow = "Expense & Bills", Title = "Bill", Subtitle = "Bill detail" };
            return;
        }
        _pageTitle = _bill.BillNumber;
        _header = new PageHeaderModel
        {
            Eyebrow = "Expense & Bills",
            Title = _bill.BillNumber,
            Subtitle = $"{_bill.VendorName} · {HumanizeStatus(_bill.Status)}"
        };
    }

    private string ResolveAccountLabel(Guid accountId)
    {
        var account = _accounts.FirstOrDefault(a => a.Id == accountId);
        return account is null ? accountId.ToString("D") : $"{account.Code}  {account.Name}";
    }

    private async Task VoidAsync()
    {
        if (_bill is null || _isMutating) return;
        _isMutating = true;
        try
        {
            var outcome = await BillClient.VoidAsync(_bill.Id);
            if (!outcome.Succeeded)
            {
                _error = outcome.ErrorMessage ?? "Void failed.";
                await Message.WarningAsync(_error);
                return;
            }
            _bill = outcome.Saved;
            ApplyHeader();
            await Message.SuccessAsync("Bill voided.");
        }
        finally { _isMutating = false; }
    }

    // Copy A3 Phase 2: navigate to /bills/new with the source id.
    // Copy is permitted from any status — copying a paid or voided
    // bill into a fresh draft is a valid recurring-bill workflow.
    private void CopyAsync()
    {
        if (_bill is null) return;
        Navigation.NavigateTo($"bills/new?copyFrom={_bill.Id:D}");
    }

    private IReadOnlyList<CitusMoreMenuItem> _moreItems => _bill is null
        ? Array.Empty<CitusMoreMenuItem>()
        : new[]
        {
            new CitusMoreMenuItem
            {
                Label = "Copy",
                OnClick = EventCallback.Factory.Create(this, CopyAsync),
                Disabled = _isMutating
            },
            new CitusMoreMenuItem
            {
                Label = "Void",
                Danger = true,
                // Server only accepts Void on draft (per BillClient.VoidAsync
                // contract); grey-out the row for any other status so
                // operators can still see the action exists.
                Disabled = _bill.Status != "draft" || _isMutating,
                OnClick = EventCallback.Factory.Create(this, VoidAsync)
            }
        };

    private static bool IsEditable(string status) => status is "draft";

    private static string HumanizeStatus(string status) => status switch
    {
        "draft" => "Draft",
        "posted" => "Posted",
        "partially_paid" => "Partially paid",
        "paid" => "Paid",
        "voided" => "Voided",
        "reversed" => "Reversed",
        _ => status
    };

    private static string StatusHint(string status) => status switch
    {
        "draft" => "Not posted yet.",
        "posted" => "Awaiting payment.",
        "partially_paid" => "Some applications received.",
        "paid" => "Fully settled.",
        "voided" => "Voided.",
        "reversed" => "Reversed.",
        _ => string.Empty
    };

    private static StatTone StatusTone(string status) => status switch
    {
        "draft" => StatTone.Neutral,
        "posted" => StatTone.Info,
        "partially_paid" => StatTone.Info,
        "paid" => StatTone.Success,
        "voided" => StatTone.Neutral,
        "reversed" => StatTone.Warning,
        _ => StatTone.Neutral
    };
}
