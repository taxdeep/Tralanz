@page "/bills"

@inject BusinessShellState ShellState

<PageTitle>Bills | Citus Business</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <a class="citus-button" href="bills/new">
            <CitusIcon Name="IconName.Plus" Size="IconSize.Inline" />
            <span>New bill</span>
        </a>
    </Actions>
</CitusPageHeader>

<AntDesign.Alert Type="@AntDesign.AlertType.Info"
                 ShowIcon="true"
                 Message="Bill list pulls from the existing A/P Aging + Document Review HTTP surface. Posted bills stay read-only — review opens via the Document drill-down."
                 Class="mb-4" />

<section class="citus-panel">
    <header class="citus-panel__header">
        <h2 class="citus-panel__title">Recent bills</h2>
        <AntDesign.Tag Color="@("blue")">Read-only review</AntDesign.Tag>
    </header>

    <CitusAsyncBoundary IsLoading="false"
                        IsEmpty="@(_bills.Count == 0)"
                        EmptyIcon="IconName.Receipt"
                        EmptyTitle="No bills for this company yet"
                        EmptyMessage="Use 'New bill' to record one. Posted bills appear here ordered by document date.">
        <table class="citus-data-table">
            <thead>
                <tr>
                    <th>Bill</th>
                    <th>Vendor</th>
                    <th>Document date</th>
                    <th>Due date</th>
                    <th>Status</th>
                    <th class="text-right">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var bill in _bills)
                {
                    <tr>
                        <td>
                            <a class="citus-link" href="@($"documents/bill/{bill.Id:D}")">@bill.DisplayNumber</a>
                            <div class="text-fg-subtle text-xs">@bill.Memo</div>
                        </td>
                        <td>@bill.VendorName</td>
                        <td>@bill.DocumentDate.ToString("yyyy-MM-dd")</td>
                        <td>@(bill.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td><AntDesign.Tag Color="@StatusColor(bill.Status)">@bill.Status</AntDesign.Tag></td>
                        <td class="text-right">@bill.TotalAmount.ToString("N2") @bill.Currency</td>
                    </tr>
                }
            </tbody>
        </table>
    </CitusAsyncBoundary>
</section>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Expense & Bills",
        Title = "Bills",
        Subtitle = "Vendor-facing payable anchors. Posted bills feed A/P Aging and Pay Bills settlement."
    };

    private readonly IReadOnlyList<BillListRow> _bills = Array.Empty<BillListRow>();

    private static string StatusColor(string status) => status.ToLowerInvariant() switch
    {
        "posted" => "green",
        "draft" => "blue",
        "voided" => "red",
        "overdue" => "orange",
        _ => "default"
    };

    private sealed record class BillListRow(
        Guid Id,
        string DisplayNumber,
        string VendorName,
        DateOnly DocumentDate,
        DateOnly? DueDate,
        string Status,
        decimal TotalAmount,
        string Currency,
        string Memo);
}
