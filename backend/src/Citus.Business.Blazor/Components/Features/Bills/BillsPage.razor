@page "/bills"

@using Radzen
@using Radzen.Blazor

@inject BusinessShellState ShellState
@inject BillClient BillClient

<PageTitle>Bills | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <a class="citus-button" href="bills/new">
            <CitusIcon Name="IconName.Plus" Size="IconSize.Inline" />
            <span>New bill</span>
        </a>
    </Actions>
</CitusPageHeader>

<section class="citus-panel">
    <header class="citus-panel__header">
        <h2 class="citus-panel__title">Bills</h2>
        <label class="inline-flex items-center gap-2 text-sm">
            <input type="checkbox"
                   checked="@_showDrafts"
                   @onchange="OnToggleDrafts" />
            Show drafts
        </label>
    </header>

    <CitusAsyncBoundary IsLoading="@_isLoading"
                        IsEmpty="@(_rows.Count == 0)"
                        EmptyIcon="IconName.Receipt"
                        EmptyTitle="No bills yet"
                        EmptyMessage="Click New bill to record one. Drafts stay local until you Post them.">
        <RadzenDataGrid TItem="BillRow"
                        Data="@_rows"
                        AllowSorting="true"
                        AllowFiltering="true"
                        AllowColumnResize="true"
                        AllowPaging="true"
                        PageSize="50"
                        FilterMode="FilterMode.Simple"
                        class="citus-radzen-grid">
            <Columns>
                <RadzenDataGridColumn TItem="BillRow" Property="@nameof(BillRow.BillNumber)" Title="Bill #" Width="180px">
                    <Template Context="row">
                        <a class="citus-link" href="@($"bills/{row.Id:D}")">
                            <span class="citus-inline-code">@row.BillNumber</span>
                        </a>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="BillRow" Property="@nameof(BillRow.VendorName)" Title="Vendor">
                    <Template Context="row">
                        <a class="citus-link" href="@($"bills/{row.Id:D}")">@row.VendorName</a>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="BillRow" Property="@nameof(BillRow.BillDate)" Title="Bill date" Width="120px">
                    <Template Context="row">@row.BillDate.ToString("yyyy-MM-dd")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="BillRow" Property="@nameof(BillRow.DueDate)" Title="Due date" Width="120px">
                    <Template Context="row">@row.DueDate.ToString("yyyy-MM-dd")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="BillRow" Property="@nameof(BillRow.Status)" Title="Status" Width="120px">
                    <Template Context="row">
                        <CitusDocumentStatusBadge Status="@row.Status" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="BillRow" Property="@nameof(BillRow.SourcePurchaseOrderNumber)" Title="Source PO" Width="140px">
                    <Template Context="row">@(string.IsNullOrEmpty(row.SourcePurchaseOrderNumber) ? "—" : row.SourcePurchaseOrderNumber)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="BillRow" Property="@nameof(BillRow.TotalAmount)" Title="Total" TextAlign="TextAlign.Right" Width="160px">
                    <Template Context="row">@row.TotalAmount.ToString("N2") @row.Currency</Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </CitusAsyncBoundary>
</section>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Expense & Bills",
        Title = "Bills",
        Subtitle = "Vendor invoices. Posted bills feed AP aging and Pay Bills settlement."
    };

    private List<BillRow> _rows = new();
    private bool _isLoading = true;
    private bool _showDrafts = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            var rows = await BillClient.ListAsync(includeDrafts: _showDrafts);
            _rows = rows.Select(r => new BillRow(
                Id: r.Id,
                BillNumber: r.BillNumber,
                VendorName: string.IsNullOrEmpty(r.VendorName) ? "—" : r.VendorName,
                BillDate: r.BillDate,
                DueDate: r.DueDate,
                Status: r.Status,
                SourcePurchaseOrderNumber: r.SourcePurchaseOrderNumber,
                TotalAmount: r.TotalAmount,
                Currency: r.DocumentCurrencyCode)).ToList();
        }
        finally { _isLoading = false; }
    }

    private async Task OnToggleDrafts(ChangeEventArgs args)
    {
        _showDrafts = (bool)(args.Value ?? true);
        await LoadAsync();
    }

    private sealed record BillRow(
        Guid Id,
        string BillNumber,
        string VendorName,
        DateOnly BillDate,
        DateOnly DueDate,
        string Status,
        string? SourcePurchaseOrderNumber,
        decimal TotalAmount,
        string Currency);
}
