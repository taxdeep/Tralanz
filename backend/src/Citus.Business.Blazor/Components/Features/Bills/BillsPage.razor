@page "/bills"

@using Radzen
@using Radzen.Blazor

@inject BusinessShellState ShellState

<PageTitle>Bills | Tralanz Business</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <a class="citus-button" href="bills/new">
            <CitusIcon Name="IconName.Plus" Size="IconSize.Inline" />
            <span>New bill</span>
        </a>
    </Actions>
</CitusPageHeader>

<CitusAlert Severity="CitusAlertSeverity.Info"
                 ShowIcon="true"
                 Message="Bill list pulls from the existing A/P Aging + Document Review HTTP surface. Posted bills stay read-only — review opens via the Document drill-down."
                 Class="mb-4" />

<section class="citus-panel">
    <header class="citus-panel__header">
        <h2 class="citus-panel__title">Recent bills</h2>
        <CitusBadge Color="@("blue")">Read-only review</CitusBadge>
    </header>

    <CitusAsyncBoundary IsLoading="false"
                        IsEmpty="@(_bills.Count == 0)"
                        EmptyIcon="IconName.Receipt"
                        EmptyTitle="No bills for this company yet"
                        EmptyMessage="Use 'New bill' to record one. Posted bills appear here ordered by document date.">
        <RadzenDataGrid TItem="BillListRow"
                        Data="@_bills"
                        AllowSorting="true"
                        AllowFiltering="true"
                        AllowColumnResize="true"
                        AllowPaging="true"
                        PageSize="50"
                        FilterMode="FilterMode.Simple"
                        class="citus-radzen-grid">
            <Columns>
                <RadzenDataGridColumn TItem="BillListRow" Property="@nameof(BillListRow.DisplayNumber)" Title="Bill" Width="180px">
                    <Template Context="bill">
                        <a class="citus-link" href="@($"documents/bill/{bill.Id:D}")">@bill.DisplayNumber</a>
                        <div class="text-fg-subtle text-xs">@bill.Memo</div>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="BillListRow" Property="@nameof(BillListRow.VendorName)" Title="Vendor" />
                <RadzenDataGridColumn TItem="BillListRow" Property="@nameof(BillListRow.DocumentDate)" Title="Document date" Width="140px">
                    <Template Context="bill">@bill.DocumentDate.ToString("yyyy-MM-dd")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="BillListRow" Property="@nameof(BillListRow.DueDate)" Title="Due date" Width="120px">
                    <Template Context="bill">@(bill.DueDate?.ToString("yyyy-MM-dd") ?? "-")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="BillListRow" Property="@nameof(BillListRow.Status)" Title="Status" Width="110px">
                    <Template Context="bill">
                        <CitusBadge Color="@StatusColor(bill.Status)">@bill.Status</CitusBadge>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="BillListRow" Property="@nameof(BillListRow.TotalAmount)" Title="Total" TextAlign="TextAlign.Right" Width="140px">
                    <Template Context="bill">@bill.TotalAmount.ToString("N2") @bill.Currency</Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </CitusAsyncBoundary>
</section>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Expense & Bills",
        Title = "Bills",
        Subtitle = "Vendor-facing payable anchors. Posted bills feed A/P Aging and Pay Bills settlement."
    };

    private readonly IReadOnlyList<BillListRow> _bills = Array.Empty<BillListRow>();

    private static string StatusColor(string status) => status.ToLowerInvariant() switch
    {
        "posted" => "green",
        "draft" => "blue",
        "voided" => "red",
        "overdue" => "orange",
        _ => "default"
    };

    private sealed record class BillListRow(
        Guid Id,
        string DisplayNumber,
        string VendorName,
        DateOnly DocumentDate,
        DateOnly? DueDate,
        string Status,
        decimal TotalAmount,
        string Currency,
        string Memo);
}
