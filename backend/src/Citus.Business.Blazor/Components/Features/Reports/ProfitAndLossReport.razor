@using Citus.Ui.Shared.Reports
@using Radzen
@using Radzen.Blazor

@inject BusinessShellState ShellState
@inject IncomeStatementClient IncomeStatementClient
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

<ReportShell IsLoading="_isLoading" Error="_error">
    <Controls>
        <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_dateFrom" Placeholder="@("From")" />
        <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_dateTo" Placeholder="@("To")" />
        <label class="inline-flex items-center gap-2 text-sm">
            <RadzenCheckBox @bind-Value="_includeZeroRows" /> Include zero-balance accounts
        </label>
        <RadzenDropDown TValue="string" @bind-Value="_basis" Data="@_basisOptions" Style="width: 9rem" />
        <RadzenDropDown TValue="string" @bind-Value="_compare" Data="@_compareOptions" Disabled="@(_columnsBy != NoColumns)" Style="width: 11rem" />
        <RadzenDropDown TValue="string" @bind-Value="_columnsBy" Data="@_columnsOptions" Style="width: 10rem" />
        <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_isLoading" OnClick="LoadAsync">
            Run Profit and Loss
        </CitusButton>
        <CitusButton LeadingIcon="IconName.Download" Disabled="@(_isLoading || _isExporting)" OnClick="ExportAsync">
            Export CSV
        </CitusButton>
    </Controls>
    <Body>
@if (_incomeStatement is not null && string.Equals(_basis, "Cash", StringComparison.OrdinalIgnoreCase))
{
    <p class="text-fg-subtle text-xs mb-3">Cash basis — invoiced/billed amounts are recognised as their payments are received/paid; direct expenses and manual entries stay at their posting date.</p>
}
@if (_incomeStatement is not null && _comparison is not null)
{
    <p class="text-fg-subtle text-xs mb-3">Comparison column: @_compare (@_comparisonRangeLabel).</p>
}
@if (_incomeStatement is not null)
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
        <CitusStatCard Label="Revenue" Value="@ReportFormat.Amount(_incomeStatement.TotalRevenue)" Description="@($"Range {_incomeStatement.DateFrom:yyyy-MM-dd} to {_incomeStatement.DateTo:yyyy-MM-dd}")" Icon="IconName.ReportAnalytics" Tone="StatTone.Success" />
        <CitusStatCard Label="Gross profit" Value="@ReportFormat.Amount(_incomeStatement.GrossProfit)" Description="@($"After cost of sales in {_incomeStatement.BaseCurrencyCode}")" Icon="IconName.ReportAnalytics" Tone="StatTone.Info" />
        <CitusStatCard Label="Expenses" Value="@ReportFormat.Amount(_incomeStatement.TotalExpenses)" Description="Operating expense accounts in the selected range." Icon="IconName.Wallet" Tone="StatTone.Warning" />
        <CitusStatCard Label="Net income" Value="@ReportFormat.Amount(_incomeStatement.NetIncome)" Description="@(_comparison is null ? $"Company base currency {_incomeStatement.BaseCurrencyCode}" : $"vs {ReportFormat.Amount(_comparison.NetIncome)} ({_compare})")" Icon="IconName.BuildingBank" Tone="@(_incomeStatement.NetIncome >= 0m ? StatTone.Success : StatTone.Danger)" />
    </div>

    @if (_incomeStatement.AccountCount == 0)
    {
        <CitusAlert Severity="CitusAlertSeverity.Info" Message="@($"No income activity was found for this company between {_incomeStatement.DateFrom:yyyy-MM-dd} and {_incomeStatement.DateTo:yyyy-MM-dd}.")" ShowIcon="true" />
    }
    else
    {
        @foreach (var sec in Sections)
        {
            <article class="citus-subpanel">
                <header class="citus-subpanel__header">
                    <h3 class="citus-subpanel__title">@sec.Title</h3>
                    <div class="flex items-center gap-2">
                        <CitusBadge Color="@TagColor(sec.Tone)">@ReportFormat.Amount(sec.TotalOf(_incomeStatement))</CitusBadge>
                        @if (_comparison is not null)
                        {
                            <span class="text-fg-subtle text-xs">vs @ReportFormat.Amount(sec.TotalOf(_comparison))</span>
                        }
                    </div>
                </header>

                @if (_periodReports.Count > 0)
                {
                    // Columns-by: one column per sub-period + Total.
                    var columnRows = BuildColumnRows(sec.RowsOf);
                    if (columnRows.Count == 0)
                    {
                        <p class="text-fg-muted text-sm">No accounts in this section for the selected range.</p>
                    }
                    else
                    {
                        <table class="citus-data-table citus-data-table--compact">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Account</th>
                                    @foreach (var period in _periods)
                                    {
                                        <th class="text-right">@period.Label</th>
                                    }
                                    <th class="text-right">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in columnRows)
                                {
                                    <tr>
                                        <td><span class="citus-inline-code">@row.Code</span></td>
                                        <td>@row.Name</td>
                                        @foreach (var value in row.Values)
                                        {
                                            <td class="text-right">@ReportFormat.Amount(value)</td>
                                        }
                                        <td class="text-right">@ReportFormat.Amount(row.Total)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }
                else
                {
                    // Single amount, or current vs comparison + change.
                    var mergedRows = MergeRows(sec.RowsOf(_incomeStatement), _comparison is null ? null : sec.RowsOf(_comparison));
                    if (mergedRows.Count == 0)
                    {
                        <p class="text-fg-muted text-sm">No accounts in this section for the selected range.</p>
                    }
                    else
                    {
                        <table class="citus-data-table citus-data-table--compact">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Account</th>
                                    <th class="text-right">Amount</th>
                                    @if (_comparison is not null)
                                    {
                                        <th class="text-right">@_compare</th>
                                        <th class="text-right">Change</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in mergedRows)
                                {
                                    <tr>
                                        <td><span class="citus-inline-code">@row.Code</span></td>
                                        <td>@row.Name</td>
                                        <td class="text-right">@ReportFormat.Amount(row.Current)</td>
                                        @if (_comparison is not null)
                                        {
                                            <td class="text-right">@ReportFormat.Amount(row.Comparison)</td>
                                            <td class="text-right">@ReportFormat.Amount(row.Current - row.Comparison)</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }
            </article>
        }
    }
}
    </Body>
</ReportShell>

@code {
    private const string NoColumns = "No columns";

    private IncomeStatementReportSummary? _incomeStatement;
    private IncomeStatementReportSummary? _comparison;
    private string _comparisonRangeLabel = string.Empty;
    private readonly List<(DateOnly From, DateOnly To, string Label)> _periods = new();
    private readonly List<IncomeStatementReportSummary?> _periodReports = new();
    private bool _isLoading;
    private bool _isExporting;
    private bool _includeZeroRows;
    private string _basis = "Accrual";
    private readonly string[] _basisOptions = { "Accrual", "Cash" };
    private string _compare = "No comparison";
    private readonly string[] _compareOptions = { "No comparison", "Previous year", "Previous period" };
    private string _columnsBy = NoColumns;
    private readonly string[] _columnsOptions = { NoColumns, "By month", "By quarter" };
    private string? _error;
    private DateTime? _dateFrom = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? _dateTo = DateTime.Today;

    private sealed record SectionDef(
        string Title,
        StatTone Tone,
        Func<IncomeStatementReportSummary, IReadOnlyList<IncomeStatementAccountSummary>> RowsOf,
        Func<IncomeStatementReportSummary, decimal> TotalOf);

    private static readonly SectionDef[] Sections =
    {
        new("Revenue", StatTone.Success, static r => r.RevenueRows, static r => r.TotalRevenue),
        new("Cost Of Sales", StatTone.Warning, static r => r.CostOfSalesRows, static r => r.TotalCostOfSales),
        new("Expenses", StatTone.Info, static r => r.ExpenseRows, static r => r.TotalExpenses),
    };

    private sealed record MergedRow(string Code, string Name, decimal Current, decimal Comparison);

    private sealed record ColumnRow(string Code, string Name, decimal[] Values, decimal Total);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;

        var dateFrom = DateOnly.FromDateTime((_dateFrom ?? new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1)).Date);
        var dateTo = DateOnly.FromDateTime((_dateTo ?? DateTime.Today).Date);

        if (dateFrom > dateTo)
        {
            ClearResults();
            _error = "Profit and Loss date range is invalid. The start date must be on or before the end date.";
            _isLoading = false;
            return;
        }

        var basis = _basis.ToLowerInvariant();

        var report = await IncomeStatementClient.GetReportAsync(
            ShellState.ActiveCompany.Id, dateFrom, dateTo, _includeZeroRows, basis);

        if (report is null)
        {
            ClearResults();
            _error = "Profit and Loss is unavailable until the active company is provisioned in the accounting core and date-range report data exists.";
            _isLoading = false;
            return;
        }

        _incomeStatement = report;
        _comparison = null;
        _comparisonRangeLabel = string.Empty;
        _periods.Clear();
        _periodReports.Clear();

        if (_columnsBy != NoColumns)
        {
            _periods.AddRange(SplitPeriods(dateFrom, dateTo, _columnsBy));
            var tasks = _periods
                .Select(period => IncomeStatementClient.GetReportAsync(
                    ShellState.ActiveCompany.Id, period.From, period.To, _includeZeroRows, basis))
                .ToArray();
            _periodReports.AddRange(await Task.WhenAll(tasks));
        }
        else
        {
            var comparisonRange = ComparisonRange(dateFrom, dateTo);
            if (comparisonRange is { } range)
            {
                _comparison = await IncomeStatementClient.GetReportAsync(
                    ShellState.ActiveCompany.Id, range.From, range.To, _includeZeroRows, basis);
                _comparisonRangeLabel = $"{range.From:yyyy-MM-dd} to {range.To:yyyy-MM-dd}";
            }
        }

        _isLoading = false;
    }

    private void ClearResults()
    {
        _incomeStatement = null;
        _comparison = null;
        _periods.Clear();
        _periodReports.Clear();
    }

    private async Task ExportAsync()
    {
        _isExporting = true;
        _error = null;

        var dateFrom = DateOnly.FromDateTime((_dateFrom ?? new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1)).Date);
        var dateTo = DateOnly.FromDateTime((_dateTo ?? DateTime.Today).Date);

        if (dateFrom > dateTo)
        {
            _error = "Profit and Loss date range is invalid. The start date must be on or before the end date.";
            _isExporting = false;
            return;
        }

        var file = await IncomeStatementClient.ExportCsvAsync(
            ShellState.ActiveCompany.Id, dateFrom, dateTo, _includeZeroRows, _basis.ToLowerInvariant());

        await ReportFormat.SaveCsvAsync(
            JSRuntime,
            file,
            "Profit and Loss CSV is unavailable until the active company is provisioned in the accounting core and date-range report data exists.",
            message => _error = message);

        _isExporting = false;
    }

    private (DateOnly From, DateOnly To)? ComparisonRange(DateOnly from, DateOnly to) => _compare switch
    {
        "Previous year" => (from.AddYears(-1), to.AddYears(-1)),
        "Previous period" => PreviousPeriod(from, to),
        _ => null
    };

    private static (DateOnly From, DateOnly To) PreviousPeriod(DateOnly from, DateOnly to)
    {
        var spanDays = to.DayNumber - from.DayNumber;
        var prevTo = from.AddDays(-1);
        return (prevTo.AddDays(-spanDays), prevTo);
    }

    private static List<(DateOnly From, DateOnly To, string Label)> SplitPeriods(DateOnly from, DateOnly to, string mode)
    {
        var periods = new List<(DateOnly From, DateOnly To, string Label)>();
        var byQuarter = mode == "By quarter";

        var startMonth = byQuarter ? (((from.Month - 1) / 3) * 3) + 1 : from.Month;
        var cursor = new DateOnly(from.Year, startMonth, 1);

        while (cursor <= to && periods.Count < 60)
        {
            var bucketEnd = (byQuarter ? cursor.AddMonths(3) : cursor.AddMonths(1)).AddDays(-1);
            var segmentFrom = cursor < from ? from : cursor;
            var segmentTo = bucketEnd > to ? to : bucketEnd;
            var label = byQuarter ? $"Q{((cursor.Month - 1) / 3) + 1} {cursor.Year}" : cursor.ToString("yyyy-MM");
            periods.Add((segmentFrom, segmentTo, label));
            cursor = byQuarter ? cursor.AddMonths(3) : cursor.AddMonths(1);
        }

        return periods;
    }

    private static IReadOnlyList<MergedRow> MergeRows(
        IReadOnlyList<IncomeStatementAccountSummary> current,
        IReadOnlyList<IncomeStatementAccountSummary>? comparison)
    {
        var map = new Dictionary<string, MergedRow>(StringComparer.OrdinalIgnoreCase);

        foreach (var row in current)
        {
            map[row.Code] = new MergedRow(row.Code, row.Name, row.DisplayAmount, 0m);
        }

        if (comparison is not null)
        {
            foreach (var row in comparison)
            {
                map[row.Code] = map.TryGetValue(row.Code, out var existing)
                    ? existing with { Comparison = row.DisplayAmount }
                    : new MergedRow(row.Code, row.Name, 0m, row.DisplayAmount);
            }
        }

        return map.Values.OrderBy(static r => r.Code, StringComparer.OrdinalIgnoreCase).ToList();
    }

    private IReadOnlyList<ColumnRow> BuildColumnRows(
        Func<IncomeStatementReportSummary, IReadOnlyList<IncomeStatementAccountSummary>> selector)
    {
        var count = _periodReports.Count;
        var map = new Dictionary<string, (string Name, decimal[] Values)>(StringComparer.OrdinalIgnoreCase);

        for (var i = 0; i < count; i++)
        {
            var periodReport = _periodReports[i];
            if (periodReport is null)
            {
                continue;
            }

            foreach (var row in selector(periodReport))
            {
                if (!map.TryGetValue(row.Code, out var entry))
                {
                    entry = (row.Name, new decimal[count]);
                    map[row.Code] = entry;
                }

                entry.Values[i] = row.DisplayAmount;
            }
        }

        return map
            .Select(kvp => new ColumnRow(kvp.Key, kvp.Value.Name, kvp.Value.Values, kvp.Value.Values.Sum()))
            .OrderBy(static r => r.Code, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static string TagColor(StatTone tone) => tone switch
    {
        StatTone.Success => "green",
        StatTone.Warning => "orange",
        StatTone.Danger => "red",
        StatTone.Info => "blue",
        StatTone.Primary => "geekblue",
        _ => "default"
    };
}
