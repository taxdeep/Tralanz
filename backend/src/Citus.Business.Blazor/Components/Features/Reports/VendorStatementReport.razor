@using Radzen
@using Radzen.Blazor
@using Citus.Ui.Shared.Reports
@using Citus.Modules.UnitySearch.Blazor
@using Citus.Modules.UnitySearch.Domain.Shared

@inject BusinessShellState ShellState
@inject ApAgingClient ApAgingClient
@inject AccountingDocumentReviewClient ReviewClient
@inject Microsoft.JSInterop.IJSRuntime JS

@* Vendor open-item statement. Stage 1: reuses the proven A/P aging report,
   filtered to the picked vendor (zero new backend / balance math). Stage 2
   swaps in a dedicated party-scoped query carrying the vendor's address +
   email for the PDF / email statement. *@

<StatementReport PartyLabel="Vendor"
                 HasParty="@_partyId.HasValue"
                 PartyName="@_partyName"
                 BaseCurrencyCode="@_baseCurrency"
                 AsOfDate="@_asOfDate"
                 Party="@_party"
                 Items="@_items"
                 IsLoading="_isLoading"
                 Error="@_error">
    <Controls>
        <div style="min-width: 18rem">
            <VendorPicker CompanyId="@ShellState.ActiveCompany.Id"
                          SelectedId="@_partyId"
                          SelectedDisplayText="@_partyName"
                          OnVendorSelected="OnPartySelectedAsync"
                          OnCleared="OnPartyCleared" />
        </div>
        <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_asOfDate" Placeholder="@("As of date")" />
        <CitusButton Variant="CitusButtonVariant.Primary" Disabled="@(_isLoading || !_partyId.HasValue)" OnClick="LoadAsync">
            Run statement
        </CitusButton>
        <CitusButton LeadingIcon="IconName.Download" Disabled="@(_isDownloadingPdf || !_partyId.HasValue)" OnClick="DownloadPdfAsync">
            @(_isDownloadingPdf ? "Generating…" : "Download PDF")
        </CitusButton>
    </Controls>
</StatementReport>

@code {
    private Guid? _partyId;
    private string _partyName = string.Empty;
    private string _baseCurrency = string.Empty;
    private DateTime? _asOfDate = DateTime.Today;
    private bool _isLoading;
    private bool _isDownloadingPdf;
    private string? _error;
    private AgingPartyRow? _party;
    private IReadOnlyList<AgingOpenItemRow>? _items;

    private DateOnly AsOf() => DateOnly.FromDateTime((_asOfDate ?? DateTime.Today).Date);

    private async Task DownloadPdfAsync()
    {
        if (!_partyId.HasValue || _isDownloadingPdf)
        {
            return;
        }

        _isDownloadingPdf = true;
        _error = null;
        try
        {
            var download = await ReviewClient.GetVendorStatementPdfAsync(ShellState.ActiveCompany.Id, _partyId.Value, AsOf());
            if (download is null)
            {
                _error = "The statement PDF could not be generated. Please try again.";
                return;
            }

            var base64 = Convert.ToBase64String(download.Bytes);
            await JS.InvokeVoidAsync("citusDownloads.saveBinaryFile", download.FileName, base64, "application/pdf");
        }
        finally
        {
            _isDownloadingPdf = false;
        }
    }

    private async Task OnPartySelectedAsync(UnitySearchPickerOption option)
    {
        _partyId = option.SourceId;
        _partyName = option.PrimaryText;
        await LoadAsync();
    }

    private void OnPartyCleared()
    {
        _partyId = null;
        _partyName = string.Empty;
        _party = null;
        _items = null;
        _error = null;
    }

    private async Task LoadAsync()
    {
        if (!_partyId.HasValue)
        {
            _error = "Pick a vendor to run the statement.";
            return;
        }

        _isLoading = true;
        _error = null;

        var report = await ApAgingClient.GetReportAsync(ShellState.ActiveCompany.Id, AsOf());

        if (report is null)
        {
            _party = null;
            _items = null;
            _error = "Vendor statement is unavailable until the active company is provisioned in the accounting core and payable open-item data exists.";
        }
        else
        {
            _baseCurrency = report.BaseCurrencyCode;
            _items = report.DetailRows
                .Where(d => d.VendorId == _partyId.Value)
                .Select(AgingReportView.OpenItemFromAp)
                .ToList();
            _party = report.VendorRows
                .Where(v => v.VendorId == _partyId.Value)
                .Select(AgingReportView.PartyRowFromAp)
                .FirstOrDefault();
        }

        _isLoading = false;
    }
}
