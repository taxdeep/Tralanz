@using Citus.Ui.Shared.Reports

@inject BusinessShellState ShellState
@inject ApAgingClient ApAgingClient
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

@if (Detail)
{
    <AgingDetailReport View="_view"
                       IsLoading="_isLoading"
                       IsExporting="_isExporting"
                       Error="_error"
                       RunLabel="Run A/P Aging Detail"
                       PartyLabel="Vendor"
                       EmptyMessage="@_emptyMessage"
                       @bind-AsOfDate="_asOfDate"
                       OnRun="LoadAsync"
                       OnExport="ExportAsync" />
}
else
{
    <AgingReport View="_view"
                 IsLoading="_isLoading"
                 IsExporting="_isExporting"
                 Error="_error"
                 RunLabel="Run A/P Aging"
                 PartyLabel="Vendor"
                 PartyCountLabel="Vendors"
                 ChartTitle="Open AP"
                 EmptyMessage="@_emptyMessage"
                 @bind-AsOfDate="_asOfDate"
                 OnRun="LoadAsync"
                 OnExport="ExportAsync" />
}

@code {
    [Parameter] public bool Detail { get; set; }

    private AgingReportView? _view;
    private bool _isLoading;
    private bool _isExporting;
    private string? _error;
    private DateTime? _asOfDate = DateTime.Today;
    private string _emptyMessage = "No open payable items were found for this company.";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private DateOnly AsOf() => DateOnly.FromDateTime((_asOfDate ?? DateTime.Today).Date);

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;

        var report = await ApAgingClient.GetReportAsync(ShellState.ActiveCompany.Id, AsOf());

        if (report is null)
        {
            _view = null;
            _error = "A/P Aging is unavailable until the active company is provisioned in the accounting core and payable open-item data exists.";
        }
        else
        {
            _view = AgingReportView.FromAp(report);
            _emptyMessage = $"No open payable items were found for this company as of {report.AsOfDate:yyyy-MM-dd}.";
        }

        _isLoading = false;
    }

    private async Task ExportAsync()
    {
        _isExporting = true;
        _error = null;

        var file = await ApAgingClient.ExportCsvAsync(ShellState.ActiveCompany.Id, AsOf());

        await ReportFormat.SaveCsvAsync(
            JSRuntime,
            file,
            "A/P Aging CSV is unavailable until the active company is provisioned in the accounting core and payable open-item data exists.",
            message => _error = message);

        _isExporting = false;
    }
}
