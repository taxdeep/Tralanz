@using Radzen
@using Radzen.Blazor
@using Citus.Ui.Shared.Reports
@using Citus.Modules.UnitySearch.Blazor
@using Citus.Modules.UnitySearch.Domain.Shared

@inject BusinessShellState ShellState
@inject ArAgingClient ArAgingClient
@inject AccountingDocumentReviewClient ReviewClient
@inject Microsoft.JSInterop.IJSRuntime JS

@* Customer open-item statement. Stage 1: reuses the proven A/R aging report,
   filtered to the picked customer (zero new backend / balance math). Stage 2
   swaps in a dedicated party-scoped query carrying the customer's address +
   email for the PDF / email statement. *@

<StatementReport PartyLabel="Customer"
                 HasParty="@_partyId.HasValue"
                 PartyName="@_partyName"
                 BaseCurrencyCode="@_baseCurrency"
                 AsOfDate="@_asOfDate"
                 Party="@_party"
                 Items="@_items"
                 IsLoading="_isLoading"
                 MoneyDecimals="ShellState.MoneyDecimals"
                 Error="@_error">
    <Controls>
        <div style="min-width: 18rem">
            <CustomerPicker CompanyId="@ShellState.ActiveCompany.Id"
                            SelectedId="@_partyId"
                            SelectedDisplayText="@_partyName"
                            OnCustomerSelected="OnPartySelectedAsync"
                            OnCleared="OnPartyCleared" />
        </div>
        <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_asOfDate" Placeholder="@("As of date")" />
        <CitusButton Variant="CitusButtonVariant.Primary" Disabled="@(_isLoading || !_partyId.HasValue)" OnClick="LoadAsync">
            Run statement
        </CitusButton>
        <CitusButton LeadingIcon="IconName.Download" Disabled="@(_isDownloadingPdf || !_partyId.HasValue)" OnClick="DownloadPdfAsync">
            @(_isDownloadingPdf ? "Generating…" : "Download PDF")
        </CitusButton>
        <CitusButton Disabled="@(!_partyId.HasValue)" OnClick="@(() => _showSend = !_showSend)">
            Send statement
        </CitusButton>
    </Controls>
</StatementReport>

@if (_sentTo is not null && !_showSend)
{
    <CitusAlert Severity="CitusAlertSeverity.Success" Message="@($"Statement emailed to {_sentTo}.")" ShowIcon="true" Class="mt-4" />
}

@if (_showSend && _partyId.HasValue)
{
    <div class="mt-4">
        <StatementSendForm ToPlaceholder="Defaults to the customer's email on file"
                           IsSending="_isSending"
                           Error="@_sendError"
                           OnSend="DoSendAsync"
                           OnCancel="@(() => _showSend = false)" />
    </div>
}

@code {
    private Guid? _partyId;
    private string _partyName = string.Empty;
    private string _baseCurrency = string.Empty;
    private DateTime? _asOfDate = DateTime.Today;
    private bool _isLoading;
    private bool _isDownloadingPdf;
    private bool _showSend;
    private bool _isSending;
    private string? _sendError;
    private string? _sentTo;
    private string? _error;
    private AgingPartyRow? _party;
    private IReadOnlyList<AgingOpenItemRow>? _items;

    private async Task DoSendAsync(StatementSendRequest request)
    {
        if (!_partyId.HasValue || _isSending)
        {
            return;
        }

        _isSending = true;
        _sendError = null;
        try
        {
            var outcome = await ReviewClient.SendCustomerStatementAsync(ShellState.ActiveCompany.Id, _partyId.Value, AsOf(), request);
            if (!outcome.Succeeded)
            {
                _sendError = outcome.ErrorMessage ?? "Email delivery failed.";
                return;
            }

            _sentTo = outcome.ToEmail;
            _showSend = false;
        }
        finally
        {
            _isSending = false;
        }
    }

    private DateOnly AsOf() => DateOnly.FromDateTime((_asOfDate ?? DateTime.Today).Date);

    private async Task DownloadPdfAsync()
    {
        if (!_partyId.HasValue || _isDownloadingPdf)
        {
            return;
        }

        _isDownloadingPdf = true;
        _error = null;
        try
        {
            var download = await ReviewClient.GetCustomerStatementPdfAsync(ShellState.ActiveCompany.Id, _partyId.Value, AsOf());
            if (download is null)
            {
                _error = "The statement PDF could not be generated. Please try again.";
                return;
            }

            var base64 = Convert.ToBase64String(download.Bytes);
            await JS.InvokeVoidAsync("citusDownloads.saveBinaryFile", download.FileName, base64, "application/pdf");
        }
        finally
        {
            _isDownloadingPdf = false;
        }
    }

    private async Task OnPartySelectedAsync(UnitySearchPickerOption option)
    {
        _partyId = option.SourceId;
        _partyName = option.PrimaryText;
        await LoadAsync();
    }

    private void OnPartyCleared()
    {
        _partyId = null;
        _partyName = string.Empty;
        _party = null;
        _items = null;
        _error = null;
    }

    private async Task LoadAsync()
    {
        if (!_partyId.HasValue)
        {
            _error = "Pick a customer to run the statement.";
            return;
        }

        _isLoading = true;
        _error = null;

        var report = await ArAgingClient.GetReportAsync(ShellState.ActiveCompany.Id, AsOf());

        if (report is null)
        {
            _party = null;
            _items = null;
            _error = "Customer statement is unavailable until the active company is provisioned in the accounting core and receivable open-item data exists.";
        }
        else
        {
            _baseCurrency = report.BaseCurrencyCode;
            _items = report.DetailRows
                .Where(d => d.CustomerId == _partyId.Value)
                .Select(AgingReportView.OpenItemFromAr)
                .ToList();
            _party = report.CustomerRows
                .Where(c => c.CustomerId == _partyId.Value)
                .Select(AgingReportView.PartyRowFromAr)
                .FirstOrDefault();
        }

        _isLoading = false;
    }
}
