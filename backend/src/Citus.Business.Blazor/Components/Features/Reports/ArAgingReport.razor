@using Citus.Ui.Shared.Reports

@inject BusinessShellState ShellState
@inject ArAgingClient ArAgingClient
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

@if (Detail)
{
    <AgingDetailReport View="_view"
                       IsLoading="_isLoading"
                       MoneyDecimals="ShellState.MoneyDecimals"
                       IsExporting="_isExporting"
                       Error="@_error"
                       RunLabel="Run A/R Aging Detail"
                       PartyLabel="Customer"
                       EmptyMessage="@_emptyMessage"
                       @bind-AsOfDate="_asOfDate"
                       OnRun="LoadAsync"
                       OnExport="ExportAsync" />
}
else
{
    <AgingReport View="_view"
                 IsLoading="_isLoading"
                 MoneyDecimals="ShellState.MoneyDecimals"
                 IsExporting="_isExporting"
                 Error="@_error"
                 RunLabel="Run A/R Aging"
                 PartyLabel="Customer"
                 PartyCountLabel="Customers"
                 ChartTitle="Open AR"
                 EmptyMessage="@_emptyMessage"
                 @bind-AsOfDate="_asOfDate"
                 OnRun="LoadAsync"
                 OnExport="ExportAsync" />
}

@code {
    [Parameter] public bool Detail { get; set; }

    private AgingReportView? _view;
    private bool _isLoading;
    private bool _isExporting;
    private string? _error;
    private DateTime? _asOfDate = DateTime.Today;
    private string _emptyMessage = "No open receivable items were found for this company.";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private DateOnly AsOf() => DateOnly.FromDateTime((_asOfDate ?? DateTime.Today).Date);

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;

        var report = await ArAgingClient.GetReportAsync(ShellState.ActiveCompany.Id, AsOf());

        if (report is null)
        {
            _view = null;
            _error = "A/R Aging is unavailable until the active company is provisioned in the accounting core and receivable open-item data exists.";
        }
        else
        {
            _view = AgingReportView.FromAr(report);
            _emptyMessage = $"No open receivable items were found for this company as of {report.AsOfDate:yyyy-MM-dd}.";
        }

        _isLoading = false;
    }

    private async Task ExportAsync()
    {
        _isExporting = true;
        _error = null;

        var file = await ArAgingClient.ExportCsvAsync(ShellState.ActiveCompany.Id, AsOf());

        await ReportFormat.SaveCsvAsync(
            JSRuntime,
            file,
            "A/R Aging CSV is unavailable until the active company is provisioned in the accounting core and receivable open-item data exists.",
            message => _error = message);

        _isExporting = false;
    }
}
