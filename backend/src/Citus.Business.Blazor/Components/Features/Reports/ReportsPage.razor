@page "/reports"

@using Citus.Ui.Shared.Reports
@using Radzen
@using Radzen.Blazor

@inject BusinessShellState ShellState
@inject AccountingHealthClient AccountingHealthClient
@inject TrialBalanceClient TrialBalanceClient
@inject IncomeStatementClient IncomeStatementClient
@inject BalanceSheetClient BalanceSheetClient
@inject ArAgingClient ArAgingClient
@inject ApAgingClient ApAgingClient
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

<PageTitle>Reports | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header" />

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <CitusStatCard
        Label="Report home"
        Value="Five reports + CSV"
        Description="Reports remain the safest early business surface to migrate into Blazor, with backend-owned CSV export and read-only source drill-down."
        Icon="IconName.ReportAnalytics"
        Tone="StatTone.Primary" />
    <CitusStatCard
        Label="Company"
        Value="@ShellState.ActiveCompany.CompanyName"
        Description="@ShellState.ActiveCompany.CompanyCode"
        Icon="IconName.BuildingSkyscraper"
        Tone="StatTone.Info" />
    <CitusStatCard
        Label="Base currency"
        Value="@ShellState.ActiveCompany.BaseCurrencyCode"
        Description="Report totals remain grounded in company base-currency truth."
        Icon="IconName.Coin"
        Tone="StatTone.Success" />
    <CitusStatCard
        Label="Accounting API"
        Value="@(_health?.Status ?? "Unavailable")"
        Description="Trial Balance, Income Statement, Balance Sheet, A/R Aging, and A/P Aging now support both live HTML reads and CSV export from backend report endpoints."
        Icon="IconName.Activity"
        Tone="StatTone.Neutral" />
</div>

@* ------------------------- Trial Balance ------------------------- *@
<section class="citus-panel mb-6">
    <header class="citus-panel__header">
        <h2 class="citus-panel__title">Trial Balance</h2>
        <CitusBadge Color="@("green")">Backend-owned report</CitusBadge>
    </header>

    <div class="flex flex-wrap items-center gap-3 mb-4">
        <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_asOfDate" Placeholder="@("As of date")" />
        <label class="inline-flex items-center gap-2 text-sm">
            <RadzenCheckBox @bind-Value="_includeZeroBalances" /> Include zero-balance accounts
        </label>
        <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_isTrialBalanceLoading" OnClick="LoadTrialBalanceAsync">
            Run Trial Balance
        </CitusButton>
        <CitusButton LeadingIcon="IconName.Download" Disabled="@(_isTrialBalanceLoading || _isTrialBalanceExporting)" OnClick="ExportTrialBalanceAsync">
            Export CSV
        </CitusButton>
    </div>

    @if (_isTrialBalanceLoading)
    {
        <div class="mb-4"><CitusLoadingBar /></div>
    }

    @if (!string.IsNullOrWhiteSpace(_trialBalanceError))
    {
        <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_trialBalanceError" ShowIcon="true" Class="mb-4" />
    }

    @if (_trialBalance is not null)
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
            <CitusStatCard Label="As of" Value="@_trialBalance.AsOfDate.ToString("yyyy-MM-dd")" Description="Trial Balance stays pinned to one backend-owned cut-off date." Icon="IconName.Calendar" Tone="StatTone.Info" />
            <CitusStatCard Label="Accounts" Value="@_trialBalance.AccountCount.ToString()" Description="Only active-company accounts participate in this report." Icon="IconName.BuildingBank" Tone="StatTone.Primary" />
            <CitusStatCard Label="Debit total" Value="@FormatAmount(_trialBalance.TotalBalanceDebit)" Description="@($"Base currency {_trialBalance.BaseCurrencyCode}")" Icon="IconName.Cash" Tone="StatTone.Success" />
            <CitusStatCard Label="Balance check" Value="@(_trialBalance.IsBalanced ? "Balanced" : "Out of balance")" Description="@($"Credit total {FormatAmount(_trialBalance.TotalBalanceCredit)} {_trialBalance.BaseCurrencyCode}")" Icon="IconName.CircleCheck" Tone="@(_trialBalance.IsBalanced ? StatTone.Success : StatTone.Danger)" />
        </div>

        @if (_trialBalance.Rows.Count == 0)
        {
            <CitusAlert Severity="CitusAlertSeverity.Info" Message="@($"No ledger-backed account balances were found for this company as of {_trialBalance.AsOfDate:yyyy-MM-dd}.")" ShowIcon="true" />
        }
        else
        {
            @* SPIKE: Radzen DataGrid replaces the plain HTML table for the
               Trial Balance. Goal — evaluate sort / filter / paging /
               column resize / virtualization quality on a real report
               that ships in Citus, before deciding whether to broaden
               Radzen's footprint. The rest of the page (P&L, Balance
               Sheet, etc.) stays on the Citus table surface for an
               apples-to-apples visual diff. *@
            <RadzenDataGrid TItem="TrialBalanceAccountSummary"
                            Data="@_trialBalance.Rows"
                            AllowSorting="true"
                            AllowFiltering="true"
                            AllowColumnResize="true"
                            AllowPaging="true"
                            PageSize="50"
                            FilterMode="FilterMode.Simple"
                            class="citus-radzen-grid">
                <Columns>
                    <RadzenDataGridColumn TItem="TrialBalanceAccountSummary"
                                          Property="@nameof(TrialBalanceAccountSummary.Code)"
                                          Title="Code"
                                          Width="110px">
                        <Template Context="row">
                            <span class="citus-inline-code">@row.Code</span>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TrialBalanceAccountSummary"
                                          Property="@nameof(TrialBalanceAccountSummary.Name)"
                                          Title="Account">
                        <Template Context="row">
                            <div>@row.Name</div>
                            @if (!string.IsNullOrWhiteSpace(row.DetailType))
                            {
                                <div class="text-fg-subtle text-xs">@row.DetailType</div>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TrialBalanceAccountSummary"
                                          Property="@nameof(TrialBalanceAccountSummary.RootType)"
                                          Title="Root type"
                                          Width="140px" />
                    <RadzenDataGridColumn TItem="TrialBalanceAccountSummary"
                                          Title="Status"
                                          Width="120px"
                                          Sortable="false"
                                          Filterable="false">
                        <Template Context="row">
                            @(row.IsActive ? "Active" : "Inactive")
                            @if (row.IsSystem)
                            {
                                <span class="text-fg-subtle text-xs"> · System</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TrialBalanceAccountSummary"
                                          Property="@nameof(TrialBalanceAccountSummary.BalanceDebit)"
                                          Title="Debit balance"
                                          TextAlign="TextAlign.Right"
                                          Width="160px">
                        <Template Context="row">@FormatAmount(row.BalanceDebit)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TrialBalanceAccountSummary"
                                          Property="@nameof(TrialBalanceAccountSummary.BalanceCredit)"
                                          Title="Credit balance"
                                          TextAlign="TextAlign.Right"
                                          Width="160px">
                        <Template Context="row">@FormatAmount(row.BalanceCredit)</Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }
    }
</section>

@* ------------------------- Income Statement ------------------------- *@
<section class="citus-panel mb-6">
    <header class="citus-panel__header">
        <h2 class="citus-panel__title">Income Statement</h2>
        <CitusBadge Color="@("blue")">Date-range report</CitusBadge>
    </header>

    <div class="flex flex-wrap items-center gap-3 mb-4">
        <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_incomeStatementDateFrom" Placeholder="@("From")" />
        <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_incomeStatementDateTo" Placeholder="@("To")" />
        <label class="inline-flex items-center gap-2 text-sm">
            <RadzenCheckBox @bind-Value="_includeZeroIncomeStatementRows" /> Include zero-balance accounts
        </label>
        <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_isIncomeStatementLoading" OnClick="LoadIncomeStatementAsync">
            Run Income Statement
        </CitusButton>
        <CitusButton LeadingIcon="IconName.Download" Disabled="@(_isIncomeStatementLoading || _isIncomeStatementExporting)" OnClick="ExportIncomeStatementAsync">
            Export CSV
        </CitusButton>
    </div>

    @if (_isIncomeStatementLoading)
    {
        <div class="mb-4"><CitusLoadingBar /></div>
    }

    @if (!string.IsNullOrWhiteSpace(_incomeStatementError))
    {
        <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_incomeStatementError" ShowIcon="true" Class="mb-4" />
    }

    @if (_incomeStatement is not null)
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
            <CitusStatCard Label="Revenue" Value="@FormatAmount(_incomeStatement.TotalRevenue)" Description="@($"Range {_incomeStatement.DateFrom:yyyy-MM-dd} to {_incomeStatement.DateTo:yyyy-MM-dd}")" Icon="IconName.ReportAnalytics" Tone="StatTone.Success" />
            <CitusStatCard Label="Gross profit" Value="@FormatAmount(_incomeStatement.GrossProfit)" Description="@($"After cost of sales in {_incomeStatement.BaseCurrencyCode}")" Icon="IconName.ReportAnalytics" Tone="StatTone.Info" />
            <CitusStatCard Label="Expenses" Value="@FormatAmount(_incomeStatement.TotalExpenses)" Description="Operating expense accounts in the selected range." Icon="IconName.Wallet" Tone="StatTone.Warning" />
            <CitusStatCard Label="Net income" Value="@FormatAmount(_incomeStatement.NetIncome)" Description="@($"Company base currency {_incomeStatement.BaseCurrencyCode}")" Icon="IconName.BuildingBank" Tone="@(_incomeStatement.NetIncome >= 0m ? StatTone.Success : StatTone.Danger)" />
        </div>

        @if (_incomeStatement.AccountCount == 0)
        {
            <CitusAlert Severity="CitusAlertSeverity.Info" Message="@($"No income-statement activity was found for this company between {_incomeStatement.DateFrom:yyyy-MM-dd} and {_incomeStatement.DateTo:yyyy-MM-dd}.")" ShowIcon="true" />
        }
        else
        {
            @foreach (var reportSection in GetIncomeSections())
            {
                <article class="citus-subpanel">
                    <header class="citus-subpanel__header">
                        <h3 class="citus-subpanel__title">@reportSection.Title</h3>
                        <CitusBadge Color="@TagColor(reportSection.Tone)">@FormatAmount(reportSection.Total)</CitusBadge>
                    </header>

                    @if (reportSection.Rows.Count == 0)
                    {
                        <p class="text-fg-muted text-sm">No accounts in this section for the selected range.</p>
                    }
                    else
                    {
                        <table class="citus-data-table">
                            <thead>
                                <tr><th>Code</th><th>Account</th><th class="text-right">Amount</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var row in reportSection.Rows)
                                {
                                    <tr>
                                        <td><span class="citus-inline-code">@row.Code</span></td>
                                        <td>
                                            <div>@row.Name</div>
                                            <div class="text-fg-subtle text-xs">@row.DetailType</div>
                                        </td>
                                        <td class="text-right">@FormatAmount(row.DisplayAmount)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </article>
            }
        }
    }
</section>

@* ------------------------- Balance Sheet ------------------------- *@
<section class="citus-panel mb-6">
    <header class="citus-panel__header">
        <h2 class="citus-panel__title">Balance Sheet</h2>
        <CitusBadge Color="@("default")">As-of report</CitusBadge>
    </header>

    <div class="flex flex-wrap items-center gap-3 mb-4">
        <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_balanceSheetAsOfDate" Placeholder="@("As of date")" />
        <label class="inline-flex items-center gap-2 text-sm">
            <RadzenCheckBox @bind-Value="_includeZeroBalanceSheetRows" /> Include zero-balance accounts
        </label>
        <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_isBalanceSheetLoading" OnClick="LoadBalanceSheetAsync">
            Run Balance Sheet
        </CitusButton>
        <CitusButton LeadingIcon="IconName.Download" Disabled="@(_isBalanceSheetLoading || _isBalanceSheetExporting)" OnClick="ExportBalanceSheetAsync">
            Export CSV
        </CitusButton>
    </div>

    @if (_isBalanceSheetLoading)
    {
        <div class="mb-4"><CitusLoadingBar /></div>
    }

    @if (!string.IsNullOrWhiteSpace(_balanceSheetError))
    {
        <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_balanceSheetError" ShowIcon="true" Class="mb-4" />
    }

    @if (_balanceSheet is not null)
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
            <CitusStatCard Label="Assets" Value="@FormatAmount(_balanceSheet.TotalAssets)" Description="@($"As of {_balanceSheet.AsOfDate:yyyy-MM-dd}")" Icon="IconName.BuildingBank" Tone="StatTone.Info" />
            <CitusStatCard Label="Liabilities" Value="@FormatAmount(_balanceSheet.TotalLiabilities)" Description="@($"Base currency {_balanceSheet.BaseCurrencyCode}")" Icon="IconName.Receipt" Tone="StatTone.Warning" />
            <CitusStatCard Label="Equity" Value="@FormatAmount(_balanceSheet.TotalEquity)" Description="@($"Includes current earnings {FormatAmount(_balanceSheet.CurrentEarnings)}")" Icon="IconName.Report" Tone="StatTone.Success" />
            <CitusStatCard Label="Balance check" Value="@(_balanceSheet.IsBalanced ? "Balanced" : "Out of balance")" Description="@($"Liabilities + equity {FormatAmount(_balanceSheet.TotalLiabilitiesAndEquity)}")" Icon="IconName.CircleCheck" Tone="@(_balanceSheet.IsBalanced ? StatTone.Success : StatTone.Danger)" />
        </div>

        @if (_balanceSheet.AccountCount == 0)
        {
            <CitusAlert Severity="CitusAlertSeverity.Info" Message="@($"No balance-sheet accounts were found for this company as of {_balanceSheet.AsOfDate:yyyy-MM-dd}.")" ShowIcon="true" />
        }
        else
        {
            @foreach (var reportSection in GetBalanceSections())
            {
                <article class="citus-subpanel">
                    <header class="citus-subpanel__header">
                        <h3 class="citus-subpanel__title">@reportSection.Title</h3>
                        <CitusBadge Color="@TagColor(reportSection.Tone)">@FormatAmount(reportSection.Total)</CitusBadge>
                    </header>

                    @if (reportSection.Rows.Count == 0)
                    {
                        <p class="text-fg-muted text-sm">No accounts in this section for the selected date.</p>
                    }
                    else
                    {
                        <table class="citus-data-table">
                            <thead>
                                <tr><th>Code</th><th>Account</th><th class="text-right">Amount</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var row in reportSection.Rows)
                                {
                                    <tr>
                                        <td><span class="citus-inline-code">@row.Code</span></td>
                                        <td>
                                            <div>@row.Name</div>
                                            <div class="text-fg-subtle text-xs">@row.DetailType</div>
                                        </td>
                                        <td class="text-right">@FormatAmount(row.DisplayAmount)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </article>
            }
        }
    }
</section>

@* ------------------------- A/R Aging ------------------------- *@
<section class="citus-panel mb-6">
    <header class="citus-panel__header">
        <h2 class="citus-panel__title">A/R Aging</h2>
        <CitusBadge Color="@("orange")">Open-item report</CitusBadge>
    </header>

    <div class="flex flex-wrap items-center gap-3 mb-4">
        <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_arAgingAsOfDate" Placeholder="@("As of date")" />
        <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_isArAgingLoading" OnClick="LoadArAgingAsync">
            Run A/R Aging
        </CitusButton>
        <CitusButton LeadingIcon="IconName.Download" Disabled="@(_isArAgingLoading || _isArAgingExporting)" OnClick="ExportArAgingAsync">
            Export CSV
        </CitusButton>
    </div>

    @if (_isArAgingLoading)
    {
        <div class="mb-4"><CitusLoadingBar /></div>
    }

    @if (!string.IsNullOrWhiteSpace(_arAgingError))
    {
        <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_arAgingError" ShowIcon="true" Class="mb-4" />
    }

    @if (_arAging is not null)
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
            <CitusStatCard Label="Outstanding" Value="@FormatAmount(_arAging.TotalOutstandingAmountBase)" Description="@($"As of {_arAging.AsOfDate:yyyy-MM-dd} in {_arAging.BaseCurrencyCode}")" Icon="IconName.Receipt" Tone="StatTone.Info" />
            <CitusStatCard Label="Customers" Value="@_arAging.CustomerCount.ToString()" Description="@($"{_arAging.OpenItemCount} open items in scope")" Icon="IconName.Users" Tone="StatTone.Primary" />
            <CitusStatCard Label="Overdue" Value="@FormatAmount(_arAging.TotalOverdueAmountBase)" Description="Total receivable value already past due." Icon="IconName.AlertTriangle" Tone="@(_arAging.TotalOverdueAmountBase > 0m ? StatTone.Warning : StatTone.Success)" />
            <CitusStatCard Label="> 90 days" Value="@FormatAmount(_arAging.DaysOver90AmountBase)" Description="The oldest overdue bucket stays visible for control review." Icon="IconName.Clock" Tone="@(_arAging.DaysOver90AmountBase > 0m ? StatTone.Danger : StatTone.Success)" />
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3 mb-4">
            <CitusStatCard Label="Current" Value="@FormatAmount(_arAging.CurrentAmountBase)" Description="Not yet due" Icon="IconName.Calendar" Tone="StatTone.Success" />
            <CitusStatCard Label="1-30" Value="@FormatAmount(_arAging.Days1To30AmountBase)" Description="Past due" Icon="IconName.Receipt" Tone="StatTone.Warning" />
            <CitusStatCard Label="31-60" Value="@FormatAmount(_arAging.Days31To60AmountBase)" Description="Past due" Icon="IconName.Receipt" Tone="StatTone.Warning" />
            <CitusStatCard Label="61-90" Value="@FormatAmount(_arAging.Days61To90AmountBase)" Description="Past due" Icon="IconName.Receipt" Tone="StatTone.Warning" />
            <CitusStatCard Label="> 90" Value="@FormatAmount(_arAging.DaysOver90AmountBase)" Description="Past due" Icon="IconName.AlertTriangle" Tone="StatTone.Danger" />
            <CitusStatCard Label="Total" Value="@FormatAmount(_arAging.TotalOutstandingAmountBase)" Description="Net open receivables" Icon="IconName.ReportAnalytics" Tone="StatTone.Info" />
        </div>

        @if (_arAging.TotalOutstandingAmountBase > 0)
        {
            <div class="citus-radzen-chart mb-4" style="height: 240px">
                <RadzenChart>
                    <RadzenColumnSeries Data="@BuildArBuckets(_arAging)" CategoryProperty="Label" ValueProperty="Amount" Title="Open AR" />
                    <RadzenColumnOptions Radius="3" />
                    <RadzenCategoryAxis />
                    <RadzenValueAxis Formatter="@FormatChartAmount" />
                </RadzenChart>
            </div>
        }

        @if (_arAging.OpenItemCount == 0)
        {
            <CitusAlert Severity="CitusAlertSeverity.Info" Message="@($"No open receivable items were found for this company as of {_arAging.AsOfDate:yyyy-MM-dd}.")" ShowIcon="true" />
        }
        else
        {
            <article class="citus-subpanel">
                <h3 class="citus-subpanel__title">Customer summary</h3>
                <RadzenDataGrid TItem="ArAgingCustomerSummary"
                                Data="@_arAging.CustomerRows"
                                AllowSorting="true"
                                AllowFiltering="true"
                                AllowColumnResize="true"
                                AllowPaging="true"
                                PageSize="50"
                                FilterMode="FilterMode.Simple"
                                class="citus-radzen-grid">
                    <Columns>
                        <RadzenDataGridColumn TItem="ArAgingCustomerSummary"
                                              Property="@nameof(ArAgingCustomerSummary.CustomerDisplayName)"
                                              Title="Customer">
                            <Template Context="row">
                                <div>@row.CustomerDisplayName</div>
                                <div class="text-fg-subtle text-xs">
                                    <span class="citus-inline-code">@row.CustomerEntityNumber</span>
                                    @if (row.OldestDueDate is not null)
                                    {
                                        <span> · oldest due @row.OldestDueDate.Value.ToString("yyyy-MM-dd")</span>
                                    }
                                </div>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ArAgingCustomerSummary"
                                              Property="@nameof(ArAgingCustomerSummary.CustomerIsActive)"
                                              Title="Status" Width="100px">
                            <Template Context="row">@(row.CustomerIsActive ? "Active" : "Inactive")</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ArAgingCustomerSummary" Property="@nameof(ArAgingCustomerSummary.CurrentAmountBase)" Title="Current" TextAlign="TextAlign.Right" Width="120px">
                            <Template Context="row">@FormatAmount(row.CurrentAmountBase)</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ArAgingCustomerSummary" Property="@nameof(ArAgingCustomerSummary.Days1To30AmountBase)" Title="1-30" TextAlign="TextAlign.Right" Width="110px">
                            <Template Context="row">@FormatAmount(row.Days1To30AmountBase)</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ArAgingCustomerSummary" Property="@nameof(ArAgingCustomerSummary.Days31To60AmountBase)" Title="31-60" TextAlign="TextAlign.Right" Width="110px">
                            <Template Context="row">@FormatAmount(row.Days31To60AmountBase)</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ArAgingCustomerSummary" Property="@nameof(ArAgingCustomerSummary.Days61To90AmountBase)" Title="61-90" TextAlign="TextAlign.Right" Width="110px">
                            <Template Context="row">@FormatAmount(row.Days61To90AmountBase)</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ArAgingCustomerSummary" Property="@nameof(ArAgingCustomerSummary.DaysOver90AmountBase)" Title="> 90" TextAlign="TextAlign.Right" Width="110px">
                            <Template Context="row">@FormatAmount(row.DaysOver90AmountBase)</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ArAgingCustomerSummary" Property="@nameof(ArAgingCustomerSummary.TotalOutstandingAmountBase)" Title="Total" TextAlign="TextAlign.Right" Width="130px">
                            <Template Context="row"><strong>@FormatAmount(row.TotalOutstandingAmountBase)</strong></Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </article>

            <article class="citus-subpanel">
                <h3 class="citus-subpanel__title">Open-item detail</h3>
                <RadzenDataGrid TItem="ArAgingOpenItemSummary"
                                Data="@_arAging.DetailRows"
                                AllowSorting="true"
                                AllowFiltering="true"
                                AllowColumnResize="true"
                                AllowPaging="true"
                                PageSize="100"
                                FilterMode="FilterMode.Simple"
                                class="citus-radzen-grid">
                    <Columns>
                        <RadzenDataGridColumn TItem="ArAgingOpenItemSummary" Property="@nameof(ArAgingOpenItemSummary.CustomerDisplayName)" Title="Customer">
                            <Template Context="row">
                                <div>@row.CustomerDisplayName</div>
                                <div class="text-fg-subtle text-xs"><span class="citus-inline-code">@row.CustomerEntityNumber</span></div>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ArAgingOpenItemSummary" Property="@nameof(ArAgingOpenItemSummary.DisplayNumber)" Title="Document" Width="200px">
                            <Template Context="row">
                                @{ var arHref = TryBuildDocumentHref(row.SourceType, row.SourceDocumentId); }
                                @if (arHref is not null)
                                {
                                    <a class="citus-link" href="@arHref">@row.DisplayNumber</a>
                                }
                                else
                                {
                                    <span>@row.DisplayNumber</span>
                                }
                                <div class="text-fg-subtle text-xs">@row.SourceType · @row.DocumentDate.ToString("yyyy-MM-dd")</div>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ArAgingOpenItemSummary" Property="@nameof(ArAgingOpenItemSummary.DueDate)" Title="Due date" Width="150px">
                            <Template Context="row">
                                @if (row.DueDate is null)
                                {
                                    <span>No due date</span>
                                }
                                else
                                {
                                    <div>@row.DueDate.Value.ToString("yyyy-MM-dd")</div>
                                    <div class="text-fg-subtle text-xs">@($"{row.DaysPastDue} days past due")</div>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ArAgingOpenItemSummary" Property="@nameof(ArAgingOpenItemSummary.AgingBucket)" Title="Bucket" Width="110px">
                            <Template Context="row">@FormatAgingBucket(row.AgingBucket)</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ArAgingOpenItemSummary" Property="@nameof(ArAgingOpenItemSummary.SignedOpenAmountBase)" Title="Open amount" TextAlign="TextAlign.Right" Width="160px">
                            <Template Context="row">
                                <div>@FormatAmount(row.SignedOpenAmountBase)</div>
                                <div class="text-fg-subtle text-xs">@FormatAmount(row.SignedOpenAmountTx) @row.DocumentCurrencyCode</div>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </article>
        }
    }
</section>

@* ------------------------- A/P Aging ------------------------- *@
<section class="citus-panel mb-6">
    <header class="citus-panel__header">
        <h2 class="citus-panel__title">A/P Aging</h2>
        <CitusBadge Color="@("orange")">Open-item report</CitusBadge>
    </header>

    <div class="flex flex-wrap items-center gap-3 mb-4">
        <RadzenDatePicker TValue="DateTime?" DateFormat="yyyy-MM-dd" ShowTime="false" @bind-Value="_apAgingAsOfDate" Placeholder="@("As of date")" />
        <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_isApAgingLoading" OnClick="LoadApAgingAsync">
            Run A/P Aging
        </CitusButton>
        <CitusButton LeadingIcon="IconName.Download" Disabled="@(_isApAgingLoading || _isApAgingExporting)" OnClick="ExportApAgingAsync">
            Export CSV
        </CitusButton>
    </div>

    @if (_isApAgingLoading)
    {
        <div class="mb-4"><CitusLoadingBar /></div>
    }

    @if (!string.IsNullOrWhiteSpace(_apAgingError))
    {
        <CitusAlert Severity="CitusAlertSeverity.Warning" Message="@_apAgingError" ShowIcon="true" Class="mb-4" />
    }

    @if (_apAging is not null)
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
            <CitusStatCard Label="Outstanding" Value="@FormatAmount(_apAging.TotalOutstandingAmountBase)" Description="@($"As of {_apAging.AsOfDate:yyyy-MM-dd} in {_apAging.BaseCurrencyCode}")" Icon="IconName.Receipt" Tone="StatTone.Info" />
            <CitusStatCard Label="Vendors" Value="@_apAging.VendorCount.ToString()" Description="@($"{_apAging.OpenItemCount} open items in scope")" Icon="IconName.BuildingStore" Tone="StatTone.Primary" />
            <CitusStatCard Label="Overdue" Value="@FormatAmount(_apAging.TotalOverdueAmountBase)" Description="Total payable value already past due." Icon="IconName.AlertTriangle" Tone="@(_apAging.TotalOverdueAmountBase > 0m ? StatTone.Warning : StatTone.Success)" />
            <CitusStatCard Label="> 90 days" Value="@FormatAmount(_apAging.DaysOver90AmountBase)" Description="The oldest overdue bucket stays visible for payment control." Icon="IconName.Clock" Tone="@(_apAging.DaysOver90AmountBase > 0m ? StatTone.Danger : StatTone.Success)" />
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3 mb-4">
            <CitusStatCard Label="Current" Value="@FormatAmount(_apAging.CurrentAmountBase)" Description="Not yet due" Icon="IconName.Calendar" Tone="StatTone.Success" />
            <CitusStatCard Label="1-30" Value="@FormatAmount(_apAging.Days1To30AmountBase)" Description="Past due" Icon="IconName.Receipt" Tone="StatTone.Warning" />
            <CitusStatCard Label="31-60" Value="@FormatAmount(_apAging.Days31To60AmountBase)" Description="Past due" Icon="IconName.Receipt" Tone="StatTone.Warning" />
            <CitusStatCard Label="61-90" Value="@FormatAmount(_apAging.Days61To90AmountBase)" Description="Past due" Icon="IconName.Receipt" Tone="StatTone.Warning" />
            <CitusStatCard Label="> 90" Value="@FormatAmount(_apAging.DaysOver90AmountBase)" Description="Past due" Icon="IconName.AlertTriangle" Tone="StatTone.Danger" />
            <CitusStatCard Label="Total" Value="@FormatAmount(_apAging.TotalOutstandingAmountBase)" Description="Net open payables" Icon="IconName.ReportAnalytics" Tone="StatTone.Info" />
        </div>

        @if (_apAging.TotalOutstandingAmountBase > 0)
        {
            <div class="citus-radzen-chart mb-4" style="height: 240px">
                <RadzenChart>
                    <RadzenColumnSeries Data="@BuildApBuckets(_apAging)" CategoryProperty="Label" ValueProperty="Amount" Title="Open AP" />
                    <RadzenColumnOptions Radius="3" />
                    <RadzenCategoryAxis />
                    <RadzenValueAxis Formatter="@FormatChartAmount" />
                </RadzenChart>
            </div>
        }

        @if (_apAging.OpenItemCount == 0)
        {
            <CitusAlert Severity="CitusAlertSeverity.Info" Message="@($"No open payable items were found for this company as of {_apAging.AsOfDate:yyyy-MM-dd}.")" ShowIcon="true" />
        }
        else
        {
            <article class="citus-subpanel">
                <h3 class="citus-subpanel__title">Vendor summary</h3>
                <RadzenDataGrid TItem="ApAgingVendorSummary"
                                Data="@_apAging.VendorRows"
                                AllowSorting="true"
                                AllowFiltering="true"
                                AllowColumnResize="true"
                                AllowPaging="true"
                                PageSize="50"
                                FilterMode="FilterMode.Simple"
                                class="citus-radzen-grid">
                    <Columns>
                        <RadzenDataGridColumn TItem="ApAgingVendorSummary" Property="@nameof(ApAgingVendorSummary.VendorDisplayName)" Title="Vendor">
                            <Template Context="row">
                                <div>@row.VendorDisplayName</div>
                                <div class="text-fg-subtle text-xs">
                                    <span class="citus-inline-code">@row.VendorEntityNumber</span>
                                    @if (row.OldestDueDate is not null)
                                    {
                                        <span> · oldest due @row.OldestDueDate.Value.ToString("yyyy-MM-dd")</span>
                                    }
                                </div>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ApAgingVendorSummary" Property="@nameof(ApAgingVendorSummary.VendorIsActive)" Title="Status" Width="100px">
                            <Template Context="row">@(row.VendorIsActive ? "Active" : "Inactive")</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ApAgingVendorSummary" Property="@nameof(ApAgingVendorSummary.CurrentAmountBase)" Title="Current" TextAlign="TextAlign.Right" Width="120px">
                            <Template Context="row">@FormatAmount(row.CurrentAmountBase)</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ApAgingVendorSummary" Property="@nameof(ApAgingVendorSummary.Days1To30AmountBase)" Title="1-30" TextAlign="TextAlign.Right" Width="110px">
                            <Template Context="row">@FormatAmount(row.Days1To30AmountBase)</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ApAgingVendorSummary" Property="@nameof(ApAgingVendorSummary.Days31To60AmountBase)" Title="31-60" TextAlign="TextAlign.Right" Width="110px">
                            <Template Context="row">@FormatAmount(row.Days31To60AmountBase)</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ApAgingVendorSummary" Property="@nameof(ApAgingVendorSummary.Days61To90AmountBase)" Title="61-90" TextAlign="TextAlign.Right" Width="110px">
                            <Template Context="row">@FormatAmount(row.Days61To90AmountBase)</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ApAgingVendorSummary" Property="@nameof(ApAgingVendorSummary.DaysOver90AmountBase)" Title="> 90" TextAlign="TextAlign.Right" Width="110px">
                            <Template Context="row">@FormatAmount(row.DaysOver90AmountBase)</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ApAgingVendorSummary" Property="@nameof(ApAgingVendorSummary.TotalOutstandingAmountBase)" Title="Total" TextAlign="TextAlign.Right" Width="130px">
                            <Template Context="row"><strong>@FormatAmount(row.TotalOutstandingAmountBase)</strong></Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </article>

            <article class="citus-subpanel">
                <h3 class="citus-subpanel__title">Open-item detail</h3>
                <RadzenDataGrid TItem="ApAgingOpenItemSummary"
                                Data="@_apAging.DetailRows"
                                AllowSorting="true"
                                AllowFiltering="true"
                                AllowColumnResize="true"
                                AllowPaging="true"
                                PageSize="100"
                                FilterMode="FilterMode.Simple"
                                class="citus-radzen-grid">
                    <Columns>
                        <RadzenDataGridColumn TItem="ApAgingOpenItemSummary" Property="@nameof(ApAgingOpenItemSummary.VendorDisplayName)" Title="Vendor">
                            <Template Context="row">
                                <div>@row.VendorDisplayName</div>
                                <div class="text-fg-subtle text-xs"><span class="citus-inline-code">@row.VendorEntityNumber</span></div>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ApAgingOpenItemSummary" Property="@nameof(ApAgingOpenItemSummary.DisplayNumber)" Title="Document" Width="200px">
                            <Template Context="row">
                                @{ var apHref = TryBuildDocumentHref(row.SourceType, row.SourceDocumentId); }
                                @if (apHref is not null)
                                {
                                    <a class="citus-link" href="@apHref">@row.DisplayNumber</a>
                                }
                                else
                                {
                                    <span>@row.DisplayNumber</span>
                                }
                                <div class="text-fg-subtle text-xs">@row.SourceType · @row.DocumentDate.ToString("yyyy-MM-dd")</div>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ApAgingOpenItemSummary" Property="@nameof(ApAgingOpenItemSummary.DueDate)" Title="Due date" Width="150px">
                            <Template Context="row">
                                @if (row.DueDate is null)
                                {
                                    <span>No due date</span>
                                }
                                else
                                {
                                    <div>@row.DueDate.Value.ToString("yyyy-MM-dd")</div>
                                    <div class="text-fg-subtle text-xs">@($"{row.DaysPastDue} days past due")</div>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ApAgingOpenItemSummary" Property="@nameof(ApAgingOpenItemSummary.AgingBucket)" Title="Bucket" Width="110px">
                            <Template Context="row">@FormatAgingBucket(row.AgingBucket)</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ApAgingOpenItemSummary" Property="@nameof(ApAgingOpenItemSummary.SignedOpenAmountBase)" Title="Open amount" TextAlign="TextAlign.Right" Width="160px">
                            <Template Context="row">
                                <div>@FormatAmount(row.SignedOpenAmountBase)</div>
                                <div class="text-fg-subtle text-xs">@FormatAmount(row.SignedOpenAmountTx) @row.DocumentCurrencyCode</div>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </article>
        }
    }
</section>

@* ------------------------- Formal report set ------------------------- *@
<section class="citus-panel mb-6">
    <h2 class="citus-panel__title">Formal report set</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
        @foreach (var report in _reports)
        {
            <article class="citus-domain-card">
                <header class="citus-domain-card__header">
                    <h4 class="citus-domain-card__title">@report.Title</h4>
                    <CitusBadge Color="@TagColor(report.Tone)">@report.Status</CitusBadge>
                </header>
                <p class="citus-domain-card__description">@report.Description</p>
            </article>
        }
    </div>
</section>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <div class="lg:col-span-7">
        <section class="citus-panel">
            <h2 class="citus-panel__title">Rules for the reports surface</h2>
            <ul class="citus-bullet-list">
                <li>Report meaning stays backend-owned across HTML, print, and export.</li>
                <li>Acceleration is allowed later, but never becomes report truth.</li>
                <li>Company context must be obvious before any report is run.</li>
                <li>Read-first pages should arrive before transactional compose screens.</li>
            </ul>
        </section>
    </div>
    <div class="lg:col-span-5">
        <section class="citus-panel">
            <h2 class="citus-panel__title">What should merge next</h2>
            <table class="citus-keyvalue">
                <tbody>
                    @foreach (var row in _nextRows)
                    {
                        <tr><th>@row.Target</th><td>@row.Reason</td></tr>
                    }
                </tbody>
            </table>
        </section>
    </div>
</div>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Accounting",
        Title = "Reports home",
        Subtitle = "The reporting surface is now anchored by real Trial Balance, Income Statement, Balance Sheet, A/R Aging, and A/P Aging endpoints backed by ledger and open-item truth, with matching backend-owned CSV export and read-only source drill-down."
    };

    private readonly IReadOnlyList<ReportCardRow> _reports =
    [
        new("Trial Balance", "Live now", "Reads from PostgreSQL ledger truth and returns debit/credit balances per account.", StatTone.Success),
        new("Income Statement", "Live now", "Returns revenue, cost of sales, expense, and net income across a backend-owned date range.", StatTone.Success),
        new("Balance Sheet", "Live now", "Returns assets, liabilities, equity, and synthetic current earnings as of a backend-owned cut-off date.", StatTone.Success),
        new("A/R Aging", "Live now", "Returns customer-level and open-item aging buckets from backend-owned receivable truth.", StatTone.Success),
        new("A/P Aging", "Live now", "Returns vendor-level and open-item aging buckets from backend-owned payable truth.", StatTone.Success),
        new("Exports", "Live now", "CSV export now follows the same backend-owned totals, ordering, and company scope as the HTML surface.", StatTone.Success)
    ];

    private readonly IReadOnlyList<NextRow> _nextRows =
    [
        new("Company provisioning flow", "Business session companies should also exist as accounting-core companies in PostgreSQL."),
        new("Print alignment", "Print-friendly layouts should reuse the same backend-owned report payloads and ordering as HTML and CSV."),
        new("Journal Entry review", "The next read path should expose journal-entry detail with the same backend-owned, read-only posture.")
    ];

    private ServiceHealthStatus? _health;
    private TrialBalanceReportSummary? _trialBalance;
    private IncomeStatementReportSummary? _incomeStatement;
    private BalanceSheetReportSummary? _balanceSheet;
    private ArAgingReportSummary? _arAging;
    private ApAgingReportSummary? _apAging;
    private bool _isTrialBalanceLoading;
    private bool _isIncomeStatementLoading;
    private bool _isBalanceSheetLoading;
    private bool _isArAgingLoading;
    private bool _isApAgingLoading;
    private bool _isTrialBalanceExporting;
    private bool _isIncomeStatementExporting;
    private bool _isBalanceSheetExporting;
    private bool _isArAgingExporting;
    private bool _isApAgingExporting;
    private bool _includeZeroBalances;
    private bool _includeZeroIncomeStatementRows;
    private bool _includeZeroBalanceSheetRows;
    private string? _trialBalanceError;
    private string? _incomeStatementError;
    private string? _balanceSheetError;
    private string? _arAgingError;
    private string? _apAgingError;
    private DateTime? _asOfDate = DateTime.Today;
    private DateTime? _incomeStatementDateFrom = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? _incomeStatementDateTo = DateTime.Today;
    private DateTime? _balanceSheetAsOfDate = DateTime.Today;
    private DateTime? _arAgingAsOfDate = DateTime.Today;
    private DateTime? _apAgingAsOfDate = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        _health = await AccountingHealthClient.GetHealthAsync();
        await LoadTrialBalanceAsync();
        await LoadIncomeStatementAsync();
        await LoadBalanceSheetAsync();
        await LoadArAgingAsync();
        await LoadApAgingAsync();
    }

    private async Task LoadTrialBalanceAsync()
    {
        _isTrialBalanceLoading = true;
        _trialBalanceError = null;

        var report = await TrialBalanceClient.GetReportAsync(
            ShellState.ActiveCompany.Id,
            DateOnly.FromDateTime((_asOfDate ?? DateTime.Today).Date),
            _includeZeroBalances);

        if (report is null)
        {
            _trialBalance = null;
            _trialBalanceError = "Trial Balance is unavailable until the active company is provisioned in the accounting core and ledger data exists.";
        }
        else
        {
            _trialBalance = report;
        }

        _isTrialBalanceLoading = false;
    }

    private async Task LoadIncomeStatementAsync()
    {
        _isIncomeStatementLoading = true;
        _incomeStatementError = null;

        var dateFrom = DateOnly.FromDateTime((_incomeStatementDateFrom ?? new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1)).Date);
        var dateTo = DateOnly.FromDateTime((_incomeStatementDateTo ?? DateTime.Today).Date);

        if (dateFrom > dateTo)
        {
            _incomeStatement = null;
            _incomeStatementError = "Income Statement date range is invalid. The start date must be on or before the end date.";
            _isIncomeStatementLoading = false;
            return;
        }

        var report = await IncomeStatementClient.GetReportAsync(
            ShellState.ActiveCompany.Id,
            dateFrom,
            dateTo,
            _includeZeroIncomeStatementRows);

        if (report is null)
        {
            _incomeStatement = null;
            _incomeStatementError = "Income Statement is unavailable until the active company is provisioned in the accounting core and date-range report data exists.";
        }
        else
        {
            _incomeStatement = report;
        }

        _isIncomeStatementLoading = false;
    }

    private async Task LoadBalanceSheetAsync()
    {
        _isBalanceSheetLoading = true;
        _balanceSheetError = null;

        var report = await BalanceSheetClient.GetReportAsync(
            ShellState.ActiveCompany.Id,
            DateOnly.FromDateTime((_balanceSheetAsOfDate ?? DateTime.Today).Date),
            _includeZeroBalanceSheetRows);

        if (report is null)
        {
            _balanceSheet = null;
            _balanceSheetError = "Balance Sheet is unavailable until the active company is provisioned in the accounting core and as-of ledger data exists.";
        }
        else
        {
            _balanceSheet = report;
        }

        _isBalanceSheetLoading = false;
    }

    private async Task LoadArAgingAsync()
    {
        _isArAgingLoading = true;
        _arAgingError = null;

        var report = await ArAgingClient.GetReportAsync(
            ShellState.ActiveCompany.Id,
            DateOnly.FromDateTime((_arAgingAsOfDate ?? DateTime.Today).Date));

        if (report is null)
        {
            _arAging = null;
            _arAgingError = "A/R Aging is unavailable until the active company is provisioned in the accounting core and receivable open-item data exists.";
        }
        else
        {
            _arAging = report;
        }

        _isArAgingLoading = false;
    }

    private async Task LoadApAgingAsync()
    {
        _isApAgingLoading = true;
        _apAgingError = null;

        var report = await ApAgingClient.GetReportAsync(
            ShellState.ActiveCompany.Id,
            DateOnly.FromDateTime((_apAgingAsOfDate ?? DateTime.Today).Date));

        if (report is null)
        {
            _apAging = null;
            _apAgingError = "A/P Aging is unavailable until the active company is provisioned in the accounting core and payable open-item data exists.";
        }
        else
        {
            _apAging = report;
        }

        _isApAgingLoading = false;
    }

    private async Task ExportTrialBalanceAsync()
    {
        _isTrialBalanceExporting = true;
        _trialBalanceError = null;

        var file = await TrialBalanceClient.ExportCsvAsync(
            ShellState.ActiveCompany.Id,
            DateOnly.FromDateTime((_asOfDate ?? DateTime.Today).Date),
            _includeZeroBalances);

        await SaveCsvAsync(
            file,
            "Trial Balance CSV is unavailable until the active company is provisioned in the accounting core and ledger data exists.",
            message => _trialBalanceError = message);

        _isTrialBalanceExporting = false;
    }

    private async Task ExportIncomeStatementAsync()
    {
        _isIncomeStatementExporting = true;
        _incomeStatementError = null;

        var dateFrom = DateOnly.FromDateTime((_incomeStatementDateFrom ?? new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1)).Date);
        var dateTo = DateOnly.FromDateTime((_incomeStatementDateTo ?? DateTime.Today).Date);

        if (dateFrom > dateTo)
        {
            _incomeStatementError = "Income Statement date range is invalid. The start date must be on or before the end date.";
            _isIncomeStatementExporting = false;
            return;
        }

        var file = await IncomeStatementClient.ExportCsvAsync(
            ShellState.ActiveCompany.Id,
            dateFrom,
            dateTo,
            _includeZeroIncomeStatementRows);

        await SaveCsvAsync(
            file,
            "Income Statement CSV is unavailable until the active company is provisioned in the accounting core and date-range report data exists.",
            message => _incomeStatementError = message);

        _isIncomeStatementExporting = false;
    }

    private async Task ExportBalanceSheetAsync()
    {
        _isBalanceSheetExporting = true;
        _balanceSheetError = null;

        var file = await BalanceSheetClient.ExportCsvAsync(
            ShellState.ActiveCompany.Id,
            DateOnly.FromDateTime((_balanceSheetAsOfDate ?? DateTime.Today).Date),
            _includeZeroBalanceSheetRows);

        await SaveCsvAsync(
            file,
            "Balance Sheet CSV is unavailable until the active company is provisioned in the accounting core and as-of ledger data exists.",
            message => _balanceSheetError = message);

        _isBalanceSheetExporting = false;
    }

    private async Task ExportArAgingAsync()
    {
        _isArAgingExporting = true;
        _arAgingError = null;

        var file = await ArAgingClient.ExportCsvAsync(
            ShellState.ActiveCompany.Id,
            DateOnly.FromDateTime((_arAgingAsOfDate ?? DateTime.Today).Date));

        await SaveCsvAsync(
            file,
            "A/R Aging CSV is unavailable until the active company is provisioned in the accounting core and receivable open-item data exists.",
            message => _arAgingError = message);

        _isArAgingExporting = false;
    }

    private async Task ExportApAgingAsync()
    {
        _isApAgingExporting = true;
        _apAgingError = null;

        var file = await ApAgingClient.ExportCsvAsync(
            ShellState.ActiveCompany.Id,
            DateOnly.FromDateTime((_apAgingAsOfDate ?? DateTime.Today).Date));

        await SaveCsvAsync(
            file,
            "A/P Aging CSV is unavailable until the active company is provisioned in the accounting core and payable open-item data exists.",
            message => _apAgingError = message);

        _isApAgingExporting = false;
    }

    private async Task SaveCsvAsync(
        ReportCsvDownload? file,
        string unavailableMessage,
        Action<string?> setError)
    {
        if (file is null)
        {
            setError(unavailableMessage);
            return;
        }

        await JSRuntime.InvokeVoidAsync(
            "citusDownloads.saveTextFile",
            file.FileName,
            file.Content,
            file.ContentType);
    }

    private static string TagColor(StatTone tone) => tone switch
    {
        StatTone.Success => "green",
        StatTone.Warning => "orange",
        StatTone.Danger => "red",
        StatTone.Info => "blue",
        StatTone.Primary => "geekblue",
        _ => "default"
    };

    private sealed record class ReportCardRow(string Title, string Status, string Description, StatTone Tone);

    private sealed record class NextRow(string Target, string Reason);

    private sealed record class IncomeSectionBlock(string Title, StatTone Tone, decimal Total, IReadOnlyList<IncomeStatementAccountSummary> Rows);

    private sealed record class BalanceSectionBlock(string Title, StatTone Tone, decimal Total, IReadOnlyList<BalanceSheetAccountSummary> Rows);

    private IEnumerable<IncomeSectionBlock> GetIncomeSections()
    {
        if (_incomeStatement is null)
        {
            return Array.Empty<IncomeSectionBlock>();
        }

        return
        [
            new IncomeSectionBlock("Revenue", StatTone.Success, _incomeStatement.TotalRevenue, _incomeStatement.RevenueRows),
            new IncomeSectionBlock("Cost Of Sales", StatTone.Warning, _incomeStatement.TotalCostOfSales, _incomeStatement.CostOfSalesRows),
            new IncomeSectionBlock("Expenses", StatTone.Info, _incomeStatement.TotalExpenses, _incomeStatement.ExpenseRows)
        ];
    }

    private IEnumerable<BalanceSectionBlock> GetBalanceSections()
    {
        if (_balanceSheet is null)
        {
            return Array.Empty<BalanceSectionBlock>();
        }

        return
        [
            new BalanceSectionBlock("Assets", StatTone.Info, _balanceSheet.TotalAssets, _balanceSheet.AssetRows),
            new BalanceSectionBlock("Liabilities", StatTone.Warning, _balanceSheet.TotalLiabilities, _balanceSheet.LiabilityRows),
            new BalanceSectionBlock("Equity", StatTone.Success, _balanceSheet.TotalEquity, _balanceSheet.EquityRows)
        ];
    }

    private static string FormatAmount(decimal amount) => amount.ToString("N2");

    /// <summary>
    /// Aging-bucket point used by the Phase 3 RadzenChart on the AR / AP
    /// sections. Five points each, ordered by bucket age. Builders run on
    /// every render — cheap (5 inserts) and lets the chart pick up theme
    /// colour swaps without a re-fetch.
    /// </summary>
    private sealed record class AgingBucketPoint(string Label, decimal Amount);

    private static IReadOnlyList<AgingBucketPoint> BuildArBuckets(ArAgingReportSummary report) =>
        new[]
        {
            new AgingBucketPoint("Current", report.CurrentAmountBase),
            new AgingBucketPoint("1-30", report.Days1To30AmountBase),
            new AgingBucketPoint("31-60", report.Days31To60AmountBase),
            new AgingBucketPoint("61-90", report.Days61To90AmountBase),
            new AgingBucketPoint("> 90", report.DaysOver90AmountBase),
        };

    private static IReadOnlyList<AgingBucketPoint> BuildApBuckets(ApAgingReportSummary report) =>
        new[]
        {
            new AgingBucketPoint("Current", report.CurrentAmountBase),
            new AgingBucketPoint("1-30", report.Days1To30AmountBase),
            new AgingBucketPoint("31-60", report.Days31To60AmountBase),
            new AgingBucketPoint("61-90", report.Days61To90AmountBase),
            new AgingBucketPoint("> 90", report.DaysOver90AmountBase),
        };

    private static string FormatChartAmount(object value) =>
        value is IConvertible convertible
            ? Convert.ToDecimal(convertible).ToString("N0")
            : value?.ToString() ?? string.Empty;

    private static string? TryBuildDocumentHref(string sourceType, Guid documentId) =>
        AccountingDocumentReviewRouteCatalog.TryBuildReviewHref(sourceType, documentId, out var href)
            ? href
            : null;

    private static string FormatAgingBucket(string bucket) =>
        bucket switch
        {
            "current" => "Current",
            "1_30" => "1-30",
            "31_60" => "31-60",
            "61_90" => "61-90",
            "over_90" => "> 90",
            _ => bucket
        };
}
