@page "/reports"

@inject BusinessShellState ShellState
@inject Microsoft.JSInterop.IJSRuntime JS

<PageTitle>Reports | Tralanz Books</PageTitle>

<CitusPageHeader Model="_header" />

<div class="mb-4" style="max-width: 28rem">
    <CitusInput TValue="string" @bind-Value="_search" Placeholder="Find a report by name…" />
</div>

@{
    var groups = FilteredByCategory();
    var favourites = FavouriteReports();
}

@if (string.IsNullOrWhiteSpace(_search) && favourites.Count > 0)
{
    <CitusFormSection Title="Favourites">
        <table class="citus-data-table">
            <tbody>
                @foreach (var report in favourites)
                {
                    <tr>
                        <td style="width: 2.25rem; vertical-align: top">
                            <button type="button" title="Remove from favourites"
                                    @onclick="() => ToggleFavouriteAsync(report.Key)"
                                    style="background: none; border: 0; cursor: pointer; font-size: 1.05rem; line-height: 1; color: var(--citus-color-warning)">★</button>
                        </td>
                        <td>
                            <a class="citus-link" href="@($"reports/{report.Key}")">@report.Title</a>
                            <div class="text-fg-subtle text-xs">@report.Description</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </CitusFormSection>
}

@if (groups.Count == 0)
{
    <CitusAlert Severity="CitusAlertSeverity.Info" Message="@($"No reports match \"{_search}\".")" ShowIcon="true" />
}
else
{
    @foreach (var group in groups)
    {
        <CitusFormSection Title="@group.Category">
            <table class="citus-data-table">
                <tbody>
                    @foreach (var report in group.Reports)
                    {
                        <tr>
                            <td style="width: 2.25rem; vertical-align: top">
                                <button type="button" title="@StarTitle(report.Key)"
                                        @onclick="() => ToggleFavouriteAsync(report.Key)"
                                        style="@($"background: none; border: 0; cursor: pointer; font-size: 1.05rem; line-height: 1; color: {StarColor(report.Key)}")">@StarGlyph(report.Key)</button>
                            </td>
                            <td>
                                @if (report.IsImplemented)
                                {
                                    <a class="citus-link" href="@($"reports/{report.Key}")">@report.Title</a>
                                }
                                else
                                {
                                    <span class="text-fg-muted">@report.Title</span>
                                    <CitusBadge Color="@("default")">Coming soon</CitusBadge>
                                }
                                <div class="text-fg-subtle text-xs">@report.Description</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </CitusFormSection>
    }
}

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Accounting",
        Title = "Reports",
        Subtitle = "Choose a report to run. Report meaning stays backend-owned across the on-screen view and CSV export."
    };

    // Per-browser favourites (localStorage). Not synced across devices — a
    // server-backed table can replace this without touching the star UI.
    private const string FavouritesKey = "citus.business.reportFavourites";

    private string _search = string.Empty;
    private HashSet<string> _favourites = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var raw = await JS.InvokeAsync<string?>("localStorage.getItem", FavouritesKey);
            if (!string.IsNullOrWhiteSpace(raw))
            {
                _favourites = raw
                    .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);
                StateHasChanged();
            }
        }
        catch
        {
            // localStorage unavailable (e.g. prerender / blocked) — favourites stay empty this session.
        }
    }

    private bool IsFavourite(string key) => _favourites.Contains(key);

    private string StarGlyph(string key) => IsFavourite(key) ? "★" : "☆";

    private string StarColor(string key) =>
        IsFavourite(key) ? "var(--citus-color-warning)" : "var(--citus-color-fg-subtle)";

    private string StarTitle(string key) =>
        IsFavourite(key) ? "Remove from favourites" : "Add to favourites";

    private async Task ToggleFavouriteAsync(string key)
    {
        if (!_favourites.Remove(key))
        {
            _favourites.Add(key);
        }

        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", FavouritesKey, string.Join(',', _favourites));
        }
        catch
        {
            // Persistence failure is non-fatal; the in-memory toggle still reflects this session.
        }
    }

    private IReadOnlyList<ReportDefinition> FavouriteReports() =>
        _favourites
            .Select(ReportCatalog.ByKey)
            .Where(r => r is not null)
            .Select(r => r!)
            .OrderBy(r => r.Title, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private IReadOnlyList<(string Category, IReadOnlyList<ReportDefinition> Reports)> FilteredByCategory()
    {
        var query = (_search ?? string.Empty).Trim();
        var groups = ReportCatalog.ByCategory();
        if (query.Length == 0)
        {
            return groups;
        }

        return groups
            .Select(group => (
                group.Category,
                Reports: (IReadOnlyList<ReportDefinition>)group.Reports
                    .Where(r => r.Title.Contains(query, StringComparison.OrdinalIgnoreCase)
                                || r.Description.Contains(query, StringComparison.OrdinalIgnoreCase))
                    .ToList()))
            .Where(group => group.Reports.Count > 0)
            .ToList();
    }
}
