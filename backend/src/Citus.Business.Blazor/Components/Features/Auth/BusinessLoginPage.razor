@page "/"
@page "/login"

@inject BusinessShellState ShellState
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject CitusToastService Message
@inject BusinessAuthenticationClient BusinessAuthenticationClient

@*
    Plain HTML inputs are used here on purpose: AntDesign 1.6.1's
    Input<T> binds against a type that .NET 11 preview removed
    (WebEventCallbackFactoryEventArgsExtensions), which throws a
    TypeLoadException the moment the component is rendered. The
    login surface must boot even when the rest of the form layer
    is awaiting an AntDesign upgrade.
*@

<PageTitle>Sign in | Tralanz Books</PageTitle>

<div class="sys-login">
    <header class="sys-login__bar">
        <span class="sys-login__bar-title">
            <CitusIcon Name="IconName.BuildingBank" Size="IconSize.Inline" />
            Tralanz Books
        </span>
        <span class="sys-login__bar-meta">Multi-tenant ERP</span>
    </header>

    <div class="sys-login__body">
        <div class="sys-login__crest" aria-hidden="true">
            <CitusIcon Name="IconName.BuildingBank" Size="IconSize.Display" />
        </div>

        <div class="sys-login__heading">
            <h1 class="sys-login__title">Sign in to your company</h1>
            <p class="text-fg-muted text-sm">
                Company-scoped accounting workspace. Use the credentials issued to your business membership.
            </p>
        </div>

        <div class="sys-login__rule"></div>

        <form class="sys-login__form flex flex-col gap-3 mt-4" @onsubmit="SignInAsync" @onsubmit:preventDefault>
            <label class="citus-form-field">
                <span class="citus-form-field__label">Email</span>
                <input type="email"
                       class="citus-form-field__input"
                       placeholder="you@company.com"
                       autocomplete="username"
                       value="@_email"
                       @oninput="OnEmailChanged"
                       disabled="@_isSubmitting" />
            </label>

            <label class="citus-form-field">
                <span class="citus-form-field__label">Password</span>
                <input type="password"
                       class="citus-form-field__input"
                       placeholder="••••••••"
                       autocomplete="current-password"
                       value="@_password"
                       @oninput="OnPasswordChanged"
                       disabled="@_isSubmitting" />
            </label>

            <CitusButton Variant="CitusButtonVariant.Primary"
                         Size="CitusButtonSize.Large"
                         Block="true"
                         HtmlType="@("submit")"
                         Disabled="_isSubmitting"
                         OnClick="SignInAsync">
                @(_isSubmitting ? "Signing in..." : "Sign in")
            </CitusButton>
        </form>
    </div>

    <footer class="sys-login__switcher">
        <span class="text-fg-muted text-xs">Platform administrator?</span>
        <a href="/sysadmin/login" class="citus-link">SysAdmin sign in</a>
    </footer>
</div>

@code {
    private string _email = string.Empty;
    private string _password = string.Empty;
    private bool _isSubmitting;

    private void OnEmailChanged(ChangeEventArgs args) =>
        _email = args.Value?.ToString() ?? string.Empty;

    private void OnPasswordChanged(ChangeEventArgs args) =>
        _password = args.Value?.ToString() ?? string.Empty;

    private async Task SignInAsync()
    {
        if (_isSubmitting)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            await Message.WarningAsync("Email and password are required.");
            return;
        }

        _isSubmitting = true;

        try
        {
            var response = await BusinessAuthenticationClient.SignInAsync(_email, _password);
            if (!response.Succeeded || string.IsNullOrWhiteSpace(response.SessionToken))
            {
                await Message.WarningAsync(string.IsNullOrWhiteSpace(response.Message)
                    ? "Unable to sign in. Check your credentials."
                    : response.Message);
                return;
            }

            ShellState.ApplyAuthenticatedSession(response.SessionToken, response.Session, response.IsBootstrap);
            await JS.InvokeVoidAsync("citusBusinessAuth.setSessionToken", response.SessionToken);

            // Merge any persisted display-name override so the user sees
            // their preferred name on the first dashboard render.
            var profileOverride = await BusinessAuthenticationClient.GetProfileOverrideAsync();
            if (profileOverride is not null && !string.IsNullOrWhiteSpace(profileOverride.DisplayName))
            {
                ShellState.UpdateUserDisplayName(profileOverride.DisplayName);
            }

            if (response.IsBootstrap)
            {
                await Message.InfoAsync("Signed in with the local bootstrap user.");
            }
            else
            {
                await Message.SuccessAsync($"Welcome back, {response.Session.User.DisplayName}.");
            }

            NavigationManager.NavigateTo("dashboard");
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
