@page "/"
@page "/login"

@inject BusinessShellState ShellState
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject CitusToastService Message
@inject BusinessAuthenticationClient BusinessAuthenticationClient
@inject BusinessSetupStatusClient SetupStatusClient
@inject ModuleFlagsClient ModuleFlagsClient
@inject ILogger<BusinessLoginPage> Logger

@*
    Plain HTML inputs are used here on purpose: the login surface must
    boot before the authenticated Radzen shell is available. Shared
    Citus form classes keep this business-layer login visually aligned
    with the rest of the app.
*@

<PageTitle>Sign in | Aiseworks</PageTitle>

<div class="sys-login">
    <header class="sys-login__bar">
        <span class="sys-login__bar-title">
            <CitusIcon Name="IconName.BuildingBank" Size="IconSize.Inline" />
            Aiseworks
        </span>
        <span class="sys-login__bar-meta">Multi-tenant ERP</span>
    </header>

    <div class="sys-login__body">
        <div class="sys-login__crest" aria-hidden="true">
            <CitusIcon Name="IconName.BuildingBank" Size="IconSize.Display" />
        </div>

        <div class="sys-login__heading">
            <h1 class="sys-login__title">Sign in to your company</h1>
            <p class="text-fg-muted text-sm">
                Company-scoped accounting workspace. Use the credentials issued to your business membership.
            </p>
        </div>

        @if (_isCheckingSetup)
        {
            <CitusAlert Severity="CitusAlertSeverity.Info"
                        ShowIcon="true"
                        Message="Checking first-time setup status..."
                        Class="mt-4" />
        }
        else if (RequiresFirstTimeSetup)
        {
            <CitusAlert Severity="CitusAlertSeverity.Warning"
                        ShowIcon="true"
                        Message="@BuildSetupMessage()"
                        Class="mt-4" />

            <div class="mt-4">
                <CitusButton Variant="CitusButtonVariant.Primary"
                             Size="CitusButtonSize.Large"
                             Block="true"
                             OnClick="OpenFirstTimeSetupAsync">
                    Open first-time setup
                </CitusButton>
            </div>
        }

        <div class="sys-login__rule"></div>

        <form class="sys-login__form flex flex-col gap-3 mt-4" @onsubmit="SignInAsync" @onsubmit:preventDefault>
            <label class="citus-form-field">
                <span class="citus-form-field__label">Email</span>
                <input type="email"
                       class="citus-form-field__input"
                       placeholder="you@company.com"
                       autocomplete="username"
                       value="@_email"
                       @oninput="OnEmailChanged"
                       disabled="@_isSubmitting" />
            </label>

            <label class="citus-form-field">
                <span class="citus-form-field__label">Password</span>
                <input type="password"
                       class="citus-form-field__input"
                       placeholder="••••••••"
                       autocomplete="current-password"
                       value="@_password"
                       @oninput="OnPasswordChanged"
                       disabled="@_isSubmitting" />
            </label>

            <label class="flex items-center gap-2 text-sm text-fg-muted">
                <input type="checkbox"
                       class="h-4 w-4 rounded border-border"
                       checked="@_rememberEmail"
                       @onchange="OnRememberEmailChanged"
                       disabled="@_isSubmitting" />
                <span>Remember email on this device</span>
            </label>

            <CitusButton Variant="CitusButtonVariant.Primary"
                         Size="CitusButtonSize.Large"
                         Block="true"
                         HtmlType="@("submit")"
                         Disabled="_isSubmitting"
                         OnClick="SignInAsync">
                @(_isSubmitting ? "Signing in..." : "Sign in")
            </CitusButton>

            <div class="text-center mt-2">
                <a href="forgot-password" class="citus-link text-sm">Forgot password?</a>
            </div>
        </form>
    </div>
</div>

@code {
    private const string RememberEmailKey = "aiseworks.business.login.rememberEmail";
    private const string SavedEmailKey = "aiseworks.business.login.email";

    private string _email = string.Empty;
    private string _password = string.Empty;
    private bool _rememberEmail;
    private bool _isSubmitting;
    private bool _isCheckingSetup = true;
    private bool _hasRedirectedToSetup;
    private BusinessSetupStatus? _setupStatus;

    private bool RequiresFirstTimeSetup =>
        _setupStatus is not null &&
        (!_setupStatus.BusinessReady ||
         _setupStatus.SetupRequired ||
         _setupStatus.FirstCompanySetupRequired);

    private void OnEmailChanged(ChangeEventArgs args) =>
        _email = args.Value?.ToString() ?? string.Empty;

    private void OnPasswordChanged(ChangeEventArgs args) =>
        _password = args.Value?.ToString() ?? string.Empty;

    private void OnRememberEmailChanged(ChangeEventArgs args) =>
        _rememberEmail = args.Value is bool value && value;

    protected override async Task OnInitializedAsync()
    {
        await LoadSetupStatusAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await LoadRememberedEmailAsync();
    }

    private async Task LoadSetupStatusAsync()
    {
        _isCheckingSetup = true;

        try
        {
            _setupStatus = await SetupStatusClient.GetSetupStatusAsync();
            if (RequiresFirstTimeSetup && !_hasRedirectedToSetup)
            {
                _hasRedirectedToSetup = true;
                NavigationManager.NavigateTo("/setup", forceLoad: true);
            }
        }
        finally
        {
            _isCheckingSetup = false;
        }
    }

    private async Task SignInAsync()
    {
        if (_isSubmitting)
        {
            return;
        }

        if (RequiresFirstTimeSetup)
        {
            await OpenFirstTimeSetupAsync();
            return;
        }

        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            await Message.WarningAsync("Email and password are required.");
            return;
        }

        _isSubmitting = true;

        try
        {
            var response = await BusinessAuthenticationClient.SignInAsync(_email, _password);
            if (!response.Succeeded || string.IsNullOrWhiteSpace(response.SessionToken))
            {
                await Message.WarningAsync(string.IsNullOrWhiteSpace(response.Message)
                    ? "Unable to sign in. Check your credentials."
                    : response.Message);
                return;
            }

            ShellState.ApplyAuthenticatedSession(response.SessionToken, response.Session);
            await JS.InvokeVoidAsync("citusBusinessAuth.setSessionToken", response.SessionToken);
            await PersistRememberedEmailAsync();

            // Merge any persisted display-name override so the user sees
            // their preferred name on the first dashboard render.
            var profileOverride = await BusinessAuthenticationClient.GetProfileOverrideAsync();
            if (profileOverride is not null && !string.IsNullOrWhiteSpace(profileOverride.DisplayName))
            {
                ShellState.UpdateUserDisplayName(profileOverride.DisplayName);
            }

            await LoadModuleFlagsForFirstDashboardRenderAsync();

            await Message.SuccessAsync($"Welcome back, {response.Session.User.DisplayName}.");

            NavigationManager.NavigateTo("dashboard");
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private Task OpenFirstTimeSetupAsync()
    {
        _hasRedirectedToSetup = true;
        NavigationManager.NavigateTo("/setup", forceLoad: true);
        return Task.CompletedTask;
    }

    private async Task LoadModuleFlagsForFirstDashboardRenderAsync()
    {
        try
        {
            var flags = await ModuleFlagsClient.ListAsync();
            ShellState.ApplyModuleFlags(flags);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Unable to preload module flags after business sign-in.");
        }
    }

    private string BuildSetupMessage()
    {
        if (_setupStatus?.SetupRequired == true)
        {
            return "Aiseworks has not been initialized yet. Create the first SysAdmin account before business users can sign in.";
        }

        if (_setupStatus?.FirstCompanySetupRequired == true || _setupStatus?.BusinessReady == false)
        {
            return "Aiseworks still needs the first company and owner account before the business workspace can be used.";
        }

        return "Aiseworks first-time setup is not complete.";
    }

    private async Task LoadRememberedEmailAsync()
    {
        try
        {
            var rememberRaw = await JS.InvokeAsync<string?>(
                "window.localStorage.getItem",
                RememberEmailKey);

            _rememberEmail = string.Equals(rememberRaw, "true", StringComparison.OrdinalIgnoreCase);
            if (_rememberEmail)
            {
                var savedEmail = await JS.InvokeAsync<string?>(
                    "window.localStorage.getItem",
                    SavedEmailKey);
                if (!string.IsNullOrWhiteSpace(savedEmail))
                {
                    _email = savedEmail.Trim();
                }
            }

            StateHasChanged();
        }
        catch
        {
            // Local browser storage can be disabled. Login still works.
        }
    }

    private async Task PersistRememberedEmailAsync()
    {
        try
        {
            if (_rememberEmail)
            {
                await JS.InvokeVoidAsync("window.localStorage.setItem", RememberEmailKey, "true");
                await JS.InvokeVoidAsync("window.localStorage.setItem", SavedEmailKey, _email.Trim());
            }
            else
            {
                await JS.InvokeVoidAsync("window.localStorage.removeItem", RememberEmailKey);
                await JS.InvokeVoidAsync("window.localStorage.removeItem", SavedEmailKey);
            }
        }
        catch
        {
            // Remembering the email is best-effort and must not block sign-in.
        }
    }
}
