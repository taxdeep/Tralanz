@page "/forgot-password"

@inject BusinessAuthenticationClient AuthClient
@inject NavigationManager Nav

<PageTitle>Forgot password | Aiseworks</PageTitle>

<div class="sys-login">
    <header class="sys-login__bar">
        <span class="sys-login__bar-title">
            <CitusIcon Name="IconName.BuildingBank" Size="IconSize.Inline" />
            Aiseworks
        </span>
        <span class="sys-login__bar-meta">Reset your password</span>
    </header>

    <div class="sys-login__body">
        <div class="sys-login__crest" aria-hidden="true">
            <CitusIcon Name="IconName.ShieldLock" Size="IconSize.Display" />
        </div>

        <div class="sys-login__heading">
            <h1 class="sys-login__title">Forgot your password?</h1>
            <p class="text-fg-muted text-sm">
                Enter the email tied to your Aiseworks account. If it matches an
                active account, we'll send a one-time reset link that expires in
                15 minutes.
            </p>
        </div>

        <div class="sys-login__rule"></div>

        @if (_acknowledged)
        {
            <CitusAlert Severity="CitusAlertSeverity.Success"
                        ShowIcon="true"
                        Class="mt-4">
                <MessageTemplate>
                    <span>@_resultMessage</span>
                </MessageTemplate>
            </CitusAlert>

            <div class="text-center mt-4">
                <a href="login" class="citus-link">Back to sign in</a>
            </div>
        }
        else
        {
            <form class="sys-login__form flex flex-col gap-3 mt-4"
                  @onsubmit="SubmitAsync" @onsubmit:preventDefault>
                <label class="citus-form-field">
                    <span class="citus-form-field__label">Email</span>
                    <input type="email"
                           class="citus-form-field__input"
                           placeholder="you@company.com"
                           autocomplete="username"
                           value="@_email"
                           @oninput="@(e => _email = e.Value?.ToString() ?? string.Empty)"
                           disabled="@_isSubmitting" />
                </label>

                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <CitusAlert Severity="CitusAlertSeverity.Warning"
                                Message="@_error"
                                ShowIcon="true" />
                }

                <CitusButton Variant="CitusButtonVariant.Primary"
                             Size="CitusButtonSize.Large"
                             Block="true"
                             HtmlType="@("submit")"
                             Disabled="_isSubmitting"
                             OnClick="SubmitAsync">
                    @(_isSubmitting ? "Sending…" : "Send reset link")
                </CitusButton>

                <div class="text-center">
                    <a href="login" class="citus-link text-sm">Back to sign in</a>
                </div>
            </form>
        }
    </div>
</div>

@code {
    private string _email = string.Empty;
    private bool _isSubmitting;
    private bool _acknowledged;
    private string _resultMessage = string.Empty;
    private string? _error;

    private async Task SubmitAsync()
    {
        if (_isSubmitting) return;

        if (string.IsNullOrWhiteSpace(_email) || !_email.Contains('@', StringComparison.Ordinal))
        {
            _error = "Enter a valid email address.";
            return;
        }

        _isSubmitting = true;
        _error = null;
        try
        {
            var outcome = await AuthClient.RequestForgotPasswordAsync(_email.Trim());
            _resultMessage = outcome.Message;
            // Acknowledge regardless — the message is generic by design,
            // and the banner doubles as the success / "check your inbox"
            // indicator.
            _acknowledged = true;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
