@page "/reset-password"

@inject BusinessAuthenticationClient AuthClient
@inject NavigationManager Nav

<PageTitle>Reset password | Tralanz Books</PageTitle>

<div class="sys-login">
    <header class="sys-login__bar">
        <span class="sys-login__bar-title">
            <CitusIcon Name="IconName.BuildingBank" Size="IconSize.Inline" />
            Tralanz Books
        </span>
        <span class="sys-login__bar-meta">Set a new password</span>
    </header>

    <div class="sys-login__body">
        <div class="sys-login__crest" aria-hidden="true">
            <CitusIcon Name="IconName.ShieldLock" Size="IconSize.Display" />
        </div>

        <div class="sys-login__heading">
            <h1 class="sys-login__title">Set a new password</h1>
            <p class="text-fg-muted text-sm">
                Enter a new password to finish the reset. After saving you'll be
                signed out from any device that doesn't have the new credential.
            </p>
        </div>

        <div class="sys-login__rule"></div>

        @if (string.IsNullOrWhiteSpace(_token))
        {
            <CitusAlert Severity="CitusAlertSeverity.Warning"
                        ShowIcon="true"
                        Class="mt-4">
                <MessageTemplate>
                    <span>This page needs a reset token. Use the link from the email we sent you.</span>
                </MessageTemplate>
            </CitusAlert>

            <div class="text-center mt-4">
                <a href="forgot-password" class="citus-link">Request a new reset link</a>
            </div>
        }
        else if (_succeeded)
        {
            <CitusAlert Severity="CitusAlertSeverity.Success"
                        ShowIcon="true"
                        Class="mt-4">
                <MessageTemplate>
                    <span>@_resultMessage</span>
                </MessageTemplate>
            </CitusAlert>

            <div class="text-center mt-4">
                <a href="login" class="citus-link">Sign in with your new password</a>
            </div>
        }
        else
        {
            <form class="sys-login__form flex flex-col gap-3 mt-4"
                  @onsubmit="SubmitAsync" @onsubmit:preventDefault>
                <label class="citus-form-field">
                    <span class="citus-form-field__label">New password</span>
                    <input type="password"
                           class="citus-form-field__input"
                           autocomplete="new-password"
                           value="@_password"
                           @oninput="@(e => _password = e.Value?.ToString() ?? string.Empty)"
                           disabled="@_isSubmitting" />
                </label>

                <label class="citus-form-field">
                    <span class="citus-form-field__label">Confirm new password</span>
                    <input type="password"
                           class="citus-form-field__input"
                           autocomplete="new-password"
                           value="@_confirm"
                           @oninput="@(e => _confirm = e.Value?.ToString() ?? string.Empty)"
                           disabled="@_isSubmitting" />
                </label>

                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <CitusAlert Severity="CitusAlertSeverity.Warning"
                                Message="@_error"
                                ShowIcon="true" />
                }

                <CitusButton Variant="CitusButtonVariant.Primary"
                             Size="CitusButtonSize.Large"
                             Block="true"
                             HtmlType="@("submit")"
                             Disabled="_isSubmitting"
                             OnClick="SubmitAsync">
                    @(_isSubmitting ? "Saving…" : "Save new password")
                </CitusButton>

                <div class="text-center">
                    <a href="login" class="citus-link text-sm">Cancel</a>
                </div>
            </form>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    private string? Token { get; set; }

    private string _token = string.Empty;
    private string _password = string.Empty;
    private string _confirm = string.Empty;
    private bool _isSubmitting;
    private bool _succeeded;
    private string _resultMessage = string.Empty;
    private string? _error;

    protected override void OnParametersSet()
    {
        _token = Token?.Trim() ?? string.Empty;
    }

    private async Task SubmitAsync()
    {
        if (_isSubmitting) return;

        if (string.IsNullOrWhiteSpace(_password) || _password.Length < 8)
        {
            _error = "Password must be at least 8 characters.";
            return;
        }
        if (!string.Equals(_password, _confirm, StringComparison.Ordinal))
        {
            _error = "Password and confirmation do not match.";
            return;
        }

        _isSubmitting = true;
        _error = null;
        try
        {
            var outcome = await AuthClient.RedeemPasswordResetAsync(_token, _password);
            if (!outcome.Succeeded)
            {
                _error = outcome.Message;
                return;
            }
            _resultMessage = outcome.Message;
            _succeeded = true;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
