@using Citus.Ui.Shared.Business

@if (Company.IsReadOnly)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-6">
        Company <strong>@Company.CompanyName</strong> is currently <strong>@FormatStatus(Company.Status)</strong>.
        Business access stays available for review, but writes, posting, and governed mutations are blocked by backend authority.
    </MudAlert>
}

@code
{
    [Parameter, EditorRequired]
    public BusinessCompanySummary Company { get; set; } = new();

    private static string FormatStatus(string? status) =>
        string.IsNullOrWhiteSpace(status)
            ? "read-only"
            : status.Trim().ToLowerInvariant();
}
