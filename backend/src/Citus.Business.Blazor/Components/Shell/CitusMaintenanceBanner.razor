@if (State.Enabled)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true" Class="mb-6">
        @State.Message
        @if (State.ScheduledUntilUtc.HasValue)
        {
            <span> Planned until @State.ScheduledUntilUtc.Value.ToUniversalTime().ToString("u").</span>
        }
    </MudAlert>
}

@code
{
    [Parameter, EditorRequired]
    public MaintenanceStateSummary State { get; set; } = new();
}
