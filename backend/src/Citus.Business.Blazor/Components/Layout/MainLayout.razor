@inject BusinessShellState ShellState
@inject BusinessSessionClient BusinessSessionClient
@inject ISnackbar Snackbar
@inject IThemeService ThemeService

@inherits LayoutComponentBase

<IconSpriteHost />
<AntDesign.AntContainer />

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6">Citus Business</MudText>
        <MudSpacer />
        <BusinessTopBar />
    </MudAppBar>

    <MudDrawer Open="true" ClipMode="DrawerClipMode.Always" Elevation="1" Variant="DrawerVariant.Responsive" Class="citus-drawer">
        <BusinessNavMenu />
    </MudDrawer>

    <MudMainContent Class="citus-main-content">
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
            @if (_isContextLoading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mb-4" />
            }

            <CitusMaintenanceBanner State="ShellState.MaintenanceState" />
            <CitusCompanyAccessBanner Company="ShellState.ActiveCompany" />
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code
{
    private bool _isContextLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var context = await BusinessSessionClient.GetContextAsync();

        if (context is null)
        {
            Snackbar.Add(
                "Business session context is unavailable. The shell is showing bootstrap values until Accounting API responds.",
                Severity.Warning);
        }
        else
        {
            ShellState.ApplySessionContext(context);
        }

        _isContextLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.InitializeInteractiveAsync();
        }
    }
}
