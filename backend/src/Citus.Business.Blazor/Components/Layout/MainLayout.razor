@inject Citus.Business.Blazor.State.BusinessShellState ShellState
@inject Citus.Business.Blazor.Services.BusinessSessionClient BusinessSessionClient
@inject Citus.Business.Blazor.Services.BusinessAuthenticationClient BusinessAuthenticationClient
@inject Citus.Business.Blazor.Services.ModuleFlagsClient ModuleFlagsClient
@inject CitusToastService Message
@inject IThemeService ThemeService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject ILogger<MainLayout> Logger

@inherits LayoutComponentBase
@implements IDisposable

@*
    MainLayout -- Citus/Radzen shell. The unauthenticated branch hosts
    the login page; the authenticated branch wraps the app in the standard
    Sider/Header/Content shell.
*@

<IconSpriteHost />
<RadzenComponents />

@if (!_isShellReady)
{
    <div class="citus-shell__bootstrap">
        <ShellBootstrapSplash />
    </div>
}
else if (!ShellState.IsAuthenticated)
{
    <div class="citus-shell__auth-frame">
        @if (IsLoginRoute)
        {
            @Body
        }
        else
        {
            <ShellBootstrapSplash />
        }
    </div>
}
else
{
    @* T-shape shell: header spans the full width (brand + topbar on one
       row); sider + content sit underneath in a horizontal split.
       Collapsing the sider also shrinks the brand cell so the vertical
       separator between brand and topbar stays aligned with the sider's
       right edge. *@
    <div class="citus-shell citus-shell--t @(_collapsed ? "citus-shell--collapsed" : null)">
        <header class="citus-shell__header">
            <div class="citus-shell__brand">
                <CitusIcon Name="IconName.BuildingBank" Size="@(_collapsed ? IconSize.Action : IconSize.Display)" />
                @if (!_collapsed)
                {
                    <div class="citus-shell__brand-stack">
                        <span class="citus-shell__brand-text">Tralanz Books</span>
                        <span class="citus-shell__brand-version">v@(AppVersion)</span>
                    </div>
                }
            </div>
            <div class="citus-shell__header-bar">
                <BusinessTopBar Collapsed="@_collapsed" OnToggle="ToggleCollapsed" />
            </div>
        </header>

        <div class="citus-shell__body">
            <aside class="citus-shell__sider">
                @if (!_collapsed)
                {
                    <div class="citus-shell__create">
                        <CreateNewButton />
                    </div>
                }
                <BusinessNavMenu Collapsed="@_collapsed" />
            </aside>

            <main class="citus-shell__content">
                <CitusMaintenanceBanner State="ShellState.MaintenanceState" />
                <CitusCompanyAccessBanner Company="ShellState.ActiveCompany" />

                @if (_isContextLoading)
                {
                    <CitusSkeleton Variant="SkeletonVariant.Detail" />
                }
                else
                {
                    @Body
                }
            </main>
        </div>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool _isContextLoading;
    private bool _isShellReady;
    private bool _collapsed;
    // Tracks the most recently observed authenticated state so the
    // OnChanged handler can detect a sign-in transition and trigger a
    // post-bootstrap context+module-flag refresh. Without this the nav
    // menu's TASKS section (and any other ModuleKey-gated entry) shows
    // empty after a fresh sign-in and only appears on a manual page
    // refresh — BootstrapShellAsync runs once on layout mount and the
    // user signed in afterwards.
    private bool _previouslyAuthenticated;

    /// <summary>
    /// Display version pulled from the assembly's
    /// <see cref="System.Reflection.AssemblyInformationalVersionAttribute"/>,
    /// which the pre-push hook keeps in lockstep with VERSION (mixed
    /// base-10 / base-36 widths). The SDK appends "+commitHash" in some
    /// build configurations; strip it so the sidebar shows just the
    /// numeric portion.
    /// </summary>
    private static readonly string AppVersion = ResolveAppVersion();

    private static string ResolveAppVersion()
    {
        var raw = typeof(MainLayout).Assembly
            .GetCustomAttributes(typeof(System.Reflection.AssemblyInformationalVersionAttribute), false)
            .Cast<System.Reflection.AssemblyInformationalVersionAttribute>()
            .FirstOrDefault()?.InformationalVersion;
        if (string.IsNullOrWhiteSpace(raw)) return "dev";
        var plus = raw.IndexOf('+');
        return plus < 0 ? raw : raw[..plus];
    }

    private bool IsLoginRoute
    {
        get
        {
            var relative = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim('/');
            return string.IsNullOrEmpty(relative) ||
                   string.Equals(relative, "login", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsHomeRoute =>
        string.IsNullOrEmpty(NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim('/'));

    protected override Task OnInitializedAsync() => Task.CompletedTask;

    protected override void OnInitialized()
    {
        ShellState.OnChanged += HandleShellStateChanged;
        _previouslyAuthenticated = ShellState.IsAuthenticated;
    }

    public void Dispose()
    {
        ShellState.OnChanged -= HandleShellStateChanged;
    }

    /// <summary>
    /// Detects the unauthenticated → authenticated transition that
    /// happens when the operator signs in on /login (LoginPage calls
    /// <c>ApplyAuthenticatedSession</c> directly, then navigates to
    /// /dashboard — MainLayout is the same instance throughout that
    /// navigation so <c>OnAfterRenderAsync(firstRender: true)</c> does
    /// NOT fire again, leaving the post-bootstrap context + module
    /// flags unfetched). On the transition we re-run
    /// <c>LoadSessionContextAsync</c> so the nav reflects the real
    /// state on the first render of the authenticated shell.
    /// </summary>
    private void HandleShellStateChanged()
    {
        var nowAuthenticated = ShellState.IsAuthenticated;
        var wasAuthenticated = _previouslyAuthenticated;
        _previouslyAuthenticated = nowAuthenticated;

        if (_isShellReady && !wasAuthenticated && nowAuthenticated)
        {
            _ = InvokeAsync(async () =>
            {
                await LoadSessionContextAsync();
                StateHasChanged();
            });
            return;
        }

        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            await BootstrapShellAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Business shell bootstrap failed; rendering login as fallback.");
            ShellState.ClearAuthenticatedSession();
        }
        finally
        {
            _isShellReady = true;
            StateHasChanged();
        }
    }

    private async Task BootstrapShellAsync()
    {
        try
        {
            await ThemeService.InitializeInteractiveAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Theme initialization failed; continuing with default theme.");
        }

        if (!ShellState.IsAuthenticated)
        {
            await TryResumeStoredSessionAsync();
        }

        if (ShellState.IsAuthenticated)
        {
            await LoadSessionContextAsync();
            if (IsHomeRoute || IsLoginRoute)
            {
                NavigationManager.NavigateTo("dashboard");
            }
        }
        else if (!IsLoginRoute)
        {
            NavigationManager.NavigateTo(string.Empty);
        }
    }

    private async Task TryResumeStoredSessionAsync()
    {
        string? storedToken;
        try
        {
            storedToken = await JS.InvokeAsync<string?>("citusBusinessAuth.getSessionToken");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "citusBusinessAuth interop unavailable; treating user as signed out.");
            return;
        }

        if (string.IsNullOrWhiteSpace(storedToken))
        {
            return;
        }

        var session = await BusinessAuthenticationClient.ResumeSessionAsync(storedToken);
        if (session is not null)
        {
            ShellState.ApplyAuthenticatedSession(storedToken, session);

            // Merge the per-user display-name override so a renamed user
            // sees their preferred name immediately on every reload.
            // Failures are best-effort — auth summary stays as the
            // authoritative fallback.
            var profileOverride = await BusinessAuthenticationClient.GetProfileOverrideAsync();
            if (profileOverride is not null && !string.IsNullOrWhiteSpace(profileOverride.DisplayName))
            {
                ShellState.UpdateUserDisplayName(profileOverride.DisplayName);
            }
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("citusBusinessAuth.clearSessionToken");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Unable to clear stored business session token.");
        }

        ShellState.ClearAuthenticatedSession();
    }

    private async Task LoadSessionContextAsync()
    {
        _isContextLoading = true;

        try
        {
            var context = await BusinessSessionClient.GetContextAsync();
            if (context is null)
            {
                await Message.WarningAsync(
                    "Business session context is unavailable. The shell is showing the cached login session.");
                return;
            }

            ShellState.ApplySessionContext(context);

            // Pull the per-company module flags after the session is in
            // place so the nav menu can hide modules the company hasn't
            // switched on. Best-effort — if it fails the menu falls
            // back to "module disabled", which is the safer default.
            try
            {
                var flags = await ModuleFlagsClient.GetAsync();
                ShellState.ApplyModuleFlags(flags);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Module-flag fetch failed; nav menu defaults to module-off.");
            }
        }
        finally
        {
            _isContextLoading = false;
        }
    }

    private void ToggleCollapsed() => _collapsed = !_collapsed;
}
