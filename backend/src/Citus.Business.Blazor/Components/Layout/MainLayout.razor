@inject Citus.Business.Blazor.State.BusinessShellState ShellState
@inject Citus.Business.Blazor.Services.BusinessSessionClient BusinessSessionClient
@inject AntDesign.IMessageService Message
@inject IThemeService ThemeService

@inherits LayoutComponentBase

@*
    MainLayout — AntDesign Layout shell. The sider hosts the navigation
    menu, the header carries the company switcher and theme toggle,
    and the content area is where every page renders.
*@

<IconSpriteHost />
<AntDesign.AntContainer />

<AntDesign.Layout Class="citus-shell">
    <AntDesign.Sider Collapsible="true"
                     Collapsed="@_collapsed"
                     CollapsedChanged="OnCollapsedChanged"
                     Breakpoint="@AntDesign.BreakpointType.Lg"
                     Width="240"
                     CollapsedWidth="64"
                     Class="citus-shell__sider"
                     Theme="@AntDesign.SiderTheme.Light">
        <div class="citus-shell__brand">
            <CitusIcon Name="IconName.BuildingBank" Size="@(_collapsed ? IconSize.Action : IconSize.Display)" />
            @if (!_collapsed)
            {
                <span class="citus-shell__brand-text">Citus Business</span>
            }
        </div>
        <BusinessNavMenu Collapsed="@_collapsed" />
    </AntDesign.Sider>

    <AntDesign.Layout>
        <AntDesign.Header Class="citus-shell__header">
            <BusinessTopBar Collapsed="@_collapsed" OnToggle="ToggleCollapsed" />
        </AntDesign.Header>

        <AntDesign.Content Class="citus-shell__content">
            @if (_isContextLoading)
            {
                <div class="citus-shell__loading">
                    <AntDesign.Progress Type="@AntDesign.ProgressType.Line" Percent="100" Status="@AntDesign.ProgressStatus.Active" ShowInfo="false" />
                </div>
            }

            <CitusMaintenanceBanner State="ShellState.MaintenanceState" />
            <CitusCompanyAccessBanner Company="ShellState.ActiveCompany" />
            @Body
        </AntDesign.Content>
    </AntDesign.Layout>
</AntDesign.Layout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool _isContextLoading = true;
    private bool _collapsed;

    protected override async Task OnInitializedAsync()
    {
        var context = await BusinessSessionClient.GetContextAsync();

        if (context is null)
        {
            await Message.WarningAsync(
                "Business session context is unavailable. The shell is showing bootstrap values until Accounting API responds.");
        }
        else
        {
            ShellState.ApplySessionContext(context);
        }

        _isContextLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.InitializeInteractiveAsync();
        }
    }

    private void ToggleCollapsed() => _collapsed = !_collapsed;

    private void OnCollapsedChanged(bool collapsed) => _collapsed = collapsed;
}
