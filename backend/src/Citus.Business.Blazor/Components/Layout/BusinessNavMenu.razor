@*
    BusinessNavMenu — plain <nav> + Blazor NavLink, rendered from
    BusinessShellState's NavigationSections. Phase 8 of the UI library
    migration: the previous menu primitives are gone; the
    `.active` class that NavLink toggles drives the selected style via
    shell.css's .citus-nav-menu__link.active rule.

    Batch 6: items carrying a ModuleKey are filtered against
    ShellState.ModuleFlags. A section whose items all fail the filter
    is suppressed entirely so the sidebar doesn't show empty headers.

    2026-05-25: subscribe to ShellState.OnChanged so toggling a module
    flag (Settings → Optional Modules) or switching companies updates
    the sidebar live, without a page refresh. The previous behaviour
    relied on accidental re-renders from elsewhere — CreateNewButton
    happened to refresh on each <details> click but this nav did not.
*@

@implements IDisposable

@inject Citus.Business.Blazor.State.BusinessShellState ShellState

<nav class="citus-nav-menu @(Collapsed ? "citus-nav-menu--collapsed" : null)">
    @foreach (var navSection in ShellState.NavigationSections)
    {
        var visibleItems = navSection.Items
            .Where(item => string.IsNullOrEmpty(item.ModuleKey) || ShellState.IsModuleEnabled(item.ModuleKey))
            .ToArray();

        if (visibleItems.Length == 0)
        {
            continue;
        }

        <div class="citus-nav-menu__group">
            <button type="button"
                    class="citus-nav-menu__group-title"
                    aria-expanded="@(!IsCollapsed(navSection.Title))"
                    @onclick="() => ToggleSection(navSection.Title)">
                <span class="citus-nav-menu__group-title-text">@navSection.Title</span>
                <span class="citus-nav-menu__group-chevron">
                    <CitusIcon Name="@(IsCollapsed(navSection.Title) ? IconName.ChevronRight : IconName.ChevronDown)" Size="IconSize.Inline" />
                </span>
            </button>
            @if (!IsCollapsed(navSection.Title))
            {
                <ul class="citus-nav-menu__items">
                    @foreach (var item in visibleItems)
                    {
                        <li>
                            <NavLink class="citus-nav-menu__link"
                                     href="@item.Href"
                                     Match="NavLinkMatch.Prefix">
                                <CitusIcon Name="item.Icon" Size="IconSize.Action" />
                                <span class="citus-nav-menu__label">@item.Title</span>
                            </NavLink>
                        </li>
                    }
                </ul>
            }
        </div>
    }
</nav>

@code {
    [Parameter] public bool Collapsed { get; set; }

    protected override void OnInitialized()
    {
        ShellState.OnChanged += HandleShellChanged;
    }

    public void Dispose()
    {
        ShellState.OnChanged -= HandleShellChanged;
    }

    private void HandleShellChanged() => InvokeAsync(StateHasChanged);

    // Per-section collapse state, keyed by section title. Held in memory so it
    // persists while navigating (this nav lives in the persistent layout) and
    // resets to all-expanded on a full page reload.
    private readonly HashSet<string> _collapsedSections = new();

    private bool IsCollapsed(string title) => _collapsedSections.Contains(title);

    private void ToggleSection(string title)
    {
        if (!_collapsedSections.Add(title))
        {
            _collapsedSections.Remove(title);
        }
    }
}
