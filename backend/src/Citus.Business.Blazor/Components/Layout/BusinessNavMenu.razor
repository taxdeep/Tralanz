@*
    BusinessNavMenu — AntDesign Menu rendered from BusinessShellState's
    NavigationSections. Each NavSection becomes a collapsible group; each
    NavMenuItem is a Tabler-iconed link. The selected key reflects the
    current route so menu state survives soft navigation.
*@

@inject NavigationManager NavigationManager
@inject Citus.Business.Blazor.State.BusinessShellState ShellState
@implements IDisposable

<AntDesign.Menu Mode="@AntDesign.MenuMode.Inline"
                Theme="@AntDesign.MenuTheme.Light"
                SelectedKeys="@SelectedKeys"
                DefaultOpenKeys="@OpenKeys"
                InlineCollapsed="Collapsed"
                Class="citus-nav-menu">
    @foreach (var section in ShellState.NavigationSections)
    {
        <AntDesign.MenuItemGroup Title="@section.Title" Key="@($"group-{section.Title}")">
            @foreach (var item in section.Items)
            {
                <AntDesign.MenuItem Key="@item.Href" RouterLink="@($"./{item.Href}")" RouterMatch="@NavLinkMatch.Prefix">
                    <span class="citus-nav-menu__item">
                        <CitusIcon Name="item.Icon" Size="IconSize.Action" />
                        <span class="citus-nav-menu__label">@item.Title</span>
                    </span>
                </AntDesign.MenuItem>
            }
        </AntDesign.MenuItemGroup>
    }
</AntDesign.Menu>

@code {
    [Parameter] public bool Collapsed { get; set; }

    private string[] SelectedKeys { get; set; } = Array.Empty<string>();

    private string[] OpenKeys =>
        ShellState.NavigationSections.Select(s => $"group-{s.Title}").ToArray();

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
        UpdateSelectedKeys();
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs args)
    {
        UpdateSelectedKeys();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateSelectedKeys()
    {
        var path = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim('/');
        if (string.IsNullOrEmpty(path))
        {
            SelectedKeys = ["dashboard"];
            return;
        }

        var matched = ShellState.NavigationSections
            .SelectMany(s => s.Items)
            .Where(item => path.StartsWith(item.Href, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(item => item.Href.Length)
            .FirstOrDefault();

        SelectedKeys = matched is null ? Array.Empty<string>() : [matched.Href];
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }
}
