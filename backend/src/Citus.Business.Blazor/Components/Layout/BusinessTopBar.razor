@*
    BusinessTopBar — header strip rendered inside the AntDesign Layout.
    Three slots from left to right:
      1. drawer toggle (only visible when the Sider is collapsible)
      2. company switcher + read-only badge
      3. theme toggle + user dropdown
    Bell-/notifications-style buttons stay out of P1 — they belong to
    later phases.
*@

@using Citus.Modules.UnitySearch.Blazor
@using Citus.Modules.UnitySearch.Domain.Shared
@inject NavigationManager NavigationManager
@inject Citus.Business.Blazor.State.BusinessShellState ShellState
@inject Citus.Business.Blazor.Services.BusinessSessionClient BusinessSessionClient
@inject Citus.Business.Blazor.Services.BusinessAuthenticationClient BusinessAuthenticationClient
@inject CitusToastService Message
@inject IJSRuntime JS

<div class="citus-topbar">
    <button type="button"
            class="citus-topbar__drawer-toggle"
            aria-label="Toggle navigation"
            @onclick="OnToggle">
        <CitusIcon Name="@(Collapsed ? IconName.Menu2 : IconName.Menu2)" Size="IconSize.Action" />
    </button>

    <div class="citus-topbar__company">
        <CitusIcon Name="IconName.BuildingSkyscraper" Size="IconSize.Inline" />
        <RadzenDropDown TValue="Guid"
                        Data="@ShellState.AvailableCompanies"
                        Value="@SelectedCompanyId"
                        ValueChanged="OnCompanyChangedAsync"
                        ValueProperty="Id"
                        Disabled="@IsCompanySwitcherDisabled"
                        Style="min-width: 220px;">
            <Template Context="ctx">
                @FormatCompanyLabel((BusinessCompanySummary)ctx)
            </Template>
        </RadzenDropDown>

        @if (ShellState.IsCompanyReadOnly)
        {
            <CitusBadge Color="@("orange")" Class="citus-topbar__readonly">
                Read-only
            </CitusBadge>
        }
    </div>

    <div class="citus-topbar__search">
        <UnitySearchPicker CompanyId="@ShellState.ActiveCompany.Id"
                           UserId="@(ShellState.User.Id == Guid.Empty ? null : ShellState.User.Id)"
                           Context="@SearchScopeContext.GlobalTopbar"
                           Placeholder="Search anything…"
                           Take="8"
                           SourceRoute="@NavigationManager.Uri"
                           OnOptionSelected="OnGlobalSearchSelected" />
    </div>

    <div class="citus-topbar__actions">
        <ThemeToggle />

        <details class="citus-popover citus-user-menu">
            <summary class="citus-topbar__user">
                <span class="citus-topbar__avatar">@AvatarInitials</span>
                <span class="citus-topbar__user-text">
                    <span class="citus-topbar__user-name">@ShellState.User.DisplayName</span>
                    @* Role/permissions line intentionally omitted: User.Roles
                       carries the company-membership permissions array (e.g.
                       "ap", "approve", "ar") whose alphabetical-first entry
                       isn't a meaningful user-facing label. Re-introduce a
                       proper "Owner" / "Admin" / "Member" badge once the API
                       session summary exposes membership.role separately. *@
                </span>
                <CitusIcon Name="IconName.ChevronDown" Size="IconSize.Inline" />
            </summary>
            <div class="citus-user-menu__panel">
                <div class="citus-user-menu__head">
                    <strong>@ShellState.User.DisplayName</strong>
                    <div class="citus-topbar__user-meta">@ShellState.User.Email</div>
                </div>
                <a class="citus-user-menu__item" href="account/profile">
                    <CitusIcon Name="IconName.User" Size="IconSize.Inline" />
                    <span>Profile</span>
                </a>
                <a class="citus-user-menu__item" href="account/companies">
                    <CitusIcon Name="IconName.BuildingSkyscraper" Size="IconSize.Inline" />
                    <span>My Companies</span>
                </a>
                <a class="citus-user-menu__item" href="session">
                    <CitusIcon Name="IconName.Activity" Size="IconSize.Inline" />
                    <span>Session</span>
                </a>
                <div class="citus-user-menu__divider"></div>
                <button type="button"
                        class="citus-user-menu__item citus-user-menu__item--danger"
                        @onclick="OnSignOutAsync">
                    <CitusIcon Name="IconName.Logout" Size="IconSize.Inline" />
                    <span>Sign out</span>
                </button>
            </div>
        </details>
    </div>
</div>

@code {
    [Parameter] public bool Collapsed { get; set; }

    [Parameter] public EventCallback OnToggle { get; set; }

    private Guid SelectedCompanyId => ShellState.ActiveCompany.Id;

    private bool IsCompanySwitcherDisabled => ShellState.AvailableCompanies.Count <= 1;

    private string AvatarInitials
    {
        get
        {
            var name = ShellState.User.DisplayName?.Trim();
            if (string.IsNullOrEmpty(name)) return "?";
            var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            return parts.Length switch
            {
                0 => "?",
                1 => parts[0][..1].ToUpperInvariant(),
                _ => $"{parts[0][..1]}{parts[^1][..1]}".ToUpperInvariant()
            };
        }
    }

    private static string FormatCompanyLabel(BusinessCompanySummary company)
    {
        // Entity number / company code intentionally omitted from the topbar
        // label: it's metadata, surfaced in Settings → Company Profile, not
        // something the operator needs to read on every page navigation. The
        // read-only badge stays because it gates write actions.
        var suffix = company.IsReadOnly ? " · read-only" : string.Empty;
        return $"{company.CompanyName}{suffix}";
    }

    private async Task OnSignOutAsync()
    {
        // Best-effort backend revocation. Bootstrap sessions short-circuit
        // inside the auth client; real sessions hit /accounting/auth/logout.
        try
        {
            await BusinessAuthenticationClient.SignOutAsync(ShellState.SessionToken);
        }
        catch (Exception)
        {
            // Sign-out must always succeed locally even if the backend can't
            // be reached — clearing client state is the user-visible promise.
        }

        try
        {
            await JS.InvokeVoidAsync("citusBusinessAuth.clearSessionToken");
        }
        catch (Exception)
        {
            // sessionStorage clear failed — proceed; the next page load will
            // not find a token and the auth gate will redirect to login.
        }

        ShellState.ClearAuthenticatedSession();
        await Message.InfoAsync("Signed out.");
        NavigationManager.NavigateTo(string.Empty);
    }

    private void OnGlobalSearchSelected(UnitySearchPickerOption option)
    {
        // Trust the backend-provided NavigationHref; the unitysearch
        // policy registry already enforced company / permission scope
        // before this row reached the client. The picker's usage event
        // (select) has already been fire-and-forgotten by the picker.
        if (string.IsNullOrWhiteSpace(option.NavigationHref))
        {
            return;
        }

        NavigationManager.NavigateTo(option.NavigationHref);
    }

    private async Task OnCompanyChangedAsync(Guid companyId)
    {
        if (companyId == Guid.Empty || companyId == ShellState.ActiveCompany.Id)
        {
            return;
        }

        var previousCompanyId = ShellState.ActiveCompany.Id;
        if (!ShellState.TrySetActiveCompany(companyId))
        {
            await Message.WarningAsync("The selected company is not available in this business session.");
            return;
        }

        var context = await BusinessSessionClient.GetContextAsync();
        if (context is null)
        {
            ShellState.TrySetActiveCompany(previousCompanyId);
            await Message.WarningAsync("Unable to refresh the business session after switching company.");
            return;
        }

        ShellState.ApplySessionContext(context);
        await Message.SuccessAsync($"Active company switched to {context.ActiveCompany.CompanyName}.");
        NavigationManager.NavigateTo("dashboard");
    }
}
