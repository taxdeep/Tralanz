@*
    SysAdminTopBar — header for the authenticated SysAdmin shell. The
    company switcher only renders when business is ready and there are
    workspaces; otherwise the header keeps a clean operator + theme +
    logout layout.
*@

@inject NavigationManager NavigationManager
@inject Citus.SysAdmin.Blazor.State.AppShellState ShellState
@inject Citus.SysAdmin.Blazor.Services.SysAdminAuthenticationClient SysAdminAuthenticationClient
@inject Citus.SysAdmin.Blazor.Services.SysAdminControlClient SysAdminControlClient
@inject IJSRuntime JS
@inject CitusToastService Message

@if (ShellState.IsAuthenticated)
{
    <div class="citus-topbar">
        <button type="button"
                class="citus-topbar__drawer-toggle"
                aria-label="Toggle navigation"
                @onclick="OnToggle">
            <CitusIcon Name="IconName.Menu2" Size="IconSize.Action" />
        </button>

        @if (ShowCompanySwitcher)
        {
            <div class="citus-topbar__company">
                <CitusIcon Name="IconName.BuildingSkyscraper" Size="IconSize.Inline" />
                <RadzenDropDown TValue="CompanyId"
                                Data="@ShellState.AvailableCompanies"
                                Value="@SelectedCompanyId"
                                ValueChanged="OnCompanyChangedAsync"
                                ValueProperty="Id"
                                Style="min-width: 220px;">
                    <Template Context="ctx">
                        @{
                            var c = (CompanyWorkspaceSummary)ctx;
                        }
                        @c.CompanyName (@c.CompanyCode)
                    </Template>
                </RadzenDropDown>
            </div>
        }
        else
        {
            <div class="citus-topbar__company">
                <CitusIcon Name="IconName.ShieldLock" Size="IconSize.Inline" />
                <span class="citus-topbar__platform-label">Platform Control</span>
            </div>
        }

        <div class="citus-topbar__spacer"></div>

        <div class="citus-topbar__actions">
            <ThemeToggle />

            <details class="citus-user-menu">
                <summary class="citus-topbar__user">
                    <span class="citus-topbar__avatar">@AvatarInitials</span>
                    <span class="citus-topbar__user-text">
                        <span class="citus-topbar__user-name">@ShellState.Operator.DisplayName</span>
                        <span class="citus-topbar__user-role">@PrimaryRole</span>
                    </span>
                    <CitusIcon Name="IconName.ChevronDown" Size="IconSize.Inline" />
                </summary>
                <div class="citus-user-menu__panel">
                    <div class="citus-user-menu__head">
                        <strong>@ShellState.Operator.DisplayName</strong>
                        <div class="citus-topbar__user-meta">@ShellState.Operator.Email</div>
                    </div>
                    <a class="citus-user-menu__item" href="security">
                        <CitusIcon Name="IconName.ShieldLock" Size="IconSize.Inline" />
                        <span>Security</span>
                    </a>
                    <div class="citus-user-menu__divider"></div>
                    <button type="button"
                            class="citus-user-menu__item citus-user-menu__item--danger"
                            @onclick="SignOutAsync">
                        <CitusIcon Name="IconName.Logout" Size="IconSize.Inline" />
                        <span>Log out</span>
                    </button>
                </div>
            </details>
        </div>
    </div>
}

@code {
    [Parameter] public bool Collapsed { get; set; }

    [Parameter] public EventCallback OnToggle { get; set; }

    private string PrimaryRole => ShellState.Operator.Roles.FirstOrDefault() ?? "sysadmin";

    private bool ShowCompanySwitcher =>
        ShellState.BusinessReady && ShellState.AvailableCompanies.Count > 0;

    private CompanyId SelectedCompanyId => ShellState.ActiveCompany.CompanyId ?? default;

    private string AvatarInitials
    {
        get
        {
            var name = ShellState.Operator.DisplayName?.Trim();
            if (string.IsNullOrEmpty(name)) return "?";
            var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            return parts.Length switch
            {
                0 => "?",
                1 => parts[0][..1].ToUpperInvariant(),
                _ => $"{parts[0][..1]}{parts[^1][..1]}".ToUpperInvariant()
            };
        }
    }

    private async Task OnCompanyChangedAsync(CompanyId companyId)
    {
        if (companyId.Value is null || companyId == ShellState.ActiveCompany.CompanyId)
        {
            return;
        }

        var context = await SysAdminControlClient.SetActiveCompanyAsync(companyId);
        if (context is null)
        {
            await Message.WarningAsync("Unable to switch the active company context.");
            return;
        }

        ShellState.ApplyControlContext(context);
        await Message.SuccessAsync($"Active company switched to {context.ActiveCompany.CompanyName}.");
        NavigationManager.NavigateTo("overview");
    }

    private async Task SignOutAsync()
    {
        await SysAdminAuthenticationClient.SignOutAsync(ShellState.SessionToken);
        await JS.InvokeVoidAsync("citusSysAdminAuth.clearSessionToken");
        ShellState.ClearAuthenticatedSession();
        await Message.SuccessAsync("SysAdmin session ended.");
        NavigationManager.NavigateTo("login", forceLoad: true);
    }
}
