@*
    SysAdminNavMenu — plain <nav> + Blazor NavLink, rendered from
    AppShellState's NavigationSections. Phase 8 of the UI library
    migration: AntDesign Menu / MenuItemGroup / MenuItem are gone.
*@

@inject Citus.SysAdmin.Blazor.State.AppShellState ShellState

<nav class="citus-nav-menu @(Collapsed ? "citus-nav-menu--collapsed" : null)">
    @foreach (var navSection in ShellState.NavigationSections)
    {
        <div class="citus-nav-menu__group">
            <div class="citus-nav-menu__group-title">@navSection.Title</div>
            <ul class="citus-nav-menu__items">
                @foreach (var item in navSection.Items)
                {
                    <li>
                        <NavLink class="citus-nav-menu__link"
                                 href="@item.Href"
                                 Match="NavLinkMatch.Prefix">
                            <CitusIcon Name="item.Icon" Size="IconSize.Action" />
                            <span class="citus-nav-menu__label">@item.Title</span>
                        </NavLink>
                    </li>
                }
            </ul>
        </div>
    }
</nav>

@code {
    [Parameter] public bool Collapsed { get; set; }
}
