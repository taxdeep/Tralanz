@page "/login"

@inject AppShellState ShellState
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject CitusToastService Message
@inject SysAdminAuthenticationClient SysAdminAuthenticationClient
@inject SysAdminControlClient SysAdminControlClient

<PageTitle>Login | Tralanz SysAdmin</PageTitle>

<div class="sys-login">
    <header class="sys-login__bar">
        <span class="sys-login__bar-title">
            <CitusIcon Name="IconName.ShieldLock" Size="IconSize.Inline" />
            SysAdmin Login
        </span>
        <span class="sys-login__bar-meta">PlatformOps</span>
    </header>

    @if (_isLoadingSetup)
    {
        <CitusLoadingBar />
    }

    <div class="sys-login__body">
        <div class="sys-login__crest" aria-hidden="true">
            <CitusIcon Name="IconName.ShieldLock" Size="IconSize.Display" />
        </div>

        @if (_setupStatus?.SetupRequired == true)
        {
            <div class="sys-login__heading">
                <h1 class="sys-login__title">Create first SysAdmin</h1>
                <p class="text-fg-muted text-sm">
                    No SysAdmin operator exists yet. Provision the independent platform admin before protected control surfaces can be used.
                </p>
            </div>

            <CitusAlert Severity="CitusAlertSeverity.Warning"
                             ShowIcon="true"
                             Message="This is the governed first-use setup path. Keep SysAdmin separate from business users."
                             Class="mt-4" />

            <div class="sys-login__rule"></div>

            <form class="sys-login__form flex flex-col gap-3 mt-4" @onsubmit="ProvisionFirstAccountAsync" @onsubmit:preventDefault>
                <label class="citus-form-field">
                    <span class="citus-form-field__label">Display name</span>
                    <input type="text"
                           class="citus-form-field__input"
                           autocomplete="name"
                           value="@_setupDisplayName"
                           @oninput="OnSetupDisplayNameChanged"
                           disabled="@_isSubmitting" />
                </label>
                <label class="citus-form-field">
                    <span class="citus-form-field__label">Email</span>
                    <input type="email"
                           class="citus-form-field__input"
                           autocomplete="username"
                           value="@_setupEmail"
                           @oninput="OnSetupEmailChanged"
                           disabled="@_isSubmitting" />
                </label>
                <label class="citus-form-field">
                    <span class="citus-form-field__label">Password</span>
                    <input type="password"
                           class="citus-form-field__input"
                           autocomplete="new-password"
                           value="@_setupPassword"
                           @oninput="OnSetupPasswordChanged"
                           disabled="@_isSubmitting" />
                </label>
                <label class="citus-form-field">
                    <span class="citus-form-field__label">Confirm password</span>
                    <input type="password"
                           class="citus-form-field__input"
                           autocomplete="new-password"
                           value="@_setupPasswordConfirm"
                           @oninput="OnSetupPasswordConfirmChanged"
                           disabled="@_isSubmitting" />
                </label>
                <CitusButton Variant="CitusButtonVariant.Primary"
                             Size="CitusButtonSize.Large"
                             Block="true"
                             HtmlType="@("submit")"
                             Disabled="_isSubmitting"
                             OnClick="ProvisionFirstAccountAsync">
                    @(_isSubmitting ? "Provisioning..." : "Create first SysAdmin")
                </CitusButton>
            </form>
        }
        else
        {
            <div class="sys-login__heading">
                <h1 class="sys-login__title">SysAdmin sign in</h1>
                <p class="text-fg-muted text-sm">
                    Independent platform governance session for maintenance, company lifecycle, and account control.
                </p>
            </div>

            @if (_setupStatus?.BootstrapSeedingActive == true)
            {
                <CitusAlert Severity="CitusAlertSeverity.Info"
                                 ShowIcon="true"
                                 Message="@($"Development bootstrap seeding is active for `{_setupStatus.BootstrapEmailHint}`. Use it only as a local bootstrap path and rotate the secret immediately after sign-in.")"
                                 Class="mt-4" />
            }

            <div class="sys-login__rule"></div>

            <form class="sys-login__form flex flex-col gap-3 mt-4" @onsubmit="SignInAsync" @onsubmit:preventDefault>
                <label class="citus-form-field">
                    <span class="citus-form-field__label">Email</span>
                    <input type="email"
                           class="citus-form-field__input"
                           autocomplete="username"
                           value="@_email"
                           @oninput="OnEmailChanged"
                           disabled="@_isSubmitting" />
                </label>
                <label class="citus-form-field">
                    <span class="citus-form-field__label">Password</span>
                    <input type="password"
                           class="citus-form-field__input"
                           autocomplete="current-password"
                           value="@_password"
                           @oninput="OnPasswordChanged"
                           disabled="@_isSubmitting" />
                </label>
                <CitusButton Variant="CitusButtonVariant.Primary"
                             Size="CitusButtonSize.Large"
                             Block="true"
                             HtmlType="@("submit")"
                             Disabled="_isSubmitting"
                             OnClick="SignInAsync">
                    @(_isSubmitting ? "Signing in..." : "Sign in")
                </CitusButton>
            </form>
        }
    </div>

    <footer class="sys-login__switcher">
        <span class="text-fg-muted text-xs">Not the correct login?</span>
        <a href="/login" class="citus-link">Login as business user</a>
    </footer>
</div>

@code {
    private SysAdminAuthenticationClient.SetupStatusResponse? _setupStatus;
    private string _email = "sysadmin@tralanz.local";
    private string _password = "change-me-now";
    private string _setupDisplayName = "Platform Administrator";
    private string _setupEmail = "sysadmin@tralanz.local";
    private string _setupPassword = string.Empty;
    private string _setupPasswordConfirm = string.Empty;
    private bool _isSubmitting;
    private bool _isLoadingSetup = true;

    private void OnEmailChanged(ChangeEventArgs args) =>
        _email = args.Value?.ToString() ?? string.Empty;

    private void OnPasswordChanged(ChangeEventArgs args) =>
        _password = args.Value?.ToString() ?? string.Empty;

    private void OnSetupDisplayNameChanged(ChangeEventArgs args) =>
        _setupDisplayName = args.Value?.ToString() ?? string.Empty;

    private void OnSetupEmailChanged(ChangeEventArgs args) =>
        _setupEmail = args.Value?.ToString() ?? string.Empty;

    private void OnSetupPasswordChanged(ChangeEventArgs args) =>
        _setupPassword = args.Value?.ToString() ?? string.Empty;

    private void OnSetupPasswordConfirmChanged(ChangeEventArgs args) =>
        _setupPasswordConfirm = args.Value?.ToString() ?? string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadSetupStateAsync();
    }

    private async Task LoadSetupStateAsync()
    {
        _isLoadingSetup = true;

        try
        {
            _setupStatus = await SysAdminAuthenticationClient.GetSetupStatusAsync();
            if (_setupStatus is not null && !string.IsNullOrWhiteSpace(_setupStatus.BootstrapEmailHint))
            {
                _email = _setupStatus.BootstrapEmailHint;
                _setupEmail = _setupStatus.BootstrapEmailHint;
            }
        }
        finally
        {
            _isLoadingSetup = false;
        }
    }

    private async Task ProvisionFirstAccountAsync()
    {
        if (string.IsNullOrWhiteSpace(_setupDisplayName) || string.IsNullOrWhiteSpace(_setupEmail) || string.IsNullOrWhiteSpace(_setupPassword))
        {
            await Message.WarningAsync("Display name, email, and password are required.");
            return;
        }

        if (!string.Equals(_setupPassword, _setupPasswordConfirm, StringComparison.Ordinal))
        {
            await Message.WarningAsync("Password confirmation does not match.");
            return;
        }

        _isSubmitting = true;

        try
        {
            var outcome = await SysAdminAuthenticationClient.ProvisionFirstAccountAsync(
                _setupEmail,
                _setupDisplayName,
                _setupPassword);

            if (!outcome.Succeeded)
            {
                await Message.WarningAsync(outcome.Message);
                return;
            }

            await Message.SuccessAsync("First SysAdmin operator provisioned.");
            _email = _setupEmail;
            _password = _setupPassword;
            _setupPassword = string.Empty;
            _setupPasswordConfirm = string.Empty;

            await LoadSetupStateAsync();
            await SignInAsync();
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task SignInAsync()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            await Message.WarningAsync("Email and password are required.");
            return;
        }

        _isSubmitting = true;

        try
        {
            var response = await SysAdminAuthenticationClient.SignInAsync(_email, _password);
            if (response is null || string.IsNullOrWhiteSpace(response.SessionToken))
            {
                await Message.WarningAsync("Unable to sign in. Check the SysAdmin secret and account status.");
                return;
            }

            ShellState.ApplyAuthenticatedSession(response.SessionToken, response.Session);
            await JS.InvokeVoidAsync("citusSysAdminAuth.setSessionToken", response.SessionToken);

            var setupStatus = await SysAdminAuthenticationClient.GetSetupStatusAsync();
            if (setupStatus is not null)
            {
                _setupStatus = setupStatus;
                ShellState.ApplySetupStatus(setupStatus);
            }

            var context = await SysAdminControlClient.GetContextAsync();
            if (context is not null)
            {
                ShellState.ApplyControlContext(context);
            }

            await Message.SuccessAsync($"Welcome back, {response.Session.DisplayName}.");
            NavigationManager.NavigateTo(GetPostSignInRoute());
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private string GetPostSignInRoute()
    {
        if (_setupStatus?.FirstCompanySetupRequired == true)
        {
            return _setupStatus.HasAnyCompany
                ? "setup/first-company"
                : "setup/company-decision";
        }

        return "overview";
    }
}
