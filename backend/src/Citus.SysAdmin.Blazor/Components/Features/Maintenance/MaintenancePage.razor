@page "/maintenance"

@inject AppShellState ShellState
@inject AntDesign.IMessageService Message
@inject SysAdminControlClient SysAdminControlClient

<PageTitle>Maintenance | Citus SysAdmin</PageTitle>

<CitusPageHeader Model="_header" />

<section class="citus-panel mb-6 max-w-3xl">
    <h2 class="citus-panel__title">Current maintenance state</h2>

    <div class="flex flex-col gap-3">
        <div class="flex items-center gap-3">
            <AntDesign.Switch @bind-Value="_enabled" />
            <span class="text-sm">@(_enabled ? "Maintenance enabled" : "Maintenance disabled")</span>
        </div>

        <div class="flex flex-col gap-1">
            <span class="text-sm font-medium">Operator message</span>
            <AntDesign.TextArea @bind-Value="_message" Rows="3" />
            <span class="text-fg-subtle text-xs">This message is shown across the SysAdmin shell when maintenance mode is active.</span>
        </div>

        <CitusInput TValue="string" @bind-Value="_scheduledUntilInput"
                    Placeholder="Planned until (UTC, optional)"
                    HelperText="Use an ISO-like value such as 2026-04-14 02:00:00Z." />

        <div class="flex items-center gap-2">
            <CitusButton Variant="CitusButtonVariant.Primary" Disabled="@_isSavingMaintenance" OnClick="SaveMaintenanceAsync">
                @(_isSavingMaintenance ? "Saving..." : "Save maintenance state")
            </CitusButton>
            <CitusButton Variant="CitusButtonVariant.Link" Disabled="@_isSavingMaintenance" OnClick="ResetMaintenanceFromShellState">Reset</CitusButton>
        </div>
    </div>
</section>

<section class="citus-panel mb-6 max-w-3xl">
    <div class="mb-3">
        <h2 class="citus-panel__title">Notification Readiness</h2>
        <p class="text-fg-muted text-sm">
            Secure email and password flows must be blocked until configuration exists, test send passes, and verification readiness is explicitly true.
        </p>
    </div>

    @if (_notificationReadiness is not null)
    {
        <AntDesign.Alert Type="@(_notificationReadiness.IsVerificationDeliveryReady ? AntDesign.AlertType.Success : AntDesign.AlertType.Warning)"
                         ShowIcon="true"
                         Message="@(_notificationReadiness.IsVerificationDeliveryReady ? "Verification delivery is ready." : "Verification delivery is blocked.")"
                         Class="mb-3" />

        @if (!string.IsNullOrWhiteSpace(_notificationReadiness.BlockingReason))
        {
            <AntDesign.Alert Type="@AntDesign.AlertType.Info" Message="@_notificationReadiness.BlockingReason" ShowIcon="true" Class="mb-3" />
        }

        @if (!string.IsNullOrWhiteSpace(_notificationReadiness.ConfigurationError))
        {
            <AntDesign.Alert Type="@AntDesign.AlertType.Warning" Message="@($"Provider configuration issue: {_notificationReadiness.ConfigurationError}")" ShowIcon="true" Class="mb-3" />
        }
    }

    <div class="flex flex-col gap-3">
        <div class="flex items-center gap-3">
            <AntDesign.Switch @bind-Value="_notificationConfigPresent" />
            <span class="text-sm">@(_notificationConfigPresent ? "Notification config present" : "Notification config missing")</span>
        </div>

        <div class="flex flex-col gap-1">
            <span class="text-sm font-medium">Test status</span>
            <AntDesign.Select TItem="string" TItemValue="string"
                              DataSource="@_testStatusOptions"
                              Value="@_notificationTestStatus"
                              ValueChanged="@(s => _notificationTestStatus = s ?? "untested")"
                              ItemValue="@(s => s)"
                              ItemLabel="@(s => s)" />
        </div>

        <CitusInput TValue="string" @bind-Value="_notificationLastTestedInput"
                    Placeholder="Last tested at (UTC, optional)"
                    HelperText="Use an ISO-like value such as 2026-04-14 02:00:00Z." />

        <div class="flex items-center gap-3">
            <AntDesign.Switch @bind-Value="_notificationVerificationReady" />
            <span class="text-sm">@(_notificationVerificationReady ? "Verification ready" : "Verification not ready")</span>
        </div>

        <div class="flex items-center gap-2">
            <CitusButton Variant="CitusButtonVariant.Primary" Disabled="@_isSavingNotificationReadiness" OnClick="SaveNotificationReadinessAsync">
                @(_isSavingNotificationReadiness ? "Saving..." : "Save notification readiness")
            </CitusButton>
            <CitusButton Variant="CitusButtonVariant.Link" Disabled="@_isSavingNotificationReadiness" OnClick="ResetNotificationReadinessAsync">Reset</CitusButton>
        </div>
    </div>

    <hr class="my-4 border-border" />

    <div class="flex flex-col gap-3">
        <h3 class="text-base font-semibold">Send Test Email</h3>
        <p class="text-fg-muted text-sm">
            This sends a real notification-provider test message without marking verification ready for business users.
        </p>

        <CitusInput TValue="string" @bind-Value="_notificationTestDestination"
                    Placeholder="Test destination email"
                    HelperText="Defaults to the current SysAdmin operator email." />

        <CitusButton Variant="CitusButtonVariant.Primary" Disabled="@_isSendingNotificationTest" OnClick="SendNotificationTestAsync">
            @(_isSendingNotificationTest ? "Sending..." : "Send notification test")
        </CitusButton>
    </div>
</section>

<section class="citus-panel max-w-3xl">
    <h2 class="citus-panel__title">Control rule</h2>
    <p class="text-fg-muted text-sm">
        Maintenance mode remains separate from business posting flows, while notification readiness now gates password reset issuance on the SysAdmin control plane.
    </p>
</section>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Operations",
        Title = "Maintenance",
        Subtitle = "Platform maintenance state and notification readiness."
    };

    private static readonly List<string> _testStatusOptions = new() { "untested", "passed", "failed" };

    private bool _enabled;
    private bool _isSavingMaintenance;
    private string _message = string.Empty;
    private string _scheduledUntilInput = string.Empty;

    private NotificationReadinessSummary? _notificationReadiness;
    private bool _notificationConfigPresent;
    private string _notificationTestStatus = "untested";
    private string _notificationLastTestedInput = string.Empty;
    private bool _notificationVerificationReady;
    private bool _isSavingNotificationReadiness;
    private string _notificationTestDestination = string.Empty;
    private bool _isSendingNotificationTest;

    protected override async Task OnInitializedAsync()
    {
        ResetMaintenanceFromShellState();
        await ResetNotificationReadinessAsync();
    }

    private void ResetMaintenanceFromShellState()
    {
        _enabled = ShellState.MaintenanceState.Enabled;
        _message = ShellState.MaintenanceState.Message;
        _scheduledUntilInput = ShellState.MaintenanceState.ScheduledUntilUtc?.ToString("u") ?? string.Empty;
    }

    private async Task ResetNotificationReadinessAsync()
    {
        _notificationReadiness = await SysAdminControlClient.GetNotificationReadinessAsync() ??
            new NotificationReadinessSummary
            {
                ConfigPresent = false,
                TestStatus = "untested",
                VerificationReady = false,
                IsVerificationDeliveryReady = false
            };

        _notificationConfigPresent = _notificationReadiness.ConfigPresent;
        _notificationTestStatus = _notificationReadiness.TestStatus;
        _notificationLastTestedInput = _notificationReadiness.LastTestedAtUtc?.ToString("u") ?? string.Empty;
        _notificationVerificationReady = _notificationReadiness.VerificationReady;
        if (string.IsNullOrWhiteSpace(_notificationTestDestination))
        {
            _notificationTestDestination = ShellState.Operator.Email;
        }
    }

    private async Task SaveMaintenanceAsync()
    {
        if (!TryParseDateTimeOffset(_scheduledUntilInput, out var scheduledUntilUtc))
        {
            await Message.WarningAsync("Planned until must be empty or parseable as a UTC date/time.");
            return;
        }

        _isSavingMaintenance = true;

        try
        {
            var state = await SysAdminControlClient.UpdateMaintenanceAsync(
                new MaintenanceUpdateRequest
                {
                    Enabled = _enabled,
                    Message = _message,
                    ScheduledUntilUtc = scheduledUntilUtc
                });

            if (state is null)
            {
                await Message.WarningAsync("Unable to update maintenance state.");
                return;
            }

            ShellState.SetMaintenanceState(state);
            ResetMaintenanceFromShellState();
            await Message.SuccessAsync("Maintenance state updated.");
        }
        finally
        {
            _isSavingMaintenance = false;
        }
    }

    private async Task SaveNotificationReadinessAsync()
    {
        if (!TryParseDateTimeOffset(_notificationLastTestedInput, out var lastTestedAtUtc))
        {
            await Message.WarningAsync("Last tested at must be empty or parseable as a UTC date/time.");
            return;
        }

        _isSavingNotificationReadiness = true;

        try
        {
            var readiness = await SysAdminControlClient.UpdateNotificationReadinessAsync(
                new NotificationReadinessUpdateRequest
                {
                    ConfigPresent = _notificationConfigPresent,
                    TestStatus = _notificationTestStatus,
                    LastTestedAtUtc = lastTestedAtUtc,
                    VerificationReady = _notificationVerificationReady
                });

            if (readiness is null)
            {
                await Message.WarningAsync("Unable to update notification readiness.");
                return;
            }

            _notificationReadiness = readiness;
            await ResetNotificationReadinessAsync();
            await Message.SuccessAsync("Notification readiness updated.");
        }
        finally
        {
            _isSavingNotificationReadiness = false;
        }
    }

    private async Task SendNotificationTestAsync()
    {
        _isSendingNotificationTest = true;

        try
        {
            var (result, error) = await SysAdminControlClient.SendNotificationTestAsync(
                new NotificationTestSendRequest
                {
                    Destination = _notificationTestDestination,
                    RecipientDisplayName = ShellState.Operator.DisplayName
                });

            if (!string.IsNullOrWhiteSpace(error))
            {
                await Message.WarningAsync(error);
                return;
            }

            if (result is null)
            {
                await Message.WarningAsync("Notification test send returned no result.");
                return;
            }

            _notificationReadiness = result.Readiness;
            _notificationConfigPresent = result.Readiness.ConfigPresent;
            _notificationTestStatus = result.Readiness.TestStatus;
            _notificationLastTestedInput = result.Readiness.LastTestedAtUtc?.ToString("u") ?? string.Empty;
            _notificationVerificationReady = result.Readiness.VerificationReady;

            if (result.Succeeded)
            {
                await Message.SuccessAsync($"Notification test sent to {result.Destination} via {result.ProviderKey}.");
            }
            else
            {
                await Message.ErrorAsync($"Notification test failed: {result.FailureMessage}");
            }
        }
        finally
        {
            _isSendingNotificationTest = false;
        }
    }

    private static bool TryParseDateTimeOffset(string input, out DateTimeOffset? value)
    {
        if (string.IsNullOrWhiteSpace(input))
        {
            value = null;
            return true;
        }

        if (DateTimeOffset.TryParse(input, out var parsed))
        {
            value = parsed;
            return true;
        }

        value = null;
        return false;
    }
}
