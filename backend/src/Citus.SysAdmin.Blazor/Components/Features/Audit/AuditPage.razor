@page "/audit"

@inject AppShellState ShellState
@inject NavigationManager NavigationManager
@inject CitusToastService Message
@inject SysAdminControlClient SysAdminControlClient

<PageTitle>Audit | Citus SysAdmin</PageTitle>

<CitusPageHeader Model="_header" />

@if (_isLoading)
{
    <div class="mb-4"><CitusLoadingBar /></div>
}

<CitusAlert Severity="CitusAlertSeverity.Info"
                 ShowIcon="true"
                 Message="This timeline is the formal governance read model for company status, platform account status, password reset requests, company membership changes, and account MFA governance."
                 Class="mb-4" />

<section class="citus-panel mb-6">
    <div class="mb-3">
        <h2 class="citus-panel__title">Account MFA Timeline</h2>
        <p class="text-fg-muted text-sm">
            Review one platform account's MFA mode changes, recovery request/review/execute actions, and emergency resets from the formal audit trail.
        </p>
    </div>

    @if (_users.Count == 0)
    {
        <CitusAlert Severity="CitusAlertSeverity.Info" Message="No managed users are available for account-scoped MFA audit review yet." ShowIcon="true" />
    }
    else
    {
        <div class="flex flex-wrap items-center gap-3 mb-3">
            <div class="min-w-[20rem]">
                <RadzenDropDown TValue="Guid?"
                                Data="@_users.OrderBy(u => u.DisplayName, StringComparer.OrdinalIgnoreCase).ToList()"
                                Value="@_selectedTimelineAccountId"
                                ValueChanged="OnSelectedTimelineAccountChangedAsync"
                                ValueProperty="Id"
                                Placeholder="Select account"
                                AllowClear="true"
                                Style="width: 100%;">
                    <Template Context="ctx">
                        @BuildUserOptionLabel((ManagedUserSummary)ctx)
                    </Template>
                </RadzenDropDown>
            </div>
            @if (_selectedTimelineUser is not null)
            {
                <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small" OnClick="ClearSelectedTimeline">Clear</CitusButton>
            }
        </div>

        @if (_selectedTimelineUser is not null)
        {
            <p class="text-fg-muted text-sm mb-3">
                @_selectedTimelineUser.DisplayName (@_selectedTimelineUser.Username | @_selectedTimelineUser.Email)
            </p>
        }

        @if (_isTimelineLoading)
        {
            <CitusLoadingBar />
        }
        else if (_selectedTimelineUser is not null && _selectedMfaTimeline.Count == 0)
        {
            <CitusAlert Severity="CitusAlertSeverity.Info" Message="No MFA governance events have been recorded for this account yet." ShowIcon="true" />
        }
        else if (_selectedMfaTimeline.Count > 0)
        {
            <div class="grid grid-cols-1 gap-3">
                @foreach (var entry in _selectedMfaTimeline)
                {
                    <article class="citus-subpanel">
                        <div class="flex flex-wrap items-start justify-between gap-3">
                            <div class="flex flex-col gap-1">
                                <div class="flex flex-wrap items-center gap-2">
                                    <CitusBadge Color="@MfaTimelineColor(entry.Action)">@entry.ActionLabel</CitusBadge>
                                    <CitusBadge Color="@("default")">
                                        @(string.IsNullOrWhiteSpace(entry.ActorDisplayName) ? entry.ActorType : entry.ActorDisplayName)
                                    </CitusBadge>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(entry.Detail))
                                {
                                    <span class="text-sm">@entry.Detail</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(entry.Reason))
                                {
                                    <span class="text-fg-subtle text-xs">Reason: @entry.Reason</span>
                                }
                            </div>
                            <span class="text-fg-subtle text-xs">@entry.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")</span>
                        </div>
                    </article>
                }
            </div>
        }
    }
</section>

@if (_events.Count == 0 && !_isLoading)
{
    <CitusEmptyState
        Icon="IconName.Report"
        Title="No governance audit events"
        Message="The SysAdmin audit surface has not returned any reviewable governance events yet."
        ActionLabel="Open users"
        ActionHref="users" />
}
else if (_events.Count > 0)
{
    <section class="citus-panel">
        <table class="citus-data-table">
            <thead>
                <tr>
                    <th>When</th>
                    <th>Scope</th>
                    <th>Action</th>
                    <th>Entity</th>
                    <th>Actor</th>
                    <th>Detail</th>
                    <th>Reason</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ev in _events)
                {
                    <tr>
                        <td>@ev.CreatedAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <CitusBadge Color="@(ev.CompanyId.HasValue ? "default" : "blue")">@ev.ScopeLabel</CitusBadge>
                        </td>
                        <td>
                            <CitusBadge Color="@ActionColor(ev.Action)">@ev.ActionLabel</CitusBadge>
                            <div class="text-fg-subtle text-xs">@ev.Action</div>
                        </td>
                        <td>
                            <div>@ev.EntityLabel</div>
                            <div class="text-fg-subtle text-xs">@ev.EntityType</div>
                        </td>
                        <td>
                            <div>@GetActorLabel(ev)</div>
                            <div class="text-fg-subtle text-xs">@ev.ActorType</div>
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(ev.Detail))
                            {
                                <div>@ev.Detail</div>
                            }
                            @if (ev.Highlights.Count > 0)
                            {
                                <div class="flex flex-wrap gap-1 mt-1">
                                    @foreach (var highlight in ev.Highlights)
                                    {
                                        <CitusBadge Color="@("default")">@highlight</CitusBadge>
                                    }
                                </div>
                            }
                        </td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(ev.Reason))
                            {
                                <span class="text-fg-subtle text-xs">No explicit reason</span>
                            }
                            else
                            {
                                <span>@ev.Reason</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    [SupplyParameterFromQuery(Name = "accountId")]
    public Guid? AccountId { get; set; }

    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Operations",
        Title = "Audit",
        Subtitle = "Review company, account, password-reset, membership, and MFA governance actions."
    };

    private bool _isLoading = true;
    private IReadOnlyList<PlatformAuditEventSummary> _events = Array.Empty<PlatformAuditEventSummary>();
    private IReadOnlyList<ManagedUserSummary> _users = Array.Empty<ManagedUserSummary>();
    private Guid? _selectedTimelineAccountId;
    private ManagedUserSummary? _selectedTimelineUser;
    private IReadOnlyList<PlatformMfaTimelineEntrySummary> _selectedMfaTimeline = Array.Empty<PlatformMfaTimelineEntrySummary>();
    private bool _isTimelineLoading;
    private Guid? _lastAppliedQueryAccountId;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_isLoading &&
            _users.Count > 0 &&
            _lastAppliedQueryAccountId != AccountId)
        {
            await ApplySelectedAccountAsync(AccountId, updateQuery: false);
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        try
        {
            var eventsTask = SysAdminControlClient.ListRecentAuditEventsAsync();
            var usersTask = SysAdminControlClient.ListUsersAsync();

            await Task.WhenAll(eventsTask, usersTask);

            _events = await eventsTask;
            _users = await usersTask;
            await ApplySelectedAccountAsync(AccountId, updateQuery: false);
        }
        catch (Exception ex)
        {
            await Message.WarningAsync($"Unable to load audit events. {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnSelectedTimelineAccountChangedAsync(Guid? accountId)
    {
        await ApplySelectedAccountAsync(accountId, updateQuery: true);
    }

    private async Task ApplySelectedAccountAsync(Guid? accountId, bool updateQuery)
    {
        _selectedTimelineAccountId = accountId;
        _lastAppliedQueryAccountId = accountId;

        if (updateQuery)
        {
            NavigationManager.NavigateTo(
                accountId.HasValue ? $"audit?accountId={accountId.Value}" : "audit",
                replace: true);
        }

        if (!accountId.HasValue)
        {
            ClearSelectedTimeline();
            return;
        }

        _selectedTimelineUser = _users.FirstOrDefault(user => user.Id == accountId.Value);

        if (_selectedTimelineUser is null)
        {
            _selectedMfaTimeline = Array.Empty<PlatformMfaTimelineEntrySummary>();
            return;
        }

        _isTimelineLoading = true;
        _selectedMfaTimeline = Array.Empty<PlatformMfaTimelineEntrySummary>();

        try
        {
            _selectedMfaTimeline = await SysAdminControlClient.ListAccountMfaTimelineAsync(accountId.Value);
        }
        catch (Exception ex)
        {
            await Message.WarningAsync($"Unable to load MFA timeline. {ex.Message}");
        }
        finally
        {
            _isTimelineLoading = false;
        }
    }

    private void ClearSelectedTimeline()
    {
        _selectedTimelineAccountId = null;
        _lastAppliedQueryAccountId = null;
        _selectedTimelineUser = null;
        _selectedMfaTimeline = Array.Empty<PlatformMfaTimelineEntrySummary>();
        _isTimelineLoading = false;
    }

    private static string BuildUserOptionLabel(ManagedUserSummary user) =>
        $"{user.DisplayName} ({user.Username} | {user.Email})";

    private static string ActionColor(string action) =>
        action switch
        {
            "company_status_changed" => "orange",
            "account_status_changed" => "orange",
            "password_reset_requested" => "blue",
            "password_reset_dispatched" => "green",
            "password_reset_dispatch_failed" => "red",
            "membership_role_changed" => "green",
            "membership_permissions_saved" => "geekblue",
            "sysadmin_first_account_created" => "blue",
            "sysadmin_password_rotated" => "orange",
            _ => "default"
        };

    private static string MfaTimelineColor(string? action) =>
        action switch
        {
            "account_totp_enrollment_started" => "blue",
            "account_totp_enrollment_confirmed" => "green",
            "profile_mfa_mode_saved" => "geekblue",
            "account_mfa_recovery_requested" => "orange",
            "account_mfa_recovery_approved" => "green",
            "account_mfa_recovery_rejected" => "red",
            "account_mfa_recovery_executed" => "default",
            "account_mfa_reset" => "orange",
            _ => "default"
        };

    private static string GetActorLabel(PlatformAuditEventSummary auditEvent)
    {
        if (!string.IsNullOrWhiteSpace(auditEvent.ActorDisplayName) &&
            !string.IsNullOrWhiteSpace(auditEvent.ActorEmail) &&
            !string.Equals(auditEvent.ActorDisplayName, auditEvent.ActorEmail, StringComparison.OrdinalIgnoreCase))
        {
            return $"{auditEvent.ActorDisplayName} ({auditEvent.ActorEmail})";
        }

        if (!string.IsNullOrWhiteSpace(auditEvent.ActorDisplayName))
        {
            return auditEvent.ActorDisplayName;
        }

        if (!string.IsNullOrWhiteSpace(auditEvent.ActorEmail))
        {
            return auditEvent.ActorEmail;
        }

        return "Unknown actor";
    }
}
