@page "/modules"

@inject PlatformCoreClient PlatformCoreClient

<PageTitle>Modules | Citus SysAdmin</PageTitle>

<CitusPageHeader Model="_header" />

@if (_isLoading)
{
    <div class="mb-4"><AntDesign.Progress Type="@AntDesign.ProgressType.Line" Percent="100" Status="@AntDesign.ProgressStatus.Active" ShowInfo="false" /></div>
}

@if (_modules.Count == 0 && !_isLoading)
{
    <CitusEmptyState
        Icon="IconName.Puzzle"
        Title="No modules available"
        Message="Bootstrap the platform core to register modules in the metadata catalog."
        ActionLabel="Return to overview"
        ActionHref="overview" />
}
else if (_modules.Count > 0)
{
    <section class="citus-panel">
        <table class="citus-data-table">
            <thead>
                <tr>
                    <th>Key</th>
                    <th>Name</th>
                    <th>Route</th>
                    <th>Capabilities</th>
                    <th class="text-right">Entity Count</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var module in _modules)
                {
                    <tr>
                        <td><span class="citus-inline-code">@module.Key</span></td>
                        <td>
                            <div>@module.Name</div>
                            <div class="text-fg-subtle text-xs">@module.Description</div>
                        </td>
                        <td><span class="citus-inline-code">@module.RoutePrefix</span></td>
                        <td>@string.Join(", ", module.Capabilities)</td>
                        <td class="text-right">@module.EntityNames.Count</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Metadata",
        Title = "Modules",
        Subtitle = "Registered platform modules surfaced through Citus.Platform.Core."
    };

    private bool _isLoading = true;
    private IReadOnlyList<PlatformModuleSummary> _modules = Array.Empty<PlatformModuleSummary>();

    protected override async Task OnInitializedAsync()
    {
        _modules = await PlatformCoreClient.ListModulesAsync();
        _isLoading = false;
    }
}
