@page "/modules"

@inject PlatformCoreClient PlatformCoreClient

<PageTitle>Modules | Citus SysAdmin</PageTitle>

<CitusPageHeader Model="_header" />

<CitusAsyncBoundary IsLoading="_isLoading"
                    IsEmpty="@(_modules.Count == 0)"
                    EmptyIcon="IconName.Puzzle"
                    EmptyTitle="No modules available"
                    EmptyMessage="Bootstrap the platform core to register modules in the metadata catalog."
                    EmptyActionLabel="Return to overview"
                    EmptyActionHref="overview"
                    RetryAction="LoadAsync">
    <section class="citus-panel">
        <table class="citus-data-table">
            <thead>
                <tr>
                    <th>Key</th>
                    <th>Name</th>
                    <th>Route</th>
                    <th>Capabilities</th>
                    <th class="text-right">Entity Count</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var module in _modules)
                {
                    <tr>
                        <td><span class="citus-inline-code">@module.Key</span></td>
                        <td>
                            <div>@module.Name</div>
                            <div class="text-fg-subtle text-xs">@module.Description</div>
                        </td>
                        <td><span class="citus-inline-code">@module.RoutePrefix</span></td>
                        <td>@string.Join(", ", module.Capabilities)</td>
                        <td class="text-right">@module.EntityNames.Count</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
</CitusAsyncBoundary>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Metadata",
        Title = "Modules",
        Subtitle = "Registered platform modules surfaced through Citus.Platform.Core."
    };

    private bool _isLoading = true;
    private IReadOnlyList<PlatformModuleSummary> _modules = Array.Empty<PlatformModuleSummary>();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _isLoading = true;
        _modules = await PlatformCoreClient.ListModulesAsync();
        _isLoading = false;
    }
}
