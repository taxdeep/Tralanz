@page "/setup/company-decision"

@inject AppShellState ShellState
@inject NavigationManager NavigationManager
@inject AntDesign.IMessageService Message
@inject SysAdminAuthenticationClient SysAdminAuthenticationClient

<PageTitle>First Company Setup | Citus SysAdmin</PageTitle>

<header class="mb-6">
    <span class="text-fg-subtle text-xs uppercase tracking-wider">First-time setup</span>
    <h1 class="text-2xl font-semibold text-fg mt-1">Create Your First Company?</h1>
    <p class="text-fg-muted mt-1">
        The platform administrator is ready. You can stop here and stay in SysAdmin, or continue into the first business-ready company bootstrap.
    </p>
</header>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <div class="lg:col-span-7">
        <section class="citus-panel">
            <CitusAlert Severity="CitusAlertSeverity.Info"
                             ShowIcon="true"
                             Message="SysAdmin remains a separate platform identity. The first company flow will create a separate Business App user and owner membership."
                             Class="mb-4" />

            <div class="mb-3">
                <h3 class="text-base font-semibold mb-1">If you continue now</h3>
                <p class="text-fg-muted text-sm">
                    We will guide you through first business owner creation, company profile capture, and chart-of-accounts template provisioning.
                </p>
            </div>

            <div class="mb-4">
                <h3 class="text-base font-semibold mb-1">If you stop here</h3>
                <p class="text-fg-muted text-sm">
                    SysAdmin stays active, but the Business App remains intentionally unavailable until the first company is created.
                </p>
            </div>

            <div class="flex flex-wrap gap-2">
                <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_isSubmitting" OnClick="@(() => PersistDecisionAsync(true))">
                    @(_isSubmitting ? "Saving..." : "Create first company now")
                </CitusButton>
                <CitusButton Disabled="_isSubmitting" OnClick="@(() => PersistDecisionAsync(false))">
                    @(_isSubmitting ? "Saving..." : "Not now")
                </CitusButton>
            </div>
        </section>
    </div>

    <div class="lg:col-span-5">
        <section class="citus-panel">
            <h2 class="citus-panel__title">Current setup state</h2>
            <table class="citus-keyvalue">
                <tbody>
                    <tr><th>Stage</th><td><CitusBadge Color="@("blue")">@ShellState.SetupStage</CitusBadge></td></tr>
                    <tr><th>SysAdmin accounts</th><td>@ShellState.AccountCount</td></tr>
                    <tr><th>Companies</th><td>@ShellState.CompanyCount</td></tr>
                    <tr><th>Owner memberships</th><td>@ShellState.OwnerMembershipCount</td></tr>
                </tbody>
            </table>
        </section>
    </div>
</div>

@code {
    private bool _isSubmitting;

    protected override void OnInitialized()
    {
        if (ShellState.BusinessReady)
        {
            NavigationManager.NavigateTo("overview");
            return;
        }

        if (ShellState.FirstCompanySetupRequired && ShellState.HasAnyCompany)
        {
            NavigationManager.NavigateTo("setup/first-company");
        }
    }

    private async Task PersistDecisionAsync(bool createCompanyNow)
    {
        _isSubmitting = true;

        try
        {
            var status = await SysAdminAuthenticationClient.SetFirstCompanyDecisionAsync(
                ShellState.SessionToken,
                createCompanyNow);

            if (status is null)
            {
                await Message.WarningAsync("Unable to persist the first-company setup decision.");
                return;
            }

            ShellState.ApplySetupStatus(status);

            if (createCompanyNow)
            {
                await Message.SuccessAsync("First company setup is ready to continue.");
                NavigationManager.NavigateTo("setup/first-company");
                return;
            }

            await Message.InfoAsync("Business setup deferred. SysAdmin remains available.");
            NavigationManager.NavigateTo("overview");
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
