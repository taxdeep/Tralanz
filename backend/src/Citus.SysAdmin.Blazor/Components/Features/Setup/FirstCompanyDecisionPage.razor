@page "/setup/company-decision"

@inject AppShellState ShellState
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject SysAdminAuthenticationClient SysAdminAuthenticationClient

<PageTitle>First Company Setup | Citus SysAdmin</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.overline" Class="text-secondary">First-time setup</MudText>
    <MudText Typo="Typo.h4">Create Your First Company?</MudText>
    <MudText Typo="Typo.body1" Class="text-secondary">
        The platform administrator is ready. You can stop here and stay in SysAdmin, or continue into the first business-ready company bootstrap.
    </MudText>
</MudStack>

<MudGrid Class="mt-4">
    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4">
            <MudStack Spacing="3">
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    SysAdmin remains a separate platform identity. The first company flow will create a separate Business App user and owner membership.
                </MudAlert>

                <MudStack Spacing="1">
                    <MudText Typo="Typo.subtitle1">If you continue now</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        We will guide you through first business owner creation, company profile capture, and chart-of-accounts template provisioning.
                    </MudText>
                </MudStack>

                <MudStack Spacing="1">
                    <MudText Typo="Typo.subtitle1">If you stop here</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        SysAdmin stays active, but the Business App remains intentionally unavailable until the first company is created.
                    </MudText>
                </MudStack>

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="_isSubmitting"
                               OnClick="@(() => PersistDecisionAsync(createCompanyNow: true))">
                        @(_isSubmitting ? "Saving..." : "Create first company now")
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               Disabled="_isSubmitting"
                               OnClick="@(() => PersistDecisionAsync(createCompanyNow: false))">
                        @(_isSubmitting ? "Saving..." : "Not now")
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">Current setup state</MudText>
            <MudList T="string" Dense="true">
                <MudListItem Text="Stage">
                    <ChildContent>
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width: 100%;">
                            <MudText Typo="Typo.body2">Stage</MudText>
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">@ShellState.SetupStage</MudChip>
                        </MudStack>
                    </ChildContent>
                </MudListItem>
                <MudListItem Text="SysAdmin accounts">
                    <ChildContent>
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width: 100%;">
                            <MudText Typo="Typo.body2">SysAdmin accounts</MudText>
                            <MudText Typo="Typo.body2">@ShellState.AccountCount</MudText>
                        </MudStack>
                    </ChildContent>
                </MudListItem>
                <MudListItem Text="Companies">
                    <ChildContent>
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width: 100%;">
                            <MudText Typo="Typo.body2">Companies</MudText>
                            <MudText Typo="Typo.body2">@ShellState.CompanyCount</MudText>
                        </MudStack>
                    </ChildContent>
                </MudListItem>
                <MudListItem Text="Owner memberships">
                    <ChildContent>
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width: 100%;">
                            <MudText Typo="Typo.body2">Owner memberships</MudText>
                            <MudText Typo="Typo.body2">@ShellState.OwnerMembershipCount</MudText>
                        </MudStack>
                    </ChildContent>
                </MudListItem>
            </MudList>
        </MudPaper>
    </MudItem>
</MudGrid>

@code
{
    private bool _isSubmitting;

    protected override void OnInitialized()
    {
        if (ShellState.BusinessReady)
        {
            NavigationManager.NavigateTo("overview");
            return;
        }

        if (ShellState.FirstCompanySetupRequired && ShellState.HasAnyCompany)
        {
            NavigationManager.NavigateTo("setup/first-company");
        }
    }

    private async Task PersistDecisionAsync(bool createCompanyNow)
    {
        _isSubmitting = true;

        try
        {
            var status = await SysAdminAuthenticationClient.SetFirstCompanyDecisionAsync(
                ShellState.SessionToken,
                createCompanyNow);

            if (status is null)
            {
                Snackbar.Add("Unable to persist the first-company setup decision.", Severity.Warning);
                return;
            }

            ShellState.ApplySetupStatus(status);

            if (createCompanyNow)
            {
                Snackbar.Add("First company setup is ready to continue.", Severity.Success);
                NavigationManager.NavigateTo("setup/first-company");
                return;
            }

            Snackbar.Add("Business setup deferred. SysAdmin remains available.", Severity.Info);
            NavigationManager.NavigateTo("overview");
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
