@page "/setup/completed"

@inject AppShellState ShellState
@inject NavigationManager NavigationManager
@inject Microsoft.Extensions.Options.IOptions<Citus.SysAdmin.Blazor.Configuration.AppHostOptions> HostOptions

<PageTitle>Setup Completed | Citus SysAdmin</PageTitle>

@if (_completion is null)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning"
                     ShowIcon="true"
                     Message="The first-company completion summary is no longer available. Returning to SysAdmin overview." />
}
else
{
    <header class="mb-6">
        <span class="text-fg-subtle text-xs uppercase tracking-wider">First-time setup</span>
        <h1 class="text-2xl font-semibold text-fg mt-1">Business-ready hand-off completed</h1>
        <p class="text-fg-muted mt-1">
            The first company, first business owner, first owner membership, default primary book, and starter chart binding are now in place.
        </p>
    </header>

    <CitusAlert Severity="CitusAlertSeverity.Success" ShowIcon="true" Class="mb-6">
        <MessageTemplate>
            <strong>@_completion.CompanyName (@_completion.CompanyEntityNumber) is ready.</strong>
            <div class="text-fg-muted text-sm mt-1">SysAdmin remains a separate platform identity. Use the business owner account below when entering the Business App.</div>
        </MessageTemplate>
    </CitusAlert>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-6">
        <div class="lg:col-span-7">
            <section class="citus-panel">
                <h2 class="citus-panel__title">Provisioned truth</h2>
                <table class="citus-keyvalue">
                    <tbody>
                        <tr><th>Business owner login</th><td>@_completion.OwnerEmail</td></tr>
                        <tr><th>Primary book</th><td>@_completion.CompanyBookCode</td></tr>
                        <tr><th>Template binding</th><td>@_completion.TemplateKey (@_completion.TemplateVersion)</td></tr>
                        <tr><th>Base currency</th><td>@_completion.BaseCurrencyCode</td></tr>
                        <tr><th>Account code length</th><td>@_completion.AccountCodeLength</td></tr>
                        <tr><th>Provisioned at</th><td>@_completion.ProvisionedAtUtc.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss 'UTC'")</td></tr>
                    </tbody>
                </table>
            </section>
        </div>

        <div class="lg:col-span-5">
            <section class="citus-panel">
                <h2 class="citus-panel__title">Next actions</h2>
                <ol class="m-0 pl-4 text-sm text-fg-muted flex flex-col gap-2">
                    <li>Keep the SysAdmin account for platform governance only.</li>
                    <li>Use the business owner email above and the password you just entered in the wizard to sign in to the Business App.</li>
                    <li>Return to SysAdmin to govern modules, users, company lifecycle, and platform maintenance.</li>
                </ol>

                <div class="flex flex-wrap gap-2 mt-4">
                    @if (!string.IsNullOrWhiteSpace(_businessLoginHref))
                    {
                        <a class="citus-button citus-button--ghost" href="@_businessLoginHref" target="_blank" rel="noopener noreferrer">
                            <CitusIcon Name="IconName.ArrowRight" Size="IconSize.Inline" />
                            <span>Open Business App login</span>
                        </a>
                    }
                    <CitusButton OnClick="ContinueInSysAdminAsync">Continue in SysAdmin</CitusButton>
                </div>
            </section>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <section class="citus-panel">
            <h2 class="citus-panel__title">Starter account codes</h2>
            @if (_completion.StarterAccountCodes.Count == 0)
            {
                <p class="text-fg-muted text-sm">No starter accounts were returned in the provisioning summary.</p>
            }
            else
            {
                <div class="flex flex-wrap gap-1">
                    @foreach (var accountCode in _completion.StarterAccountCodes)
                    {
                        <CitusBadge Color="@("blue")">@accountCode</CitusBadge>
                    }
                </div>
            }
        </section>

        <section class="citus-panel">
            <h2 class="citus-panel__title">Reserved multi-currency families</h2>
            @if (_completion.ReservedFamilies.Count == 0)
            {
                <p class="text-fg-muted text-sm">No reserved families were returned in the provisioning summary.</p>
            }
            else
            {
                <div class="flex flex-wrap gap-1">
                    @foreach (var family in _completion.ReservedFamilies)
                    {
                        <CitusBadge Color="@("default")">@family</CitusBadge>
                    }
                </div>
            }
        </section>
    </div>
}

@code {
    private SysAdminAuthenticationClient.FirstCompanyProvisioningResponse? _completion;
    private string _businessLoginHref = string.Empty;

    protected override void OnInitialized()
    {
        _completion = ShellState.FirstCompanyCompletion;
        _businessLoginHref = GetBusinessLoginHref();

        if (_completion is null)
        {
            NavigationManager.NavigateTo("overview");
        }
    }

    private Task ContinueInSysAdminAsync()
    {
        ShellState.ClearFirstCompanyCompletion();
        NavigationManager.NavigateTo("overview");
        return Task.CompletedTask;
    }

    private string GetBusinessLoginHref()
    {
        var configured = HostOptions.Value.BusinessAppBaseUrl?.Trim();
        if (!string.IsNullOrWhiteSpace(configured) &&
            Uri.TryCreate(configured, UriKind.Absolute, out var configuredUri) &&
            !IsLoopbackBrowserHost(configuredUri.Host))
        {
            return configured.EndsWith("/login", StringComparison.OrdinalIgnoreCase)
                ? configured
                : configured.TrimEnd('/') + "/login";
        }

        var browserOrigin = NavigationManager.ToAbsoluteUri("/").GetLeftPart(UriPartial.Authority);
        return browserOrigin.TrimEnd('/') + "/login";
    }

    private static bool IsLoopbackBrowserHost(string host) =>
        string.Equals(host, "localhost", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(host, "127.0.0.1", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(host, "::1", StringComparison.OrdinalIgnoreCase);
}
