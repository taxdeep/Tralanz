@page "/setup/completed"

@inject AppShellState ShellState
@inject NavigationManager NavigationManager
@inject Microsoft.Extensions.Options.IOptions<Citus.SysAdmin.Blazor.Configuration.AppHostOptions> HostOptions

<PageTitle>Setup Completed | Citus SysAdmin</PageTitle>

@if (_completion is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        The first-company completion summary is no longer available. Returning to SysAdmin overview.
    </MudAlert>
}
else
{
    <MudStack Spacing="3">
        <MudStack Spacing="1">
            <MudText Typo="Typo.overline" Class="text-secondary">First-time setup</MudText>
            <MudText Typo="Typo.h4">Business-ready hand-off completed</MudText>
            <MudText Typo="Typo.body1" Class="text-secondary">
                The first company, first business owner, first owner membership, default primary book, and starter chart binding are now in place.
            </MudText>
        </MudStack>

        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
            <MudStack Spacing="1">
                <MudText Typo="Typo.subtitle1">
                    @_completion.CompanyName (@_completion.CompanyEntityNumber) is ready.
                </MudText>
                <MudText Typo="Typo.body2">
                    SysAdmin remains a separate platform identity. Use the business owner account below when entering the Business App.
                </MudText>
            </MudStack>
        </MudAlert>

        <MudGrid>
            <MudItem xs="12" lg="7">
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-3">Provisioned truth</MudText>
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Class="text-secondary">Business owner login</MudText>
                            <MudText Typo="Typo.body1">@_completion.OwnerEmail</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Class="text-secondary">Primary book</MudText>
                            <MudText Typo="Typo.body1">@_completion.CompanyBookCode</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Class="text-secondary">Template binding</MudText>
                            <MudText Typo="Typo.body1">@_completion.TemplateKey (@_completion.TemplateVersion)</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Class="text-secondary">Base currency</MudText>
                            <MudText Typo="Typo.body1">@_completion.BaseCurrencyCode</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Class="text-secondary">Account code length</MudText>
                            <MudText Typo="Typo.body1">@_completion.AccountCodeLength</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Class="text-secondary">Provisioned at</MudText>
                            <MudText Typo="Typo.body1">@_completion.ProvisionedAtUtc.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss 'UTC'")</MudText>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="5">
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-3">Next actions</MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem Text="1">
                            <ChildContent>
                                <MudText Typo="Typo.body2">Keep the SysAdmin account for platform governance only.</MudText>
                            </ChildContent>
                        </MudListItem>
                        <MudListItem Text="2">
                            <ChildContent>
                                <MudText Typo="Typo.body2">Use the business owner email above and the password you just entered in the wizard to sign in to the Business App.</MudText>
                            </ChildContent>
                        </MudListItem>
                        <MudListItem Text="3">
                            <ChildContent>
                                <MudText Typo="Typo.body2">Return to SysAdmin to govern modules, users, company lifecycle, and platform maintenance.</MudText>
                            </ChildContent>
                        </MudListItem>
                    </MudList>

                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" Class="mt-4">
                        @if (!string.IsNullOrWhiteSpace(_businessLoginHref))
                        {
                            <MudButton
                                Variant="Variant.Filled"
                                Color="Color.Primary"
                                Href="@_businessLoginHref"
                                Target="_blank"
                                Rel="noopener noreferrer">
                                Open Business App login
                            </MudButton>
                        }
                        <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="ContinueInSysAdminAsync">
                            Continue in SysAdmin
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudGrid>
            <MudItem xs="12" lg="6">
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-3">Starter account codes</MudText>
                    @if (_completion.StarterAccountCodes.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="text-secondary">No starter accounts were returned in the provisioning summary.</MudText>
                    }
                    else
                    {
                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                            @foreach (var accountCode in _completion.StarterAccountCodes)
                            {
                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">@accountCode</MudChip>
                            }
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="6">
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-3">Reserved multi-currency families</MudText>
                    @if (_completion.ReservedFamilies.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="text-secondary">No reserved families were returned in the provisioning summary.</MudText>
                    }
                    else
                    {
                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                            @foreach (var family in _completion.ReservedFamilies)
                            {
                                <MudChip T="string" Variant="Variant.Outlined">@family</MudChip>
                            }
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudStack>
}

@code
{
    private SysAdminAuthenticationClient.FirstCompanyProvisioningResponse? _completion;
    private string _businessLoginHref = string.Empty;

    protected override void OnInitialized()
    {
        _completion = ShellState.FirstCompanyCompletion;
        _businessLoginHref = GetBusinessLoginHref();

        if (_completion is null)
        {
            NavigationManager.NavigateTo("overview");
        }
    }

    private Task ContinueInSysAdminAsync()
    {
        ShellState.ClearFirstCompanyCompletion();
        NavigationManager.NavigateTo("overview");
        return Task.CompletedTask;
    }

    private string GetBusinessLoginHref()
    {
        var configured = HostOptions.Value.BusinessAppBaseUrl?.Trim();
        if (string.IsNullOrWhiteSpace(configured))
        {
            return string.Empty;
        }

        return configured.EndsWith("/login", StringComparison.OrdinalIgnoreCase)
            ? configured
            : configured.TrimEnd('/') + "/login";
    }
}
