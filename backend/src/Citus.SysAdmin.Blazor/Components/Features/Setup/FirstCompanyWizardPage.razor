@page "/setup/first-company"

@inject AppShellState ShellState
@inject NavigationManager NavigationManager
@inject SysAdminAuthenticationClient AuthClient

<PageTitle>First Company Wizard | Citus SysAdmin</PageTitle>

<header class="mb-6">
    <span class="text-fg-subtle text-xs uppercase tracking-wider">First-time setup</span>
    <h1 class="text-2xl font-semibold text-fg mt-1">First Company Wizard</h1>
    <p class="text-fg-muted mt-1">
        Provision the first business owner, company profile, default primary book, and starter chart-of-accounts binding. This is the hand-off from platform-ready to business-ready.
    </p>
</header>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <AntDesign.Alert Type="@AntDesign.AlertType.Error" Message="@_error" ShowIcon="true" Class="mb-4" />
}

@if (!string.IsNullOrWhiteSpace(_success))
{
    <AntDesign.Alert Type="@AntDesign.AlertType.Success" Message="@_success" ShowIcon="true" Class="mb-4" />
}

<div class="grid grid-cols-1 xl:grid-cols-12 gap-6">
    <div class="xl:col-span-7 flex flex-col gap-6">
        <section class="citus-panel">
            <h2 class="citus-panel__title">1. First business owner</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <CitusInput TValue="string" @bind-Value="_ownerDisplayName" Placeholder="Display name" />
                <CitusInput TValue="string" @bind-Value="_ownerEmail" Placeholder="Email" />
                <AntDesign.InputPassword @bind-Value="_ownerPassword" Placeholder="@("Password")" />
                <AntDesign.InputPassword @bind-Value="_ownerPasswordConfirm" Placeholder="@("Confirm password")" />
            </div>
        </section>

        <section class="citus-panel">
            <h2 class="citus-panel__title">2. Company profile</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <CitusInput TValue="string" @bind-Value="_companyName" Placeholder="Company name" />
                <AntDesign.Select TItem="string" TItemValue="string"
                                  DataSource="@_entityTypes"
                                  Value="@EntityType"
                                  ValueChanged="OnEntityTypeChanged"
                                  ItemValue="@(s => s)"
                                  ItemLabel="@(s => EntityTypeLabel(s))"
                                  Placeholder="@("Entity type")" />
                <AntDesign.Select TItem="string" TItemValue="string"
                                  DataSource="@_industries"
                                  Value="@Industry"
                                  ValueChanged="OnIndustryChanged"
                                  ItemValue="@(s => s)"
                                  ItemLabel="@(s => IndustryLabel(s))"
                                  Placeholder="@("Industry")" />
                <RadzenDatePicker TValue="DateTime?" @bind-Value="_incorporatedOn" Placeholder="@("Incorporated date")" />
                <CitusInput TValue="string" @bind-Value="_fiscalYearEnd" Placeholder="Fiscal year end (MM-DD)" />
                <CitusInput TValue="string" @bind-Value="_businessNumber" Placeholder="Business number" />
                <AntDesign.Select TItem="int" TItemValue="int"
                                  DataSource="@_codeLengths"
                                  Value="@_accountCodeLength"
                                  ValueChanged="@(v => _accountCodeLength = v)"
                                  ItemValue="@(i => i)"
                                  ItemLabel="@(i => i.ToString())"
                                  Placeholder="@("Account code length")" />
                <CitusInput TValue="string" @bind-Value="_phone" Placeholder="Phone (optional)" />
                <CitusInput TValue="string" @bind-Value="_companyEmail" Placeholder="Company email" />
                <div class="md:col-span-2"><CitusInput TValue="string" @bind-Value="_addressLine" Placeholder="Address line" /></div>
                <CitusInput TValue="string" @bind-Value="_city" Placeholder="City" />
                <CitusInput TValue="string" @bind-Value="_province" Placeholder="Province / State" />
                <CitusInput TValue="string" @bind-Value="_postalCode" Placeholder="Postal code" />
                <CitusInput TValue="string" Value="@Country" ValueChanged="OnCountryChanged" Placeholder="Country" />
            </div>
        </section>

        <section class="citus-panel">
            <h2 class="citus-panel__title">3. Chart template and multi-currency reserve preview</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
                <AntDesign.Select TItem="string" TItemValue="string"
                                  DataSource="@_templates"
                                  Value="@TemplateKey"
                                  ValueChanged="OnTemplateChanged"
                                  ItemValue="@(s => s)"
                                  ItemLabel="@(s => GetTemplateLabel(s))"
                                  Placeholder="@("Template")" />
                <CitusInput TValue="string" @bind-Value="_baseCurrencyCode" Placeholder="Base currency" />
            </div>

            <AntDesign.Alert Type="@AntDesign.AlertType.Info"
                             ShowIcon="true"
                             Class="mb-3">
                <MessageTemplate>
                    Suggested template from company profile: <strong>@GetTemplateLabel(GetSuggestedTemplateKey())</strong>
                </MessageTemplate>
            </AntDesign.Alert>

            <table class="citus-data-table">
                <thead>
                    <tr><th>Reserved family</th><th>Purpose</th></tr>
                </thead>
                <tbody>
                    @foreach (var family in _reservedFamilies)
                    {
                        <tr><td>@family.CodeRange</td><td>@family.Purpose</td></tr>
                    }
                </tbody>
            </table>
        </section>
    </div>

    <div class="xl:col-span-5 flex flex-col gap-6">
        <section class="citus-panel">
            <h2 class="citus-panel__title">4. Review</h2>
            <table class="citus-keyvalue">
                <tbody>
                    <tr><th>Business owner</th><td>@FormatReview(_ownerDisplayName, _ownerEmail)</td></tr>
                    <tr><th>Company</th><td>@FormatReview(_companyName, _country)</td></tr>
                    <tr><th>Profile</th><td>@($"{EntityType} / {Industry} / FY {_fiscalYearEnd}")</td></tr>
                    <tr><th>COA template</th><td>@TemplateKey</td></tr>
                    <tr><th>Account code length</th><td>@_accountCodeLength</td></tr>
                    <tr><th>Base currency</th><td>@_baseCurrencyCode</td></tr>
                </tbody>
            </table>
        </section>

        <section class="citus-panel">
            <h2 class="citus-panel__title">Finish</h2>
            <p class="text-fg-muted text-sm mb-4">
                Finish will create the first business owner, create the company, assign the first owner membership, seed the default primary book, and provision the selected starter chart with multi-currency reserve families.
            </p>
            <div class="flex flex-wrap gap-2">
                <a class="citus-button citus-button--ghost" href="setup/company-decision">
                    <CitusIcon Name="IconName.ArrowLeft" Size="IconSize.Inline" />
                    <span>Back</span>
                </a>
                <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_submitting" OnClick="FinishSetupAsync">
                    @(_submitting ? "Provisioning..." : "Finish setup")
                </CitusButton>
            </div>
        </section>
    </div>
</div>

@code {
    private static readonly List<string> _entityTypes = new() { "corporation", "partnership", "sole_proprietorship" };
    private static readonly List<string> _industries = new() { "general_services", "trading", "property_rental" };
    private static readonly List<int> _codeLengths = new() { 4, 5, 6 };
    private static readonly List<string> _templates = new() { "ca_general_small_business", "ca_property_rental" };

    private string _ownerDisplayName = "Business Owner";
    private string _ownerEmail = string.Empty;
    private string _ownerPassword = string.Empty;
    private string _ownerPasswordConfirm = string.Empty;
    private string _companyName = string.Empty;
    private string _entityType = "corporation";
    private string _industry = "general_services";
    private DateTime? _incorporatedOn = DateTime.Today;
    private string _fiscalYearEnd = "12-31";
    private string _businessNumber = string.Empty;
    private int _accountCodeLength = 4;
    private string _phone = string.Empty;
    private string _companyEmail = string.Empty;
    private string _addressLine = string.Empty;
    private string _city = string.Empty;
    private string _province = string.Empty;
    private string _postalCode = string.Empty;
    private string _country = "Canada";
    private string _templateKey = "ca_general_small_business";
    private string _baseCurrencyCode = "CAD";
    private bool _templateWasManuallySelected;
    private bool _submitting;
    private string _error = string.Empty;
    private string _success = string.Empty;

    private readonly IReadOnlyList<ReservedCodeFamily> _reservedFamilies =
    [
        new("1000-1099", "Cash and bank family"),
        new("1200", "Base accounts receivable control"),
        new("1210-1249", "Multi-currency AR reserve"),
        new("3000", "Base accounts payable control"),
        new("3010-3049", "Multi-currency AP reserve"),
        new("5600-5699", "FX gain/loss and translation reserve family")
    ];

    protected override void OnInitialized()
    {
        if (ShellState.BusinessReady)
        {
            NavigationManager.NavigateTo("overview");
            return;
        }

        if (ShellState.FirstCompanySetupDeferred && !ShellState.HasAnyCompany)
        {
            NavigationManager.NavigateTo("setup/company-decision");
        }

        _templateKey = GetSuggestedTemplateKey();
    }

    private string EntityType => _entityType;

    private string Industry => _industry;

    private string Country => _country;

    private string TemplateKey => _templateKey;

    private void OnEntityTypeChanged(string? value)
    {
        _entityType = value ?? "corporation";
        ApplyTemplateSuggestion();
    }

    private void OnIndustryChanged(string? value)
    {
        _industry = value ?? "general_services";
        ApplyTemplateSuggestion();
    }

    private Task OnCountryChanged(string? value)
    {
        _country = value ?? "Canada";
        ApplyTemplateSuggestion();
        return Task.CompletedTask;
    }

    private void OnTemplateChanged(string? value)
    {
        _templateKey = value ?? "ca_general_small_business";
        _templateWasManuallySelected = true;
    }

    private void ApplyTemplateSuggestion()
    {
        if (_templateWasManuallySelected)
        {
            return;
        }

        _templateKey = GetSuggestedTemplateKey();
    }

    private string GetSuggestedTemplateKey()
    {
        if (string.Equals(_country, "Canada", StringComparison.OrdinalIgnoreCase) &&
            string.Equals(_industry, "property_rental", StringComparison.OrdinalIgnoreCase))
        {
            return "ca_property_rental";
        }

        return "ca_general_small_business";
    }

    private static string GetTemplateLabel(string templateKey) =>
        templateKey switch
        {
            "ca_property_rental" => "Canada property rental",
            _ => "Canada general small business"
        };

    private static string EntityTypeLabel(string value) => value switch
    {
        "partnership" => "Partnership",
        "sole_proprietorship" => "Sole proprietorship",
        _ => "Corporation"
    };

    private static string IndustryLabel(string value) => value switch
    {
        "trading" => "Trading",
        "property_rental" => "Property rental",
        _ => "General services"
    };

    private async Task FinishSetupAsync()
    {
        _error = string.Empty;
        _success = string.Empty;

        var validationError = Validate();
        if (validationError is not null)
        {
            _error = validationError;
            return;
        }

        _submitting = true;

        try
        {
            var result = await AuthClient.ProvisionFirstCompanyAsync(
                ShellState.SessionToken,
                new SysAdminAuthenticationClient.FirstCompanyProvisioningRequest
                {
                    OwnerDisplayName = _ownerDisplayName.Trim(),
                    OwnerEmail = _ownerEmail.Trim(),
                    OwnerPassword = _ownerPassword,
                    CompanyName = _companyName.Trim(),
                    EntityType = _entityType,
                    Industry = _industry,
                    IncorporatedOn = _incorporatedOn,
                    FiscalYearEnd = _fiscalYearEnd.Trim(),
                    BusinessNumber = _businessNumber.Trim(),
                    AccountCodeLength = _accountCodeLength,
                    Phone = _phone.Trim(),
                    CompanyEmail = _companyEmail.Trim(),
                    AddressLine = _addressLine.Trim(),
                    City = _city.Trim(),
                    ProvinceState = _province.Trim(),
                    PostalCode = _postalCode.Trim(),
                    Country = _country.Trim(),
                    TemplateKey = _templateKey,
                    BaseCurrencyCode = _baseCurrencyCode.Trim().ToUpperInvariant()
                });

            if (!result.Succeeded)
            {
                _error = string.IsNullOrWhiteSpace(result.FailureMessage)
                    ? "Unable to provision the first company. Confirm the SysAdmin API is reachable and the database is ready."
                    : $"Backend rejected the request: {result.FailureMessage}";
                return;
            }

            _success = $"Provisioned {result.CompanyName} ({result.CompanyEntityNumber}) with owner {result.OwnerEmail}.";

            var setupStatus = await AuthClient.GetSetupStatusAsync();
            if (setupStatus is not null)
            {
                ShellState.ApplySetupStatus(setupStatus);
            }

            ShellState.SetFirstCompanyCompletion(result);
            NavigationManager.NavigateTo("setup/completed");
        }
        catch (Exception ex)
        {
            _error = $"Provisioning failed before the backend acknowledged: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }

    private string? Validate()
    {
        if (string.IsNullOrWhiteSpace(_ownerDisplayName))
        {
            return "Business owner display name is required.";
        }
        if (string.IsNullOrWhiteSpace(_ownerEmail) || !_ownerEmail.Contains('@', StringComparison.Ordinal))
        {
            return "Business owner email looks invalid.";
        }
        if (string.IsNullOrWhiteSpace(_ownerPassword) || _ownerPassword.Length < 8)
        {
            return "Owner password must be at least 8 characters.";
        }
        if (!string.Equals(_ownerPassword, _ownerPasswordConfirm, StringComparison.Ordinal))
        {
            return "Owner password confirmation does not match.";
        }
        if (string.IsNullOrWhiteSpace(_companyName))
        {
            return "Company name is required.";
        }
        if (!IsValidFiscalYearEnd(_fiscalYearEnd))
        {
            return "Fiscal year end must be MM-DD (for example 12-31).";
        }
        if (string.IsNullOrWhiteSpace(_baseCurrencyCode) || _baseCurrencyCode.Trim().Length != 3)
        {
            return "Base currency must be a 3-letter ISO code.";
        }
        if (string.IsNullOrWhiteSpace(_country))
        {
            return "Country is required to bind the chart-of-accounts template.";
        }
        return null;
    }

    private static bool IsValidFiscalYearEnd(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return false;
        var parts = value.Trim().Split('-');
        if (parts.Length != 2) return false;
        if (!int.TryParse(parts[0], out var month) || month is < 1 or > 12) return false;
        if (!int.TryParse(parts[1], out var day) || day is < 1 or > 31) return false;
        return true;
    }

    private static string FormatReview(string primary, string secondary) =>
        string.IsNullOrWhiteSpace(primary) && string.IsNullOrWhiteSpace(secondary)
            ? "Not entered yet"
            : $"{(string.IsNullOrWhiteSpace(primary) ? "Unspecified" : primary)} / {(string.IsNullOrWhiteSpace(secondary) ? "Unspecified" : secondary)}";

    private sealed record ReservedCodeFamily(string CodeRange, string Purpose);
}
