@page "/"
@page "/overview"

@inject AppShellState ShellState
@inject AntDesign.IMessageService Message
@inject PlatformCoreClient PlatformCoreClient
@inject SysAdminHealthClient SysAdminHealthClient
@inject AccountingHealthClient AccountingHealthClient

<PageTitle>Overview | Citus SysAdmin</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusButton Variant="CitusButtonVariant.Primary" LeadingIcon="IconName.Refresh"
                     Disabled="_isBootstrapping" OnClick="BootstrapCoreAsync">
            @(_isBootstrapping ? "Bootstrapping..." : "Bootstrap core")
        </CitusButton>
        <CitusButton Disabled="_isLoading" OnClick="LoadAsync">Refresh</CitusButton>
    </Actions>
</CitusPageHeader>

@if (!ShellState.BusinessReady)
{
    <AntDesign.Alert Type="@AntDesign.AlertType.Info"
                     ShowIcon="true"
                     Class="mb-6">
        <MessageTemplate>
            <div class="flex flex-col gap-2">
                <strong>Business setup is not complete yet</strong>
                <span>@GetSetupMessage()</span>
                <div class="flex flex-wrap gap-2 mt-2">
                    <a class="citus-button citus-button--ghost" href="setup/company-decision">First company setup</a>
                    @if (ShellState.FirstCompanySetupRequired && ShellState.HasAnyCompany)
                    {
                        <a class="citus-button citus-button--ghost" href="setup/first-company">Continue company wizard</a>
                    }
                </div>
            </div>
        </MessageTemplate>
    </AntDesign.Alert>
}

@if (_lastBootstrapReport is not null)
{
    <section class="citus-panel mb-6">
        <h2 class="citus-panel__title">Last bootstrap</h2>
        <p class="text-fg-muted text-sm mb-2">
            Seeded @_lastBootstrapReport.ModulesSeeded modules and @_lastBootstrapReport.EntitiesSeeded entities at
            @_lastBootstrapReport.BootstrappedAtUtc.ToUniversalTime().ToString("u").
        </p>
        <div class="flex flex-wrap gap-1">
            @foreach (var moduleKey in _lastBootstrapReport.ModuleKeys)
            {
                <CitusBadge Color="@("blue")">@moduleKey</CitusBadge>
            }
        </div>
    </section>
}

@if (_isLoading)
{
    <div class="mb-4"><AntDesign.Progress Type="@AntDesign.ProgressType.Line" Percent="100" Status="@AntDesign.ProgressStatus.Active" ShowInfo="false" /></div>
}

@if (_overview is null && _modules.Count == 0 && _entities.Count == 0 && !_isLoading)
{
    <CitusEmptyState
        Icon="IconName.World"
        Title="Platform data is not reachable yet"
        Message="The phase 1 shell is ready, but the SysAdmin API has not returned platform metadata. Start the API and bootstrap the core to populate this view."
        ActionLabel="Open modules"
        ActionHref="modules" />
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <CitusStatCard Label="Core" Value="@(_overview?.Name ?? "Unavailable")" Description="Metadata kernel for modules and entities." Icon="IconName.World" Tone="StatTone.Primary" />
        <CitusStatCard Label="Modules" Value="@(_overview?.ModulesRegistered.ToString() ?? _modules.Count.ToString())" Description="Registered platform modules." Icon="IconName.Puzzle" Tone="StatTone.Neutral" />
        <CitusStatCard Label="Entities" Value="@(_overview?.EntitiesRegistered.ToString() ?? _entities.Count.ToString())" Description="Metadata entities under control." Icon="IconName.Database" Tone="StatTone.Info" />
        <CitusStatCard Label="Health" Value="@HealthSummary" Description="Cross-service snapshot for the control plane." Icon="IconName.Activity" Tone="StatTone.Success" />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-7 flex flex-col gap-6">
            <section class="citus-panel">
                <header class="citus-panel__header">
                    <h2 class="citus-panel__title">Platform capabilities</h2>
                    <CitusBadge Color="@("blue")">Phase 1</CitusBadge>
                </header>

                @if (_overview?.Capabilities.Count > 0)
                {
                    <div class="flex flex-wrap gap-1">
                        @foreach (var capability in _overview.Capabilities)
                        {
                            <CitusBadge Color="@("default")">@capability</CitusBadge>
                        }
                    </div>
                }
                else
                {
                    <p class="text-fg-muted text-sm">Capability data will appear here after the platform core is reachable.</p>
                }
            </section>

            <section class="citus-panel">
                <header class="citus-panel__header">
                    <h2 class="citus-panel__title">Module snapshot</h2>
                    <a class="citus-link text-sm" href="modules">View all</a>
                </header>

                <table class="citus-data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Route</th>
                            <th class="text-right">Entities</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var module in _modules.Take(5))
                        {
                            <tr>
                                <td>@module.Name</td>
                                <td><span class="citus-inline-code">@module.RoutePrefix</span></td>
                                <td class="text-right">@module.EntityNames.Count</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        </div>

        <div class="lg:col-span-5 flex flex-col gap-6">
            <section class="citus-panel">
                <h2 class="citus-panel__title">Service status</h2>
                <ul class="flex flex-col gap-2 m-0 p-0 list-none">
                    <li class="flex items-center justify-between">
                        <span class="text-sm">SysAdmin API</span>
                        <CitusStatusBadge Status="_sysAdminHealth" />
                    </li>
                    <li class="flex items-center justify-between">
                        <span class="text-sm">Accounting API</span>
                        <CitusStatusBadge Status="_accountingHealth" />
                    </li>
                </ul>
            </section>

            <section class="citus-panel">
                <header class="citus-panel__header">
                    <h2 class="citus-panel__title">Entity coverage</h2>
                    <a class="citus-link text-sm" href="entities">Inspect entities</a>
                </header>
                <p class="text-fg-muted text-sm mb-2">
                    The first phase keeps business truth in backend engines while exposing metadata and control surfaces in Blazor.
                </p>
                <div class="text-3xl font-semibold text-fg">@_entities.Count</div>
                <p class="text-fg-muted text-sm">Entities currently visible to the platform shell.</p>
            </section>
        </div>
    </div>
}

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Phase 1",
        Title = "Platform overview",
        Subtitle = "Blazor control shell for the metadata-driven Citus core."
    };

    private bool _isLoading = true;
    private bool _isBootstrapping;
    private PlatformOverviewSummary? _overview;
    private PlatformBootstrapReportSummary? _lastBootstrapReport;
    private IReadOnlyList<PlatformModuleSummary> _modules = Array.Empty<PlatformModuleSummary>();
    private IReadOnlyList<PlatformEntitySummary> _entities = Array.Empty<PlatformEntitySummary>();
    private ServiceHealthStatus? _sysAdminHealth;
    private ServiceHealthStatus? _accountingHealth;

    private string HealthSummary =>
        string.Equals(_sysAdminHealth?.Status, "ok", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(_accountingHealth?.Status, "ok", StringComparison.OrdinalIgnoreCase)
            ? "Nominal"
            : "Attention";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        var overviewTask = PlatformCoreClient.GetOverviewAsync();
        var modulesTask = PlatformCoreClient.ListModulesAsync();
        var entitiesTask = PlatformCoreClient.ListEntitiesAsync();
        var sysAdminHealthTask = SysAdminHealthClient.GetHealthAsync();
        var accountingHealthTask = AccountingHealthClient.GetHealthAsync();

        _overview = await overviewTask;
        _modules = await modulesTask;
        _entities = await entitiesTask;
        _sysAdminHealth = await sysAdminHealthTask;
        _accountingHealth = await accountingHealthTask;
        _isLoading = false;
    }

    private async Task BootstrapCoreAsync()
    {
        _isBootstrapping = true;

        try
        {
            var report = await PlatformCoreClient.BootstrapAsync();

            if (report is null)
            {
                await Message.WarningAsync("Platform core bootstrap failed. Check SysAdmin API connectivity and database readiness.");
                return;
            }

            _lastBootstrapReport = report;
            await Message.SuccessAsync(
                $"Platform core bootstrapped: {report.ModulesSeeded} modules and {report.EntitiesSeeded} entities seeded.");

            await LoadAsync();
        }
        finally
        {
            _isBootstrapping = false;
        }
    }

    private string GetSetupMessage()
    {
        if (ShellState.FirstCompanySetupDeferred)
        {
            return "Platform governance is ready. Business initialization is currently deferred until you choose to create the first company.";
        }

        if (ShellState.FirstCompanySetupRequired)
        {
            return ShellState.HasAnyCompany
                ? "A company record exists, but the first business-ready owner bootstrap is not complete yet."
                : "Create the first company and first business owner before using the Business App.";
        }

        return "Platform setup is still being assessed.";
    }
}
