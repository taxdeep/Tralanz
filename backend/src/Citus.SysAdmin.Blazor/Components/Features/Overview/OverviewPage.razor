@page "/"
@page "/overview"

@implements IAsyncDisposable

@inject AppShellState ShellState
@inject CitusToastService Message
@inject PlatformCoreClient PlatformCoreClient
@inject SysAdminHealthClient SysAdminHealthClient
@inject AccountingHealthClient AccountingHealthClient
@inject PlatformRuntimeMetricsClient MetricsClient

<PageTitle>Overview | Tralanz SysAdmin</PageTitle>

<CitusPageHeader Model="_header">
    <Actions>
        <CitusButton Variant="CitusButtonVariant.Primary" LeadingIcon="IconName.Refresh"
                     Disabled="_isBootstrapping" OnClick="BootstrapCoreAsync">
            @(_isBootstrapping ? "Bootstrapping..." : "Bootstrap core")
        </CitusButton>
        <CitusButton Disabled="_isLoading" OnClick="LoadAsync">Refresh</CitusButton>
    </Actions>
</CitusPageHeader>

@if (!ShellState.BusinessReady)
{
    <CitusAlert Severity="CitusAlertSeverity.Info"
                     ShowIcon="true"
                     Class="mb-6">
        <MessageTemplate>
            <div class="flex flex-col gap-2">
                <strong>Business setup is not complete yet</strong>
                <span>@GetSetupMessage()</span>
                <div class="flex flex-wrap gap-2 mt-2">
                    <a class="citus-button citus-button--ghost" href="setup/company-decision">First company setup</a>
                    @if (ShellState.FirstCompanySetupRequired && ShellState.HasAnyCompany)
                    {
                        <a class="citus-button citus-button--ghost" href="setup/first-company">Continue company wizard</a>
                    }
                </div>
            </div>
        </MessageTemplate>
    </CitusAlert>
}

@if (_lastBootstrapReport is not null)
{
    <section class="citus-panel mb-6">
        <h2 class="citus-panel__title">Last bootstrap</h2>
        <p class="text-fg-muted text-sm mb-2">
            Seeded @_lastBootstrapReport.ModulesSeeded modules and @_lastBootstrapReport.EntitiesSeeded entities at
            @_lastBootstrapReport.BootstrappedAtUtc.ToUniversalTime().ToString("u").
        </p>
        <div class="flex flex-wrap gap-1">
            @foreach (var moduleKey in _lastBootstrapReport.ModuleKeys)
            {
                <CitusBadge Color="@("blue")">@moduleKey</CitusBadge>
            }
        </div>
    </section>
}

@if (_isLoading)
{
    <div class="mb-4"><CitusLoadingBar /></div>
}

@if (_overview is null && _modules.Count == 0 && _entities.Count == 0 && !_isLoading)
{
    <CitusEmptyState
        Icon="IconName.World"
        Title="Platform data is not reachable yet"
        Message="The phase 1 shell is ready, but the SysAdmin API has not returned platform metadata. Start the API and bootstrap the core to populate this view."
        ActionLabel="Open modules"
        ActionHref="modules" />
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <CitusStatCard Label="Core" Value="@(_overview?.Name ?? "Unavailable")" Description="Metadata kernel for modules and entities." Icon="IconName.World" Tone="StatTone.Primary" />
        <CitusStatCard Label="Modules" Value="@(_overview?.ModulesRegistered.ToString() ?? _modules.Count.ToString())" Description="Registered platform modules." Icon="IconName.Puzzle" Tone="StatTone.Neutral" />
        <CitusStatCard Label="Entities" Value="@(_overview?.EntitiesRegistered.ToString() ?? _entities.Count.ToString())" Description="Metadata entities under control." Icon="IconName.Database" Tone="StatTone.Info" />
        <CitusStatCard Label="Health" Value="@HealthSummary" Description="Cross-service snapshot for the control plane." Icon="IconName.Activity" Tone="StatTone.Success" />
    </div>

    <section class="citus-panel mb-6">
        <header class="citus-panel__header">
            <h2 class="citus-panel__title">Resource utilization</h2>
            <span class="text-fg-subtle text-xs">
                @if (_metrics is null)
                {
                    <span>Sampling…</span>
                }
                else
                {
                    <span>Last sampled @_metrics.CapturedAt.ToLocalTime().ToString("HH:mm:ss")</span>
                }
            </span>
        </header>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mt-3">
            <CitusStatCard
                Label="CPU"
                Value="@FormatCpu(_metrics?.Cpu)"
                Description="@FormatCpuDescription(_metrics?.Cpu)"
                Icon="IconName.Activity"
                Tone="@CpuTone(_metrics?.Cpu)" />
            <CitusStatCard
                Label="Memory"
                Value="@FormatMemoryValue(_metrics?.Memory)"
                Description="@FormatMemoryDescription(_metrics?.Memory)"
                Icon="IconName.Database"
                Tone="@MemoryTone(_metrics?.Memory)" />
            <CitusStatCard
                Label="Database"
                Value="@FormatDatabaseSize(_metrics?.Database)"
                Description="@FormatDatabaseDescription(_metrics?.Database)"
                Icon="IconName.Database"
                Tone="@DatabaseTone(_metrics?.Database)" />
            <CitusStatCard
                Label="Attachments"
                Value="@FormatAttachmentSize(_metrics?.Attachments)"
                Description="@FormatAttachmentDescription(_metrics?.Attachments)"
                Icon="IconName.File"
                Tone="@AttachmentTone(_metrics?.Attachments)" />
        </div>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-7 flex flex-col gap-6">
            <section class="citus-panel">
                <header class="citus-panel__header">
                    <h2 class="citus-panel__title">Platform capabilities</h2>
                    <CitusBadge Color="@("blue")">Phase 1</CitusBadge>
                </header>

                @if (_overview?.Capabilities.Count > 0)
                {
                    <div class="flex flex-wrap gap-1">
                        @foreach (var capability in _overview.Capabilities)
                        {
                            <CitusBadge Color="@("default")">@capability</CitusBadge>
                        }
                    </div>
                }
                else
                {
                    <p class="text-fg-muted text-sm">Capability data will appear here after the platform core is reachable.</p>
                }
            </section>

            <section class="citus-panel">
                <header class="citus-panel__header">
                    <h2 class="citus-panel__title">Module snapshot</h2>
                    <a class="citus-link text-sm" href="modules">View all</a>
                </header>

                <table class="citus-data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Route</th>
                            <th class="text-right">Entities</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var module in _modules.Take(5))
                        {
                            <tr>
                                <td>@module.Name</td>
                                <td><span class="citus-inline-code">@module.RoutePrefix</span></td>
                                <td class="text-right">@module.EntityNames.Count</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        </div>

        <div class="lg:col-span-5 flex flex-col gap-6">
            <section class="citus-panel">
                <h2 class="citus-panel__title">Service status</h2>
                <ul class="flex flex-col gap-2 m-0 p-0 list-none">
                    <li class="flex items-center justify-between">
                        <span class="text-sm">SysAdmin API</span>
                        <CitusStatusBadge Status="_sysAdminHealth" />
                    </li>
                    <li class="flex items-center justify-between">
                        <span class="text-sm">Accounting API</span>
                        <CitusStatusBadge Status="_accountingHealth" />
                    </li>
                </ul>
            </section>

            <section class="citus-panel">
                <header class="citus-panel__header">
                    <h2 class="citus-panel__title">Entity coverage</h2>
                    <a class="citus-link text-sm" href="entities">Inspect entities</a>
                </header>
                <p class="text-fg-muted text-sm mb-2">
                    The first phase keeps business truth in backend engines while exposing metadata and control surfaces in Blazor.
                </p>
                <div class="text-3xl font-semibold text-fg">@_entities.Count</div>
                <p class="text-fg-muted text-sm">Entities currently visible to the platform shell.</p>
            </section>
        </div>
    </div>
}

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Phase 1",
        Title = "Platform overview",
        Subtitle = "Blazor control shell for the metadata-driven Citus core."
    };

    private bool _isLoading = true;
    private bool _isBootstrapping;
    private PlatformOverviewSummary? _overview;
    private PlatformBootstrapReportSummary? _lastBootstrapReport;
    private IReadOnlyList<PlatformModuleSummary> _modules = Array.Empty<PlatformModuleSummary>();
    private IReadOnlyList<PlatformEntitySummary> _entities = Array.Empty<PlatformEntitySummary>();
    private ServiceHealthStatus? _sysAdminHealth;
    private ServiceHealthStatus? _accountingHealth;
    private PlatformRuntimeMetricsSnapshotDto? _metrics;
    private System.Threading.Timer? _metricsTimer;
    private static readonly TimeSpan MetricsRefreshInterval = TimeSpan.FromSeconds(30);

    private string HealthSummary =>
        string.Equals(_sysAdminHealth?.Status, "ok", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(_accountingHealth?.Status, "ok", StringComparison.OrdinalIgnoreCase)
            ? "Nominal"
            : "Attention";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        // Resource utilization tiles auto-refresh every 30s — light enough
        // (one Postgres query + a /proc read) to leave running while the
        // operator stays on the page. Disposed on page teardown.
        _metricsTimer = new System.Threading.Timer(
            async _ => await RefreshMetricsAsync(),
            state: null,
            dueTime: MetricsRefreshInterval,
            period: MetricsRefreshInterval);
    }

    public async ValueTask DisposeAsync()
    {
        if (_metricsTimer is not null)
        {
            await _metricsTimer.DisposeAsync();
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        var overviewTask = PlatformCoreClient.GetOverviewAsync();
        var modulesTask = PlatformCoreClient.ListModulesAsync();
        var entitiesTask = PlatformCoreClient.ListEntitiesAsync();
        var sysAdminHealthTask = SysAdminHealthClient.GetHealthAsync();
        var accountingHealthTask = AccountingHealthClient.GetHealthAsync();
        var metricsTask = MetricsClient.GetSnapshotAsync();

        _overview = await overviewTask;
        _modules = await modulesTask;
        _entities = await entitiesTask;
        _sysAdminHealth = await sysAdminHealthTask;
        _accountingHealth = await accountingHealthTask;
        _metrics = await metricsTask;
        _isLoading = false;
    }

    private async Task RefreshMetricsAsync()
    {
        var snapshot = await MetricsClient.GetSnapshotAsync();
        if (snapshot is null) return;
        _metrics = snapshot;
        await InvokeAsync(StateHasChanged);
    }

    // Formatter helpers — every method gracefully handles null inputs so
    // tiles render "—" while the first sample is still loading.
    private static string FormatCpu(PlatformCpuMetricsDto? cpu)
    {
        if (cpu?.ProcessCpuPercent is null) return "—";
        return $"{cpu.ProcessCpuPercent.Value:F1}%";
    }

    private static string FormatCpuDescription(PlatformCpuMetricsDto? cpu)
    {
        if (cpu is null) return "Sampling process CPU…";
        var loadPart = cpu.LoadAverage1m is { } load
            ? $" · load {load:F2}"
            : string.Empty;
        return $"{cpu.LogicalProcessorCount} logical cores{loadPart}";
    }

    private static StatTone CpuTone(PlatformCpuMetricsDto? cpu)
    {
        if (cpu?.ProcessCpuPercent is null) return StatTone.Neutral;
        return cpu.ProcessCpuPercent.Value switch
        {
            > 80 => StatTone.Warning,
            > 50 => StatTone.Info,
            _ => StatTone.Success,
        };
    }

    private static string FormatMemoryValue(PlatformMemoryMetricsDto? memory)
    {
        if (memory is null) return "—";
        if (memory.HostTotalBytes is { } hostTotal && memory.HostUsedBytes is { } hostUsed && hostTotal > 0)
        {
            var percent = (double)hostUsed / hostTotal * 100;
            return $"{percent:F0}% · {FormatBytes(hostUsed)}";
        }
        return FormatBytes(memory.ProcessWorkingSetBytes);
    }

    private static string FormatMemoryDescription(PlatformMemoryMetricsDto? memory)
    {
        if (memory is null) return "Sampling memory…";
        if (memory.HostTotalBytes is { } total)
        {
            return $"Host {FormatBytes(memory.HostUsedBytes ?? 0)} / {FormatBytes(total)} · process {FormatBytes(memory.ProcessWorkingSetBytes)}";
        }
        return $"Process working set · GC heap {FormatBytes(memory.ManagedHeapBytes)}";
    }

    private static StatTone MemoryTone(PlatformMemoryMetricsDto? memory)
    {
        if (memory?.HostTotalBytes is { } total && memory.HostUsedBytes is { } used && total > 0)
        {
            var pct = (double)used / total * 100;
            return pct > 90 ? StatTone.Warning : pct > 70 ? StatTone.Info : StatTone.Success;
        }
        return StatTone.Neutral;
    }

    private static string FormatDatabaseSize(PlatformDatabaseMetricsDto? db)
    {
        if (db is null) return "—";
        if (!db.IsReachable) return "Unreachable";
        return db.SizeBytes is { } bytes ? FormatBytes(bytes) : "—";
    }

    private static string FormatDatabaseDescription(PlatformDatabaseMetricsDto? db)
    {
        if (db is null) return "Sampling database…";
        if (!db.IsReachable) return db.ErrorMessage ?? "Cannot reach Postgres.";
        var conn = db.ActiveConnections is { } c ? $"{c} active connections" : "connections —";
        return $"pg_database_size · {conn}";
    }

    private static StatTone DatabaseTone(PlatformDatabaseMetricsDto? db) =>
        db is null ? StatTone.Neutral : db.IsReachable ? StatTone.Info : StatTone.Warning;

    private static string FormatAttachmentSize(PlatformAttachmentMetricsDto? attachments)
    {
        if (attachments is null) return "—";
        if (!attachments.IsProvisioned) return "Not enabled";
        return attachments.TotalBytes is { } bytes ? FormatBytes(bytes) : "—";
    }

    private static string FormatAttachmentDescription(PlatformAttachmentMetricsDto? attachments)
    {
        if (attachments is null) return "Sampling attachments…";
        if (!attachments.IsProvisioned) return "Configure PlatformAttachments:RootPath to enable.";
        var count = attachments.FileCount is { } c ? $"{c:N0} files" : "files —";
        return $"On-disk store · {count}";
    }

    private static StatTone AttachmentTone(PlatformAttachmentMetricsDto? attachments) =>
        attachments is null ? StatTone.Neutral
        : attachments.IsProvisioned ? StatTone.Info
        : StatTone.Neutral;

    private static string FormatBytes(long bytes)
    {
        // Plain if/else chain: a `<` switch-pattern arm (e.g. `< mb =>`)
        // confuses the Razor source generator inside @code {} blocks —
        // it parses the leading `<` as an HTML tag opener and the build
        // then fails with RZ9980 / RZ1006 on Release. Same logic, no `<`
        // at the start of any line below.
        const long kb = 1024L;
        const long mb = kb * 1024L;
        const long gb = mb * 1024L;
        const long tb = gb * 1024L;
        if (bytes >= tb) return $"{bytes / (double)tb:F2} TB";
        if (bytes >= gb) return $"{bytes / (double)gb:F2} GB";
        if (bytes >= mb) return $"{bytes / (double)mb:F1} MB";
        if (bytes >= kb) return $"{bytes / (double)kb:F1} KB";
        return $"{bytes} B";
    }

    private async Task BootstrapCoreAsync()
    {
        _isBootstrapping = true;

        try
        {
            var report = await PlatformCoreClient.BootstrapAsync();

            if (report is null)
            {
                await Message.WarningAsync("Platform core bootstrap failed. Check SysAdmin API connectivity and database readiness.");
                return;
            }

            _lastBootstrapReport = report;
            await Message.SuccessAsync(
                $"Platform core bootstrapped: {report.ModulesSeeded} modules and {report.EntitiesSeeded} entities seeded.");

            await LoadAsync();
        }
        finally
        {
            _isBootstrapping = false;
        }
    }

    private string GetSetupMessage()
    {
        if (ShellState.FirstCompanySetupDeferred)
        {
            return "Platform governance is ready. Business initialization is currently deferred until you choose to create the first company.";
        }

        if (ShellState.FirstCompanySetupRequired)
        {
            return ShellState.HasAnyCompany
                ? "A company record exists, but the first business-ready owner bootstrap is not complete yet."
                : "Create the first company and first business owner before using the Business App.";
        }

        return "Platform setup is still being assessed.";
    }
}
