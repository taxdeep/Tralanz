@page "/security"

@inject AppShellState ShellState
@inject CitusToastService Message
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject SysAdminAuthenticationClient SysAdminAuthenticationClient

<PageTitle>Security | Tralanz SysAdmin</PageTitle>

<CitusPageHeader Model="_header" />

<section class="citus-panel max-w-2xl">
    <div class="mb-3">
        <h2 class="citus-panel__title">Rotate SysAdmin Secret</h2>
        <p class="text-fg-muted text-sm">
            Rotate the current platform operator secret and revoke existing SysAdmin sessions.
        </p>
    </div>

    <CitusAlert Severity="CitusAlertSeverity.Warning"
                     ShowIcon="true"
                     Message="After a successful secret rotation, the current SysAdmin session is revoked and you will sign in again with the new secret."
                     Class="mb-4" />

    <div class="flex flex-col gap-3">
        <CitusInput TValue="string" Value="@ShellState.Operator.DisplayName" Disabled="true" Placeholder="@("Operator")" />
        <CitusInput TValue="string" Value="@ShellState.Operator.Email" Disabled="true" Placeholder="@("Email")" />
        <RadzenPassword @bind-Value="_currentPassword" Placeholder="@("Current password")" />
        <RadzenPassword @bind-Value="_newPassword" Placeholder="@("New password")" />
        <RadzenPassword @bind-Value="_confirmPassword" Placeholder="@("Confirm new password")" />
        <CitusButton Variant="CitusButtonVariant.Primary" Disabled="_isSubmitting" OnClick="RotateSecretAsync">
            @(_isSubmitting ? "Rotating..." : "Rotate secret")
        </CitusButton>
    </div>
</section>

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Operations",
        Title = "Security",
        Subtitle = "Rotate the current SysAdmin secret and close existing platform sessions."
    };

    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _isSubmitting;

    private async Task RotateSecretAsync()
    {
        if (string.IsNullOrWhiteSpace(_currentPassword) || string.IsNullOrWhiteSpace(_newPassword))
        {
            await Message.WarningAsync("Current and new passwords are required.");
            return;
        }

        if (!string.Equals(_newPassword, _confirmPassword, StringComparison.Ordinal))
        {
            await Message.WarningAsync("Password confirmation does not match.");
            return;
        }

        _isSubmitting = true;

        try
        {
            var outcome = await SysAdminAuthenticationClient.RotateSecretAsync(
                ShellState.SessionToken,
                _currentPassword,
                _newPassword);

            if (!outcome.Succeeded)
            {
                await Message.WarningAsync(outcome.Message);
                return;
            }

            await JS.InvokeVoidAsync("citusSysAdminAuth.clearSessionToken");
            ShellState.ClearAuthenticatedSession();
            _currentPassword = string.Empty;
            _newPassword = string.Empty;
            _confirmPassword = string.Empty;

            await Message.SuccessAsync("SysAdmin secret rotated. Sign in again with the new secret.");
            NavigationManager.NavigateTo("login", forceLoad: true);
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
