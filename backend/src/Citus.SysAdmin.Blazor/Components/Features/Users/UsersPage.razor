@page "/users"

@inject AppShellState ShellState
@inject NavigationManager NavigationManager
@inject AntDesign.IMessageService Message
@inject SysAdminControlClient SysAdminControlClient

<PageTitle>Users | Citus SysAdmin</PageTitle>

<CitusPageHeader Model="_header" />

@if (_isLoading)
{
    <div class="mb-4"><AntDesign.Progress Type="@AntDesign.ProgressType.Line" Percent="100" Status="@AntDesign.ProgressStatus.Active" ShowInfo="false" /></div>
}

@if (_users.Count == 0 && !_isLoading)
{
    <CitusEmptyState
        Icon="IconName.Users"
        Title="No managed users"
        Message="The SysAdmin control directory has not returned any users yet."
        ActionLabel="Open companies"
        ActionHref="companies" />
}
else if (_users.Count > 0)
{
    @if (_notificationReadiness is not null && !_notificationReadiness.IsVerificationDeliveryReady)
    {
        <AntDesign.Alert Type="@AntDesign.AlertType.Warning"
                         ShowIcon="true"
                         Message="Password reset is currently blocked because notification readiness is not verified. Open Maintenance and Notification Readiness to confirm config, test status, and verification readiness."
                         Class="mb-4" />
    }

    <section class="citus-panel">
        <table class="citus-data-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Status</th>
                    <th>MFA</th>
                    <th>System Role</th>
                    <th>Platform Roles</th>
                    <th>Companies</th>
                    <th>Governance</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in _users)
                {
                    <tr>
                        <td>
                            <div>@user.DisplayName</div>
                            <div class="text-fg-subtle text-xs">@user.Username | @user.Email</div>
                        </td>
                        <td>
                            <CitusBadge Color="@(user.IsActive ? "green" : "default")">@(user.IsActive ? "Active" : "Disabled")</CitusBadge>
                        </td>
                        <td>
                            <CitusBadge Color="@(string.Equals(user.MfaMode, "none", StringComparison.OrdinalIgnoreCase) ? "default" : "blue")">@user.MfaModeLabel</CitusBadge>
                            @if (user.LastMfaResetAtUtc.HasValue)
                            {
                                <div class="text-fg-subtle text-xs mt-1">
                                    Reset @user.LastMfaResetAtUtc.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm")
                                </div>
                                @if (!string.IsNullOrWhiteSpace(user.LastMfaResetReason))
                                {
                                    <div class="text-fg-subtle text-xs">@user.LastMfaResetReason</div>
                                }
                            }
                            @if (HasOpenMfaRecoveryRequest(user.Id))
                            {
                                <div class="text-warning text-xs mt-1">Recovery request open</div>
                            }
                            <div class="text-fg-subtle text-xs">@user.EmergencyMfaResetPolicyReason</div>
                        </td>
                        <td>
                            <CitusBadge Color="@(user.IsSysAdmin ? "blue" : "default")">@(user.IsSysAdmin ? "SysAdmin" : "Business")</CitusBadge>
                        </td>
                        <td>
                            @if (user.Roles.Count == 0)
                            {
                                <span class="text-fg-subtle text-xs">None</span>
                            }
                            else
                            {
                                <span>@string.Join(", ", user.Roles)</span>
                            }
                        </td>
                        <td>
                            @if (user.CompanyCodes.Count == 0)
                            {
                                <span class="text-fg-subtle text-xs">No company memberships</span>
                            }
                            else
                            {
                                <span>@string.Join(", ", user.CompanyCodes)</span>
                            }
                        </td>
                        <td>
                            <div class="flex flex-wrap gap-1">
                                @if (user.IsSysAdmin)
                                {
                                    <CitusBadge Color="@("blue")">Protected</CitusBadge>
                                }
                                else
                                {
                                    @if (user.IsActive)
                                    {
                                        <CitusButton Size="CitusButtonSize.Small" Disabled="@IsAccountUpdating(user.Id)" OnClick="@(() => SetAccountStatusAsync(user, "inactive"))">
                                            Disable
                                        </CitusButton>
                                    }
                                    else
                                    {
                                        <CitusButton Size="CitusButtonSize.Small" Disabled="@IsAccountUpdating(user.Id)" OnClick="@(() => SetAccountStatusAsync(user, "active"))">
                                            Activate
                                        </CitusButton>
                                    }
                                    <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small" Disabled="@IsAccountUpdating(user.Id)" OnClick="@(() => RequestPasswordResetAsync(user))">
                                        Password reset
                                    </CitusButton>
                                    <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small" Disabled="@(IsAccountUpdating(user.Id) || !user.CanEmergencyMfaReset)" OnClick="@(() => ResetMfaAsync(user))">
                                        Reset MFA
                                    </CitusButton>
                                    <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small" Disabled="@IsMfaTimelineLoading(user.Id)" OnClick="@(() => LoadMfaTimelineAsync(user))">
                                        MFA history
                                    </CitusButton>
                                    <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small" OnClick="@(() => OpenAuditForAccount(user.Id))">
                                        Open audit
                                    </CitusButton>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    @if (_selectedTimelineUser is not null)
    {
        <section class="citus-panel mt-6">
            <div class="mb-3">
                <h2 class="citus-panel__title">MFA Timeline</h2>
                <p class="text-fg-muted text-sm">@_selectedTimelineUser.DisplayName (@_selectedTimelineUser.Username | @_selectedTimelineUser.Email)</p>
            </div>

            @if (_isSelectedTimelineLoading)
            {
                <AntDesign.Progress Type="@AntDesign.ProgressType.Line" Percent="100" Status="@AntDesign.ProgressStatus.Active" ShowInfo="false" />
            }
            else if (_selectedMfaTimeline.Count == 0)
            {
                <AntDesign.Alert Type="@AntDesign.AlertType.Info" Message="No MFA governance events have been recorded for this account yet." ShowIcon="true" />
            }
            else
            {
                <div class="grid grid-cols-1 gap-3">
                    @foreach (var entry in _selectedMfaTimeline)
                    {
                        <article class="citus-subpanel">
                            <div class="flex flex-wrap items-start justify-between gap-3">
                                <div class="flex flex-col gap-1">
                                    <div class="flex flex-wrap items-center gap-2">
                                        <CitusBadge Color="@GetTimelineColor(entry.Action)">@entry.ActionLabel</CitusBadge>
                                        <CitusBadge Color="@("default")">
                                            @(string.IsNullOrWhiteSpace(entry.ActorDisplayName) ? entry.ActorType : entry.ActorDisplayName)
                                        </CitusBadge>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(entry.Detail))
                                    {
                                        <span class="text-sm">@entry.Detail</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(entry.Reason))
                                    {
                                        <span class="text-fg-subtle text-xs">Reason: @entry.Reason</span>
                                    }
                                </div>
                                <div class="flex flex-col items-end gap-1">
                                    <span class="text-fg-subtle text-xs">@entry.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")</span>
                                    <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small" OnClick="@(() => OpenAuditForAccount(_selectedTimelineUser.Id))">
                                        Open in audit
                                    </CitusButton>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }

    <section class="citus-panel mt-6">
        <div class="mb-3">
            <h2 class="citus-panel__title">MFA Recovery Queue</h2>
            <p class="text-fg-muted text-sm">Recovery is a governed flow: business users request, SysAdmin reviews, then executes the approved reset.</p>
        </div>
        <AntDesign.Alert Type="@AntDesign.AlertType.Info"
                         ShowIcon="true"
                         Message="Policy: self-service can only request recovery. Review and execution remain SysAdmin-controlled, and direct emergency reset should stay out-of-band while an open recovery request already exists for the same account."
                         Class="mb-4" />

        @if (_mfaRecoveryRequests.Count == 0)
        {
            <AntDesign.Alert Type="@AntDesign.AlertType.Info" Message="No open MFA recovery requests are pending review or execution." ShowIcon="true" />
        }
        else
        {
            <table class="citus-data-table">
                <thead>
                    <tr>
                        <th>Account</th>
                        <th>Current MFA</th>
                        <th>Status</th>
                        <th>Requested</th>
                        <th>Reason</th>
                        <th>Governance</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in _mfaRecoveryRequests)
                    {
                        <tr>
                            <td>
                                <div>@request.DisplayName</div>
                                <div class="text-fg-subtle text-xs">@request.Username | @request.Email</div>
                            </td>
                            <td>
                                <CitusBadge Color="@("blue")">@request.CurrentMfaModeLabel</CitusBadge>
                            </td>
                            <td>
                                <CitusBadge Color="@GetRecoveryStatusColor(request.Status)">@GetRecoveryStatusLabel(request.Status)</CitusBadge>
                                <div class="flex flex-wrap gap-1 mt-1">
                                    <CitusBadge Color="@("blue")">Requested</CitusBadge>
                                    <CitusBadge Color="@GetRecoveryReviewStageColor(request.Status)">Review</CitusBadge>
                                    <CitusBadge Color="@GetRecoveryExecutionStageColor(request.Status)">Execute</CitusBadge>
                                </div>
                                @if (request.ReviewedAtUtc.HasValue)
                                {
                                    <div class="text-fg-subtle text-xs mt-1">Reviewed @request.ReviewedAtUtc.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</div>
                                }
                            </td>
                            <td>
                                <div>@request.RequestedAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</div>
                                @if (!string.IsNullOrWhiteSpace(request.ReviewedByDisplayName))
                                {
                                    <div class="text-fg-subtle text-xs">@request.ReviewedByDisplayName</div>
                                }
                            </td>
                            <td>
                                <div>@request.RequestReason</div>
                                @if (!string.IsNullOrWhiteSpace(request.ReviewReason))
                                {
                                    <div class="text-fg-subtle text-xs">Review: @request.ReviewReason</div>
                                }
                            </td>
                            <td>
                                <div class="flex flex-wrap gap-1">
                                    @if (string.Equals(request.Status, "requested", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <CitusButton Size="CitusButtonSize.Small" Disabled="@IsMfaRecoveryUpdating(request.RequestId)" OnClick="@(() => ReviewMfaRecoveryRequestAsync(request, "approve"))">
                                            Approve
                                        </CitusButton>
                                        <CitusButton Size="CitusButtonSize.Small" Danger="true" Disabled="@IsMfaRecoveryUpdating(request.RequestId)" OnClick="@(() => ReviewMfaRecoveryRequestAsync(request, "reject"))">
                                            Reject
                                        </CitusButton>
                                    }
                                    @if (string.Equals(request.Status, "approved", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small" Disabled="@IsMfaRecoveryUpdating(request.RequestId)" OnClick="@(() => ExecuteMfaRecoveryRequestAsync(request))">
                                            Execute reset
                                        </CitusButton>
                                    }
                                    <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small" OnClick="@(() => SelectRecoveryRequestAsync(request))">Flow</CitusButton>
                                    <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small" OnClick="@(() => OpenAuditForAccount(request.AccountId))">Audit</CitusButton>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    @if (_selectedRecoveryRequest is not null)
    {
        <section class="citus-panel mt-6">
            <div class="mb-3">
                <h2 class="citus-panel__title">Recovery Flow</h2>
                <p class="text-fg-muted text-sm">@_selectedRecoveryRequest.DisplayName (@_selectedRecoveryRequest.Username | @_selectedRecoveryRequest.Email)</p>
            </div>

            <div class="grid grid-cols-1 gap-3">
                <article class="citus-subpanel">
                    <div class="flex items-center justify-between gap-3 mb-2">
                        <CitusBadge Color="@("blue")">1. Requested</CitusBadge>
                        <span class="text-fg-subtle text-xs">@_selectedRecoveryRequest.RequestedAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                    <p class="text-sm m-0">@_selectedRecoveryRequest.RequestReason</p>
                    <p class="text-fg-subtle text-xs m-0">Current MFA mode at request time: @_selectedRecoveryRequest.CurrentMfaModeLabel</p>
                </article>

                <article class="citus-subpanel">
                    <div class="flex items-center justify-between gap-3 mb-2">
                        <CitusBadge Color="@GetRecoveryReviewStageColor(_selectedRecoveryRequest.Status)">2. Review</CitusBadge>
                        @if (_selectedRecoveryRequest.ReviewedAtUtc.HasValue)
                        {
                            <span class="text-fg-subtle text-xs">@_selectedRecoveryRequest.ReviewedAtUtc.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                        }
                    </div>
                    <p class="text-sm m-0">@GetRecoveryReviewDescription(_selectedRecoveryRequest)</p>
                    @if (!string.IsNullOrWhiteSpace(_selectedRecoveryRequest.ReviewReason))
                    {
                        <p class="text-fg-subtle text-xs m-0">Review reason: @_selectedRecoveryRequest.ReviewReason</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(_selectedRecoveryRequest.ReviewedByDisplayName))
                    {
                        <p class="text-fg-subtle text-xs m-0">Reviewed by @_selectedRecoveryRequest.ReviewedByDisplayName</p>
                    }
                </article>

                <article class="citus-subpanel">
                    <div class="flex items-center justify-between gap-3 mb-2">
                        <CitusBadge Color="@GetRecoveryExecutionStageColor(_selectedRecoveryRequest.Status)">3. Execute</CitusBadge>
                        <CitusBadge Color="@GetRecoveryStatusColor(_selectedRecoveryRequest.Status)">@GetRecoveryExecutionStatusChipLabel(_selectedRecoveryRequest.Status)</CitusBadge>
                    </div>
                    <p class="text-sm m-0">@GetRecoveryExecutionDescription(_selectedRecoveryRequest)</p>
                    <div class="flex flex-wrap gap-1 mt-2">
                        @if (string.Equals(_selectedRecoveryRequest.Status, "approved", StringComparison.OrdinalIgnoreCase))
                        {
                            <CitusButton Size="CitusButtonSize.Small" Disabled="@IsMfaRecoveryUpdating(_selectedRecoveryRequest.RequestId)" OnClick="@(() => ExecuteMfaRecoveryRequestAsync(_selectedRecoveryRequest))">
                                Execute reset
                            </CitusButton>
                        }
                        <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small" OnClick="@(() => OpenAuditForAccount(_selectedRecoveryRequest.AccountId))">
                            Open audit
                        </CitusButton>
                    </div>
                </article>
            </div>
        </section>

        <section class="citus-panel mt-4">
            <div class="mb-3">
                <h2 class="citus-panel__title">Recent Recovery History</h2>
                <p class="text-fg-muted text-sm">Formal recovery requests for this account, including rejected and executed outcomes.</p>
            </div>

            @if (_isSelectedRecoveryHistoryLoading)
            {
                <AntDesign.Progress Type="@AntDesign.ProgressType.Line" Percent="100" Status="@AntDesign.ProgressStatus.Active" ShowInfo="false" />
            }
            else if (_selectedRecoveryHistory.Count == 0)
            {
                <AntDesign.Alert Type="@AntDesign.AlertType.Info" Message="No historical recovery requests have been recorded for this account yet." ShowIcon="true" />
            }
            else
            {
                <div class="grid grid-cols-1 gap-3">
                    @foreach (var history in _selectedRecoveryHistory)
                    {
                        <article class="citus-subpanel">
                            <div class="flex items-start justify-between gap-3 mb-2">
                                <div class="flex flex-wrap items-center gap-2">
                                    <CitusBadge Color="@GetRecoveryStatusColor(history.Status)">@GetRecoveryStatusLabel(history.Status)</CitusBadge>
                                    @if (_selectedRecoveryRequest?.RequestId == history.RequestId)
                                    {
                                        <CitusBadge Color="@("geekblue")">Selected</CitusBadge>
                                    }
                                </div>
                                <span class="text-fg-subtle text-xs">Requested @history.RequestedAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                            </div>

                            <p class="text-sm m-0">@history.RequestReason</p>

                            @if (history.ReviewedAtUtc.HasValue)
                            {
                                <p class="text-fg-subtle text-xs m-0">
                                    Review: @GetRecoveryStatusLabel(history.Status) at @history.ReviewedAtUtc.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm")
                                    @if (!string.IsNullOrWhiteSpace(history.ReviewedByDisplayName))
                                    {
                                        <text> by @history.ReviewedByDisplayName</text>
                                    }
                                </p>
                            }

                            @if (!string.IsNullOrWhiteSpace(history.ReviewReason))
                            {
                                <p class="text-fg-subtle text-xs m-0">Review reason: @history.ReviewReason</p>
                            }

                            @if (history.ExecutedAtUtc.HasValue)
                            {
                                <p class="text-fg-subtle text-xs m-0">
                                    Executed at @history.ExecutedAtUtc.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm")
                                    @if (!string.IsNullOrWhiteSpace(history.ExecutedByDisplayName))
                                    {
                                        <text> by @history.ExecutedByDisplayName</text>
                                    }
                                </p>
                            }

                            @if (!string.IsNullOrWhiteSpace(history.ExecutionReason))
                            {
                                <p class="text-fg-subtle text-xs m-0">Execution reason: @history.ExecutionReason</p>
                            }

                            <div class="flex flex-wrap gap-1 mt-2">
                                <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small" OnClick="@(() => SelectRecoveryRequestAsync(history))">View flow</CitusButton>
                                <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small" OnClick="@(() => OpenAuditForAccount(history.AccountId))">Open audit</CitusButton>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }

    <section class="citus-panel mt-6">
        <div class="mb-3">
            <h2 class="citus-panel__title">Current Company Memberships</h2>
            <p class="text-fg-muted text-sm">CompanyAccess governance for the current active company context.</p>
        </div>

        @if (ShellState.ActiveCompany.IsSystemScope || !ShellState.ActiveCompany.CompanyId.HasValue)
        {
            <AntDesign.Alert Type="@AntDesign.AlertType.Info" Message="Switch to a business company from the Companies page to manage owner and user memberships." ShowIcon="true" />
        }
        else if (_memberships.Count == 0)
        {
            <AntDesign.Alert Type="@AntDesign.AlertType.Info" Message="@($"No active company memberships were returned for {ShellState.ActiveCompany.CompanyName}.")" ShowIcon="true" />
        }
        else
        {
            <table class="citus-data-table">
                <thead>
                    <tr>
                        <th>Member</th>
                        <th>Role</th>
                        <th>Permissions</th>
                        <th>Status</th>
                        <th>Updated</th>
                        <th>Governance</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var membership in _memberships)
                    {
                        <tr>
                            <td>
                                <div>@membership.DisplayName</div>
                                <div class="text-fg-subtle text-xs">@membership.Username | @membership.Email</div>
                            </td>
                            <td>
                                <CitusBadge Color="@(string.Equals(membership.Role, "owner", StringComparison.OrdinalIgnoreCase) ? "orange" : "default")">@membership.Role</CitusBadge>
                            </td>
                            <td>
                                @if (membership.PermissionTokens.Count == 0)
                                {
                                    <span class="text-fg-subtle text-xs">Inherited owner scope or no custom grants</span>
                                }
                                else
                                {
                                    <div class="flex flex-wrap gap-1">
                                        @foreach (var permission in membership.PermissionTokens)
                                        {
                                            <CitusBadge Color="@("default")">@permission</CitusBadge>
                                        }
                                    </div>
                                }
                            </td>
                            <td>
                                <CitusBadge Color="@(membership.IsActive ? "green" : "default")">@(membership.IsActive ? "Active" : "Inactive")</CitusBadge>
                            </td>
                            <td>@membership.UpdatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <div class="flex flex-wrap gap-1">
                                    @if (string.Equals(membership.Role, "owner", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <CitusButton Size="CitusButtonSize.Small" Disabled="@IsMembershipUpdating(membership.MembershipId)" OnClick="@(() => ChangeMembershipRoleAsync(membership, "user"))">
                                            Set user
                                        </CitusButton>
                                    }
                                    else
                                    {
                                        <CitusButton Size="CitusButtonSize.Small" Disabled="@IsMembershipUpdating(membership.MembershipId)" OnClick="@(() => ChangeMembershipRoleAsync(membership, "owner"))">
                                            Promote owner
                                        </CitusButton>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Operations",
        Title = "Users",
        Subtitle = "Platform accounts plus current-company membership governance for SysAdmin."
    };

    private bool _isLoading = true;
    private IReadOnlyList<ManagedUserSummary> _users = Array.Empty<ManagedUserSummary>();
    private IReadOnlyList<MfaRecoveryRequestSummary> _mfaRecoveryRequests = Array.Empty<MfaRecoveryRequestSummary>();
    private IReadOnlyList<MfaRecoveryRequestSummary> _selectedRecoveryHistory = Array.Empty<MfaRecoveryRequestSummary>();
    private IReadOnlyList<PlatformMfaTimelineEntrySummary> _selectedMfaTimeline = Array.Empty<PlatformMfaTimelineEntrySummary>();
    private IReadOnlyList<ManagedCompanyMembershipSummary> _memberships = Array.Empty<ManagedCompanyMembershipSummary>();
    private NotificationReadinessSummary? _notificationReadiness;
    private ManagedUserSummary? _selectedTimelineUser;
    private MfaRecoveryRequestSummary? _selectedRecoveryRequest;
    private bool _isSelectedTimelineLoading;
    private bool _isSelectedRecoveryHistoryLoading;
    private readonly HashSet<Guid> _accountUpdates = [];
    private readonly HashSet<Guid> _mfaRecoveryUpdates = [];
    private readonly HashSet<Guid> _membershipUpdates = [];
    private readonly HashSet<Guid> _mfaTimelineLoads = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        try
        {
            _users = await SysAdminControlClient.ListUsersAsync();
            _mfaRecoveryRequests = await SysAdminControlClient.ListOpenMfaRecoveryRequestsAsync();
            _notificationReadiness = await SysAdminControlClient.GetNotificationReadinessAsync();
            await LoadMembershipsAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadMembershipsAsync()
    {
        if (ShellState.ActiveCompany.IsSystemScope || !ShellState.ActiveCompany.CompanyId.HasValue)
        {
            _memberships = Array.Empty<ManagedCompanyMembershipSummary>();
            return;
        }

        _memberships = await SysAdminControlClient.ListCompanyMembershipsAsync(ShellState.ActiveCompany.CompanyId.Value);
    }

    private bool IsAccountUpdating(Guid accountId) => _accountUpdates.Contains(accountId);

    private bool IsMfaRecoveryUpdating(Guid requestId) => _mfaRecoveryUpdates.Contains(requestId);

    private bool IsMfaTimelineLoading(Guid accountId) => _mfaTimelineLoads.Contains(accountId);

    private bool IsMembershipUpdating(Guid membershipId) => _membershipUpdates.Contains(membershipId);

    private bool HasOpenMfaRecoveryRequest(Guid accountId) =>
        _users.FirstOrDefault(user => user.Id == accountId)?.HasActiveMfaRecoveryRequest == true ||
        _mfaRecoveryRequests.Any(request => request.AccountId == accountId);

    private void OpenAuditForAccount(Guid accountId) =>
        NavigationManager.NavigateTo($"audit?accountId={accountId}");

    private async Task SelectRecoveryRequestAsync(MfaRecoveryRequestSummary request)
    {
        _selectedRecoveryRequest = request;
        _isSelectedRecoveryHistoryLoading = true;
        _selectedRecoveryHistory = Array.Empty<MfaRecoveryRequestSummary>();

        try
        {
            _selectedRecoveryHistory = await SysAdminControlClient.ListAccountMfaRecoveryHistoryAsync(request.AccountId);
            _selectedRecoveryRequest = _selectedRecoveryHistory.FirstOrDefault(candidate => candidate.RequestId == request.RequestId) ?? request;
        }
        finally
        {
            _isSelectedRecoveryHistoryLoading = false;
        }
    }

    private async Task SetAccountStatusAsync(ManagedUserSummary user, string status)
    {
        if (user.IsSysAdmin)
        {
            await Message.InfoAsync("SysAdmin accounts are protected from business-side lifecycle changes.");
            return;
        }

        _accountUpdates.Add(user.Id);
        var reason = $"SysAdmin set platform account {user.Username} from {(user.IsActive ? "active" : "inactive")} to {status}.";

        try
        {
            var updated = await SysAdminControlClient.SetAccountStatusAsync(user.Id, status, null, reason);
            if (!updated)
            {
                await Message.WarningAsync($"Unable to set {user.Username} to {status}.");
                return;
            }

            _users = await SysAdminControlClient.ListUsersAsync();
            await Message.SuccessAsync($"{user.Username} is now {status}.");
        }
        finally
        {
            _accountUpdates.Remove(user.Id);
        }
    }

    private async Task RequestPasswordResetAsync(ManagedUserSummary user)
    {
        if (user.IsSysAdmin)
        {
            await Message.InfoAsync("SysAdmin accounts use the platform operator flow and are not reset from this surface.");
            return;
        }

        _accountUpdates.Add(user.Id);
        var reason = $"SysAdmin requested password reset delivery for {user.Username}.";

        try
        {
            var requested = await SysAdminControlClient.RequestPasswordResetAsync(user.Id, reason);
            if (!requested.Succeeded)
            {
                await Message.WarningAsync(
                    string.IsNullOrWhiteSpace(requested.Message)
                        ? $"Unable to queue password reset for {user.Username}."
                        : requested.Message);
                return;
            }

            _notificationReadiness = await SysAdminControlClient.GetNotificationReadinessAsync();
            await Message.SuccessAsync($"Password reset request recorded for {user.Username}.");
        }
        finally
        {
            _accountUpdates.Remove(user.Id);
        }
    }

    private async Task ResetMfaAsync(ManagedUserSummary user)
    {
        if (user.IsSysAdmin)
        {
            await Message.InfoAsync("SysAdmin accounts do not use the business-platform MFA reset flow.");
            return;
        }

        if (!user.CanEmergencyMfaReset)
        {
            await Message.InfoAsync(user.EmergencyMfaResetPolicyReason);
            return;
        }

        _accountUpdates.Add(user.Id);
        var reason = $"SysAdmin reset business MFA for {user.Username}.";

        try
        {
            var outcome = await SysAdminControlClient.ResetMfaAsync(user.Id, reason);
            if (!outcome.Succeeded)
            {
                await Message.WarningAsync(
                    string.IsNullOrWhiteSpace(outcome.Message)
                        ? $"Unable to reset MFA for {user.Username}."
                        : outcome.Message);
                return;
            }

            _users = await SysAdminControlClient.ListUsersAsync();
            await Message.SuccessAsync($"MFA reset applied for {user.Username}.");
        }
        finally
        {
            _accountUpdates.Remove(user.Id);
        }
    }

    private async Task ReviewMfaRecoveryRequestAsync(MfaRecoveryRequestSummary request, string decision)
    {
        _mfaRecoveryUpdates.Add(request.RequestId);
        var reason = decision switch
        {
            "approve" => $"SysAdmin approved MFA recovery for {request.Username}.",
            _ => $"SysAdmin rejected MFA recovery for {request.Username}."
        };

        try
        {
            var outcome = await SysAdminControlClient.ReviewMfaRecoveryRequestAsync(request.RequestId, decision, reason);
            if (!outcome.Succeeded)
            {
                await Message.WarningAsync(
                    string.IsNullOrWhiteSpace(outcome.Message)
                        ? $"Unable to {decision} MFA recovery for {request.Username}."
                        : outcome.Message);
                return;
            }

            _users = await SysAdminControlClient.ListUsersAsync();
            _mfaRecoveryRequests = await SysAdminControlClient.ListOpenMfaRecoveryRequestsAsync();
            _selectedRecoveryHistory = await SysAdminControlClient.ListAccountMfaRecoveryHistoryAsync(request.AccountId);
            _selectedRecoveryRequest = _selectedRecoveryHistory.FirstOrDefault(candidate => candidate.RequestId == request.RequestId);
            await Message.SuccessAsync(
                decision == "approve"
                    ? $"Approved MFA recovery for {request.Username}."
                    : $"Rejected MFA recovery for {request.Username}.");
        }
        finally
        {
            _mfaRecoveryUpdates.Remove(request.RequestId);
        }
    }

    private async Task LoadMfaTimelineAsync(ManagedUserSummary user)
    {
        _selectedTimelineUser = user;
        _selectedMfaTimeline = Array.Empty<PlatformMfaTimelineEntrySummary>();
        _mfaTimelineLoads.Add(user.Id);
        _isSelectedTimelineLoading = true;

        try
        {
            _selectedMfaTimeline = await SysAdminControlClient.ListAccountMfaTimelineAsync(user.Id);
        }
        finally
        {
            _isSelectedTimelineLoading = false;
            _mfaTimelineLoads.Remove(user.Id);
        }
    }

    private async Task ExecuteMfaRecoveryRequestAsync(MfaRecoveryRequestSummary request)
    {
        _mfaRecoveryUpdates.Add(request.RequestId);
        var reason = $"SysAdmin executed approved MFA recovery for {request.Username}.";

        try
        {
            var outcome = await SysAdminControlClient.ExecuteMfaRecoveryRequestAsync(request.RequestId, reason);
            if (!outcome.Succeeded)
            {
                await Message.WarningAsync(
                    string.IsNullOrWhiteSpace(outcome.Message)
                        ? $"Unable to execute MFA recovery for {request.Username}."
                        : outcome.Message);
                return;
            }

            _users = await SysAdminControlClient.ListUsersAsync();
            _mfaRecoveryRequests = await SysAdminControlClient.ListOpenMfaRecoveryRequestsAsync();
            _selectedRecoveryHistory = await SysAdminControlClient.ListAccountMfaRecoveryHistoryAsync(request.AccountId);
            _selectedRecoveryRequest = _selectedRecoveryHistory.FirstOrDefault(candidate => candidate.RequestId == request.RequestId);
            await Message.SuccessAsync($"Executed MFA recovery reset for {request.Username}.");
        }
        finally
        {
            _mfaRecoveryUpdates.Remove(request.RequestId);
        }
    }

    private async Task ChangeMembershipRoleAsync(ManagedCompanyMembershipSummary membership, string role)
    {
        if (ShellState.ActiveCompany.IsSystemScope || !ShellState.ActiveCompany.CompanyId.HasValue)
        {
            await Message.InfoAsync("Select a business company before changing membership roles.");
            return;
        }

        _membershipUpdates.Add(membership.MembershipId);
        var companyId = ShellState.ActiveCompany.CompanyId.Value;
        var reason = $"SysAdmin changed {membership.Username} role from {membership.Role} to {role} in {ShellState.ActiveCompany.CompanyCode}.";

        try
        {
            var changed = await SysAdminControlClient.ChangeMembershipRoleAsync(companyId, membership.MembershipId, role, reason);
            if (!changed)
            {
                await Message.WarningAsync($"Unable to change membership role for {membership.Username}.");
                return;
            }

            await LoadMembershipsAsync();
            await Message.SuccessAsync($"{membership.Username} role updated to {role}.");
        }
        finally
        {
            _membershipUpdates.Remove(membership.MembershipId);
        }
    }

