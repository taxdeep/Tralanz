@page "/companies"

@inject AppShellState ShellState
@inject CitusToastService Message
@inject SysAdminControlClient SysAdminControlClient

<PageTitle>Companies | Citus SysAdmin</PageTitle>

<CitusPageHeader Model="_header" />

@if (_isLoading)
{
    <div class="mb-4"><CitusLoadingBar /></div>
}

@if (_companies.Count == 0 && !_isLoading)
{
    <CitusEmptyState
        Icon="IconName.BuildingSkyscraper"
        Title="No managed companies"
        Message="SysAdmin control context did not return any companies. Complete the first-company provisioning flow to create the initial workspace."
        ActionLabel="Back to overview"
        ActionHref="overview" />
}
else if (_companies.Count > 0)
{
    <section class="citus-panel">
        <table class="citus-data-table">
            <thead>
                <tr>
                    <th>Company</th>
                    <th>Base Currency</th>
                    <th>Status</th>
                    <th>Multi-Currency</th>
                    <th class="text-right">Members</th>
                    <th>Context</th>
                    <th>Governance</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var company in _companies)
                {
                    <tr>
                        <td>
                            <div>@company.CompanyName</div>
                            <div class="text-fg-subtle text-xs">@company.CompanyCode</div>
                        </td>
                        <td>@company.BaseCurrencyCode</td>
                        <td>
                            <CitusBadge Color="@StatusColor(company.Status)">@company.Status</CitusBadge>
                        </td>
                        <td>@(company.MultiCurrencyEnabled ? "Enabled" : "Base only")</td>
                        <td class="text-right">@company.MemberCount</td>
                        <td>
                            @if (ShellState.ActiveCompany.CompanyId == company.Id)
                            {
                                <CitusBadge Color="@("blue")">Active</CitusBadge>
                            }
                            else
                            {
                                <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small" OnClick="@(() => SwitchCompanyAsync(company.Id))">
                                    Switch here
                                </CitusButton>
                            }
                        </td>
                        <td>
                            <div class="flex flex-wrap gap-1">
                                @if (string.Equals(company.Status, "active", StringComparison.OrdinalIgnoreCase))
                                {
                                    <CitusButton Size="CitusButtonSize.Small" Disabled="@IsStatusUpdating(company.Id)" OnClick="@(() => SetCompanyStatusAsync(company, "inactive"))">
                                        Set inactive
                                    </CitusButton>
                                    <CitusButton Size="CitusButtonSize.Small" Danger="true" Disabled="@IsStatusUpdating(company.Id)" OnClick="@(() => SetCompanyStatusAsync(company, "suspended"))">
                                        Suspend
                                    </CitusButton>
                                }
                                else
                                {
                                    <CitusButton Size="CitusButtonSize.Small" Disabled="@IsStatusUpdating(company.Id)" OnClick="@(() => SetCompanyStatusAsync(company, "active"))">
                                        Reactivate
                                    </CitusButton>
                                }

                                @if (!string.Equals(company.Status, "archived", StringComparison.OrdinalIgnoreCase))
                                {
                                    <CitusButton Variant="CitusButtonVariant.Link" Size="CitusButtonSize.Small" Danger="true" Disabled="@IsStatusUpdating(company.Id)" OnClick="@(() => SetCompanyStatusAsync(company, "archived"))">
                                        Archive
                                    </CitusButton>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Operations",
        Title = "Companies",
        Subtitle = "SysAdmin-managed company workspaces and active company control."
    };

    private bool _isLoading = true;
    private IReadOnlyList<CompanyWorkspaceSummary> _companies = Array.Empty<CompanyWorkspaceSummary>();
    private readonly HashSet<Guid> _statusUpdates = [];

    protected override async Task OnInitializedAsync()
    {
        _companies = await SysAdminControlClient.ListCompaniesAsync();
        _isLoading = false;
    }

    private async Task SwitchCompanyAsync(Guid companyId)
    {
        var context = await SysAdminControlClient.SetActiveCompanyAsync(companyId);

        if (context is null)
        {
            await Message.WarningAsync("Unable to switch the active company context.");
            return;
        }

        ShellState.ApplyControlContext(context);
        await Message.SuccessAsync($"Active company switched to {context.ActiveCompany.CompanyName}.");
    }

    private bool IsStatusUpdating(Guid companyId) => _statusUpdates.Contains(companyId);

    private async Task SetCompanyStatusAsync(CompanyWorkspaceSummary company, string status)
    {
        _statusUpdates.Add(company.Id);
        var reason = $"SysAdmin set company status from {company.Status} to {status} from the control shell.";

        try
        {
            var updated = await SysAdminControlClient.SetCompanyStatusAsync(company.Id, status, reason);
            if (!updated)
            {
                await Message.WarningAsync($"Unable to set {company.CompanyCode} to {status}.");
                return;
            }

            _companies = await SysAdminControlClient.ListCompaniesAsync();
            await Message.SuccessAsync($"{company.CompanyCode} status changed to {status}.");
        }
        finally
        {
            _statusUpdates.Remove(company.Id);
        }
    }

    private static string StatusColor(string? status) =>
        string.Equals(status, "active", StringComparison.OrdinalIgnoreCase)
            ? "green"
            : string.Equals(status, "archived", StringComparison.OrdinalIgnoreCase)
                ? "default"
                : "orange";
}
