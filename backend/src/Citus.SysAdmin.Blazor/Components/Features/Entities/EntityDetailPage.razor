@page "/entities/{EntityName}"

@inject PlatformCoreClient PlatformCoreClient

<PageTitle>Entity Detail | Tralanz SysAdmin</PageTitle>

@if (_isLoading)
{
    <div class="mb-4"><CitusLoadingBar /></div>
}

@if (_entity is null && !_isLoading)
{
    <CitusPageHeader Model="_missingHeader" />
    <CitusEmptyState
        Icon="IconName.Database"
        Title="Entity metadata not found"
        Message="The requested entity is not registered in the platform core or the SysAdmin API is unavailable."
        ActionLabel="Return to entities"
        ActionHref="entities" />
}
else if (_entity is not null)
{
    <CitusPageHeader Model="@GetHeader(_entity)">
        <Actions>
            <a class="citus-button citus-button--ghost" href="entities">
                <CitusIcon Name="IconName.ArrowLeft" Size="IconSize.Inline" />
                <span>Back to entities</span>
            </a>
        </Actions>
    </CitusPageHeader>

    <div class="flex flex-wrap items-center gap-2 mb-6">
        <CitusBadge Color="@("blue")">@_entity.ModuleKey</CitusBadge>
        <CitusBadge Color="@("geekblue")">@GetScope(_entity)</CitusBadge>
        <CitusBadge Color="@("default")">@($"{_entity.Fields.Count} fields")</CitusBadge>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-8">
            <section class="citus-panel">
                <h2 class="citus-panel__title">Definition</h2>
                <table class="citus-data-table">
                    <thead>
                        <tr>
                            <th>Field</th>
                            <th>Type</th>
                            <th>Column</th>
                            <th>Flags</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var field in _entity.Fields)
                        {
                            <tr>
                                <td>
                                    <div>@field.Label</div>
                                    <div class="text-fg-subtle text-xs">@field.Name</div>
                                </td>
                                <td>@field.FieldType</td>
                                <td><span class="citus-inline-code">@field.SourceColumn</span></td>
                                <td>
                                    <div class="flex flex-wrap gap-1">
                                        @if (field.Required)
                                        {
                                            <CitusBadge Color="@("default")">Required</CitusBadge>
                                        }
                                        @if (field.Searchable)
                                        {
                                            <CitusBadge Color="@("default")">Searchable</CitusBadge>
                                        }
                                        @if (field.Auditable)
                                        {
                                            <CitusBadge Color="@("default")">Auditable</CitusBadge>
                                        }
                                        @if (field.System)
                                        {
                                            <CitusBadge Color="@("default")">System</CitusBadge>
                                        }
                                        @if (field.MaxLength.HasValue)
                                        {
                                            <CitusBadge Color="@("default")">Max @field.MaxLength.Value</CitusBadge>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        </div>

        <div class="lg:col-span-4 flex flex-col gap-6">
            <section class="citus-panel">
                <h2 class="citus-panel__title">Storage and scope</h2>
                <table class="citus-keyvalue">
                    <tbody>
                        <tr><th>Storage table</th><td><span class="citus-inline-code">@_entity.StorageTable</span></td></tr>
                        <tr><th>Scope</th><td>@GetScope(_entity)</td></tr>
                        @if (!string.IsNullOrWhiteSpace(_entity.Description))
                        {
                            <tr><th>Description</th><td>@_entity.Description</td></tr>
                        }
                    </tbody>
                </table>
            </section>

            <section class="citus-panel">
                <h2 class="citus-panel__title">Permissions</h2>
                @foreach (var (label, principals) in BuildPermissionGroups())
                {
                    <div class="mb-3">
                        <div class="text-sm font-medium mb-1">@label</div>
                        <div class="flex flex-wrap gap-1">
                            @foreach (var principal in principals)
                            {
                                <CitusBadge Color="@("default")">@principal</CitusBadge>
                            }
                        </div>
                    </div>
                }
            </section>
        </div>
    </div>
}

@code {
    [Parameter]
    public string EntityName { get; set; } = string.Empty;

    private readonly PageHeaderModel _missingHeader = new()
    {
        Eyebrow = "Metadata",
        Title = "Entity detail",
        Subtitle = "Detailed metadata for a platform entity."
    };

    private bool _isLoading = true;
    private PlatformEntityDetail? _entity;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _entity = await PlatformCoreClient.GetEntityAsync(EntityName);
        _isLoading = false;
    }

    private static PageHeaderModel GetHeader(PlatformEntityDetail entity) =>
        new()
        {
            Eyebrow = "Metadata",
            Title = entity.Label,
            Subtitle = string.IsNullOrWhiteSpace(entity.Description)
                ? $"Entity key: {entity.Name}"
                : entity.Description
        };

    private IEnumerable<(string Label, IReadOnlyList<string> Principals)> BuildPermissionGroups()
    {
        if (_entity is null) yield break;
        yield return ("Create", GetPrincipals(_entity.Permissions.Create));
        yield return ("Read", GetPrincipals(_entity.Permissions.Read));
        yield return ("Update", GetPrincipals(_entity.Permissions.Update));
        yield return ("Delete", GetPrincipals(_entity.Permissions.Delete));
    }

    private static IReadOnlyList<string> GetPrincipals(IReadOnlyList<string> principals) =>
        principals.Count == 0 ? ["No explicit principals"] : principals;

    private static string GetScope(PlatformEntityDetail entity)
    {
        if (entity.SystemScoped)
        {
            return "System";
        }

        return entity.CompanyScoped ? "Company" : "Shared";
    }
}
