@page "/entities/{EntityName}"

@inject PlatformCoreClient PlatformCoreClient

<PageTitle>Entity Detail | Citus SysAdmin</PageTitle>

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mb-6" />
}

@if (_entity is null)
{
    <CitusPageHeader Model="_missingHeader" />
    <CitusEmptyState
        Title="Entity metadata not found"
        Message="The requested entity is not registered in the platform core or the SysAdmin API is unavailable."
        ActionLabel="Return to entities"
        ActionHref="entities" />
}
else
{
    <CitusPageHeader Model="@GetHeader(_entity)" />

    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-6">
        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">@_entity.ModuleKey</MudChip>
        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">@GetScope(_entity)</MudChip>
        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Secondary">@($"{_entity.Fields.Count} fields")</MudChip>
        <MudSpacer />
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="entities">Back to entities</MudButton>
    </MudStack>

    <MudGrid>
        <MudItem xs="12" lg="8">
            <MudPaper Class="pa-4 mb-6">
                <MudText Typo="Typo.h6" Class="mb-3">Definition</MudText>
                <MudTable Items="_entity.Fields" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>Field</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Column</MudTh>
                        <MudTh>Flags</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Field">
                            <MudText Typo="Typo.body1">@context.Label</MudText>
                            <MudText Typo="Typo.caption" Class="text-secondary">@context.Name</MudText>
                        </MudTd>
                        <MudTd DataLabel="Type">@context.FieldType</MudTd>
                        <MudTd DataLabel="Column"><span class="citus-inline-code">@context.SourceColumn</span></MudTd>
                        <MudTd DataLabel="Flags">
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                @if (context.Required)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">Required</MudChip>
                                }
                                @if (context.Searchable)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">Searchable</MudChip>
                                }
                                @if (context.Auditable)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">Auditable</MudChip>
                                }
                                @if (context.System)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">System</MudChip>
                                }
                                @if (context.MaxLength.HasValue)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">Max @context.MaxLength.Value</MudChip>
                                }
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="4">
            <MudPaper Class="pa-4 mb-6">
                <MudText Typo="Typo.h6" Class="mb-3">Storage and scope</MudText>
                <MudStack Spacing="2">
                    <MudText Typo="Typo.body2">
                        Storage table: <span class="citus-inline-code">@_entity.StorageTable</span>
                    </MudText>
                    <MudText Typo="Typo.body2">
                        Scope: @GetScope(_entity)
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(_entity.Description))
                    {
                        <MudText Typo="Typo.body2" Class="text-secondary">@_entity.Description</MudText>
                    }
                </MudStack>
            </MudPaper>

            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-3">Permissions</MudText>

                <div class="mb-4">
                    <MudText Typo="Typo.body2" Class="mb-1">Create</MudText>
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                        @foreach (var principal in GetPrincipals(_entity.Permissions.Create))
                        {
                            <MudChip T="string" Variant="Variant.Outlined">@principal</MudChip>
                        }
                    </MudStack>
                </div>

                <div class="mb-4">
                    <MudText Typo="Typo.body2" Class="mb-1">Read</MudText>
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                        @foreach (var principal in GetPrincipals(_entity.Permissions.Read))
                        {
                            <MudChip T="string" Variant="Variant.Outlined">@principal</MudChip>
                        }
                    </MudStack>
                </div>

                <div class="mb-4">
                    <MudText Typo="Typo.body2" Class="mb-1">Update</MudText>
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                        @foreach (var principal in GetPrincipals(_entity.Permissions.Update))
                        {
                            <MudChip T="string" Variant="Variant.Outlined">@principal</MudChip>
                        }
                    </MudStack>
                </div>

                <div>
                    <MudText Typo="Typo.body2" Class="mb-1">Delete</MudText>
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                        @foreach (var principal in GetPrincipals(_entity.Permissions.Delete))
                        {
                            <MudChip T="string" Variant="Variant.Outlined">@principal</MudChip>
                        }
                    </MudStack>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code
{
    [Parameter]
    public string EntityName { get; set; } = string.Empty;

    private readonly PageHeaderModel _missingHeader = new()
    {
        Eyebrow = "Metadata",
        Title = "Entity detail",
        Subtitle = "Detailed metadata for a platform entity."
    };

    private bool _isLoading = true;
    private PlatformEntityDetail? _entity;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _entity = await PlatformCoreClient.GetEntityAsync(EntityName);
        _isLoading = false;
    }

    private static PageHeaderModel GetHeader(PlatformEntityDetail entity) =>
        new()
        {
            Eyebrow = "Metadata",
            Title = entity.Label,
            Subtitle = string.IsNullOrWhiteSpace(entity.Description)
                ? $"Entity key: {entity.Name}"
                : entity.Description
        };

    private static IReadOnlyList<string> GetPrincipals(IReadOnlyList<string> principals) =>
        principals.Count == 0 ? ["No explicit principals"] : principals;

    private static string GetScope(PlatformEntityDetail entity)
    {
        if (entity.SystemScoped)
        {
            return "System";
        }

        return entity.CompanyScoped ? "Company" : "Shared";
    }
}
