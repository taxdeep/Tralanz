@page "/entities"

@inject PlatformCoreClient PlatformCoreClient

<PageTitle>Entities | Citus SysAdmin</PageTitle>

<CitusPageHeader Model="_header" />

@if (_isLoading)
{
    <div class="mb-4"><AntDesign.Progress Type="@AntDesign.ProgressType.Line" Percent="100" Status="@AntDesign.ProgressStatus.Active" ShowInfo="false" /></div>
}

@if (_entities.Count == 0 && !_isLoading)
{
    <CitusEmptyState
        Icon="IconName.Database"
        Title="No entities available"
        Message="Entity metadata will appear here after the platform core is bootstrapped."
        ActionLabel="Open overview"
        ActionHref="overview" />
}
else if (_entities.Count > 0)
{
    <section class="citus-panel">
        <table class="citus-data-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Module</th>
                    <th>Storage</th>
                    <th>Scope</th>
                    <th class="text-right">Fields</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entity in _entities)
                {
                    <tr>
                        <td>
                            <a class="citus-link" href="@GetDetailHref(entity.Name)">@entity.Label</a>
                            <div class="text-fg-subtle text-xs">@entity.Name</div>
                        </td>
                        <td><span class="citus-inline-code">@entity.ModuleKey</span></td>
                        <td><span class="citus-inline-code">@entity.StorageTable</span></td>
                        <td>@GetScope(entity)</td>
                        <td class="text-right">@entity.FieldCount</td>
                    </tr>
                }
            </tbody>
        </table>
        <p class="text-fg-subtle text-xs mt-3">
            Phase 1 exposes metadata only. Business document authoring will be added later on top of engine-safe workflows.
        </p>
    </section>
}

@code {
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Metadata",
        Title = "Entities",
        Subtitle = "Platform entities available to the control shell."
    };

    private bool _isLoading = true;
    private IReadOnlyList<PlatformEntitySummary> _entities = Array.Empty<PlatformEntitySummary>();

    protected override async Task OnInitializedAsync()
    {
        _entities = await PlatformCoreClient.ListEntitiesAsync();
        _isLoading = false;
    }

    private static string GetDetailHref(string entityName) =>
        $"entities/{Uri.EscapeDataString(entityName)}";

    private static string GetScope(PlatformEntitySummary entity)
    {
        if (entity.SystemScoped)
        {
            return "System";
        }

        return entity.CompanyScoped ? "Company" : "Shared";
    }
}
