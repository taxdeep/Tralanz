@page "/entities"

@inject PlatformCoreClient PlatformCoreClient

<PageTitle>Entities | Citus SysAdmin</PageTitle>

<CitusPageHeader Model="_header" />

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mb-6" />
}

@if (_entities.Count == 0)
{
    <CitusEmptyState
        Title="No entities available"
        Message="Entity metadata will appear here after the platform core is bootstrapped."
        ActionLabel="Open overview"
        ActionHref="overview" />
}
else
{
    <MudPaper Class="pa-4">
        <MudTable Items="_entities" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Module</MudTh>
                <MudTh>Storage</MudTh>
                <MudTh>Scope</MudTh>
                <MudTh>Fields</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">
                    <MudLink Href="@GetDetailHref(context.Name)">@context.Label</MudLink>
                    <MudText Typo="Typo.caption" Class="text-secondary">@context.Name</MudText>
                </MudTd>
                <MudTd DataLabel="Module"><span class="citus-inline-code">@context.ModuleKey</span></MudTd>
                <MudTd DataLabel="Storage"><span class="citus-inline-code">@context.StorageTable</span></MudTd>
                <MudTd DataLabel="Scope">@GetScope(context)</MudTd>
                <MudTd DataLabel="Fields">@context.FieldCount</MudTd>
            </RowTemplate>
        </MudTable>
        <MudText Typo="Typo.caption" Class="citus-table-note mt-3">
            Phase 1 exposes metadata only. Business document authoring will be added later on top of engine-safe workflows.
        </MudText>
    </MudPaper>
}

@code
{
    private readonly PageHeaderModel _header = new()
    {
        Eyebrow = "Metadata",
        Title = "Entities",
        Subtitle = "Platform entities available to the control shell."
    };

    private bool _isLoading = true;
    private IReadOnlyList<PlatformEntitySummary> _entities = Array.Empty<PlatformEntitySummary>();

    protected override async Task OnInitializedAsync()
    {
        _entities = await PlatformCoreClient.ListEntitiesAsync();
        _isLoading = false;
    }

    private static string GetDetailHref(string entityName) =>
        $"entities/{Uri.EscapeDataString(entityName)}";

    private static string GetScope(PlatformEntitySummary entity)
    {
        if (entity.SystemScoped)
        {
            return "System";
        }

        return entity.CompanyScoped ? "Company" : "Shared";
    }
}
