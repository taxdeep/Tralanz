<MudChip T="string" Color="@ResolvedColor" Variant="Variant.Filled" Size="Size.Small">
    @ResolvedText
</MudChip>

@code
{
    [Parameter]
    public ServiceHealthStatus? Status { get; set; }

    [Parameter]
    public string FallbackText { get; set; } = "Unavailable";

    private string ResolvedText =>
        string.IsNullOrWhiteSpace(Status?.Status)
            ? FallbackText
            : Status!.Status;

    private Color ResolvedColor =>
        string.Equals(Status?.Status, "ok", StringComparison.OrdinalIgnoreCase)
            ? Color.Success
            : Color.Warning;
}
