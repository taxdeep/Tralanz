@*
    CitusAsyncBoundary — single tri-state wrapper for loading / error /
    empty / content. Pages that previously hand-rolled the
    AntDesign.Progress + AntDesign.Alert + CitusEmptyState chain in
    three separate @if blocks should use this instead.

    Usage:
        <CitusAsyncBoundary IsLoading="@_isLoading"
                            ErrorMessage="@_error"
                            IsEmpty="@(_items.Count == 0)"
                            EmptyTitle="No invoices yet"
                            EmptyMessage="...">
            ... content when data present ...
        </CitusAsyncBoundary>

    Each state can be overridden via render fragments (LoadingTemplate,
    ErrorTemplate, EmptyTemplate); the defaults match the rest of the
    shell so callers usually don't need to.
*@

@if (IsLoading)
{
    @if (LoadingTemplate is not null)
    {
        @LoadingTemplate
    }
    else
    {
        <div class="citus-async-boundary__loading mb-4">
            <AntDesign.Progress Type="@AntDesign.ProgressType.Line"
                                Percent="100"
                                Status="@AntDesign.ProgressStatus.Active"
                                ShowInfo="false" />
        </div>
    }
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    @if (ErrorTemplate is not null)
    {
        @ErrorTemplate
    }
    else
    {
        <AntDesign.Alert Type="@AntDesign.AlertType.Warning"
                         ShowIcon="true"
                         Message="@ErrorMessage"
                         Class="mb-4" />
        @if (RetryAction.HasDelegate)
        {
            <CitusButton LeadingIcon="IconName.Refresh" OnClick="@RetryAction">@RetryLabel</CitusButton>
        }
    }
}
else if (IsEmpty)
{
    @if (EmptyTemplate is not null)
    {
        @EmptyTemplate
    }
    else
    {
        <CitusEmptyState Icon="@EmptyIcon"
                         Title="@EmptyTitle"
                         Message="@EmptyMessage"
                         ActionLabel="@EmptyActionLabel"
                         ActionHref="@EmptyActionHref" />
    }
}
else
{
    @ChildContent
}

@code {
    [Parameter] public bool IsLoading { get; set; }

    [Parameter] public string? ErrorMessage { get; set; }

    [Parameter] public bool IsEmpty { get; set; }

    [Parameter] public IconName EmptyIcon { get; set; } = IconName.InfoCircle;

    [Parameter] public string EmptyTitle { get; set; } = "No data";

    [Parameter] public string EmptyMessage { get; set; } = string.Empty;

    [Parameter] public string EmptyActionLabel { get; set; } = string.Empty;

    [Parameter] public string EmptyActionHref { get; set; } = string.Empty;

    [Parameter] public EventCallback RetryAction { get; set; }

    [Parameter] public string RetryLabel { get; set; } = "Retry";

    [Parameter] public RenderFragment? LoadingTemplate { get; set; }

    [Parameter] public RenderFragment? ErrorTemplate { get; set; }

    [Parameter] public RenderFragment? EmptyTemplate { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
}
