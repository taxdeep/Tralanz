@*
    CitusDocumentStatusBadge — single source of truth for the color +
    label vocabulary of business-document lifecycle status (Invoice,
    Bill, Credit Note, Purchase Order, Task, etc.).

    The audit found same-named statuses ('posted', 'partially_paid')
    rendering in different colors on different list pages because each
    page carried its own `StatusColor` switch. Operators relied on
    color as a semantic signal and got drift. This component owns the
    canonical mapping so a future status added to one entity instantly
    looks right everywhere.

    Canonical color vocabulary:
      draft / submitted (commitless)     → blue   (active, awaiting action)
      posted / paid / closed / completed → green  (committed / settled)
      partially_paid / partially_applied → blue   (in-progress settlement)
      open                                → blue   (active)
      billed                              → gold   (transitioned downstream — attention)
      reversed                            → orange (compensating entry exists — audit)
      voided / cancelled / canceled / void → default (explicit no-op)

    To override (e.g. an entity-specific status not yet in the table),
    pass Color and/or Label explicitly.
*@

<CitusBadge Color="@ResolvedColor" Class="@Class">@ResolvedLabel</CitusBadge>

@code {
    [Parameter, EditorRequired] public string Status { get; set; } = string.Empty;

    [Parameter] public string? Color { get; set; }

    [Parameter] public string? Label { get; set; }

    [Parameter] public string? Class { get; set; }

    private string ResolvedColor => Color ?? ResolveColor(Status);

    private string ResolvedLabel => Label ?? HumanizeStatus(Status);

    public static string ResolveColor(string? status) => (status ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "draft" => "blue",
        "submitted" => "blue",
        "open" => "blue",
        "partially_paid" => "blue",
        "partially_applied" => "blue",
        "posted" => "green",
        "paid" => "green",
        "closed" => "green",
        "completed" => "green",
        "billed" => "gold",
        // H6-4: PartiallyBilled is the in-progress side of the
        // Completed→Billed transition for Tasks. Blue keeps it in the
        // "in-progress settlement" family alongside partially_paid /
        // partially_applied (which also use blue). The enum's
        // ToString form is "PartiallyBilled"; the wire/JSON form is
        // "partially_billed". Accept both so callers don't need to
        // normalize before passing.
        "partially_billed" => "blue",
        "partiallybilled" => "blue",
        // Sales-order downstream lifecycle (confirmed = committed but not yet
        // invoiced; invoiced = fully billed → settled, same green as paid).
        "confirmed" => "geekblue",
        "invoiced" => "green",
        "reversed" => "orange",
        "voided" => "default",
        "cancelled" => "default",
        "canceled" => "default",
        "void" => "default",
        _ => "default",
    };

    public static string HumanizeStatus(string? status) => (status ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "draft" => "Draft",
        "submitted" => "Submitted",
        "open" => "Open",
        "posted" => "Posted",
        "partially_paid" => "Partially paid",
        "partially_applied" => "Partially applied",
        "partially_billed" => "Partially billed",
        "partiallybilled" => "Partially billed",
        "paid" => "Paid",
        "closed" => "Closed",
        "completed" => "Completed",
        "billed" => "Billed",
        "confirmed" => "Confirmed",
        "invoiced" => "Invoiced",
        "reversed" => "Reversed",
        "voided" => "Voided",
        "cancelled" => "Cancelled",
        "canceled" => "Canceled",
        "void" => "Void",
        _ => status ?? string.Empty,
    };

    // Canonical document-status -> CitusStatCard tone (single source of truth
    // for the StatCard Tone vocabulary, mirroring ResolveColor for badges).
    // NOTE: posted -> Success here is SETTLED-document semantics. AP/AR docs
    // (Bill, Invoice) and the refund receipt deliberately keep a LOCAL StatusTone
    // (posted -> Info / Warning = "awaiting payment" / "money-out caution") and
    // do NOT call this — that drift is intentional, not a bug.
    public static StatTone ResolveTone(string? status) => (status ?? string.Empty).Trim().ToLowerInvariant() switch
    {
        "draft" => StatTone.Neutral,
        "submitted" => StatTone.Info,
        "open" => StatTone.Info,
        "pending" => StatTone.Info,
        "partially_paid" => StatTone.Info,
        "partially_applied" => StatTone.Info,
        "partially_billed" => StatTone.Info,
        "partiallybilled" => StatTone.Info,
        "posted" => StatTone.Success,
        "paid" => StatTone.Success,
        "closed" => StatTone.Success,
        "completed" => StatTone.Success,
        "confirmed" => StatTone.Success,
        "invoiced" => StatTone.Success,
        "accepted" => StatTone.Success,
        "converted" => StatTone.Primary,
        "billed" => StatTone.Warning,
        "reversed" => StatTone.Warning,
        "amended" => StatTone.Warning,
        "expired" => StatTone.Warning,
        "rejected" => StatTone.Danger,
        "voided" => StatTone.Neutral,
        "cancelled" => StatTone.Neutral,
        "canceled" => StatTone.Neutral,
        "void" => StatTone.Neutral,
        _ => StatTone.Neutral,
    };
}
