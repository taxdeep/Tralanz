@*
    CitusMaintenanceBanner — yellow rail at the top of every page when
    the platform is in maintenance mode. Uses the shared CitusAlert
    contract so both shells render the same maintenance state.
*@

@using Citus.Ui.Shared.Shell

@if (State.Enabled)
{
    <CitusAlert Severity="CitusAlertSeverity.Warning"
                     ShowIcon="true"
                     Banner="true"
                     Class="citus-banner mb-4">
        <MessageTemplate>
            @State.Message
            @if (State.ScheduledUntilUtc.HasValue)
            {
                <span> Planned until @State.ScheduledUntilUtc.Value.ToUniversalTime().ToString("u").</span>
            }
        </MessageTemplate>
    </CitusAlert>
}

@code {
    [Parameter, EditorRequired]
    public MaintenanceStateSummary State { get; set; } = new();
}
