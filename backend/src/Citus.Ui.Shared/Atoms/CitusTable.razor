@*
    CitusTable — wraps AntDesign Blazor's Table with a fixed density
    contract (Compact / Default / Comfortable) and tabular numeric
    figures by default so accounting columns line up across rows.
    Pass column definitions via ChildContent (AntDesign's <Column> /
    <ActionColumn> components work directly). Empty state defaults to
    a CitusEmpty block.
*@

@typeparam TItem

<div class="citus-table citus-table--@(DensityClass) @(string.IsNullOrEmpty(Class) ? string.Empty : Class)">
    <Table TItem="TItem"
           DataSource="@Items"
           Loading="Loading"
           Bordered="Bordered"
           Size="@AntSize"
           HidePagination="HidePagination"
           PageSize="PageSize"
           Total="Total"
           PageIndex="PageIndex"
           PageIndexChanged="OnPageIndexChanged"
           Locale="@Locale"
           RowKey="@RowKey"
           OnRowClick="OnRowClickHandler">
        @ChildContent
    </Table>
    @if (Items?.Count == 0 && !Loading)
    {
        <CitusEmpty Icon="@EmptyIcon"
                    Title="@EmptyTitle"
                    Description="@EmptyDescription"
                    Action="@EmptyAction" />
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<TItem>? Items { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public Func<TItem, object>? RowKey { get; set; }

    [Parameter] public bool Loading { get; set; }

    [Parameter] public bool Bordered { get; set; }

    [Parameter] public bool HidePagination { get; set; }

    [Parameter] public int PageSize { get; set; } = 50;

    [Parameter] public int PageIndex { get; set; } = 1;

    [Parameter] public int Total { get; set; }

    [Parameter] public EventCallback<int> PageIndexChanged { get; set; }

    [Parameter] public CitusTableDensity Density { get; set; } = CitusTableDensity.Default;

    [Parameter] public IconName EmptyIcon { get; set; } = IconName.Receipt;

    [Parameter] public string? EmptyTitle { get; set; } = "暂无数据";

    [Parameter] public string? EmptyDescription { get; set; }

    [Parameter] public RenderFragment? EmptyAction { get; set; }

    [Parameter] public EventCallback<RowData<TItem>> OnRowClick { get; set; }

    [Parameter] public string? Class { get; set; }

    private TableLocale? Locale { get; set; }

    private string DensityClass => Density switch
    {
        CitusTableDensity.Compact => "compact",
        CitusTableDensity.Comfortable => "comfortable",
        _ => "default"
    };

    private TableSize AntSize => Density switch
    {
        CitusTableDensity.Compact => TableSize.Small,
        CitusTableDensity.Comfortable => TableSize.Default,
        _ => TableSize.Middle
    };

    private Task OnPageIndexChanged(int index) =>
        PageIndexChanged.HasDelegate ? PageIndexChanged.InvokeAsync(index) : Task.CompletedTask;

    private Task OnRowClickHandler(RowData<TItem> row) =>
        OnRowClick.HasDelegate ? OnRowClick.InvokeAsync(row) : Task.CompletedTask;
}
