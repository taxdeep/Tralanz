@*
    CitusSelect — typed dropdown over AntDesign's Select. Caller supplies
    the option list plus value/label selectors so this stays generic over
    domain types (account codes, currencies, vendors, …).
*@

@typeparam TValue
@typeparam TItem

<Select TItemValue="TValue"
        TItem="TItem"
        DataSource="@Items"
        Value="@Value"
        ValueChanged="HandleValueChanged"
        ItemValue="@(item => ValueSelector(item))"
        ItemLabel="@(item => LabelSelector(item))"
        Placeholder="@Placeholder"
        Disabled="Disabled"
        AllowClear="AllowClear"
        Size="@AntSize"
        Class="@CssClass">
</Select>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<TItem> Items { get; set; } = Array.Empty<TItem>();

    [Parameter, EditorRequired] public Func<TItem, TValue> ValueSelector { get; set; } = default!;

    [Parameter, EditorRequired] public Func<TItem, string> LabelSelector { get; set; } = default!;

    [Parameter] public TValue? Value { get; set; }

    [Parameter] public EventCallback<TValue?> ValueChanged { get; set; }

    [Parameter] public string? Placeholder { get; set; }

    [Parameter] public bool Disabled { get; set; }

    [Parameter] public bool AllowClear { get; set; } = true;

    [Parameter] public CitusButtonSize Size { get; set; } = CitusButtonSize.Medium;

    [Parameter] public string? Class { get; set; }

    private InputSize AntSize => Size switch
    {
        CitusButtonSize.Small => InputSize.Small,
        CitusButtonSize.Large => InputSize.Large,
        _ => InputSize.Default
    };

    private string CssClass => string.IsNullOrEmpty(Class) ? "citus-select" : $"citus-select {Class}";

    private Task HandleValueChanged(TValue? next) =>
        ValueChanged.HasDelegate ? ValueChanged.InvokeAsync(next) : Task.CompletedTask;
}
