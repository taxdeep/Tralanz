@*
    CitusInput — single-line text input. Adds a leading icon slot and
    a Clearable affordance that AntDesign supports out of the box.
*@

@typeparam TValue

<div class="citus-input @(string.IsNullOrEmpty(Class) ? string.Empty : Class)">
    <Input TValue="TValue"
           Value="@Value"
           ValueChanged="HandleValueChanged"
           Placeholder="@Placeholder"
           Disabled="Disabled"
           ReadOnly="ReadOnly"
           AllowClear="AllowClear"
           Size="@AntSize"
           MaxLength="MaxLength"
           Prefix="@PrefixSlot"
           Suffix="@Suffix" />
    @if (!string.IsNullOrEmpty(HelperText))
    {
        <p class="citus-input__helper">@HelperText</p>
    }
</div>

@code {
    [Parameter] public TValue? Value { get; set; }

    [Parameter] public EventCallback<TValue?> ValueChanged { get; set; }

    [Parameter] public string? Placeholder { get; set; }

    [Parameter] public IconName? LeadingIcon { get; set; }

    [Parameter] public RenderFragment? Suffix { get; set; }

    [Parameter] public string? HelperText { get; set; }

    [Parameter] public bool Disabled { get; set; }

    [Parameter] public bool ReadOnly { get; set; }

    [Parameter] public bool AllowClear { get; set; } = true;

    [Parameter] public int MaxLength { get; set; } = -1;

    [Parameter] public CitusButtonSize Size { get; set; } = CitusButtonSize.Medium;

    [Parameter] public string? Class { get; set; }

    private InputSize AntSize => Size switch
    {
        CitusButtonSize.Small => InputSize.Small,
        CitusButtonSize.Large => InputSize.Large,
        _ => InputSize.Default
    };

    private RenderFragment? PrefixSlot => LeadingIcon is null
        ? null
        : builder =>
        {
            builder.OpenComponent<CitusIcon>(0);
            builder.AddAttribute(1, nameof(CitusIcon.Name), LeadingIcon.Value);
            builder.AddAttribute(2, nameof(CitusIcon.Size), IconSize.Inline);
            builder.CloseComponent();
        };

    private Task HandleValueChanged(TValue? next) =>
        ValueChanged.HasDelegate ? ValueChanged.InvokeAsync(next) : Task.CompletedTask;
}
