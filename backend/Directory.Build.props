    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>preview</LangVersion>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <RootNamespace>$(MSBuildProjectName)</RootNamespace>
    <Version>0.1.0003.20</Version>
    <AssemblyVersion>0.1.0003.20</AssemblyVersion>
    <FileVersion>0.1.0003.20</FileVersion>
    <InformationalVersion>0.1.0003.20</InformationalVersion>
  </PropertyGroup>
</Project>
