generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sessions     Session[]
  companySetup CompanySetup?
  accounts     Account[]
  journalEntries JournalEntry[]
  customers      Customer[]
  invoices       Invoice[]
  taxCodes       TaxCode[]
  vendors        Vendor[]
  bills          Bill[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CompanySetup {
  id                    String   @id @default(cuid())
  legalName             String
  companyType           String
  businessNumber        String
  address               String
  baseCurrency          String   @default("CAD")
  fiscalYearEndMonth    Int
  fiscalYearEndDay      Int
  gstHstRegistered      Boolean  @default(false)
  taxRegistrationNumber String?
  taxRegime             String
  setupCompleteAt       DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id             String   @id @default(cuid())
  accountNumber  String
  accountName    String
  accountType    String
  reportCategory String
  isActive       Boolean  @default(true)
  isSystem       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payableTaxCodes    TaxCode[] @relation("TaxPayableAccount")
  recoverableTaxCodes TaxCode[] @relation("TaxRecoverableAccount")
  journalEntryLines   JournalEntryLine[]
  billLines           BillLine[]

  @@unique([userId, accountNumber])
}

model JournalEntry {
  id          String             @id @default(cuid())
  entryNumber String
  entryDate   DateTime
  memo        String?
  status      String             @default("draft")
  postedAt    DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  lines       JournalEntryLine[]

  @@unique([userId, entryNumber])
}

model JournalEntryLine {
  id             String       @id @default(cuid())
  lineNumber     Int
  details        String?
  debitAmount    Float        @default(0)
  creditAmount   Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  journalEntryId String
  accountId      String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)
}

model Customer {
  id          String    @id @default(cuid())
  displayName String
  email       String?
  phone       String?
  address     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices    Invoice[]
}

model TaxCode {
  id                     String   @id @default(cuid())
  code                   String
  name                   String
  ratePercent            Float
  appliesTo              String   @default("both")
  isRecoverableOnPurchase Boolean @default(false)
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  userId                 String
  payableAccountId       String?
  recoverableAccountId   String?
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payableAccount         Account? @relation("TaxPayableAccount", fields: [payableAccountId], references: [id], onDelete: SetNull)
  recoverableAccount     Account? @relation("TaxRecoverableAccount", fields: [recoverableAccountId], references: [id], onDelete: SetNull)
  invoiceLines           InvoiceLine[]
  billLines              BillLine[]

  @@unique([userId, code])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String
  invoiceDate   DateTime
  dueDate       DateTime
  memo          String?
  status        String        @default("draft")
  postedAt      DateTime?
  subtotal      Float         @default(0)
  taxAmount     Float         @default(0)
  totalAmount   Float         @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  userId        String
  customerId    String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lines         InvoiceLine[]

  @@unique([userId, invoiceNumber])
}

model InvoiceLine {
  id           String    @id @default(cuid())
  description  String
  quantity     Float
  unitPrice    Float
  lineAmount   Float
  taxAmount    Float     @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  invoiceId    String
  taxCodeId    String?
  invoice      Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  taxCode      TaxCode?  @relation(fields: [taxCodeId], references: [id], onDelete: SetNull)
}

model Vendor {
  id          String   @id @default(cuid())
  displayName String
  email       String?
  phone       String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bills       Bill[]
}

model Bill {
  id         String     @id @default(cuid())
  billNumber String
  billDate   DateTime
  dueDate    DateTime
  memo       String?
  status     String     @default("draft")
  postedAt   DateTime?
  subtotal   Float      @default(0)
  taxAmount  Float      @default(0)
  totalAmount Float     @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  userId     String
  vendorId   String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor     Vendor     @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  lines      BillLine[]

  @@unique([userId, billNumber])
}

model BillLine {
  id               String   @id @default(cuid())
  description      String
  amount           Float
  taxAmount        Float    @default(0)
  isTaxRecoverable Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  billId           String
  expenseAccountId String
  taxCodeId        String?
  bill             Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  expenseAccount   Account  @relation(fields: [expenseAccountId], references: [id], onDelete: Restrict)
  taxCode          TaxCode? @relation(fields: [taxCodeId], references: [id], onDelete: SetNull)
}
